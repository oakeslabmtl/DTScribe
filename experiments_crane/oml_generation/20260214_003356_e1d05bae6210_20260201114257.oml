// Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures hoist swinging motion"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Measures wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// Physical Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Controls horizontal movement of the crane cart"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Controls vertical movement of the hoist"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Picks up and releases containers (pucks)"
]

// Data Transmitted Instances
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// Time-Series Data Instances
instance SwingAngleTimeSeriesData : DTDFVocab:Data [
    base:desc "Time-series data of swing angle measurements"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

instance WindSpeedTimeSeriesData : DTDFVocab:Data [
    base:desc "Time-series data of wind speed measurements"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]

// CAD and Kinematic Models
instance CADModelFusion360 : DTDFVocab:Model [
    base:desc "3D CAD model of gantry crane system created in Autodesk Fusion360"
    DTDFVocab:inputTo PythonGantrylib
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Mathematical model for trajectory generation and motion planning"
    DTDFVocab:inputTo PythonGantrylib
]

instance CraneDynamicsSimulationModel : DTDFVocab:Model [
    base:desc "Simulation of crane dynamics for virtual testing"
    DTDFVocab:inputTo PythonGantrylib
]

// Enablers
instance DockerContainerization : DTDFVocab:Enabler [
    base:desc "Containerization platform for hosting all digital twin services in a single architecture"
    DTDFVocab:enables TrajectoryGenerationService, SimulationService, ValidationService, DataVisualizationService, LoggingService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "Time-series database for storing historical data and sensor readings"
    DTDFVocab:enables LoggingService, ValidationService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Visualization tool for real-time data monitoring via dashboards"
    DTDFVocab:enables DataVisualizationService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for communication between digital twin services"
    DTDFVocab:enables LoggingService, SimulationService, ValidationService
]

instance PythonGantrylib : DTDFVocab:Enabler [
    base:desc "Python module for crane control and data handling"
    DTDFVocab:enables TrajectoryGenerationService, SimulationService, ValidationService, LoggingService
]

instance ArduinoSensorInterface : DTDFVocab:Enabler [
    base:desc "Arduino microcontroller for interfacing physical sensors"
    DTDFVocab:enables LoggingService
]

instance TMC4671EvalController : DTDFVocab:Enabler [
    base:desc "Motor controller for precise stepper motor movement"
    DTDFVocab:enables TrajectoryGenerationService
]

instance Fusion360 : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion360 for CAD modeling"
    DTDFVocab:enables TrajectoryGenerationService
]

// Services
instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal trajectories using kinematic models for crane movement"
    DTDFVocab:provides TrajectoryOptimizationInsight, GenerateTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates crane dynamics in real-time for validation"
    DTDFVocab:provides SimulationValidationInsight
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Compares real-time measurements with simulation results for continuous validation"
    DTDFVocab:provides ValidationBreachesNotification, ManualAdjustmentAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Visualizes crane data via Grafana dashboard for operator monitoring"
    DTDFVocab:provides DashboardVisualizationInsight
]

instance LoggingService : DTDFVocab:Service [
    base:desc "Logs sensor data and control commands to TimescaleDB for historical analysis"
    DTDFVocab:provides HistoricalDataLoggingAction
]

// Insights
instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimal movement paths for improved crane efficiency"
]

instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Real-time comparison between simulation and actual crane behavior"
]

instance ValidationBreachesNotification : DTDFVocab:Insight [
    base:desc "Alerts for discrepancies between real-time measurements and simulation"
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of crane status and sensor data"
]

// Actions
instance GenerateTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatic generation of optimal movement paths for crane"
    DTDFVocab:IsAutomatic true
]

instance ManualAdjustmentAction : DTDFVocab:Action [
    base:desc "Operator-driven adjustment of crane parameters based on validation breaches"
    DTDFVocab:IsAutomatic false
]

instance HistoricalDataLoggingAction : DTDFVocab:Action [
    base:desc "Logs sensor data to TimescaleDB for historical analysis"
    DTDFVocab:IsAutomatic true
]

// System Environment
instance GantryCraneSystem : DTDFVocab:Environment [
    base:desc "Lab-scale gantry crane system for container movement simulation inspired by port of Antwerp"
]

instance GantryCraneSystemUnderStudy : DTDFVocab:SystemUnderStudy [
    DTDFVocab:hasEnvironment GantryCraneSystem
]

instance GantryCraneDigitalTwin : DTDFVocab:DigitalTwin [
    base:contains SwingAngleEncoder, Anemometer, CartStepperMotor, HoistStepperMotor, Electromagnet, CADModelFusion360, KinematicModel, CraneDynamicsSimulationModel, DockerContainerization, TimescaleDB, GrafanaDashboard, MQTTBroker, PythonGantrylib, ArduinoSensorInterface, TMC4671EvalController, Fusion360, TrajectoryGenerationService, SimulationService, ValidationService, DataVisualizationService, LoggingService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands for crane movement (cart and hoist) generated by Trajectory Generator Service and Control Application transmitted via Python Crane Interface to TMC4671-Eval motor controllers."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real-time synchronization with no specified time intervals; validation and logging occur continuously."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized constellation with physical crane components, Python-based control and logging applications, containerized database (TimescaleDB), dashboard (Grafana), and services (trajectory generation, simulation, validation) interconnected via MQTT broker; all deployed on a single personal computer."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers as-operated phase for continuous validation and control; CAD models represent the designed phase, but the primary use is during operation for monitoring and optimization."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous validation using distance metrics between real-time measurements and simulations; threshold-based validation to detect discrepancies; model validation techniques applied to ensure accuracy of simulation against physical system behavior."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol (Eclipse Mosquitto) for inter-service communication; direct database writes to TimescaleDB for logging; no specific hardware communication protocols detailed beyond Arduino control."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All services deployed on a single personal computer; containerized using Docker (TimescaleDB, MQTT, Grafana); Python gantrylib module installed via pip for control and logging applications."
]