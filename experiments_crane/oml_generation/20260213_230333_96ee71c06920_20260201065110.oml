// =========================
// Acting Components
// =========================
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor driven through TMC4671‑Eval controller"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor driven through TMC4671‑Eval controller"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist used to pick up loads"
]

// =========================
// Sensing Components & Data Flow
// =========================
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring swing angle of the crane, read by Arduino"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurements"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed, read by Arduino"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed measurements"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance MotorPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Motor controller feedback providing position, accessed via Python crane interface"
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionSensor
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Time‑stamped motor position feedback"
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance MotorSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Motor controller feedback providing speed, accessed via Python crane interface"
    DTDFVocab:producedData MotorSpeedDataTransmitted
]

instance MotorSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSpeedSensor
]

instance MotorSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped motor speed feedback"
    DTDFVocab:fromData MotorSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// =========================
// Enablers
// =========================
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB stores time‑series data from sensors"
    DTDFVocab:enables DataLoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard visualizing time‑series data from TimescaleDB"
    DTDFVocab:enables VisualizationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Mosquitto MQTT broker for inter‑service messaging"
    DTDFVocab:enables MessagingService
]

instance CADModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler providing CAD models to the digital twin"
    DTDFVocab:enables CADModelService
]

instance TrajectoryGeneratorEngine : DTDFVocab:Enabler [
    base:desc "Engine that computes optimal swing‑free trajectories from the kinematic model"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Engine that emulates crane dynamics for validation"
    DTDFVocab:enables SimulationService
]

instance ValidationEngine : DTDFVocab:Enabler [
    base:desc "Engine that compares measured and simulated trajectories and raises alerts"
    DTDFVocab:enables ContinuousValidationService
]

// =========================
// Services
// =========================
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that writes time‑stamped sensor records into TimescaleDB"
    DTDFVocab:provides FaultDetectionSignal
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides Grafana dashboards for operator monitoring"
    DTDFVocab:provides InsightDashboardAvailable
]

instance MessagingService : DTDFVocab:Service [
    base:desc "Publishes status messages over MQTT for other services"
    DTDFVocab:provides ActionPublishStatusMessage
]

instance CADModelService : DTDFVocab:Service [
    base:desc "Provides CAD models of the crane to users"
    DTDFVocab:provides CADModelAvailable
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free trajectories for the crane"
    DTDFVocab:provides OptimalSwingFreeTrajectory
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates crane dynamics and provides simulated trajectory data"
    DTDFVocab:provides SimulatedTrajectoryDataInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates measured trajectories against simulation and raises alerts"
    DTDFVocab:provides ValidationAlert
]

// =========================
// Models
// =========================
instance Fusion360CADModel : DTDFVocab:Model [
    base:desc "3‑D CAD assembly of the gantry crane created in Autodesk Fusion 360"
    DTDFVocab:inputTo CADModelEnabler
]

instance KinematicCraneModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator for swing‑free trajectory computation"
    DTDFVocab:inputTo TrajectoryGeneratorEngine
]

instance DynamicCraneModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the crane and its controllers used by the Simulation Service"
    DTDFVocab:inputTo SimulationEngine
]

// =========================
// Insights & Actions
// =========================
instance FaultDetectionSignal : DTDFVocab:Insight [
    base:desc "Fault detection signals derived from time‑series classification"
]

instance InsightDashboardAvailable : DTDFVocab:Insight [
    base:desc "Dashboard visualizing sensor and simulation data for operators"
]

instance CADModelAvailable : DTDFVocab:Insight [
    base:desc "Availability of up‑to‑date CAD model for engineering tasks"
]

instance OptimalSwingFreeTrajectory : DTDFVocab:Insight [
    base:desc "Optimal swing‑free trajectory computed for moving loads"
]

instance SimulatedTrajectoryDataInsight : DTDFVocab:Insight [
    base:desc "Simulated trajectory data produced by the Simulation Service"
]

instance ValidationAlert : DTDFVocab:Insight [
    base:desc "Alert raised when validation metrics exceed predefined thresholds"
]

instance ActionPublishStatusMessage : DTDFVocab:Action [
    base:desc "Publishes status updates to MQTT topics"
    DTDFVocab:IsAutomatic true
]

instance CommandCartMotor : DTDFVocab:Action [
    base:desc "Command to move cart stepper motor to target position"
    DTDFVocab:IsAutomatic false
]

instance CommandHoistMotor : DTDFVocab:Action [
    base:desc "Command to raise or lower hoist stepper motor"
    DTDFVocab:IsAutomatic false
]

instance ActivateElectromagnet : DTDFVocab:Action [
    base:desc "Activate electromagnet to grip load"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application and the Trajectory Generator Service send motion set‑points and electromagnet activation commands to the Physical Crane Interface, which transmits them to the motor controllers to drive the cart, hoist and electromagnet; operator commands from the Human Machine Interface follow the same path."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A hybrid architecture where the physical crane is connected to a PC running four Python applications (Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface); these interact with six Docker‑container services (Database, Dashboard, MQTT broker, Trajectory Generator, Simulation, Continuous Validation) via MQTT and SQL, forming the complete digital twin constellation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the design stage (CAD models of the crane), the manufacturing/assembly stage (hardware components listed), and the operation stage where runtime data are logged, simulated and validated."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously computes distance metrics between executed trajectories (from sensor data) and simulated trajectories, compares them against a predefined threshold, and notifies operators via the Grafana dashboard; simulation confidence bounds are visualised alongside measured data to assess model fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication uses MQTT (Eclipse Mosquitto) for event signalling; data persistence uses SQL over TimescaleDB; the Physical Crane Interface communicates with motor controllers likely via serial/USB (Python library); all Docker containers share a virtual network defined by Docker Compose."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software runs on a single personal computer; Docker containers (Database, MQTT broker, Dashboard) are launched with a Docker‑compose file; the Python modules are installed via pip; the source code, Docker files, CAD models and documentation are hosted publicly on a GitHub repository (Cosys‑Lab)."
]