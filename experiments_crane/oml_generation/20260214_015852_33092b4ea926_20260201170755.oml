// C3: Physical Sensing Components
instance CarbonDioxideSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry Pi-equipped CO₂ sensor for real-time indoor air quality monitoring"
    DTDFVocab:producedData CarbonDioxideDataTransmitted
]

instance ParticulateMatterSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry Pi-equipped particulate matter sensor for real-time indoor air quality monitoring"
    DTDFVocab:producedData ParticulateMatterDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry Pi-equipped humidity sensor for real-time environmental monitoring"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry Pi-equipped temperature sensor for real-time environmental monitoring"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance CraneHorizontalPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder for tracking horizontal crane movement along gantry beam"
    DTDFVocab:producedData HorizontalPositionDataTransmitted
]

instance CraneVerticalPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Hoist position sensor for tracking vertical container movement"
    DTDFVocab:producedData VerticalPositionDataTransmitted
]

instance CraneMotionSensor : DTDFVocab:SensingComponent [
    base:desc "Motion sensor for tracking crane kinematic state and container positioning"
    DTDFVocab:producedData MotionStateDataTransmitted
]

instance PhysicalSystemTelemetry : DTDFVocab:SensingComponent [
    base:desc "Generic telemetry interface for GreenhouseDT physical system climate and crop health monitoring"
    DTDFVocab:producedData GreenhouseTelemetryDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance CarbonDioxideDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CarbonDioxideSensor
]

instance ParticulateMatterDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ParticulateMatterSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HorizontalPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneHorizontalPositionEncoder
]

instance VerticalPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVerticalPositionSensor
]

instance MotionStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneMotionSensor
]

instance GreenhouseTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemTelemetry
]

// C2: Acting Components
instance HorizontalMovementMotor : DTDFVocab:ActingComponent [
    base:desc "Motor controlling cart's horizontal movement along gantry beam with closed-loop control"
]

instance VerticalMovementMotor : DTDFVocab:ActingComponent [
    base:desc "Motor managing hoisting mechanism for vertical container movement with closed-loop control"
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet enabling container pickup/release via magnetic adhesion synchronized with kinematic model"
]

// C10: Models/Data
instance AirQualitySimulationModel : DTDFVocab:Model [
    base:desc "AutomationML-based digital twin model for indoor air quality simulation and prediction"
    DTDFVocab:inputTo AirQualityEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Geometric and behavioral model representing crane kinematics and container movement logic"
    DTDFVocab:inputTo CraneControlEnabler
]

instance GreenhouseBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral adaptation model for physical greenhouse and its digital twin counterpart"
    DTDFVocab:inputTo GreenhouseEnabler
]

instance AirQualityData : DTDFVocab:Data [
    base:desc "Real-time and historical air quality measurements including CO₂, particulate matter, humidity, and temperature"
    DTDFVocab:fromData CarbonDioxideDataTransmitted, ParticulateMatterDataTransmitted, HumidityDataTransmitted, TemperatureDataTransmitted
    DTDFVocab:inputTo AirQualityEnabler
]

instance CraneStateData : DTDFVocab:Data [
    base:desc "Real-time operational data including crane state, puck positions, and trajectory execution metrics"
    DTDFVocab:fromData HorizontalPositionDataTransmitted, VerticalPositionDataTransmitted, MotionStateDataTransmitted
    DTDFVocab:inputTo CraneControlEnabler
]

instance GreenhouseTelemetryData : DTDFVocab:Data [
    base:desc "Time-series climate and crop health data from physical greenhouse system"
    DTDFVocab:fromData GreenhouseTelemetryDataTransmitted
    DTDFVocab:inputTo GreenhouseEnabler
]

// C11: Enablers
instance AirQualityEnabler : DTDFVocab:Enabler [
    base:desc "Microsoft Azure-based computational pipeline for air quality analytics and decision support"
    DTDFVocab:enables AirQualityMonitoringService, AirQualityVisualizationService
]

instance CraneControlEnabler : DTDFVocab:Enabler [
    base:desc "Python-based gantrylib module for kinematic modeling, control logic, and real-time trajectory optimization"
    DTDFVocab:enables CraneTrajectoryOptimizationService, ContinuousValidationService
]

instance GreenhouseEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB-based time-series storage and ActiveMQ message brokerage for greenhouse data exchange"
    DTDFVocab:enables GreenhouseBehavioralAdaptationService
]

instance TimescaleDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB for high-frequency time-series data storage of crane operational metrics"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for lightweight, low-latency data streaming between physical crane and digital twin"
    DTDFVocab:enables DataStreamingService
]

instance DockerContainerizationEnabler : DTDFVocab:Enabler [
    base:desc "Docker containerization for modular deployment of digital twin services"
    DTDFVocab:enables DeploymentService
]

// C6: Services
instance AirQualityMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of indoor air quality parameters with prediction capabilities"
    DTDFVocab:provides AirQualityInsight
]

instance AirQualityVisualizationService : DTDFVocab:Service [
    base:desc "Runtime visualization of air quality simulation results and historical trends"
    DTDFVocab:provides AirQualityDashboardAction
]

instance CraneTrajectoryOptimizationService : DTDFVocab:Service [
    base:desc "Real-time trajectory optimization and closed-loop control for gantry crane movements"
    DTDFVocab:provides OptimizedTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Automated validation comparing digital twin predictions with physical system behavior"
    DTDFVocab:provides ValidationResultInsight, FaultDetectionAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Continuous recording of operational data for post-analysis and performance benchmarking"
    DTDFVocab:provides HistoricalDataInsight
]

instance GreenhouseBehavioralAdaptationService : DTDFVocab:Service [
    base:desc "Dynamic adjustment of both physical greenhouse and digital twin based on real-time conditions"
    DTDFVocab:provides AdaptationInsight
]

instance DataStreamingService : DTDFVocab:Service [
    base:desc "MQTT-based asynchronous communication between physical crane and digital twin components"
    DTDFVocab:provides DataStreamingInsight
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Modular deployment of digital twin services using Docker containers"
    DTDFVocab:provides DeploymentInsight
]

// C17: Insights/Actions
instance AirQualityInsight : DTDFVocab:Insight [
    base:desc "Real-time air quality metrics and predictive analytics for virus spread prevention strategies"
]

instance AirQualityDashboardAction : DTDFVocab:Action [
    base:desc "Interactive visualization of air quality simulation results"
    DTDFVocab:IsAutomatic false
]

instance OptimizedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimized movement paths for container relocation with precision positioning"
]

instance ValidationResultInsight : DTDFVocab:Insight [
    base:desc "Continuous validation results comparing digital twin predictions with physical execution"
]

instance FaultDetectionAction : DTDFVocab:Action [
    base:desc "Automated detection of discrepancies between digital twin and physical system"
    DTDFVocab:IsAutomatic true
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Stored operational data for performance benchmarking and anomaly detection"
]

instance AdaptationInsight : DTDFVocab:Insight [
    base:desc "Dynamic behavioral adjustments for both physical greenhouse and digital twin"
]

instance DataStreamingInsight : DTDFVocab:Insight [
    base:desc "Real-time data synchronization between physical crane and digital twin components"
]

instance DeploymentInsight : DTDFVocab:Insight [
    base:desc "Modular deployment status and service availability metrics"
]

// C1: Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Controlled lab environment with defined constraints for gantry crane operations"
    base:contains GantryCranePhysicalSystem, CraneControlSystem, DigitalTwinSystem
]

instance GantryCranePhysicalSystem : DTDFVocab:Component [
    base:desc "Lab-scale gantry crane with mechanical components and actuators for X/Y/vertical movements"
]

instance CraneControlSystem : DTDFVocab:Component [
    base:desc "Dedicated hardware/software system interfacing with crane actuators for closed-loop control"
]

instance DigitalTwinSystem : DTDFVocab:Component [
    base:desc "Digital twin implementation for gantry crane with kinematic modeling and real-time synchronization"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the **Trajectory Generator Service**, which leverages a kinematics model to produce optimal movement trajectories for the crane, ensuring no residual swinging motion at termination. These trajectories are forwarded to the **Control Application**, a Python module that interfaces with the **Physical Crane Interface** to execute commands on the hardware. The **Human Machine Interface (HMI)** allows operators to configure and override crane operations. No explicit validation or authentication mechanisms are documented for command execution, though the **Continuous Validation Service** indirectly ensures trajectory fidelity by comparing simulated and executed paths. Feedback loops exist via the **Logging Application**, which records crane state post-execution, but no real-time confirmation or conflict resolution protocols are specified. Command formats and message structures are not detailed beyond their role in trajectory generation and control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin systems in the documents adopt a **lightweight, ad-hoc orchestration approach** without relying on commercial digital twin frameworks. The **GreenhouseDT** exemplar uses **InfluxDB (time-series database) + ActiveMQ (message broker) + virtual machines** for behavioral adaptation, indicating a **loosely coupled, service-oriented constellation** with **modular components** (e.g., data storage, messaging, and virtualized runtime). The **Air Quality Management** exemplar employs **AutomationML for digital twin modeling** and **Microsoft Azure tools** (e.g., cloud-based pipelines) for runtime visualization, simulation, and prediction, suggesting a **hybrid orchestration** combining edge (Raspberry Pi) and cloud resources. The **gantry crane system** (logistics domain) is described using the **C4 Model for architecture visualization**, implying a **component-based design** with **containerization/virtualization** for dissemination, but lacks explicit details on system-wide coordination. Integration patterns are **ad-hoc**, with no standardized framework for cross-twin or enterprise-level orchestration."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The **GreenhouseDT** exemplar emphasizes **self-adaptive behavioral models** for both the physical greenhouse and its digital twin, implying dynamic validation through **real-time feedback loops** and **prerecorded data** for baseline comparisons. The **Air Quality Management** exemplar focuses on **model-driven engineering** for digital twin fidelity, with explicit applications in **runtime visualization, simulation, and prediction**, suggesting validation via **Azure-based analytics** and **AutomationML model consistency checks**. Uncertainty sources are not quantified, but the ad-hoc approach implies reliance on **sensor accuracy** (e.g., Raspberry Pi sensor calibration) and **model calibration techniques** for error mitigation. The **gantry crane system** (though not detailed) likely requires **geometric and kinematic model validation** to ensure fidelity in container movement simulations. Quality assurance processes are inferred to include **data-driven adaptation** (e.g., InfluxDB/ActiveMQ for telemetry integrity) and **domain-specific model tuning** (e.g., air quality thresholds for virus spread prevention). No explicit error detection/correction mechanisms are described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin's technical network infrastructure relies on a **single-machine deployment** (a personal computer) where the physical crane is plugged in. Communication between services is mediated by an **MQTT Broker**, enabling lightweight, publish-subscribe messaging with low latency. The **TimescaleDB database** stores all system-generated data, including trajectory logs and validation metrics. No explicit network topology (e.g., decentralized microservices) is described; instead, the system bundles Python containers (e.g., **Trajectory Generator Service**, **Simulation Service**) into a single module (**gantrylib**), suggesting a tightly coupled architecture. Bandwidth and latency requirements are not quantified, but the use of MQTT implies efficiency for event-driven signaling. Security protocols are not mentioned, nor are redundancy mechanisms for fault tolerance."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin system is hosted **on-premise** on a personal computer, where the **Physical Crane** is directly connected and all software components (Physical Crane Interface, Control Application, Logging Application, HMI, Database, MQTT Broker, Dashboard, Trajectory Generator, Simulation, and Continuous Validation Services) are executed locally. The **Database (TimescaleDB)**, **MQTT Broker**, and **Dashboard (Grafana)** are containerized, while application logic (e.g., Python-based services) relies on the `gantrylib` module. No cloud or edge deployment is mentioned, and scalability mechanisms are not documented. Availability/reliability assurances are implied by the Continuous Validation Service’s real-time monitoring but lack explicit redundancy or high-availability configurations."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin systems demonstrate **limited horizontal integration** with external systems, relying on **domain-specific or lightweight interoperability standards**. The **GreenhouseDT** exemplar integrates with **InfluxDB (time-series data storage)** and **ActiveMQ (message broker)**, but no external system dependencies (e.g., ERP, IoT platforms) are mentioned. The **Air Quality Management** exemplar uses **AutomationML** for digital twin modeling, which is a **standardized engineering data format** for interoperability, and **Microsoft Azure tools** for cloud-based pipelines, implying integration with **Azure services (e.g., IoT Hub, Logic Apps)**. However, no explicit protocols (e.g., OPC UA, MQTT) or enterprise system dependencies (e.g., SAP, MES) are detailed. The **gantry crane system** lacks explicit horizontal integration descriptions, though its **C4 Model-based architecture** suggests potential for **modular integration** with logistics or cyber-physical systems (e.g., warehouse management systems). Dependencies on external Digital Twins or enterprise systems are **not specified** in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to AutomationML for model-driven engineering, specifically in the Air Quality Management exemplar. The GreenhouseDT exemplar uses InfluxDB and ActiveMQ, which are open-source technologies without explicit standardization mandates. The Air Quality Management exemplar leverages Microsoft Azure tools for implementation, though no specific cloud or interoperability standards (e.g., ISO 23247) are explicitly mentioned. The system prioritizes interoperability through ad-hoc approaches and open-source dissemination, but lacks formal certification or compliance frameworks as described in the provided documents."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system for the lab-scale gantry crane incorporates a **Continuous Validation Service** that actively monitors and compares the trajectories of the physical crane (e.g., puck movements) with the digital twin’s predicted trajectories. This service implements **real-time safety validation** by enforcing predefined thresholds for deviations. If the threshold is breached (e.g., a puck deviates from its expected path), the system triggers **automated alerts** to notify operators, ensuring immediate corrective action. The architecture leverages **cyber-physical system (CPS) safety protocols** to mitigate risks associated with misalignment between the physical and digital representations, though no explicit mention of formal cybersecurity frameworks (e.g., ISO 27001, IEC 62443) or access control mechanisms (e.g., role-based authentication) is provided in the documents."
]