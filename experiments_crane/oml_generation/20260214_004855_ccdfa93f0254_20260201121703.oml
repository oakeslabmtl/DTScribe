// Acting Components
instance CartStepperMotorController : DTDFVocab:ActingComponent [
    base:desc "Cross‑layer motor controller TMC4671‑Eval driving stepper motor for cart movement via crane interface"
]
instance HoistStepperMotorController : DTDFVocab:ActingComponent [
    base:desc "Cross‑layer motor controller TMC4671‑Eval driving stepper motor for hoist movement via crane interface"
]
instance CraneElectromagnetController : DTDFVocab:ActingComponent [
    base:desc "Electromagnet controller for picking and dropping containers via crane interface"
]

// Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder measuring the hoist’s swing motion"
    DTDFVocab:producedData SwingAngleData
]
instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer capturing wind speed affecting crane dynamics"
    DTDFVocab:producedData WindSpeedData
]
instance ArduinoController : DTDFVocab:SensingComponent [
    base:desc "Arduino controller reading sensor signals and publishing actuator status telemetry via MQTT"
    DTDFVocab:producedData CartPositionData, CartSpeedData, ElectromagnetStatusData, MotorCurrentData
]

// Data transmitted
instance SwingAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance WindSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]
instance CartPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoController
]
instance CartSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoController
]
instance ElectromagnetStatusData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoController
]
instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoController
]

// Time‑series data stored in TimescaleDB
instance SwingAngleTimeseries : DTDFVocab:Data [
    base:desc "Swing angle measurement stored every update cycle in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData SwingAngleData
]
instance WindSpeedTimeseries : DTDFVocab:Data [
    base:desc "Wind speed measurement stored every update cycle in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData WindSpeedData
]
instance CartPositionTimeseries : DTDFVocab:Data [
    base:desc "Cart position measurement stored every update cycle in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData CartPositionData
]
instance CartSpeedTimeseries : DTDFVocab:Data [
    base:desc "Cart speed measurement stored every update cycle in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData CartSpeedData
]
instance ElectromagnetStatusTimeseries : DTDFVocab:Data [
    base:desc "Electromagnet status stored every update cycle in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData ElectromagnetStatusData
]
instance MotorCurrentTimeseries : DTDFVocab:Data [
    base:desc "Motor current measurement stored every update cycle in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData MotorCurrentData
]

// Enablers
instance GantrylibEnabler : DTDFVocab:Enabler [
    base:desc "Python library gantrylib for crane control and trajectory computations"
    DTDFVocab:enables TrajectoryGenerationService, TrajectorySimulationService, ContinuousValidationService, OperatorInteractionService
]
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB for time-series storage of state data"
    DTDFVocab:enables DataLoggingService
]
instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana for real‑time monitoring dashboards"
    DTDFVocab:enables RealTimeMonitoringService
]
instance MosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for publishing sensor data and telemetry"
    DTDFVocab:enables MQTTDataIngestService
]

// Models
instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the crane used by trajectory generator and simulation services"
    DTDFVocab:inputTo GantrylibEnabler
]
instance CADModel360 : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane in Autodesk Fusion 360 for simulation reference"
    DTDFVocab:inputTo GantrylibEnabler
]

// Auxiliary Service for ingesting MQTT messages into TimescaleDB
instance MQTTDataIngestService : DTDFVocab:Service [
    base:desc "Service that ingests MQTT messages from Mosquitto broker and forwards to TimescaleDB"
    DTDFVocab:provides LoggingStatusInsight
]

// Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs and persists state data into TimescaleDB"
    DTDFVocab:provides LoggingStatusInsight
]
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring via Grafana dashboards"
    DTDFVocab:provides TrajectoryAdherenceInsight, SwingDynamicsInsight, EnvironmentalConditionInsight
]
instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal trajectories using the crane’s kinematic model"
    DTDFVocab:provides TrajectoryAdherenceInsight
]
instance TrajectorySimulationService : DTDFVocab:Service [
    base:desc "Simulates trajectories for validation and testing"
    DTDFVocab:provides SwingDynamicsInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed and simulated motion for continuous validation"
    DTDFVocab:provides ValidationInsight
]
instance ThresholdNotificationService : DTDFVocab:Service [
    base:desc "Notifies operators of threshold breaches"
    DTDFVocab:provides NotifyThresholdBreachingAction
]
instance OperatorInteractionService : DTDFVocab:Service [
    base:desc "Human‑machine interface for operator interaction"
    DTDFVocab:provides AdjustTrajectoryAction
]

// Insights
instance TrajectoryAdherenceInsight : DTDFVocab:Insight [
    base:desc "Dashboard visualization of trajectory adherence derived from kinematic and execution data"
]
instance SwingDynamicsInsight : DTDFVocab:Insight [
    base:desc "Visualization of swing dynamics influenced by wind speed and cart motion"
]
instance EnvironmentalConditionInsight : DTDFVocab:Insight [
    base:desc "Display of environmental conditions such as wind speed affecting crane performance"
]
instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Comparison result between executed motion and simulated motion"
]
instance LoggingStatusInsight : DTDFVocab:Insight [
    base:desc "Status of data logging and persistence into TimescaleDB"
]

// Actions
instance AdjustTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatic or manual adjustment of trajectory parameters based on validation feedback"
    DTDFVocab:IsAutomatic true
]
instance NotifyThresholdBreachingAction : DTDFVocab:Action [
    base:desc "Automatic notification to operators when operational thresholds are breached"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Generated trajectory commands from the Trajectory Generator Service are transmitted via the Control Application to the physical crane’s motor controllers; the continuous validation service may trigger alerts sent to the operator through the Grafana dashboard."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in real‑time: sensor telemetry is logged continuously (seconds or faster), trajectories are generated and dispatched on demand, and continuous validation runs concurrently with execution to detect deviations immediately."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation consists of containerised services: Database, MQTT broker, Dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service, and a Python Control Application; all components communicate over a Docker networking overlay, with the physical crane interfaced via the gantrylib Python module and Arduino firmware."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin is built during design (CAD and kinematic modeling), manufactured (physical crane built from BOM), and operated (real‑time monitoring and control); it also supports research evolution such as fault detection and future harbor extensions."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service constantly compares measured trajectory data with simulated motion, computing distance metrics and checking against a predefined threshold; deviations trigger operator alerts, ensuring model fidelity; the kinematic model is validated against real measurements during continuous validation runs."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical to virtual data are sent over MQTT (Eclipse Mosquitto) using TCP/IP; virtual to physical commands travel via the gantrylib Python interface over serial/USB to the Arduino controller; the database and dashboard communicate over PostgreSQL (TimescaleDB) within the Docker network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All grouped services are containerised and orchestrated via Docker Compose on a personal computer; the gantrylib Python library runs natively on the host OS; the database, MQTT broker, and Grafana dashboards are run inside Docker containers; the entire stack is deployed with a single compose command."
]