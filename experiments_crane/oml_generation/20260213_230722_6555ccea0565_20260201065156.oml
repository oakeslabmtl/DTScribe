import DTDFVocab

// ------------------------------------------------------------
// Physical sensing components
// ------------------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the crane swing angle, read by the Arduino board",
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting crane stability",
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Arduino-derived status feedback from cart and hoist stepper motors",
    DTDFVocab:producedData MotorStatusDataTransmitted
]

// ------------------------------------------------------------
// Physical acting components
// ------------------------------------------------------------
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the crane cart, controlled via TMC4671-Eval"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist, controlled via TMC4671-Eval"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist used to grip loads"
]

// ------------------------------------------------------------
// Data transmitted from sensors
// ------------------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

// ------------------------------------------------------------
// Data (time-series)
// ------------------------------------------------------------
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Continuous time-series of swing-angle measurements",
    DTDFVocab:fromData SwingAngleDataTransmitted,
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Continuous time-series of wind-speed measurements",
    DTDFVocab:fromData WindSpeedDataTransmitted,
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance MotorStatusTimeSeries : DTDFVocab:Data [
    base:desc "Continuous time-series of motor speed, torque and error flags",
    DTDFVocab:fromData MotorStatusDataTransmitted,
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance LoggedMeasurementsData : DTDFVocab:Data [
    base:desc "Aggregated logged measurements stored in TimescaleDB",
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance GeneratedTrajectoryData : DTDFVocab:Data [
    base:desc "Planned trajectory (position, velocity) generated by the Trajectory Generator",
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance ValidationMetricsData : DTDFVocab:Data [
    base:desc "Metrics comparing measured vs. simulated trajectories, with thresholds",
    DTDFVocab:inputTo ValidationEngineEnabler
]

// ------------------------------------------------------------
// Models
// ------------------------------------------------------------
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "Full CAD geometry of the gantry crane (Fusion 360 files)",
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator to compute joint positions",
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Physics-based dynamic simulation model used by the Simulation Service",
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance ValidationModel : DTDFVocab:Model [
    base:desc "Mathematical model executed by the Continuous Validation Service for trajectory comparison",
    DTDFVocab:inputTo ValidationEngineEnabler
]

// ------------------------------------------------------------
// Enablers (software / infrastructure)
// ------------------------------------------------------------
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) storing time-series data",
    DTDFVocab:enables ContinuousLoggingService, ContinuousValidationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard visualising data from TimescaleDB",
    DTDFVocab:enables VisualizationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker publishing sensor events",
    DTDFVocab:enables ContinuousLoggingService, VisualizationService, TrajectoryGenerationService, SimulationService, ContinuousValidationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module generating optimal crane trajectories",
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python-based physics engine executing dynamic simulation",
    DTDFVocab:enables SimulationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python validation engine comparing measured and simulated trajectories",
    DTDFVocab:enables ContinuousValidationService
]

// ------------------------------------------------------------
// Services
// ------------------------------------------------------------
instance ContinuousLoggingService : DTDFVocab:Service [
    base:desc "Continuous data logging from Arduino to TimescaleDB via MQTT",
    DTDFVocab:provides InsightLoggingInfo
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualising trajectories, confidence bounds and alerts",
    DTDFVocab:provides TrajectoryPlotInsight, ConfidenceBoundsInsight, AlertInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Optimal trajectory generation using the kinematic model",
    DTDFVocab:provides GeneratedTrajectoryData, TrajectoryPlotInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Physics-based simulation of crane dynamics using the dynamic model",
    DTDFVocab:provides ValidationMetricsData
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation of measured vs. simulated trajectories with alerting",
    DTDFVocab:provides AlertInsight, PauseCraneAction, ReplanTrajectoryAction, AdjustControllerParametersAction
]

// ------------------------------------------------------------
// Insights
// ------------------------------------------------------------
instance TrajectoryPlotInsight : DTDFVocab:Insight [
    base:desc "Visualization of planned vs. actual crane trajectory on the dashboard"
]

instance ConfidenceBoundsInsight : DTDFVocab:Insight [
    base:desc "Confidence bounds around the trajectory generated from validation metrics"
]

instance AlertInsight : DTDFVocab:Insight [
    base:desc "Automatic alert when validation thresholds are exceeded"
]

instance InsightLoggingInfo : DTDFVocab:Insight [
    base:desc "Information that logging has successfully stored new sensor samples"
]

// ------------------------------------------------------------
// Actions
// ------------------------------------------------------------
instance PauseCraneAction : DTDFVocab:Action [
    base:desc "Automatically pause crane motion when an alert is raised",
    DTDFVocab:IsAutomatic true
]

instance ReplanTrajectoryAction : DTDFVocab:Action [
    base:desc "Trigger a new trajectory generation after a validation failure",
    DTDFVocab:IsAutomatic false
]

instance AdjustControllerParametersAction : DTDFVocab:Action [
    base:desc "Operator adjusts stepper motor controller parameters based on validation feedback",
    DTDFVocab:IsAutomatic false
]

// ------------------------------------------------------------
// Environment (logical twin containers)
// ------------------------------------------------------------
instance TimescaleDBContainer : DTDFVocab:Environment [
    base:contains TimescaleDBEnabler
]

instance GrafanaContainer : DTDFVocab:Environment [
    base:contains GrafanaEnabler
]

instance MQTTBrokerContainer : DTDFVocab:Environment [
    base:contains MQTTBrokerEnabler
]

instance TrajectoryGeneratorContainer : DTDFVocab:Environment [
    base:contains TrajectoryGeneratorEnabler
]

instance SimulationContainer : DTDFVocab:Environment [
    base:contains SimulationEngineEnabler
]

instance ValidationContainer : DTDFVocab:Environment [
    base:contains ValidationEngineEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Control Application, Trajectory Generator Service, or the Human‑Machine Interface are transmitted through the Physical Crane Interface to the motor controllers and electromagnet, effecting movements, homing, zeroing and container pick‑up."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture consists of the physical crane connected to a PC via the Arduino interface; on the PC run Docker‑containerized services (DB, MQTT, Dashboard) and Python applications (Control, Logging, HMI) that communicate through MQTT and direct API calls, forming an integrated digital twin orchestrated by Docker‑Compose."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the design stage (CAD models of the crane in Autodesk Fusion 360), the manufacturing stage (physical crane built from the bill‑of‑materials), and the operational stage (real‑time sensor data, simulated models and validation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares executed trajectories with simulated ones, computes distance metrics, checks against a predefined threshold and raises alerts on the dashboard when the fidelity drops below the acceptable level."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses a Python interface over a serial/USB link to the Arduino, and inter‑service messaging uses MQTT (Eclipse Mosquitto) over TCP/IP; the database is accessed via standard PostgreSQL/TimescaleDB SQL connections."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components run on a single personal computer; Docker containers host the database, MQTT broker and Grafana dashboard, while the Python modules run as processes; Docker‑Compose automates startup and network configuration."
]