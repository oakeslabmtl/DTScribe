// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing–angle encoder measuring pendulum swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartMotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Current/position sensor in the cart motor driver (TMC4671 Eval) monitored via Arduino"
    DTDFVocab:producedData CartMotorEncoderDataTransmitted
]

instance HoistMotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Current/position sensor in the hoist motor driver (TMC4671 Eval) monitored via Arduino"
    DTDFVocab:producedData HoistMotorEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CartMotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoderSensor
]

instance HoistMotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoderSensor
]

// C10: Models/Data
instance SwingAngleTelemetry : DTDFVocab:Data [
    base:desc "Real‑time telemetry of swing angle"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo MosquittoMQTTBroker, TimescaleDB
]

instance WindSpeedTelemetry : DTDFVocab:Data [
    base:desc "Real‑time telemetry of wind speed"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo MosquittoMQTTBroker, TimescaleDB
]

instance CartPositionTelemetry : DTDFVocab:Data [
    base:desc "Real‑time telemetry of cart position"
    DTDFVocab:fromData CartMotorEncoderDataTransmitted
    DTDFVocab:inputTo MosquittoMQTTBroker, TimescaleDB
]

instance HoistPositionTelemetry : DTDFVocab:Data [
    base:desc "Real‑time telemetry of hoist position"
    DTDFVocab:fromData HoistMotorEncoderDataTransmitted
    DTDFVocab:inputTo MosquittoMQTTBroker, TimescaleDB
]

instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane prototype"
    DTDFVocab:inputTo PythonGantryLib
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the trajectory generator"
    DTDFVocab:inputTo PythonGantryLib
]

instance MotorDynamicsSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of motor dynamics"
    DTDFVocab:inputTo PythonGantryLib
]

// C11: Enablers
instance MosquittoMQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for streaming sensor data"
    DTDFVocab:enables LoggingService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB for time‑series data storage and analysis"
    DTDFVocab:enables LoggingService, ValidationService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboards for real‑time data visualization"
    DTDFVocab:enables VisualizationService
]

instance PythonGantryLib : DTDFVocab:Enabler [
    base:desc "Python gantrylib module for kinematic calculations and simulation"
    DTDFVocab:enables TrajectoryGenerationService, SimulationService, ValidationService, FaultDetectionService
]

instance DockerCompose : DTDFVocab:Enabler [
    base:desc "Docker Compose configuration for containerized service deployment"
    DTDFVocab:enables LoggingService, VisualizationService, TrajectoryGenerationService, SimulationService, ValidationService, FaultDetectionService
]

instance CapellaArcadiaModel : DTDFVocab:Enabler [
    base:desc "Capella/Arcadia models for system design and twin development"
    DTDFVocab:enables LoggingService, VisualizationService, TrajectoryGenerationService, SimulationService, ValidationService, FaultDetectionService
]

// C6: Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Continuous data logging to TimescaleDB via MQTT broker, supplied by the Logging Application"
    DTDFVocab:provides TelemetryDataLoggingInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Real‑time data visualization via Grafana dashboards"
    DTDFVocab:provides RealTimeDashboardInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Optimal trajectory generation using the kinematic model of the gantry crane"
    DTDFVocab:provides OptimalTrajectoryPlanInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service that reproduces trajectory execution using the motor dynamics model"
    DTDFVocab:provides SimulatedTrajectoryInsight
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Continuous validation comparing measured and simulated trajectories; triggers alerts when thresholds are exceeded"
    DTDFVocab:provides ValidationInsight, SendAlertAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection classification built on top of validation data"
    DTDFVocab:provides FaultDetectionInsight, UpdateControlParametersAction
]

// C17: Insights
instance TelemetryDataLoggingInsight : DTDFVocab:Insight [
    base:desc "Insight representing continuous data logging activity"
]

instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time trajectory and confidence bounds displayed on Grafana dashboards"
]

instance OptimalTrajectoryPlanInsight : DTDFVocab:Insight [
    base:desc "Optimized trajectory plan generated by the kinematic model"
]

instance SimulatedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Simulated trajectory execution replicated by the motor dynamics model"
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Continuous validation comparing measured and simulated trajectories"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Fault detection classification derived from validation data"
]

// C17: Actions
instance SendAlertAction : DTDFVocab:Action [
    base:desc "Automatic alert notification when validation thresholds are exceeded"
    DTDFVocab:IsAutomatic true
]

instance UpdateControlParametersAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of control parameters based on fault detection"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance ControlApplicationActingComponent : DTDFVocab:ActingComponent [
    base:desc "Generates velocity and position commands for cart, hoist, and electromagnet"
]

instance TrajectoryGeneratorActingComponent : DTDFVocab:ActingComponent [
    base:desc "Trajectory generator computing optimal motion paths for the gantry crane"
]

instance ElectromagnetActingComponent : DTDFVocab:ActingComponent [
    base:desc "Electromagnet controlling pickup of container proxies"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands from the Control Application and Trajectory‑Generator Service are published to the Physical‑Crane Interface via MQTT and executed by the motor drivers to move the cart and hoist, while validation alerts are transmitted back to the Human‑Machine Interface on Grafana."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Five physical containers (Physical Crane, Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface) and six digital twin containers (Database TimescaleDB, MQTT Broker, Grafana Dashboard, Trajectory Generator Service, Simulation Service, Continuous Validation Service) orchestrated via Docker Compose and communicating over MQTT; the Physical‑Crane Interface bridges the physical and digital worlds."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Designed stage (CAD models in Autodesk Fusion360 and kinematic model), Manufactured stage (physical hardware including motors, encoders, Arduino, PSU), and Operated stage (real‑time operation, continuous monitoring and validation during active use)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation is performed by continuously comparing executed trajectories (sensor data) with simulated trajectories using distance metrics; thresholds define acceptable deviation; simulation uses a physics‑based kinematic model; continuous validation provides runtime verification; uncertainties arise from sensor noise and modeling approximations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Local network connection utilizing MQTT protocol via Eclipse Mosquitto broker; sensor data and control commands are published to topics with QoS 1; all components run on a single personal computer within a Docker network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital twin services are containerized and deployed on a personal computer using Docker Compose; TimescaleDB, Mosquitto, and Grafana run as Docker containers, with the gantrylib Python module installed via pip; the Physical‑Crane Interface runs as a Python process on the host."
]