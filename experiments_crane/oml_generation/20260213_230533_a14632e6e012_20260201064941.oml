// =============================
// Acting Components (Physical)
// =============================

instance StepperMotorCartMove : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart movement, controlled by a Trinamic TMC4671‑Eval motor controller"
]

instance StepperMotorHoistMove : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist movement, controlled by a Trinamic TMC4671‑Eval motor controller"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted at the end of the hoist used to pick up metal loads"
]

instance ArduinoDriverBoard : DTDFVocab:ActingComponent [
    base:desc "Arduino‑based driver board that issues commands to the two stepper motors and the electromagnet and reads sensor signals"
]

// =============================
// Sensing Components (Physical)
// =============================

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring swing angle of the hoist to capture crane sway",
    DTDFVocab:producedData = SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed near the crane",
    DTDFVocab:producedData = WindSpeedDataTransmitted
]

// =============================
// Data Transmission (Physical‑to‑Virtual)
// =============================

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom = SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom = AnemometerSensor
]

// =============================
// Data Objects (Stored / Consumed)
// =============================

instance SwingAngleTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements stored in TimescaleDB",
    DTDFVocab:fromData = SwingAngleDataTransmitted,
    DTDFVocab:inputTo = TimescaleDB
]

instance WindSpeedTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements stored in TimescaleDB",
    DTDFVocab:fromData = WindSpeedDataTransmitted,
    DTDFVocab:inputTo = TimescaleDB
]

// =============================
// Models (Virtual)
// =============================

instance CraneCADModel : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane created in Fusion360",
    DTDFVocab:inputTo = PythonGantryLib
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generation Service to compute motion plans",
    DTDFVocab:inputTo = PythonGantryLib
]

instance CranePhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model used by the Simulation Service to predict crane behaviour",
    DTDFVocab:inputTo = PythonGantryLib
]

// =============================
// Enablers (Software / Infrastructure)
// =============================

instance MosquittoMQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker container used for publish/subscribe of sensor data",
    DTDFVocab:enables = DataLoggingService, RealTimeVisualizationService, TrajectoryGenerationService, PhysicsSimulationService, ContinuousValidationService, HumanMachineInterfaceService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL) container storing time‑series sensor and state data",
    DTDFVocab:enables = DataLoggingService, ContinuousValidationService, TrajectoryGenerationService, PhysicsSimulationService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana container providing real‑time visualisation dashboards and HMI",
    DTDFVocab:enables = RealTimeVisualizationService, HumanMachineInterfaceService
]

instance PythonGantryLib : DTDFVocab:Enabler [
    base:desc "Python gantrylib module (Docker‑based) that implements kinematics, simulation, validation and trajectory algorithms",
    DTDFVocab:enables = TrajectoryGenerationService, PhysicsSimulationService, ContinuousValidationService
]

instance DockerComposeOrchestrator : DTDFVocab:Enabler [
    base:desc "Docker‑compose orchestration that deploys all twin containers (Database, MQTT broker, Dashboard, etc.)",
    DTDFVocab:enables = DataLoggingService, RealTimeVisualizationService, TrajectoryGenerationService, PhysicsSimulationService, ContinuousValidationService, HumanMachineInterfaceService
]

// =============================
// Services (Digital Twin Functionality)
// =============================

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuously logs incoming sensor data into TimescaleDB",
    DTDFVocab:provides = DataLoggingInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides live visualisation of crane state and sensor streams via Grafana dashboards",
    DTDFVocab:provides = VisualizationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal motion trajectories that minimise swing using the kinematic model",
    DTDFVocab:provides = OptimalTrajectoryInsight
]

instance PhysicsSimulationService : DTDFVocab:Service [
    base:desc "Runs physics‑based simulations of the crane and its controllers",
    DTDFVocab:provides = SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares measured data with simulation predictions and raises alerts on deviation",
    DTDFVocab:provides = DeviationAlertInsight, TriggerAlertAction
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "HMI allowing operators to adjust control parameters based on dashboard visualisation",
    DTDFVocab:provides = AdjustParametersAction
]

// =============================
// Insights & Actions
// =============================

instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data have been successfully persisted in TimescaleDB"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Current visual representation of crane status shown on Grafana dashboards"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Suggested motion plan that reduces swing and meets operator constraints"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Predicted crane behaviour from physics simulation for a given control input"
]

instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating significant deviation between measured state and simulated prediction"
]

instance TriggerAlertAction : DTDFVocab:Action [
    base:desc "Automatic trigger of safety protocol when deviation exceeds predefined threshold",
    DTDFVocab:IsAutomatic = true
]

instance AdjustParametersAction : DTDFVocab:Action [
    base:desc "Operator‑initiated adjustment of trajectory or control parameters via the HMI",
    DTDFVocab:IsAutomatic = false
]

// =============================
// Environment (Container Constellation)
// =============================

instance GantryCraneTwinEnvironment : DTDFVocab:Environment [
    base:contains MosquittoMQTTBroker, TimescaleDB, GrafanaDashboard, PythonGantryLib, DockerComposeOrchestrator
]

// =============================
// Physical System Under Study
// =============================

instance LabScaleGantryCrane : DTDFVocab:SystemUnderStudy [
    base:desc "Lab‑scale gantry crane (physical system) equipped with two stepper motors, electromagnet, swing‑angle encoder and anemometer"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application consumes trajectories or commands from the Trajectory Generator Service (and optionally from the Simulation Service) and sends motion set‑points to the Physical Crane Interface, which forwards them to the motor controllers and electromagnet via the Arduino."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical crane ↔ Python interface ↔ MQTT broker ↔ services (Trajectory Generator, Simulation, Continuous Validation) ↔ TimescaleDB ↔ Grafana dashboard ↔ Human‑Machine Interface; all components run on a single PC and communicate via MQTT and SQL over localhost."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service repeatedly compares executed trajectories (measured via sensors) with simulated trajectories, computes distance metrics, and triggers operator alerts when the metric exceeds a predefined threshold, providing runtime model fidelity checks."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT services uses MQTT (Eclipse Mosquitto) for signaling and command messages; state data is transferred to the digital side via the Python interface and stored in TimescaleDB accessed through standard PostgreSQL SQL over TCP/IP."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital‑twin services (database, MQTT broker, dashboard) are containerized with Docker; deployment is performed on a personal computer using a docker‑compose file that starts and connects the containers automatically."
]