// Sensing components for environmental monitoring
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor installed on greenhouse roof to measure ambient temperature"
    DTDFVocab:producedData TemperatureMQTTMessage
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor located inside greenhouse walls measuring relative humidity"
    DTDFVocab:producedData HumidityMQTTMessage
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor positioned in greenhouse interior to monitor atmospheric CO₂ concentration"
    DTDFVocab:producedData CO2MQTTMessage
]

instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor mounted on greenhouse roof to assess photosynthetically active radiation"
    DTDFVocab:producedData LightMQTTMessage
]

// Data transmitted via MQTT to ActiveMQ broker
instance TemperatureMQTTMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
    base:desc "MQTT message carrying temperature reading, forwarded by ActiveMQ broker"
]

instance HumidityMQTTMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
    base:desc "MQTT message carrying humidity reading, forwarded by ActiveMQ broker"
]

instance CO2MQTTMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
    base:desc "MQTT message carrying CO₂ reading, forwarded by ActiveMQ broker"
]

instance LightMQTTMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
    base:desc "MQTT message carrying light level reading, forwarded by ActiveMQ broker"
]

// Persisted data stored in InfluxDB
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature time-series data from greenhouse roof sensor persisted in InfluxDB"
    DTDFVocab:inputTo InfluxDBEnabler
    DTDFVocab:fromData TemperatureMQTTMessage
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity time-series data from greenhouse interior sensor persisted in InfluxDB"
    DTDFVocab:inputTo InfluxDBEnabler
    DTDFVocab:fromData HumidityMQTTMessage
]

instance CO2Data : DTDFVocab:Data [
    base:desc "CO₂ time-series data from greenhouse interior sensor persisted in InfluxDB"
    DTDFVocab:inputTo InfluxDBEnabler
    DTDFVocab:fromData CO2MQTTMessage
]

instance LightData : DTDFVocab:Data [
    base:desc "Light level time-series data from greenhouse roof sensor persisted in InfluxDB"
    DTDFVocab:inputTo InfluxDBEnabler
    DTDFVocab:fromData LightMQTTMessage
]

// Historical greenhouse data seeded into the database during VM image preloading
instance HistoricalGreenhouseData : DTDFVocab:Data [
    base:desc "Historical greenhouse sensor data preloaded into InfluxDB via virtual machine image"
    DTDFVocab:inputTo DataSeederEnabler
    DTDFVocab:fromData HistoricalDataMQTTMessage
]

instance HistoricalDataSource : DTDFVocab:SensingComponent [
    base:desc "Virtual data source representing preloaded historical greenhouse data in the VM image"
    DTDFVocab:producedData HistoricalDataMQTTMessage
]

instance HistoricalDataMQTTMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HistoricalDataSource
    base:desc "Historical data message originating from virtual machine image, forwarded to InfluxDB"
]

// Physical acting components of the gantry crane system
instance VerticalRailActingComponent : DTDFVocab:ActingComponent [
    base:desc "Vertical rail providing vertical travel for the crane carriage within the lab-scale gantry"
]

instance HorizontalCarriageActingComponent : DTDFVocab:ActingComponent [
    base:desc "Horizontal carriage traveling along the vertical rail to position the crane arm"
]

instance CraneArmActingComponent : DTDFVocab:ActingComponent [
    base:desc "Crane arm that extends and retracts to lift and position payloads"
]

instance CraneControllerActingComponent : DTDFVocab:ActingComponent [
    base:desc "Controller providing command signals for position, velocity, load, and actuator management"
]

// Environment containing all crane components
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains VerticalRailActingComponent, HorizontalCarriageActingComponent, CraneArmActingComponent, CraneControllerActingComponent
]

// Behavioral and structural models
instance GreenhouseAutomationML : DTDFVocab:Model [
    base:desc "AutomationML structural model of greenhouse equipment, processes, and interconnections"
    DTDFVocab:inputTo AutomationMLEnabler
]

instance GreenhouseBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral simulation of greenhouse plant environment, synchronised with the physical twin via AutomationML"
    DTDFVocab:inputTo SimulationEnabler, AutomationMLEnabler
]

// Enablers for data exchange, simulation, and historical data seeding
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "ActiveMQ broker enabling MQTT message forwarding from sensors"
]

instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time-series database for storing environmental sensor data"
]

instance AutomationMLEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for mapping AutomationML structural model to behavioral simulation"
]

instance DataSeederEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for seeding historic greenhouse data into InfluxDB during VM image preloading"
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for executing behavioral simulation of greenhouse dynamics"
]

// Enablers for specific services
instance CraneControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for executing crane optimal control logic"
    DTDFVocab:enables OptimalControlService
]

instance TelemetryLoggingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for logging telemetry into InfluxDB"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for rendering real-time visualization dashboards"
    DTDFVocab:enables DataVisualizationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for performing continuous validation of live sensor data"
    DTDFVocab:enables ContinuousValidationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for fault detection logic on validated data"
    DTDFVocab:enables FaultDetectionService
]

// Services provided by the digital twin
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Generates feed-forward trajectories to accelerate the physical crane toward desired positions"
    DTDFVocab:provides OptimalControlAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Records telemetry such as speed, acceleration, payload load, and actuator positions into a persistent time-series database for later analysis"
    DTDFVocab:provides DataLoggingInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Presents real-time kinematic states and archived metrics through graphical dashboards"
    DTDFVocab:provides DataVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares live sensor data against the kinematic model to detect deviations and faults in near real-time"
    DTDFVocab:provides ValidationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Applies diagnostic logic to the validated observations to identify and flag abnormal behavior"
    DTDFVocab:provides FaultDetectionInsight
]

// Insights derived by the services
instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Event indicating new telemetry entries have been persisted in the database"
]

instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Dashboard update indicating real-time visualization of kinematic states"
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "State validation successful live sensor data matches kinematic model within acceptable tolerance"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Fault detected in the crane kinematic state"
]

// Actions initiated by services
instance OptimalControlAction : DTDFVocab:Action [
    base:desc "Calculated feed-forward trajectory for the crane controller"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control of the physical crane is performed by the Control Application, a Python program that sends command messages to the Physical Crane Interface. The commands are simple control instructions (e.g., move to a specified coordinates, lift load, start/stop). The Control Application does not specify validation, authentication or conflict resolution within the documentation; however, any issued command is executed on the crane’s controllers via the interface. Feedback from the crane (e.g., updated state) is reported back to the interface and subsequently logged by the Logging Application."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The exemplar adopts a hybrid software stack orchestrated through containerized services running on virtual machines. The architecture layers include: a physical layer comprising Raspberry‑Pi single‑board computers (in the Air Quality Management case) or greenhouse sensors, a data ingestion layer using an ActiveMQ message broker to decouple sensor streams from downstream services, a persistence layer built on InfluxDB to store time‑series telemetry for status analysis and prediction engines, a virtualization layer leveraging pre‑configured virtual machine images that bundle software and prerecorded datasets, and an integration layer that pieces together automation workflows within Microsoft Azure for simulation, runtime visualization and prediction. Coordination is achieved through asynchronous message queues and container orchestration, with resource management handled by virtual machine slots and container resource limits. The system follows an event‑driven microservices architecture wherein each functional domain (sensor acquisition, data storage, simulation, visualization) is implemented as an independent container, and overall system coordination is centrally managed by the message broker and Azure pipelines."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin relies on an MQTT broker for inter‑service messaging, connecting the Trajectory Generator Service, Simulation Service, Continuous Validation Service, Database, and Dashboard. Data flows from the Physical Crane into the Logging Application, which writes to TimescaleDB; the Desktop Dashboard (Grafana) queries this database. Network topology is not explicitly defined beyond the presence of these services; no bandwidth, latency, reliability, redundancy, or security protocols are specified in the documentation."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The twin leverages standard, open‑source communication protocols: sensor data is published over the MQTT‑like protocol supported by ActiveMQ; instrumentation data is encapsulated following AutomationML schemas to ensure semantic interoperability. The Azure services expose RESTful APIs and Event Grid topics to publish state changes, while the pipeline integrates with external analytics services via HTTP/HTTPS. In addition, the Raspberry‑Pi hardware directly interfaces with external sensors over I²C/SPI, forwarding data through the broker to Azure IoT Hub. The integration pattern follows a publish‑sub approach, decoupling the twin’s internal services from external enterprise systems and enabling easy plugging of additional digital twins via the same broker architecture."
]