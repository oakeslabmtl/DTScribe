// -----------------------------------------------------------------------------
// C3: Physical sensing components
// -----------------------------------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring crane swing angle, accessed via Arduino interface"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the crane, read by Arduino"
    DTDFVocab:producedData AnemometerDataTransmitted
]

// -----------------------------------------------------------------------------
// C4: Physical-to-virtual interaction (DataTransmitted)
// -----------------------------------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// -----------------------------------------------------------------------------
// C5: Data (produced from DataTransmitted)
// -----------------------------------------------------------------------------
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series swing‑angle measurements of the gantry crane"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo PhysicalCraneInterface
]

instance AnemometerData : DTDFVocab:Data [
    base:desc "Time‑series wind‑speed measurements captured by the anemometer"
    DTDFVocab:fromData AnemometerDataTransmitted
    DTDFVocab:inputTo PhysicalCraneInterface
]

// -----------------------------------------------------------------------------
// C10: Models/Data
// -----------------------------------------------------------------------------
instance GantryCraneCADModel : DTDFVocab:Model [
    base:desc "Detailed CAD geometry of crane components used for visualization and simulation"
    DTDFVocab:inputTo GrafanaDashboard
    DTDFVocab:inputTo SimulationContainer
]

instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model describing crane motion input for trajectory generation and validation"
    DTDFVocab:inputTo TrajectoryGeneratorContainer
    DTDFVocab:inputTo ContinuousValidationContainer
]

// -----------------------------------------------------------------------------
// C11: Enablers (containers, platforms, middleware)
// -----------------------------------------------------------------------------
instance PhysicalCraneInterface : DTDFVocab:Enabler [
    base:desc "Python program that connects to crane controllers and reads sensor data via Arduino"
    DTDFVocab:enables OptimalControlService
    DTDFVocab:enables HistoricalDataLoggingService
    DTDFVocab:enables ContinuousValidationService
]

instance TimescaleDBDatabase : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance persisting sensor and operational time‑series data"
    DTDFVocab:enables HistoricalDataLoggingService
    DTDFVocab:enables DataVisualizationService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboard rendering crane pose, puck positions, and operation metrics"
    DTDFVocab:enables DataVisualizationService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating communication among all twin services"
    DTDFVocab:enables OptimalControlService
    DTDFVocab:enables HistoricalDataLoggingService
    DTDFVocab:enables DataVisualizationService
    DTDFVocab:enables ContinuousValidationService
    DTDFVocab:enables TrajectoryGenerationService
    DTDFVocab:enables SimulationService
]

instance TrajectoryGeneratorContainer : DTDFVocab:Enabler [
    base:desc "Container running trajectory generation algorithms using the kinematic model"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationContainer : DTDFVocab:Enabler [
    base:desc "Container providing what‑if simulation of crane motion"
    DTDFVocab:enables SimulationService
]

instance ContinuousValidationContainer : DTDFVocab:Enabler [
    base:desc "Container that continuously compares measured behaviour against the kinematic model"
    DTDFVocab:enables ContinuousValidationService
]

// -----------------------------------------------------------------------------
// C6: Services
// -----------------------------------------------------------------------------
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes optimal motion commands and dispatches them to the crane controller"
    DTDFVocab:provides MotionCommandAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Records sensor readings and actuator states into TimescaleDB for later analysis"
    DTDFVocab:provides HistoricalTrendInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Renders real‑time crane pose, puck locations and operational metrics on Grafana"
    DTDFVocab:provides RealTimeCraneStateInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Automatically validates live crane behaviour against the kinematic model"
    DTDFVocab:provides DeviationAlertInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal trajectory plans for crane motion"
    DTDFVocab:provides TrajectoryPlanInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Performs what‑if analysis of crane motion under different ventilation or occupancy scenarios"
    DTDFVocab:provides SimulationInsight
]

// -----------------------------------------------------------------------------
// C17: Insights / Actions
// -----------------------------------------------------------------------------
instance MotionCommandAction : DTDFVocab:Action [
    base:desc "Dispatches computed motion command to the crane controller"
    DTDFVocab:IsAutomatic true
]

instance HistoricalTrendInsight : DTDFVocab:Insight [
    base:desc "Identifies trends and anomalies in historical operational data"
]

instance RealTimeCraneStateInsight : DTDFVocab:Insight [
    base:desc "Provides live visualization of crane pose and puck positions"
]

instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alerts when measured crane behaviour deviates from the kinematic model"
]

instance TrajectoryPlanInsight : DTDFVocab:Insight [
    base:desc "Presents the computed optimal trajectory plan for the upcoming motion"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Shows predicted impact of ventilation or occupancy changes on indoor air quality"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, a Python service, uses the Physical Crane Interface to transmit control commands to the crane’s controllers. Commands (such as movement trajectories generated by the Trajectory Generator Service) are sent through the interface to the motors and hoist, effecting physical actions on the crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital‑twin architecture follows a service‑oriented pattern where the six containers are coordinated via an MQTT broker for event‑driven signalling and a common TimescaleDB for state persistence. The Physical Crane Interface (a Python program) feeds real‑time measurements into the Logging Application, which stores them in the database. The Trajectory Generator Service creates optimal movement plans using a kinematics model; the Simulation Service can replay these plans; the Continuous Validation Service continuously compares logged measurements with simulated results, computes distance metrics, and raises alerts via the Grafana dashboard when thresholds are exceeded. All services are implemented in Python and run on virtual machines or containers, enabling modular deployment and resource management."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The exemplar is employed to illustrate continuous‑validation methods, fault‑detection techniques based on time‑series classification, and co‑evolution validation of the digital twin. Validation is achieved by comparing predictions of the kinematic model with measured behaviour of the physical crane and by applying the DarTwin notation for system evolution, constituting the quality‑assurance process for model fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital‑twin services are deployed as Docker containers on a single host computer and orchestrated with Docker Compose. An Eclipse Mosquitto MQTT broker provides signaling between services, while the TimescaleDB database and Grafana dashboard are also containerized. Communication between services occurs over the local Docker network using MQTT for inter‑service messages and standard TCP/IP for database and dashboard access."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin runs on‑premise on a personal computer. Python containers are packaged in the pip‑installable module gantrylib, and the Database, MQTT Broker, and Dashboard are containerized with Docker. Deployment is performed via a provided Docker‑Compose file that starts and stops all containers on the host, offering a reproducible, single‑machine deployment with open‑source components."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external components is realized through the MQTT protocol (for inter‑service signalling) and standard open‑source tools: TimescaleDB for time‑series storage and Grafana for data visualization. The Physical Crane Interface connects to the crane controllers via a Python API, exposing sensor data to the twin. No enterprise‑level standards (e.g., AutomationML) or additional external Digital Twins are referenced for this exemplar."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar uses AutomationML as the modeling framework for its digital twin, complying with the AutomationML specification to achieve interoperable model exchange. No additional industry standards, certifications, or compliance frameworks are mentioned in the documents."
]