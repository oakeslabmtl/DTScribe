import base from "http://www.w3.org/2004/02/skos/core"
import DTDFVocab from "http://example.com/DTDFVocab"
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures hoist swinging motion",
    DTDFVocab:producedData SwingAngleDataTransmitted
]
instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Measures wind speed",
    DTDFVocab:producedData WindSpeedDataTransmitted
]
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Swing angle measurements",
    DTDFVocab:fromData SwingAngleDataTransmitted,
    DTDFVocab:inputTo TimescaleDB
]
instance WindSpeedData : DTDFVocab:Data [
    base:desc "Wind speed measurements",
    DTDFVocab:fromData WindSpeedDataTransmitted,
    DTDFVocab:inputTo TimescaleDB
]
instance TimeSeriesOperationalData : DTDFVocab:Data [
    base:desc "Time-series operational data stored in TimescaleDB",
    DTDFVocab:fromData SwingAngleDataTransmitted, WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDB
]
instance CADModel : DTDFVocab:Model [
    base:desc "CAD model created in Autodesk Fusion360",
    DTDFVocab:inputTo AutodeskFusion360
]
instance KinematicModel : DTDFVocab:Model [
    base:desc "Used for trajectory generation",
    DTDFVocab:inputTo Gantrylib
]
instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "Time-series database for operational data storage",
    DTDFVocab:enables DataLoggingService
]
instance EclipseMosquitto : DTDFVocab:Enabler [
    base:desc "MQTT broker for real-time messaging",
    DTDFVocab:enables DataLoggingService, VisualizationService
]
instance Docker : DTDFVocab:Enabler [
    base:desc "Containerization platform for database, MQTT broker, and Grafana",
    DTDFVocab:enables DataLoggingService, VisualizationService, TrajectoryGenerationService, SimulationService, ContinuousValidationService
]
instance Gantrylib : DTDFVocab:Enabler [
    base:desc "Python module for crane control and data handling",
    DTDFVocab:enables TrajectoryGenerationService, SimulationService, ContinuousValidationService
]
instance Arduino : DTDFVocab:Enabler [
    base:desc "Microcontroller interfacing physical sensors and controllers",
    DTDFVocab:enables DataLoggingService
]
instance TMC4671Eval : DTDFVocab:Enabler [
    base:desc "Motor controller for stepper motors"
]
instance AutodeskFusion360 : DTDFVocab:Enabler [
    base:desc "CAD modeling tool"
]
instance Capella : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering tool for Arcadia models, used in twinning process with DarTwin notation for evolution documentation",
    DTDFVocab:enables TrajectoryGenerationService, SimulationService
]
instance GitHub : DTDFVocab:Enabler [
    base:desc "Repository for code and documentation",
    DTDFVocab:enables DocumentationService
]
instance MkDocs : DTDFVocab:Enabler [
    base:desc "Documentation generation tool",
    DTDFVocab:enables DocumentationService
]
instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal trajectories using kinematic models",
    DTDFVocab:provides TrajectoryOptimizationInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates crane dynamics and controllers for virtual execution",
    DTDFVocab:provides SimulationInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares real-time measurements with simulations for validation",
    DTDFVocab:provides ValidationThresholdNotification
]
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs historical data to TimescaleDB",
    DTDFVocab:provides HistoricalDataInsight
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides data visualization via Grafana dashboard and Human Machine Interface for operator control",
    DTDFVocab:provides RealTimeStatusVisualization
]
instance DocumentationService : DTDFVocab:Service [
    base:desc "Manages system documentation",
    DTDFVocab:provides DocumentationInsight
]
instance ValidationThresholdNotification : DTDFVocab:Insight [
    base:desc "Operator notification for validation threshold breaches"
]
instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight for trajectory optimization in movement planning"
]
instance RealTimeStatusVisualization : DTDFVocab:Insight [
    base:desc "Real-time status visualization for operational decisions"
]
instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight for virtual commissioning using simulation"
]
instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Access to historical operational data for analysis"
]
instance DocumentationInsight : DTDFVocab:Insight [
    base:desc "System documentation for reference"
]
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor controlling cart movement"
]
instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor controlling hoist movement"
]
instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet for picking up containers"
]
instance DatabaseContainer : DTDFVocab:Component [
    base:desc "Containerized TimescaleDB database for time-series data"
]
instance DashboardContainer : DTDFVocab:Component [
    base:desc "Grafana dashboard container for visualization"
]
instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Container for trajectory generation service"
]
instance SimulationContainer : DTDFVocab:Component [
    base:desc "Container for crane dynamics simulation"
]
instance ContinuousValidationContainer : DTDFVocab:Component [
    base:desc "Container for continuous validation service"
]
instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Containerized Eclipse Mosquitto MQTT broker"
]
instance CranePhysicalContainer : DTDFVocab:Component [
    base:desc "Physical gantry crane system"
]
instance InterfaceContainer : DTDFVocab:Component [
    base:desc "Arduino microcontroller interface for physical sensors and controllers"
]
instance ControlAppContainer : DTDFVocab:Component [
    base:desc "Control application managing motor controllers"
]
instance LoggingAppContainer : DTDFVocab:Component [
    base:desc "Application logging crane state to TimescaleDB"
]
instance HMIDeviceContainer : DTDFVocab:Component [
    base:desc "Human Machine Interface device for operator control"
]
instance DigitalTwinSystem : DTDFVocab:Environment [
    base:desc "Lab-scale gantry crane inspired by harbor cranes in the port of Antwerp, moving small pucks (representing containers) between locations cyber-physical system consisting of physical hardware and digital twin",
    base:contains DatabaseContainer, DashboardContainer, TrajectoryGeneratorContainer, SimulationContainer, ContinuousValidationContainer, MQTTBrokerContainer, CranePhysicalContainer, InterfaceContainer, ControlAppContainer, LoggingAppContainer, HMIDeviceContainer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Commands from the Control Application (Python) are sent through the Physical Crane Interface to the TMC4671-Eval motor controllers for cart and hoist movement, enabling precise trajectory execution."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real-time data logging and validation with no specified time intervals; measurements and simulations are compared in real-time for continuous validation service."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized orchestration where physical components (crane frame, motors, sensors) interact with digital services (database, dashboard, trajectory generator, simulation, validation) via MQTT broker and TimescaleDB. Physical Crane Interface and Control Application mediate interactions between physical and digital layers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers 'as designed' (CAD models in Autodesk Fusion360, kinematic model) and 'as operated' (real-time sensor data logging and execution of physical movements). No mention of 'as manufactured' stage."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous validation service calculates distance metrics between executed trajectory measurements and simulated trajectories, comparing against predefined thresholds. Breaches trigger operator notifications for validation checks."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol (Eclipse Mosquitto) for real-time signaling between services; TimescaleDB for persistent data storage. Physical sensors connect to Arduino, which interfaces with the digital system via Python modules."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Docker containers for TimescaleDB, MQTT broker, and Grafana dashboard; Python module 'gantrylib' installed via pip; all components deployed on a single personal computer as per deployment diagram (Figure 5)."
]