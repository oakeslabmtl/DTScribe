// -----------------------------------------------------------
// C2: Acting Components
// -----------------------------------------------------------
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor that drives the gantry cart, controlled by a Trinamic TMC4671‑Eval motor controller."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor that drives the hoist lift, controlled by a Trinamic TMC4671‑Eval motor controller."
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted at the end of the hoist used for picking up containers."
]

// -----------------------------------------------------------
// C3: Physical Sensing Components
// -----------------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the crane to measure the swing angle of the load."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer connected to the Arduino board to measure ambient wind speed."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// -----------------------------------------------------------
// C4: Physical‑to‑Virtual Interaction (Data Transmission)
// -----------------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series data of swing‑angle measurements."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler , MqttBrokerEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series data of wind‑speed measurements."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler , MqttBrokerEnabler
]

instance OperationalTimeSeriesData : DTDFVocab:Data [
    base:desc "Aggregated operational data (sensor readings, command logs) stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDBEnabler , GrafanaEnabler
]

// -----------------------------------------------------------
// C10: Models / Data
// -----------------------------------------------------------
instance CADModelFusion360 : DTDFVocab:Model [
    base:desc "3‑D CAD model of the gantry crane created in Autodesk Fusion360."
    DTDFVocab:inputTo DockerComposeEnabler
]

instance KinematicModelCrane : DTDFVocab:Model [
    base:desc "Kinematic model of the crane used to compute swing‑free trajectories."
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance SimulationModelCrane : DTDFVocab:Model [
    base:desc "Simulation model that reproduces crane dynamics and controller behaviour."
    DTDFVocab:inputTo SimulationEnabler
]

// -----------------------------------------------------------
// C11: Enablers (Tools / Platforms)
// -----------------------------------------------------------
instance PythonPhysicalInterface : DTDFVocab:Enabler [
    base:desc "Python program (using gantrylib) that reads Arduino sensors and publishes state via MQTT and TimescaleDB."
    DTDFVocab:enables DataLoggingService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) container for time‑series storage."
    DTDFVocab:enables DataLoggingService , GrafanaDashboardService
]

instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker container for pub‑sub messaging between services."
    DTDFVocab:enables TrajectoryGeneratorService , SimulationService , ContinuousValidationService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestration of all containerised services."
    DTDFVocab:enables TrajectoryGeneratorService , SimulationService , ContinuousValidationService , GrafanaDashboardService , DataLoggingService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Docker container that hosts the Trajectory Generator Service."
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Docker container that runs the Simulation Service."
    DTDFVocab:enables SimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Docker container that runs the Continuous Validation Service."
    DTDFVocab:enables ContinuousValidationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana container for visualising data stored in TimescaleDB."
    DTDFVocab:enables GrafanaDashboardService
]

// -----------------------------------------------------------
// C6: Services
// -----------------------------------------------------------
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs incoming sensor data and writes it into TimescaleDB."
    DTDFVocab:provides DataStorageInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Provides visual dashboards for operational data using Grafana."
    DTDFVocab:provides VisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free trajectories using the crane kinematic model."
    DTDFVocab:provides OptimalTrajectoryInsight , ApplyOptimalTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Performs runtime simulation of the crane and its controllers."
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories against simulated ones and raises alerts on deviations."
    DTDFVocab:provides ValidationAlertInsight , OperatorInterventionAction
]

instance FaultClassificationService : DTDFVocab:Service [
    base:desc "Classifies detected faults to support maintenance decisions."
    DTDFVocab:provides FaultDiagnosticInsight
]

// -----------------------------------------------------------
// C17: Insights / Actions
// -----------------------------------------------------------
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory computed for the current load and wind conditions."
]

instance ApplyOptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatically sends motion commands to the stepper motors based on the optimal trajectory."
    DTDFVocab:IsAutomatic true
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation output indicating predicted crane behaviour for a given command set."
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert raised when actual trajectory deviates beyond predefined thresholds."
]

instance OperatorInterventionAction : DTDFVocab:Action [
    base:desc "Requires operator to manually intervene when a validation alert is triggered."
    DTDFVocab:IsAutomatic false
]

instance FaultDiagnosticInsight : DTDFVocab:Insight [
    base:desc "Diagnostic information pinpointing the likely fault source within the crane system."
]

instance DataStorageInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data has been successfully persisted in TimescaleDB."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualisation of crane operational parameters."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends motion commands via the Physical Crane Interface to the motor controllers, and the Human Machine Interface (Python front‑end) allows an operator to issue commands that are transmitted through the same interface to the physical crane."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A personal computer hosts all software components; Docker containers provide the database, MQTT broker and dashboard, while Python modules implement the crane interface, control, logging, trajectory generation, simulation and continuous validation. The physical crane connects via USB/serial to the PC where the Python interface communicates with the Arduino and motor controllers."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, checks them against predefined thresholds, and generates operator alerts when thresholds are exceeded, ensuring the digital twin remains a faithful representation of the physical crane."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses a Python‑based Physical Crane Interface over USB/serial to the Arduino and motor controllers; MQTT (Eclipse Mosquitto) is used for event‑driven messaging between services; TimescaleDB is accessed via standard PostgreSQL SQL queries; all Docker containers share a virtual network defined by Docker‑Compose."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT services run on a single personal computer; Docker containers for the database, MQTT broker and Grafana are launched with Docker‑Compose; the gantrylib Python module is installed via pip; the system can be started and stopped with a single compose command."
]