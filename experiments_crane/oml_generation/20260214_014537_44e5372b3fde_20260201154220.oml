]

instance GreenhouseEnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseEnvironmentalSensorSet
    base:desc "Pre-recorded environmental data (temperature, humidity) embedded in virtual machine images for offline analysis."
]

instance CranePositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GantryCranePositionSensor
    base:desc "Continuous encoder readings for crane position, velocity, and acceleration transmitted via serial/TCP/IP protocol at high frequency."
]

instance PuckStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GantryCranePuckStateSensor
    base:desc "Real-time puck state data (presence, load status) transmitted upon detection events."
]

instance ControllerStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GantryCraneControllerStateSensor
    base:desc "Controller state changes (e.g., emergency stops, trajectory commands) transmitted via MQTT for synchronized system coordination."
]

