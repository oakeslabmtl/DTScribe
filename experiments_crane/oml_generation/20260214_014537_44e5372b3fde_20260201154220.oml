    DTDFVocab:inputTo MicrosoftAzureToolsPipeline
]

instance GreenhouseEnvironmentalData : DTDFVocab:Data [
    base:desc "Time-series environmental data (temperature, humidity) from pre-recorded datasets embedded in virtual machine images."
