]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Message broker facilitating signaling between services (e.g., Logging Application, Trajectory Generator) for synchronized data flows."
    DTDFVocab:enables DataVisualizationService, OptimalControlService
]

instance PythonPhysicalCraneInterface : DTDFVocab:Enabler [
    base:desc "Python-based bridge between physical crane hardware and digital twin components, enabling bidirectional data flow."
