    DTDFVocab:inputTo TimescaleDBTimeSeriesDatabase
]

instance AirQualitySensorData : DTDFVocab:Data [
    base:desc "Structured air quality metrics (e.g., CO2, particulate matter) collected from Raspberry Pi sensors for real-time monitoring and predictive analytics."
