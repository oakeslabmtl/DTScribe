]

instance KinematicSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Custom Python-based kinematic simulation framework (SymPy/SciPy) for deriving forward/inverse kinematics of the gantry crane, used for trajectory planning and motion validation."
    DTDFVocab:enables GantryCraneKinematicService, GantryCraneTrajectoryOptimizationService
]

instance PhysicsEngineEnabler : DTDFVocab:Enabler [
    base:desc "Optional physics engine (MuJoCo/Gazebo) for high-fidelity dynamic simulation of the gantry crane, enabling validation of load dynamics and stability under varying operational conditions."
    DTDFVocab:enables GantryCraneDynamicValidationService
]

instance AzureCloudEnabler : DTDFVocab:Enabler [
    base:desc "Microsoft Azure cloud infrastructure hosting predictive analytics pipelines and runtime visualization dashboards for the air quality management digital twin, supporting scalable data processing."
    DTDFVocab:enables AirQualityPredictionService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT-based message broker facilitating asynchronous communication between the Physical Crane Interface, Logging Application, and digital twin services, ensuring low-latency data exchange."
    DTDFVocab:enables GantryCraneDataStreamingService
]

