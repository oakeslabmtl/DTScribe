// C2: Acting Components
instance LinearActuatorActingComponent : DTDFVocab:ActingComponent [
    base:desc "Linear actuator forming the translation axis of the gantry rail system, controlled by an embedded controller."
]

// C3: Physical sensing components
instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the gantry's position along the linear rail, providing real-time positional data."
    DTDFVocab:producedData CraneTelemetryDataTransmitted
]
instance CraneForceSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring actuator forces applied to the gantry crane."
    DTDFVocab:producedData CraneTelemetryDataTransmitted
]

// C4: Physical-to-virtual interaction
instance CraneTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor, CraneForceSensor
]

// C10: Models/Data
instance CraneTelemetryDataTimescale : DTDFVocab:Data [
    base:desc "Telemetry data persisted in TimescaleDB for real‑time monitoring and validation."
    DTDFVocab:fromData CraneTelemetryDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance CraneTelemetryDataInflux : DTDFVocab:Data [
    base:desc "Historical telemetry data stored in InfluxDB for long‑term analysis and replay."
    DTDFVocab:fromData CraneTelemetryDataTransmitted
    DTDFVocab:inputTo InfluxDBEnabler
]
instance CraneTelemetryDataActiveMQ : DTDFVocab:Data [
    base:desc "Telemetry data streamed via ActiveMQ broker for asynchronous decoupled communication."
    DTDFVocab:fromData CraneTelemetryDataTransmitted
    DTDFVocab:inputTo ActiveMQBrokerEnabler
]
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "CAD‑modeled kinematic chain of the gantry crane, used for forward kinematics and trajectory generation."
    DTDFVocab:inputTo AutomationMLEngineEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database enabling real‑time data persistence and monitoring of crane telemetry."
    DTDFVocab:enables RealTimeMonitoringService, ValidationComparisonService
]
instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database enabling historical data logging and replay for simulation."
    DTDFVocab:enables HistoricalDataLoggingService
]
instance ActiveMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "ActiveMQ message broker enabling asynchronous delivery of crane telemetry between physical and virtual systems."
    DTDFVocab:enables RealTimeMonitoringService
]
instance AutomationMLEngineEnabler : DTDFVocab:Enabler [
    base:desc "AutomationML engine enabling interpretation of the kinematic model for adaptive control logic."
    DTDFVocab:enables OptimalControlTrajectoryService, ValidationComparisonService
]
instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Python/Unity visualization platform enabling real‑time 3D rendering of crane motion."
    DTDFVocab:enables MotionVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of actuator positions and forces, providing live telemetry dashboards."
    DTDFVocab:provides TelemetryDataInsight
]
instance OptimalControlTrajectoryService : DTDFVocab:Service [
    base:desc "Generation of optimal control trajectories from the kinematic model for efficient motion planning."
    DTDFVocab:provides GenerateOptimalControlTrajectoryAction
]
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Comprehensive logging of all operational states into InfluxDB for historical analysis and replay."
    DTDFVocab:provides HistoricalDataInsight
]
instance MotionVisualizationService : DTDFVocab:Service [
    base:desc "3D visualization of crane motion in real‑time, integrating telemetry data into a Unity environment."
    DTDFVocab:provides CraneMotionVisualizationInsight
]
instance ValidationComparisonService : DTDFVocab:Service [
    base:desc "Continuous validation comparing live telemetry against simulated predictions from the kinematic model."
    DTDFVocab:provides ValidationResultInsight
]

// C17: Insights/Actions
instance TelemetryDataInsight : DTDFVocab:Insight [
    base:desc "Live telemetry insight showing current position, velocity, and force of the gantry crane."
]
instance GenerateOptimalControlTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatic generation and deployment of optimal control trajectories for the crane's motion."
    DTDFVocab:IsAutomatic true
]
instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Historical analysis insight presenting logged operational states over time."
]
instance CraneMotionVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time 3D visualization of crane motion based on live telemetry."
]
instance ValidationResultInsight : DTDFVocab:Insight [
    base:desc "Insight comparing live measurements against simulated predictions to assess fidelity."
]

// Misc Components
instance MechanicalGantryComponent : DTDFVocab:Component [
    base:desc "Mechanical gantry structure spanning the laboratory, providing support for linear actuators."
]
instance LinearActuatorComponent : DTDFVocab:Component [
    base:desc "Linear actuator motor driving the gantry along the rail."
]
instance EmbeddedControllerComponent : DTDFVocab:Component [
    base:desc "Embedded controller managing actuator commands and processing sensor data."
]
instance CADModelComponent : DTDFVocab:Component [
    base:desc "CAD‑modeled representation of the gantry crane's geometry used for kinematic analysis."
]
instance LoggingApplicationComponent : DTDFVocab:Component [
    base:desc "Python logging application continuously reading crane state via a Physical Crane Interface and persisting data to TimescaleDB."
]

// C1: Environment
instance LabEnvironment : DTDFVocab:Environment [
    base:contains MechanicalGantryComponent, LinearActuatorComponent, EmbeddedControllerComponent, CADModelComponent, LoggingApplicationComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the Control Application, a Python program that sends motion directives (trajectory points or movement commands) to the Physical Crane Interface, which then translates them into the crane’s controller commands and executes them on the Physical Crane hardware. The documents do not specify the concrete message format, authentication, or feedback confirmation mechanisms, but the system assumes that state changes are monitored through the Logging Application, which can be used to confirm execution."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter-service communication is facilitated by an MQTT broker that exchanges control and telemetry messages between the Digital Twin services (Trajectory Generator, Simulation, Continuous Validation, and Dashboard). The database (TimescaleDB) and Grafana dashboard also interact over local network connections using PostgreSQL and HTTP/HTTPS. The documents do not provide specifics on network topology, bandwidth, latency or security protocols, but the architecture implies a local network hosting all components."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Air Quality Management exemplar integrates with Microsoft Azure by employing Azure IoT Hub for ingesting sensor telemetry from the Raspberry‑Pi, Azure Functions for real‑time processing and prediction, and Azure Blob Storage for long‑term persistence. The twin model itself is expressed in AutomationML and exchanged over the ActiveMQ broker, supporting asynchronous messaging with the physical plant. Docker containers encapsulate the twin components, and the entire stack is versioned and managed via GitHub, enabling CI/CD pipelines that deploy updates to the Azure landscape."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar adopts AutomationML for its digital‑twin model, enabling standardized, machine‑readable descriptions of the indoor environment and sensor network. No additional industry standards, certification requirements, or interoperability frameworks are cited in the documentation."
]