// Acting Components
instance GantryTranslationMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Brushless DC motor for horizontal gantry translation, controlled by a dedicated motor controller that receives position setpoints via a CAN‑bus interface and operates between 0°–180° at a maximum speed of 60°/s."
]
instance VerticalLiftMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Brushless DC motor for vertical lift, controlled by a dedicated motor controller that receives position setpoints via a CAN‑bus interface and operates between 0°–180° at a maximum speed of 30°/s."
]
instance EndEffectorElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the end‑effector, driven by a PWM‑controlled driver, used to pick up and release small container pucks."
]
instance EmergencyStopSwitchActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency stop switch that cuts power to both motors and disables the electromagnet if a fault is detected."
]

// Sensing Components
instance SwingAngleEncoderSensingComponent : DTDFVocab:SensingComponent [
    base:desc "High‑resolution swing‑angle encoder attached to the gantry carriage, providing angular position feedback with a resolution of 0.05° at a nominal sampling rate of 100 Hz."
    DTDFVocab:producedData SwingAngleDataTransmitted
]
instance AnemometerWindSensorSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Standard anemometer mounted on the gantry, monitoring wind speed and direction, providing data at 5 Hz."
    DTDFVocab:producedData AnemometerWindDataTransmitted
]

// Data Transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensingComponent
]
instance AnemometerWindDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerWindSensorSensingComponent
]

// Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series data of swing‑angle encoder readings, serialized in JSON and published via the ActiveMQ broker under topic 'crane/angle'."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo GantryLibSimulationEnabler, ContinuousValidationEnabler, InfluxDBTimeSeriesEnabler, ActiveMQBrokerEnabler
]
instance AnemometerWindData : DTDFVocab:Data [
    base:desc "Time‑series data of wind speed and direction from the anemometer, serialized in JSON and published via the ActiveMQ broker under topic 'crane/wind'."
    DTDFVocab:fromData AnemometerWindDataTransmitted
    DTDFVocab:inputTo GantryLibSimulationEnabler, InfluxDBTimeSeriesEnabler, ActiveMQBrokerEnabler
]
instance PuckTrajectoryPredictionData : DTDFVocab:Data [
    base:desc "Predicted coordinates of the suspended puck within the crane's workspace, generated by the analytical kinematic model every few milliseconds."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo ContinuousValidationEnabler, InfluxDBTimeSeriesEnabler
]

// Models
instance KinematicPositionModel : DTDFVocab:Model [
    base:desc "Analytical kinematic model that computes the position of the suspended puck from real‑time motor encoder readings and electromagnet state."
    DTDFVocab:inputTo GantryLibSimulationEnabler
]

// Enablers
instance GantryLibSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib library that performs the kinematic simulation of the gantry crane."
    DTDFVocab:enables FeedbackControlSynthesisService
]
instance FeedbackControlEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source control framework that supplies optimal feedback control laws to the motor controllers."
    DTDFVocab:enables FeedbackControlSynthesisService
]
instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Python module that compares live encoder and IMU measurements against simulated trajectories, reports RMSE, and flags drift."
    DTDFVocab:enables ContinuousValidationService
]
instance HistoricalDataLoggingEnabler : DTDFVocab:Enabler [
    base:desc "Relational database driver that logs historical operational metrics for retrospective analysis."
    DTDFVocab:enables HistoricalDataLoggingService
]
instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana plugin that visualizes real‑time metrics and historical data on dashboards."
    DTDFVocab:enables InteractiveDataVisualizationService
]
instance ActiveMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "ActiveMQ message broker that distributes sensor payloads over MQTT topics."
    DTDFVocab:enables ContinuousValidationService
]
instance InfluxDBTimeSeriesEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database host that stores high‑frequency sensor data."
    DTDFVocab:enables HistoricalDataLoggingService
]
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database that stores the comprehensive crane state captured by the logging application."
    DTDFVocab:enables HistoricalDataLoggingService
]
instance DockerContainerEnabler : DTDFVocab:Enabler [
    base:desc "Docker container orchestrator ensuring reproducibility of the entire software stack."
]

// Services
instance FeedbackControlSynthesisService : DTDFVocab:Service [
    base:desc "Service that synthesizes optimal feedback control laws based on real‑time model output and sensor data, adjusting motor setpoints for improved performance."
    DTDFVocab:provides OptimalControlInsight, UpdateControllerAction
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously validates the physical system against simulated trajectories, reporting RMSE and flagging drift."
    DTDFVocab:provides ValidationInsight, FlagDriftAction
]
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that logs historical operational metrics into a relational database for retrospective analysis."
    DTDFVocab:provides HistoricalDataInsight
]
instance InteractiveDataVisualizationService : DTDFVocab:Service [
    base:desc "Service that displays real‑time metrics, alerts, and historical trajectories on Grafana dashboards."
    DTDFVocab:provides VisualizationInsight
]

// Insights
instance OptimalControlInsight : DTDFVocab:Insight [
    base:desc "Insight into the optimal control strategy derived from the kinematic model and sensor feedback."
]
instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Insight reporting RMSE values and drift status during continuous validation."
]
instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing logged operational metrics for retrospective analysis."
]
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing a real‑time, interactive view of system performance on Grafana dashboards."
]

// Actions
instance UpdateControllerAction : DTDFVocab:Action [
    base:desc "Action that automatically updates motor setpoints based on the optimal control synthesis."
    DTDFVocab:IsAutomatic true
]
instance FlagDriftAction : DTDFVocab:Action [
    base:desc "Action that automatically flags drift when RMSE exceeds predefined thresholds during continuous validation."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands flow from the digital twin to the physical crane via the Control Application, which uses the Physical Crane Interface to issue commands generated by the Trajectory Generator Service. The trajectory data, expressed as a sequence of position way‑points and velocity profiles, is sent from the Trajectory Generator to the Control Application, which transmits the commands to the crane controllers over the Physical Crane Interface. Validation and authentication mechanisms are not detailed; the only feedback loop present in the document is the Logging Application’s continuous state logging, which allows the Continuous Validation Service to compare executed trajectories against simulations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through a Continuous Validation Service that compares the simulated puck positions against the encoder‑derived ground truth on a real‑time basis. Discrepancies trigger alerts that are visualised on a dashboard (Grafana) and notify operators via the broker; no automatic parameter tuning is performed. Validation and verification rely on manual comparison loops and the feedback from the operator, ensuring the twin remains an accurate representation of the physical system within the defined operational envelope."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin is performed through an MQTT broker; the broker is used for signaling between services such as the Trajectory Generator, Simulation Service, and Continuous Validation Service. The Logging Application writes state data to a TimescaleDB database, which is a PostgreSQL‑based time‑series database. The Physical Crane Interface connects directly to the hardware controllers of the crane, but the communication protocol and network layer are not specified in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components of the digital twin are described as Docker containers: Database (TimescaleDB), MQTT Broker, Dashboard (Grafana), Trajectory Generator Service, Simulation Service, and Continuous Validation Service. The Physical Crane, Physical Crane Interface, Control Application, Logging Application, and Human Machine Interface are Python programs that are bundled into a Python module and are not containerized. The system can be deployed on a single machine through a Docker Compose setup; scalability, redundancy, and detailed deployment models are not provided in the document."
]