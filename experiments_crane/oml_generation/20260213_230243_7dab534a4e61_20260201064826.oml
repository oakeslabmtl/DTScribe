// =========================
// Acting Components
// =========================
instance CartStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Stepper motor moving the gantry cart, driven by a Trinamic TMC4671‑Eval motor controller"
]

instance HoistStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Stepper motor raising and lowering the hoist, driven by a Trinamic TMC4671‑Eval motor controller"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist for picking up containers"
]

instance TrinamicMotorControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval motor controller interfacing between the Arduino board and the stepper motors"
]

// =========================
// Physical Sensing Components
// =========================
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the hoist pendulum"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// =========================
// Data Transmitted (Physical → Virtual)
// =========================
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// =========================
// Data (Stored / Processed)
// =========================
instance SwingAngleMeasurementData : DTDFVocab:Data [
    base:desc "Time‑stamped swing‑angle measurements streamed from the encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance WindSpeedMeasurementData : DTDFVocab:Data [
    base:desc "Time‑stamped wind‑speed measurements streamed from the anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance ValidationMetricsData : DTDFVocab:Data [
    base:desc "Distance‑based validation metrics and threshold values produced by the Continuous Validation Service"
    DTDFVocab:inputTo TimescaleDBEnabler
]

// =========================
// Models / Data (Digital)
// =========================
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane used for visualization and collision checking"
    DTDFVocab:inputTo DockerComposeEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model employed by the Trajectory Generator service"
    DTDFVocab:inputTo PythonGantryLibEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the crane and its controllers used by the Simulation Service"
    DTDFVocab:inputTo PythonGantryLibEnabler
]

// =========================
// Enablers (Tooling & Infrastructure)
// =========================
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB PostgreSQL time‑series database storing sensor measurements and validation metrics"
    DTDFVocab:enables LoggingApplicationService, DataVisualizationDashboardService, ContinuousValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker publishing sensor streams and status events"
    DTDFVocab:enables LoggingApplicationService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

instance PythonGantryLibEnabler : DTDFVocab:Enabler [
    base:desc "gantrylib Python module (pip‑installable) providing kinematic and dynamic models"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestration handling container deployment of all twin services"
    DTDFVocab:enables LoggingApplicationService, DataVisualizationDashboardService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService, HumanMachineInterfaceService
]

// =========================
// Services
// =========================
instance LoggingApplicationService : DTDFVocab:Service [
    base:desc "Data logging service that receives sensor streams via MQTT and writes them into TimescaleDB"
    DTDFVocab:provides SensorDataLoggingInsight
]

instance DataVisualizationDashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualizing stored measurements, simulation results and validation alerts"
    DTDFVocab:provides OperatorVisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Kinematics‑based trajectory generator producing swing‑free motion plans"
    DTDFVocab:provides OptimalTrajectoryInsight, TrajectoryCommandAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Dynamic simulation of the crane and its controllers using the kinematic and dynamic models"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares measured trajectories with simulated ones, generates validation metrics and alerts"
    DTDFVocab:provides ValidationAlertInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Web‑based human‑machine interface allowing operators to issue commands and view insights"
    DTDFVocab:provides OperatorControlAction
]

// =========================
// Insights & Actions
// =========================
instance SensorDataLoggingInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data have been successfully persisted in TimescaleDB"
]

instance OperatorVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time plots of swing angle, wind speed and validation alerts displayed to the operator"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal, swing‑free trajectory computed for the requested move"
]

instance TrajectoryCommandAction : DTDFVocab:Action [
    base:desc "Command sent to the control application to execute the optimal trajectory"
    DTDFVocab:IsAutomatic false
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulated trajectory used as reference for validation comparison"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert raised when validation metrics exceed predefined thresholds"
]

instance OperatorControlAction : DTDFVocab:Action [
    base:desc "Operator manually initiates a crane movement via the HMI"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (Python) receives trajectory commands from the Trajectory Generator Service (via MQTT or direct API) and forwards motion set‑points to the Physical Crane Interface, which then drives the motor controllers; also the Continuous Validation Service can trigger operator alerts that influence manual overrides through the Human‑Machine Interface."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A C4‑modelled architecture where the physical crane is interfaced through a Python layer; sensor data flows to the Logging Application, then to TimescaleDB and MQTT; DT services (trajectory generation, simulation, validation) consume data via MQTT, generate outputs, and the HMI presents visualisations via Grafana, all deployed on a single personal computer using Docker‑Compose."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The exemplar covers design (CAD models in Autodesk Fusion 360 and kinematic model), manufacturing (Bill‑of‑Materials and assembled hardware), and operation (runtime logging, control, validation, and visualization)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares executed trajectories (measured by sensors) with simulated trajectories, computes distance metrics, checks against a predefined acceptable threshold, and raises alerts on the Grafana dashboard when the threshold is exceeded."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication uses the MQTT protocol (Eclipse Mosquitto broker) for signalling; data persistence uses SQL over PostgreSQL (TimescaleDB) accessed by Python applications; the Human‑Machine Interface communicates with services via standard REST/HTTP endpoints provided by the Python modules."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components run on a single PC; Docker containers host the TimescaleDB, MQTT broker, and Grafana dashboard; the remaining Python services run as processes within the gantrylib module; deployment is automated with a Docker‑Compose file that also initializes the database and dashboard."
]