// C2: Acting Components
instance CartMotorStepper : DTDFVocab:ActingComponent [
    base:desc "Stepper motor controlling the cart motion along the gantry."
]

instance HoistMotorStepper : DTDFVocab:ActingComponent [
    base:desc "Stepper motor controlling hoist vertical movement."
]

instance HoistElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet engaging the container for lifting."
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder measuring the crane's swing angle, interfaced via Arduino."
    DTDFVocab:producedData SwingAngleData
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting crane operation."
    DTDFVocab:producedData WindSpeedData
]

instance ArduinoSensorHub : DTDFVocab:SensingComponent [
    base:desc "Hub aggregating additional sensors interfaced via Arduino, including motor status sensors."
    DTDFVocab:producedData ArduinoHubData
]

// C4: Physical-to-virtual interaction
instance SwingAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance ArduinoHubData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoSensorHub
]

instance CartMotorPositionData : DTDFVocab:DataTransmitted [
]

instance HoistMotorPositionData : DTDFVocab:DataTransmitted [
]

instance HoistElectromagnetStateData : DTDFVocab:DataTransmitted [
]

// C10: Models/Data
instance Fusion360CADModel : DTDFVocab:Model [
    base:desc "Autodesk Fusion 360 CAD model of the lab‑scale gantry crane."
    DTDFVocab:inputTo PythonGantryLibEnabler
]

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Kinematic model used for optimal trajectory calculation of the gantry crane."
    DTDFVocab:inputTo PythonGantryLibEnabler
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of the crane and controllers."
    DTDFVocab:inputTo PythonGantryLibEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database for storing time-series sensor data."
    DTDFVocab:enables DataLoggingService, ContinuousValidationService
]

instance PythonGantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib runtime within Docker Compose, used for simulation and trajectory generation."
    DTDFVocab:enables OptimalTrajectoryGenerationService, CraneControllerSimulationService, ContinuousValidationService
]

instance MosquittoMQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for real‑time data publication."
    DTDFVocab:enables DataLoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana visualization engine integrated with Docker Compose."
    DTDFVocab:enables GrafanaVisualizationService
]

// C7: Data instances
instance SwingAngleSensorData : DTDFVocab:Data [
    base:desc "Time‑series data of the swing angle, stored in TimescaleDB."
    DTDFVocab:fromData SwingAngleData
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedSensorData : DTDFVocab:Data [
    base:desc "Time‑series data of wind speed, stored in TimescaleDB."
    DTDFVocab:fromData WindSpeedData
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance ArduinoHubSensorData : DTDFVocab:Data [
    base:desc "Time‑series data from Arduino sensor hub, stored in TimescaleDB."
    DTDFVocab:fromData ArduinoHubData
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance CartMotorPositionSensorData : DTDFVocab:Data [
    base:desc "Time‑series of cart motor position, stored in TimescaleDB."
    DTDFVocab:fromData CartMotorPositionData
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HoistMotorPositionSensorData : DTDFVocab:Data [
    base:desc "Time‑series of hoist motor position, stored in TimescaleDB."
    DTDFVocab:fromData HoistMotorPositionData
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HoistElectromagnetStateSensorData : DTDFVocab:Data [
    base:desc "Time‑series of hoist electromagnet activation status, stored in TimescaleDB."
    DTDFVocab:fromData HoistElectromagnetStateData
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs real‑time sensor data from motors, encoder, wind speed, and other sensors into TimescaleDB."
    DTDFVocab:provides DataQualityInsight
]

instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Ensures integrity of logged sensor data."
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Validates live measurements against simulation, alerts when deviations exceed thresholds."
    DTDFVocab:provides ContinuousValidationAlertInsight, AutomatedCorrectiveAction
]

instance ContinuousValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alerts when deviation from simulated trajectory exceeds thresholds."
]

instance AutomatedCorrectiveAction : DTDFVocab:Action [
    base:desc "Automated corrective measures when deviation thresholds are exceeded."
    DTDFVocab:IsAutomatic true
]

instance OptimalTrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal trajectories for the crane based on kinematic data."
    DTDFVocab:provides TrajectoryOptimizationInsight, OperatorManualAdjustmentAction
]

instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory results that inform operator actions."
]

instance OperatorManualAdjustmentAction : DTDFVocab:Action [
    base:desc "Guides operator to manually adjust crane movement based on trajectory optimization."
    DTDFVocab:IsAutomatic false
]

instance CraneControllerSimulationService : DTDFVocab:Service [
    base:desc "Simulates crane dynamics and controller responses."
    DTDFVocab:provides CraneSimulationInsight
]

instance CraneSimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results used for continuous validation."
]

instance GrafanaVisualizationService : DTDFVocab:Service [
    base:desc "Visualizes sensor and simulation data in Grafana dashboards."
    DTDFVocab:provides GrafanaVisualizationInsight
]

instance GrafanaVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight into historical data trends via Grafana."
]

instance OperatorInterfaceAlertingService : DTDFVocab:Service [
    base:desc "Provides operator interface with alerting for deviations and fault diagnostics."
    DTDFVocab:provides ContinuousValidationAlertInsight, FaultClassificationInsight, OperatorManualAdjustmentAction, AutomatedCorrectiveAction
]

instance FaultClassificationInsight : DTDFVocab:Insight [
    base:desc "Classifies faults detected during continuous validation."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory Generator Service produces optimal trajectories; the Control Application sends motion commands to the Physical Crane Interface which drives cart and hoist motors via their controllers, with feedback triggering updates or alerts."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time operation; logging and validation run continuously at each control cycle; trajectory generation invoked per task request."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Context diagram shows Operator and Researcher actors; container diagram shows five physical containers (CR, Interface, Control App, Logging App, HM Interface) and six digital twin containers (Database, Dashboard, Trajectory Generator, Simulation, Continuous Validation, MQTT Broker) interconnected via MQTT and database links."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design stage (CAD and kinematic models), manufacturing stage (physical crane built per BOM), and operational stage (continuous operation, logging, validation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service compares live measurements with simulation, computing distance metrics and threshold checks to detect deviations; simulation model provides reference behavior."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT broker (Eclipse Mosquitto) mediates inter‑service communication; Logging Application writes to TimescaleDB via PostgreSQL SQL; Physical interface connects to motor controllers likely via serial/USB."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin services containerized with Docker and launched via docker‑compose on a personal computer; application modules distributed as pip package; code hosted on GitHub with MkDocs documentation."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of open‑source standards such as MQTT protocol, PostgreSQL‑compatible TimescaleDB, and Grafana dashboards; no industry‑specific twin frameworks."
]