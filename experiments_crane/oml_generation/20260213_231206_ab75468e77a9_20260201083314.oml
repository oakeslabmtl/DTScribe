// ----------------------------------------------------
// C3: Physical sensing components
// ----------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing on the gantry crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed in the crane workspace"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// ----------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// ----------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// ----------------------------------------------------
// C5: Data produced from sensors
// ----------------------------------------------------
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "High‑frequency time‑stamped swing angle series stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDatabaseEnabler
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "High‑frequency wind speed series stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDatabaseEnabler
]

// ----------------------------------------------------
// C2: Acting components
// ----------------------------------------------------
instance CartMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart along the gantry"
]

instance HoistMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist vertically"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist for picking up pucks"
]

instance MotorControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval motor controller interfacing the cart and hoist motors"
]

// ----------------------------------------------------
// C10: Models / Data
// ----------------------------------------------------
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane used for visualisation"
    DTDFVocab:inputTo GrafanaDashboardEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model employed by the Trajectory Generator to compute swing‑free paths"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based dynamic simulation model used by the Simulation Service"
    DTDFVocab:inputTo SimulationEngineEnabler
]

// ----------------------------------------------------
// C11: Enablers (logical containers / tooling)
// ----------------------------------------------------
instance TimescaleDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑containerized TimescaleDB instance for persisting high‑frequency sensor data"
    DTDFVocab:enables ContinuousDataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for inter‑service signalling"
    DTDFVocab:enables MQTTSignallingService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard container providing real‑time visualisation"
    DTDFVocab:enables RealTimeVisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Container hosting the Trajectory Generator Service (python‑based, uses gantrylib)"
    DTDFVocab:enables OptimalTrajectoryGenerationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Container running the Simulation Service (dynamic crane physics simulation)"
    DTDFVocab:enables PhysicsBasedSimulationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Container running the Continuous Validation Service that compares executed and simulated trajectories"
    DTDFVocab:enables ContinuousValidationService
]

// ----------------------------------------------------
// C6: Services
// ----------------------------------------------------
instance ContinuousDataLoggingService : DTDFVocab:Service [
    base:desc "Continuously logs sensor streams into TimescaleDB and publishes MQTT events"
    DTDFVocab:provides RealTimeValidationViolationAlertInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualisation of historic motion data via Grafana"
    DTDFVocab:provides HistoricalMotionAnalyticsInsight
]

instance OptimalTrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free trajectories using the kinematic model"
    DTDFVocab:provides OptimalSwingFreeTrajectoryInsight
]

instance PhysicsBasedSimulationService : DTDFVocab:Service [
    base:desc "Runs physics‑based simulation of crane motions for virtual commissioning"
    DTDFVocab:provides SimulationOutputData
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates executed trajectories against simulation outputs and raises alerts"
    DTDFVocab:provides RealTimeValidationViolationAlertInsight
]

instance MQTTSignallingService : DTDFVocab:Service [
    base:desc "MQTT‑based signalling backbone for inter‑service communication"
    DTDFVocab:provides ValidationEventAction
]

// ----------------------------------------------------
// C17: Insights / Actions
// ----------------------------------------------------
instance OptimalSwingFreeTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight that the generated trajectory minimizes swing while moving the load"
]

instance RealTimeValidationViolationAlertInsight : DTDFVocab:Insight [
    base:desc "Real‑time alert when executed trajectory deviates beyond threshold from simulated trajectory"
]

instance HistoricalMotionAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Visual analytics of historic motion data to support operator decisions"
]

instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Simulation output data (position, velocity, swing) used by validation service"
    DTDFVocab:inputTo ValidationEngineEnabler
]

instance ValidationEventAction : DTDFVocab:Action [
    base:desc "Triggers fault‑localisation workflow when a validation violation occurs"
    DTDFVocab:IsAutomatic false
]

// ----------------------------------------------------
// C12: Environment & Physical Components (optional grouping)
// ----------------------------------------------------
instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains SwingAngleEncoder, Anemometer, CartMotorActuator, HoistMotorActuator, ElectromagnetActuator, MotorControllerActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends motion commands (position, velocity profiles) to the Physical Crane Interface, which forwards them to the motor controllers; the Trajectory Generator Service supplies optimal, swing‑free trajectories to the Control Application; validation alerts are pushed from the Continuous Validation Service to the operator via the Grafana Dashboard."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall architecture follows a C4 model: the Physical Crane interacts with a Python interface, which feeds the Logging Application, Control Application, and HMI; digital‑twin services communicate via MQTT and share state through the TimescaleDB; the Dashboard visualizes all data, completing a closed‑loop twin ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans design (CAD models of the crane in Autodesk Fusion 360 and a kinematic model), manufacturing (the physical crane assembled from the BOM), and operation (runtime data acquisition, simulation, validation, and visualization)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously computes distance metrics between measured trajectories and simulated counterparts, compares them against a predefined threshold, and triggers operator notifications when the threshold is exceeded; trajectory generation ensures zero residual swing, providing a fidelity check on motion planning."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange uses MQTT (Eclipse Mosquitto) for event signalling, HTTPS/SQL connections to TimescaleDB for time‑series storage, and a serial/USB link from the Python Physical Crane Interface to the Arduino‑based sensor/actuator controllers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software components run on a single personal computer; the Database, MQTT broker, and Grafana Dashboard are Docker‑containerized and launched via a docker‑compose command; the gantrylib Python module provides the remaining services as native processes."
]