// C1: Components
instance PhysicalCrane : DTDFVocab:Component [
    base:desc "Physical gantry crane with cart and hoist motors, inspired by harbor cranes"
]

instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Python program that reads motor and sensor states and publishes telemetry over MQTT"
]

instance ControlApplication : DTDFVocab:Component [
    base:desc "Python control logic that issues motor commands to the cart and hoist motors"
]

instance LoggingApplication : DTDFVocab:Component [
    base:desc "Service that writes all state samples to a TimescaleDB instance"
]

instance TrajectoryGeneratorService : DTDFVocab:Component [
    base:desc "Generates optimal trajectories based on a kinematic crane model"
]

instance HumanMachineInterface : DTDFVocab:Component [
    base:desc "Interactive web UI for operators to review logs and adjust trajectories"
]

instance MQTTBroker : DTDFVocab:Service [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service communication"
]

instance TimescaleDB : DTDFVocab:Component [
    base:desc "Time‑series database that stores position, velocity, swing angle, wind speed, trajectory labels and validation metrics"
]

instance GrafanaDashboard : DTDFVocab:Component [
    base:desc "Grafana dashboards visualizing real‑time monitoring and trend analysis of crane operations"
]

// C2: Acting Components
instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval motor controller driving the cart stepper motor"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval motor controller driving the hoist stepper motor"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist that can be activated to pick up containers"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encodes hoist swing angle, feeding data to the twin"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance WindSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer that measures wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartMotorPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Senses cart motor position via encoder feedback"
    DTDFVocab:producedData CartPositionDataTransmitted
]

instance CartMotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures current drawn by the cart motor"
    DTDFVocab:producedData CartCurrentDataTransmitted
]

instance HoistMotorPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Senses hoist motor position via encoder feedback"
    DTDFVocab:producedData HoistPositionDataTransmitted
]

instance HoistMotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures current drawn by the hoist motor"
    DTDFVocab:producedData HoistCurrentDataTransmitted
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedSensor
]

instance CartPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorPositionSensor
]

instance CartCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorCurrentSensor
]

instance HoistPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorPositionSensor
]

instance HoistCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorCurrentSensor
]

// C10: Models/Data
instance CADModel : DTDFVocab:Model [
    base:desc "Autodesk Fusion360 CAD model of the central gantry frame and motors"
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the TrajectoryGeneratorService to calculate optimal paths"
    DTDFVocab:inputTo TrajectoryGenEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the crane and its controllers implemented in Python, used by the SimulationService"
    DTDFVocab:inputTo SimulationEnabler
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Recorded swing angle data sampled from the swing angle encoder"
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData SwingAngleDataTransmitted
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Recorded wind speed data produced by the anemometer"
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData WindSpeedDataTransmitted
]

instance CartPositionData : DTDFVocab:Data [
    base:desc "Recorded cart position data from the cart motor encoder"
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData CartPositionDataTransmitted
]

instance CartCurrentData : DTDFVocab:Data [
    base:desc "Recorded cart motor current data"
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData CartCurrentDataTransmitted
]

instance HoistPositionData : DTDFVocab:Data [
    base:desc "Recorded hoist position data from the hoist motor encoder"
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData HoistPositionDataTransmitted
]

instance HoistCurrentData : DTDFVocab:Data [
    base:desc "Recorded hoist motor current data"
    DTDFVocab:inputTo MQTTBrokerEnabler
    DTDFVocab:fromData HoistCurrentDataTransmitted
]

// C11: Enablers
instance PhysicalCraneInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Interface that exposes sensor telemetry over MQTT topics"
    DTDFVocab:enables MQTTBroker
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto broker that routes published messages to subscribed services"
    DTDFVocab:enables LoggingService, TrajectoryGenService, SimulationService, ContinuousValidationService
]

instance LoggingAppEnabler : DTDFVocab:Enabler [
    base:desc "Enables data logging to TimescaleDB"
    DTDFVocab:enables LoggingService
]

instance TrajectoryGenEnabler : DTDFVocab:Enabler [
    base:desc "Enables the trajectory generation service using the kinematic model"
    DTDFVocab:enables TrajectoryGenService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enables the dynamic simulation service"
    DTDFVocab:enables SimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enables continuous validation comparing executed vs simulated trajectories"
    DTDFVocab:enables ContinuousValidationService
]

instance ControlAppEnabler : DTDFVocab:Enabler [
    base:desc "Enables the control application to send commands to cart and hoist motors"
    DTDFVocab:enables ControlService
]

instance HMIServerEnabler : DTDFVocab:Enabler [
    base:desc "Enables the human‑machine interface for operator interaction"
    DTDFVocab:enables HMIServerService
]

// C6: Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Writes telemetry data from MQTT to TimescaleDB"
    DTDFVocab:provides RealTimeMonitoringInsight, LogStorageInsight
]

instance TrajectoryGenService : DTDFVocab:Service [
    base:desc "Calculates optimal trajectories for the gantry crane"
    DTDFVocab:provides TrajectoryPlanningInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates crane dynamics and controller behavior"
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories against simulations and notifies operators upon deviations"
    DTDFVocab:provides DeviationAlertAction, ValidationMetricInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Sends stepper motor commands and activates electromagnet"
    DTDFVocab:provides MotorControlAction, EnvironmentInteractionAction
]

instance HMIServerService : DTDFVocab:Service [
    base:desc "Provides Grafana dashboards and logs review functionality"
    DTDFVocab:provides DashboardInsight, HistoricalAnalysisInsight
]

// C17: Insights/Actions
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring of crane dynamics such as position, velocity, and swing angle"
]

instance LogStorageInsight : DTDFVocab:Insight [
    base:desc "Insight into historical data retention and query performance in TimescaleDB"
]

instance TrajectoryPlanningInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory plans generated by the kinematic model"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation output of dynamic crane behavior and controller responses"
]

instance DeviationAlertAction : DTDFVocab:Action [
    base:desc "Notifies operators when executed trajectories deviate beyond configured thresholds"
    DTDFVocab:IsAutomatic true
]

instance ValidationMetricInsight : DTDFVocab:Insight [
    base:desc "Metrics used for validating crane operation against simulation"
]

instance MotorControlAction : DTDFVocab:Action [
    base:desc "Commands issued to cart or hoist stepper motors"
    DTDFVocab:IsAutomatic false
]

instance EnvironmentInteractionAction : DTDFVocab:Action [
    base:desc "Activation or deactivation of the hoist electromagnet"
    DTDFVocab:IsAutomatic false
]

instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Visualisation of real‑time telemetry and trend analysis in Grafana dashboards"
]

instance HistoricalAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analysis of operational data trends over time" 
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Twin’s Trajectory Generator Service outputs optimal movement trajectories (including swing‑free motion profiles) to the Control Application, which sends velocity setpoints to the cart and hoist motor controllers. Continuous Validation Service can produce alerts sent to the dashboard to trigger operator actions."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time operation and logging during crane execution; trajectory‑based validation performed after each executed trajectory; no specific sampling frequency is specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin constellation is coordinated by a Docker Compose network that links the Physical Crane Interface, Control Application, Logging Application, Trajectory Generator Service, Simulation Service, Continuous Validation Service, MQTT broker, TimescaleDB, and Grafana dashboard; data flows through MQTT topics and the database, while the dashboard provides a unified view for operators."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the full lifecycle: the CAD and kinematic models represent the design phase; the simulation and control scripts emulate the manufactured system; during operation, live telemetry logs and continuous validation monitor the PT and the twin’s behavior, allowing runtime adaptations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by using a physics‑based kinematic model for trajectory planning and a dynamic simulation that includes motor dynamics; validation is performed by continuously comparing measured state trajectories against simulated ones, computing distance metrics and triggering alerts if deviation exceeds a threshold, thereby verifying both model accuracy and system behaviour."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual data flow uses serial/USB communications to the Arduino, which forwards sensor data to the Logging Application. Virtual services communicate via MQTT (Eclipse Mosquitto) and store/retrieve data from TimescaleDB using SQL. Control commands follow the same path back to the motors."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The twin is deployed on a personal computer; the database, MQTT broker, and Grafana dashboards are run in Docker containers as defined in a Docker Compose file, while the gantrylib Python package is installed via pip and executed directly on the host. This lightweight deployment enables easy spin‑up and shut‑down."
]