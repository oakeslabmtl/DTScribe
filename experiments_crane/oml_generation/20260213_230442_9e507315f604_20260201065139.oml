// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring the hoist swing angle"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed near the crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorControllerStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Status signals from the Trinamic TMC4671 motor controllers"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerStatusSensor
]

// C10: Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of hoist swing angle values"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBContainer, MQTTBrokerContainer
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of ambient wind speed measurements"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBContainer, MQTTBrokerContainer
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Time‑series of motor controller status flags and error codes"
    DTDFVocab:fromData MotorStatusDataTransmitted
    DTDFVocab:inputTo TimescaleDBContainer, MQTTBrokerContainer
]

// C10: Models/Data
instance Fusion360CADModel : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane (Autodesk Fusion 360)"
    DTDFVocab:inputTo TrajectoryGeneratorContainer
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used for swing‑free trajectory computation"
    DTDFVocab:inputTo TrajectoryGeneratorContainer, SimulationEngineContainer
]

instance TrajectoryModel : DTDFVocab:Model [
    base:desc "Generated optimal trajectories stored as data"
    DTDFVocab:inputTo SimulationEngineContainer, ContinuousValidationContainer
]

instance SimulationTraceModel : DTDFVocab:Model [
    base:desc "Runtime simulation execution traces"
    DTDFVocab:inputTo ContinuousValidationContainer
]

// C11: Enablers
instance TimescaleDBContainer : DTDFVocab:Enabler [
    base:desc "Docker container running TimescaleDB for time‑series storage"
    DTDFVocab:enables DataLoggingService
]

instance MQTTBrokerContainer : DTDFVocab:Enabler [
    base:desc "Docker container running Eclipse Mosquitto MQTT broker"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, HumanMachineInterfaceService
]

instance GrafanaContainer : DTDFVocab:Enabler [
    base:desc "Docker container running Grafana for visualization"
    DTDFVocab:enables GrafanaDashboardService
]

instance TrajectoryGeneratorContainer : DTDFVocab:Enabler [
    base:desc "Docker container hosting the Trajectory Generator Service"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEngineContainer : DTDFVocab:Enabler [
    base:desc "Docker container hosting the Simulation Service"
    DTDFVocab:enables SimulationService
]

instance ContinuousValidationContainer : DTDFVocab:Enabler [
    base:desc "Docker container hosting the Continuous Validation Service"
    DTDFVocab:enables ContinuousValidationService
]

instance HMIContainer : DTDFVocab:Enabler [
    base:desc "Docker container providing the Human‑Machine Interface for operator control"
    DTDFVocab:enables HumanMachineInterfaceService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuously streams crane state to TimescaleDB and publishes over MQTT"
    DTDFVocab:provides VisualizationInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Visualizes time‑series data and alerts on Grafana dashboards"
    DTDFVocab:provides DashboardInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Computes optimal swing‑free trajectories using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs runtime simulation of crane dynamics and controller behavior"
    DTDFVocab:provides SimulationTraceInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories against simulated ones and raises alerts"
    DTDFVocab:provides ValidationAlertInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Operator control panel allowing manual parameter adjustments"
    DTDFVocab:provides OperatorControlAction
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Provides the optimal swing‑free path for the crane to follow"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Generates alerts when trajectory deviation exceeds predefined thresholds"
]

instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Displays real‑time crane state, sensor readings and alerts on Grafana"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Shows logged time‑series data summaries for analysis"
]

instance SimulationTraceInsight : DTDFVocab:Insight [
    base:desc "Presents simulated execution traces for comparison with real data"
]

instance OperatorControlAction : DTDFVocab:Action [
    base:desc "Allows the operator to modify control parameters via the HMI"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart along the gantry"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor lifting the hoist vertically"
]

instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval controller for the cart motor"
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval controller for the hoist motor"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist for picking up containers"
]

instance ArduinoActuatorInterface : DTDFVocab:ActingComponent [
    base:desc "Arduino board that drives motors and the electromagnet based on controller commands"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (Python) consumes trajectory commands from the Trajectory Generator Service via the MQTT broker and sends motion set‑points to the Physical Crane Interface, which forwards them to the motor controllers; the HMI can also issue commands that are relayed similarly."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical layer: crane hardware, Arduino, motor controllers, sensors; interface layer: Python Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface; virtual layer: TimescaleDB, MQTT broker, Grafana dashboard, Trajectory Generator, Simulation, Continuous Validation; all virtual components run as Docker containers on a personal computer and communicate via MQTT and SQL."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin includes design artefacts (CAD models of the crane), a kinematic model used for trajectory generation, and runtime artefacts (historical state data, simulation results) supporting both design and operational phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, checks against predefined thresholds and raises operator alerts, thereby providing runtime verification of the kinematic model."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor and controller data are transferred to the twin via a Python interface over serial/USB; state updates are published to the MQTT broker (Eclipse Mosquitto) and persisted in TimescaleDB via SQL; DT services subscribe/publish to MQTT topics; Grafana reads data from TimescaleDB via PostgreSQL protocol."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All virtual components are dockerised and launched together with Docker‑Compose on a single personal computer; the Python modules run locally; source code and Docker files are hosted on a public GitHub repository."
]