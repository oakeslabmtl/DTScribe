// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder attached to the hoist that measures the swing angle of the gantry crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer that measures ambient wind speed around the crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that reads motor controller state feedback for cart and hoist stepper motors"
    DTDFVocab:producedData MotorStateDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmission)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStateSensor
]

// C10: Data produced from sensors
instance SwingAngleTimeseries : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedTimeseries : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance MotorStateTimeseries : DTDFVocab:Data [
    base:desc "Time‑series of motor controller state feedback stored in TimescaleDB"
    DTDFVocab:fromData MotorStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C10: Models
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "3‑D CAD geometry of the lab‑scale gantry crane"
    DTDFVocab:inputTo GrafanaEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used for optimal trajectory generation"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the crane and its motor controllers"
    DTDFVocab:inputTo SimulationEnabler
]

// C10: Data generated by services/models
instance GeneratedTrajectoryData : DTDFVocab:Data [
    base:desc "Optimally generated crane trajectories produced by the trajectory generator"
    DTDFVocab:inputTo GrafanaEnabler, SimulationEnabler
]

instance SimulatedTrajectoryData : DTDFVocab:Data [
    base:desc "Simulated crane trajectories generated by the simulation service"
    DTDFVocab:inputTo ValidationEnabler
]

instance ValidationMetricData : DTDFVocab:Data [
    base:desc "Distance metrics comparing measured and simulated trajectories"
    DTDFVocab:inputTo ValidationEnabler
]

// C11: Enablers (logical containers & tooling)
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database hosted in a Docker container"
    DTDFVocab:enables ContinuousDataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker running in Docker, transports sensor streams"
    DTDFVocab:enables ContinuousDataLoggingService, RealTimeVisualizationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard container used for real‑time visualization"
    DTDFVocab:enables RealTimeVisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Dockerised trajectory generator service that consumes the kinematic model"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Dockerised crane dynamics simulation service"
    DTDFVocab:enables SimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Docker container hosting continuous validation and fault localisation services"
    DTDFVocab:enables ContinuousValidationService, FaultLocalisationService
]

instance PythonGantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module providing APIs for trajectory generation and validation"
    DTDFVocab:enables TrajectoryGeneratorService, ContinuousValidationService
]

instance DockerEngineEnabler : DTDFVocab:Enabler [
    base:desc "Docker engine orchestrating all containerised services"
    DTDFVocab:enables ContinuousDataLoggingService, RealTimeVisualizationService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService, FaultLocalisationService
]

// GitHub repository does not enable another Enabler (range violation removed)
instance GitHubRepoEnabler : DTDFVocab:Enabler [
    base:desc "GitHub repository storing source code and MkDocs documentation"
]

// C6: Services
instance ContinuousDataLoggingService : DTDFVocab:Service [
    base:desc "Continuously logs sensor time‑series into TimescaleDB via MQTT"
    DTDFVocab:provides DataLoggingInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time dashboards in Grafana using data from TimescaleDB"
    DTDFVocab:provides VisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal crane trajectories using the kinematic model to reduce swing"
    DTDFVocab:provides OptimalTrajectoryInsight, AdjustTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Emulates crane dynamics based on the dynamic simulation model"
    DTDFVocab:provides SimulatedTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates measured trajectories against simulated ones and raises alerts"
    DTDFVocab:provides ValidationAlertInsight
]

instance FaultLocalisationService : DTDFVocab:Service [
    base:desc "Localises faults by classifying time‑series sensor data"
    DTDFVocab:provides FaultLocalizationInsight, FaultMitigationAction
]

// C17: Insights & Actions
instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Indicates successful persistence of sensor logs in TimescaleDB"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Shows real‑time status of crane variables on Grafana dashboards"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Displays the generated optimal trajectory that minimizes swing"
]

instance AdjustTrajectoryAction : DTDFVocab:Action [
    base:desc "Operator can adjust trajectory parameters via the human‑machine interface"
    DTDFVocab:IsAutomatic false
]

instance SimulatedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Displays simulated crane motion for comparison with measured data"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert raised when validation distance exceeds the predefined threshold"
]

instance FaultLocalizationInsight : DTDFVocab:Insight [
    base:desc "Identifies probable fault source from abnormal sensor patterns"
]

instance FaultMitigationAction : DTDFVocab:Action [
    base:desc "Operator initiates corrective actions (e.g., motor reset) based on fault localisation"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor driven by a TMC4671‑Eval motor controller"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor driven by a TMC4671‑Eval motor controller"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist used to pick up and release pucks"
]

// C5: Miscellaneous components
instance ArduinoController : DTDFVocab:Component [
    base:desc "Arduino board that reads swing‑angle encoder and anemometer and forwards data via USB"
]

// C5: System under study
instance LabScaleGantryCraneSystem : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane exemplar with CAD model, kinematic and dynamic simulation models"
]

// C5: Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains SwingAngleEncoder, AnemometerSensor, MotorStateSensor, CartStepperMotor, HoistStepperMotor, ElectromagnetActuator, ArduinoController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal motion trajectories and sends them through the MQTT broker to the Control Application, which uses the Physical Crane Interface to issue velocity/position commands to the cart and hoist motor controllers; the Dashboard can also send control commands (e.g., homing, zeroing) to the crane via the same path."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall constellation consists of the physical crane and its controller, a Python‑based Physical Crane Interface, a Control Application, a Logging Application, an MQTT broker, a TimescaleDB database, a Grafana dashboard, and the three DT services (Trajectory Generator, Simulation, Continuous Validation) forming a tightly coupled cyber‑physical system deployed on a single PC."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the design stage (CAD models of the crane in Autodesk Fusion360 and the kinematic model) and the operation stage (real‑time sensor data, execution of trajectories, and validation); the manufacturing stage is represented indirectly by the Bill‑of‑Materials but not modelled as a separate twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by the Continuous Validation Service, which continuously compares measured trajectories with simulated ones, computes distance metrics, and checks them against predefined thresholds; violations trigger operator alerts on the dashboard, enabling corrective action."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses MQTT (Eclipse Mosquitto) for event and command messages, and SQL/REST interfaces to TimescaleDB for data retrieval; all components run on the same host machine and connect via a Docker‑provided virtual network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The database, MQTT broker and Grafana dashboard are Docker containers managed by Docker‑Compose; the remaining Python services and applications run directly on the host PC after installing the gantrylib package via pip; the entire setup can be started with a single Docker‑Compose command."
]