// C3: Physical Sensing Components
instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor reading the crane's longitudinal position from the motion controller"
    DTDFVocab:producedData PositionDataTransmitted
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Velocity sensor measuring the crane's linear velocity from the motion controller"
    DTDFVocab:producedData VelocityDataTransmitted
]

instance ActuatorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Actuator status sensor reporting the operational state of hoist, jib, and rails"
    DTDFVocab:producedData ActuatorStatusDataTransmitted
]

// C4: Physical-to-virtual interaction
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySensor
]

instance ActuatorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ActuatorStatusSensor
]

// C10: Models/Data
instance PositionData : DTDFVocab:Data [
    base:desc "Timestamped position measurement stored in TimescaleDB via PostgreSQL binary protocol"
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo LoggingApplication, SimulationEngine, WebVisualizationEnabler
]

instance VelocityData : DTDFVocab:Data [
    base:desc "Timestamped velocity measurement stored in TimescaleDB via PostgreSQL binary protocol"
    DTDFVocab:fromData VelocityDataTransmitted
    DTDFVocab:inputTo LoggingApplication, SimulationEngine, WebVisualizationEnabler
]

instance ActuatorStatusData : DTDFVocab:Data [
    base:desc "Timestamped actuator status stored in TimescaleDB via PostgreSQL binary protocol"
    DTDFVocab:fromData ActuatorStatusDataTransmitted
    DTDFVocab:inputTo LoggingApplication, SimulationEngine, WebVisualizationEnabler
]

// C11: Enablers
instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Python program that streams sensor data into TimescaleDB over the network using the native PostgreSQL wire protocol"
    DTDFVocab:enables RealTimeMonitoringService, HistoricalDataLoggingService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Open‑source kinematic modelling framework that receives real‑time sensor data to optimise trajectories and validate the dynamic model"
    DTDFVocab:enables TrajectoryOptimizationService, KinematicModelValidationService
]

instance WebVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source libraries such as Plotly and Matplotlib that render 3D CAD models and time‑series plots via a web interface"
    DTDFVocab:enables WebDataVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of the physical crane via real‑time sensor streams from the controller"
    DTDFVocab:provides RealTimeOperationalInsight
]

instance TrajectoryOptimizationService : DTDFVocab:Service [
    base:desc "Optimal control through model‑based trajectory optimisation that reduces energy consumption and wear"
    DTDFVocab:provides TrajectoryOptimizationInsight, TrajectoryCommandAdjustmentAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Historical data logging where all sensor outputs are timestamped and stored for later analysis"
    DTDFVocab:provides HistoricalDataInsight
]

instance WebDataVisualizationService : DTDFVocab:Service [
    base:desc "Interactive data visualization via a web interface that renders 3D CAD models and displays time‑series plots"
    DTDFVocab:provides DataVisualizationInsight
]

instance KinematicModelValidationService : DTDFVocab:Service [
    base:desc "Continuous validation by updating the kinematic model against live measurements to detect drift or faults"
    DTDFVocab:provides KinematicValidationInsight, FaultRecoveryAction
]

// C17: Insights/Actions
instance RealTimeOperationalInsight : DTDFVocab:Insight [
    base:desc "Insight into real‑time crane operational status derived from continuous sensor streams"
]

instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight into optimal trajectories that reduce energy consumption and wear"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight into historical sensor data for retrospective analysis and trend assessment"
]

instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight into live 3D visualisations of the crane and associated time‑series plots"
]

instance KinematicValidationInsight : DTDFVocab:Insight [
    base:desc "Insight into drift or faults detected by continuous model validation against live measurements"
]

instance TrajectoryCommandAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated adjustment of control commands based on trajectory optimisation outputs"
    DTDFVocab:IsAutomatic true
]

instance FaultRecoveryAction : DTDFVocab:Action [
    base:desc "Manual fault recovery action triggered by detected drift or fault in the kinematic model"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate in the Control Application, which takes operator orders from the Human Machine Interface. Commands are encoded as high‑level movement trajectories and passed through the Physical Crane Interface to the physical crane controllers via a Python API over TCP. The Digital Twin issues these commands without explicit authentication or verification steps, and the Physical Crane Interface forwards them to the hardware where they are executed. No explicit feedback loop or command‑execution confirmation mechanism is described in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration is built around containerization or virtualization for easy deployment. In GreenhouseDT, the stack consists of a virtual‑machine image that bundles an InfluxDB time‑series database for sensor data and an ActiveMQ message broker for real‑time data flow. Air Quality Management leverages Microsoft Azure services (IoT Hub, Azure Functions, and Azure Stream Analytics) to ingest sensor streams from a Raspberry‑Pi and drive an AutomationML‐based Digital Twin model; the same pattern uses a cloud‑hosted message bus (Service Bus) for cross‑service communication. The gantry crane example references containerized deployment but does not specify a concrete orchestration platform. Overall, the system employs a central message bus (ActiveMQ or Azure Service Bus), persistent data stores (InfluxDB or Azure Table/Blob), and containerized application components running on virtual machines or cloud instances."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the Digital Twin is orchestrated by an MQTT broker, which publishes and subscribes to topics for coordination between the Trajectory Generator, Simulation, Continuous Validation, and Dashboard services. The Physical Crane Interface and Logging Application communicate over the local network using TCP, with data persisted through PostgreSQL’s wire protocol to TimescaleDB. The documents do not specify bandwidth, latency, redundancy, or security protocols beyond the use of MQTT and TCP."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All Digital Twin containers (Python services, TimescaleDB, Grafana dashboard, MQTT broker) are deployed on the same on‑premises host that houses the physical crane, as indicated by the direct use of local network connections and a single TimescaleDB instance. No explicit cloud or edge deployment, scalability strategy, or availability mechanisms are mentioned in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is performed primarily via message passing protocols: ActiveMQ for on‑premises instrumentation in GreenhouseDT, Azure IoT Hub/Service Bus for Azure‑based ingestion in Air Quality Management, and AutomationML as an interoperability standard for semantic modeling. Data is exchanged in JSON or binary formats over MQTT/AMQP, and the Digital Twins expose REST/HTTPS APIs for platform integration. The dashboards and simulation engines consume the published data streams; no direct integration with third‑party enterprise systems is described beyond the cloud services and message brokers cited."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplar adopts the AutomationML standard for modeling the plant environment and the twin representation. Other components rely on common industry protocols (e.g., MQTT for message brokering inferred from the ActiveMQ mention in GreenhouseDT, time‑series database InfluxDB, and containerisation via Docker or virtual machines). No explicit certification or compliance framework is referenced."
]