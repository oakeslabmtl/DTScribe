// C3: Physical Sensing Components
instance SwingAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder mounted on the gantry frame, measuring the horizontal arm rotation of the miniature crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer integrated into the crane structure to measure ambient wind speed affecting crane dynamics"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartMotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded status sensor on the TMC4671 cart motor driver that reports motor current and fault flags"
    DTDFVocab:producedData CartMotorStatusDataTransmitted
]

instance HoistMotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded status sensor on the TMC4671 hoist motor driver that reports motor current and fault flags"
    DTDFVocab:producedData HoistMotorStatusDataTransmitted
]

// C4: Physical‑to‑Virtual Interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensor
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance CartMotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorStatusSensor
]

instance HoistMotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorStatusSensor
]

instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensor, AnemometerSensor, CartMotorStatusSensor, HoistMotorStatusSensor
]

instance ControlCommandDataTransmitted : DTDFVocab:DataTransmitted [
]

// C10: Models/Data
instance GantryCADModel : DTDFVocab:Model [
    base:desc "3‑D CAD geometry model of the miniature gantry crane used for simulation and validation"
    DTDFVocab:inputTo SimulationEnabler
]

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Analytical kinematic model providing collision‑free optimum trajectories for the crane arm"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance CraneDynamicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based dynamic simulation model of the crane and its controllers"
    DTDFVocab:inputTo SimulationEnabler
]

instance CraneStateTimeseriesData : DTDFVocab:Data [
    base:desc "TimescaleDB time‑series log of all crane state variables, including motor positions, encoder angles, and wind speed"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData CraneStateDataTransmitted
]

instance CraneCommandTimeseriesData : DTDFVocab:Data [
    base:desc "TimescaleDB time‑series log of all crane command set‑points generated by the control application"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData ControlCommandDataTransmitted
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker enabling real‑time message exchange between data logging and validation services"
    DTDFVocab:enables MQTTBrokerService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB enabler that persists all state and command time‑series data"
    DTDFVocab:enables TimescaleDBLoggingService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the trajectory generator service that uses analytical kinematics"
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the crane physics simulation service"
    DTDFVocab:enables CraneSimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the continuous validation service that compares logged trajectories against simulated ones"
    DTDFVocab:enables ContinuousValidationService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the Grafana dashboard service providing live telemetry visualisations"
    DTDFVocab:enables GrafanaDashboardService
]

instance ControlApplicationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the Python‑based control application that issues motor set‑points"
    DTDFVocab:enables ControlApplicationService
]

// C6: Services
instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Service that publishes sensor and state data to MQTT topics"
    DTDFVocab:provides MessagingInsight
]

instance TimescaleDBLoggingService : DTDFVocab:Service [
    base:desc "Service that persists logged state and command time‑series to TimescaleDB"
    DTDFVocab:provides DataStorageInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service generating optimal trajectories using the crane’s analytical kinematic model"
    DTDFVocab:provides TrajectoryPerformanceInsight
]

instance CraneSimulationService : DTDFVocab:Service [
    base:desc "Service running physics‑based simulation of the crane dynamics and controller"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service performing real‑time distance‑metric validation of logged against simulated trajectories"
    DTDFVocab:provides ValidationMetricInsight, ValidationAlertAction
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Service providing live telemetry visualisations and confidence bounds via Grafana dashboards"
    DTDFVocab:provides DashboardVisualizationInsight
]

instance ControlApplicationService : DTDFVocab:Service [
    base:desc "Service that receives operator commands and sends velocity/position set‑points to the motor drivers"
    DTDFVocab:provides CommandSendingInsight, OperatorInterventionAction
]

// C17: Insights / Actions
instance TrajectoryPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight on optimal trajectory execution, reporting path efficiency and deviation metrics"
]

instance ValidationMetricInsight : DTDFVocab:Insight [
    base:desc "Insight reporting real‑time trajectory error distances between logged measurements and simulated predictions"
]

instance ValidationAlertAction : DTDFVocab:Action [
    base:desc "Automatic alert action triggered when trajectory deviation exceeds threshold limits"
    DTDFVocab:IsAutomatic true
]

instance DataStorageInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful persistence of state and command logs in TimescaleDB"
]

instance MessagingInsight : DTDFVocab:Insight [
    base:desc "Insight validating that sensor data is correctly published to MQTT topics"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight providing simulated trajectory predictions for comparison with real measurements"
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight detailing live telemetry and confidence bounds displayed on Grafana dashboards"
]

instance CommandSendingInsight : DTDFVocab:Insight [
    base:desc "Insight confirming that operator or automated commands are received by the control application"
]

instance OperatorInterventionAction : DTDFVocab:Action [
    base:desc "Manual operator action available to adjust configuration or intervene during crane operation"
    DTDFVocab:IsAutomatic false
]

instance FaultProbabilityInsight : DTDFVocab:Insight [
    base:desc "Insight predicting fault likelihood based on time‑series classification of motor loads and sensor data"
]

instance HistoricalTrendInsight : DTDFVocab:Insight [
    base:desc "Insight summarising historical trends in motor loads and trajectory performance over time"
]

// C2: Acting Components
instance TMC4671ControlApplication : DTDFVocab:ActingComponent [
    base:desc "Python‑based control application that sends velocity and position setpoints to the TMC4671 motor drivers and controls the electromagnet"
]

instance CartMotorControllerActingComponent : DTDFVocab:ActingComponent [
    base:desc "TMC4671 controller commanding the cart stepper motor drive"
]

instance HoistMotorControllerActingComponent : DTDFVocab:ActingComponent [
    base:desc "TMC4671 controller commanding the hoist stepper motor"
]

instance ElectromagnetActingComponent : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling the pickup electromagnet via the same interface as the motor controllers"
]

// C7: Environment
instance CraneExperimentalSetupEnvironment : DTDFVocab:Environment [
    base:contains GantryFrameComponent, CartMotorComponent, HoistMotorComponent, ElectromagnetComponent, SwingAngleEncoderComponent, AnemometerComponent, ArduinoUnitComponent, PSUComponent, PhysicalControlElectronicsComponent
]

// C8: Components
instance GantryFrameComponent : DTDFVocab:Component [
    base:desc "Gantry frame forming the scaffold for cart and hoist motion"
]

instance CartMotorComponent : DTDFVocab:Component [
    base:desc "Stepper wheel motor driven by TMC4671, moving the cart horizontally along the gantry"
]

instance HoistMotorComponent : DTDFVocab:Component [
    base:desc "Stepper wheel motor driven by TMC4671, lifting the arm vertically"
]

instance ElectromagnetComponent : DTDFVocab:Component [
    base:desc "Electromagnet actuated to pick up and release small pucks representing container payloads"
]

instance SwingAngleEncoderComponent : DTDFVocab:Component [
    base:desc "Hardware encoder attached to the swing arm for accurate angle measurement"
]

instance AnemometerComponent : DTDFVocab:Component [
    base:desc "Wind speed sensor mounted on the crane structure"
]

instance ArduinoUnitComponent : DTDFVocab:Component [
    base:desc "Arduino board that reads sensor signals, converts them into digital measurements, and publishes them to the twin via the Physical Crane Interface"
]

instance PSUComponent : DTDFVocab:Component [
    base:desc "12 V power supply unit supplying DC voltage to all electronic subsystems"
]

instance PhysicalControlElectronicsComponent : DTDFVocab:Component [
    base:desc "Integrated control electronics including TMC4671 motor drivers and the control application runtime"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service computes optimal Cartesian trajectories using a kinematic model of the crane and publishes the resulting motor commands to the Physical Crane Interface over MQTT. The Control Application consumes these commands and forwards them to the appropriate motor controllers. Resulting state changes are reflected back to the twin via the logging stream."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation comprises the Physical Crane and its control interface, the Control Application, Logging Application, HMI, and the digital twin stack: Database, MQTT broker, Trajectory Generator Service, Simulation Service, Continuous Validation Service, Dashboard. All are connected through a local network via MQTT for inter‑service communication, with persistent state in TimescaleDB. The whole system is orchestrated by a Docker Compose setup deployed on a personal PC."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The exemplar spans all twin lifecycle stages: (a) design‑time – CAD models in Autodesk Fusion360 and kinematic models used by trajectory generation; (b) manufacturing – BOM assembled in the lab, custom shield and Arduino firmware deployed; (c) operation – runtime services (control, logging, validation) deployed via Docker Compose on a host PC, with data collection, visualization and fault monitoring continuously active."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation is performed by the Continuous Validation Service which computes distance metrics between executed trajectories (PT logs) and simulated trajectories, comparing them against a pre‑defined acceptable threshold. The kinematic model’s fidelity is ensured during design and validated against physical measurements. Uncertainty arising from sensor noise, motor delays, and wind is implicitly addressed by the simulation confidence bounds."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Intra‑twin communication uses MQTT (Eclipse Mosquitto) over TCP on the local host. Data persistence via TimescaleDB uses PostgreSQL over TCP. The Physical Crane Interface communicates with the Arduino microcontroller over a serial/USB link; the controllers are addressed by the motor drivers via the Python program."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital twin services are packaged as Docker containers and launched via a Docker Compose configuration on the same host PC as the physical crane. The database, broker, and dashboard containers are initialised automatically. The repository is hosted on GitHub and serves documentation via MkDocs on GitHub Pages."
]