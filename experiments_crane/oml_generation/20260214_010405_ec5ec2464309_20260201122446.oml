// Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder mounted on the hoist measuring swing angle"
    DTDFVocab:producedData SwingAngleData
]
instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer sensor mounted on the crane measuring wind speed"
    DTDFVocab:producedData WindSpeedData
]
instance CartMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the cart stepper motor measuring position"
    DTDFVocab:producedData CartMotorCountData
]
instance HoistMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the hoist stepper motor measuring position"
    DTDFVocab:producedData HoistMotorCountData
]

// Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Step motor controlling the cart on the gantry rail"
]
instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Step motor controlling the hoist for vertical movement"
]
instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet actuator at the hoist end for gripping containers"
]

// Data Transmitted (via MQTT)
instance SwingAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance WindSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]
instance CartMotorCountData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoder
]
instance HoistMotorCountData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoder
]

// Time‑series Data stored in TimescaleDB
instance SwingAngleTimeSeriesData : DTDFVocab:Data [
    base:desc "Historical time‑series record of hoist swing angle stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData SwingAngleData
]
instance WindSpeedTimeSeriesData : DTDFVocab:Data [
    base:desc "Historical time‑series record of wind speed stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData WindSpeedData
]
instance CartMotorCountTimeSeriesData : DTDFVocab:Data [
    base:desc "Historical time‑series record of cart motor steps stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData CartMotorCountData
]
instance HoistMotorCountTimeSeriesData : DTDFVocab:Data [
    base:desc "Historical time‑series record of hoist motor steps stored in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData HoistMotorCountData
]
instance ValidationMetricsTimeSeriesData : DTDFVocab:Data [
    base:desc "Historical record of validation metrics comparing simulated and real trajectories"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData SwingAngleData
    DTDFVocab:fromData WindSpeedData
    DTDFVocab:fromData CartMotorCountData
    DTDFVocab:fromData HoistMotorCountData
]

// Models
instance Fusion360CADModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane in Autodesk Fusion 360"
    DTDFVocab:inputTo Fusion360DesignerEnabler
]
instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Kinematic model derived from the CAD geometry for trajectory planning"
    DTDFVocab:inputTo PythonGantryLibEnabler
]

// Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance for time‑series storage of telemetry and validation data"
    DTDFVocab:enables HistoricalDataLoggingService, ContinuousValidationService, TrajectoryGeneratorService
]
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for real‑time telemetry streaming"
    DTDFVocab:enables TrajectoryGeneratorService, ContinuousValidationService
]
instance PythonGantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib library for trajectory generation and simulation"
    DTDFVocab:enables TrajectoryGeneratorService, PhysicalSimulationService
]
instance Fusion360DesignerEnabler : DTDFVocab:Enabler [
    base:desc "Autodesk Fusion 360 designer tool for CAD model creation"
]

// Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal companion trajectories for the crane based on kinematic model and historical data"
    DTDFVocab:provides TrajectoryOptimizationOutcomeInsight, TrajectoryPerformanceInsight
]
instance PhysicalSimulationService : DTDFVocab:Service [
    base:desc "Runs physics‑based simulation of the crane using the kinematic model"
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates simulated trajectories against real telemetry"
    DTDFVocab:provides FaultDetectionInsight, ValidationBreachesAction
]
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Logs all telemetry and simulation traces into TimescaleDB for historical analysis"
    DTDFVocab:provides HistoricalDataAnalysisInsight
]
instance InteractiveDashboardService : DTDFVocab:Service [
    base:desc "Provides interactive data visualization through a Grafana dashboard"
    DTDFVocab:provides OperatorNotificationAction
]

// Insights
instance TrajectoryOptimizationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Insight into optimized trajectory yields from the trajectory generator"
]
instance TrajectoryPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight comparing reference and actual trajectory execution performance"
]
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight identifying faults or deviations between simulated and real trajectories"
]
instance HistoricalDataAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight derived from historical telemetry data for teaching and decision support"
]

// Actions
instance ValidationBreachesAction : DTDFVocab:Action [
    base:desc "Automatic action to notify operators when validation metrics breach thresholds"
    DTDFVocab:IsAutomatic true
]
instance OperatorNotificationAction : DTDFVocab:Action [
    base:desc "Automatic action to display alerts on the Grafana dashboard for operator awareness"
    DTDFVocab:IsAutomatic true
]

// Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains CartStepperMotor, HoistStepperMotor, ElectromagnetActuator, SwingAngleEncoder, Anemometer, CartMotorEncoder, HoistMotorEncoder
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Optimized trajectory commands (position, velocity profiles) are generated by the trajectory generator service, passed through the control application, and sent to the motors via the crane interface; the continuous validation service may trigger operator alerts through the dashboard but does not directly command the hardware"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A containerized architecture where the physical system (crane, controllers, sensors) is linked via the crane interface to a suite of application containers (control app, logging app, human‑machine interface) that interact with the digital twin side (database, MQTT broker, dashboard, trajectory generator, simulation, continuous validation) all orchestrated through a Docker Compose stack on a personal computer"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (CAD model creation, kinematic modeling), manufacturing (assembly of the physical crane and electronics), and operation (runtime monitoring, continuous validation, and adaptation of control parameters during use)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous validation compares real and simulated trajectories, computing distance metrics against a user‑defined threshold; when the threshold is breached operators are notified via the dashboard; the fidelity of the kinematic model is anchored to the CAD geometry and updated as the physical system evolves"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Serial communication (Arduino UART) between the crane interface and physical electronics; MQTT (Eclipse Mosquitto) broker for intra‑service messaging; TimescaleDB accessed over PostgreSQL protocol; all container communication occurs over Docker‑managed network on localhost"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Containerized deployment using Docker Compose on a single personal computer; vertical stack includes TimescaleDB, Mosquitto broker, Grafana, and six application containers; source code and configuration hosted on public GitHub repository"
]