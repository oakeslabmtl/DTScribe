// C2: Acting Components
instance LinearRailActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator that drives the gantry crane's linear rail along the X‑axis."
]

instance RotationalActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator (hoist motor) that rotates the crane around the vertical Z‑axis."
]

// C3: Physical sensing components
instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the linear rail position along the X‑axis."
    DTDFVocab:producedData PositionTelemetry
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the velocity of the gantry crane's linear motion."
    DTDFVocab:producedData VelocityTelemetry
]

instance LoadSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting the load being hoisted by the crane."
    DTDFVocab:producedData LoadTelemetry
]

instance StatusFlagSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing status flags from the crane controller (e.g., fault, overload)."
    DTDFVocab:producedData StatusFlagTelemetry
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in a Raspberry‑Pi monitoring indoor air quality."
    DTDFVocab:producedData TempTelemetry
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor embedded in a Raspberry‑Pi monitoring indoor air quality."
    DTDFVocab:producedData HumidityTelemetry
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor embedded in a Raspberry‑Pi monitoring indoor air quality."
    DTDFVocab:producedData CO2Telemetry
]

// C4: Physical-to-virtual data transmission
instance PositionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

instance VelocityTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySensor
]

instance LoadTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadSensor
]

instance StatusFlagTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StatusFlagSensor
]

instance TempTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance CO2Telemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

// C10: Modeling & Data
instance PositionData : DTDFVocab:Data [
    base:desc "Time‑stamped position data of the gantry crane."
    DTDFVocab:fromData PositionTelemetry
    DTDFVocab:inputTo CraneLoggingEnabler, CraneValidationEnabler, CraneSimulationEnabler
]

instance VelocityData : DTDFVocab:Data [
    base:desc "Time‑stamped velocity data of the gantry crane."
    DTDFVocab:fromData VelocityTelemetry
    DTDFVocab:inputTo CraneLoggingEnabler, CraneValidationEnabler, CraneSimulationEnabler
]

instance LoadData : DTDFVocab:Data [
    base:desc "Time‑stamped load data being hoisted by the crane."
    DTDFVocab:fromData LoadTelemetry
    DTDFVocab:inputTo CraneLoggingEnabler, CraneValidationEnabler
]

instance StatusFlagData : DTDFVocab:Data [
    base:desc "Time‑stamped status flag data from the crane controller."
    DTDFVocab:fromData StatusFlagTelemetry
    DTDFVocab:inputTo CraneLoggingEnabler, CraneValidationEnabler
]

instance TempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature data from the indoor air quality sensor."
    DTDFVocab:fromData TempTelemetry
    DTDFVocab:inputTo AzureIAQPipelinesEnabler
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Time‑stamped humidity data from the indoor air quality sensor."
    DTDFVocab:fromData HumidityTelemetry
    DTDFVocab:inputTo AzureIAQPipelinesEnabler
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Time‑stamped CO₂ data from the indoor air quality sensor."
    DTDFVocab:fromData CO2Telemetry
    DTDFVocab:inputTo AzureIAQPipelinesEnabler
]

instance KinematicSimulationModel : DTDFVocab:Model [
    base:desc "CAD‑based kinematic model simulating the two‑degree‑of‑freedom gantry crane."
    DTDFVocab:inputTo CraneSimulationEnabler
]

// C11: Enablers
instance CraneLoggingEnabler : DTDFVocab:Enabler [
    base:desc "Python interface that streams sensor data into TimescaleDB for historical logging."
    DTDFVocab:enables HistoricalLoggingService
]

instance CraneValidationEnabler : DTDFVocab:Enabler [
    base:desc "Component that feeds live sensor data into the continuous validation engine."
    DTDFVocab:enables ContinuousValidationService
]

instance CraneSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python program that supplies sensor data to the CAD‑based kinematic simulation engine."
    DTDFVocab:enables MotionPlanningService
]

instance CraneVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Framework that streams the crane state and planned trajectory to a real‑time 3‑D viewer."
    DTDFVocab:enables RealTime3DVisualizationService
]

instance CraneControlEnabler : DTDFVocab:Enabler [
    base:desc "Bidirectional link that delivers refined control commands from the digital twin to the physical crane."
    DTDFVocab:enables BiDirectionalFeedbackService
]

instance AzureIAQPipelinesEnabler : DTDFVocab:Enabler [
    base:desc "AutomationML‑based pipeline that ingests Raspberry‑Pi sensor data into Azure for IAQ analytics."
    DTDFVocab:enables IAQSimulationService
]

// C6: Services
instance MotionPlanningService : DTDFVocab:Service [
    base:desc "Optimizes motion planning and real‑time control to accelerate motion while respecting actuator limits."
    DTDFVocab:provides MotionPlanCommandAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares live sensor data with kinematic model predictions and flags deviations."
    DTDFVocab:provides DeviationInsight
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Logs sensor streams and control commands for post‑hoc analysis."
    DTDFVocab:provides HistoricalDataInsight
]

instance RealTime3DVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time 3‑D visualization of the crane state and planned trajectory."
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance BiDirectionalFeedbackService : DTDFVocab:Service [
    base:desc "Executes refined control instructions on the physical crane."
    DTDFVocab:provides ControlCommandAction
]

instance IAQSimulationService : DTDFVocab:Service [
    base:desc "Exposes real‑time visualization, numerical simulation, and predictive analytics of indoor air quality to prevent virus spread."
    DTDFVocab:provides VirusSpreadPredictionInsight
]

// C17: Insights/Actions
instance MotionPlanCommandAction : DTDFVocab:Action [
    base:desc "Control command to execute the optimized trajectory."
    DTDFVocab:IsAutomatic true
]

instance DeviationInsight : DTDFVocab:Insight [
    base:desc "Flagged deviation between live sensor data and the kinematic model predictions."
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Aggregated historical logs of sensor data and control commands."
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live 3‑D representation of crane position and trajectory."
]

instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Command sent back to the physical crane controller."
    DTDFVocab:IsAutomatic true
]

instance VirusSpreadPredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics of indoor air quality indicating potential virus spread."
]

// C10: Models/Data (other)
instance IAQSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model for indoor air quality and virus spread prediction."
    DTDFVocab:inputTo AzureIAQPipelinesEnabler
]

// C3: Environment and Components
instance SteelFrame : DTDFVocab:Component [
    base:desc "Steel frame forming the structural backbone of the gantry crane."
]

instance LinearRail : DTDFVocab:Component [
    base:desc "Linear rail enabling horizontal translational motion of the crane."
]

instance HoistMotor : DTDFVocab:Component [
    base:desc "Hoist motor serving as the rotational actuator of the crane."
]

instance DigitalController : DTDFVocab:Component [
    base:desc "Digital controller managing actuator commands and monitoring."
]

instance RaspberryPi : DTDFVocab:Component [
    base:desc "Embedded Raspberry‑Pi hosting temperature, humidity, and CO₂ sensors for IAQ monitoring."
]

instance LabGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains SteelFrame, LinearRail, HoistMotor, DigitalController, RaspberryPi
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are issued by the Control Application, a Python component that consumes trajectory data from the Trajectory Generator Service. The Control Application uses the Physical Crane Interface to translate high‑level trajectory commands (target positions, speeds, and accelerations) into concrete controller instructions sent over a TCP/IP socket to the crane’s low‑level controllers. The documents do not describe explicit authentication or encryption, but the execution of a command is confirmed indirectly through the Logging Application’s continuous state capture, which stores the resulting physical state in TimescaleDB – the state is then visualised in the Grafana dashboard and compared by the Continuous Validation Service."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin relies on an MQTT broker to mediate inter‑service signalling between the Trajectory Generator, Simulation, Validation services, and the Dashboard. The broker operates over the standard MQTT protocol (TCP/IP, default port 1883) and is configured to publish trajectory events, state updates, and validation thresholds, while services subscribe to relevant topics. No additional security mechanisms such as TLS or username/password authentication are detailed in the documents, nor are bandwidth or latency requirements specified."
]