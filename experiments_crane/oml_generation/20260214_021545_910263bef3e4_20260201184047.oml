// C2: Acting Components
instance SwingAngleEncoder : DTDFVocab:ActingComponent [
    base:desc "Measures the hoist's swinging motion for trajectory validation and operational monitoring"
]

instance CartMotorSystem : DTDFVocab:Actuator [
    base:desc "Comprises TMC4671-Eval motor controller paired with a stepper motor for horizontal movement along the gantry"
    DTDFVocab:producedData SwingAngleDataTransmission
]

instance HoistMotorSystem : DTDFVocab:Actuator [
    base:desc "Comprises TMC4671-Eval motor controller paired with a stepper motor for vertical hoisting"
    DTDFVocab:producedData SwingAngleDataTransmission
]

instance Electromagnet : DTDFVocab:Actuator [
    base:desc "Used for container pickup in the lab-scale gantry crane system"
    DTDFVocab:producedData ArduinoDataTransmission
]

instance ArduinoControlUnit : DTDFVocab:Actuator [
    base:desc "Handles sensor/control integration for electromagnet, encoders, and embedded systems"
    DTDFVocab:producedData ArduinoDataTransmission
]

// C3: Physical Sensing Components
instance SwingAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Swing Angle Encoder for measuring the hoist's swinging motion"
    DTDFVocab:producedData SwingAngleDataTransmission
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer for measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmission
]

instance ArduinoSensorInterface : DTDFVocab:SensingComponent [
    base:desc "Arduino-based sensor integration handling data from electromagnet, encoders, and embedded systems"
    DTDFVocab:producedData ArduinoDataTransmission
]

// C4: Data Transmission
instance SwingAngleDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleSensor, CartMotorSystem, HoistMotorSystem
]

instance WindSpeedDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance ArduinoDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Electromagnet, ArduinoControlUnit, ArduinoSensorInterface
]

// Rest of the code remains unchanged from original
// C10: Models/Data
instance Fusion360CraneModel : DTDFVocab:Model [
    base:desc "Autodesk Fusion 360 CAD models of the crane frame and components"
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance CapellaKinematicModel : DTDFVocab:Model [
    base:desc "Capella Arcadia models for trajectory planning and kinematic modeling"
    DTDFVocab:inputTo TrajectoryGeneratorService
]

instance TimescaleDBOperationalLogs : DTDFVocab:Data [
    base:desc "Real-time operational logs stored in TimescaleDB for historical analysis"
    DTDFVocab:fromData SwingAngleDataTransmission, WindSpeedDataTransmission, ArduinoDataTransmission
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance TrajectoryExecutionLogs : DTDFVocab:Data [
    base:desc "Trajectory execution logs including position, velocity, and operational status"
    DTDFVocab:fromData SwingAngleDataTransmission
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance EnvironmentalConditionsData : DTDFVocab:Data [
    base:desc "Environmental conditions data including wind speed measurements"
    DTDFVocab:fromData WindSpeedDataTransmission
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance SimulationValidationData : DTDFVocab:Data [
    base:desc "Data for continuous validation comparing executed vs. simulated trajectories"
    DTDFVocab:fromData SwingAngleDataTransmission
    DTDFVocab:inputTo SimulationService
]

instance OptimizedTrajectoryPaths : DTDFVocab:Data [
    base:desc "Optimized and executed paths generated by the trajectory generator service"
    DTDFVocab:fromData CapellaKinematicModel
    DTDFVocab:inputTo TrajectoryGeneratorService
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL-based) for time-series database storage"
    DTDFVocab:enables DataLoggingService, ValidationService
]

instance MosquittoMQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for real-time data transmission"
    DTDFVocab:enables DataLoggingService
]

instance PythonGantryLib : DTDFVocab:Enabler [
    base:desc "Python module gantrylib for modular service integration"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ValidationService, DataLoggingService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Interactive dashboard for real-time and historical trajectory visualization"
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuous logging of crane state data to TimescaleDB via MQTT broker"
    DTDFVocab:provides TrajectoryExecutionLogs, EnvironmentalConditionsData, TimescaleDBOperationalLogs
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Kinematic-based trajectory planning to minimize swinging motion and energy consumption"
    DTDFVocab:provides OptimizedTrajectoryPaths
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Discrete-event simulation service replicating crane behavior for validation"
    DTDFVocab:provides SimulationValidationData
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Real-time comparison of executed trajectories against simulations using distance metrics"
    DTDFVocab:provides InsightTrajectoryDeviation
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Time-series classification for fault localization in sensor data"
    DTDFVocab:provides InsightFaultClassification
]

instance PerformanceOptimizationService : DTDFVocab:Service [
    base:desc "Provides optimal paths to minimize energy consumption or residual motion"
    DTDFVocab:provides ActionOptimizedTrajectory
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive dashboards displaying real-time and historical trajectory traces with simulated confidence bounds"
    DTDFVocab:provides ActionDashboardConfiguration
]

instance HMIService : DTDFVocab:Service [
    base:desc "Python-based frontend for operator control, logging configuration, and system monitoring"
    DTDFVocab:provides ActionOperatorInterface
]

// C17: Insights/Actions
instance InsightTrajectoryDeviation : DTDFVocab:Insight [
    base:desc "Real-time comparison of executed vs. simulated trajectories identifying deviations in swinging motion"
]

instance InsightFaultClassification : DTDFVocab:Insight [
    base:desc "Time-series classification identifying anomalies in sensor data (e.g., motor controller errors)"
]

instance InsightPerformanceOptimization : DTDFVocab:Insight [
    base:desc "Analysis of trajectory generator outputs to optimize energy consumption and motion efficiency"
]

instance ActionOptimizedTrajectory : DTDFVocab:Action [
    base:desc "Provides optimal path instructions to minimize energy consumption or residual motion"
    DTDFVocab:IsAutomatic true
]

instance ActionDashboardConfiguration : DTDFVocab:Action [
    base:desc "Allows operators to adjust logging thresholds and system configurations dynamically"
    DTDFVocab:IsAutomatic false
]

instance ActionOperatorInterface : DTDFVocab:Action [
    base:desc "Enables operators to control crane operations and monitor system status"
    DTDFVocab:IsAutomatic false
]

// C1: Physical Crane System Component
instance PhysicalCraneSystem : DTDFVocab:Component [
    base:desc "Hardware + controllers for the lab-scale gantry crane system including frame, motors, controllers, and electromagnet"
    base:contains SwingAngleEncoder, CartMotorSystem, HoistMotorSystem, Electromagnet, ArduinoControlUnit
]

// C5: Digital Twin Services Component
instance DigitalTwinServices : DTDFVocab:Component [
    base:desc "Centralized Python module gantrylib integrating database, MQTT broker, trajectory generator, simulation, and validation services"
    base:contains DataLoggingService, TrajectoryGeneratorService, SimulationService, ValidationService, FaultDetectionService, PerformanceOptimizationService, VisualizationService, HMIService
]

// C12: Environment
instance CraneLabEnvironment : DTDFVocab:Environment [
    base:contains PhysicalCraneSystem, DigitalTwinServices
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin orchestrates virtual-to-physical interactions through the **Control Application** Python module, which sends optimized trajectory commands (generated by the **Trajectory Generator Service**) to the physical crane’s motor controllers (TMC4671-Eval) via the **Physical Crane Interface**. This enables real-time adjustments to movement paths, ensuring minimal residual swinging motion."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twinning operates on a **real-time to near-real-time** scale. Data logging occurs at high frequency (continuous for state variables, sampled trajectories), while validation and simulation services operate in near-real-time (latency < 1 second for trajectory execution feedback). The **Trajectory Generator Service** pre-computes optimal paths offline but can adapt dynamically during operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation consists of **11 interconnected components** (5 physical + 6 digital twin services) deployed across a single personal computer. The architecture follows a **C4 Model** abstraction: (1) **Physical Crane** (hardware + controllers) interacts with (2) **Physical Crane Interface** (Python), which connects to (3) **Control Application** and (4) **Logging Application**. The digital twin services (5) **Database**, (6) **MQTT Broker**, (7) **Trajectory Generator**, (8) **Simulation Service**, (9) **Continuous Validation Service**, and (10) **Dashboard** (Grafana) are containerized and orchestrated via Docker. The **Human-Machine Interface** serves as the operator-facing layer."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin spans the following lifecycle stages: (1) **As Designed**: CAD models (Autodesk Fusion 360) and kinematic models (Capella Arcadia) represent idealized crane behavior; (2) **As Manufactured**: Physical crane components (motors, controllers, Arduino) and their operational data (sensor logs) populate the digital twin; (3) **As Operated**: Real-time data logging, validation, and trajectory optimization occur during runtime, with continuous feedback loops for fault detection and performance tuning."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through: (1) **Verification**: CAD and kinematic models are validated against physical component specifications; (2) **Validation**: Continuous validation compares real-time sensor data (e.g., encoder readings) with simulated trajectories using Euclidean distance metrics; (3) **Uncertainty Handling**: Thresholds for validation are configurable to account for sensor noise (e.g., swing angle encoder) and environmental factors (e.g., wind speed from anemometer); (4) **Data Quality**: TimescaleDB ensures time-series integrity, while Grafana dashboards highlight deviations between real and simulated data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Technical connections are established via: (1) **MQTT Protocol**: Used for real-time data signaling between services (e.g., crane interface → database); (2) **Network Architecture**: Docker containers communicate via a shared network stack; (3) **Database Integration**: TimescaleDB stores logged data with timestamps for temporal analysis; (4) **APIs**: Python-based interfaces (e.g., Control Application) expose services for remote operation; (5) **Hardware Interfaces**: Arduino handles sensor/actuator communication (e.g., TMC4671-Eval motor controllers)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is hosted and deployed on a **single personal computer** via Docker Compose. The deployment workflow includes: (1) **Initialization**: Docker containers (TimescaleDB, MQTT broker, Grafana) are started with pre-configured initialization scripts; (2) **Service Orchestration**: The **gantrylib** Python module bundles all services into a modular architecture; (3) **Containerization**: Database, MQTT broker, and dashboard are containerized for portability; (4) **Scalability**: Services can be extended by adding new Python modules to **gantrylib** without redeploying the entire system."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration occurs with external systems via: (1) **Data Exchange**: TimescaleDB and MQTT broker support integration with third-party IoT platforms or cloud services (e.g., Azure for Air Quality Management exemplar); (2) **APIs**: Python services expose RESTful endpoints for remote access; (3) **Simulation Extensions**: Future extensions (e.g., harbor simulations) will integrate with container identification systems or buoyancy models for broader logistics applications; (4) **Research Protocols**: Used in publications for continuous validation, fault detection, and DarTwin evolution."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership is **shared**: (1) **Physical Crane Owner**: Controls sensor data (e.g., swing angle encoder, anemometer) and operational logs; (2) **Digital Twin Service Provider**: Manages data storage (TimescaleDB) and visualization (Grafana) but does not own raw sensor data; (3) **Research Use**: Data is anonymized in publications (e.g., no personal identifiers) and hosted on GitHub under MIT license. Privacy is ensured via encrypted MQTT communication and Docker-sealed container networks."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplar adheres to **partial standardization**: (1) **Open-Source Frameworks**: Uses open-source tools (TimescaleDB, Grafana, Mosquitto, Docker) but does not rely on a dedicated digital twin framework (e.g., Eclipse Ditto/BaSyx); (2) **Industry Standards**: CAD models use Autodesk Fusion 360 (industry-standard), while MQTT follows IoT standards; (3) **Modeling Methodologies**: Capella Arcadia for system modeling aligns with Model-Based Systems Engineering (MBSE) standards; (4) **GitHub Hosting**: Follows open-source best practices for reproducibility."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety are addressed through: (1) **Remote Operation**: The HMI allows operators to control the crane remotely but requires physical presence for critical actions (e.g., emergency stops); (2) **Data Encryption**: MQTT communication uses TLS for secure data transmission; (3) **Fault Isolation**: Continuous validation alerts operators to deviations (e.g., motor controller errors) before system failure; (4) **Hardware Safety**: Arduino-based sensor/control integration includes safeguards (e.g., PSU overcurrent protection) to prevent physical damage; (5) **Access Control**: Docker containers are isolated via network policies to limit unauthorized access to services."
]