// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring swing angle of the gantry crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerWindSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ElectromagnetStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor detecting electromagnet status (container presence) on the crane"
    DTDFVocab:producedData ContainerPresenceDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerWindSpeedSensor
]

instance ContainerPresenceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ElectromagnetStatusSensor
]

// C10: Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of crane swing angle values"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of measured wind speed around the crane"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance ContainerPresenceData : DTDFVocab:Data [
    base:desc "Binary indication of container presence from electromagnet"
    DTDFVocab:fromData ContainerPresenceDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C10: Models/Data
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "CAD geometric model of the gantry crane structure"
    DTDFVocab:inputTo GrafanaEnabler
]

instance KinematicBehavioralModel : DTDFVocab:Model [
    base:desc "Kinematic behavioral model representing crane motion dynamics"
    DTDFVocab:inputTo SimulationEngineEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database storing sensor and control data"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service messaging"
    DTDFVocab:enables SimulationService
    DTDFVocab:enables ContinuousValidationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for real‑time visualization of crane state"
    DTDFVocab:enables RealTimeVisualizationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine running the kinematic model"
    DTDFVocab:enables SimulationService
]

// C6: Services
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that records timestamped sensor readings and control commands into TimescaleDB"
    DTDFVocab:provides HistoricalTrendInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Service that streams current crane state to Grafana dashboards"
    DTDFVocab:provides RealTimeStateVisualizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs motion simulations using the kinematic model"
    DTDFVocab:provides MotionSimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that compares live sensor data against simulated behavior for validation"
    DTDFVocab:provides ModelValidationInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service that computes optimal crane control commands based on the kinematic model"
    DTDFVocab:provides OptimalCraneControlAction
]

// C17: Insights
instance RealTimeStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight presenting live crane measurements on a dashboard"
]

instance MotionSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight delivering simulated motion trajectories for scenario analysis"
]

instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Insight reporting discrepancies between physical behavior and simulated model"
]

instance HistoricalTrendInsight : DTDFVocab:Insight [
    base:desc "Insight revealing historical trends of sensor data and control actions"
]

// C17: Actions
instance OptimalCraneControlAction : DTDFVocab:Action [
    base:desc "Automatically generated optimal control command for crane motion"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance CraneControllerActingComponent : DTDFVocab:ActingComponent [
    base:desc "Controller unit driving crane actuators (motors) based on commands"
]

// C5: Container-level components
instance TimescaleDBComponent : DTDFVocab:Component [
    base:desc "Container hosting the TimescaleDB database"
]

instance GrafanaComponent : DTDFVocab:Component [
    base:desc "Container hosting the Grafana dashboard"
]

instance TrajectoryGeneratorComponent : DTDFVocab:Component [
    base:desc "Container providing trajectory generation for crane motion"
]

instance SimulationComponent : DTDFVocab:Component [
    base:desc "Container running the kinematic simulation engine"
]

instance ContinuousValidationComponent : DTDFVocab:Component [
    base:desc "Container implementing continuous model validation"
]

instance MQTTBrokerComponent : DTDFVocab:Component [
    base:desc "Container running the Eclipse Mosquitto MQTT broker"
]

// C8: Environment
instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains TimescaleDBComponent, GrafanaComponent, TrajectoryGeneratorComponent, SimulationComponent, ContinuousValidationComponent, MQTTBrokerComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, implemented in Python, issues motion commands (such as cart translation, hoist translation, and electromagnet activation) through the Physical Crane Interface to the crane’s motor controllers. The interface translates high‑level commands into the low‑level signals required by the controllers and sends them to the hardware. After execution, the crane’s sensed state is again measured by the Arduino and logged, providing implicit feedback. No explicit authentication, validation, or command‑acknowledgement mechanisms are described in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall constellation follows an ad‑hoc, container‑based orchestration using the C4 model. All components run as independent processes (Python applications) coordinated through an MQTT broker that provides publish‑subscribe messaging. Persistence is handled by TimescaleDB; visualization by Grafana. Resource management relies on the underlying host (virtual machine) and containerization rather than a dedicated digital‑twin framework, resulting in a single‑instance twin with decentralized messaging."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The exemplar provides a continuous‑validation service that compares live data from the physical crane against the kinematic model to ensure model fidelity. It has been used in research on continuous validation methods, fault detection, and system evolution, indicating that validation routines are integral to the twin, though specific quantitative fidelity thresholds or uncertainty quantification methods are not described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital‑twin components are deployed as Docker containers on a single personal computer. The TimescaleDB database, Eclipse Mosquitto MQTT broker, and Grafana dashboard each run in separate containers connected via Docker’s default bridge network over TCP/IP. MQTT is used as the messaging protocol for signaling between services (e.g., Trajectory Generator, Simulation, Continuous Validation). The documents do not provide details on bandwidth, latency, redundancy, or security protocols beyond the use of open‑source components."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system is hosted on‑premise on a personal computer (edge deployment). Python services are packaged in the pip‑installable module gantrylib. Docker Compose orchestrates the TimescaleDB, MQTT broker, and Grafana containers, handling automatic initialisation and lifecycle management. Computational requirements are modest, limited to a PC capable of running Python and Docker; storage is provided by the TimescaleDB instance. Scalability is limited to what can be achieved with Docker containers on the host, and no cloud or distributed deployment is mentioned. Availability is ensured by Docker Compose orchestration, though no explicit high‑availability or redundancy mechanisms are described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is limited to standard protocols: the services exchange data through MQTT and store measurements in TimescaleDB, which can be accessed by any client supporting PostgreSQL/SQL. The Grafana dashboard consumes data via its native TimescaleDB connector. No specific enterprise integration standards (e.g., AutomationML, OPC‑UA) are mentioned for this twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management twin is built on an AutomationML‑based model, adhering to the AutomationML specification for model‑driven digital twins. The architecture of the lab‑scale gantry crane is described using the C4 modelling notation. No other industry standards or certification requirements are mentioned."
]