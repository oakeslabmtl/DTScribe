// C2: Acting Components
instance CartMotor : DTDFVocab:ActingComponent [
    base:desc "Cart motor driven via TMC4671 Eval controller mounted on gantry frame."
]
instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist motor driven via TMC4671 Eval controller controlling vertical movement."
]
instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet attached to hoist shaft, actuated by TMC4671 Eval controller."
]
instance ArduinoController : DTDFVocab:ActingComponent [
    base:desc "Arduino microcontroller sampling sensor data and publishing to MQTT."
]
instance PSUUnit : DTDFVocab:ActingComponent [
    base:desc "Power supply unit managing energy for motors, magnet, sensors, and Arduino."
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder attached to the hoist to measure crane sway."
    DTDFVocab:producedData SwingAngleDataTransmitted
]
instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer mounted on the crane frame to measure wind speed."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// C10: Models/Data – Data instances
instance SwingAngleTimeseriesData : DTDFVocab:Data [
    base:desc "Time‑series of swing angle gathered via SwingAngleDataTransmitted."
    DTDFVocab:inputTo TimescaleDBEnabler, MosquittoBrokerEnabler
    DTDFVocab:fromData SwingAngleDataTransmitted
]
instance WindSpeedTimeseriesData : DTDFVocab:Data [
    base:desc "Time‑series of wind speed gathered via WindSpeedDataTransmitted."
    DTDFVocab:inputTo TimescaleDBEnabler, SimulationContainerEnabler, MosquittoBrokerEnabler
    DTDFVocab:fromData WindSpeedDataTransmitted
]
instance MotorStateTimeseriesData : DTDFVocab:Data [
    base:desc "Time‑series of motor angles and velocities persisted from controller."
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance TrajectoryLogTimeseriesData : DTDFVocab:Data [
    base:desc "Log of generated trajectories including timestamps and parameters."
    DTDFVocab:inputTo TimescaleDBEnabler, ValidationContainerEnabler
]
instance FaultClassificationOutputData : DTDFVocab:Data [
    base:desc "Output of fault‑mode classification model applied to historical time‑series data."
    DTDFVocab:inputTo TimescaleDBEnabler, VisualizationContainerEnabler
]

// C10: Models/Data – Model instances
instance CADModelFusion360 : DTDFVocab:Model [
    base:desc "CAD model of gantry crane created in Autodesk Fusion360."
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance KinematicModelPython : DTDFVocab:Model [
    base:desc "Python kinematic model used for optimal trajectory generation."
    DTDFVocab:inputTo TrajectoryGenerationContainerEnabler
]
instance SimulationModelMotorControllers : DTDFVocab:Model [
    base:desc "Simulation model of motor drivers and controllers in Python."
    DTDFVocab:inputTo SimulationContainerEnabler
]
instance ValidationModelTrajectoryComparison : DTDFVocab:Model [
    base:desc "Model for validating generated trajectories against simulation results."
    DTDFVocab:inputTo ValidationContainerEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database container persisting motor, sensor, and log data."
    DTDFVocab:enables LoggingService
]
instance MosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker enabling inter‑service signalling."
    DTDFVocab:enables TrajectoryGenerationService, SimulationService, ContinuousValidationService
]
instance TrajectoryGenerationContainerEnabler : DTDFVocab:Enabler [
    base:desc "Docker container running optimal trajectory generator using the kinematic model."
    DTDFVocab:enables TrajectoryGenerationService
]
instance SimulationContainerEnabler : DTDFVocab:Enabler [
    base:desc "Docker container running simulation twin of the crane motors and controllers."
    DTDFVocab:enables SimulationService
]
instance ValidationContainerEnabler : DTDFVocab:Enabler [
    base:desc "Docker container running validation twin comparing trajectories to simulation."
    DTDFVocab:enables ContinuousValidationService
]
instance VisualizationContainerEnabler : DTDFVocab:Enabler [
    base:desc "Docker container hosting Grafana dashboard for visualising telemetry and insights."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Data logging service persisting telemetry to TimescaleDB via Python application."
]
instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service providing optimal trajectory generation using the kinematic model."
    DTDFVocab:provides TrajectoryPerformanceInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Service simulating crane motors and controllers for testing trajectories."
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service validating generated trajectories against simulation and generating alerts."
    DTDFVocab:provides ValidationInsight, NotifyMaintenanceAction
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Service visualising telemetry, logs, and insights on Grafana dashboards."
    DTDFVocab:provides TrajectoryPerformanceInsight, FaultModeClassificationInsight
]

// C11: Insights / Actions
instance TrajectoryPerformanceInsight : DTDFVocab:Insight [
    base:desc "Real‑time trajectory performance metrics displayed on Grafana with threshold monitoring."
]
instance FaultModeClassificationInsight : DTDFVocab:Insight [
    base:desc "Time‑series classification model predictions of fault modes to support proactive reliability."
]
instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Comparison of generated trajectories versus simulation results, highlighting discrepancies."
]
instance NotifyMaintenanceAction : DTDFVocab:Action [
    base:desc "Automatic notification to operators when threshold breaches occur, prompting maintenance."
    DTDFVocab:IsAutomatic true
]

// C17: Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains CartMotor, HoistMotor, Electromagnet, ArduinoController, PSUUnit,
        SwingAngleEncoder, Anemometer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Optimised trajectory payloads (desired cart and hoist positions/speeds) are sent over MQTT to the Control Application, which translates them into motor commands for the cart and hoist controllers, driving the physical crane motors; Continuous Validation alerts the operator via the Grafana dashboard when thresholds are breached."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in continuous real‑time mode. The Logging Application writes data to the database at the rate of sensor sampling (typically tens of Hz), the Control Application processes motion commands at the motor controller rate (~1 kHz), and the Validation Service evaluates trajectories once each execution cycle, providing near‑real‑time fault detection."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical crane hardware, Python crane interface, control application, logging application, human‑machine interface, MQTT broker, TimescaleDB, trajectory generator service, simulation service, continuous validation service, Grafana dashboard—all orchestrated via Docker‑Compose."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (CAD and kinematic model), Manufacturing (physical crane build), and Operational (runtime data logging and continuous validation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Executed trajectories are validated by comparing real telemetry to simulation outputs using distance metrics; thresholds trigger fault alerts; kinematic model calibrated to CAD geometry; simulation provides confidence bounds displayed in dashboard."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT (Eclipse Mosquitto) for inter‑service messaging; PostgreSQL (TimescaleDB) via libpq for database access; serial/USB communication from Python interface to motor controllers; Docker network for isolated localhost communication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All services run locally on a personal computer using Docker‑Compose; containers include TimescaleDB, Mosquitto, Grafana; Python application and crane interface run on host OS; Docker‑Compose file and init scripts provided; repository public on GitHub (MIT license)."
]