// Sensing components
instance CartPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Stepper encoder attached to the cart motor, providing cart position data"
    DTDFVocab:producedData CartPositionDataTransmitted
]

instance HoistPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Step encoder attached to the hoist motor, providing hoist position data"
    DTDFVocab:producedData HoistPositionDataTransmitted
]

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution swing‑angle encoder measuring the hoist swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed which affects crane dynamics"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor monitoring the cart motor current"
    DTDFVocab:producedData CartCurrentDataTransmitted
]

instance HoistCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor monitoring the hoist motor current"
    DTDFVocab:producedData HoistCurrentDataTransmitted
]

// Data transmitted (from sensors via MQTT)
instance CartPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartPositionEncoder
]

instance HoistPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistPositionEncoder
]

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance CartCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartCurrentSensor
]

instance HoistCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistCurrentSensor
]

// Data stored in TimescaleDB
instance CartPositionData : DTDFVocab:Data [
    base:desc "Time‑stamped cart position telemetry recorded in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData CartPositionDataTransmitted
]

instance HoistPositionData : DTDFVocab:Data [
    base:desc "Time‑stamped hoist position telemetry recorded in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData HoistPositionDataTransmitted
]

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing angle telemetry recorded in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData SwingAngleDataTransmitted
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind speed telemetry recorded in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData WindSpeedDataTransmitted
]

instance CartCurrentData : DTDFVocab:Data [
    base:desc "Time‑stamped cart motor current telemetry recorded in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData CartCurrentDataTransmitted
]

instance HoistCurrentData : DTDFVocab:Data [
    base:desc "Time‑stamped hoist motor current telemetry recorded in TimescaleDB"
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData HoistCurrentDataTransmitted
]

// Digital models
instance CraneCADModel : DTDFVocab:Model [
    base:desc "Autodesk Fusion360 CAD model of the crane hardware used for visualization and design reference"
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the gantry crane used by the trajectory generator for optimal swing‑free trajectory planning"
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Discrete‑time simulation model of the crane dynamics executed by the Simulation Service"
    DTDFVocab:inputTo PythonRuntimeEnabler
]

// Enablers
instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker enabling inter‑service messaging"
    DTDFVocab:enables DataLoggingService, ContinuousValidationService, TrajectoryGeneratorService, SimulationService, HumanMachineInterfaceService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database enabling persistent storage of sensor telemetry"
    DTDFVocab:enables DataLoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboarding enabling live visualization of telemetry"
    DTDFVocab:enables GrafanaDashboardService
]

instance PythonRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime environment enabling execution of services such as TrajectoryGeneratorService, SimulationService, ContinuousValidationService"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

instance ArduinoControlEnabler : DTDFVocab:Enabler [
    base:desc "Arduino microcontroller firmware enabling physical‑to‑virtual interaction via serial link and MQTT"
    DTDFVocab:enables HumanMachineInterfaceService
]

// Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service ingesting sensor data from MQTT and storing into TimescaleDB for historical analysis"
    DTDFVocab:provides MaintenanceDecisionInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Service providing dynamic visualization of telemetry via Grafana dashboards"
    DTDFVocab:provides DashboardVisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service generating swing‑free trajectories using the kinematic model"
    DTDFVocab:provides TrajectoryPerformanceInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service performing discrete‑time simulation of crane dynamics for comparison with real execution"
    DTDFVocab:provides SimulationAccuracyInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service comparing executed and simulated trajectories in real time, generating alerts when thresholds are exceeded"
    DTDFVocab:provides ContinuousValidationAlertInsight, FaultClassificationInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Operator console for configuration, control, and decision making"
    DTDFVocab:provides OperatorControlInsight, TrajectoryParameterAdjustmentAction, ControllerGainsAdjustmentAction, MaintenanceDecisionAction
]

// Insights
instance TrajectoryPerformanceInsight : DTDFVocab:Insight [
    base:desc "Real‑time dashboard displays trajectory traces and swing metrics"
]

instance ContinuousValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Continuous validation service emits fault classification alerts for operational oversight"
]

instance FaultClassificationInsight : DTDFVocab:Insight [
    base:desc "Fault classification reports identify specific fault types detected during validation"
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Grafana dashboards provide live telemetry visualization for operators and researchers"
]

instance SimulationAccuracyInsight : DTDFVocab:Insight [
    base:desc "Simulation accuracy compared against real trajectory execution to calibrate models"
]

instance OperatorControlInsight : DTDFVocab:Insight [
    base:desc "Human‑machine interface provides operators with control commands and status feedback"
]

instance MaintenanceDecisionInsight : DTDFVocab:Insight [
    base:desc "Insights guiding maintenance scheduling and operational decision making based on validation and telemetry"
]

// Actions
instance TrajectoryParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjusting trajectory generation parameters to improve swing performance"
    DTDFVocab:IsAutomatic false
]

instance ControllerGainsAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjusting controller gains based on validation metrics and telemetry"
    DTDFVocab:IsAutomatic false
]

instance MaintenanceDecisionAction : DTDFVocab:Action [
    base:desc "Initiating maintenance actions based on fault classification and validation alerts"
    DTDFVocab:IsAutomatic false
]

// Acting components (actuators)
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Step‑motor driven cart motor controlled via Trinamic TMC4671 driver"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper‑driven hoist motor controlled by Trinamic TMC4671 driver"
]

instance HoistElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet on hoist end activated via Arduino control board to grasp containers"
]

// Environment
instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:desc "All components of the digital twin"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory plans generated by the Trajectory Generator Service are published over MQTT to the Control Application, which translates them into stepper motor commands sent via the Physical Crane Interface to the TMC4671‑Eval drivers, thus commanding cart and hoist motion. The electromagnet is also controlled through this channel when a container is to be picked or released."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates in real time, synchronizing with the physical crane's sensor update and control loop, typically 10–50 Hz. High‑level services such as trajectory generation, simulation, and continuous validation execute on a per‑execution basis (seconds to minutes). Data logging occurs continuously at sensor rate, while trajectory execution commands are dispatched at each control cycle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system architecture uses a containerized constellation: the Physical Crane consists of hardware components; the digital side includes six containers: TimescaleDB, Grafana, Trajectory Generator, Simulation, Continuous Validation, MQTT broker. A Python module (gantrylib) provides a public API; the Control, Logging, and HMI applications consume this API. Docker Compose orchestrates services, automating first‑time setup of database, dashboard, and broker."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans three key stages: (1) Design – CAD models and kinematic models are created in Autodesk Fusion 360 and used by services; (2) Manufacturing – the physical lab‑scale crane is built from the BOM (~1250 €) and assembled; (3) Operation – live data logging, validation, trajectory planning and control are performed, while continuous validation ensures fidelity over time."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by the Continuous Validation Service, which computes distance metrics between real and simulated trajectories and checks against configurable thresholds. Further validation occurs during design via simulation, and during operation the twin logs discrepancies."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Interaction between PT and DT occurs over a defined communication stack: Arduino micro‑controller communicates via UART/USB to the PC; the logging and control applications send and receive MQTT messages over the local host running Eclipse Mosquitto. All Docker containers share the default Docker bridge network, enabling seamless inter‑service communication without external networking."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The exemplar is deployed on a single personal computer. Docker Compose brings up TimescaleDB, MQTT broker, and Grafana on the same host. The Python applications run directly on the host's OS. This on‑premises, local deployment uses only open‑source components and no cloud services."
]