// C3: Physical sensing components
instance SwingAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Swing Angle Encoder measuring the crane's swing angle."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed affecting crane motion."
    DTDFVocab:producedData AnemometerDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensor
]

instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// C10: Models/Data
instance TimescaleCraneTelemetryData : DTDFVocab:Data [
    base:desc "Aggregated crane telemetry (position, sensor readings) stored in TimescaleDB."
    DTDFVocab:fromData SwingAngleDataTransmitted, AnemometerDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ValidationEnabler, OptimalControlEnabler
]

instance CraneCADModel : DTDFVocab:Model [
    base:desc "Detailed CAD geometry of the lab‑scale gantry crane."
    DTDFVocab:inputTo SimulationEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model capturing motion relationships of crane parts."
    DTDFVocab:inputTo ValidationEnabler, OptimalControlEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB container storing time‑series crane data."
    DTDFVocab:enables HistoricalLoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard container providing real‑time visualization of crane state."
    DTDFVocab:enables RealTimeVisualizationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker (Eclipse Mosquitto) for inter‑service signalling."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, OptimalControlService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Container generating feasible crane trajectories."
    DTDFVocab:enables OptimalControlService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation container running the CAD model for preview."
    DTDFVocab:enables RealTimeVisualizationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation container comparing live data to the kinematic model."
    DTDFVocab:enables ContinuousValidationService
]

instance OptimalControlEnabler : DTDFVocab:Enabler [
    base:desc "Service container computing optimal motion commands."
    DTDFVocab:enables OptimalControlService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal control service computing and sending motion commands to the crane controller."
    DTDFVocab:provides ComputeMotionCommandAction, MotionOptimizationInsight
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Historical logging service recording sensor and actuator data over time."
    DTDFVocab:provides RecordSensorDataAction, HistoricalDataInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization service rendering crane state and trajectory."
    DTDFVocab:provides VisualizeCraneStateAction, DataVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service comparing live data to the kinematic model to detect deviations."
    DTDFVocab:provides DetectDeviationAction, DeviationDetectionInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service generating feasible crane trajectories."
    DTDFVocab:provides ComputeMotionCommandAction, MotionOptimizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service running crane simulation based on CAD model."
    DTDFVocab:provides VisualizeCraneStateAction, DataVisualizationInsight
]

// C17: Insights
instance MotionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Provides an optimal motion plan reducing travel time and energy consumption."
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Enables analysis of past crane operations for performance evaluation."
]

instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Offers real‑time visual dashboards of crane trajectory and system health."
]

instance DeviationDetectionInsight : DTDFVocab:Insight [
    base:desc "Alerts when crane behavior diverges from expected kinematics, supporting corrective actions."
]

// C17: Actions
instance ComputeMotionCommandAction : DTDFVocab:Action [
    base:desc "Computes motion commands for hoist and trolley based on the optimal trajectory."
    DTDFVocab:IsAutomatic true
]

instance RecordSensorDataAction : DTDFVocab:Action [
    base:desc "Writes incoming sensor and actuator data into TimescaleDB."
    DTDFVocab:IsAutomatic true
]

instance VisualizeCraneStateAction : DTDFVocab:Action [
    base:desc "Displays current crane position, swing angle, and payload status on Grafana dashboards."
    DTDFVocab:IsAutomatic true
]

instance DetectDeviationAction : DTDFVocab:Action [
    base:desc "Detects deviations between observed telemetry and kinematic model predictions."
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance CraneDriveActuator : DTDFVocab:ActingComponent [
    base:desc "Motorised drive mechanisms (actuators) moving the hoist and trolley."
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet used to engage and release the payload hook."
]

// C8: Containerized components
instance TimescaleDBContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the TimescaleDB instance."
]

instance GrafanaContainer : DTDFVocab:Component [
    base:desc "Docker container hosting the Grafana dashboard."
]

instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Docker container running the trajectory generation service."
]

instance SimulationContainer : DTDFVocab:Component [
    base:desc "Docker container running crane simulation based on the CAD model."
]

instance ValidationContainer : DTDFVocab:Component [
    base:desc "Docker container performing continuous validation of live data."
]

instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Docker container running the Eclipse Mosquitto MQTT broker."
]

// C12: Environment
instance GantryCraneTwinEnvironment : DTDFVocab:Environment [
    base:contains TimescaleDBContainer, GrafanaContainer, TrajectoryGeneratorContainer, SimulationContainer, ValidationContainer, MQTTBrokerContainer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "A Control Application, implemented in Python, uses the same Physical Crane Interface to issue command messages to the crane controllers. Desired motion trajectories are computed by the Trajectory Generator Service and passed to the Control Application, which then transmits control commands (e.g., motor speed, hoist actuation) to the physical crane. The execution of commands is observed by the Logging Application and validated by the Continuous Validation Service, which compares measured trajectories with simulated ones. Specific command formats, authentication or confirmation mechanisms are not described in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows an ad‑hoc, container‑based orchestration pattern (as modelled with the C4 diagram). Core services (trajectory generation, simulation, continuous validation) are implemented as Python applications that communicate via an MQTT broker for signaling. Persistent state is stored in a TimescaleDB database, and visualisation is provided through a Grafana dashboard. The physical crane interface is a Python program that connects to the crane controllers. No commercial digital twin framework is used; integration relies on the described containers and the MQTT messaging backbone."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through continuous validation methods that compare the kinematic model’s predictions with measured behaviour of the physical crane. The exemplar has been employed in research on continuous validation, fault detection, and the DarTwin notation for systematic evolution of the twin, indicating that verification and validation processes are integral to its operation. Details on uncertainty quantification, error correction mechanisms, or formal quality‑assurance procedures are not explicitly provided."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital‑twin components are deployed as Docker containers on a single host computer. The TimescaleDB database, Grafana dashboard and Eclipse Mosquitto MQTT broker run in Docker containers orchestrated by Docker‑Compose. All Python services (Physical Crane Interface, Control Application, Logging Application, Trajectory Generator, Simulation Service, Continuous Validation Service) run on the host and communicate with the containers over the local TCP/IP stack, using MQTT for signalling between services and standard database connections for TimescaleDB. The network topology is essentially a local star where each service connects to the MQTT broker; no explicit bandwidth, latency, redundancy or security protocol specifications are provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire system is hosted on‑premise on a personal computer. Python components are packaged in a pip‑installable module (gantrylib). The database, MQTT broker and dashboard are containerised with Docker and started via a Docker‑Compose file, which also handles initial database and dashboard setup. Deployment relies on open‑source software (TimescaleDB, Grafana, Eclipse Mosquitto) and does not use cloud platforms. Scalability is limited to the resources of the host machine; the documents do not describe additional scaling, high‑availability or redundancy mechanisms."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external components is achieved through standard protocols and tools: an MQTT broker enables inter‑service messaging; TimescaleDB serves as the time‑series data store; Grafana provides external visualisation access; and the Physical Crane Interface uses a Python program to talk to the crane controllers. The documents do not mention interoperability with enterprise systems, external standards (e.g., OPC‑UA), or other digital twins."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin is built using AutomationML, a standardized data‑exchange format for engineering models. The exemplar follows model‑driven engineering practices and adopts common containerisation and virtualization standards for deployment, ensuring interoperability with other tools and platforms."
]