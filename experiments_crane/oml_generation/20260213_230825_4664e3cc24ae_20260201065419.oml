// C11: Enablers
instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database used for historical data logging of crane state",
    DTDFVocab:enables HistoricalLoggingService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana runtime dashboard that visualises deviation metrics and alerts operators",
    DTDFVocab:enables DataVisualizationService
]

instance ControlEngine : DTDFVocab:Enabler [
    base:desc "Software engine that implements optimal control algorithms for the crane",
    DTDFVocab:enables OptimalControlService
]

instance ValidationEngine : DTDFVocab:Enabler [
    base:desc "Continuous validation engine that automatically compares real‑time measurements against CAD and kinematic models",
    DTDFVocab:enables ContinuousValidationService
]

// C17: Insights
instance DeviationMetricInsight : DTDFVocab:Insight [
    base:desc "Insight generated by simulating the planned trajectory, measuring actual movement, and computing deviation metrics"
]

instance TrajectoryDeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert insight triggered when deviation metrics exceed predefined thresholds"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that historic logged data is available for offline analysis"
]

// C17: Actions
instance AlertAction : DTDFVocab:Action [
    base:desc "Automatically triggers visual and audible alerts on the dashboard when thresholds are exceeded",
    DTDFVocab:IsAutomatic true
]

instance TrajectoryReplanningAction : DTDFVocab:Action [
    base:desc "Operator‑initiated re‑planning of crane trajectory based on deviation insight",
    DTDFVocab:IsAutomatic false
]

instance MaintenanceAction : DTDFVocab:Action [
    base:desc "Schedules maintenance activities when persistent deviations are detected",
    DTDFVocab:IsAutomatic false
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes and sends control commands to improve crane motion based on the kinematic model",
    DTDFVocab:provides TrajectoryReplanningAction, MaintenanceAction
]

instance HistoricalLoggingService : DTDFVocab:Service [
    base:desc "Stores time‑stamped sensor and actuation data in TimescaleDB for later analysis",
    DTDFVocab:provides HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Provides graphical views of crane state and performance, visualising deviation metrics on Grafana",
    DTDFVocab:provides DeviationMetricInsight, AlertAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Automatically compares real‑time measurements against CAD and kinematic models to detect deviations",
    DTDFVocab:provides DeviationMetricInsight, TrajectoryDeviationAlertInsight
]

// C3: Physical sensing components (software extracted state)
instance CraneStateExtractor : DTDFVocab:SensingComponent [
    base:desc "Python program that connects to crane controllers and extracts the crane's state (position and motion data) during operation",
    DTDFVocab:producedData CraneStateDataTransmitted
]

// C4: Physical-to-virtual interaction
instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneStateExtractor
]

// C10: Models/Data
instance GantryCraneCADModel : DTDFVocab:Model [
    base:desc "CAD model capturing the geometric structure of the lab‑scale gantry crane",
    DTDFVocab:inputTo ValidationEngine
]

instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model encoding the motion behaviour of the gantry crane used for optimal control and validation",
    DTDFVocab:inputTo ValidationEngine, ControlEngine
]

instance CraneStateData : DTDFVocab:Data [
    base:desc "Time‑stamped position and motion data of the gantry crane, streamed from the Physical Crane Interface",
    DTDFVocab:fromData CraneStateDataTransmitted,
    DTDFVocab:inputTo TimescaleDB, ValidationEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, also implemented in Python, sends command messages to the Physical Crane Interface, which forwards them to the crane’s controllers to actuate movements. Commands may originate from the Human Machine Interface or other services. The documents do not describe the command syntax, validation, authentication, conflict resolution, or execution acknowledgment mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The gantry crane digital twin architecture is described using the C4 Model, adopting an ad‑hoc approach that employs containerization/virtualization technologies for easy dissemination and deployment of components, as noted for the exemplars."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through a continuous validation service that compares real‑time sensor data from the crane with the predictions of the kinematic model. The exemplar has been employed in research on continuous validation methods and fault detection, using runtime comparison to detect model‑data mismatches, but specific uncertainty quantification or quality‑assurance procedures are not described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Digital‑twin components communicate via an MQTT broker for service‑level signaling (publish/subscribe) and through standard database connections to the TimescaleDB instance. The Grafana dashboard accesses the database over HTTP/TCP. No explicit details on network topology, bandwidth, latency, reliability, redundancy, or security protocols are provided in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system is deployed on a single on‑premise personal computer. The TimescaleDB database, MQTT broker, and Grafana dashboard are containerized with Docker; the remaining Python components (Physical Crane Interface, Control Application, Logging Application, Human Machine Interface, Trajectory Generator, Simulation, Continuous Validation) are packaged in a Python module named gantrylib and run natively on the host. The documentation does not mention cloud or edge hosting, scalability mechanisms, or availability/reliability provisions beyond local Docker deployment."
]