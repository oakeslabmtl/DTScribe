// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing angle on the gantry crane",
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed for the crane operation",
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// C10: Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements from the encoder",
    DTDFVocab:fromData SwingAngleDataTransmitted,
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements from the anemometer",
    DTDFVocab:fromData WindSpeedDataTransmitted,
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C2: Acting components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart motion, controlled via TMC4671‑Eval driver"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist motion, controlled via TMC4671‑Eval driver"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist used to pick up and release pucks"
]

instance ArduinoActuatorInterface : DTDFVocab:ActingComponent [
    base:desc "Arduino‑based board that drives the electromagnet and stepper motor controllers"
]

// C10: Models/Data
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "CAD geometric model of the gantry crane frame and components",
    DTDFVocab:inputTo GrafanaEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used for trajectory generation of cart and hoist",
    DTDFVocab:inputTo GantryLibPythonModuleEnabler
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model of the crane and its controllers",
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance ValidationDistanceMetricModel : DTDFVocab:Model [
    base:desc "Model of distance‑metric validation data produced by continuous validation",
    DTDFVocab:inputTo ValidationEngineEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database (PostgreSQL extension) storing sensor data",
    DTDFVocab:enables LoggingApplicationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for service coordination and message exchange",
    DTDFVocab:enables TrajectoryGeneratorService,
    DTDFVocab:enables SimulationService,
    DTDFVocab:enables ContinuousValidationService
]

instance GantryLibPythonModuleEnabler : DTDFVocab:Enabler [
    base:desc "gantrylib Python module (pip‑installable) providing kinematic computations",
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Physics simulation engine used by the Simulation Service",
    DTDFVocab:enables SimulationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Engine that computes validation distance metrics for executed trajectories",
    DTDFVocab:enables ContinuousValidationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard visualizing stored data and real‑time status",
    DTDFVocab:enables VisualizationDashboardService
]

// C6: Services
instance LoggingApplicationService : DTDFVocab:Service [
    base:desc "Application that logs incoming sensor data into TimescaleDB",
    DTDFVocab:provides LogSensorDataAction
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Grafana‑based dashboard presenting real‑time crane status and alerts",
    DTDFVocab:provides RealTimeStatusInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service generating optimal motion plans using the kinematic model",
    DTDFVocab:provides OptimalMotionPlanInsight,
    DTDFVocab:provides ExecuteOptimalTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation of crane dynamics and controller behavior",
    DTDFVocab:provides SimulatedTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service continuously comparing executed trajectories against simulated ones and issuing alerts",
    DTDFVocab:provides ValidationResultInsight,
    DTDFVocab:provides SendAlertAction,
    DTDFVocab:provides NotifyOperatorAction
]

// C17: Insights
instance RealTimeStatusInsight : DTDFVocab:Insight [
    base:desc "Real‑time status of crane operation displayed on the HMI/dashboard"
]

instance OptimalMotionPlanInsight : DTDFVocab:Insight [
    base:desc "Quantitative optimal trajectory plan for cart and hoist motions"
]

instance SimulatedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Predicted trajectory from physics simulation for validation purposes"
]

instance ValidationResultInsight : DTDFVocab:Insight [
    base:desc "Quantitative validation result (distance metric) comparing executed vs. simulated trajectory"
]

// C17: Actions
instance LogSensorDataAction : DTDFVocab:Action [
    base:desc "Automatically store incoming sensor data into the time‑series database",
    DTDFVocab:IsAutomatic true
]

instance ExecuteOptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Command the crane controllers to follow the generated optimal motion plan",
    DTDFVocab:IsAutomatic true
]

instance SendAlertAction : DTDFVocab:Action [
    base:desc "Issue an alert when validation exceeds predefined thresholds",
    DTDFVocab:IsAutomatic false
]

instance NotifyOperatorAction : DTDFVocab:Action [
    base:desc "Notify the human operator via HMI about faults or validation alerts",
    DTDFVocab:IsAutomatic false
]

// C13: Physical components (logical containers)
instance PhysicalCrane : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane comprising steel frame, stepper motors, and electromagnet"
]

instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Python‑based interface reading controller and sensor data via serial/USB"
]

instance ControlApplication : DTDFVocab:Component [
    base:desc "Application that issues motion commands to the crane actuators"
]

instance LoggingApplicationComponent : DTDFVocab:Component [
    base:desc "Docker container running the Logging Application service"
]

instance HumanMachineInterfaceComponent : DTDFVocab:Component [
    base:desc "Dashboard/HMI used by operators for status monitoring and fault notifications"
]

// C14: Environment
instance GantryCraneSystemEnvironment : DTDFVocab:Environment [
    base:contains PhysicalCrane,
    base:contains PhysicalCraneInterface,
    base:contains ControlApplication,
    base:contains LoggingApplicationComponent,
    base:contains HumanMachineInterfaceComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (Python) sends motion set‑points and actuator commands to the Physical Crane Interface, which forwards them to the motor controllers and electromagnet; trajectory commands generated by the Trajectory Generator Service are delivered in the same way."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates continuously in (near) real‑time: sensor data are logged and validated continuously, and trajectory generation and validation run on the fly during operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centrally orchestrated set of Docker containers on a personal computer: the physical side runs Python programs communicating with the Arduino; the virtual side consists of a TimescaleDB instance, Grafana dashboard, MQTT broker, and the three service containers (trajectory generation, simulation, continuous validation) that exchange data via MQTT and the database."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers design (CAD models of the crane in Autodesk Fusion‑360), manufacturing (BOM for the physical crane), and operation (runtime data logging, simulation, validation, and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, checks them against a predefined threshold, and triggers operator alerts via the dashboard when the threshold is exceeded, ensuring model fidelity during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses a Python interface over serial/USB to the Arduino, MQTT (Eclipse Mosquitto) for event signalling between services, HTTP(S) for Grafana dashboard access, and SQL (PostgreSQL) queries to TimescaleDB for data retrieval."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All virtual components are Dockerised and launched together with a single Docker Compose command; the repository (including source code, CAD files, and documentation) is publicly hosted on GitHub, and the Python module is distributed via pip."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture description follows the C4 Model notation for context, container, and component diagrams; the digital‑twin uses open‑source standards such as MQTT, TimescaleDB (PostgreSQL), and Grafana."
]