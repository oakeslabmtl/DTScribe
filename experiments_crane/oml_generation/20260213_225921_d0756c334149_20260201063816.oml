// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the crane's swing angle, read via Arduino attached to the crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the crane, read via Arduino attached to the crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmission)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// C10: Models/Data (sensor data)
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series swing‑angle measurements from the encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series wind‑speed measurements from the anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// Additional DT data produced by services
instance OptimizedTrajectoryData : DTDFVocab:Data [
    base:desc "Swing‑free optimal trajectories generated by the Trajectory Generator Service"
    DTDFVocab:inputTo DockerComposeOrchestrator
]

instance SimulatedTrajectoryData : DTDFVocab:Data [
    base:desc "Trajectory predictions produced by the Simulation Service, including confidence bounds"
    DTDFVocab:inputTo DockerComposeOrchestrator
]

instance ValidationMetricsData : DTDFVocab:Data [
    base:desc "Distance metrics comparing measured and simulated trajectories for validation"
    DTDFVocab:inputTo DockerComposeOrchestrator
]

instance LoggedCraneStateData : DTDFVocab:Data [
    base:desc "Logged crane state (motor positions, timestamps) stored by the Data Logging Service"
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database storing sensor measurements, simulation outputs and logs"
    DTDFVocab:enables DataLoggingService, ContinuousValidationService, VisualizationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for inter‑service signalling"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, VisualizationService
]

instance PythonKinematicModelEnabler : DTDFVocab:Enabler [
    base:desc "Python implementation of the crane kinematic analytical model"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService
]

instance DockerComposeOrchestrator : DTDFVocab:Enabler [
    base:desc "Docker Compose orchestrates the containerised digital‑twin services"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, DataLoggingService, VisualizationService
]

// C10: Models
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "CAD geometric model of the gantry crane structure"
    DTDFVocab:inputTo DockerComposeOrchestrator
]

instance KinematicAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical kinematic model computing crane motion for trajectory generation and simulation"
    DTDFVocab:inputTo PythonKinematicModelEnabler
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates swing‑free optimal movement trajectories using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight, ExecuteTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs real‑time simulation of crane and low‑level controllers for prediction and what‑if analysis"
    DTDFVocab:provides PredictedTrajectoryInsight, RunWhatIfAnalysisAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares executed measurements with simulated trajectories, computes distance metrics and raises alerts"
    DTDFVocab:provides AnomalyDetectionInsight, AlertOperatorAction
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuously records crane state into TimescaleDB"
    DTDFVocab:provides HistoricalDataInsight, StoreMeasurementAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualises real‑time and historical data with confidence bounds and alerts"
    DTDFVocab:provides RealTimeVisualizationInsight, AdjustThresholdAction
]

// C17: Insights
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Provides pre‑validated, swing‑free trajectories for operators"
]

instance PredictedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Provides simulated trajectories with confidence bounds for what‑if analysis"
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects deviations between measured and simulated trajectories exceeding a configurable threshold"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Aggregates logged crane state data for retrospective analysis"
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Displays live sensor readings, simulation confidence bounds and alerts on the Grafana dashboard"
]

// C17: Actions
instance ExecuteTrajectoryAction : DTDFVocab:Action [
    base:desc "Sends the selected optimal trajectory to the Physical Crane Interface for execution"
    DTDFVocab:IsAutomatic false
]

instance RunWhatIfAnalysisAction : DTDFVocab:Action [
    base:desc "Triggers simulation of alternative trajectories based on user‑defined parameters"
    DTDFVocab:IsAutomatic true
]

instance AlertOperatorAction : DTDFVocab:Action [
    base:desc "Sends an alert to the operator via Grafana when validation metrics exceed the threshold"
    DTDFVocab:IsAutomatic true
]

instance StoreMeasurementAction : DTDFVocab:Action [
    base:desc "Writes incoming crane state measurements into TimescaleDB"
    DTDFVocab:IsAutomatic true
]

instance AdjustThresholdAction : DTDFVocab:Action [
    base:desc "Allows the operator to tune validation and alert thresholds through the Human‑Machine Interface"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are produced by the Control Application (a Python application) and by services such as the Trajectory Generator Service, which compute optimal trajectories. These commands are sent to the Physical Crane Interface, which forwards them to the crane’s controllers to drive the motors and electromagnet. The documents do not detail command message formats, validation, authentication, feedback, conflict‑resolution, or execution confirmation mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin is orchestrated as a set of six Docker‑compose containers: a TimescaleDB instance storing all logged data, a Grafana dashboard visualising the database, a Trajectory Generator Service that consumes a kinematic model to compute swing‑free trajectories, a Simulation Service that mimics the crane dynamics and its controllers, a Continuous Validation Service that continuously compares the measured trajectory (received from the Logging Application) with the simulated trajectory and raises alerts when a distance metric exceeds a configurable threshold, and an MQTT broker that provides publish/subscribe signalling between the services. The physical side consists of five containers (Physical Crane, Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface) all implemented in Python and communicating with the twin via the MQTT broker and by writing state updates into the TimescaleDB. The whole system can be started with a single `docker compose up` command (Fig. 7), reflecting an ad‑hoc, container‑based orchestration rather than a commercial DT framework."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The exemplar follows a four‑stage DT life‑cycle. In the **modeling stage** CAD models of the gantry crane and a kinematic model are created. In the **service‑implementation stage** Python applications (Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface) and DT services (Trajectory Generator, Simulation, Continuous Validation) are developed, the data layer (TimescaleDB) and visualisation layer (Grafana) are set up, and an MQTT broker is added for inter‑service signalling. The **deployment stage** packages all components into Docker containers and brings them up with a single Docker‑Compose command, providing a reproducible environment. Finally, the **operational stage** runs the twin continuously: the Logging Application stores sensor data, the Simulation Service reproduces the motion, the Trajectory Generator creates swing‑free trajectories, and the Continuous Validation Service compares measured and simulated trajectories, triggering alerts on the Dashboard. The system can also be run without the DT, indicating an optional activation of the twin during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by ensuring that the kinematic model can generate trajectories with zero residual swing, providing high‑precision motion planning. Validation is performed continuously by the Continuous Validation Service, which compares the measured executed trajectory (logged by the Logging Application) with the simulated trajectory from the Simulation Service. Distance metrics are calculated and compared against an acceptance threshold; violations trigger operator notifications via the Grafana dashboard. This runtime validation constitutes the verification method for the twin’s models and data, and the use of a central TimescaleDB ensures traceability of both measured and simulated data for quality assurance."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital‑twin software is built from Docker containers: TimescaleDB for the database, Eclipse Mosquitto for the MQTT broker, and Grafana for the dashboard, all orchestrated with docker‑compose on a personal computer. Inter‑service signalling uses MQTT. The deployment runs on a single host, with no explicit mention of bandwidth, latency, redundancy, or additional security protocols beyond the use of MQTT and container isolation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components (physical‑crane interface, control and logging applications, database, MQTT broker, dashboard, and the various twin services) are hosted on‑premise on a personal computer using Docker containers. Required resources include a PC capable of running Python and Docker, storage for TimescaleDB, and network loopback for MQTT communication. The system is open‑source, can be reproduced on other machines, and scales only within the limits of a single‑host Docker deployment; no cloud platforms, high‑availability, or explicit scalability mechanisms are described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration is realised through standard open‑source protocols and tools: MQTT is used for event‑driven messaging between the twin services and the physical‑side applications; data persistence and exchange with analytical components is performed via SQL access to the TimescaleDB database; the Grafana dashboard pulls data over HTTP/REST from the same database for visualisation. All components are packaged as Docker containers and can be deployed on any host that supports Docker, enabling straightforward integration with external monitoring or automation platforms that understand MQTT or SQL. No proprietary enterprise systems or external standards (e.g., OPC-UA, AutomationML) are employed in this exemplar."
]