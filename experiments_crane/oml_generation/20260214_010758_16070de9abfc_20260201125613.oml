// C2: Acting Components
instance CartMotor : DTDFVocab:ActingComponent [
    base:desc "DC motor drives the horizontal cart rail of the gantry crane, controlled via the crane's wired communication bus."
]

instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "DC motor drives the vertical hoist shaft, commanded remotely by the central control system."
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted at the hoist's end picks up and releases puck containers."
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing angle encoder reports the angular displacement of the hoist shaft relative to the vertical axis."
    DTDFVocab:producedData SwingAngleMeasurementData
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer records ambient wind speed entering the gantry crane enclosure."
    DTDFVocab:producedData WindSpeedMeasurementData
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance SwingAngleMeasurementData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedMeasurementData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CartMotorCurrentData : DTDFVocab:DataTransmitted [
    /* producedFrom CartMotor */ 
]

instance HoistMotorCurrentData : DTDFVocab:DataTransmitted [
    /* producedFrom HoistMotor */
]

// C10: Models/Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Timestamped swing angle measurements stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData SwingAngleMeasurementData
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Timestamped ambient wind speed measurements stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData WindSpeedMeasurementData
]

instance CartMotorCurrentDataStored : DTDFVocab:Data [
    base:desc "Timestamped cart motor current measurements stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData CartMotorCurrentData
]

instance HoistMotorCurrentDataStored : DTDFVocab:Data [
    base:desc "Timestamped hoist motor current measurements stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDBEnabler
    DTDFVocab:fromData HoistMotorCurrentData
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB service for storing sensor logs and model outputs."
    DTDFVocab:enables HistoricalDataLoggingService, ContinuousValidationService
]

instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Mosquitto MQTT broker facilitating publish/subscribe communication between services and the physical crane."
    DTDFVocab:enables OptimalTrajectoryGenerationService, HistoricalDataLoggingService, ContinuousValidationService, VisualizationService
]

instance KinematicEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python-based kinematic engine using CAD (Fusion 360 exported STL/STEP) for trajectory planning."
    DTDFVocab:enables OptimalTrajectoryGenerationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboards querying TimescaleDB for real‑time visualization of crane status and historic trends."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance OptimalTrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates energy‑efficient motion plans using the crane's kinematic model."
    DTDFVocab:provides TrajectoryOptimizationInsight, EnergyEfficiencyInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Streams real‑time sensor readings (position, velocity, motor currents) to TimescaleDB for historical analysis."
    DTDFVocab:provides DataIntegrityInsight, SystemHealthInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares logged sensor measurements against model predictions and flags discrepancies."
    DTDFVocab:provides DiscrepancyFlagInsight, SafetyMarginInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Renders logged data on Grafana dashboards for operators and researchers."
    DTDFVocab:provides RealTimeDashboardInsight
]

// C17: Insights
instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight into optimal trajectory plans that minimize travel time and energy consumption."
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight into energy usage of proposed crane movements."
]

instance DataIntegrityInsight : DTDFVocab:Insight [
    base:desc "Insight ensuring that historical sensor logs are complete and consistent."
]

instance SystemHealthInsight : DTDFVocab:Insight [
    base:desc "Insight into overall system operational health derived from logged metrics."
]

instance DiscrepancyFlagInsight : DTDFVocab:Insight [
    base:desc "Insight that flags when actual sensor data diverges significantly from model predictions."
]

instance SafetyMarginInsight : DTDFVocab:Insight [
    base:desc "Insight indicating safety margins based on swing angle and wind speed assessments."
]

instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time visualization of crane state and validation results."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Operator commands issued through the Human Machine Interface are forwarded by the Control Application to the Physical Crane Interface, which in turn sends motion commands (e.g., target coordinates or velocity profiles) to the physical crane controllers over the same Python connection. The document does not detail any authentication, validation, or command‑confirmation procedures; however, a Continuous Validation Service compares executed trajectories against simulated ones stored in the database and alerts the operator via the Dashboard if an error threshold is exceeded."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Dt constellation: The lab‑scale gantry crane twin orchestrates its components in an ad‑hoc, containerized architecture.  A set of Docker containers are deployed that encapsulate the core services: the Physical Crane Interface—a lightweight Python program that directly interrogates the crane’s PLC controllers for status and kinematic data; the Logging Application, which subscribes to the MQTT topics published by the interface and writes the telemetry into a time‑series database; and optional services such as a trajectory planner and a web‑based dashboard.  All intra‑twin communication proceeds over an MQTT broker that runs on the host.  Docker’s native cgroup limits provide the basic resource management, while coordination is achieved implicitly via the broker and via shared configuration files.  No external orchestration framework or central registry is employed."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A Continuous Validation Service runs in parallel with the trajectory generator.  It compares the trajectory measured by the sensors against the simulated trajectory produced by the kinematic model, computing a distance metric between the two.  This metric is then checked against a predefined tolerance threshold; if the threshold is exceeded, a fault‑detection alert is generated, triggering investigation of the trajectory or the underlying model."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All intra‑service communication is performed over MQTT using an Eclipse Mosquitto broker. The broker is deployed in a Docker container alongside the TimescaleDB, Dashboard, and Simulation services. MQTT operates over TCP sockets and leverages Docker Compose to create a shared bridge network for all containers. The architecture excludes explicit HTTP REST endpoints; instead, messaging is used for service coordination."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire Digital Twin stack is run locally on a personal computer that is physically connected to the crane. The software consists of Python modules bundled under the gantrylib package and is deployed via Docker Compose, which orchestrates the TimescaleDB database, the Eclipse Mosquitto MQTT broker, and the Grafana dashboard containers. All services are isolated in Docker containers, allowing for on‑premises, edge deployment without cloud involvement. Specific computational and storage requirements are not detailed, but TimescaleDB and Grafana are containerized and can be scaled by increasing container resources."
]