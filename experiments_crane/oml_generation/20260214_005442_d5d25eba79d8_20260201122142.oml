// C2: Acting components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor driven by TMC4671‑Eval controller for horizontal motion"
]
instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor driven by TMC4671‑Eval controller for vertical motion"
]
instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet actuator at hoist end for picking up containers"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures cabin swing angle"
    DTDFVocab:producedData SwingAngleTransmitted
]
instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Measures wind speed above the crane"
    DTDFVocab:producedData WindSpeedTransmitted
]
instance CartMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures cart stepper motor shaft encoder for horizontal position"
    DTDFVocab:producedData CartPositionTransmitted
]
instance HoistMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures hoist stepper motor shaft encoder for vertical position"
    DTDFVocab:producedData HoistHeightTransmitted
]
instance ElectromagnetStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Reports on/off status of the electromagnet actuator"
    DTDFVocab:producedData ElectromagnetStatusTransmitted
]

// C4: Physical‑to‑virtual interaction – Data transmitted
instance SwingAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance WindSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]
instance CartPositionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoder
]
instance HoistHeightTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoder
]
instance ElectromagnetStatusTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ElectromagnetStatusSensor
]

// C10: Models/Data
instance CADFusion360Model : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane system designed in Autodesk Fusion360"
    DTDFVocab:inputTo SimulationEnabler, TrajectoryEnabler
]
instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the crane used for trajectory generation and simulation"
    DTDFVocab:inputTo SimulationEnabler, TrajectoryEnabler
]

// C10: Data
instance CartPositionData : DTDFVocab:Data [
    base:desc "Time-series data of cart horizontal position logged to TimescaleDB"
    DTDFVocab:inputTo LoggingEnabler, ValidationEnabler
    DTDFVocab:fromData CartPositionTransmitted
]
instance HoistHeightData : DTDFVocab:Data [
    base:desc "Time-series data of hoist vertical height logged to TimescaleDB"
    DTDFVocab:inputTo LoggingEnabler, ValidationEnabler
    DTDFVocab:fromData HoistHeightTransmitted
]
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time-series data of cabin swing angle logged to TimescaleDB"
    DTDFVocab:inputTo LoggingEnabler, ValidationEnabler
    DTDFVocab:fromData SwingAngleTransmitted
]
instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time-series data of wind speed logged to TimescaleDB"
    DTDFVocab:inputTo LoggingEnabler, ValidationEnabler
    DTDFVocab:fromData WindSpeedTransmitted
]
instance ElectromagnetStatusData : DTDFVocab:Data [
    base:desc "Time-series data of electromagnet status logged to TimescaleDB"
    DTDFVocab:inputTo LoggingEnabler, ValidationEnabler
    DTDFVocab:fromData ElectromagnetStatusTransmitted
]

// C11: Enablers
instance LoggingEnabler : DTDFVocab:Enabler [
    base:desc "Enables the real‑time data logging service to TimescaleDB"
    DTDFVocab:enables DataLoggingService
]
instance TrajectoryEnabler : DTDFVocab:Enabler [
    base:desc "Enables trajectory generation based on the kinematic model"
    DTDFVocab:enables TrajectoryGenerationService
]
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enables simulation of the crane kinematic model"
    DTDFVocab:enables SimulationService
]
instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enables continuous real‑time validation by comparing telemetry with simulation"
    DTDFVocab:enables ContinuousValidationService
]
instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enables visualization of data via Grafana dashboards"
    DTDFVocab:enables VisualizationService
]
instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Enables fault detection using classification algorithms"
    DTDFVocab:enables FaultDetectionService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs real‑time telemetry to TimescaleDB"
    DTDFVocab:provides LoggingInsight
]
instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal collision‑free trajectories without residual swing"
    DTDFVocab:provides OptimalTrajectoryInsight, ExecuteTrajectoryAction
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Runs simulation of the crane kinematic model"
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares real‑time telemetry against simulation results for validation"
    DTDFVocab:provides ValidationDeviationInsight
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualizes telemetry and validation outcomes via Grafana dashboards"
    DTDFVocab:provides StatusDashboardInsight
]
instance OperatorHMIService : DTDFVocab:Service [
    base:desc "Operator interface for configuration and real‑time status monitoring"
    DTDFVocab:provides ConfigureTrajectoryAction
]
instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults through classification models based on telemetry data"
    DTDFVocab:provides FaultDetectionInsight
]

// C17: Insights
instance LoggingInsight : DTDFVocab:Insight [
    base:desc "Logs all real‑time telemetry for analysis"
]
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Provides computed optimal trajectory for control decisions"
]
instance ValidationDeviationInsight : DTDFVocab:Insight [
    base:desc "Alerts operators to deviations between real‑time data and simulation"
]
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Flags abnormal patterns indicating potential faults"
]
instance StatusDashboardInsight : DTDFVocab:Insight [
    base:desc "Shows real‑time system status on Grafana dashboards"
]

// C17: Actions
instance ExecuteTrajectoryAction : DTDFVocab:Action [
    base:desc "Executes the generated trajectory on the crane under operator control"
    DTDFVocab:IsAutomatic false
]
instance ConfigureTrajectoryAction : DTDFVocab:Action [
    base:desc "Allows operator to configure and initiate a new trajectory"
    DTDFVocab:IsAutomatic false
]
instance ToggleElectromagnetAction : DTDFVocab:Action [
    base:desc "Activates or deactivates the electromagnet actuator"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital twin services compute optimal 3‑D trajectories and publish target cart/hoist positions to the Control Application, which sends command sequences to the TMC4671 controllers via the Crane Interface; Continuous Validation and Simulation Services can issue retraction or safe‑stop commands when thresholds are breached; all commands are transmitted over the same interface via TCP/serial."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Telemetry is logged continuously at ≈10 Hz; trajectory commands are issued instantly; validation checks run every incoming data sample, providing near real‑time coupling between physical and virtual domains."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Container diagram: Physical Crane + Crane Interface + Control App + Logging App + HMI; Digital Twin – Database, MQTT Broker, Trajectory Generator, Simulation Service, Continuous Validation Service, Dashboard; orchestrated via Docker‑compose on a local PC with MQTT as inter‑service messaging backbone."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers design (CAD and kinematic model), manufacturing (physical assembly), and operation (continuous monitoring and validation during use), with historical data retained for post‑hoc analysis."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service compares measured trajectories to simulated ones, computing distance metrics and triggering alerts when deviations exceed thresholds; trajectory generator guarantees no residual swing; historical logs enable model verification; data quality assured by atomic writes to TimescaleDB."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Local Docker bridge network; MQTT broker on port 1883; TimescaleDB accessed via PostgreSQL protocol on port 5432; Arduino to database communication over local TCP/serial; all services publish/subscribe over MQTT topics."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components deployed as Docker containers on a single Ubuntu/POSIX PC; database and broker persist using Docker volumes; gantrylib installed via pip; the entire stack started with docker‑compose; no external cloud deployment."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Employs open industrial protocols – MQTT, PostgreSQL/TimescaleDB, standard SQL; CAD uses standard 3‑D formats from Fusion360."
]