    DTDFVocab:provides DynamicValidationInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service generating and deploying optimal motion profiles (e.g., jerk-limited trajectories) to minimize energy consumption or maximize throughput."
    DTDFVocab:provides OptimalControlInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service implementing real-time synchronization and discrepancy detection between physical and digital twin states."
    DTDFVocab:provides ContinuousValidationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service monitoring sensor residuals and detecting faults (e.g., motor stalls, cable slippage) using machine learning or model-based methods."
    DTDFVocab:provides FaultDetectionInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service providing real-time and offline visualization of crane states, trajectories, and anomalies via 3D CAD and time-series plots."
