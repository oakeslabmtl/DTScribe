// C1: Physical System Components
instance PhysicalCrane : DTDFVocab:Component [
    base:desc "Lab-scale mechanical gantry crane with movable components (hoist, trolley, bridge) for material handling in controlled environment."
]

instance CraneController : DTDFVocab:Component [
    base:desc "Dedicated hardware/software system interfacing with crane actuators/sensors to execute motion commands and ensure operational safety."
]

instance LaboratoryEnvironment : DTDFVocab:Component [
    base:desc "Controlled laboratory setting with constrained motion ranges, low payload capacity, and deterministic conditions."
]

instance HumanMachineInterface : DTDFVocab:Component [
    base:desc "Interface for operator actions and manual adjustments to the crane system."
]

instance DigitalTwinContainer : DTDFVocab:Component [
    base:desc "Container hosting digital twin models, services, and validation logic synchronized with physical crane."
]

// C2: Acting Components
