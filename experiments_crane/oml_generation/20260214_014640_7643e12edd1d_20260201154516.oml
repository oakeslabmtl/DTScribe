// C3: Physical Sensing Components
instance CranePositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Incremental encoder capturing real-time position data of the crane's trolley and bridge components with high precision for kinematic synchronization."
    DTDFVocab:producedData CranePositionData
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring velocity of crane components (trolley, hoist) derived from encoder data or dedicated velocity sensors for dynamic modeling."
    DTDFVocab:producedData CraneVelocityData
]

instance CraneAccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing acceleration data of crane components to enable dynamic validation and trajectory optimization."
    DTDFVocab:producedData CraneAccelerationData
]

instance LoadCellSensor : DTDFVocab:SensingComponent [
    base:desc "Load cell measuring payload weight and force distribution for safety monitoring and dynamic model validation."
    DTDFVocab:producedData LoadData
]

instance ControllerStateSensor : DTDFVocab:SensingComponent [
    base:desc "Interface capturing controller output states including setpoints, control signals, and operational modes for validation purposes."
    DTDFVocab:producedData ControllerStateData
]

instance TrajectoryExecutionLogger : DTDFVocab:SensingComponent [
    base:desc "Logging application capturing actual movement trajectories, residual swinging motion, and end-effector states for validation against simulated trajectories."
    DTDFVocab:producedData TrajectoryExecutionData
]

instance HumanMachineInterfaceSensor : DTDFVocab:SensingComponent [
    base:desc "Interface capturing operator actions and manual adjustments via the Human Machine Interface for synchronization with digital twin."
    DTDFVocab:producedData OperatorActionData
]

// C4: Physical-to-Virtual Interaction
instance CranePositionData : DTDFVocab:DataTransmitted [
    base:desc "Real-time position data transmitted from CranePositionEncoder via Physical Crane Interface using unspecified protocol to Logging Application."
    DTDFVocab:producedFrom CranePositionEncoder
]

instance CraneVelocityData : DTDFVocab:DataTransmitted [
    base:desc "Real-time velocity data transmitted from CraneVelocitySensor via Physical Crane Interface to Logging Application."
    DTDFVocab:producedFrom CraneVelocitySensor
]

instance CraneAccelerationData : DTDFVocab:DataTransmitted [
    base:desc "Real-time acceleration data transmitted from CraneAccelerationSensor via Physical Crane Interface to Logging Application."
    DTDFVocab:producedFrom CraneAccelerationSensor
]

instance LoadData : DTDFVocab:DataTransmitted [
    base:desc "Load and force data transmitted from LoadCellSensor via Physical Crane Interface to Logging Application for dynamic validation."
    DTDFVocab:producedFrom LoadCellSensor
]

instance ControllerStateData : DTDFVocab:DataTransmitted [
    base:desc "Controller state data transmitted from ControllerStateSensor via Physical Crane Interface to Logging Application for synchronization."
    DTDFVocab:producedFrom ControllerStateSensor
]

instance TrajectoryExecutionData : DTDFVocab:DataTransmitted [
    base:desc "Trajectory execution data including actual movement trajectories and residual swinging motion transmitted from TrajectoryExecutionLogger to Logging Application."
    DTDFVocab:producedFrom TrajectoryExecutionLogger
]

instance OperatorActionData : DTDFVocab:DataTransmitted [
    base:desc "Operator action data transmitted from HumanMachineInterfaceSensor via Physical Crane Interface to Logging Application for real-time synchronization."
    DTDFVocab:producedFrom HumanMachineInterfaceSensor
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "Cartesian coordinate-based kinematic model of the gantry crane defining degrees of freedom for trolley, bridge, and hoist movement."
    DTDFVocab:inputTo KinematicSolverEnabler
]

instance DynamicModel : DTDFVocab:Model [
    base:desc "Physics-based dynamic model incorporating rigid-body dynamics, friction, and payload effects for accurate simulation."
    DTDFVocab:inputTo DynamicSimulationEnabler
]

instance ControlModel : DTDFVocab:Model [
    base:desc "Control model implementing PID, MPC, or adaptive control strategies for optimal motion profile generation."
    DTDFVocab:inputTo ControlOptimizationEnabler
]

instance SimulatedTrajectoryData : DTDFVocab:Data [
    base:desc "Precomputed or real-time generated simulated trajectories from TrajectoryGeneratorEnabler for validation against physical execution."
    DTDFVocab:fromData TrajectoryExecutionData
    DTDFVocab:inputTo ContinuousValidationEnabler
]

instance HistoricalCraneData : DTDFVocab:Data [
    base:desc "Time-series historical data repository storing sensor readings, controller outputs, and operational logs at high temporal resolution (1ms-10ms)."
    DTDFVocab:fromData CranePositionData, CraneVelocityData, CraneAccelerationData, LoadData, ControllerStateData
    DTDFVocab:inputTo FaultDetectionEnabler
]

instance RealTimeCraneStateData : DTDFVocab:Data [
    base:desc "Normalized and preprocessed real-time state data from Physical Crane Interface for synchronization with digital twin."
    DTDFVocab:fromData CranePositionData, CraneVelocityData, CraneAccelerationData, LoadData, OperatorActionData
    DTDFVocab:inputTo ContinuousValidationEnabler, DataVisualizationEnabler
]

// C11: Enablers
instance PhysicalCraneInterface : DTDFVocab:Enabler [
    base:desc "Python-based interface normalizing raw sensor/controller data and transmitting it to Logging Application via unspecified protocol."
    DTDFVocab:enables DataNormalizationService, DataTransmissionService
]

instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Application continuously logging crane state data and trajectory execution details to TimescaleDB for validation and analysis."
    DTDFVocab:enables DataStorageService, HistoricalAnalysisService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "Time-series database storing structured crane data with timestamps for querying and historical analysis."
    DTDFVocab:enables DataQueryService, HistoricalAnalysisService
]

instance KinematicSolverEnabler : DTDFVocab:Enabler [
    base:desc "Enabler implementing forward/inverse kinematic solvers (e.g., Cartesian-to-joint transformations) using MATLAB/Simulink or Python."
    DTDFVocab:enables KinematicValidationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Enabler generating optimal motion profiles (e.g., jerk-limited trajectories) using kinematic and dynamic models."
    DTDFVocab:enables OptimalControlService
]

instance DynamicSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler executing physics-based simulations (e.g., rigid-body dynamics) using Simulink or Gazebo."
    DTDFVocab:enables DynamicValidationService
]

instance ControlOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler deploying control algorithms (e.g., PID, MPC) to physical controller via MATLAB/Simulink Real-Time Workshop."
    DTDFVocab:enables OptimalControlService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler implementing online validation methods (e.g., RMSE, cross-correlation) to compare physical and digital twin states."
    DTDFVocab:enables ContinuousValidationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler using machine learning (e.g., isolation forests) or model-based methods (e.g., parity equations) for anomaly detection."
    DTDFVocab:enables FaultDetectionService
]

instance DataVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler rendering 3D CAD models and time-series plots using MATLAB App Designer, Python Dash, or Unity for real-time monitoring."
    DTDFVocab:enables DataVisualizationService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Broker facilitating signaling between services (e.g., notifying Dashboard of validation alerts) for event-driven synchronization."
    DTDFVocab:enables AlertNotificationService
]

instance DarTwinNotation : DTDFVocab:Enabler [
    base:desc "Formal notation documenting evolutionary changes in physical and digital twins (e.g., hardware upgrades, software patches)."
    DTDFVocab:enables SystemEvolutionService
]

// C6: Services
instance DataNormalizationService : DTDFVocab:Service [
    base:desc "Service normalizing raw sensor and controller data before forwarding to Logging Application."
    DTDFVocab:provides DataNormalizationInsight
]

instance DataTransmissionService : DTDFVocab:Service [
    base:desc "Service transmitting normalized data from Physical Crane Interface to Logging Application via unspecified protocol."
