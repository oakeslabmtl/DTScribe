// C2: Acting Components
instance HorizontalMovementMotorController : DTDFVocab:ActingComponent [
    base:desc "Embedded controller interfacing with the horizontal movement motor of the lab-scale gantry crane, enabling precise positioning through closed-loop feedback with the Digital Twin system. Controls motor currents and joint angles for trajectory execution."
]

instance VerticalMovementMotorController : DTDFVocab:ActingComponent [
    base:desc "Embedded controller interfacing with the vertical movement motor of the lab-scale gantry crane, responsible for hoist positioning. Integrates with the Digital Twin's trajectory generation service for real-time control adjustments."
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnetic actuator at the end of the crane's hoist for picking up and releasing containers. Controlled via Python-based Control Application with safety mechanisms for controlled release."
]

// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "High-precision encoder measuring the swinging motion of the crane's hoist to ensure accurate kinematic tracking for trajectory validation."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance CraneAnemometer : DTDFVocab:SensingComponent [
    base:desc "Wind speed sensor deployed at the perimeter of the gantry crane to monitor environmental conditions that may impact crane stability and trajectory execution."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the position of the crane's articulated joints (horizontal and vertical axes) for real-time state monitoring and validation against digital twin simulations."
    DTDFVocab:producedData PositionDataTransmitted
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the velocity of the crane's hoist and joints to support trajectory validation and control adjustments in the digital twin system."
    DTDFVocab:producedData VelocityDataTransmitted
]

instance AccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring acceleration of the crane's pucks and joints to enhance dynamic modeling and validation of simulated trajectories."
    DTDFVocab:producedData AccelerationDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor currents for both horizontal and vertical motors to enable energy consumption analysis and fault detection in the digital twin system."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance JointAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring joint angles of the crane's mechanical structure to support kinematic modeling and validation against the digital twin's trajectory generator."
    DTDFVocab:producedData JointAngleDataTransmitted
]

// C4: Data Transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneAnemometer
]

instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySensor
]

instance AccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AccelerationSensor
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance JointAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointAngleSensor
]

instance ControllerTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, JointAngleSensor
]

// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Geometric and kinematic model representing the lab-scale gantry crane's structure, joints, and load-bearing mechanisms used by the Trajectory Generator Service for motion trajectory computation."
    DTDFVocab:inputTo TrajectoryGeneratorService, ContinuousValidationService
]

instance CraneCADModel : DTDFVocab:Model [
    base:desc "3D CAD representation of the gantry crane's physical structure used for visualization and spatial analysis in the digital twin system."
    DTDFVocab:inputTo VisualizationService
]

instance CraneStateData : DTDFVocab:Data [
    base:desc "Continuously logged time-series data representing the crane's operational state including sensor measurements (position, velocity, acceleration), controller telemetry, and system events."
    DTDFVocab:fromData PositionDataTransmitted, VelocityDataTransmitted, AccelerationDataTransmitted, ControllerTelemetryDataTransmitted
    DTDFVocab:inputTo LoggingApplication, ContinuousValidationService
]

instance TrajectoryExecutionData : DTDFVocab:Data [
    base:desc "Historical data recording executed crane trajectories for offline analysis, enabling root-cause analysis of operational issues and performance optimization."
    DTDFVocab:fromData PositionDataTransmitted, VelocityDataTransmitted
    DTDFVocab:inputTo HistoricalAnalysisService
]

instance SensorFusionData : DTDFVocab:Data [
    base:desc "Processed sensor data resulting from state estimation techniques (e.g., Kalman filtering) used for enhanced trajectory validation and control adjustments."
    DTDFVocab:fromData PositionDataTransmitted, VelocityDataTransmitted, AccelerationDataTransmitted
    DTDFVocab:inputTo ContinuousValidationService
]

// C11: Enablers
instance PythonBasedPhysicalCraneInterface : DTDFVocab:Enabler [
    base:desc "Python-based container connecting the crane's controllers via unspecified proprietary or industry-standard protocols, facilitating physical-to-virtual data interaction."
    DTDFVocab:enables LoggingApplication, ContinuousValidationService
]

instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Primary data acquisition and preprocessing layer that continuously logs crane state data to TimescaleDB, handling raw sensor measurements and controller telemetry."
    DTDFVocab:enables DataStorageService, PreprocessingService
]

instance TimescaleDBDatabase : DTDFVocab:Enabler [
    base:desc "Time-series database storing all operational data including sensor readings, trajectory executions, and system states for real-time monitoring and historical analysis."
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Message broker facilitating inter-service communication between Physical Crane Interface, Logging Application, and database using structured message passing."
]

instance TrajectoryGeneratorService : DTDFVocab:Enabler [
    base:desc "Service utilizing the kinematic model to compute motion trajectories for the crane's articulated joints, supporting real-time trajectory optimization."
    DTDFVocab:enables OptimalControlService
]

instance SimulationService : DTDFVocab:Enabler [
    base:desc "Simulation engine providing physics-based modeling of crane movements, collision detection, and load dynamics for validation against physical execution."
    DTDFVocab:enables ContinuousValidationService
]

instance ContinuousValidationService : DTDFVocab:Enabler [
    base:desc "Real-time validation service comparing simulated trajectories with executed trajectories using distance metrics (e.g., Euclidean or kinematic error calculations)."
]

instance PreprocessingService : DTDFVocab:Enabler [
    base:desc "Data preprocessing layer implementing filtering (e.g., Kalman filtering) and noise reduction techniques on raw sensor data before storage and analysis."
    DTDFVocab:enables DataStorageService
]

instance DataStorageService : DTDFVocab:Enabler [
    base:desc "Service managing the storage and retrieval of operational data from TimescaleDB, supporting historical analysis and real-time monitoring."
    DTDFVocab:enables HistoricalAnalysisService
]

instance VisualizationService : DTDFVocab:Enabler [
    base:desc "Service providing 3D kinematic visualization of the crane's CAD model with real-time sensor data overlays for intuitive debugging and performance monitoring."
]

instance FaultDetectionService : DTDFVocab:Enabler [
    base:desc "Service implementing machine learning or rule-based methods for detecting anomalies in crane operation (e.g., motor failures, sensor drift)."
]

instance ROSMiddleware : DTDFVocab:Enabler [
    base:desc "Robot Operating System middleware enabling real-time communication between sensors, actuators, and digital twin services for closed-loop operation."
    DTDFVocab:enables ControlStrategyService
]

instance DockerComposeOrchestrator : DTDFVocab:Enabler [
    base:desc "Container orchestration tool managing C4 containers (Database, MQTT Broker, Dashboard) for deployment of digital twin services."
]

instance DarTwinNotation : DTDFVocab:Enabler [
    base:desc "Custom metadata schema tracking system evolution (e.g., hardware/software updates) and their impact on digital twin accuracy."
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Real-time trajectory optimization service computing energy-efficient or time-optimal paths for the crane's articulated joints using kinematic/dynamic models."
    DTDFVocab:provides TrajectoryOptimizationInsight, ControlStrategyAdaptationAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Real-time validation service detecting discrepancies between physical and digital states using kinematic residuals and state estimation errors."
    DTDFVocab:provides ValidationMetricsInsight, FaultDetectionInsight
]

instance MonitoringDashboard : DTDFVocab:Service [
    base:desc "Service displaying key performance indicators (KPIs) such as energy consumption, cycle time, and error metrics via web-based or embedded interfaces."
    DTDFVocab:provides PerformanceMonitoringInsight
]

instance HistoricalAnalysisService : DTDFVocab:Service [
    base:desc "Service enabling offline analysis of historical data for root-cause analysis of operational issues and performance optimization."
    DTDFVocab:provides HistoricalTrendInsight
]

instance EvolutionTrackingService : DTDFVocab:Service [
    base:desc "Service tracking system evolution through DarTwin notation, maintaining a versioned digital twin model for retrospective analysis of design changes."
    DTDFVocab:provides EvolutionAnalysisInsight
]

instance ControlStrategyService : DTDFVocab:Service [
    base:desc "Service supporting PID tuning and model-predictive control via bidirectional feedback loops with the physical crane."
    DTDFVocab:provides ControlParameterOptimizationInsight
]

// C17: Insights/Actions
instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized motion trajectories for the crane's articulated joints computed using energy-efficient or time-optimal algorithms."
]

instance ControlStrategyAdaptationAction : DTDFVocab:Action [
    base:desc "Automatic adaptation of control strategies based on real-time validation metrics and operational constraints."
    DTDFVocab:IsAutomatic true
]

instance ValidationMetricsInsight : DTDFVocab:Insight [
    base:desc "Real-time kinematic residuals and state estimation errors comparing simulated trajectories with executed trajectories."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detected anomalies in crane operation including motor failures, sensor drift, and trajectory deviations."
]

instance PerformanceMonitoringInsight : DTDFVocab:Insight [
    base:desc "Key performance indicators including energy consumption, cycle time, and error metrics for operational monitoring."
]

instance HistoricalTrendInsight : DTDFVocab:Insight [
    base:desc "Historical analysis of crane operations enabling root-cause analysis of performance issues and optimization opportunities."
]

instance EvolutionAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analysis of system evolution changes tracked through DarTwin notation, assessing impact on digital twin accuracy."
]

instance ControlParameterOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized control parameters for PID tuning and model-predictive control strategies."
]

// C18: Environments/Components
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Physical environment containing the lab-scale gantry crane system including mechanical structure, embedded controllers, and sensors."
    base:contains MechanicalGantryStructure, EmbeddedController, CraneSensors
]

instance MechanicalGantryStructure : DTDFVocab:Component [
    base:desc "Physical structure of the lab-scale gantry crane including kinematic joints and load-bearing mechanisms."
    base:isContainedIn LabScaleGantryCraneEnvironment
]

instance EmbeddedController : DTDFVocab:Component [
    base:desc "Hardware/software interface between physical sensors/actuators and digital twin services, enabling real-time monitoring and control adjustments."
    base:isContainedIn LabScaleGantryCraneEnvironment
]

instance CraneSensors : DTDFVocab:Component [
    base:desc "Collection of sensors including swing angle encoder, anemometer, position/velocity/acceleration sensors, and motor current/joint angle sensors."
    base:isContainedIn LabScaleGantryCraneEnvironment
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:desc "Digital environment containing all computational components of the digital twin system including models, services, and data storage."
    base:contains CraneKinematicModel, CraneCADModel, LoggingApplication, ContinuousValidationService
]

instance CraneKinematicModel : DTDFVocab:Component [
    base:desc "Geometric and kinematic model representing the lab-scale gantry crane's structure, joints, and load-bearing mechanisms used by the Trajectory Generator Service for motion trajectory computation."
    base:isContainedIn DigitalTwinEnvironment
]

instance CraneCADModel : DTDFVocab:Component [
    base:desc "3D CAD representation of the gantry crane's physical structure used for visualization and spatial analysis in the digital twin system."
    base:isContainedIn DigitalTwinEnvironment
]

instance LoggingApplication : DTDFVocab:Component [
    base:desc "Primary data acquisition and preprocessing layer that continuously logs crane state data to TimescaleDB, handling raw sensor measurements and controller telemetry."
    base:isContainedIn DigitalTwinEnvironment
]

instance ContinuousValidationService : DTDFVocab:Component [
    base:desc "Real-time validation service comparing simulated trajectories with executed trajectories using distance metrics (e.g., Euclidean or kinematic error calculations)."
    base:isContainedIn DigitalTwinEnvironment
]

