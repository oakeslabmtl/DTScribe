// C2: Acting Components
instance PhysicalCraneInterface : DTDFVocab:ActingComponent [
    base:desc "Python interface that reads sensor data from an Arduino over serial/USB, writes time‑stamped crane state to TimescaleDB, and reads current state to generate control commands."
]

instance MotorDriverTMC4671Cart : DTDFVocab:ActingComponent [
    base:desc "TMC4671 motor driver controlling the cart motor via serial/USB."
]

instance MotorDriverTMC4671Hoist : DTDFVocab:ActingComponent [
    base:desc "TMC4671 motor driver controlling the hoist motor via serial/USB."
]

// C3: Physical sensing components
instance CartEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder attached to the cart motor measuring horizontal position and velocity."
    DTDFVocab:producedData CartEncoderTelemetry
]

instance HoistEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder attached to the hoist motor measuring vertical position and velocity."
    DTDFVocab:producedData HoistEncoderTelemetry
]

instance SwingAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the hoist cable."
    DTDFVocab:producedData SwingAngleTelemetry
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed that affects crane dynamics."
    DTDFVocab:producedData AnemometerTelemetry
]

instance ArduinoSerialInterfaceSensor : DTDFVocab:SensingComponent [
    base:desc "Arduino collecting all sensor signals and publishing them over serial/USB."
    DTDFVocab:producedData ArduinoSerialTelemetry
]

// Virtual output sensors for service results
instance TrajectoryGeneratorOutputSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor representing trajectory data generated by the Trajectory Generation Service."
    DTDFVocab:producedData TrajectoryDataTelemetry
]

instance SimulatorOutputSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor representing simulation outputs from the Simulator Service."
    DTDFVocab:producedData SimulationOutputTelemetry
]

instance CADModelGeneratorSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor representing CAD model data used by the Simulator Service."
    DTDFVocab:producedData CADModelTelemetry
]

// C4: Data transmitted
instance CartEncoderTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartEncoderSensor
]

instance HoistEncoderTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistEncoderSensor
]

instance SwingAngleTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensor
]

instance AnemometerTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance ArduinoSerialTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoSerialInterfaceSensor
]

instance TrajectoryDataTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TrajectoryGeneratorOutputSensor
]

instance SimulationOutputTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulatorOutputSensor
]

instance CADModelTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CADModelGeneratorSensor
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "First‑principles kinematic model used for optimal, swing‑free trajectory planning."
    DTDFVocab:inputTo TrajectoryGeneratorContainer
]

instance CADModelData : DTDFVocab:Data [
    base:desc "CAD geometry of the lab‑scale gantry crane used by the Simulator Service."
    DTDFVocab:inputTo SimulatorContainer
    DTDFVocab:fromData CADModelTelemetry
]

// Data from sensors
instance CartEncoderDataSeries : DTDFVocab:Data [
    base:desc "Time‑series of cart motor encoder counts stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDBContainer
    DTDFVocab:fromData CartEncoderTelemetry
]

instance HoistEncoderDataSeries : DTDFVocab:Data [
    base:desc "Time‑series of hoist motor encoder counts stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDBContainer
    DTDFVocab:fromData HoistEncoderTelemetry
]

instance SwingAngleDataSeries : DTDFVocab:Data [
    base:desc "Time‑series of swing angle measurements stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDBContainer
    DTDFVocab:fromData SwingAngleTelemetry
]

instance AnemometerDataSeries : DTDFVocab:Data [
    base:desc "Time‑series of wind speed readings stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDBContainer
    DTDFVocab:fromData AnemometerTelemetry
]

instance CraneStateAggregatedData : DTDFVocab:Data [
    base:desc "Aggregated time‑stamped crane state data read from Arduino and stored in TimescaleDB."
    DTDFVocab:inputTo TimescaleDBContainer
    DTDFVocab:fromData ArduinoSerialTelemetry
]

// Data from services
instance TrajectoryDataFile : DTDFVocab:Data [
    base:desc "Optimal trajectory data generated by the Trajectory Generation Service, used for simulation and validation."
    DTDFVocab:inputTo TrajectoryGeneratorContainer
    DTDFVocab:inputTo ValidationContainer
    DTDFVocab:fromData TrajectoryDataTelemetry
]

instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Simulation output time‑series from the Simulator Service used for validation and fault classification."
    DTDFVocab:inputTo ValidationContainer
    DTDFVocab:fromData SimulationOutputTelemetry
]

// C11: Enablers (Docker containers)
instance TimescaleDBContainer : DTDFVocab:Enabler [
    base:desc "Docker container running TimescaleDB for logging, validation, fault detection, and visualization."
    DTDFVocab:enables DataLoggingService, ContinuousValidationService, FaultDetectionService, VisualizationService
]

instance MosquittoBrokerContainer : DTDFVocab:Enabler [
    base:desc "Docker container running Eclipse Mosquitto MQTT broker for inter‑service communication."
    DTDFVocab:enables TrajectoryGenerationService, SimulatorService
]

instance GrafanaContainer : DTDFVocab:Enabler [
    base:desc "Docker container running Grafana for real‑time dashboard visualization."
    DTDFVocab:enables VisualizationService
]

instance TrajectoryGeneratorContainer : DTDFVocab:Enabler [
    base:desc "Docker container running the Trajectory Generation Service."
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulatorContainer : DTDFVocab:Enabler [
    base:desc "Docker container running the Simulator Service."
    DTDFVocab:enables SimulatorService
]

instance ValidationContainer : DTDFVocab:Enabler [
    base:desc "Docker container running the Continuous Validation Service and Fault Detection Service."
    DTDFVocab:enables ContinuousValidationService, FaultDetectionService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs time‑stamped crane state into TimescaleDB via the PostgreSQL wire protocol."
    DTDFVocab:provides InsightDataLoggingInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates executed trajectories against simulated data, computing distance metrics."
    DTDFVocab:provides InsightValidationResultInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults by classifying time‑series using machine‑learning on simulation outputs."
    DTDFVocab:provides InsightFaultDetectionInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal, swing‑free trajectories using the kinematic model."
    DTDFVocab:provides InsightOptimalTrajectoryInsight, ActionGenerateTrajectoryAction
]

instance SimulatorService : DTDFVocab:Service [
    base:desc "Simulates crane dynamics and controller behavior."
    DTDFVocab:provides InsightSimulationResultInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides Grafana dashboards for real‑time state, validation, and fault‑detection visualization."
    DTDFVocab:provides InsightGrafanaDashboardInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Enables operator control and configuration via a human‑machine interface."
    DTDFVocab:provides ActionOperatorControlAction
]

// C17: Insights and Actions
instance InsightDataLoggingInsight : DTDFVocab:Insight [
    base:desc "Shows that crane state data has been successfully logged into TimescaleDB."
]

instance InsightOptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Provides a swing‑free trajectory plan computed by the kinematic model."
]

instance InsightSimulationResultInsight : DTDFVocab:Insight [
    base:desc "Displays simulation results of crane dynamics and controller behavior."
]

instance InsightValidationResultInsight : DTDFVocab:Insight [
    base:desc "Compares executed trajectories with simulated data and reports distance metrics."
]

instance InsightFaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Indicates detected fault conditions based on time‑series classification."
]

instance InsightGrafanaDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time Grafana dashboard displaying state, validation, and fault alerts."
]

instance ActionGenerateTrajectoryAction : DTDFVocab:Action [
    base:desc "Action to generate and transmit a new trajectory plan to the crane."
    DTDFVocab:IsAutomatic true
]

instance ActionOperatorControlAction : DTDFVocab:Action [
    base:desc "Manual operator command to adjust control parameters or intervene."
    DTDFVocab:IsAutomatic false
]

// Environment
instance EnvironmentLabScaleCrane : DTDFVocab:Environment [
    base:contains PhysicalCraneInterface, MotorDriverTMC4671Cart, MotorDriverTMC4671Hoist,
    CartEncoderSensor, HoistEncoderSensor, SwingAngleEncoderSensor, AnemometerSensor,
    ArduinoSerialInterfaceSensor, TrajectoryGeneratorOutputSensor, SimulatorOutputSensor,
    CADModelGeneratorSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin’s Control Application generates motor commands (step pulses or PWM commands) to achieve a desired trajectory. It serially transmits these commands through the Physical Crane Interface to the TMC4671 motor drivers, which drive the cart and hoist motors. No intermediate MQTT layer is used for PT–DT control traffic."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate continuously in real time. The Logging Application logs sensor data at the native sampling rate of the sensors (≈10 Hz to 100 Hz as implied by the rotor and motor drivers), the Continuous Validation Service performs continuous checks each cycle, and the Dashboard updates in real time. There is no explicit discrete campaign mode mentioned."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A C4‑model based architecture with several containers: on the physical side the crane, its interface, control, logging, and HMI; on the digital side the MQTT broker, database, dashboard, trajectory generator, simulator, and continuous validation services. The entire constellation is deployed via a single docker‑compose configuration on a personal PC, providing a coherent twin ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design – CAD models (Autodesk Fusion 360) and kinematic models; Manufacturing – physical assembly of the crane hardware (motors, controllers, Arduino board, shield); Operation – runtime twin services (logging, simulation, validation) that interact with the PT during daily use."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous validation ensures model fidelity by comparing live sensor data against simulated trajectories; distance metrics are computed and threshold breaches trigger alerts. Time‑series classification techniques are applied to detect faults. All models are validated against measured data during operation, and uncertainty is managed by confidence bounds displayed in the Grafana dashboards."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Physical Crane Interface communicates with the Arduino via a UART serial link over USB. The interface writes data to TimescaleDB over the PostgreSQL wire protocol. Services exchange messages via the Eclipse Mosquitto MQTT broker over standard MQTT protocol on localhost. The Docker Compose network exposes HTTP endpoints for Grafana and database clients. All communications use TCP sockets."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital twin components are containerized with Docker, launched using docker‑compose on a commodity PC. The host OS is unspecified but typically Linux; the Docker network provides isolation and easy scaling of individual services."
]