namespace base = "http://example.org/base"
namespace DTDFVocab = "http://example.org/DTDFVocab"
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service for logging historical crane operational metrics",
    DTDFVocab:provides OperationalMetricsInsight
]
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service optimizing crane movement trajectories for efficiency",
    DTDFVocab:provides MovementOptimizationAction
]
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real-time visualization interface for crane operational data",
    DTDFVocab:provides RealTimeVisualizationInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service ensuring continuous alignment of physical and digital twin states",
    DTDFVocab:provides StateAlignmentInsight
]
instance AirQualityRuntimeVisualizationService : DTDFVocab:Service [
    base:desc "Runtime visualization application for indoor air quality management",
    DTDFVocab:provides AirQualityVisualizationInsight
]
instance AirQualitySimulationService : DTDFVocab:Service [
    base:desc "Simulation application for indoor air quality scenarios",
    DTDFVocab:provides AirQualitySimulationInsight
]
instance AirQualityPredictionService : DTDFVocab:Service [
    base:desc "Prediction application for indoor air quality trends",
    DTDFVocab:provides AirQualityPredictionInsight
]
instance ArchitectureVisualizationService : DTDFVocab:Service [
    base:desc "Visualization service for system architecture using C4 model",
    DTDFVocab:provides ArchitectureVisualizationInsight
]
instance MDEService : DTDFVocab:Service [
    base:desc "Service supporting Model-Driven Engineering approach",
    DTDFVocab:provides MDEInsight
]
instance VersionControlService : DTDFVocab:Service [
    base:desc "Service managing version history of digital twin components",
    DTDFVocab:provides VersionHistoryInsight
]
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database enabler for historical data storage",
    DTDFVocab:enables HistoricalDataLoggingService
]
instance OptimalControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for optimal control algorithms in crane movement",
    DTDFVocab:enables OptimalControlService
]
instance RealTimeVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for real-time crane data visualization",
    DTDFVocab:enables RealTimeVisualizationService
]
instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for continuous validation between physical and digital states",
    DTDFVocab:enables ContinuousValidationService
]
instance AzureCloudEnabler : DTDFVocab:Enabler [
    base:desc "Microsoft Azure cloud services enabler for digital twin pipeline",
    DTDFVocab:enables AirQualityRuntimeVisualizationService, AirQualitySimulationService, AirQualityPredictionService
]
instance C4ModelEnabler : DTDFVocab:Enabler [
    base:desc "C4 model visualization tool for system architecture",
    DTDFVocab:enables ArchitectureVisualizationService
]
instance MDEEnabler : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering enabler for Air Quality Management",
    DTDFVocab:enables MDEService
]
instance GitHubVersionControlEnabler : DTDFVocab:Enabler [
    base:desc "GitHub repository for version control of digital twin artifacts",
    DTDFVocab:enables VersionControlService
]
instance CraneStateData : DTDFVocab:Data [
    base:desc "Crane state data logged into TimescaleDB",
    DTDFVocab:fromData CraneStateDataTransmitted,
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance AirQualityData : DTDFVocab:Data [
    base:desc "Indoor air quality data used for virus spread prevention",
    DTDFVocab:fromData AirQualityDataTransmitted,
    DTDFVocab:inputTo AzureCloudEnabler
]
instance C4Model : DTDFVocab:Model [
    base:desc "C4 architecture model for Gantry Crane system visualization",
    DTDFVocab:inputTo C4ModelEnabler
]
instance MDEModel : DTDFVocab:Model [
    base:desc "Model-Driven Engineering model for Air Quality Management exemplar",
    DTDFVocab:inputTo MDEEnabler
]
instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneStateSensor,
    base:desc "Transmitted data stream from crane state sensors"
]
instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualitySensor,
    base:desc "Transmitted data stream from air quality sensors"
]
instance CraneStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors monitoring crane state data in physical lab-scale gantry crane system",
    DTDFVocab:producedData CraneStateDataTransmitted
]
instance AirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors monitoring indoor air quality parameters",
    DTDFVocab:producedData AirQualityDataTransmitted
]
instance OperationalMetricsInsight : DTDFVocab:Insight [
    base:desc "Insight into crane operational performance metrics from historical data"
]
instance MovementOptimizationAction : DTDFVocab:Action [
    base:desc "Automated movement optimization to improve crane efficiency",
    DTDFVocab:IsAutomatic true
]
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visual representation of crane state for monitoring"
]
instance StateAlignmentInsight : DTDFVocab:Insight [
    base:desc "Insight into the accuracy of digital twin representation of physical crane"
]
instance AirQualityVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of indoor air quality for virus spread prevention"
]
instance AirQualitySimulationInsight : DTDFVocab:Insight [
    base:desc "Simulated air quality scenarios for virus spread analysis"
]
instance AirQualityPredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive insights on indoor air quality for preventive measures"
]
instance ArchitectureVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight into system architecture structure for Gantry Crane"
]
instance MDEInsight : DTDFVocab:Insight [
    base:desc "Insight into Model-Driven Engineering process for digital twin development"
]
instance VersionHistoryInsight : DTDFVocab:Insight [
    base:desc "Insight into version history and changes of digital twin artifacts"
]
instance GantryCraneSystem : DTDFVocab:SystemUnderStudy [
    base:desc "Lab-scale gantry crane system including physical structure and dedicated controller",
    DTDFVocab:hasEnvironment LaboratoryEnvironment
]
instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Python-based interface for physical crane data transmission"
]
instance TimescaleDBDatabase : DTDFVocab:Component [
    base:desc "TimescaleDB database for storing crane state data"
]
instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains PhysicalCraneInterface, TimescaleDBDatabase
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are issued by the Control Application (Python) through the Physical Crane Interface to execute movements on the Physical Crane. Specific command types, message formats, validation and authentication mechanisms, feedback systems, conflict resolution, and command execution confirmation details are not provided in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Utilizes the C4 Model to visualize and describe the system architecture via context and container diagrams, detailing component interactions and structure."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Digital twin services communicate via an MQTT broker for signaling. TimescaleDB is used for data storage and Grafana for visualization. Network topology, bandwidth, latency, reliability, redundancy, and security protocols are not specified in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "AutomationML is used for digital twin modeling in the Air Quality Management exemplar, and the C4 Model is applied for system architecture description in the Gantry Crane system."
]