]

instance GreenhouseDataVisualizationService : DTDFVocab:Service [
    base:desc "Runtime visualization service for greenhouse environmental metrics with interactive parameter adjustment capabilities"
    DTDFVocab:provides GreenhouseEnvironmentalStatusInsight
]

instance AirQualityRuntimeVisualizationService : DTDFVocab:Service [
    base:desc "Real-time dashboard service for air quality monitoring with interactive 3D environmental visualization"
