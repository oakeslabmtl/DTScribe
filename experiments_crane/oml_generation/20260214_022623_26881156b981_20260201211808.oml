// C3: Physical Sensing Components
instance CraneEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Proximity sensor and encoder array for tracking puck/container position and velocity in the lab-scale gantry crane system"
    DTDFVocab:producedData CranePositionDataTransmitted
]

instance GreenhouseEnvironmentSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded sensor array within the greenhouse capturing real-time environmental metrics including temperature, humidity, and CO2 levels"
    DTDFVocab:producedData GreenhouseEnvironmentDataTransmitted
]

instance AirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry Pi-integrated sensor network for monitoring air quality parameters including particulate matter, volatile organic compounds, and virus spread indicators"
    DTDFVocab:producedData AirQualityDataTransmitted
]

instance CraneLoadSensor : DTDFVocab:SensingComponent [
    base:desc "Load cell sensors measuring crane payload weight and distribution for dynamic control calculations"
    DTDFVocab:producedData CraneLoadDataTransmitted
]

instance CraneIMUSensor : DTDFVocab:SensingComponent [
    base:desc "Inertial measurement unit capturing acceleration, orientation, and vibration data for kinematic validation"
    DTDFVocab:producedData CraneIMUDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance CranePositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneEncoderSensor
]

instance GreenhouseEnvironmentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseEnvironmentSensor
]

instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualitySensor
]

instance CraneLoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneLoadSensor
]

instance CraneIMUDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneIMUSensor
]

// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Geometric and kinematic model of the lab-scale gantry crane including joint trajectories, constraints, and dynamic response characteristics"
    DTDFVocab:inputTo CraneSimulationEnabler
]

instance GreenhouseBehavioralModel : DTDFVocab:Model [
    base:desc "Self-adaptive model of greenhouse environmental dynamics with behavioral feedback loops between physical greenhouse and digital twin"
    DTDFVocab:inputTo GreenhouseSimulationEnabler
]

instance AirQualitySimulationModel : DTDFVocab:Model [
    base:desc "AutomationML-based digital twin model for air quality management including virus spread prediction and environmental condition simulations"
    DTDFVocab:inputTo AirQualitySimulationEnabler
]

instance CraneTrajectoryDatabase : DTDFVocab:Data [
    base:desc "Structured time-series database storing historical crane movement trajectories, sensor readings, and control command logs"
    DTDFVocab:fromData CranePositionDataTransmitted, CraneLoadDataTransmitted, CraneIMUDataTransmitted
    DTDFVocab:inputTo DataLoggingEnabler
]

instance GreenhouseEnvironmentDatabase : DTDFVocab:Data [
    base:desc "Time-series database capturing greenhouse environmental metrics with temporal alignment for behavioral adaptation analysis"
    DTDFVocab:fromData GreenhouseEnvironmentDataTransmitted
    DTDFVocab:inputTo GreenhouseDataProcessingEnabler
]

instance AirQualityTimeSeriesData : DTDFVocab:Data [
    base:desc "InfluxDB-stored time-series data containing air quality sensor readings and processed environmental metrics"
    DTDFVocab:fromData AirQualityDataTransmitted
    DTDFVocab:inputTo AirQualityDataProcessingEnabler
]

instance PreRecordedValidationDataset : DTDFVocab:Data [
    base:desc "Pre-recorded sensor data stored within virtual machine images for digital twin installation testing and validation"
    DTDFVocab:inputTo ValidationEnabler
]

// C11: Enablers
instance CraneSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python-based kinematic simulation engine using PyBullet for modeling joint trajectories, constraints, and dynamic response of the gantry crane"
    DTDFVocab:enables CraneOptimalControlService, CraneDataVisualizationService
]

instance GreenhouseSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Model-driven simulation environment for greenhouse behavioral adaptation with real-time feedback loop processing"
    DTDFVocab:enables GreenhouseBehavioralAdaptationService
]

instance AirQualitySimulationEnabler : DTDFVocab:Enabler [
    base:desc "AutomationML-based simulation platform integrated with Microsoft Azure for cloud-based air quality modeling and prediction"
    DTDFVocab:enables AirQualityRuntimeVisualizationService, AirQualityPredictionService
]

instance DataLoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB-based logging system continuously capturing crane sensor data with real-time synchronization capabilities"
    DTDFVocab:enables CraneHistoricalDataLoggingService
]

instance GreenhouseDataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Containerized data processing pipeline for greenhouse environmental metrics with adaptive behavioral analysis capabilities"
    DTDFVocab:enables GreenhouseDataVisualizationService
]

instance AirQualityDataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB and Azure-based processing pipeline for air quality time-series data with predictive analytics capabilities"
    DTDFVocab:enables AirQualityRuntimeVisualizationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation system comparing simulated outputs with real-world sensor data using residual analysis and adaptive calibration"
    DTDFVocab:enables CraneContinuousValidationService
]

instance MessageBrokerEnabler : DTDFVocab:Enabler [
    base:desc "ActiveMQ-based message broker facilitating real-time communication between physical sensors and digital twin services"
    DTDFVocab:enables CraneDataTransmissionService, GreenhouseDataTransmissionService
]

instance ContainerizationEnabler : DTDFVocab:Enabler [
    base:desc "Docker/Kubernetes-based containerization platform enabling modular deployment of digital twin services and data processing components"
    DTDFVocab:enables CraneDataTransmissionService, GreenhouseDataTransmissionService, CraneContinuousValidationService, GreenhouseDataVisualizationService
]

// C6: Services
instance CraneOptimalControlService : DTDFVocab:Service [
    base:desc "Dynamic adjustment service for crane operations including load positioning, speed optimization, and trajectory planning to minimize energy consumption"
    DTDFVocab:provides CraneOptimalTrajectoryInsight, CraneEnergyEfficiencyAction
]

