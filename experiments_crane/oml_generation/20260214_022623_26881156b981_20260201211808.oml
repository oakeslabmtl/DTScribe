]

instance AirQualityPredictionService : DTDFVocab:Service [
    base:desc "Predictive analytics service for virus spread modeling and environmental condition forecasting"
    DTDFVocab:provides AirQualityPredictionInsight
]

instance CraneDataTransmissionService : DTDFVocab:Service [
    base:desc "Service for transmitting real-time sensor data from physical crane to digital twin components"
    DTDFVocab:provides CraneDataTransmissionInsight
]

instance GreenhouseDataTransmissionService : DTDFVocab:Service [
