    DTDFVocab:provides CraneModelFidelityInsight
]

instance GreenhouseBehavioralAdaptationService : DTDFVocab:Service [
    base:desc "Self-adaptive service maintaining behavioral synchronization between physical greenhouse and its digital twin counterpart"
