// -------------------------------------------------
// C3: Physical sensing components
// -------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing",
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed",
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorControllerStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Arduino‑based acquisition of motor controller status and other low‑level signals",
    DTDFVocab:producedData MotorStatusDataTransmitted
]

// -------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// -------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerStatusSensor
]

// -------------------------------------------------
// C10: Data instances (time‑series)
// -------------------------------------------------
instance SwingAngleTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle measurements",
    DTDFVocab:fromData SwingAngleDataTransmitted,
    DTDFVocab:inputTo TimescaleDatabase, MosquittoBroker
]

instance WindSpeedTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements",
    DTDFVocab:fromData WindSpeedDataTransmitted,
    DTDFVocab:inputTo TimescaleDatabase, MosquittoBroker
]

instance MotorStatusTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of motor controller status signals",
    DTDFVocab:fromData MotorStatusDataTransmitted,
    DTDFVocab:inputTo TimescaleDatabase, MosquittoBroker
]

// -------------------------------------------------
// C2: Acting components
// -------------------------------------------------
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor that drives gantry motion"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor that lifts the electromagnet"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist used to pick and place pucks"
]

// -------------------------------------------------
// C10: Models
// -------------------------------------------------
instance Fusion360CADModel : DTDFVocab:Model [
    base:desc "CAD model of the lab‑scale gantry crane (Autodesk Fusion360)"
]

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator to compute swing‑free paths"
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model used by the Simulation Service"
]

// -------------------------------------------------
// C11: Enablers (tools & platforms)
// -------------------------------------------------
instance MosquittoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for publishing sensor data and trajectory messages",
    DTDFVocab:enables LoggingApplication, VisualizationDashboard, TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

instance TimescaleDatabase : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL‑based time‑series DB) storing measurement data",
    DTDFVocab:enables LoggingApplication, ContinuousValidationService
]

instance DockerComposeRuntime : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestration for all containerised services",
    DTDFVocab:enables LoggingApplication, VisualizationDashboard, TrajectoryGeneratorService, SimulationService, ContinuousValidationService, HumanMachineInterface
]

instance PythonGantrayLib : DTDFVocab:Enabler [
    base:desc "Python ‘gantrylib’ module (open‑source) providing kinematics, simulation and validation utilities",
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboards for real‑time visualization of crane data",
    DTDFVocab:enables VisualizationDashboard
]

// -------------------------------------------------
// C6: Services
// -------------------------------------------------
instance LoggingApplication : DTDFVocab:Service [
    base:desc "Data logging application that writes time‑series data into TimescaleDB",
    DTDFVocab:provides PersistMeasurementData
]

instance VisualizationDashboard : DTDFVocab:Service [
    base:desc "Grafana dashboard presenting live sensor readings and simulation results",
    DTDFVocab:provides DisplayVisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service that generates optimal swing‑free trajectories for the crane",
    DTDFVocab:provides GenerateOptimalTrajectory
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation of crane dynamics and controllers",
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates executed trajectories against simulation predictions",
    DTDFVocab:provides ExecutionDeviationAlert
]

instance HumanMachineInterface : DTDFVocab:Service [
    base:desc "Operator front‑end (HMI) allowing manual intervention and monitoring",
    DTDFVocab:provides OperatorInterventionAction
]

// -------------------------------------------------
// C17: Insights & Actions
// -------------------------------------------------
instance PersistMeasurementData : DTDFVocab:Action [
    base:desc "Writes incoming sensor time‑series into the TimescaleDB",
    DTDFVocab:IsAutomatic true
]

instance DisplayVisualizationInsight : DTDFVocab:Insight [
    base:desc "Shows live sensor and simulation data on Grafana dashboards"
]

instance GenerateOptimalTrajectory : DTDFVocab:Action [
    base:desc "Computes optimal, swing‑free trajectories for pallet movement",
    DTDFVocab:IsAutomatic true
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Provides physics‑based simulation outputs for comparison with real execution"
]

instance ExecutionDeviationAlert : DTDFVocab:Insight [
    base:desc "Alerts operators when executed trajectories deviate from simulated expectations"
]

instance OperatorInterventionAction : DTDFVocab:Action [
    base:desc "Allows the operator to intervene and adjust crane commands after an alert",
    DTDFVocab:IsAutomatic false
]

// -------------------------------------------------
// C1: System under study (environment)
// -------------------------------------------------
instance LabScaleGantryCrane : DTDFVocab:Environment [
    base:contains CartStepperMotor, HoistStepperMotor, ElectromagnetActuator,
                SwingAngleEncoder, Anemometer, MotorControllerStatusSensor,
                Fusion360CADModel, KinematicTrajectoryModel, PhysicsSimulationModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (e.g., move cart, move hoist, activate electromagnet) are generated by the Trajectory Generator Service or issued by the Human‑Machine Interface, sent over MQTT to the Control Application, which uses the Physical Crane Interface to drive the motor controllers via serial/USB links."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A cyber‑physical system where the physical crane is linked to a Python‑based Physical Crane Interface; the interface communicates via MQTT with six Docker‑container services (Database, MQTT broker, Dashboard, Trajectory Generator, Simulation, Continuous Validation). The Control Application and Human‑Machine Interface issue commands, while the Logging Application continuously records state to the database; all services run on a single personal computer."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated ones, computes distance metrics, checks against predefined thresholds, and alerts operators via the dashboard when deviations exceed acceptable limits, thereby assessing model fidelity in real time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Mosquitto MQTT broker is used for all inter‑service signaling; Python applications communicate with the Arduino over serial/USB; Docker containers share a common network on the host PC; the database is accessed via standard PostgreSQL/SQL connections."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software components run on a personal computer. The database, MQTT broker, and Grafana dashboard are Docker‑containerized and started with a single Docker‑Compose command. The Python modules are installed via pip and executed directly on the host OS."
]