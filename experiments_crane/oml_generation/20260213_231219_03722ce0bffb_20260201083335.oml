// C3: Physical sensing components
instance SwingAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Swing-angle encoder measuring hoist swing angle"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorControllerFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Built‑in position feedback from the Trinamic TMC4671 stepper motor controllers"
    DTDFVocab:producedData MotorFeedbackDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensor
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorFeedbackDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerFeedbackSensor
]

// C10: Data (from DataTransmitted)
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series swing‑angle measurements streamed via MQTT and stored in TimescaleDB"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series wind‑speed measurements streamed via MQTT and stored in TimescaleDB"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance MotorFeedbackData : DTDFVocab:Data [
    base:desc "Position feedback data from stepper motor controllers streamed via MQTT and stored in TimescaleDB"
    DTDFVocab:fromData MotorFeedbackDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

// C10: Models/Data
instance CADCraneModel : DTDFVocab:Model [
    base:desc "Detailed CAD model of the gantry crane used for visualization"
    DTDFVocab:inputTo GrafanaEnabler
]

instance KinematicCraneModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Optimal Trajectory Generation Service"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the crane and its controllers used by the Crane Simulation Service"
    DTDFVocab:inputTo SimulationEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB container storing logged sensor data"
    DTDFVocab:enables DataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for event‑driven communication"
    DTDFVocab:enables DataVisualizationService, ContinuousValidationService, OptimalTrajectoryGenerationService, CraneSimulationService, HumanMachineInterfaceService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana container providing dashboards for data visualization"
    DTDFVocab:enables DataVisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Docker container running the Optimal Trajectory Generation algorithm"
    DTDFVocab:enables OptimalTrajectoryGenerationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Docker container executing the dynamic crane simulation"
    DTDFVocab:enables CraneSimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Service container performing continuous validation of measured vs simulated trajectories"
    DTDFVocab:enables ContinuousValidationService
]

instance HMIEnabler : DTDFVocab:Enabler [
    base:desc "Human‑Machine Interface container allowing operator control"
    DTDFVocab:enables HumanMachineInterfaceService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that logs sensor data into TimescaleDB"
    DTDFVocab:provides TrendVisualizationInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service that visualizes logged data via Grafana dashboards"
    DTDFVocab:provides TrendVisualizationInsight
]

instance OptimalTrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free trajectories based on the kinematic model"
    DTDFVocab:provides OptimalSwingFreeTrajectoryInsight
]

instance CraneSimulationService : DTDFVocab:Service [
    base:desc "Runs dynamic simulation of crane and controller behavior"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates measured trajectories against simulation results"
    DTDFVocab:provides ValidationAlertInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Provides operator control interface for the digital twin"
    DTDFVocab:provides AdjustControlParametersAction
]

// C17: Insights
instance OptimalSwingFreeTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Provides the optimal swing‑free trajectory for the crane payload"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when measured vs simulated trajectory deviates beyond tolerance"
]

instance TrendVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual trends of sensor data displayed on Grafana dashboard"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation results of crane dynamics for validation and planning"
]

// C17: Actions
instance AdjustControlParametersAction : DTDFVocab:Action [
    base:desc "Operator can adjust control parameters via the HMI"
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance CartStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor driven by a Trinamic TMC4671‑Eval controller"
]

instance HoistStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor driven by a Trinamic TMC4671‑Eval controller"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist end for picking pucks"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin generates optimal trajectories using the Trajectory Generator Service and transmits motion commands through the Control Application to the Physical Crane Interface, which drives the cart and hoist motors; the Continuous Validation Service can also issue operator alerts that result in manual intervention via the Human‑Machine Interface."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "All software runs on a single PC; Docker containers host the database, MQTT broker, and Grafana dashboard, while Python modules implement the Physical Crane Interface, Control Application, Logging Application, HMI, Trajectory Generator, Simulation, and Continuous Validation services. Communication occurs via MQTT messages and SQL queries to TimescaleDB."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares executed trajectories with simulation outputs, calculates distance metrics, and checks them against predefined thresholds; violations trigger operator notifications on the Grafana dashboard, ensuring model fidelity and system safety."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication uses the Eclipse Mosquitto MQTT broker (publish‑subscribe pattern) for signalling. The TimescaleDB is accessed via standard PostgreSQL SQL queries over TCP. The Physical Crane Interface is a Python program that connects to the crane controllers (communication method not further specified in the document). No additional network protocols are described."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire stack is deployed on a personal computer. Docker containers (TimescaleDB, MQTT broker, Grafana) are started with a single docker‑compose command. Python components are installed via pip from the gantrylib package. The repository provides scripts for first‑time setup."
]