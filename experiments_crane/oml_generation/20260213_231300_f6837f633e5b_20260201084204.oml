// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring hoist swing angle on the gantry crane"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the crane"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoBoard : DTDFVocab:SensingComponent [
    base:desc "Arduino board that reads swing encoder, anemometer and motor controller status"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

// C4: Physical‑to‑virtual interaction (Data transmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoBoard
]

// C10: Data objects
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series swing angle values collected from the encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series wind speed measurements from the anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Operational status of stepper motors and electromagnet obtained via Arduino"
    DTDFVocab:fromData MotorStatusDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

// C10: Models
instance CADCraneModel : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane created in Autodesk Fusion360"
]

instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Kinematic model used to generate optimal crane trajectories"
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of crane dynamics and controllers"
    DTDFVocab:inputTo PythonRuntimeEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB Docker container storing time‑series operational data"
    DTDFVocab:enables LoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service signaling"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService, HumanMachineInterfaceService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana Docker container visualising data from TimescaleDB"
    DTDFVocab:enables VisualizationService
]

instance PythonRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime with gantrylib library executing trajectory generation, simulation and validation"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

// C6: Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Logging Application that writes sensor time‑series to TimescaleDB"
    DTDFVocab:provides OperationalDataStoredInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboard displaying real‑time crane metrics"
    DTDFVocab:provides OperationalDashboardInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service generating optimal crane trajectories using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight, TrajectoryPlanAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Virtual crane and controller simulation producing simulated trajectories"
    DTDFVocab:provides SimulatedTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares measured vs simulated trajectories, emits deviation metrics and operator alerts"
    DTDFVocab:provides DeviationMetricInsight, OperatorAlertAction
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "HMI allowing operator to approve and dispatch trajectory plans to the physical crane"
    DTDFVocab:provides OperatorCommandAction
]

// C17: Insights and Actions
instance OperationalDataStoredInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data has been persisted in TimescaleDB"
]

instance OperationalDashboardInsight : DTDFVocab:Insight [
    base:desc "Live visual representation of crane swing, wind, and motor status"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal motion plan for the crane generated by the trajectory service"
]

instance TrajectoryPlanAction : DTDFVocab:Action [
    base:desc "Operator approves and dispatches the optimal trajectory to the crane"
    DTDFVocab:IsAutomatic false
]

instance SimulatedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Simulated crane trajectory produced by the simulation service"
]

instance DeviationMetricInsight : DTDFVocab:Insight [
    base:desc "Quantitative deviation between measured and simulated trajectories with threshold evaluation"
]

instance OperatorAlertAction : DTDFVocab:Action [
    base:desc "Automatic alert to operator when deviation exceeds defined thresholds"
    DTDFVocab:IsAutomatic true
]

instance OperatorCommandAction : DTDFVocab:Action [
    base:desc "Operator command sent from HMI to the Physical Crane Interface to execute a trajectory"
    DTDFVocab:IsAutomatic false
]

// C17: Environment and Components (C4 containers)
instance DTEnvironment : DTDFVocab:Environment [
    base:contains TimescaleDBContainer, GrafanaContainer, MQTTBrokerContainer, TrajectoryGeneratorComponent, SimulationComponent, ContinuousValidationComponent, HumanMachineInterfaceComponent
]

instance TimescaleDBContainer : DTDFVocab:Component [
    base:desc "Docker container running TimescaleDB for time‑series storage"
]

instance GrafanaContainer : DTDFVocab:Component [
    base:desc "Docker container running Grafana for dashboards"
]

instance MQTTBrokerContainer : DTDFVocab:Component [
    base:desc "Docker container running Eclipse Mosquitto MQTT broker"
]

instance TrajectoryGeneratorComponent : DTDFVocab:Component [
    base:desc "Python process implementing the trajectory generation service"
]

instance SimulationComponent : DTDFVocab:Component [
    base:desc "Python process implementing the crane simulation service"
]

instance ContinuousValidationComponent : DTDFVocab:Component [
    base:desc "Python process implementing the continuous validation service"
]

instance HumanMachineInterfaceComponent : DTDFVocab:Component [
    base:desc "Python process providing the operator HMI"
]

// C2: Acting components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the crane cart, controlled by TMC4671‑Eval"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist, controlled by TMC4671‑Eval"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the hoist end for picking and releasing containers"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application uses the Physical Crane Interface to transmit motion commands (trajectory waypoints, speed profiles) and electromagnet activation signals to the motor controllers and Arduino. Trajectories generated by the Trajectory Generator Service are forwarded through the same interface to the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The PT is connected to a Python‑based Physical Crane Interface which feeds sensor data to the Logging Application and receives commands from the Control Application. All digital services (trajectory generation, simulation, validation, visualization) communicate via MQTT and share state through the TimescaleDB. The three core infrastructure containers (database, MQTT broker, dashboard) are Dockerized and orchestrated by Docker Compose on a single personal computer."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured executed trajectories with simulated trajectories, computes distance metrics, and checks them against predefined thresholds. Breaches trigger alerts on the Grafana dashboard for operator intervention, ensuring model fidelity is monitored during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT services uses a Python interface over USB/serial to the Arduino and motor controllers, MQTT (Eclipse Mosquitto) for inter‑service messaging, and SQL over TCP for TimescaleDB access. All components share a Docker‑managed virtual network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital‑twin components are hosted locally on a personal computer. The database, MQTT broker, and Grafana dashboard run as Docker containers; other services run as Python processes within the same host. Deployment is automated with a Docker Compose file that starts and configures the entire stack with a single command."
]