// ---------------------------
// Components
// ---------------------------

instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains GantryCraneFrameComponent, CartMotorComponent, HoistMotorComponent, ElectromagnetComponent, SwingAngleEncoderComponent, AnemometerComponent, CartMotorEncoderComponent, HoistMotorEncoderComponent, ArduinoControllerComponent, PhysicalCraneInterfaceActingComponent
]

instance GantryCraneFrameComponent : DTDFVocab:Component [
    base:desc "Main structural frame of the lab‑scale gantry crane, supporting cart, hoist motors and electromagnet."
]

instance CartMotorComponent : DTDFVocab:Component [
    base:desc "Stepper motor driving the horizontal cart movement."
]

instance HoistMotorComponent : DTDFVocab:Component [
    base:desc "Stepper motor driving vertical hoisting of the crane cradle."
]

instance ElectromagnetComponent : DTDFVocab:Component [
    base:desc "Electromagnet used to pick up and release small pucks representing containers."
]

instance SwingAngleEncoderComponent : DTDFVocab:Component [
    base:desc "Encoder mounted on the crane rail to measure swing angle of the cart."
]

instance AnemometerComponent : DTDFVocab:Component [
    base:desc "Anemometer mounted on the crane to measure wind speed acting on the crane carriage."
]

instance CartMotorEncoderComponent : DTDFVocab:Component [
    base:desc "Motor encoder on the cart stepper motor providing position feedback."
]

instance HoistMotorEncoderComponent : DTDFVocab:Component [
    base:desc "Motor encoder on the hoist stepper motor providing position feedback."
]

instance ArduinoControllerComponent : DTDFVocab:Component [
    base:desc "Arduino microcontroller processing sensor data and generating motor drive signals."
]

instance PhysicalCraneInterfaceActingComponent : DTDFVocab:ActingComponent [
    base:desc "Interface translating velocity and position setpoints from the control application into TMC4671 stepper driver signals for the cart and hoist motors."
]

// ---------------------------
// Sensing Components
// ---------------------------

instance SwingAngleEncoderSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Sensing component that reads the swing angle from the swing angle encoder."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Sensing component that reads wind speed from the anemometer."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartMotorEncoderSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Sensing component that reads cart motor position from the motor encoder."
    DTDFVocab:producedData CartPositionDataTransmitted
]

instance HoistMotorEncoderSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Sensing component that reads hoist motor position from the motor encoder."
    DTDFVocab:producedData HoistPositionDataTransmitted
]

// ---------------------------
// Data Transmitted
// ---------------------------

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensingComponent
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensingComponent
]

instance CartPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoderSensingComponent
]

instance HoistPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoderSensingComponent
]

// ---------------------------
// Data
// ---------------------------

instance SwingAngleMeasurementData : DTDFVocab:Data [
    base:desc "Measured swing angle of the gantry crane carriage."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedMeasurementData : DTDFVocab:Data [
    base:desc "Measured wind speed acting on the crane carriage."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance CartPositionMeasurementData : DTDFVocab:Data [
    base:desc "Measured cart position along the rail."
    DTDFVocab:fromData CartPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance HoistPositionMeasurementData : DTDFVocab:Data [
    base:desc "Measured hoist position of the crane carriage."
    DTDFVocab:fromData HoistPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// ---------------------------
// Enablers
// ---------------------------

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB service used for persistent telemetry storage and query."
    DTDFVocab:enables LoggingService, ContinuousValidationService, VisualisationService, RealTimeSimulationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker facilitating sensor data exchange among the twin services."
    DTDFVocab:enables LoggingService, ContinuousValidationService, TrajectoryGeneratorService
]

// ---------------------------
// Services
// ---------------------------

instance LoggingService : DTDFVocab:Service [
    base:desc "Logs telemetry data from the crane into TimescaleDB."
    DTDFVocab:provides TelemetryDataStoredInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Computes deviation metrics between actual trajectory and model to validate the twin."
    DTDFVocab:provides DeviationThresholdBreachedInsight, OperatorNotificationAction
]

instance VisualisationService : DTDFVocab:Service [
    base:desc "Provides live trajectory and confidence bounds visualization on the Grafana dashboard."
    DTDFVocab:provides LiveTrajectoryInsight, ConfidenceBoundsInsight
]

instance RealTimeSimulationService : DTDFVocab:Service [
    base:desc "Runs real‑time simulation of crane dynamics using the simulation model."
    DTDFVocab:provides RealTimeSimulationInsight
]

instance OptimalTrajectoryService : DTDFVocab:Service [
    base:desc "Generates optimal trajectory based on the kinematic model."
    DTDFVocab:provides OptimizedTrajectoryInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Issues motion trajectories for the crane from the control application."
    DTDFVocab:provides IssueMotionTrajectoryAction
]

// ---------------------------
// Insights
// ---------------------------

instance TelemetryDataStoredInsight : DTDFVocab:Insight [
    base:desc "Confirms that telemetry data has been successfully stored in TimescaleDB."
]

instance DeviationThresholdBreachedInsight : DTDFVocab:Insight [
    base:desc "Indicates that the deviation metric between actual and planned trajectory exceeds the predefined threshold."
]

instance LiveTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Live trajectory of the crane plotted on the dashboard."
]

instance ConfidenceBoundsInsight : DTDFVocab:Insight [
    base:desc "Confidence bounds displayed alongside live trajectory to indicate uncertainty."
]

instance HistoricalDataAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insights derived from historical logs for optimization and fault detection."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Highlights detected faults or anomalies in crane operation based on historical data."
]

instance OptimizedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Shows the optimized trajectory generated by the kinematic model."
]

instance RealTimeSimulationInsight : DTDFVocab:Insight [
    base:desc "Provides simulation output of current crane state in real time."
]

// ---------------------------
// Actions
// ---------------------------

instance OperatorNotificationAction : DTDFVocab:Action [
    base:desc "Sends a notification to the operator when deviation thresholds are breached."
    DTDFVocab:IsAutomatic true
]

instance IssueMotionTrajectoryAction : DTDFVocab:Action [
    base:desc "Generates motion setpoints for the cart and hoist motors."
    DTDFVocab:IsAutomatic true
]

// ---------------------------
// Models
// ---------------------------

instance KinematicModel : DTDFVocab:Model [
    base:desc "Python kinematic model used to compute optimal trajectories for the gantry crane."
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulation model replicating motor driver dynamics for real‑time crane simulation."
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory Generator and Control Application publish velocity and position setpoints to the Physical Crane Interface via MQTT; the interface drives the TMC4671 stepper drivers to move the cart and hoist."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Logging occurs at real‑time sample rates (e.g., every 10 ms to 100 ms implied), trajectory generation and validation execute continuously during operation, while simulation and classification run in near real‑time; no explicit discrete time step is specified."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated via Docker Compose; containers cluster on a single PC; inter‑container communication on private network; external interfaces: operator’s HMI and research tools connect via HTTP/HTTPS to dashboard, MQTT to services, and PostgreSQL to databases."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The system covers design (CAD and kinematic model), manufacturing (assembly per BOM), and operation (actual crane with digital twin services). Development iterations include continuous validation and future extensions for education and fault‑detection."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service compares measured trajectory moments with simulated counterparts using Euclidean distance metrics; thresholds determined experimentally; classification models would augment detecting faults; validation occurs in real‑time, enabling reliability assessment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication via Mosquitto MQTT broker (TCP port 1883) between services and physical interface; database accessed via PostgreSQL TCP; all services run over Docker bridge network; HMI communicates via HTTP to dashboard."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted locally on a personal computer; Docker Compose deploys Database, MQTT Broker, Grafana containers; Python applications run natively (gantrylib module) or via containers; all code is open source and available on GitHub repository."
]