// C3: Physical Sensing Components
instance JointEncoder1 : DTDFVocab:SensingComponent [
    base:desc "Rotary encoder on Joint 1 reporting joint angle at approximately 100 Hz."
    DTDFVocab:producedData MQTTTopicJoint1Angle
]

instance JointEncoder2 : DTDFVocab:SensingComponent [
    base:desc "Rotary encoder on Joint 2 reporting joint angle at approximately 100 Hz."
    DTDFVocab:producedData MQTTTopicJoint2Angle
]

instance PayloadPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the 3‑D position of the payload via integrated linear actuator encoders."
    DTDFVocab:producedData MQTTTopicPayloadPosition
]

// C4: Physical-to-virtual interaction
instance MQTTTopicJoint1Angle : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointEncoder1
]

instance MQTTTopicJoint2Angle : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointEncoder2
]

instance MQTTTopicPayloadPosition : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PayloadPositionSensor
]

// C4: Data
instance JointAngleData1 : DTDFVocab:Data [
    base:desc "Time‑series data of Joint 1 angle received from MQTT."
    DTDFVocab:fromData MQTTTopicJoint1Angle
    DTDFVocab:inputTo TimescaleDB
    DTDFVocab:inputTo PythonProcessingModule
]

instance JointAngleData2 : DTDFVocab:Data [
    base:desc "Time‑series data of Joint 2 angle received from MQTT."
    DTDFVocab:fromData MQTTTopicJoint2Angle
    DTDFVocab:inputTo TimescaleDB
    DTDFVocab:inputTo PythonProcessingModule
]

instance PayloadPositionData : DTDFVocab:Data [
    base:desc "Time‑series data of payload 3‑D position received from MQTT."
    DTDFVocab:fromData MQTTTopicPayloadPosition
    DTDFVocab:inputTo TimescaleDB
    DTDFVocab:inputTo PythonProcessingModule
]

// C11: Enablers
instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB database running in a Docker container storing high‑frequency telemetry."
    DTDFVocab:enables HistoricalDataLoggingService
]

instance PythonProcessingModule : DTDFVocab:Enabler [
    base:desc "Python module (NumPy, Pandas, Matplotlib) consuming MQTT streams to perform optimal control calculations."
    DTDFVocab:enables OptimalTrajectoryGeneratorService
    DTDFVocab:enables ContinuousValidationService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto broker relaying sensor telemetry over MQTT to downstream modules."
]

instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana dashboard reading data from TimescaleDB for live trajectory plots and alert visualisation."
    DTDFVocab:enables GrafanaDashboardService
]

instance ThreeDViewer : DTDFVocab:Enabler [
    base:desc "Custom 3‑D viewer integrated into Grafana that visualises the kinematic model defined in Autodesk Fusion360."
    DTDFVocab:enables ThreeDViewerService
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "Functional‑specification model of gantry crane kinematics encoded in a custom domain language."
    DTDFVocab:inputTo PythonProcessingModule
]

// C6: Services
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that persists telemetry data into TimescaleDB."
    DTDFVocab:provides HistoricalTelemetryInsight
    DTDFVocab:provides LogTelemetryAction
]

instance OptimalTrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service that computes collision‑free, minimum‑time optimal trajectories for the gantry crane."
    DTDFVocab:provides CollisionFreeTrajectoryInsight
    DTDFVocab:provides GenerateOptimalTrajectoryAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously validates real‑time sensor data against predicted trajectories."
    DTDFVocab:provides TrajectoryDeviationAlertInsight
    DTDFVocab:provides NotifyOperatorAction
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Service providing live trajectory plots, health indicators, and alert notifications via Grafana."
    DTDFVocab:provides LiveTrajectoryPlotInsight
    DTDFVocab:provides AlertVisualizationInsight
]

instance ThreeDViewerService : DTDFVocab:Service [
    base:desc "Service that renders the full kinematic model in a 3‑D CAD viewer."
    DTDFVocab:provides CADVisualizationInsight
]

// C17: Insights/Actions
instance HistoricalTelemetryInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that all telemetry data has been stored for retrospective analysis."
]

instance CollisionFreeTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight confirming that the computed trajectory is collision‑free and minimizes travel time."
]

instance TrajectoryDeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when real‑time sensor data deviates from predicted trajectory beyond threshold."
]

instance LiveTrajectoryPlotInsight : DTDFVocab:Insight [
    base:desc "Live plot of the current crane trajectory displayed in Grafana."
]

instance AlertVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of deviation alerts on the Grafana dashboard."
]

instance CADVisualizationInsight : DTDFVocab:Insight [
    base:desc "3‑D visualisation of the gantry crane’s kinematic state."
]

instance LogTelemetryAction : DTDFVocab:Action [
    base:desc "Automatic action that logs incoming telemetry to TimescaleDB."
    DTDFVocab:IsAutomatic true
]

instance GenerateOptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Automatic action that publishes optimal control commands to the motion controller."
    DTDFVocab:IsAutomatic true
]

instance NotifyOperatorAction : DTDFVocab:Action [
    base:desc "Automatic action that sends deviation alerts to the operator via the Grafana dashboard."
    DTDFVocab:IsAutomatic true
]

// C11: Environment
instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains JointEncoder1, JointEncoder2, PayloadPositionSensor, TimescaleDB, PythonProcessingModule, MQTTBroker, GrafanaDashboard, ThreeDViewer, KinematicModel, HistoricalDataLoggingService, OptimalTrajectoryGeneratorService, ContinuousValidationService, GrafanaDashboardService, ThreeDViewerService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the Control Application and sent to the physical crane through the Physical Crane Interface. The commands are handled as Python messages over the same local communication channel used to communicate with the crane controllers. The document does not describe command message formats, validation or authentication mechanisms, feedback systems, conflict resolution, or execution confirmation processes."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is deployed on virtual machines provided as GitHub images. It follows a containerised micro‑service pattern (C4 model) with separate services for data ingestion (InfluxDB), message streaming (ActiveMQ/MQTT), and state visualization (frontend dashboard). The twin logic container subscribes to broker topics, updates the database, and exposes status for the dashboard. Deployment scripts and configuration are maintained in the repository, allowing seamless setup of the entire stack."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All digital twin services communicate through an MQTT broker, which handles signaling between the Trajectory Generator Service, Simulation Service, Continuous Validation Service, and the Grafana dashboard. The broker implements the MQTT protocol and operates on a local network or LAN. No further details on network topology, bandwidth, latency, reliability, redundancy, or security protocols are given."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin runs entirely on a personal computer that is physically linked to the crane controllers via a local serial or CAN interface. All key software components – TimescaleDB (database), MQTT Broker, Grafana Dashboard, and the control and logging services – are packaged as Docker containers and instantiated from that host. Computational requirements are modest (standard CPU, 4 GB RAM for example) as indicated by typical desktop deployment; storage requires sufficient capacity for time‑series logging (e.g., several hundred MB per day). The deployment model is a single‑node edge deployment with Docker container orchestration; scalability is limited to the host’s resources, but containers facilitate horizontal scaling if future hardware is provisioned. Availability is driven by the host OS uptime and Docker container health checks, with no explicit high‑availability or redundant infrastructure described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Physical sensors on a Raspberry‑Pi publish telemetry to the message broker (ActiveMQ/MQTT). The Digital Twin consumes these messages, stores data in InfluxDB, and visualises state via the dashboard. In the Air Quality exemplar, MQTT messages are forwarded to Microsoft Azure IoT Hub, where data is persisted in Azure storage and the AutomationML twin model is retrieved from Azure Blob Storage. Interaction with other enterprise systems is limited to these broker and cloud ingestion mechanisms; no external REST APIs were described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplar follows the AutomationML standard for twin description, enabling model interchange between the physical Raspberry‑Pi sensor network and the Azure‑based simulation and prediction services. The twin model adheres to AutomationML v2.x syntax and incorporates IEC 61360 semantic annotations for indoor air parameters. No additional commercial twin framework, certification, or interoperability standard is referenced in the material."
]