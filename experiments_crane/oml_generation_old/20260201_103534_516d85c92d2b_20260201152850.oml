// C3: Physical Sensing Components
instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Captures kinematic measurements including puck coordinates and crane joint angles for real-time monitoring of the gantry crane's physical state."
    DTDFVocab:producedData CranePositionDataTransmitted
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Measures velocity of crane components (bridge, hoist, trolley) to enable dynamic trajectory validation and control."
    DTDFVocab:producedData CraneVelocityDataTransmitted
]

instance CraneAccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Tracks acceleration data for detecting abrupt movements or operational anomalies in the crane system."
    DTDFVocab:producedData CraneAccelerationDataTransmitted
]

instance ControllerCommandSensor : DTDFVocab:SensingComponent [
    base:desc "Logs controller commands and operational status to ensure synchronization between digital twin and physical system."
    DTDFVocab:producedData ControllerCommandDataTransmitted
]

instance OperationalStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors crane operational state including error conditions, timestamps, and system health metrics."
    DTDFVocab:producedData OperationalStatusDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance CranePositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor
]

instance CraneVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneVelocitySensor
]

instance CraneAccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneAccelerationSensor
]

instance ControllerCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ControllerCommandSensor
]

instance OperationalStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalStatusSensor
]

// C10: Models/Data
instance KinematicModel : DTDFVocab:Model [
    base:desc "Mathematical representation of the gantry crane's motion and dynamics, enabling simulation of movements and interactions."
    DTDFVocab:inputTo KinematicModelingEnabler
]

instance TrajectorySimulationModel : DTDFVocab:Model [
    base:desc "Physics-based model simulating crane behavior under various operational conditions for validation of control strategies."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance HistoricalOperationalData : DTDFVocab:Data [
    base:desc "Time-series data capturing crane's past operational states, including kinematic measurements and controller logs."
    DTDFVocab:fromData CranePositionDataTransmitted, CraneVelocityDataTransmitted, CraneAccelerationDataTransmitted, ControllerCommandDataTransmitted, OperationalStatusDataTransmitted
    DTDFVocab:inputTo DatabaseEnabler
]

instance RealTimeTelemetryData : DTDFVocab:Data [
    base:desc "Continuously streamed data representing the crane's current state for real-time monitoring and validation."
    DTDFVocab:fromData CranePositionDataTransmitted, CraneVelocityDataTransmitted, CraneAccelerationDataTransmitted
    DTDFVocab:inputTo ContinuousValidationEnabler
]

// C11: Enablers
instance KinematicModelingEnabler : DTDFVocab:Enabler [
    base:desc "Custom or open-source libraries for developing mathematical models describing the crane's motion and dynamics."
    DTDFVocab:enables OptimalControlService, ContinuousValidationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Physics-based simulators for validating control strategies and ensuring digital twin accuracy."
    DTDFVocab:enables ContinuousValidationService, FaultDetectionService
]

instance DatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Lightweight or open-source database storing historical operational data and logs for querying and analysis."
    DTDFVocab:enables HistoricalDataLoggingService, DataVisualizationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Algorithms or methodologies for validating the digital twin's accuracy by comparing predictions with real-world data."
    DTDFVocab:enables ContinuousValidationService
]

instance DevelopmentEnvironmentEnabler : DTDFVocab:Enabler [
    base:desc "Open-source or freely available software (e.g., Python, MATLAB, ROS) serving as the primary development environment for digital twin services."
    DTDFVocab:enables OptimalControlService, FaultDetectionService, DataVisualizationService
]

instance CommunicationProtocolEnabler : DTDFVocab:Enabler [
    base:desc "Bidirectional data exchange protocol (e.g., OPC UA, MQTT) enabling real-time streaming of sensor data and control commands."
    DTDFVocab:enables HistoricalDataLoggingService, ContinuousValidationService
]

instance VersionControlEnabler : DTDFVocab:Enabler [
    base:desc "Version control systems (e.g., Git) and IDEs (e.g., VS Code) facilitating collaborative development and reproducibility."
    DTDFVocab:enables OptimalControlService, FaultDetectionService
]

instance DarTwinFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Framework for documenting and managing the evolution of the digital twin system, supporting versioning and adaptation."
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Provides algorithms for optimizing the crane's movement, energy consumption, or operational efficiency."
    DTDFVocab:provides OptimalTrajectoryInsight, EnergyEfficiencyAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Collects and stores operational data from the physical crane for analysis, validation, or retrospective studies."
    DTDFVocab:provides OperationalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Enables real-time or historical visualization of the crane's state, performance metrics, and operational data."
    DTDFVocab:provides CraneStateVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Validates the digital twin's accuracy by comparing its predictions with real-world data from the physical system."
    DTDFVocab:provides ValidationAccuracyInsight, ModelRefinementAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Monitors the physical system for faults or deviations from expected behavior, triggering alerts or corrective actions."
    DTDFVocab:provides FaultDetectionInsight, PredictiveMaintenanceAction
]

// C17: Insights/Actions
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Real-time trajectory planning optimized for efficiency and safety based on kinematic models and operational constraints."
]

instance EnergyEfficiencyAction : DTDFVocab:Action [
    base:desc "Automated adjustments to crane operations to minimize energy consumption while maintaining performance."
    DTDFVocab:IsAutomatic true
]

instance OperationalDataInsight : DTDFVocab:Insight [
    base:desc "Time-series data storage and event logging for crane operations, including faults and operational anomalies."
]

instance CraneStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D CAD model visualization with real-time telemetry dashboards and anomaly highlighting."
]

instance ValidationAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantitative metrics comparing digital twin predictions with physical system measurements for accuracy assessment."
]

instance ModelRefinementAction : DTDFVocab:Action [
    base:desc "Automated feedback loop for refining digital twin models based on validation discrepancies."
    DTDFVocab:IsAutomatic true
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identified anomalies in sensor data and operational states indicating potential faults in the crane system."
]

instance PredictiveMaintenanceAction : DTDFVocab:Action [
    base:desc "Triggered alerts and corrective actions for maintenance teams based on detected operational anomalies."
    DTDFVocab:IsAutomatic false
]

// C1: Physical Components
instance LabScaleGantryCrane : DTDFVocab:Component [
    base:desc "Mechanical gantry crane system designed for laboratory-scale operations with movable bridge, hoist, and trolley mechanism."
]

instance CraneController : DTDFVocab:Component [
    base:desc "Embedded or programmable logic controller managing crane actuators and ensuring precise movement and operational safety."
]

instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Python program connecting crane controllers to the digital twin system for bidirectional data exchange."
]

instance TimescaleDatabase : DTDFVocab:Component [
    base:desc "Centralized database storing real-time and historical operational data serving as the single source of truth for digital twin services."
]

instance TrajectoryGeneratorService : DTDFVocab:Component [
    base:desc "Service generating optimized trajectories based on kinematic models and operational constraints."
]

instance SimulationService : DTDFVocab:Component [
    base:desc "Physics-based simulation engine validating control strategies and digital twin accuracy."
]

instance Dashboard : DTDFVocab:Component [
    base:desc "Visualization interface displaying crane state, performance metrics, and operational data in real-time."
]

// C2: Acting Components
instance CraneActuators : DTDFVocab:ActingComponent [
    base:desc "Mechanical actuators (motors, drives) executing movements commanded by the crane controller."
]

// C12: Environment
instance IndoorLaboratoryEnvironment : DTDFVocab:Environment [
    base:desc "Controlled indoor setting for lab-scale gantry crane operations and digital twin validation."
    base:contains LabScaleGantryCrane, CraneController, CraneActuators
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control flows from the digital twin to the **Physical Crane** are mediated by the **Control Application**, a Python program that interfaces with the **Physical Crane Interface**. Commands generated by the **Trajectory Generator Service** (e.g., optimal trajectories with zero residual swinging) are transmitted as structured control messages to the crane's controllers. The exact message format is unspecified, but the system implies a deterministic, kinematics-driven command structure. Validation and authentication mechanisms are not explicitly described, though the **Continuous Validation Service** ensures executed trajectories adhere to simulated models, indirectly validating command integrity. Feedback systems are implicit: the **Logging Application** captures real-time crane state data, which is compared against simulated trajectories to detect deviations. Conflict resolution is not detailed, but the **MQTT Broker** facilitates signaling between services, suggesting asynchronous event handling for command prioritization or error recovery. Command execution confirmation is implied via the **Dashboard**, which notifies operators of threshold breaches (e.g., trajectory deviations exceeding acceptable limits)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system exemplars demonstrate an **ad-hoc, component-based orchestration** rather than a standardized constellation. The **GreenhouseDT** exemplifies a **self-adaptive architecture** where both the physical greenhouse and its digital twin exhibit **behavioral adaptation**, coordinated via **InfluxDB (time-series database)** and **ActiveMQ (message broker)** for event-driven communication. The **Air Quality Management** exemplar uses a **pipeline architecture** on **Microsoft Azure**, integrating **runtime visualization, simulation, and prediction** services with **AutomationML** for model-driven engineering. The **gantry crane system** (logistics domain) employs the **C4 Model** for architecture visualization, suggesting a **containerized microservices approach** with **modular components** (e.g., control, sensing, actuation) but lacks explicit orchestration frameworks. All exemplars avoid commercial digital twin frameworks, opting for **custom integration patterns** (e.g., virtualization, containerization) to ensure **easy dissemination** and **domain-specific adaptability**. Resource management is implicit, relying on **single-board computers (Raspberry Pi)** and **cloud/VM-based services** for scalability."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The **GreenhouseDT** exemplar emphasizes **self-adaptive behavioral fidelity**, where both the physical greenhouse and its digital twin dynamically adjust based on real-time or prerecorded data. Validation is implied through **prerecorded datasets** in virtual machine images, ensuring reproducibility. The **Air Quality Management** exemplar focuses on **model-driven engineering fidelity**, with **AutomationML-based models** validated via **runtime visualization, simulation, and predictive analytics** for virus spread prevention. Microsoft Azure tools facilitate **data-driven validation**, though explicit methods (e.g., uncertainty quantification, error correction) are not detailed. The **lab-scale gantry crane** exemplar lacks specific fidelity metrics but adheres to **ad-hoc validation approaches**, likely relying on **containerized deployment** for consistency. Uncertainty sources (e.g., sensor noise, model approximations) are not quantified, and no explicit **quality assurance processes** (e.g., calibration protocols, cross-validation) are described in the provided documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin’s technical network infrastructure relies on a **TimescaleDB database** (a PostgreSQL extension optimized for time-series data) as the central data repository, connected to services via unspecified protocols. The **MQTT Broker** enables lightweight, publish-subscribe communication between services (e.g., **Trajectory Generator Service**, **Simulation Service**, and **Continuous Validation Service**), ensuring low-latency signaling. Network topology is not explicitly defined, but the system’s modular design (C4 container abstraction) suggests a distributed architecture with services communicating over a local or dedicated network. Bandwidth and latency requirements are not quantified, though real-time kinematic data (e.g., trajectory metrics) imply low-latency constraints. Reliability and redundancy mechanisms are not detailed, but the **Continuous Validation Service**’s threshold-based alerts imply fault detection. Security protocols are unspecified, though the use of a dedicated **MQTT Broker** and centralized database suggests controlled access points."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin’s deployment infrastructure is not explicitly described as cloud/edge/on-premise, but the system’s components (e.g., **TimescaleDB**, **Grafana Dashboard**, and Python services) suggest an **on-premise or edge deployment** due to the lab-scale, real-time nature of the gantry crane operations. Computational requirements are moderate: the **Trajectory Generator Service** and **Simulation Service** rely on kinematic models, while the **Logging Application** and **Continuous Validation Service** require continuous data processing. Storage demands are driven by the **TimescaleDB database**, which archives time-series crane state data. Scalability mechanisms are not mentioned, but the modular C4 architecture implies potential horizontal scaling for services like the **MQTT Broker** or **Dashboard**. Deployment models are not specified, though the Python-based services and TimescaleDB suggest containerization (e.g., Docker) or virtualization. Availability/reliability assurance is implied by the **Continuous Validation Service**’s real-time monitoring and operator alerts, but no explicit redundancy (e.g., failover) is described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin systems exhibit **limited horizontal integration** with external systems, primarily relying on **domain-specific technologies** and **ad-hoc protocols**. The **GreenhouseDT** integrates with **InfluxDB (time-series database)** and **ActiveMQ (message broker)** for internal data exchange but lacks explicit interoperability standards for external systems. The **Air Quality Management** exemplar uses **AutomationML** for digital twin modeling and **Microsoft Azure tools** for pipeline implementation, implying **cloud-native integration** but no standardized protocols for enterprise systems. The **gantry crane system** (logistics domain) does not document external integrations, though its **C4 Model-based architecture** suggests potential for **modular extensions** via containerization. No evidence of **OPC UA, MQTT, or other industrial interoperability standards** is provided. Dependencies are localized to **single-board computers, virtual machines, or cloud services**, with no mention of **cross-Digital Twin or enterprise system integration patterns**."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The **Air Quality Management** exemplar adheres to **AutomationML** for digital twin modeling, a standardized format for engineering data exchange. The **GreenhouseDT** exemplar uses **InfluxDB** (a time-series database standard) and **ActiveMQ** (a widely adopted message broker protocol), though these are not domain-specific standards. Neither exemplar explicitly mentions **certification requirements** or **compliance frameworks** (e.g., ISO, IEC). **Interoperability** is implied through the use of **Raspberry Pi sensors** (common IoT hardware) and **containerization/virtualization** (e.g., VMs, Azure tools), but no formal standards (e.g., OPC UA, MTConnect) are referenced. The **ad-hoc approach** of the exemplars suggests limited adherence to proprietary or industry-specific digital twin standards."
]