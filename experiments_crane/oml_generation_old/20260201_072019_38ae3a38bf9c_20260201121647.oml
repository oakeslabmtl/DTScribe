// C2: Acting Components
instance CartStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor managed by a Trinamic TMC4671 driver board"
]
instance HoistStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor managed by a Trinamic TMC4671 driver board"
]
instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet driven by an Arduino controller for cargo pickup"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Optical encoder measuring the swing angle at the hoist"
    DTDFVocab:producedData SwingAngleMQTT
]
instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer recording wind speed affecting the crane dynamics"
    DTDFVocab:producedData WindSpeedMQTT
]
instance CartStepperMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the cart stepper motor providing steps per revolution"
    DTDFVocab:producedData CartMotorPositionMQTT
]
instance HoistStepperMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on the hoist stepper motor providing steps per revolution"
    DTDFVocab:producedData HoistMotorPositionMQTT
]
instance ArduinoVoltageSensor : DTDFVocab:SensingComponent [
    base:desc "Arduino‑based voltage sensor monitoring supply voltage"
    DTDFVocab:producedData VoltageMQTT
]
instance ArduinoTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Arduino‑based temperature sensor monitoring ambient temperature"
    DTDFVocab:producedData TemperatureMQTT
]

// C4: Physical-to-virtual interaction
instance SwingAngleMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance WindSpeedMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]
instance CartMotorPositionMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartStepperMotorEncoder
]
instance HoistMotorPositionMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistStepperMotorEncoder
]
instance VoltageMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoVoltageSensor
]
instance TemperatureMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoTemperatureSensor
]

// C10: Models/Data
instance CADModelFusion360 : DTDFVocab:Model [
    base:desc "Fusion 360 CAD geometry of the lab‑scale gantry crane replica"
    DTDFVocab:inputTo CapellaArcadia
]
instance KinematicTrajectoryModel : DTDFVocab:Model [
    base:desc "Kinematic trajectory generation model used to compute swing‑minimizing plans"
    DTDFVocab:inputTo TrajectoryGenerationService
]
instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the crane and its controllers"
    DTDFVocab:inputTo CraneSimulationService
]
instance ValidationMetricsModel : DTDFVocab:Model [
    base:desc "Metrics derived from comparing logged and simulated trajectories"
    DTDFVocab:inputTo ContinuousValidationService
]

// Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series data of swing angle logged at 10 ms intervals"
    DTDFVocab:inputTo TimescaleDBContainer
    DTDFVocab:fromData SwingAngleMQTT
]
instance WindSpeedData : DTDFVocab:Data [
    base:desc "Wind speed data recorded by the anemometer, sampled every 10 ms"
    DTDFVocab:inputTo TimescaleDBContainer
    DTDFVocab:fromData WindSpeedMQTT
]
instance CartMotorPositionData : DTDFVocab:Data [
    base:desc "Cart motor position data from encoder, sampled every 10 ms"
    DTDFVocab:inputTo TimescaleDBContainer
    DTDFVocab:fromData CartMotorPositionMQTT
]
instance HoistMotorPositionData : DTDFVocab:Data [
    base:desc "Hoist motor position data from encoder, sampled every 10 ms"
    DTDFVocab:inputTo TimescaleDBContainer
    DTDFVocab:fromData HoistMotorPositionMQTT
]
instance VoltageData : DTDFVocab:Data [
    base:desc "Continuous voltage monitoring data from the Arduino"
    DTDFVocab:inputTo TimescaleDBContainer
    DTDFVocab:fromData VoltageMQTT
]
instance TemperatureData : DTDFVocab:Data [
    base:desc "Continuous temperature monitoring data from the Arduino"
    DTDFVocab:inputTo TimescaleDBContainer
    DTDFVocab:fromData TemperatureMQTT
]

// C11: Enablers
instance TimescaleDBContainer : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL‑based time‑series database) running in a Docker container"
    DTDFVocab:enables TrajectoryGenerationService, CraneSimulationService, ContinuousValidationService
]
instance MosquittoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker container orchestrating data streams"
    DTDFVocab:enables DataLoggingService, RealTimeVisualizationService
]
instance GrafanaDashboard : DTDFVocab:Enabler [
    base:desc "Grafana instance providing real‑time dashboards for logged data"
    DTDFVocab:enables RealTimeVisualizationService
]
instance DockerComposeOrchestrator : DTDFVocab:Enabler [
    base:desc "Docker Compose orchestrator managing all containerized services"
]
instance CapellaArcadia : DTDFVocab:Enabler [
    base:desc "Capella Arcadia tool enabling system‑level modeling of the digital twin"
    DTDFVocab:enables CADModelFusion360
]
instance MkDocsDocumentation : DTDFVocab:Enabler [
    base:desc "MkDocs generating documentation for the digital twin"
]
instance GitHubPagesHosting : DTDFVocab:Enabler [
    base:desc "GitHub Pages hosting the generated documentation"
]
instance KiCadSchematic : DTDFVocab:Enabler [
    base:desc "KiCad schematic editor used for PCB design of the crane electronics"
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Streams logged state (motor positions, encoder ticks, wind speed, etc.) from containers to TimescaleDB via MQTT"
    DTDFVocab:provides DataRetentionInsight
]
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Grafana dashboards visualizing real‑time data from TimescaleDB"
    DTDFVocab:provides RealTimeDashboardInsight
]
instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑minimizing trajectory plans using the kinematic model"
    DTDFVocab:provides AutomaticTrajectoryPlanAction
]
instance CraneSimulationService : DTDFVocab:Service [
    base:desc "Simulates the crane’s dynamics and controllers for virtual commissioning"
    DTDFVocab:provides SimulationResultInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares logged versus simulated trajectories in real time to validate model fidelity"
    DTDFVocab:provides ValidationThresholdAlertInsight, FaultClassificationInsight
]
instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Operator control interface allowing manual override of trajectory plans"
    DTDFVocab:provides OperatorControlAction
]

// C17: Insights/Actions
instance DataRetentionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the retention status of logged data in TimescaleDB"
]
instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Insight showing real‑time dashboard metrics and alerts"
]
instance ValidationThresholdAlertInsight : DTDFVocab:Insight [
    base:desc "Insight alerting operators when trajectory validation thresholds are exceeded"
]
instance FaultClassificationInsight : DTDFVocab:Insight [
    base:desc "Insight providing fault classification analysis for anomalous behavior"
]
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight providing simulation result metrics for the crane dynamics"
]
instance AutomaticTrajectoryPlanAction : DTDFVocab:Action [
    base:desc "Automatically generated trajectory plan minimizing swing"
    DTDFVocab:IsAutomatic true
]
instance OperatorControlAction : DTDFVocab:Action [
    base:desc "Manual operator action to override or adjust the trajectory plan"
    DTDFVocab:IsAutomatic false
]

// Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains CartStepperMotorActuator, HoistStepperMotorActuator, ElectromagnetActuator,
              SwingAngleEncoder, Anemometer, CartStepperMotorEncoder, HoistStepperMotorEncoder,
              ArduinoVoltageSensor, ArduinoTemperatureSensor, TimescaleDBContainer,
              MosquittoBroker, GrafanaDashboard, DockerComposeOrchestrator,
              CapellaArcadia, MkDocsDocumentation, GitHubPagesHosting, KiCadSchematic
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service produces optimal motion trajectories which are sent as command messages via MQTT to the Physical Crane Interface; the Control Application forwards these commands to the Arduino that actuates the motors. The Continuous Validation Service publishes alerts to the HMI Dashboard when deviation thresholds are exceeded."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in near real‑time; the Logging Application samples the crane state at each motor update cycle, the Trajectory Generator updates trajectory points continuously, and the Continuous Validation Service evaluates each executed trajectory immediately after completion, synchronizing via the MQTT broker."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A containerized microservice architecture powered by Docker Compose: the physical subsystem is interfaced through a Python module; inter‑service communication occurs over an MQTT broker; logs are stored in TimescaleDB and visualized with Grafana; all services are deployed on a single personal computer."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the design phase (z‑CAD model in Fusion 360), the manufacturing phase (physical crane built and assembled), and the operational phase (runtime state logging, live validation, and operator interaction)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service computes Euclidean distance between measured and simulated trajectories; a threshold is configured to trigger alerts if residual swing is non‑zero. The kinematic model is verified against real‑world data from the Logging Application, and fault detection is enhanced using time‑series classification techniques."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical hardware connects to the Python interface via serial/USB to the Arduino; inter‑service messaging uses MQTT over TCP; the TimescaleDB and Grafana containers expose PG and HTTP ports on the Docker network; data transfer rates are limited by the motor control loop and logging frequency."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin components are containerized and deployed using Docker Compose on a single workstation; the Python modules run as local processes or as Docker containers, while TimescaleDB, Mosquitto, and Grafana run as separate containers; the repository and documentation are hosted on GitHub and GitHub Pages."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "No explicit integration with external enterprise systems or other digital twins is described; the exemplar is self‑contained and the repository is publicly available on GitHub."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Employs open‑source industry standards – Docker, MQTT (Eclipse Mosquitto), TimescaleDB/SQL, Grafana, C4 model notation, Capella, and Autodesk Fusion 360; no formal twin reference model or ISO standard is referenced."
]