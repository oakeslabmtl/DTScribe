// Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder on the crane hoist, reporting the load’s swing angle."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer mounted on the crane, measuring wind speed at the crane location."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder on the cart motor, providing cart position and time data."
    DTDFVocab:producedData CartMotorEncoderDataTransmitted
]

instance HoistMotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder on the hoist motor, providing hoist position and time data."
    DTDFVocab:producedData HoistMotorEncoderDataTransmitted
]

// Physical-to-virtual interaction data transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]

instance CartMotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoder
]

instance HoistMotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoder
]

// Data stored in the time‑series database
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Recorded swing‑angle values with timestamps."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBContainer
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Recorded wind‑speed values with timestamps."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBContainer
]

instance CartPositionData : DTDFVocab:Data [
    base:desc "Recorded cart motor encoder counts (position) with timestamps."
    DTDFVocab:fromData CartMotorEncoderDataTransmitted
    DTDFVocab:inputTo TrajectoryGeneratorContainer
]

instance HoistPositionData : DTDFVocab:Data [
    base:desc "Recorded hoist motor encoder counts with timestamps."
    DTDFVocab:fromData HoistMotorEncoderDataTransmitted
    DTDFVocab:inputTo TrajectoryGeneratorContainer
]

// Models used in the twin
instance KinematicAnalyticalModel : DTDFVocab:Model [
    base:desc "Kinematic analytical model used by the Trajectory Generator to compute optimal trajectories."
    DTDFVocab:inputTo TrajectoryGeneratorContainer
]

instance PhysicsBasedSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model implemented in Python representing crane motion."
    DTDFVocab:inputTo SimulationContainer
]

instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane derived from Autodesk Fusion 360 files."
    DTDFVocab:inputTo SimulationContainer
]

// Enablers (Docker containers)
instance TimescaleDBContainer : DTDFVocab:Enabler [
    base:desc "Docker container running TimescaleDB for continuous high‑frequency telemetry logging."
    DTDFVocab:enables LoggingService
]

instance MosquittoBrokerContainer : DTDFVocab:Enabler [
    base:desc "Docker container running Eclipse Mosquitto MQTT broker for inter‑service messaging."
    DTDFVocab:enables MQTTBrokerService
]

instance GrafanaDashboardContainer : DTDFVocab:Enabler [
    base:desc "Docker container running Grafana for historical data visualization and alerting."
    DTDFVocab:enables GrafanaDashboardService
]

instance TrajectoryGeneratorContainer : DTDFVocab:Enabler [
    base:desc "Docker container running the Python Trajectory Generator service."
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationContainer : DTDFVocab:Enabler [
    base:desc "Docker container running the real‑time simulation service."
    DTDFVocab:enables SimulationService
]

instance ContinuousValidationContainer : DTDFVocab:Enabler [
    base:desc "Docker container running Continuous Validation service to compare executed motion against simulation."
    DTDFVocab:enables ContinuousValidationService
]

// Services
instance LoggingService : DTDFVocab:Service [
    base:desc "Service logging telemetry data to TimescaleDB."
    DTDFVocab:provides StoreTelemetryAction
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Service enabling publication of control signals and status updates via MQTT."
    DTDFVocab:provides PublishControlSignalAction
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Service enabling visualization of trajectory plots and validation alerts in Grafana."
    DTDFVocab:provides ViewTrajectoryPlotsInsight
    DTDFVocab:provides ViewValidationAlertsInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service generating optimal trajectories using the kinematic model."
    DTDFVocab:provides GenerateTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service running real‑time simulation of crane motion."
    DTDFVocab:provides RunSimulationAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service continuously validating executed motion against simulation."
    DTDFVocab:provides ValidationAlertInsight
]

// Insights and Actions
instance StoreTelemetryAction : DTDFVocab:Action [
    base:desc "Store telemetry data records in TimescaleDB."
    DTDFVocab:IsAutomatic true
]

instance PublishControlSignalAction : DTDFVocab:Action [
    base:desc "Publish control signals and status updates to subscribed clients via MQTT."
    DTDFVocab:IsAutomatic true
]

instance ViewTrajectoryPlotsInsight : DTDFVocab:Insight [
    base:desc "Trajectory plots displayed in Grafana for operator observation."
]

instance ViewValidationAlertsInsight : DTDFVocab:Insight [
    base:desc "Validation alert messages displayed in Grafana when deviations exceed thresholds."
]

instance GenerateTrajectoryAction : DTDFVocab:Action [
    base:desc "Generate optimal trajectory waypoints based on operator payload and constraints."
    DTDFVocab:IsAutomatic false
]

instance RunSimulationAction : DTDFVocab:Action [
    base:desc "Run real‑time simulation of the crane’s motion."
    DTDFVocab:IsAutomatic false
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when executed motion deviates from the simulated trajectory beyond defined thresholds."
]

// Physical system component
instance GantryCraneSystem : DTDFVocab:Component [
    base:desc "Laboratory‑scale gantry crane that moves small containers between two locations in a port‑style setting."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Trajectory Generator Service outputs optimal discrete waypoints (position, velocity, acceleration) to the MQTT broker; the Control Application consumes these messages and sends corresponding PWM/duty‑cycle commands to the motor controllers. The Continuous Validation Service sends alert messages via MQTT to the HMI if the measured trajectory deviates beyond a predefined RMS threshold. The HMI can then re‑compute trajectories or adjust control parameters."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Services operate at distinct time‑scales: Logging is continuous (sub‑second sampling); Trajectory generation and simulation are invoked on demand (upon operator request); Continuous Validation runs continuously, comparing measurements and simulated trajectories in near‑real‑time (within the same cycle as telemetry). The PT and DT are synchronised over the MQTT broker in real time."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin runs on a single PC orchestrated by Docker Compose: the physical interface and control application run as Python processes; micro‑services (Database, MQTT, Dashboard, Trajectory, Simulation, Validation) are independent Docker containers linked via the internal Docker network; the HMI (Grafana front‑end) interfaces with the operators over HTTPS and visualises data from the Database; continuous communication between services is via MQTT topics; logging and storage are decoupled from control logic."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the full lifecycle: design (CAD kinematic model and CAD assemblies in Fusion 360), manufacturing (constructing the physical crane from BOM), and operation (run time monitoring, data logging, validation). The twin evolves through research iterations—continuous validation, fault‑classification, and future extensions to harbor/ship simulation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Continuous Validation Service compares the real trajectory timestamps and positions against the simulation, computing a distance metric (e.g., RMS error) and flagging deviations that exceed a predefined threshold. The validation uses time‑aligned data streams and statistically assessed error bounds. Fault‑classification research applies time‑series classification to detect anomalies. No formal formal verification is described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication occurs over a local TCP/IP network: MQTT broker (Eclipse Mosquitto) for publish/subscribe between services; HTTP/HTTPS for Grafana dashboards; direct serial (UART) from Arduino to the PC for sensor polling. The Logging Application writes to TimescaleDB via PostgreSQL protocol. All Docker containers share a bridge network on the host PC."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted on a personal computer; Docker Compose brings up services via Docker engine; repository and documentation hosted on GitHub; the module can be installed via pip. No cloud deployment is described. All services run locally, container‑ized; the database and broker are initialized automatically on first run."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not addressed in the documents."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not addressed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "No specific industrial or data standards (e.g., AutomationML, Asset Administration Shell, Eclipse Ditto) are employed in the described implementation. The system uses MQTT, TimescaleDB (PostgreSQL), and open‑source software, but does not claim adherence to a formal standard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Not addressed in the documents."
]