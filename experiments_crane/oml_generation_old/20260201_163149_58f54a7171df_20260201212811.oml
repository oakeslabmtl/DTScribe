// C1: Environments
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Physical environment containing the lab-scale gantry crane system including mechanical components, embedded controllers, and sensing/acting devices."
    base:contains CranePositionEncoder, CraneVelocitySensor, CraneAccelerationSensor, CraneMotorCurrentSensor, PuckPositionSensor, CraneMotorActuator
]

instance IndoorAirQualityEnvironment : DTDFVocab:Environment [
    base:desc "Indoor environment equipped with Raspberry Pi-based sensors for monitoring air quality metrics (CO2, particulate matter) in the Air Quality Management exemplar."
    base:contains AirQualityCO2Sensor, AirQualityParticulateSensor
]

