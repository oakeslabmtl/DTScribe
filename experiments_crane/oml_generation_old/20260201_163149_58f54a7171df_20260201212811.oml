// C3: Physical Sensing Components
instance CranePositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder sensor embedded in the lab-scale gantry crane measuring joint angles and position of the crane mechanism for real-time kinematic tracking."
