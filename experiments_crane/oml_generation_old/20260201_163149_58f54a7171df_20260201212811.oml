// C10: Models/Data
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "CAD-derived kinematic model of the lab-scale gantry crane representing joint trajectories, load dynamics, and movement constraints for simulation."
    DTDFVocab:inputTo CraneSimulationEnabler
]

instance CraneDynamicModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the crane including mass properties, friction coefficients, and actuator response characteristics for control validation."
    DTDFVocab:inputTo CraneControlEnabler
]

instance AirQualityAutomationMLModel : DTDFVocab:Model [
    base:desc "AutomationML-based digital twin model for indoor air quality simulation and predictive modeling of CO2 and particulate matter dynamics."
    DTDFVocab:inputTo AirQualitySimulationEnabler
]

instance GreenhouseEnvironmentalModel : DTDFVocab:Model [
    base:desc "Behavioral adaptation model for the GreenhouseDT exemplar simulating temperature, humidity, and ventilation interactions for closed-loop control."
    DTDFVocab:inputTo GreenhouseSimulationEnabler
]

instance CraneRealTimeData : DTDFVocab:Data [
    base:desc "Continuous time-series data stream capturing crane kinematic states, sensor readings, and control commands for real-time monitoring and validation."
    DTDFVocab:fromData CranePositionDataTransmitted, CraneVelocityDataTransmitted, CraneAccelerationDataTransmitted, CraneMotorCurrentDataTransmitted, PuckPositionDataTransmitted
    DTDFVocab:inputTo CraneDataLoggingEnabler, CraneContinuousValidationEnabler
]

instance AirQualityTimeSeriesData : DTDFVocab:Data [
    base:desc "Time-series data from Raspberry Pi sensors recording CO2 levels, particulate matter concentrations, and environmental parameters for air quality analysis."
