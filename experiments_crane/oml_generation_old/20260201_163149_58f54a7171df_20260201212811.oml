    DTDFVocab:inputTo AirQualityDataProcessingEnabler
]

instance GreenhousePrerecordedData : DTDFVocab:Data [
    base:desc "Prerecorded environmental data stored in virtual machine images for the GreenhouseDT exemplar enabling rapid deployment and simulation of greenhouse conditions."
    DTDFVocab:fromData GreenhouseTemperatureDataTransmitted, GreenhouseHumidityDataTransmitted
    DTDFVocab:inputTo GreenhouseDeploymentEnabler
]

// C11: Enablers
instance CraneSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink-based simulation engine for virtual testing of crane kinematic and dynamic scenarios including load variations and fault injections."
    DTDFVocab:enables CraneOptimalControlService, CraneFaultDetectionService
]

instance CraneControlEnabler : DTDFVocab:Enabler [
    base:desc "ROS-based control framework implementing real-time PID and model predictive control algorithms for crane trajectory optimization and load balancing."
    DTDFVocab:enables CraneOptimalControlService, CraneContinuousValidationService
]

instance CraneDataLoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB-based time-series database storing operational data for post-analysis, trend detection, and predictive maintenance of the crane system."
    DTDFVocab:enables CraneHistoricalAnalysisService
]

instance CraneContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation service comparing physical sensor data with kinematic/dynamic models to detect discrepancies and validate model accuracy."
    DTDFVocab:enables CraneContinuousValidationService
]

instance AirQualitySimulationEnabler : DTDFVocab:Enabler [
    base:desc "AutomationML-based simulation platform enabling predictive modeling of air quality dynamics under varying operational conditions (e.g., ventilation adjustments)."
    DTDFVocab:enables AirQualityRuntimeVisualizationService, AirQualityPredictionService
]

instance AirQualityDataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ActiveMQ-based message broker processing time-series air quality data for real-time analysis and decision support."
    DTDFVocab:enables AirQualityRuntimeVisualizationService
]

instance GreenhouseSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python-based simulation environment processing prerecorded data to model greenhouse environmental behavior and enable closed-loop control."
    DTDFVocab:enables GreenhouseBehavioralAdaptationService
]

instance GreenhouseDeploymentEnabler : DTDFVocab:Enabler [
    base:desc "Virtual machine deployment framework preloaded with prerecorded environmental data for rapid setup and replication across environments."
    DTDFVocab:enables GreenhouseBehavioralAdaptationService
]

instance MQTTCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker enabling asynchronous communication between physical sensors, digital twin components, and visualization services."
    DTDFVocab:enables CraneDataLoggingEnabler, AirQualityDataProcessingEnabler
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB 3D Toolbox and custom Python (Plotly) framework rendering real-time and historical data for interactive dashboards."
    DTDFVocab:enables CraneDataVisualizationService
]

// C6: Services
instance CraneOptimalControlService : DTDFVocab:Service [
    base:desc "Real-time control service implementing PID and model predictive control algorithms to optimize crane operations including trajectory planning and load balancing."
    DTDFVocab:provides CraneOptimalControlInsight, CraneControlAdjustmentAction
]

instance CraneContinuousValidationService : DTDFVocab:Service [
