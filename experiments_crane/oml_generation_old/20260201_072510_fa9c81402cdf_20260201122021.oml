// C3: Physical sensing components // Return code: 1 | Stderr:
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring pendular motion of the hoist (mounted on the crane and read via Arduino)."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed that can affect the load on the crane."
    DTDFVocab:producedData AnemometerDataTransmitted
]

instance LimitSwitch : DTDFVocab:SensingComponent [
    base:desc "Limit switch sensors indicating position limits of the cart and hoist motors."
    DTDFVocab:producedData LimitSwitchDataTransmitted
]

instance MotorEncoderFeedback : DTDFVocab:SensingComponent [
    base:desc "Motor driver encoder sending position and velocity feedback from the stepper motor controllers."
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction – Data transmitted via MQTT
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
    base:desc "MQTT topic payload containing raw swing‑angle data streamed from the crane."
]

instance AnemometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
    base:desc "MQTT topic payload containing raw wind‑speed data streamed from the crane."
]

instance LimitSwitchDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LimitSwitch
    base:desc "MQTT topic payload containing raw limit‑switch state data streamed from the crane."
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderFeedback
    base:desc "MQTT topic payload containing raw motor‑encoder data streamed from the crane."
]

// C10: Models/Data – Time‑series and derived metrics
instance SwingAngleRaw : DTDFVocab:Data [
    base:desc "Time‑series log of raw swing‑angle sensor readings."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ValidationEnabler
]

instance WindSpeedRaw : DTDFVocab:Data [
    base:desc "Time‑series log of raw wind‑speed sensor readings."
    DTDFVocab:fromData AnemometerDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ValidationEnabler
]

instance LimitSwitchStateRaw : DTDFVocab:Data [
    base:desc "Time‑series log of raw limit‑switch state readings."
    DTDFVocab:fromData LimitSwitchDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, ValidationEnabler
]

instance MotorEncoderRaw : DTDFVocab:Data [
    base:desc "Time‑series log of raw motor‑encoder readings."
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, SimulationEnabler
]

// C11: Enablers – Open‑source tools used to process data
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (postgreSQL extension) enabling time‑series storage of sensor data."
    DTDFVocab:enables DataLoggingService, RealTimeSimulationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker enabling publish/subscribe communication between sensors, services, and actuators."
    DTDFVocab:enables TrajectoryGenerationService, HumanMachineInterfaceService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation runtime environment enabling real‑time simulation of crane dynamics."
    DTDFVocab:enables RealTimeSimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Validation framework enabling continuous comparison of executed trajectories with simulated ones."
    DTDFVocab:enables ContinuousValidationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard enabling live visualization of sensor data and insights."
    DTDFVocab:enables DataVisualizationService
]

// C6: Services – Digital twin services provided
instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service that generates optimal trajectories for the crane cart and hoist based on real‑time condition."
    DTDFVocab:provides UpdateTrajectoryParametersInsight, UpdateTrajectoryParametersAction
] // TODO: Fix the error on this line helped with this error message: 'Couldn't resolve reference to NamedInstance 'UpdateTrajectoryParametersInsight'.

instance RealTimeSimulationService : DTDFVocab:Service [
    base:desc "Service that runs real‑time simulation of crane dynamics using the kinematic and dynamic models."
    DTDFVocab:provides TrajectoryEfficiencyInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously validates executed trajectories against simulated behaviours and detects faults."
    DTDFVocab:provides SwingAngleErrorTrendInsight, FaultIndicationInsight, UpdateTrajectoryParametersAction, AdjustControlLawAction, ScheduleMaintenanceAction
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service responsible for persisting all sensor state data and motor commands into TimescaleDB."
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service that publishes dashboards to Grafana for operator monitoring."
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Service exposing a human‑machine interface for manual control, configuration, and alerts."
    DTDFVocab:provides OperatorAlertInsight, AlertOperatorAction
]

// C17: Insights – Knowledge derived by the DT services
instance SwingAngleErrorTrendInsight : DTDFVocab:Insight [
    base:desc "Insight reporting trends in swing‑angle error detected by continuous validation."
]

instance TrajectoryEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the efficiency of the executed trajectory compared to the optimal plan."
]

instance FaultIndicationInsight : DTDFVocab:Insight [
    base:desc "Insight identifying early fault indications such as abnormal swing‑angle or motor behaviour."
]

instance OperatorAlertInsight : DTDFVocab:Insight [
    base:desc "Insight that triggers an alert for the operator via the human‑machine interface."
]

instance UpdateTrajectoryParametersInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that trajectory parameters should be updated."
]

// C17: Actions – Automatable decisions derived from insights
instance UpdateTrajectoryParametersAction : DTDFVocab:Action [
    base:desc "Automatic action to update trajectory parameters on the fly."
    DTDFVocab:IsAutomatic true
]

instance AdjustControlLawAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust control law parameters based on validation insights."
    DTDFVocab:IsAutomatic true
]

instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Automatic action to schedule maintenance when fault indications are detected."
    DTDFVocab:IsAutomatic true
]

instance AlertOperatorAction : DTDFVocab:Action [
    base:desc "Automatic action that alerts the operator via the HMI."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The twin feeds control commands back to the crane: the Trajectory Generator Service produces optimal trajectories, which the Control Application translates into motor step commands and sends to the motor drivers. The Continuous Validation Service triggers operator notifications via the dashboard if deviations exceed thresholds. These commands are transmitted over MQTT to the Arduino‑based interface."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data is exchanged in near‑real‑time with a sampling interval of a few milliseconds for sensor uploads, while trajectory planning and validation operate at higher (1–5 s) intervals. The twin therefore operates at real‑time/ near‑real‑time synchronization with the physical system."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin constellation consists of the physical‑crane interface, control application, logging application on the physical side; on the virtual side, the database, dashboard, trajectory generator, simulation, continuous validation, and MQTT broker, all orchestrated via docker‑compose and interconnected through an MQTT network."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers all phases of the system's life‑cycle: design (CAD and kinematic model), manufacturing (assembly of the physical crane), operation (runtime monitoring, control, and validation), and maintenance (periodic updates of the twin services)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity ensured by detailed kinematic and dynamic models; validity continuously checked by comparing real measurements to simulation outputs. Deviations beyond a defined threshold trigger alerts. Model uncertainties, sensor noise, and unmodeled disturbances are acknowledged and handled by the validation service."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses an MQTT broker (Eclipse Mosquitto) running locally on the same host or network. The Arduino controller publishes sensor data to MQTT topics and subscribes to command topics; the Python interface translates between hardware and MQTT. The Docker containers connect over a Docker network, and the physical interface may use USB/serial to the Arduino."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin services are containerized and deployed on a single compute node (e.g., a personal computer) using Docker Compose. The database, broker, and dashboard are separate containers, while the application logic resides in dedicated containers. The process is automatically bootstrapped by the compose file, which initializes the database schema and Grafana dashboards."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "While not directly integrated in the exemplar, the authors mention potential extensions to link the crane twin to a ship and harbor simulation, suggesting that integration with other DTs or external systems could be achieved in future work."
]