// -------------------------------------------------
// Physical Sensing Components
// -------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring angular displacement of the hoist payload in degrees."
    DTDFVocab:producedData AngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring ambient wind speed in m·s⁻¹."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// -------------------------------------------------
// Data Transmitted (from Sensors)
// -------------------------------------------------
instance AngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// -------------------------------------------------
// Data Entries (stored / processed)
// -------------------------------------------------
instance AngleDataEntry : DTDFVocab:Data [
    base:desc "Angle measurement data (degrees) sampled by the swing‑angle encoder."
    DTDFVocab:fromData AngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedDataEntry : DTDFVocab:Data [
    base:desc "Wind speed measurement data (m·s⁻¹) sampled by the anemometer."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// -------------------------------------------------
// Enablers (Tooling & Infrastructure)
// -------------------------------------------------
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance used for storing historical sensor and actuator time‑series."
    DTDFVocab:enables LoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for bi‑directional streaming between Arduino controllers and digital services."
    DTDFVocab:enables ValidationService, OptimalControlService
]

instance DockerContainerEnabler : DTDFVocab:Enabler [
    base:desc "Docker containers encapsulating the Python simulation engine, logging, validation and visualization services."
    DTDFVocab:enables OptimalControlService, ValidationService, VisualizationService, LoggingService, FaultDetectionService
]

instance CADSoftwareEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source CAD software providing geometric models of the gantry crane."
    DTDFVocab:enables VisualizationService
]

instance KinematicSimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python‑based kinematic simulation engine used for optimal control computation and validation."
    DTDFVocab:enables OptimalControlService, ValidationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboards visualising crane state, trajectories and validation results."
    DTDFVocab:enables VisualizationService
]

// -------------------------------------------------
// Services
// -------------------------------------------------
instance LoggingService : DTDFVocab:Service [
    base:desc "Historical data logging service that records sensor and actuator data into TimescaleDB."
    DTDFVocab:provides HistoricalDataInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Optimal control service that computes motion commands for the crane actuators."
    DTDFVocab:provides ControlRecommendationInsight, ExecuteMotionCommandAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Data visualization service rendering crane state, trajectories and validation results."
    DTDFVocab:provides VisualizationDashboardAction
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service comparing kinematic model predictions with real‑time measurements."
    DTDFVocab:provides DeviationAlertInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection service applying time‑series classification to sensor streams."
    DTDFVocab:provides FaultDetectedInsight
]

// -------------------------------------------------
// Insights / Actions produced by Services
// -------------------------------------------------
instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight that historical sensor and actuator data are available for analysis."
]

instance ControlRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight providing optimal motion command recommendations based on current twin state."
]

instance ExecuteMotionCommandAction : DTDFVocab:Action [
    base:desc "Action to send computed motion commands to crane motor controllers."
    DTDFVocab:IsAutomatic true
]

instance VisualizationDashboardAction : DTDFVocab:Action [
    base:desc "Action to display current crane state and trajectories on Grafana dashboards."
    DTDFVocab:IsAutomatic false
]

instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Insight that model‑measurement deviation exceeds predefined thresholds, triggering operator alert."
]

instance FaultDetectedInsight : DTDFVocab:Insight [
    base:desc "Insight that abnormal behavior has been detected in sensor streams."
]

// -------------------------------------------------
// Models (CAD & Kinematic)
// -------------------------------------------------
instance GantryCraneCADModel : DTDFVocab:Model [
    base:desc "CAD model of the lab‑scale gantry crane geometry."
    DTDFVocab:inputTo CADSoftwareEnabler, VisualizationService
]

instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the crane used for motion prediction, optimal control and validation."
    DTDFVocab:inputTo KinematicSimulationEngineEnabler, OptimalControlService, ValidationService
]

// -------------------------------------------------
// Physical Acting Components
// -------------------------------------------------
instance CartMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Electric motor driving the horizontal cart along the track with full‑track travel range."
]

instance HoistMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Electric motor actuating the vertical hoist with defined travel limits."
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist serving as a binary payload release mechanism."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the Control Application, a Python application that uses the Physical Crane Interface to issue actuation commands to the crane hardware. Operator configuration entered through the Human Machine Interface is passed to the Control Application, which then communicates with the physical crane via the interface. The document provides no details on command formats, validation/authentication, feedback loops, conflict resolution, or execution confirmation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The gantry crane digital twin follows an ad‑hoc architecture that relies on containerisation and virtualization technologies, and does not employ a commercial digital‑twin framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin includes a continuous validation service that checks model behavior against incoming data; the exemplar has been used to demonstrate continuous validation methods and fault detection, but specific validation metrics or uncertainty quantification are not detailed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital‑twin services exchange messages through an MQTT broker that provides publish/subscribe signaling between components such as the Trajectory Generator Service, Simulation Service, and Continuous Validation Service. The broker uses the MQTT protocol; no further information on network topology, bandwidth, latency, reliability/redundancy, or security protocols is given."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software components (Python applications, TimescaleDB, Grafana, MQTT broker) are deployed as a set of local containers as described by the C4 model. The deployment is on‑premise (no cloud or edge platform is mentioned) on a single host that runs the database, broker, and services. The document does not detail scalability mechanisms, specific computational or storage sizing, or availability/reliability provisions."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplar adopts an ad‑hoc architecture and does not employ a commercial digital‑twin framework or any cited industry standards such as AutomationML or IEC specifications. No certification requirements, compliance frameworks, or interoperability standards are mentioned."
]