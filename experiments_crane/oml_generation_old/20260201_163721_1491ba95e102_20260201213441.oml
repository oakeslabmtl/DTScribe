]

instance ActiveMQMessageBroker : DTDFVocab:Enabler [
    base:desc "Message broker facilitating low-latency, asynchronous communication between physical sensors and digital twin components with sub-second data exchange"
    DTDFVocab:enables RealTimeDataProcessing, AdaptiveControlService
]

