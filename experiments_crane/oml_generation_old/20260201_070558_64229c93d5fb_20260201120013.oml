// Sensing components – Greenhouse
instance GreenhouseTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature probe in the greenhouse, data stored in InfluxDB and relayed via ActiveMQ"
    DTDFVocab:producedData GreenhouseTempDataTransmitted
]

instance GreenhouseHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity probe in the greenhouse, data stored in InfluxDB and relayed via ActiveMQ"
    DTDFVocab:producedData GreenhouseHumidityDataTransmitted
]

// Sensing components – Air Quality Management
instance AirQualityCO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor on Raspberry‑Pi, feeds AutomationML model and Azure analytics pipelines"
    DTDFVocab:producedData AirQualityCO2DataTransmitted
]

instance AirQualityTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor on Raspberry‑Pi, contributes to air‑quality analytics"
    DTDFVocab:producedData AirQualityTempDataTransmitted
]

instance AirQualityHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor on Raspberry‑Pi, feeds Azure-based prediction model"
    DTDFVocab:producedData AirQualityHumidityDataTransmitted
]

instance AirQualityParticulateSensor : DTDFVocab:SensingComponent [
    base:desc "Particulate Matter sensor on Raspberry‑Pi, used in dispersion simulation"
    DTDFVocab:producedData AirQualityParticulateDataTransmitted
]

// Sensing components – Laboratory‑scale Gantry Crane
instance GantryPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Linear position encoder for the X‑axis carriage of the gantry crane"
    DTDFVocab:producedData GantryTelemetryDataTransmitted
]

instance GantryVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Velocity sensor measuring carriage speed"
    DTDFVocab:producedData GantryTelemetryDataTransmitted
]

instance GantryLoadSensor : DTDFVocab:SensingComponent [
    base:desc "Load cell measuring payload on the crane jib"
    DTDFVocab:producedData GantryTelemetryDataTransmitted
]

instance GantryEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Rotational encoder on the crane jib"
    DTDFVocab:producedData GantryTelemetryDataTransmitted
]

// Data transmitted from sensors
instance GreenhouseTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseTemperatureSensor
]

instance GreenhouseHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseHumiditySensor
]

instance AirQualityCO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityCO2Sensor
]

instance AirQualityTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityTemperatureSensor
]

instance AirQualityHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityHumiditySensor
]

instance AirQualityParticulateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityParticulateSensor
]

instance GantryTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GantryPositionSensor, GantryVelocitySensor, GantryLoadSensor, GantryEncoderSensor
]

// Data objects
instance GreenhouseTempData : DTDFVocab:Data [
    base:desc "Time‑stamped greenhouse temperature readings"
    DTDFVocab:inputTo InfluxDBEnabler, ActiveMQEnabler
    DTDFVocab:fromData GreenhouseTempDataTransmitted
]

instance GreenhouseHumidityData : DTDFVocab:Data [
    base:desc "Time‑stamped greenhouse humidity readings"
    DTDFVocab:inputTo InfluxDBEnabler, ActiveMQEnabler
    DTDFVocab:fromData GreenhouseHumidityDataTransmitted
]

instance AirQualityCO2Data : DTDFVocab:Data [
    base:desc "Time‑stamped CO₂ concentrations from Raspberry‑Pi"
    DTDFVocab:inputTo AzureServicesEnabler, AutomationMLEnabler
    DTDFVocab:fromData AirQualityCO2DataTransmitted
]

instance AirQualityTempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature readings for indoor air quality"
    DTDFVocab:inputTo AzureServicesEnabler, AutomationMLEnabler
    DTDFVocab:fromData AirQualityTempDataTransmitted
]

instance AirQualityHumidityData : DTDFVocab:Data [
    base:desc "Time‑stamped humidity readings for indoor air quality"
    DTDFVocab:inputTo AzureServicesEnabler, AutomationMLEnabler
    DTDFVocab:fromData AirQualityHumidityDataTransmitted
]

instance AirQualityParticulateData : DTDFVocab:Data [
    base:desc "Time‑stamped particulate matter levels detected by Raspberry‑Pi"
    DTDFVocab:inputTo AzureServicesEnabler, AutomationMLEnabler
    DTDFVocab:fromData AirQualityParticulateDataTransmitted
]

instance GantryTelemetryData : DTDFVocab:Data [
    base:desc "Combined telemetry of gantry position, velocity, load, and encoder state"
    DTDFVocab:inputTo TimescaleDBEnabler, DockerContainerEnabler
    DTDFVocab:fromData GantryTelemetryDataTransmitted
]

// Enablers – data stores and messaging
instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "Time‑series database storing greenhouse sensor data"
    DTDFVocab:enables GreenhouseHistoricalLoggingService, GreenhouseControlService
]

instance ActiveMQEnabler : DTDFVocab:Enabler [
    base:desc "Message broker used to send control commands to greenhouse actuators"
    DTDFVocab:enables GreenhouseControlService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Database collecting gantry crane telemetry for validation and replay"
    DTDFVocab:enables CraneContinuousValidationService
]

instance AzureServicesEnabler : DTDFVocab:Enabler [
    base:desc "Azure IoT Hub and Stream Analytics pipeline feeding the air‑quality twin"
    DTDFVocab:enables AirQualityPredictionService, AirQualityVisualizationService
]

instance AutomationMLEnabler : DTDFVocab:Enabler [
    base:desc "AutomationML model interpreting indoor air quality data"
    DTDFVocab:enables AirQualityPredictionService
]

instance DockerContainerEnabler : DTDFVocab:Enabler [
    base:desc "Docker container hosting the greenhouse twin simulation environment"
    DTDFVocab:enables GreenhouseControlService
]

// Services – greenhouse twin
instance GreenhouseControlService : DTDFVocab:Service [
    base:desc "Optimal control of greenhouse environmental settings using sensor feedback and model predictions"
    DTDFVocab:provides GreenhouseOptimalEnvironmentalSettingsInsight, GreenhouseSendCommandAction
]

instance GreenhouseHistoricalLoggingService : DTDFVocab:Service [
    base:desc "Historical data logging of greenhouse sensor streams for post‑mission analysis"
    DTDFVocab:provides GreenhouseHistoricalLoggingInsight
]

// Services – air‑quality twin
instance AirQualityPredictionService : DTDFVocab:Service [
    base:desc "Simulation and prediction of indoor air‑quality trajectories via AutomationML and Azure pipelines"
    DTDFVocab:provides AirQualityVentilationAdjustmentInsight, AirQualityOccupancyLimitInsight
]

instance AirQualityVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization dashboard for indoor air quality metrics"
    DTDFVocab:provides AirQualityDashboardInsight
]

// Services – gantry crane twin
instance CraneContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation comparing real‑world crane motion against the computational model"
    DTDFVocab:provides CraneFaultDetectionInsight
]

instance CraneOptimalControlService : DTDFVocab:Service [
    base:desc "Motion planning for the gantry crane that minimizes energy consumption or travel time"
    DTDFVocab:provides CraneMotionPlanInsight
]

// Insights
instance GreenhouseOptimalEnvironmentalSettingsInsight : DTDFVocab:Insight [
    base:desc "Predicted optimal temperature and humidity settings for greenhouse control"
]

instance GreenhouseHistoricalLoggingInsight : DTDFVocab:Insight [
    base:desc "Record of historical greenhouse sensor data for analysis"
]

instance AirQualityVentilationAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Recommendation to adjust ventilation based on predicted CO₂ concentration"
]

instance AirQualityOccupancyLimitInsight : DTDFVocab:Insight [
    base:desc "Suggested occupancy limit to maintain safe indoor air quality"
]

instance AirQualityDashboardInsight : DTDFVocab:Insight [
    base:desc "Live dashboard view of indoor air quality metrics"
]

instance CraneFaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of deviations between model predictions and actual crane telemetry"
]

instance CraneMotionPlanInsight : DTDFVocab:Insight [
    base:desc "Recommended motion plan for the gantry crane to achieve task objectives efficiently"
]

// Actions
instance GreenhouseSendCommandAction : DTDFVocab:Action [
    base:desc "Automatic command sent to greenhouse actuators via ActiveMQ broker"
    DTDFVocab:IsAutomatic true
]

instance AirQualityVentilationAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment command for ventilation system based on twin prediction"
    DTDFVocab:IsAutomatic true
]

instance OccupancyLimitAction : DTDFVocab:Action [
    base:desc "Alert action to enforce occupancy limits for safety"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the Control Application, also written in Python, which obtains motion trajectories from the Trajectory Generator Service and invokes the Physical Crane Interface to command the crane hardware. The Physical Crane Interface translates high‑level motion instructions into controller commands passed directly to the crane’s field‑bus controllers. The documentation does not describe authentication, conflict resolution or execution acknowledgement mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "GreenhouseDT orchestrates data flow using an InfluxDB time‑series database that stores sensor telemetry, an Apache ActiveMQ broker that mediates messages between the greenhouse’s physical devices and the digital twin runtime, and virtual machine images containing prerecorded datasets. The Air Quality Management exemplar utilizes Microsoft Azure components—IoT Hub for device ingress, Azure Functions for processing, and Azure Stream Analytics for real‑time aggregation—alongside an AutomationML model that defines the twin’s structure. Both systems employ service‑oriented integration patterns, with message queues (ActiveMQ/JMS or AMQP via Azure IoT Hub) decoupling data ingestion from model updates and analytics."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin relies on an MQTT broker. The MQTT broker facilitates publish/subscribe messaging for services such as the Trajectory Generator Service, Simulation Service, Continuous Validation Service, and the Dashboard. The broker operates over TCP using the MQTT protocol. The physical crane interface communicates directly with the crane controllers via their native controller interface (not explicitly specified, likely a proprietary field‑bus protocol). No further details on network topology, bandwidth, latency, reliability or security protocols are provided."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Both exemplars expose sensor streams to external services via standard messaging protocols: ActiveMQ (JMS/AMQP) for GreenhouseDT and Azure IoT Hub (MQTT/AMQP) for the Air Quality Management exemplar. The latter’s AutomationML digital twin model enables interoperability with engineering tools that consume AutomationML, while code and configurations are shared through GitHub repositories and Docker images. No commercial digital twin framework is invoked; the integration relies on open‑source middleware, cloud services, and containerization to interface with downstream analytics, visualization, and prediction services."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air Quality Management exemplar adopts the AutomationML standard for twin modelling and employs Microsoft Azure’s IoT and analytics services, which adhere to Azure IoT standards and RESTful APIs for interoperability. The Greenhouse and Gantry Crane exemplars do not follow a dedicated commercial twin framework and instead use an ad‑hoc stack of IoT protocols (e.g., MQTT via ActiveMQ) and open‑source databases (InfluxDB). Compliance with industry standards beyond AutomationML is not documented."
]