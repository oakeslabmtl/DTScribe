// Acting Components // Return code: 1 | Stderr:
instance HorizontalDriveMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Horizontal cart rail DC motor driven by the controller to move the carriage along the gantry."
]
instance VerticalHoistMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Vertical hoist shaft DC motor driven by the controller to raise and lower the hoist."
]
instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted at the hoist end that picks up and releases small puck containers."
]

// Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder that reports the angular displacement of the hoist shaft relative to the vertical axis."
    DTDFVocab:producedData SwingAngleData
]
instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer that records ambient wind speed affecting the crane operation."
    DTDFVocab:producedData AnemometerData
]

// Physical-to-Virtual Interaction: Data Transmitted
instance SwingAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance AnemometerData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// Physical-to-Virtual Interaction: Data
instance SwingAngleMeasurement : DTDFVocab:Data [
    base:desc "Timestamped measurement of the swing angle recorded by the swing angle encoder."
    DTDFVocab:fromData SwingAngleData
    DTDFVocab:inputTo PythonDataIngestionEnabler, ValidationEngineEnabler, TimescaleDBEnabler
]
instance AnemometerReading : DTDFVocab:Data [
    base:desc "Timestamped wind speed reading recorded by the anemometer."
    DTDFVocab:fromData AnemometerData
    DTDFVocab:inputTo PythonDataIngestionEnabler, ValidationEngineEnabler, TimescaleDBEnabler
]

// Model and Data
instance KinematicModel_GantryCrane : DTDFVocab:Model [
    base:desc "Kinematic model capturing Cartesian motion of the gantry crane's cart and hoist."
    DTDFVocab:inputTo KinematicEngineEnabler
]
instance PredictedTrajectoryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom KinematicEngineEnabler
]
instance PredictedTrajectoryData : DTDFVocab:Data [
    base:desc "Model-generated expected position data for cart and hoist used for trajectory verification."
    DTDFVocab:fromData PredictedTrajectoryTransmitted
    DTDFVocab:inputTo KinematicEngineEnabler, ValidationEngineEnabler
]

// Enablers
instance PythonDataIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Python application that ingests sensor data and streams it to MQTT and TimescaleDB."
    DTDFVocab:enables HistoricalDataLoggingService, ContinuousValidationService
]
instance KinematicEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python execution of the kinematic engine that generates predicted trajectories."
    DTDFVocab:enables OptimalTrajectoryGenerationService
]
instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python application that compares sensor measurements against model predictions."
    DTDFVocab:enables ContinuousValidationService
]
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance storing sensor logs and model outputs."
    DTDFVocab:enables HistoricalDataLoggingService
]
instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboards that query TimescaleDB and display real‑time status, historical trends, and validation alerts."
    DTDFVocab:enables VisualizationService
]
instance MosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Mosquitto MQTT broker handling publish/subscribe messaging between the controller and digital-twin services."
    DTDFVocab:enables HistoricalDataLoggingService, OptimalTrajectoryGenerationService, ContinuousValidationService, VisualizationService
]

// Services
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that streams real‑time sensor readings (position, velocity, motor currents) to TimescaleDB."
    DTDFVocab:provides SystemHealthInsight
]
instance OptimalTrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service that uses the crane's kinematic model to compute energy‑efficient motion plans."
    DTDFVocab:provides TrajectoryEfficiencyInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously compares sensor measurements against model predictions and flags discrepancies."
    DTDFVocab:provides SafetyMarginInsight, DiscrepancyAlertInsight
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that renders logged data on Grafana dashboards for operators and researchers."
    DTDFVocab:provides DashboardInsight
]

// Insights
instance TrajectoryEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight on trajectory efficiency derived from optimal trajectory generation."
]
instance SafetyMarginInsight : DTDFVocab:Insight [
    base:desc "Insight on safety margins computed from continuous validation comparing measured swing angles to model predictions."
]
instance SystemHealthInsight : DTDFVocab:Insight [
    base:desc "Insight on overall system health derived from historic data logging of sensor readings."
]
instance DiscrepancyAlertInsight : DTDFVocab:Insight [
    base:desc "Insight alerting discrepancies between expected and measured trajectories."
]
instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Insight providing operators with real‑time status, historical trends, and validation alerts via Grafana dashboards."
]

// Actions
instance AdjustTrajectoryAction : DTDFVocab:Action [
    base:desc "Automated adjustment of the crane trajectory in response to validation discrepancies."
    DTDFVocab:IsAutomatic true
]

// Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:desc "Laboratory‑scale gantry crane system consisting of the physical crane structure, its controller, and associated sensors and actuators."
    base:contains HorizontalDriveMotorActuator, VerticalHoistMotorActuator, ElectromagnetActuator, SwingAngleEncoder, Anemometer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Operator commands issued through the Human Machine Interface are forwarded by the Control Application to the Physical Crane Interface, which in turn sends motion commands (e.g., target coordinates or velocity profiles) to the physical crane controllers over the same Python connection. The document does not detail any authentication, validation, or command‑confirmation procedures; however, a Continuous Validation Service compares executed trajectories against simulated ones stored in the database and alerts the operator via the Dashboard if an error threshold is exceeded."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Dt constellation: The lab‑scale gantry crane twin orchestrates its components in an ad‑hoc, containerized architecture.  A set of Docker containers are deployed that encapsulate the core services: the Physical Crane Interface—a lightweight Python program that directly interrogates the crane’s PLC controllers for status and kinematic data; the Logging Application, which subscribes to the MQTT topics published by the interface and writes the telemetry into a time‑series database; and optional services such as a trajectory planner and a web‑based dashboard.  All intra‑twin communication proceeds over an MQTT broker that runs on the host.  Docker’s native cgroup limits provide the basic resource management, while coordination is achieved implicitly via the broker and via shared configuration files.  No external orchestration framework or central registry is employed."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A Continuous Validation Service runs in parallel with the trajectory generator.  It compares the trajectory measured by the sensors against the simulated trajectory produced by the kinematic model, computing a distance metric between the two.  This metric is then checked against a predefined tolerance threshold; if the threshold is exceeded, a fault‑detection alert is generated, triggering investigation of the trajectory or the underlying model."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All intra‑service communication is performed over MQTT using an Eclipse Mosquitto broker. The broker is deployed in a Docker container alongside the TimescaleDB, Dashboard, and Simulation services. MQTT operates over TCP sockets and leverages Docker Compose to create a shared bridge network for all containers. The architecture excludes explicit HTTP REST endpoints; instead, messaging is used for service coordination."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire Digital Twin stack is run locally on a personal computer that is physically connected to the crane. The software consists of Python modules bundled under the gantrylib package and is deployed via Docker Compose, which orchestrates the TimescaleDB database, the Eclipse Mosquitto MQTT broker, and the Grafana dashboard containers. All services are isolated in Docker containers, allowing for on‑premises, edge deployment without cloud involvement. Specific computational and storage requirements are not detailed, but TimescaleDB and Grafana are containerized and can be scaled by increasing container resources."
]