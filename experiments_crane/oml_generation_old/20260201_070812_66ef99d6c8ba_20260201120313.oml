// ---------- Environment and Components for Crane Twin ----------
instance CraneTwinEnvironment : DTDFVocab:Environment [
    base:contains GantryCraneMesh, CraneSensorCluster, CraneActuatorCluster
]

instance GantryCraneMesh : DTDFVocab:Component [
    base:desc "Laboratory‑scale gantry crane mechanical frame and geometry modeled in CAD."
]

instance CraneSensorCluster : DTDFVocab:Component [
    base:desc "Cluster of sensors monitoring crane state: position, velocity, and load."
]

instance CraneActuatorCluster : DTDFVocab:Component [
    base:desc "Actuation system commanding motors to move trolley and hoist."
]

// ---------- Crane Sensing Components ----------
instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring trolley position along rail."
    DTDFVocab:producedData CraneStateDataTransmitted
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Accelerometer‑derived sensor measuring crane velocity."
    DTDFVocab:producedData CraneStateDataTransmitted
]

instance CraneLoadSensor : DTDFVocab:SensingComponent [
    base:desc "Load cell sensor measuring payload weight."
    DTDFVocab:producedData CraneStateDataTransmitted
]

// ---------- Crane Data Transmitted ----------
instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor, CraneVelocitySensor, CraneLoadSensor
]

// ---------- Crane Time‑Series Data ----------
instance CraneStateTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of crane state (position, velocity, load) stored in TimescaleDB."
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// ---------- Enablers ----------
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB instance used for logging crane telemetry."
    DTDFVocab:enables CraneDataLoggingService, CraneHistoricalDataService, CraneVisualizationDashboardService
]

instance ActiveMQEnabler : DTDFVocab:Enabler [
    base:desc "ActiveMQ broker facilitating inter‑module communication within the crane twin."
    DTDFVocab:enables CraneControlService, CraneValidationService, CraneRealTimeMonitoringService
]

instance SimulationEngineCraneEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine for crane kinematic model."
    DTDFVocab:enables CraneSimulationService
]

// ---------- Crane Kinematic Model ----------
instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Open format kinematic model of the gantry crane geometry."
    DTDFVocab:inputTo SimulationEngineCraneEnabler
]

// ---------- Crane Services ----------
instance CraneRealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing live visualization of crane telemetry."
    DTDFVocab:provides CraneStateInsight
]

instance CraneControlService : DTDFVocab:Service [
    base:desc "Service computing optimal feedforward commands to minimize trajectory error."
    DTDFVocab:provides ControlCommandInsight, ControlAction
]

instance CraneDataLoggingService : DTDFVocab:Service [
    base:desc "Service handling real‑time logging of all sensor and actuator streams."
    DTDFVocab:provides HistoricalDataInsight
]

instance CraneHistoricalDataService : DTDFVocab:Service [
    base:desc "Service serving archived data for post‑hoc analysis."
    DTDFVocab:provides HistoricalDataInsight
]

instance CraneValidationService : DTDFVocab:Service [
    base:desc "Service performing continuous validation comparing model and measured motion."
    DTDFVocab:provides ValidationResultInsight
]

instance CraneSimulationService : DTDFVocab:Service [
    base:desc "Service running kinematic simulation for predictive insight."
    DTDFVocab:provides CraneSimulationInsight
]

instance CraneVisualizationDashboardService : DTDFVocab:Service [
    base:desc "Service rendering current and past crane operations in dashboards."
    DTDFVocab:provides CraneVisualizationInsight
]

// ---------- Crane Insights and Actions ----------
instance CraneStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time display of crane state including position, velocity, load."
]

instance ControlCommandInsight : DTDFVocab:Insight [
    base:desc "Insight into computed optimal feedforward commands."
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Command sent to crane actuators to adjust trajectory."
    DTDFVocab:IsAutomatic true
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Archive insight showing historical sensor and actuator series."
]

instance ValidationResultInsight : DTDFVocab:Insight [
    base:desc "Comparison result of model predictions vs. measured motion."
]

instance CraneSimulationInsight : DTDFVocab:Insight [
    base:desc "Predicted crane trajectory from kinematic simulation."
]

instance CraneVisualizationInsight : DTDFVocab:Insight [
    base:desc "Dashboard visualization of crane operations."
]

// ---------- Environment and Components for Air Quality Twin ----------
instance AirQualityTwinEnvironment : DTDFVocab:Environment [
    base:contains GreenhouseMesh, AirQualityControlSystem
]

instance GreenhouseMesh : DTDFVocab:Component [
    base:desc "Low‑cost greenhouse geometry modeled in CAD."
]

instance AirQualityControlSystem : DTDFVocab:Component [
    base:desc "Indoor air quality control system represented in AutomationML."
]

// ---------- Air Quality Sensing Components ----------
instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry‑Pi attached temperature sensor measuring indoor ambient temperature."
    DTDFVocab:producedData AirQualityDataTransmitted
]

instance CO2ConcentrationSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry‑Pi attached CO₂ sensor measuring indoor concentration."
    DTDFVocab:producedData AirQualityDataTransmitted
]

instance VOCSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry‑Pi attached volatile organic compound sensor."
    DTDFVocab:producedData AirQualityDataTransmitted
]

instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor, CO2ConcentrationSensor, VOCSensor
]

// ---------- Air Quality Time‑Series Data ----------
instance AirQualityTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of indoor air quality metrics stored in InfluxDB."
    DTDFVocab:fromData AirQualityDataTransmitted
    DTDFVocab:inputTo InfluxDBEnabler
]

// ---------- Enablers ----------
instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB instance storing indoor air quality time series data."
    DTDFVocab:enables AirQualityVisualizationService
]

instance AzureMLEnabler : DTDFVocab:Enabler [
    base:desc "Azure Machine Learning service ingesting data for forecasting."
    DTDFVocab:enables AirQualityForecastService
]

instance SimulationEngineAirQualityEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine for airflow and contaminant dispersion."
    DTDFVocab:enables AirQualitySimulationService
]

// ---------- AutomationML Air Quality Model ----------
instance AutomationMLAirQualityModel : DTDFVocab:Model [
    base:desc "AutomationML‑based model representing indoor air quality control system."
    DTDFVocab:inputTo SimulationEngineAirQualityEnabler
]

// ---------- Air Quality Services ----------
instance AirQualityVisualizationService : DTDFVocab:Service [
    base:desc "Service rendering real‑time sensor streams and control dashboard."
    DTDFVocab:provides AQIRuntimeInsight
]

instance AirQualityForecastService : DTDFVocab:Service [
    base:desc "Azure ML pipeline generating future air quality indices."
    DTDFVocab:provides ForecastInsight
]

instance AirQualitySimulationService : DTDFVocab:Service [
    base:desc "Service simulating airflow and contaminant dispersion."
    DTDFVocab:provides AirQualitySimulationInsight
]

// ---------- Air Quality Insights and Actions ----------
instance AQIRuntimeInsight : DTDFVocab:Insight [
    base:desc "Live display of current indoor air quality sensor streams."
]

instance ForecastInsight : DTDFVocab:Insight [
    base:desc "Prediction of future air quality indices for virus‑spread prevention."
]

instance AirQualitySimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation output of indoor airflow and contaminant dispersion."
]

instance VentilationCommandAction : DTDFVocab:Action [
    base:desc "Automated command to adjust ventilation based on prediction."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are issued by the Control Application, which uses the Physical Crane Interface to send movement or trajectory instructions to the crane hardware via a Python program. The command format, authentication, and feedback mechanisms are not detailed; execution confirmation is inferred indirectly through the state logs captured by the Logging Application."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The GreenhouseDT explorer orchestrates its digital twin through a micro‑service style architecture that relies heavily on containerization or virtualization for rapid deployment. Sensor data streams from a Raspberry‑Pi based physical greenhouse are published to an Apache ActiveMQ message broker, which decouples the ingestion layer from downstream analytics and control services. The twin’s state is persisted in an InfluxDB time‑series database, accessible via its HTTP API or Telegraf agents. Virtual machine images bundle prerecorded data for replay and testing scenarios, while the entire stack (including the message broker, database, and twin logic) can be assembled from Docker containers for reproducibility. For the Air Quality Management exemplar, the twin leverages an AutomationML model to describe asset relationships and uses Microsoft Azure services (e.g., Azure IoT Hub, Azure Functions, Azure Sentinel) to implement runtime visualization, simulation, and prediction pipelines. Overall, the system coordinates resources via message‑driven event buses, uses cloud or on‑premise deployment patterns, and manages compute and storage through VM image snapshots and Docker images."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Components communicate via an MQTT broker that facilitates signaling between services such as the Trajectory Generator, Simulation Service, and Continuous Validation Service. The architecture follows a container-based model; specific bandwidth, latency, network topology, or security protocol details are not provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components run on local infrastructure—a lab environment—using Python applications, a TimescaleDB database, and a Grafana dashboard. Deployment is on‑premise; scalability, cloud support, redundancy, and availability mechanisms are not described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through standardized middleware and cloud connectors. Physical subsystems (e.g., Raspberry‑Pi controllers) push telemetry to the twin via ActiveMQ JMS queues, while the twin exposes its state through InfluxDB’s RESTful line‑protocol endpoint for downstream analytics. The Air Quality twin utilizes AutomationML to exchange asset metadata and configuration with enterprise PLM systems or other twins. Azure services—such as IoT Hub for device connectivity, Azure Functions for serverless orchestration, and Azure Sentinel for security analytics—provide managed integration points that connect the twin to broader enterprise IT fabrics. All components are exposed over standard protocols (HTTP, WebSocket for IoT Hub, JMS for ActiveMQ) ensuring interoperability with legacy or third‑party systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin model conforms to the AutomationML specification, ensuring machine‑equipment data interoperability with CAPP and CAM systems. Communication between physical and virtual layers uses MQTT, an industry‑wide open‑standard messaging protocol supported by ActiveMQ. Data persistence employs InfluxDB, an open‑source time‑series database that follows the OpenTSDB schema. Version control and collaboration are handled via Git on GitHub, following best practices for open‑source software development."
]