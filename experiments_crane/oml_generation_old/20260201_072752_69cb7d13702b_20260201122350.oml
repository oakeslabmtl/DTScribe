// Component representing the physical system // Return code: 1 | Stderr:
instance LabScaleGantryCraneComponent : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane inspired by Antwerp harbor cranes, consisting of a cart and hoist, stepper motors, electromagnet, swing‑angle encoder, anemometer, all powered by an Arduino controller."
]

// Acting Components (Actuators)
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Step‑per motor driving the cart, interfaced through a TMC4671 Eval board and controlled via Python 'Physical Crane Interface' communicating with Arduino."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Step‑per motor driving the hoist, interfaced through a TMC4671 Eval board and controlled via Python 'Physical Crane Interface' communicating with Arduino."
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist, used for picking up small container pucks."
]

// Sensing Components
instance SwingAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring the swing angle of the cart‑hoist system."
    DTDFVocab:producedData SwingAngleTelemetry
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring wind speed acting on the crane."
    DTDFVocab:producedData WindSpeedTelemetry
]

instance CartMotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder on cart stepper motor providing position measurements."
    DTDFVocab:producedData CartEncoderTelemetry
]

instance CartMotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor on cart stepper motor providing real‑time current draw."
    DTDFVocab:producedData CartCurrentTelemetry
]

instance HoistMotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder on hoist stepper motor providing position measurements."
    DTDFVocab:producedData HoistEncoderTelemetry
]

instance HoistMotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor on hoist stepper motor providing real‑time current draw."
    DTDFVocab:producedData HoistCurrentTelemetry
]

instance MiscPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Miscellaneous redundant position sensor on the cart."
    DTDFVocab:producedData MiscPositionTelemetry
]

// Data transmitted from sensors
instance SwingAngleTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensor
]

instance WindSpeedTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance CartEncoderTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorEncoderSensor
]

instance CartCurrentTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorCurrentSensor
]

instance HoistEncoderTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorEncoderSensor
]

instance HoistCurrentTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorCurrentSensor
]

instance MiscPositionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MiscPositionSensor
]

// Data stored persistently
instance SwingAngleTelemetryData : DTDFVocab:Data [
    base:desc "Swing angle telemetry recorded in TimescaleDB persistent time‑series."
    DTDFVocab:fromData SwingAngleTelemetry
    DTDFVocab:inputTo DockerComposeEnabler
]

instance WindSpeedTelemetryData : DTDFVocab:Data [
    base:desc "Wind speed telemetry recorded in TimescaleDB persistent time‑series."
    DTDFVocab:fromData WindSpeedTelemetry
    DTDFVocab:inputTo DockerComposeEnabler
]

instance CartEncoderTelemetryData : DTDFVocab:Data [
    base:desc "Cart motor encoder telemetry recorded in TimescaleDB persistent time‑series."
    DTDFVocab:fromData CartEncoderTelemetry
    DTDFVocab:inputTo DockerComposeEnabler
]

instance CartCurrentTelemetryData : DTDFVocab:Data [
    base:desc "Cart motor current telemetry recorded in TimescaleDB persistent time‑series."
    DTDFVocab:fromData CartCurrentTelemetry
    DTDFVocab:inputTo DockerComposeEnabler
]

instance HoistEncoderTelemetryData : DTDFVocab:Data [
    base:desc "Hoist motor encoder telemetry recorded in TimescaleDB persistent time‑series."
    DTDFVocab:fromData HoistEncoderTelemetry
    DTDFVocab:inputTo DockerComposeEnabler
]

instance HoistCurrentTelemetryData : DTDFVocab:Data [
    base:desc "Hoist motor current telemetry recorded in TimescaleDB persistent time‑series."
    DTDFVocab:fromData HoistCurrentTelemetry
    DTDFVocab:inputTo DockerComposeEnabler
]

instance MiscPositionTelemetryData : DTDFVocab:Data [
    base:desc "Miscellaneous position telemetry recorded in TimescaleDB persistent time‑series."
    DTDFVocab:fromData MiscPositionTelemetry
    DTDFVocab:inputTo DockerComposeEnabler
]

// Models and related data
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "Autodesk Fusion360 CAD geometric model of the gantry crane."
    DTDFVocab:inputTo DockerComposeEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Python kinematic model of cart‑hoist motion used for trajectory planning."
    DTDFVocab:inputTo DockerComposeEnabler
]

instance TimeSeriesLogsModel : DTDFVocab:Model [
    base:desc "Model representation of TimescaleDB time‑series logs for telemetry."
    DTDFVocab:inputTo DockerComposeEnabler
]

instance SimulationControllerModel : DTDFVocab:Model [
    base:desc "Simulation model of the crane controller implemented in Python."
    DTDFVocab:inputTo DockerComposeEnabler
]

instance OptimalTrajectoryGeneratorModel : DTDFVocab:Model [
    base:desc "Optimal trajectory generator algorithm determining swing‑free paths."
    DTDFVocab:inputTo DockerComposeEnabler
]

instance ContinuousValidationMetricModel : DTDFVocab:Model [
    base:desc "Distance metric model used for continuous validation of executed vs. simulated trajectories."
    DTDFVocab:inputTo DockerComposeEnabler
]

// Enabler (Docker Compose orchestration)
instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker Compose orchestration for all service containers."
    DTDFVocab:enables DataLoggingService, GrafanaDashboardService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService, MQTTBrokerService
]

// Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Collects sensor telemetry via MQTT and logs it into TimescaleDB for persistent storage."
    DTDFVocab:provides DataLoggedInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of telemetry data stored in TimescaleDB using Grafana dashboards."
    DTDFVocab:provides DashboardVisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free trajectories using the kinematic model and publishes commands to the physical interface."
    DTDFVocab:provides TrajectoryGeneratedInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs simulation of the crane controller to predict trajectory outcomes."
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectory telemetry with simulated predictions to compute a distance metric and triggers alerts when deviation exceeds threshold."
    DTDFVocab:provides DeviationAlertInsight, FaultLocalizationInsight
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Eclipse Mosquitto broker delivering real‑time telemetry and control commands between components and services."
    DTDFVocab:provides MessagingServiceInsight
]

// Insights
instance DataLoggedInsight : DTDFVocab:Insight [
    base:desc "Indicates that telemetry data has been successfully logged into TimescaleDB."
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time performance metrics are visualized on Grafana dashboards."
]

instance TrajectoryGeneratedInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory has been generated by the trajectory generator."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation of the crane controller has produced predicted trajectory data."
]

instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Deviation between executed and simulated trajectory exceeds the configured threshold."
]

instance FaultLocalizationInsight : DTDFVocab:Insight [
    base:desc "Fault localized via classification of sensor and actuator diagnostics."
]

instance OperatorNotificationInsight : DTDFVocab:Insight [
    base:desc "Operator notified for maintenance scheduling or fault localization."
]

instance MessagingServiceInsight : DTDFVocab:Insight [
    base:desc "Messaging service is available for inter‑component communication."
]

// Actions
instance OperatorNotificationAction : DTDFVocab:Action [
    base:desc "Sends notifications to operator for maintenance scheduling or fault localization."
    DTDFVocab:IsAutomatic false
]

// Environment containing all components
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains LabScaleGantryCraneComponent, CartStepperMotor, HoistStepperMotor, ElectromagnetActuator,
                SwingAngleEncoderSensor, AnemometerSensor, CartMotorEncoderSensor, CartMotorCurrentSensor,
                HoistMotorEncoderSensor, HoistMotorCurrentSensor, MiscPositionSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory commands and control signals generated by the Trajectory Generator Service are sent via MQTT to the Control Application, which forwards them to the physical crane drivers; the Continuous Validation Service publishes alerts to the dashboard when deviations exceed thresholds; operators can adjust commands through the Human Machine Interface."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in near real‑time: Sensor data is logged at the native sampling rate of the Arduino (typically 10–100 Hz), the Continuous Validation Service processes data continuously, and trajectory generation updates are performed on demand as users command new starts; the entire set of operations is synchronized via the MQTT broker."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A container‑based constellation where data flows from the Physical Crane Interface to the Logging Service via MQTT, aggregates in TimescaleDB, is visualized through Grafana, receives trajectory commands from the Trajectory Generator, and validates operations via the Continuous Validation Service; all services communicate over MQTT and share a shared database."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design phase: CAD models in Autodesk Fusion360 and kinematic model defined in the software; Manufacturing phase: the physical crane is assembled from the BOM and firmware deployed to microcontrollers; Operated phase: the twin runs in parallel during crane operation, providing continuous validation and live visualization."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service compares real‑time sensor traces against simulated trajectories using distance metrics and thresholds; model validation trust is established through repeated comparison with measured data, and time‑series classification is employed to localize faults, ensuring fidelity of both kinematic and control models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical interface communicates with Arduino over serial (e.g., UART/USB); data from Arduino to DT services is published to an Eclipse Mosquitto MQTT broker using standard JSON payloads; services read/write to TimescaleDB via PostgreSQL‑compatible SQL; the Human Machine Interface connects to the broker and database through HTTPS to Grafana."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All Docker containers (Database, MQTT broker, Grafana dashboard, Logging, Trajectory Generator, Simulator, Validation) are orchestrated with Docker Compose on a local personal computer; Python modules are pip‑installable; documentation is served via MkDocs on GitHub Pages."
]