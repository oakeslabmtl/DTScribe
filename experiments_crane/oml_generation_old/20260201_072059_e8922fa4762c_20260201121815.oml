// Sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑Angle Encoder measuring the crane’s swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance MotorStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring low‑level motor controller state"
    DTDFVocab:producedData MotorStateDataTransmitted
]

// Data transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStateSensor
]

// Data
instance SwingAngleMeasurementData : DTDFVocab:Data [
    base:desc "Measured swing angle recorded by the swing‑angle encoder"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedMeasurementData : DTDFVocab:Data [
    base:desc "Measured wind speed recorded by the anemometer"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance MotorStateLogData : DTDFVocab:Data [
    base:desc "Log of low‑level motor controller state"
    DTDFVocab:fromData MotorStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// Models
instance Fusion360CADModel : DTDFVocab:Model [
    base:desc "CAD models of the crane (Fusion360)"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler, SimulationEngineEnabler
]

instance KinematicMotionModel : DTDFVocab:Model [
    base:desc "Parametric kinematic model used by the trajectory generator"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance SimulatedSwingAngleData : DTDFVocab:Data [
    base:desc "Simulated swing angle from crane dynamics simulation"
    DTDFVocab:inputTo ContinuousValidationEnabler
]

// Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB for time‑series storage of sensor and actuator data"
    DTDFVocab:enables DataLoggingService
]

instance MosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service messaging"
    DTDFVocab:enables DataLoggingService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for kinematic trajectory generation logic"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python simulation engine for crane dynamics"
    DTDFVocab:enables SimulationService
]

instance ContinuousValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for continuous validation of measurements versus simulation"
    DTDFVocab:enables ContinuousValidationService
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for real‑time data visualization"
    DTDFVocab:enables DataVisualizationService
]

instance ControlAppEnabler : DTDFVocab:Enabler [
    base:desc "Python control application issuing motor commands via TMC4671 drivers"
    DTDFVocab:enables TrajectoryGenerationService, ContinuousValidationService
]

// Acting components
instance CartMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor driven by a TMC4671 evaluation driver"
]

instance HoistMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor driven by a TMC4671 evaluation driver"
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet used to pick up puck‑like containers"
]

// Actions
instance UpdateTrajectoryAction : DTDFVocab:Action [
    base:desc "Update cart and hoist motors with the optimal trajectory computed by the trajectory generator"
    DTDFVocab:IsAutomatic true
]

instance RunSimulationAction : DTDFVocab:Action [
    base:desc "Execute a full simulation of crane dynamics with current parameters"
    DTDFVocab:IsAutomatic false
]

instance HaltCartAction : DTDFVocab:Action [
    base:desc "Terminate cart motion when a deviation threshold is exceeded during continuous validation"
    DTDFVocab:IsAutomatic true
]

// Insights
instance DataStoredInsight : DTDFVocab:Insight [
    base:desc "Indicates that sensor and actuator state are successfully written to TimescaleDB"
]

instance VisualizationDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of measurements and confidence bounds on Grafana dashboards"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory computed that minimises swing using the kinematic model"
]

instance SimulationAccuracyInsight : DTDFVocab:Insight [
    base:desc "Assessment of simulation accuracy compared to sensor measurements"
]

instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating deviation between measured and simulated trajectories exceeds predefined thresholds"
]

// Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Data logging service captures sensor and actuator state and writes to TimescaleDB"
    DTDFVocab:provides DataStoredInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Data visualization service renders real‑time plots and confidence bounds on Grafana"
    DTDFVocab:provides VisualizationDashboardInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Trajectory generation service computes minimal‑swing paths using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight, UpdateTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service runs crane dynamics simulations and produces predicted sensor traces"
    DTDFVocab:provides SimulationAccuracyInsight, RunSimulationAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service compares measured and simulated trajectories and triggers alerts"
    DTDFVocab:provides DeviationAlertInsight, HaltCartAction
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory Generator outputs optimal motor trajectories, which are sent over MQTT to the Control Application; the Control Application forwards the motor position/speed setpoints to the Physical Crane Interface, which writes the commands to the TMC4671 drivers on the Arduino controlling the stepper motors."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in real‑time; logging occurs continuously at the rate of sensor polling (typically 10 Hz), continuous validation polls the database each update, and trajectory generation/commanding occurs on demand yet processes data with minimal latency (sub‑100 ms)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated architecture where a Python application (gantrylib) controls the physical crane via serial to Arduino and exposes MQTT topics. The twin services consume these topics, generate trajectories, simulate behavior, validate against measurements, and expose results via a Grafana panel, all coordinated through Docker Compose."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The exemplar supports holistic lifecycle coverage: design (CAD and kinematic model), manufacturing (physical crane built from BOM), operation (real‑time control and logging), as well as validation and maintenance stages, where continuous validation and fault classification are applied during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is verified by comparing logged measurements against simulated trajectories; distance metrics are calculated within the Continuous Validation service and compared to an acceptable threshold, triggering operator alerts. Validation methodologies rely on model‑based checks and time‑series classification techniques to detect faults and quantify uncertainty due to sensor noise and actuator dynamics."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical–digital coupling uses a USB serial link from PC to Arduino, which drives the stepper motors via TMC4671 drivers; inter‑service communication is over MQTT (Eclipse Mosquitto) using standard MQTT v3.1.1; data persistence occurs over PostgreSQL/TimescaleDB via SQL; dashboards connect to TimescaleDB through Grafana’s data source."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted on a local personal computer; Docker Compose brings up all containers (TimescaleDB, Mosquitto, Grafana, and the custom twin services). The Python modules run within the containers, and the system is version‑controlled via GitHub. The setup is reproducible via a single `docker compose up` command."
]