// Physical system component
instance GantryCranePhysicalSystem : DTDFVocab:Component [
    base:desc "Lab-scale gantry crane consisting of a frame, two stepper motors (cart and hoist) with TMC4671‑Eval controllers, an electromagnet, swing‑angle encoder, anemometer, Arduino with custom KiCad shield, and a PSU."
]

// Acting components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the cart along the gantry, controlled via TMC4671‑Eval controller."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist, controlled via TMC4671‑Eval controller."
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted on the hoist for picking up pucks, driven by Arduino."
]

instance TMC4671EvalControllerCart : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval motor controller for the cart motor."
]

instance TMC4671EvalControllerHoist : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval motor controller for the hoist motor."
]

// Sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder measuring hoist swing angle."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance WindAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed near the crane."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// Data transmitted from sensors
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindAnemometer
]

// Sensor data stored in TimescaleDB
instance SwingAngleTimeSeriesData : DTDFVocab:Data [
    base:desc "High‑frequency time series of swing‑angle values."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedTimeSeriesData : DTDFVocab:Data [
    base:desc "High‑frequency time series of wind‑speed measurements."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// Models
instance CADGeometryModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane used for visualization and collision checks."
    DTDFVocab:inputTo VisualizationEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the crane used to compute optimal swing‑free trajectories."
    DTDFVocab:inputTo TrajectoryProcessingEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based dynamic simulation model employed by the Simulation Service."
    DTDFVocab:inputTo SimulationEngineEnabler
]

// Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑containerized TimescaleDB storing high‑frequency sensor data."
    DTDFVocab:enables DataLoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana instance visualizing time‑series data from TimescaleDB."
    DTDFVocab:enables DashboardService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for inter‑service messaging."
    DTDFVocab:enables MqttSignallingService, ContinuousValidationService, DashboardService, TrajectoryGeneratorService, SimulationService
]

instance TrajectoryProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Python processing environment (gantrylib) that consumes the kinematic model to generate trajectories."
    DTDFVocab:enables TrajectoryGeneratorService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python simulation engine executing the dynamic simulation model."
    DTDFVocab:enables SimulationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Analytics component that compares executed trajectories with simulated ones and computes distance metrics."
    DTDFVocab:enables ContinuousValidationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Component that renders CAD geometry in the Grafana dashboard."
    DTDFVocab:enables DashboardService
]

instance DockerComposeOrchestrationEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑compose orchestration managing TimescaleDB, Grafana, MQTT broker and all service containers."
    DTDFVocab:enables DatabaseContainer, MqttBrokerContainer, DashboardContainer, TrajectoryGeneratorContainer, SimulationContainer, ContinuousValidationContainer
]

// Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuous data logging service that receives sensor streams and writes timestamped records to TimescaleDB."
    DTDFVocab:provides DataLoggingInsight
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Real‑time visualization service presenting historic motion analytics via Grafana."
    DTDFVocab:provides HistoricMotionAnalyticsInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free trajectories using the kinematic model."
    DTDFVocab:provides OptimalSwingFreeTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation service generating dynamic crane behavior."
    DTDFVocab:provides SimulationOutputInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Validates executed trajectories against simulated ones, raises alerts and triggers fault localization."
    DTDFVocab:provides RealTimeAlertInsight, FaultLocalizationAction
]

instance MqttSignallingService : DTDFVocab:Service [
    base:desc "MQTT‑based signalling service for event distribution among twin components."
    DTDFVocab:provides MqttSignalInsight
]

// Insights
instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful logging of sensor data into TimescaleDB."
]

instance HistoricMotionAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Visual analytics of historic crane motion data displayed on the dashboard."
]

instance OptimalSwingFreeTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal swing‑free trajectory recommendation for the next pick‑place operation."
]

instance SimulationOutputInsight : DTDFVocab:Insight [
    base:desc "Simulation results describing predicted crane dynamics for a given trajectory."
]

instance RealTimeAlertInsight : DTDFVocab:Insight [
    base:desc "Real‑time alert when executed trajectory deviates beyond threshold from simulated reference."
]

instance MqttSignalInsight : DTDFVocab:Insight [
    base:desc "Notification that an MQTT event has been published for downstream consumers."
]

// Actions
instance FaultLocalizationAction : DTDFVocab:Action [
    base:desc "Automated fault localization routine triggered by validation alerts."
    DTDFVocab:IsAutomatic true
]

// Data transmitted and data produced by services
instance SimulationOutputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationService
]

instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Time series of simulated crane state variables generated by Simulation Service."
    DTDFVocab:fromData SimulationOutputDataTransmitted
    DTDFVocab:inputTo VisualizationEnabler
]

instance ValidationMetricDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContinuousValidationService
]

instance ValidationMetricData : DTDFVocab:Data [
    base:desc "Distance metrics comparing executed and simulated trajectories."
    DTDFVocab:fromData ValidationMetricDataTransmitted
    DTDFVocab:inputTo ValidationEngineEnabler
]

// Physical-to-virtual interface component
instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Python‑based interface that reads controller registers and sensor values, streams them to the Logging Service via MQTT."
    base:contains SwingAngleEncoder, WindAnemometer, DataLoggingService, MQTTBrokerEnabler
]

// Containers (logical twins)
instance DatabaseContainer : DTDFVocab:Component [
    base:desc "Docker container hosting TimescaleDB."
]

instance MqttBrokerContainer : DTDFVocab:Component [
    base:desc "Docker container hosting Eclipse Mosquitto MQTT broker."
]

instance DashboardContainer : DTDFVocab:Component [
    base:desc "Docker container hosting Grafana dashboard."
]

instance TrajectoryGeneratorContainer : DTDFVocab:Component [
    base:desc "Docker container running the Trajectory Generator Service."
]

instance SimulationContainer : DTDFVocab:Component [
    base:desc "Docker container running the Simulation Service."
]

instance ContinuousValidationContainer : DTDFVocab:Component [
    base:desc "Docker container running the Continuous Validation Service."
]

// Twinning process and evolution description
instance TwinningProcess : DTDFVocab:Component [
    base:desc "Ad‑hoc open‑source development using GitHub; services added as separate Python containers; future integration with Eclipse Ditto/BaSyx and addition of a fully simulated crane for virtual commissioning."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends motion commands (position, velocity profiles) to the Physical Crane Interface, which forwards them to the motor controllers; the Trajectory Generator Service supplies optimal, swing‑free trajectories to the Control Application; validation alerts are pushed from the Continuous Validation Service to the operator via the Grafana Dashboard."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall architecture follows a C4 model: the Physical Crane interacts with a Python interface, which feeds the Logging Application, Control Application, and HMI; digital‑twin services communicate via MQTT and share state through the TimescaleDB; the Dashboard visualizes all data, completing a closed‑loop twin ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans design (CAD models of the crane in Autodesk Fusion 360 and a kinematic model), manufacturing (the physical crane assembled from the BOM), and operation (runtime data acquisition, simulation, validation, and visualization)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously computes distance metrics between measured trajectories and simulated counterparts, compares them against a predefined threshold, and triggers operator notifications when the threshold is exceeded; trajectory generation ensures zero residual swing, providing a fidelity check on motion planning."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange uses MQTT (Eclipse Mosquitto) for event signalling, HTTPS/SQL connections to TimescaleDB for time‑series storage, and a serial/USB link from the Python Physical Crane Interface to the Arduino‑based sensor/actuator controllers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software components run on a single personal computer; the Database, MQTT broker, and Grafana Dashboard are Docker‑containerized and launched via a docker‑compose command; the gantrylib Python module provides the remaining services as native processes."
]