// ----------------------------------------------------
// C3: Physical sensing components
// ----------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder that measures the crane’s pendulum swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer that records ambient wind speed affecting crane dynamics"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// ----------------------------------------------------
// C4: Physical‑to‑virtual interaction (Data transmitted)
// ----------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

// ----------------------------------------------------
// C10: Data (aggregated sensor data)
// ----------------------------------------------------
instance CraneSensorData : DTDFVocab:Data [
    base:desc "Aggregated real‑time sensor data (swing angle + wind speed) streamed from the physical crane"
    DTDFVocab:fromData SwingAngleDataTransmitted, WindSpeedDataTransmitted
    DTDFVocab:inputTo SimulationEngineEnabler, ControlAlgorithmEnabler, DataLoggingEnabler
]

instance CraneHistoricalData : DTDFVocab:Data [
    base:desc "Historical record of sensor readings stored for later analysis"
    DTDFVocab:fromData SwingAngleDataTransmitted, WindSpeedDataTransmitted
    DTDFVocab:inputTo DataLoggingEnabler
]

// ----------------------------------------------------
// C10: Models (geometric & kinematic)
// ----------------------------------------------------
instance GantryCraneCADModel : DTDFVocab:Model [
    base:desc "Geometric CAD model of the lab‑scale gantry crane (freely available open‑source CAD files)"
    DTDFVocab:inputTo SimulationEngineEnabler, ControlAlgorithmEnabler, VisualizationDashboardEnabler
]

instance GantryCraneKinematicModel : DTDFVocab:Model [
    base:desc "Analytical kinematic model capturing the motion dynamics of the crane"
    DTDFVocab:inputTo SimulationEngineEnabler, ControlAlgorithmEnabler
]

// ----------------------------------------------------
// C2: Acting components
// ----------------------------------------------------
instance CraneDriveActuator : DTDFVocab:ActingComponent [
    base:desc "Drive mechanisms (motors/actuators) that move the crane and transport payloads"
]

instance EmbeddedController : DTDFVocab:ActingComponent [
    base:desc "Embedded controller that issues motion commands to the crane actuators"
]

// ----------------------------------------------------
// C11: Enablers (open‑source software & tools)
// ----------------------------------------------------
instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source kinematic simulation library that predicts crane motion using CAD and kinematic models"
    DTDFVocab:enables ContinuousValidationService, RealTimeVisualizationService
]

instance ControlAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source optimal‑control algorithm that computes optimal trajectories for the crane"
    DTDFVocab:enables OptimalControlService, TrajectoryGeneratorService
]

instance DataLoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB based logging component that stores sensor and actuator states over time"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance VisualizationDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source visualization stack (e.g., Python plotting libraries) rendering real‑time pose, puck positions and confidence bounds"
    DTDFVocab:enables RealTimeVisualizationService
]

// ----------------------------------------------------
// C6: Services
// ----------------------------------------------------
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes optimal movement trajectories for the crane using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight, ExecuteOptimalTrajectoryAction
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Supplies optimal paths for the gantry crane based on the control algorithm"
    DTDFVocab:provides TrajectoryPathInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Records sensor and actuator states into TimescaleDB for later analysis"
    DTDFVocab:provides StoreHistoricalDataAction
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Renders real‑time crane pose, puck locations and simulation confidence bounds on a dashboard"
    DTDFVocab:provides ConfidenceBoundsInsight, AlertOnThresholdBreachAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares live sensor data against simulation predictions and alerts operators on threshold breaches"
    DTDFVocab:provides ValidationResultInsight, OperatorAlertAction
]

// ----------------------------------------------------
// C17: Insights & Actions
// ----------------------------------------------------
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Provides the optimal trajectory path for crane motion"
]

instance ExecuteOptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Command the crane actuators to follow the computed optimal trajectory"
    DTDFVocab:IsAutomatic false
]

instance TrajectoryPathInsight : DTDFVocab:Insight [
    base:desc "Details of the generated optimal path (waypoints, velocities, timings)"
]

instance StoreHistoricalDataAction : DTDFVocab:Action [
    base:desc "Persist sensor and actuator readings into the TimescaleDB database"
    DTDFVocab:IsAutomatic true
]

instance ConfidenceBoundsInsight : DTDFVocab:Insight [
    base:desc "Upper and lower confidence bounds derived from the simulation model"
]

instance AlertOnThresholdBreachAction : DTDFVocab:Action [
    base:desc "Displays a visual alert on the dashboard when observed values exceed predefined validation thresholds"
    DTDFVocab:IsAutomatic true
]

instance ValidationResultInsight : DTDFVocab:Insight [
    base:desc "Shows discrepancy between live sensor data and simulation predictions together with a confidence level"
]

instance OperatorAlertAction : DTDFVocab:Action [
    base:desc "Notifies the operator via the dashboard about a validation breach"
    DTDFVocab:IsAutomatic true
]

// ----------------------------------------------------
// C1: System Under Study (contextual component)
// ----------------------------------------------------
instance GantryCraneLabScale : DTDFVocab:Component [
    base:desc "Lab‑scale gantry crane inspired by the harbor cranes of the Port of Antwerp; includes a small gantry structure, motorised crane mechanism, controller unit and interchangeable pucks"
]

instance GantryCraneEnvironment : DTDFVocab:Environment [
    base:contains GantryCraneLabScale, SwingAngleEncoder, Anemometer, CraneDriveActuator, EmbeddedController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, a Python application, uses the Physical Crane Interface to send control commands to the crane. Trajectories generated by the Trajectory Generator Service can be supplied to the Control Application for execution. The documents do not describe command message formats, validation, authentication, conflict‑resolution, or explicit execution confirmations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The exemplar provides a continuous‑validation service that continuously compares real‑time measurements from the crane with predictions of the kinematic model to detect deviations, supporting research on validation and fault‑detection methods. The document does not enumerate quantitative fidelity metrics, uncertainty quantification, or specific verification procedures, but the presence of continuous validation indicates an ongoing verification loop between physical data and the digital model."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication within the digital twin relies on an MQTT broker for signaling between services and on direct connections to a TimescaleDB instance for data storage. The documentation does not provide details on network topology, bandwidth, latency, redundancy, or additional security protocols beyond the use of MQTT."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system is deployed on‑premise in a laboratory environment. Each functional part (Physical Crane Interface, Control Application, Logging Application, HMI, MQTT broker, TimescaleDB, Grafana dashboard, Trajectory Generator, Simulation, Continuous Validation) runs in its own container as defined by the C4 model. Storage is provided by TimescaleDB; compute resources are supplied by the host machine running the containers. No cloud or edge platform, scalability, or high‑availability mechanisms are mentioned."
]