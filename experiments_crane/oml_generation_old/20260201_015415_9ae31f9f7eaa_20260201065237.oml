// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing Angle Encoder measuring hoist swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoSensorInterface : DTDFVocab:SensingComponent [
    base:desc "Arduino‑based interface reading sensor values and motor controller states"
    DTDFVocab:producedData ArduinoStatusDataTransmitted
]

// C4: Physical‑to‑virtual interaction (Data transmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance ArduinoStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoSensorInterface
]

// C10: Data objects
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing angle measurements"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of wind speed measurements"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance ArduinoStatusData : DTDFVocab:Data [
    base:desc "Time‑series of motor positions, status flags and timestamps"
    DTDFVocab:fromData ArduinoStatusDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers (tooling & infrastructure)
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB time‑series database (PostgreSQL extension) for persistent logging"
    DTDFVocab:enables DataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for message transport"
    DTDFVocab:enables DataLoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard for visualising logged data"
    DTDFVocab:enables VisualizationDashboardService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module used by the trajectory generator"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑containerised simulation engine for crane dynamics"
    DTDFVocab:enables SimulationService
]

instance ValidationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation engine comparing measurements with simulation"
    DTDFVocab:enables ContinuousValidationService
]

instance HMIEnabler : DTDFVocab:Enabler [
    base:desc "Human‑Machine Interface (web UI) for operator control"
    DTDFVocab:enables HumanMachineInterfaceService
]

// C6: Services (logical service containers)
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that streams sensor measurements into TimescaleDB via MQTT"
    DTDFVocab:provides StoreSensorDataAction
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualising real‑time crane state and simulation results"
    DTDFVocab:provides OperatorVisualizationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service that generates optimal swing‑free motion plans using the kinematic model"
    DTDFVocab:provides GenerateOptimalTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs a physics‑based crane simulation for validation and training"
    DTDFVocab:provides RunCraneSimulationAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that continuously validates live data against simulation, emitting alerts on excess deviation"
    DTDFVocab:provides TrajectoryDeviationAlertInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Web‑based HMI allowing operators to issue commands and view alerts"
    DTDFVocab:provides OperatorControlCommandAction
]

// C17: Insights
instance TrajectoryDeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Real‑time alert when trajectory deviation exceeds predefined thresholds"
]

instance OperatorVisualizationInsight : DTDFVocab:Insight [
    base:desc "Dashboard visualisations guiding operator decisions based on live data and simulation"
]

// C17: Actions
instance StoreSensorDataAction : DTDFVocab:Action [
    base:desc "Automatically store incoming sensor measurements into TimescaleDB"
    DTDFVocab:IsAutomatic true
]

instance GenerateOptimalTrajectoryAction : DTDFVocab:Action [
    base:desc "Compute an optimal, swing‑free motion plan for the crane"
    DTDFVocab:IsAutomatic true
]

instance RunCraneSimulationAction : DTDFVocab:Action [
    base:desc "Execute the crane simulation model with current command inputs"
    DTDFVocab:IsAutomatic true
]

instance OperatorControlCommandAction : DTDFVocab:Action [
    base:desc "Operator issues movement or electromagnet activation commands via the HMI"
    DTDFVocab:IsAutomatic false
]

// C10: Models / Data artifacts
instance CADCraneModel : DTDFVocab:Model [
    base:desc "CAD model of the gantry crane used for visualisation"
    DTDFVocab:inputTo GrafanaEnabler
]

instance KinematicCraneModel : DTDFVocab:Model [
    base:desc "Kinematic model employed by the trajectory generator"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance SimulationCraneModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model of the crane and its controllers"
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance ValidationMetricModel : DTDFVocab:Model [
    base:desc "Model computing distance‑metric for validation between measurements and simulation"
    DTDFVocab:inputTo ValidationEngineEnabler
]

// C2: Acting components
instance CartStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor driven by a TMC4671‑Eval controller"
]

instance HoistStepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor driven by a TMC4671‑Eval controller"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet mounted at the hoist, controlled via Arduino"
]

instance ArduinoActuatorBoard : DTDFVocab:ActingComponent [
    base:desc "Arduino board that drives the electromagnet and motor controllers"
]

instance PSUPowerSupply : DTDFVocab:ActingComponent [
    base:desc "Power supply unit providing electricity to all electronics"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (Python) sends motion commands and trajectory set‑points to the Physical Crane Interface, which forwards them to the motor controllers and electromagnet; the Trajectory Generator Service provides optimal trajectory commands, and the Continuous Validation Service can trigger operator alerts through the dashboard."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous (real‑time) data streaming and validation; logging occurs continuously while the crane operates, and services such as trajectory generation and validation run synchronously with the physical process."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical crane ↔ Python Interface ↔ Control/Logging Applications ↔ MQTT broker ↔ Services (Trajectory Generator, Simulation, Continuous Validation) ↔ TimescaleDB ↔ Grafana dashboard; all services run on a single PC with Docker‑containerised database, broker and dashboard, coordinated via Docker‑compose."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the design stage (CAD models in Autodesk Fusion360 and kinematic model), the manufacture/assembly stage (physical crane components), and the operation stage (real‑time sensor data, control commands, and validation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service computes distance metrics between measured trajectories and simulated ones, compares them against predefined thresholds, and alerts operators; model validation methods from prior work are reused to ensure twin fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT (Eclipse Mosquitto) for lightweight signalling between services; Python interface communicates with motor controllers (likely via serial/USB); TimescaleDB accessed over TCP/IP using standard PostgreSQL SQL queries."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software runs on a personal computer; Docker containers host the TimescaleDB, MQTT broker and Grafana dashboard; the gantrylib module is installed via pip; deployment automated with a Docker‑compose file; source code and documentation hosted publicly on GitHub under an MIT license."
]