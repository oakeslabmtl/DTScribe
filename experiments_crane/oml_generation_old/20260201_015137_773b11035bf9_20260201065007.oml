// ----------------------------------------------------
// Physical Sensing Components (C3)
// ----------------------------------------------------
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder that measures hoist swing angle on the lab‑scale gantry crane."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Wind speed sensor measuring ambient wind for the crane environment."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoBoard : DTDFVocab:SensingComponent [
    base:desc "Arduino board that reads the swing‑angle encoder, anemometer and motor controller states, reporting sensor and motor state information."
    DTDFVocab:producedData MotorStateDataTransmitted
]

// ----------------------------------------------------
// Data Transmitted (C4)
// ----------------------------------------------------
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance MotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoBoard
]

// ----------------------------------------------------
// Data (C10)
// ----------------------------------------------------
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series swing‑angle measurements."
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series wind‑speed measurements."
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance MotorStateData : DTDFVocab:Data [
    base:desc "Time‑series motor state information (position, speed, current) reported by the Arduino."
    DTDFVocab:fromData MotorStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

// ----------------------------------------------------
// Enablers (C11)
// ----------------------------------------------------
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL‑based time‑series database) storing logged sensor and motor data."
    DTDFVocab:enables DataLoggingService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for real‑time data streaming between components."
    DTDFVocab:enables RealTimeVisualizationService, TrajectoryGenerationService, PhysicsSimulationService, ContinuousValidationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard that visualises time‑series data from TimescaleDB."
    DTDFVocab:enables RealTimeVisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module (installed via pip) that implements the kinematic model for optimal trajectory generation."
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Physics‑based simulation engine that uses the kinematic model to predict crane motion."
    DTDFVocab:enables PhysicsSimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation component that compares executed trajectories with simulated ones and raises alerts."
    DTDFVocab:enables ContinuousValidationService
]

// ----------------------------------------------------
// Services (C6)
// ----------------------------------------------------
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Continuously logs sensor and motor data into TimescaleDB via MQTT."
    DTDFVocab:provides DataLoggingInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides live visualisation of crane performance using Grafana dashboards."
    DTDFVocab:provides VisualizationInsight, AdjustParameterAction
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Generates optimal motion plans using the kinematic model."
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance PhysicsSimulationService : DTDFVocab:Service [
    base:desc "Runs physics‑based simulations of planned trajectories."
    DTDFVocab:provides SimulationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously validates executed trajectories against simulation results and raises alerts on excessive deviation."
    DTDFVocab:provides ValidationAlertInsight, ManualInterventionAction
]

// ----------------------------------------------------
// Insights (C17)
// ----------------------------------------------------
instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data is successfully stored in TimescaleDB."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Live visualisation of sensor streams and crane performance in Grafana dashboards."
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal motion plan generated by the kinematic model for efficient crane movement."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Results of physics‑based simulation of planned trajectories."
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when discrepancy between simulated and executed trajectories exceeds predefined thresholds."
]

// ----------------------------------------------------
// Actions (C17)
// ----------------------------------------------------
instance AdjustParameterAction : DTDFVocab:Action [
    base:desc "Operator can adjust motion parameters based on visualisation or validation insights."
    DTDFVocab:IsAutomatic false
]

instance ManualInterventionAction : DTDFVocab:Action [
    base:desc "Operator can intervene manually to stop or modify crane motion when alerts are raised."
    DTDFVocab:IsAutomatic false
]

// ----------------------------------------------------
// Acting Components (C2)
// ----------------------------------------------------
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor that drives the horizontal cart of the gantry crane."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor that raises and lowers the hoist on the gantry crane."
]

instance CartMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval controller for the cart stepper motor."
]

instance HoistMotorController : DTDFVocab:ActingComponent [
    base:desc "Trinamic TMC4671‑Eval controller for the hoist stepper motor."
]

instance Electromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist used to pick up and release pucks."
]

// ----------------------------------------------------
// Models & Data (C10)
// ----------------------------------------------------
instance CraneCADModel : DTDFVocab:Model [
    base:desc "3‑D CAD model of the lab‑scale gantry crane created in Autodesk Fusion360."
    DTDFVocab:inputTo VisualizationInsight, SimulationInsight
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the crane used for trajectory generation and simulation."
    DTDFVocab:inputTo TrajectoryGenerationService, PhysicsSimulationService
]

// ----------------------------------------------------
// Environment & Components (C17)
// ----------------------------------------------------
instance GantryCraneStructure : DTDFVocab:Component [
    base:desc "Physical frame of the lab‑scale gantry crane supporting cart, hoist and sensors."
]

instance LabCraneEnvironment : DTDFVocab:Environment [
    base:contains GantryCraneStructure, CartStepperMotor, HoistStepperMotor, CartMotorController, HoistMotorController, Electromagnet, SwingAngleEncoder, Anemometer, ArduinoBoard
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital twin services (e.g., the Trajectory Generator Service) send motion commands to the Physical Crane Interface, which forwards them to the Control Application and ultimately to the motor controllers over the same Python‑based communication channel, enabling the DT to command cart and hoist motions and activate the electromagnet."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall constellation consists of the physical crane with its controllers and Arduino, a Python‑based interface layer, a set of Docker‑containerised services (DB, MQTT broker, dashboard, trajectory generator, simulator, continuous validation), and a human‑machine interface front‑end. Communication flows via MQTT and SQL, forming a tightly coupled cyber‑physical system."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated trajectories, computes distance metrics, and checks them against predefined thresholds; violations trigger operator notifications via the dashboard, providing runtime fidelity assessment of the digital twin models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑component communication relies on MQTT (Eclipse Mosquitto) for signaling and command exchange, and SQL (PostgreSQL) connections for data persistence in TimescaleDB. The Physical Crane Interface uses a Python program to communicate with Arduino and motor controllers over serial/USB links."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital twin services (database, MQTT broker, dashboard) are Docker‑containerised and deployed on a personal computer using a provided docker‑compose file. The Python modules and applications run directly on the host OS and are installed via pip."
]