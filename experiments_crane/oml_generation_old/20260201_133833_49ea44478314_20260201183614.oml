    base:desc "Embedded temperature sensor for greenhouse monitoring with real-time data collection (1Hz-10Hz sampling)"
]

instance GreenhouseHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded humidity sensor for greenhouse environmental monitoring with real-time data collection"
]

instance GreenhouseCO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Embedded CO₂ sensor for greenhouse air quality monitoring with real-time data collection"
]

instance AirQualityCO2SensorArray : DTDFVocab:SensingComponent [
    base:desc "Raspberry-Pi based sensor array for CO₂, temperature, and humidity monitoring in construction environments (±1-5% precision)"
]

instance AirQualityParticleCounter : DTDFVocab:SensingComponent [
    base:desc "Sensor array component for particle counting in air quality monitoring"
]

instance AirQualityVirusSpreadIndicator : DTDFVocab:SensingComponent [
    base:desc "Predictive algorithm component for virus spread indicators using Azure tools"
]

instance RaspberryPiSensorNode : DTDFVocab:SensingComponent [
    base:desc "Raspberry Pi platform hosting sensor arrays for indoor air quality monitoring with Wi-Fi/Bluetooth connectivity"
]

// C4: Data transmission components
instance GreenhouseTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseTemperatureSensor
]

instance GreenhouseHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseHumiditySensor
]

instance GreenhouseCO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseCO2Sensor
]

instance AirQualityCO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityCO2SensorArray
]

instance AirQualityParticleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityParticleCounter
]

instance AirQualitySensorNetworkData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RaspberryPiSensorNode
]

instance VirusSpreadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityVirusSpreadIndicator
]

instance GreenhouseInfluxDBDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseTemperatureDataTransmitted,
        GreenhouseHumidityDataTransmitted,
        GreenhouseCO2DataTransmitted
]

instance AirQualityAzureDataPipeline : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityCO2DataTransmitted,
        AirQualityParticleDataTransmitted,
        AirQualitySensorNetworkData,
        VirusSpreadDataTransmitted
]

// C5: Data storage components
instance GreenhouseTimeSeriesData : DTDFVocab:Data [
    base:desc "Time-series storage of greenhouse environmental parameters (temperature, humidity, CO₂) in InfluxDB with 1Hz-10Hz sampling"
    DTDFVocab:fromData GreenhouseInfluxDBDataStream
    DTDFVocab:inputTo InfluxDBDatabase
]

instance AirQualityCloudProcessedData : DTDFVocab:Data [
    base:desc "Processed air quality data from Azure pipelines with standardized AutomationML format"
    DTDFVocab:fromData AirQualityAzureDataPipeline
    DTDFVocab:inputTo AzureDataStorage
]

instance ActiveMQMessageBrokerData : DTDFVocab:Data [
    base:desc "Real-time message synchronization data between physical greenhouse and digital twin via ActiveMQ"
    DTDFVocab:fromData GreenhouseInfluxDBDataStream
    DTDFVocab:inputTo ActiveMQBroker
]

// C10: Models/Data - Behavioral Models
instance GreenhouseAdaptiveBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model for adaptive greenhouse climate control responses to real-time sensor inputs"
    DTDFVocab:inputTo RuleBasedController
]

instance AirQualityAutomationMLModel : DTDFVocab:Model [
    base:desc "AutomationML-based digital twin model for standardized air quality management exchange"
    DTDFVocab:inputTo AutomationMLStandardization
]

instance AirQualityRuntimeVisualizationModel : DTDFVocab:Model [
    base:desc "Runtime visualization model for indoor air quality simulation and prediction"
    DTDFVocab:inputTo AzureDataProcessing
]

// C11: Enablers
instance RuleBasedController : DTDFVocab:Enabler [
    base:desc "Rule-based controller implementing adaptive behavior for greenhouse climate control via VM workflows"
    DTDFVocab:enables GreenhouseAdaptiveBehaviorModel
]

instance AutomationMLStandardization : DTDFVocab:Enabler [
    base:desc "AutomationML framework for standardized model exchange between physical sensors and digital air quality models"
    DTDFVocab:enables AirQualityAutomationMLModel
]

instance AzureDataProcessing : DTDFVocab:Enabler [
    base:desc "Microsoft Azure tools for processing and orchestrating air quality data via Azure pipelines"
    DTDFVocab:enables AirQualityRuntimeVisualizationModel
]

instance ActiveMQBroker : DTDFVocab:Enabler [
    base:desc "ActiveMQ message broker for real-time synchronization between physical greenhouse sensors and digital twin components"
    DTDFVocab:enables ActiveMQMessageBrokerData
]

instance InfluxDBDatabase : DTDFVocab:Enabler [
    base:desc "InfluxDB time-series database for storing greenhouse environmental data with high-resolution timestamps"
    DTDFVocab:enables GreenhouseTimeSeriesData
]

instance AzureDataStorage : DTDFVocab:Enabler [
    base:desc "Azure cloud storage for processed air quality data with AutomationML interoperability"
    DTDFVocab:enables AirQualityCloudProcessedData
]

instance ContainerizedVMEnvironment : DTDFVocab:Enabler [
    base:desc "Containerized virtual machines with pre-loaded datasets for low-latency data exchange between physical and digital components"
    DTDFVocab:enables GreenhouseAdaptiveBehaviorModel,
        ActiveMQMessageBrokerData
]

// C6: Services - GreenhouseDT
instance GreenhouseRealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring service visualizing greenhouse time-series data (temperature, humidity) via InfluxDB for anomaly detection"
    DTDFVocab:provides GreenhouseAnomalyDetectionInsight
]

instance GreenhousePredictiveAdaptationService : DTDFVocab:Service [
    base:desc "Predictive adaptation service adjusting greenhouse parameters (ventilation) based on real-time sensor deviations"
    DTDFVocab:provides GreenhouseParameterAdjustmentAction
]

instance AirQualityVisualizationService : DTDFVocab:Service [
    base:desc "Runtime visualization service for indoor air quality simulation and virus spread prediction using Azure tools"
    DTDFVocab:provides AirQualitySimulationInsight
]

instance AirQualityDataOrchestrationService : DTDFVocab:Service [
    base:desc "Azure pipeline orchestration service for processing and distributing air quality sensor data"
    DTDFVocab:provides AirQualityDataDistributionAction
]

// C17: Insights/Actions - GreenhouseDT
instance GreenhouseAnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Real-time anomaly detection in greenhouse environmental parameters (temperature/humidity spikes) visualized via InfluxDB"
]

instance GreenhouseParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of greenhouse climate control parameters (ventilation) based on rule-based triggers"
    DTDFVocab:IsAutomatic true
]

instance AirQualitySimulationInsight : DTDFVocab:Insight [
    base:desc "Runtime visualization of air quality simulation including virus spread mitigation scenarios"
]

instance AirQualityDataDistributionAction : DTDFVocab:Action [
    base:desc "Automated distribution of processed air quality data via Azure pipelines for further analysis"
    DTDFVocab:IsAutomatic true
]

