instance AirQualitySensorDataInsight : DTDFVocab:Insight [
    base:desc "Real-time air quality sensor data visualization including CO₂, temperature, humidity, and particle counts"
]

instance VirusSpreadMitigationInsight : DTDFVocab:Insight [
    base:desc "Predictive visualization of virus spread patterns in construction environments using Azure tools"
]

// C1: Environment
instance GreenhouseEnvironment : DTDFVocab:Environment [
    base:contains GreenhouseTemperatureSensor,
        GreenhouseHumiditySensor,
        GreenhouseCO2Sensor,
        GreenhouseClimateControlActuator,
