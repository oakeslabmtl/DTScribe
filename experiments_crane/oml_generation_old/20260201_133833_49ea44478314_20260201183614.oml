    base:desc "Automated greenhouse climate control system for temperature/humidity regulation via embedded systems"
]

instance AirQualityVentilationActuator : DTDFVocab:ActingComponent [
    base:desc "Central control hub for ventilation systems and air purification in construction environments using Raspberry Pi"
]

