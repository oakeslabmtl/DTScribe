// C3: Physical sensing components
instance SwingAngleEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist swing"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoderSensor
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

// C10: Data
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing angle measurements"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of wind speed measurements"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C10: Models/Data (CAD, Kinematic, Simulation)
instance Fusion360CADModel : DTDFVocab:Model [
    base:desc "CAD models of the crane (Autodesk Fusion360)"
    DTDFVocab:inputTo DockerComposeEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator"
    DTDFVocab:inputTo DockerComposeEnabler
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulation model of the crane and its controllers used by the Simulation Service"
    DTDFVocab:inputTo DockerComposeEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB PostgreSQL extension for time‑series storage"
    DTDFVocab:enables DataLoggingService, GrafanaDashboardService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker for streaming sensor data"
    DTDFVocab:enables ContinuousValidationService, SimulationService
]

instance DockerComposeEnabler : DTDFVocab:Enabler [
    base:desc "Docker & Docker‑Compose orchestration of containerised services"
    DTDFVocab:enables DataLoggingService, GrafanaDashboardService, TrajectoryGeneratorService, SimulationService, ContinuousValidationService, HumanMachineInterfaceService
]

instance PythonGantryLibEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module (pip‑installable) providing model and trajectory APIs"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Data logging service storing sensor streams into TimescaleDB"
    DTDFVocab:provides DataPersistedInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard for visualising crane status and historical data"
    DTDFVocab:provides CraneStatusVisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Trajectory Generator supplies optimal swing‑free trajectories"
    DTDFVocab:provides SwingFreeTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service runs kinematic and controller simulations of the crane"
    DTDFVocab:provides SimulationRuntimeInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous Validation compares measured vs simulated trajectories and raises alerts"
    DTDFVocab:provides ModelDeviationAlertInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Human‑Machine Interface lets operators view status and issue commands via HMI"
    DTDFVocab:provides OperatorDecisionAction
]

// C17: Insights
instance DataPersistedInsight : DTDFVocab:Insight [
    base:desc "Indicates that sensor data has been successfully persisted in TimescaleDB"
]

instance CraneStatusVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualisation of crane position, swing angle and wind speed"
]

instance SwingFreeTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Optimal swing‑free trajectory computed for the next pick operation"
]

instance SimulationRuntimeInsight : DTDFVocab:Insight [
    base:desc "Result of the crane simulation run (predicted positions, velocities)"
]

instance ModelDeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when measured trajectory deviates from simulated model"
]

instance OperatorDecisionAction : DTDFVocab:Action [
    base:desc "Operator manually decides on actions via the HMI"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application (or Trajectory Generator Service) sends motion commands/trajectory set‑points to the Physical Crane Interface, which translates them into controller commands for the cart and hoist motors and for the electromagnet."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical crane ↔ Physical Crane Interface ↔ Control Application ↔ Logging Application ↔ HMI on PC, while digital side consists of MQTT broker, TimescaleDB, Grafana, Trajectory Generator, Simulation, Continuous Validation; all communicate over MQTT and database, deployed on a single personal computer."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service computes distance metrics between measured trajectories and simulated trajectories, compares against a configurable threshold, and notifies operators via the dashboard when the threshold is exceeded."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses a Python‑based Physical Crane Interface over a serial/USB link to motor controllers; inter‑service communication uses MQTT (Eclipse Mosquitto) and the TimescaleDB is accessed via standard PostgreSQL TCP connections."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All software is hosted in a public GitHub repository; Docker containers (TimescaleDB, MQTT broker, Grafana) are launched with a single docker‑compose command on a personal computer; the Python modules run locally."
]