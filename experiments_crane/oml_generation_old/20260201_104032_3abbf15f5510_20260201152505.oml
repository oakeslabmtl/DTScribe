// Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measures hoist sway"
]
instance WindSpeedAnemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measures wind speed affecting crane dynamics"
]
instance CartPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution encoder tracks cart horizontal position"
]
instance HoistPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder tracks vertical hoist position"
]

// Data Transmitted
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]
instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WindSpeedAnemometer
]
instance CartPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartPositionEncoder
]
instance HoistPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistPositionEncoder
]

// Logged Data
instance SwingAngleLogData : DTDFVocab:Data [
    base:desc "Logged swing angle time‑series captured by the crane"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance WindSpeedLogData : DTDFVocab:Data [
    base:desc "Logged wind speed time‑series captured by the crane"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance CartPositionLogData : DTDFVocab:Data [
    base:desc "Logged cart horizontal position time‑series captured by the crane"
    DTDFVocab:fromData CartPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]
instance HoistPositionLogData : DTDFVocab:Data [
    base:desc "Logged hoist vertical position time‑series captured by the crane"
    DTDFVocab:fromData HoistPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB enabler for persistent time‑series storage"
    DTDFVocab:enables TimescaleDBService
]
instance MosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Mqtt broker enabler for inter‑service message passing"
    DTDFVocab:enables MosquittoBrokerService
]
instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana enabler for real‑time dashboard visualization"
    DTDFVocab:enables GrafanaDashboardService
]
instance KinematicModelEnabler : DTDFVocab:Enabler [
    base:desc "Kinematic model enabler for trajectory generation"
    DTDFVocab:enables KinematicTrajectoryService
]
instance SimulationModelEnabler : DTDFVocab:Enabler [
    base:desc "Physics‑based simulation model enabler for crane dynamics"
    DTDFVocab:enables CraneDynamicsSimulationService
]
instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation enabler comparing executed to simulated trajectories"
    DTDFVocab:enables TrajectoryValidationService
]
instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Fault detection enabler using threshold‑based distance analysis"
    DTDFVocab:enables FaultDetectionService
]
instance CraneInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Crane interface enabler for physical motor control"
    DTDFVocab:enables CraneInterfaceService
]
instance ControlAppEnabler : DTDFVocab:Enabler [
    base:desc "Control application enabler translating trajectories to motor steps"
    DTDFVocab:enables ControlAppService
]
instance LoggingAppEnabler : DTDFVocab:Enabler [
    base:desc "Logging application enabler streaming sensor data to database"
    DTDFVocab:enables LoggingAppService
]
instance HMIEnabler : DTDFVocab:Enabler [
    base:desc "Human‑Machine Interface enabler for operator interaction"
    DTDFVocab:enables HMIService
]
instance CADModelEnabler : DTDFVocab:Enabler [
    base:desc "CAD geometric model enabler for simulation reference"
    DTDFVocab:enables CADModelService
]

// Services
instance TimescaleDBService : DTDFVocab:Service [
    base:desc "TimescaleDB database service storing sensor and actuator logs"
    DTDFVocab:provides DataStorageInsight
]
instance MosquittoBrokerService : DTDFVocab:Service [
    base:desc "MQTT broker service handling real‑time message passing"
    DTDFVocab:provides MessageBrokerInsight
]
instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard service visualizing crane performance metrics"
    DTDFVocab:provides DashboardVisualizationInsight
]
instance KinematicTrajectoryService : DTDFVocab:Service [
    base:desc "Trajectory generation service computing optimal paths from kinematic model"
    DTDFVocab:provides TrajectoryGenerationInsight
]
instance CraneDynamicsSimulationService : DTDFVocab:Service [
    base:desc "Offline simulation service predicting crane dynamics with physics model"
    DTDFVocab:provides SimulationInsight
]
instance TrajectoryValidationService : DTDFVocab:Service [
    base:desc "Validation service comparing executed trajectories to simulated ones"
    DTDFVocab:provides ValidationInsight
]
instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection service identifying anomalies via threshold metrics"
    DTDFVocab:provides FaultDetectionInsight
]
instance CraneInterfaceService : DTDFVocab:Service [
    base:desc "Physical crane interface service translating commands to motor steps"
    DTDFVocab:provides InterfaceOperationInsight
]
instance ControlAppService : DTDFVocab:Service [
    base:desc "Control application service generating motor step pulses from trajectories"
    DTDFVocab:provides ControlCommandInsight
]
instance LoggingAppService : DTDFVocab:Service [
    base:desc "Logging application service streaming sensor data to TimescaleDB"
    DTDFVocab:provides LoggingInsight
]
instance HMIService : DTDFVocab:Service [
    base:desc "Human‑Machine Interface service providing operator controls"
    DTDFVocab:provides HMIVisualizationInsight
]
instance CADModelService : DTDFVocab:Service [
    base:desc "CAD model service hosting geometric data for simulations"
    DTDFVocab:provides CADInsight
]

// Models
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "CAD geometric model of the gantry crane generated in Fusion 360"
    DTDFVocab:inputTo CADModelEnabler
]
instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used for optimal trajectory computation"
    DTDFVocab:inputTo KinematicModelEnabler
]
instance PhysicsBasedSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model for crane dynamics prediction"
    DTDFVocab:inputTo SimulationModelEnabler
]

// Insights
instance DataStorageInsight : DTDFVocab:Insight [
    base:desc "Persistent data stored in TimescaleDB"
]
instance MessageBrokerInsight : DTDFVocab:Insight [
    base:desc "MQTT broker handling inter‑service messages"
]
instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Grafana dashboards visualizing real‑time crane metrics"
]
instance TrajectoryGenerationInsight : DTDFVocab:Insight [
    base:desc "Optimal trajectory plan computed by the kinematic model"
]
instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Offline simulation results of crane dynamics"
]
instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Comparison of executed trajectories to simulated ones for continuous validation"
]
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection using threshold‑based distance metrics"
]
instance InterfaceOperationInsight : DTDFVocab:Insight [
    base:desc "Operability status of the physical crane interface"
]
instance ControlCommandInsight : DTDFVocab:Insight [
    base:desc "Motor step pulse commands generated by the Control Application"
]
instance LoggingInsight : DTDFVocab:Insight [
    base:desc "Logging of sensor data streams to TimescaleDB"
]
instance HMIVisualizationInsight : DTDFVocab:Insight [
    base:desc "Operator interaction via Human‑Machine Interface"
]
instance CADInsight : DTDFVocab:Insight [
    base:desc "CAD geometric model data loaded for simulation reference"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control Application publishes motion commands (e.g., desired cart/hoist trajectories) to the Physical Crane Interface via MQTT or direct API calls; the Trajectory Generator Service produces optimal swing‑free trajectories that are sent to the Control Application for execution."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates in near real‑time, with sensor loops at roughly 10 Hz. Trajectory generation, simulation, and validation run on each command cycle or per trajectory event, typically within milliseconds to reach to tens of milliseconds. Data logging and visualization are instantaneously reflected in Grafana; alerting is immediate (within one processing cycle)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is orchestrated via Docker Compose: ten containers (Database, MQTT Broker, Dashboard, Trajectory Generator, Simulation, Continuous Validation, Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface) interconnected through the Docker network; physical side uses a Python interface to the Arduino‑based controller."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Designed phase – CAD models (Autodesk Fusion 360) and kinematic model; Manufactured phase – physical assembly of crane components; Operated phase – live logging, simulation and continuous validation during crane operation; the DT encompasses all three phases by mirroring the physical counterpart at each lifecycle stage."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service computes distance metrics between measured and simulated trajectories, comparing to an acceptable threshold; deviations trigger dashboard notifications; the kinematic model is validated against CAD geometry; all models are open‑source for peer verification."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical → Digital: UART/USB serial communication between Arduino controller and PC Python interface, with data packaged and written to TimescaleDB; Digital → Physical: MQTT topics (published by DT services) consumed by Control Application; internal DT services communicate via Docker networking; timeseries queries use PostgreSQL protocol."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT services are containerized and deployed locally on a personal computer via Docker Compose; the entire stack is hosted in a public GitHub repository with open‑source licensing (MIT)."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not documented; the exemplar focuses on a stand‑alone system without external DT or enterprise integration."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not documented; no explicit statement on data ownership or privacy policies."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Not explicitly referenced. The tools used (Docker, MQTT, TimescaleDB, Grafana, Python) are open standards but the crane model does not adhere to any industrial digital‑twin standard such as Eclipse Ditto or Basyx."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Not explicitly documented; the system is locally deployed, but no mention of remote execution safety or cybersecurity measures beyond standard MQTT broker usage."
]