//=== Sensing Components (Physical) ===
instance EncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoders on rotary joints providing joint position measurements."
    DTDFVocab:producedData EncoderDataTransmission
]
instance LoadCellSensor : DTDFVocab:SensingComponent [
    base:desc "Load cells on the crane carriage measuring payload weight."
    DTDFVocab:producedData LoadCellDataTransmission
]
instance AirQualitySensorArray : DTDFVocab:SensingComponent [
    base:desc "Raspberry‑Pi based sensor array collecting ambient air quality, temperature and humidity data."
    DTDFVocab:producedData AirQualityDataTransmission
]
instance GreenhouseAirSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensors in the greenhouse collecting air temperature, humidity and CO₂ concentrations."
    DTDFVocab:producedData GreenhouseAirDataTransmission
]

//=== Data Transmitted (Physical → Virtual) ===
instance EncoderDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderSensor
]
instance LoadCellDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadCellSensor
]
instance AirQualityDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualitySensorArray
]
instance GreenhouseAirDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GreenhouseAirSensor
]

//=== Data (Persistent / Virtual) ===
instance EncoderData : DTDFVocab:Data [
    base:desc "Time‑stamped encoder readings capturing joint positions."
    DTDFVocab:fromData EncoderDataTransmission
]
instance LoadCellData : DTDFVocab:Data [
    base:desc "Time‑stamped load cell readings capturing payload weight."
    DTDFVocab:fromData LoadCellDataTransmission
]
instance AirQualityData : DTDFVocab:Data [
    base:desc "Stream of ambient air quality, temperature, and humidity measurements."
    DTDFVocab:fromData AirQualityDataTransmission
]
instance GreenhouseAirData : DTDFVocab:Data [
    base:desc "Environmental data collected from greenhouse sensors."
    DTDFVocab:fromData GreenhouseAirDataTransmission
]
instance InfluxDBTimeSeriesData : DTDFVocab:Data [
    base:desc "Pre‑recorded greenhouse data stored in InfluxDB time‑series database."
    DTDFVocab:fromData GreenhouseAirData
]

//=== Enablers ===
// Physical state logging
instance LoggingApplication : DTDFVocab:Enabler [
    base:desc "Python application that reads crane state via Physical Crane Interface and writes state records to TimescaleDB."
    DTDFVocab:inputTo EncoderData, LoadCellData
    DTDFVocab:enables HistoricalDataLoggingService
]
instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "TimescaleDB database storing crane state records via PostgreSQL operations."
    DTDFVocab:inputTo LoggingApplication
    DTDFVocab:enables InteractiveDataVisualizationService
]
// Greenhouse simulation
instance InfluxDB : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database storing pre‑recorded greenhouse data."
    DTDFVocab:inputTo InfluxDBTimeSeriesData
    DTDFVocab:enables SimulationService
]
// Azure IoT pipeline
instance AzureIoTHub : DTDFVocab:Enabler [
    base:desc "Azure IoT Hub receives MQTT messages from Raspberry‑Pi sensor array."
    DTDFVocab:inputTo AirQualityData
    DTDFVocab:enables AzureStreamAnalytics, AzureMachineLearning
]
instance AzureStreamAnalytics : DTDFVocab:Enabler [
    base:desc "Azure Stream Analytics processes live data from Azure IoT Hub."
    DTDFVocab:inputTo AzureIoTHub
    DTDFVocab:enables AzureDigitalTwinService
]
instance AzureMachineLearning : DTDFVocab:Enabler [
    base:desc "Azure Machine Learning extrapolates future indoor air quality under varying scenarios."
    DTDFVocab:inputTo AzureIoTHub
    DTDFVocab:enables PredictiveAnalyticsService
]
// Virtual twin core
instance VirtualTwinEnabler : DTDFVocab:Enabler [
    base:desc "Virtual twin core that integrates sensor data for monitoring, control, and validation."
    DTDFVocab:inputTo EncoderData, LoadCellData, AirQualityData
    DTDFVocab:enables RealTimeMonitoringService, OptimalControlService, ContinuousValidationService
]

//=== Services ===
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Archives time‑stamped sensor measurements for trend and fault analysis."
    DTDFVocab:provides DataLogInsight
]
instance InteractiveDataVisualizationService : DTDFVocab:Service [
    base:desc "Interactive dashboards displaying trajectory plots and error indicators."
    DTDFVocab:provides VisualizationInsight
]
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of joint positions, payload weight, and actuator currents."
    DTDFVocab:provides JointPositionInsight, PayloadWeightInsight, ActuatorCurrentInsight
]
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Computes feedforward commands to minimize motion time while respecting torque limits."
    DTDFVocab:provides ControlCommandInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares measured and simulated states to detect modeling discrepancies."
    DTDFVocab:provides ValidationInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Computes predictive state trajectories by consuming InfluxDB outputs."
    DTDFVocab:provides PredictiveTrajectoryInsight
]
instance AzureDigitalTwinService : DTDFVocab:Service [
    base:desc "Azure Digital Twins maintains real‑time geometric and behavioral representation."
    DTDFVocab:provides RuntimeVisualizationInsight, PredictiveSimulationInsight
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Provides predictive analytics with quantified risk assessments for virus‑spread mitigation."
    DTDFVocab:provides RiskAssessmentInsight
]
instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Triggers decision logic when thresholds exceed, logging events and suggesting interventions."
    DTDFVocab:provides DecisionLogicAction
]

//=== Insights ===
instance DataLogInsight : DTDFVocab:Insight [
    base:desc "Log of historical sensor data used for trend analysis."
]
instance JointPositionInsight : DTDFVocab:Insight [
    base:desc "Current joint positions derived from encoder readings."
]
instance PayloadWeightInsight : DTDFVocab:Insight [
    base:desc "Current payload weight derived from load cell readings."
]
instance ActuatorCurrentInsight : DTDFVocab:Insight [
    base:desc "Actuator currents measured by embedded controller."
]
instance ControlCommandInsight : DTDFVocab:Insight [
    base:desc "Computed feedforward control commands for crane actuators."
]
instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Discrepancies identified between measured and simulated states."
]
instance PredictiveTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Predictive state trajectories generated by simulation."
]
instance RuntimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of system state in Azure Digital Twins."
]
instance PredictiveSimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation predictions shown in the digital twin."
]
instance RiskAssessmentInsight : DTDFVocab:Insight [
    base:desc "Quantified risk assessment for virus‑spread mitigation."
]
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive visualization of sensor data and system metrics."
]

//=== Actions ===
instance DecisionLogicAction : DTDFVocab:Action [
    base:desc "Automatically logs events and proposes interventions when threshold values are exceeded."
    DTDFVocab:IsAutomatic true
]

//=== Physical Components (System Under Study) ===
instance GantryCrane : DTDFVocab:Component [
    base:desc "Laboratory‑scale gantry crane comprising steel frame, linear rails, rotary joints, hoist, and embedded controller."
]
instance SteelFrame : DTDFVocab:Component [
    base:desc "Steel frame forming the structural backbone of the gantry crane."
]
instance LinearRails : DTDFVocab:Component [
    base:desc "Linear rails supporting the vertical motion of the crane."
]
instance RotaryJoint : DTDFVocab:Component [
    base:desc "Rotary joint enabling horizontal motion of the crane."
]
instance Hoist : DTDFVocab:Component [
    base:desc "Hoist mechanism for payload lift."
]
instance EmbeddedController : DTDFVocab:Component [
    base:desc "Embedded controller providing closed‑loop control for the gantry crane."
]
instance PayloadMount : DTDFVocab:Component [
    base:desc "Modular payload mounting system."
]
instance EncoderSensingUnit : DTDFVocab:Component [
    base:desc "Unit housing encoders attached to rotary joints."
]
instance LoadCellSensingUnit : DTDFVocab:Component [
    base:desc "Unit housing load cells on the crane carriage."
]
instance PhysicalCraneInterface : DTDFVocab:Component [
    base:desc "Interface that reads the crane state and distributes it to the logging application."
]
instance ActiveMQBroker : DTDFVocab:Component [
    base:desc "ActiveMQ message broker used for data streaming in the greenhouse twin."
]
instance MunicipalDashboard : DTDFVocab:Component [
    base:desc "Web‑based dashboard for real‑time visualization of air quality data."
]
instance GrafanaDashboard : DTDFVocab:Component [
    base:desc "Grafana dashboard consuming TimescaleDB for crane state visualization."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Control Application are dispatched through the Python‑based Physical Crane Interface to the crane controllers. Commands are sent as direct function calls over the interface; specific message formats, authentication, or validation steps are not described in the document. The system relies on the underlying Physical Crane Interface to handle low‑level communication protocols, while the Logging Application provides feedback by recording the resulting state for monitoring. No explicit conflict resolution logic or command execution confirmation protocol is detailed."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "GreenhouseDT employs a three-tiered architecture comprising the physical greenhouse equipped with sensors, a virtual machine-based digital twin environment, and a backend services layer. Communication between the greenhouse and the twin is mediated by an ActiveMQ message broker that handles asynchronous messaging for sensor telemetry and twin commands. Telemetry data are stored in an InfluxDB time‑series database, providing persistent, time‑ordered storage for monitoring and analysis. The digital twin logic, including its adaptation algorithms, is encapsulated within software components deployed in virtual machines, ensuring reproducibility and ease of installation via pre‑configured VM images."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Digital twin services communicate over an MQTT broker implementing the MQTT protocol, serving as the pub/sub middleware between components such as Trajectory Generator, Simulation, Validation, and Dashboard. The Physical Crane Interface connects to the crane controllers via a Python library; the specific underlying protocol (e.g., serial, Ethernet/IP) is not specified. Network topology is implicitly a local network with all services running as containers on the same host; no explicit bandwidth, latency, redundancy, or security measures are documented."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system comprises multiple Python‑based containers (Physical Crane Interface, Control Application, Logging Application, Human Machine Interface, Trajectory Generator, Simulation, Validation, Dashboard) but the deployment environment—whether on‑premises edge hardware, cloud, or hybrid—is not specified in the document. Computational, storage, scalability, and availability requirements are likewise not described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The exemplar utilizes Azure-based tools for its digital twin pipeline, indicating integration with Microsoft Azure services. Internally, data flow is orchestrated through an ActiveMQ broker and an InfluxDB database, while external interfaces are exposed via standard protocols such as HTTPS for RESTful access and MQTT for device communication, as suggested by the use of Raspberry‑Pi sensor nodes and Azure tools. The system’s code is hosted on GitHub, enabling source‑level integration and version control interoperability."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplar implements an AutomationML‑based digital twin model, leveraging the AutomationML specification to encode plant and component hierarchy, process data, and enable interoperability with other PLM and manufacturing systems. It also adheres to common IoT communication standards: sensor data is published over MQTT via ActiveMQ, and data ingestion into Azure utilizes the Azure IoT Hub interface, which supports industry‑standard protocols such as AMQP and HTTPS. No explicit certifications or regulatory compliance frameworks are reported."
]