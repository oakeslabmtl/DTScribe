// C3: Physical sensing components
instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the crane’s position"
    DTDFVocab:producedData PositionDataTx
]
instance SpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the crane’s speed"
    DTDFVocab:producedData SpeedDataTx
]
instance LoadSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures the load mass"
    DTDFVocab:producedData LoadDataTx
]
instance StatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that reports the crane’s operational status"
    DTDFVocab:producedData StatusDataTx
]

// C4: Physical‑to‑virtual interaction
instance PositionDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]
instance SpeedDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SpeedSensor
]
instance LoadDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadSensor
]
instance StatusDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StatusSensor
]

// C10: Models/Data
instance PositionData : DTDFVocab:Data [
    base:desc "Time‑series data stream of crane position"
    DTDFVocab:fromData PositionDataTx
    DTDFVocab:inputTo TimescaleDBEnabler, PythonDataInterfaceEnabler
]
instance SpeedData : DTDFVocab:Data [
    base:desc "Time‑series data stream of crane speed"
    DTDFVocab:fromData SpeedDataTx
    DTDFVocab:inputTo TimescaleDBEnabler, PythonDataInterfaceEnabler
]
instance LoadData : DTDFVocab:Data [
    base:desc "Time‑series data stream of crane load"
    DTDFVocab:fromData LoadDataTx
    DTDFVocab:inputTo TimescaleDBEnabler, PythonDataInterfaceEnabler
]
instance StatusData : DTDFVocab:Data [
    base:desc "Time‑series data stream of crane operational status"
    DTDFVocab:fromData StatusDataTx
    DTDFVocab:inputTo TimescaleDBEnabler, PythonDataInterfaceEnabler
]
instance KinematicModel : DTDFVocab:Model [
    base:desc "Composite kinematic model computing forward and inverse kinematics of the gantry crane"
    DTDFVocab:inputTo KinematicModellingFrameworkEnabler
]
instance DynamicModel : DTDFVocab:Model [
    base:desc "Dynamic model simulating the motion dynamics of the crane"
    DTDFVocab:inputTo KinematicModellingFrameworkEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database for storing continuous state data"
    DTDFVocab:enables HistoricalDataLoggingService
]
instance PythonDataInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Python‑based interface that reads state data over local network"
    DTDFVocab:enables RealTimeMonitoringService
]
instance TCPIPCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "TCP/IP protocol stack for communication between physical controller and twin"
    DTDFVocab:enables OptimalControlService
]
instance CADToolEnabler : DTDFVocab:Enabler [
    base:desc "CAD software used to generate accurate geometric representation of the crane"
    DTDFVocab:enables KinematicModelGenerationService
]
instance KinematicModellingFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source kinematic modelling framework deriving kinematic states"
    DTDFVocab:enables KinematicCalculationService
]
instance ScriptingLibraryEnabler : DTDFVocab:Enabler [
    base:desc "Scripting libraries for data visualization and validation"
    DTDFVocab:enables DataVisualizationDashboardService, ContinuousValidationService
]

// C6: Services
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that logs historical data for post‑processing and analysis"
    DTDFVocab:provides HistoricalDataInsight
]
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors crane’s pose and load in real‑time"
    DTDFVocab:provides CranePoseLoadInsight
]
instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service that computes actuator commands to improve efficiency or reduce motion time"
    DTDFVocab:provides ComputeActuatorCommandsAction
]
instance DataVisualizationDashboardService : DTDFVocab:Service [
    base:desc "Dashboard service that displays kinematic states and performance metrics"
    DTDFVocab:provides KinematicStatesInsight, PerformanceMetricsInsight
]
instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that validates simulated and measured behavior to detect drift or faults"
    DTDFVocab:provides DetectDriftFaultAction
]
instance KinematicCalculationService : DTDFVocab:Service [
    base:desc "Service that calculates kinematic states of the crane"
    DTDFVocab:provides KinematicStateInsight
]
instance KinematicModelGenerationService : DTDFVocab:Service [
    base:desc "Service that generates a kinematic model from the CAD representation"
    DTDFVocab:provides CADModelInsight
]

// C17: Insights / Actions
instance CranePoseLoadInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into crane pose and load"
]
instance ComputeActuatorCommandsAction : DTDFVocab:Action [
    base:desc "Action that computes actuator commands to improve efficiency"
    DTDFVocab:IsAutomatic true
]
instance KinematicStateInsight : DTDFVocab:Insight [
    base:desc "Insight on computed kinematic states of the crane"
]
instance KinematicStatesInsight : DTDFVocab:Insight [
    base:desc "Visualization of kinematic states via dashboard"
]
instance PerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Insight displaying performance metrics in dashboards"
]
instance DetectDriftFaultAction : DTDFVocab:Action [
    base:desc "Action that detects drift or faults by validating simulated vs. measured behavior"
    DTDFVocab:IsAutomatic true
]
instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Insight derived from logged historical data for post‑processing"
]
instance CADModelInsight : DTDFVocab:Insight [
    base:desc "Insight on CAD‑derived kinematic model of the crane"
]

// Physical Components
instance GantryAssembly : DTDFVocab:Component [
    base:desc "Mechanical gantry assembly of the laboratory‑scale crane"
]
instance LinearActuator : DTDFVocab:Component [
    base:desc "Linear actuator providing the rail drive for the load carriage"
]
instance LoadCarriage : DTDFVocab:Component [
    base:desc "Load carriage that carries the payload"
]
instance CraneController : DTDFVocab:Component [
    base:desc "Controller that manages crane operations"
]

// Environment
instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains GantryAssembly, LinearActuator, LoadCarriage, CraneController,
            PositionSensor, SpeedSensor, LoadSensor, StatusSensor,
            TimescaleDBEnabler, PythonDataInterfaceEnabler, TCPIPCommunicationEnabler, 
            CADToolEnabler, KinematicModellingFrameworkEnabler, ScriptingLibraryEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control Application receives trajectory commands from the Trajectory Generator Service and sends execution commands to the Physical Crane through the Python Physical Crane Interface. The Physical Crane executes these commands via its controller hardware. Feedback from the crane is read by the Physical Crane Interface and relayed back to the Control Application for monitoring."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All services communicate over a local network; an MQTT broker is used for inter-service messaging (e.g., between Simulation Service, Continuous Validation Service, and the Dashboard). The TimescaleDB database and Grafana dashboard also connect via standard database connections (e.g., PostgreSQL wire protocol). No explicit bandwidth, latency, or topology details are provided in the document."
]