// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Cart stepper motor that drives the linear motion of the crane frame"
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Hoist stepper motor that raises and lowers the load via the rope"
]

instance TMC4671EvalControllerCart : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval motor controller for the cart stepper motor"
]

instance TMC4671EvalControllerHoist : DTDFVocab:ActingComponent [
    base:desc "TMC4671‑Eval motor controller for the hoist stepper motor"
]

instance ElectromagnetActuator : DTDFVocab:ActingComponent [
    base:desc "Electromagnet that can be switched on/off by the Arduino to grasp metal objects"
]

// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder that measures the swing angle of the load"
    DTDFVocab:producedData SwingAngleMessage
]

instance AnemometerSensor : DTDFVocab:SensingComponent [
    base:desc "Anemometer that measures wind speed around the crane"
    DTDFVocab:producedData WindSpeedMessage
]

instance MotorControllerFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Status feedback (position, current) read from the TMC4671‑Eval controllers"
    DTDFVocab:producedData MotorFeedbackMessage
]

// C4: Physical-to-virtual interaction (data transmission)
instance SwingAngleMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnemometerSensor
]

instance MotorFeedbackMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerFeedbackSensor
]

// C5: Data items derived from transmissions
instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑series of swing‑angle values"
    DTDFVocab:fromData SwingAngleMessage
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of wind‑speed measurements"
    DTDFVocab:fromData WindSpeedMessage
    DTDFVocab:inputTo TimescaleDBEnabler
]

instance MotorFeedbackData : DTDFVocab:Data [
    base:desc "Time‑series of motor position and current feedback"
    DTDFVocab:fromData MotorFeedbackMessage
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C10: Models / Data (digital twin artefacts)
instance CAD3DModel : DTDFVocab:Model [
    base:desc "3‑D CAD model of the gantry crane (Fusion360 export)"
    DTDFVocab:inputTo GantrylibEnabler
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator to compute feasible motions"
    DTDFVocab:inputTo GantrylibEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the crane and its controllers used by the Simulation Service"
    DTDFVocab:inputTo GantrylibEnabler
]

instance ContinuousValidationComparisonData : DTDFVocab:Data [
    base:desc "Historical validation comparison data used by the Continuous Validation Service"
    DTDFVocab:inputTo GantrylibEnabler
]

// C11: Enablers (software / infrastructure)
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) storing time‑series sensor data"
    DTDFVocab:enables DataLoggingService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana visualisation dashboard connected to TimescaleDB"
    DTDFVocab:enables GrafanaDashboardService
]

instance MosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker used for real‑time messaging"
    DTDFVocab:enables MQTTBrokerService
    DTDFVocab:enables HumanMachineInterfaceService
]

instance GantrylibEnabler : DTDFVocab:Enabler [
    base:desc "gantrylib Python module (installed via pip) providing APIs for trajectory generation, simulation and validation"
    DTDFVocab:enables TrajectoryGeneratorService
    DTDFVocab:enables SimulationService
    DTDFVocab:enables ContinuousValidationService
]

instance DockerComposeOrchestrationEnabler : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestration managing all containerised services"
    DTDFVocab:enables DataLoggingService
    DTDFVocab:enables GrafanaDashboardService
    DTDFVocab:enables TrajectoryGeneratorService
    DTDFVocab:enables SimulationService
    DTDFVocab:enables ContinuousValidationService
    DTDFVocab:enables HumanMachineInterfaceService
    DTDFVocab:enables MQTTBrokerService
]

// C6: Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that writes incoming sensor time‑series to the TimescaleDB database"
    DTDFVocab:provides LoggingInsight
]

instance GrafanaDashboardService : DTDFVocab:Service [
    base:desc "Grafana service visualising performance trends and diagnostic plots"
    DTDFVocab:provides PerformanceVisualizationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Kinematics‑based service that computes optimal motion plans for the crane"
    DTDFVocab:provides GenerateOptimalTrajectory
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Dynamic simulation service that evaluates crane behaviour under given trajectories"
    DTDFVocab:provides SimulationResultInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuous validation service that compares live metrics against thresholds and historical baselines"
    DTDFVocab:provides ValidationAlertInsight
    DTDFVocab:provides DiagnosticMetricInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Web‑based HMI allowing operators to monitor status and issue control commands"
    DTDFVocab:provides OperatorControlAction
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "MQTT broker service routing sensor data and control messages between components"
    DTDFVocab:provides MessagingInsight
]

// C17: Insights / Actions
instance LoggingInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data has been successfully persisted in TimescaleDB"
]

instance PerformanceVisualizationInsight : DTDFVocab:Insight [
    base:desc "Dashboard visualisations showing trends, spikes and long‑term performance of the crane"
]

instance GenerateOptimalTrajectory : DTDFVocab:Action [
    base:desc "Automatic generation of a collision‑free, energy‑optimal trajectory for a requested pick‑and‑place task"
    DTDFVocab:IsAutomatic true
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Outcome of a simulation run, including predicted load swing and motor currents"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert raised when live sensor metrics exceed predefined safety thresholds"
]

instance DiagnosticMetricInsight : DTDFVocab:Insight [
    base:desc "Diagnostic metric (e.g., RMS error, motor temperature) computed for ongoing health monitoring"
]

instance OperatorControlAction : DTDFVocab:Action [
    base:desc "Operator‑issued command to start/stop motion, engage electromagnet, or modify set‑points"
    DTDFVocab:IsAutomatic false
]

instance MessagingInsight : DTDFVocab:Insight [
    base:desc "Status indicating successful publish/subscribe of MQTT messages between components"
]

// C13: Environment (physical layout)
instance PhysicalCraneEnvironment : DTDFVocab:Environment [
    base:contains CartStepperMotor, HoistStepperMotor, TMC4671EvalControllerCart, TMC4671EvalControllerHoist, ElectromagnetActuator, SwingAngleEncoder, AnemometerSensor, MotorControllerFeedbackSensor
]

// C14: High‑level Component (Arduino board)
instance ArduinoBoard : DTDFVocab:Component [
    base:desc "Arduino board that reads sensors, drives the electromagnet and forwards data via MQTT"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Trajectory and control set‑points generated by the Trajectory Generator Service (and the Control Application) are sent over MQTT to the Physical Crane Interface, which forwards them to the motor controllers and Arduino to drive the cart, hoist and electromagnet; manual commands from the Human‑Machine Interface follow the same path."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A cyber‑physical system where the physical crane is linked via a Python interface to a set of digital services (MQTT broker, TimescaleDB, Grafana dashboard, Trajectory Generator, Simulation Service, Continuous Validation Service) and an operator HMI; all services communicate through MQTT and the shared database, forming a tightly coupled digital twin constellation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the design stage (CAD models in Autodesk Fusion360), the manufacturing/assembly stage (physical crane built from the bill‑of‑materials), and the operation stage (runtime services for control, logging, simulation and validation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares measured trajectories with simulated trajectories, computes distance metrics, checks against a predefined threshold, and raises alerts on the dashboard when the threshold is exceeded, thereby providing runtime fidelity assessment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses MQTT (Eclipse Mosquitto) for command and telemetry messages, and SQL over TCP/IP for TimescaleDB access. The Physical Crane Interface runs a Python program that connects to the motor controllers via serial/USB and publishes/subscribes to MQTT topics."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital twin components are hosted on a personal computer; Docker containers run the database, MQTT broker and Grafana dashboard, while the remaining Python services run as processes. Deployment is automated with a Docker‑compose file provided in the repository."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture is described using the C4 model (context and container diagrams) as a standardized visual notation; the digital twin uses open standards such as MQTT and SQL, but no formal industry standards are cited."
]