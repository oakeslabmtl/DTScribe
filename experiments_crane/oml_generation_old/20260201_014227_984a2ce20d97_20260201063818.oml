// C3: Physical sensing components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing Angle Encoder measuring the crane swing angle, acquired via Arduino"
    DTDFVocab:producedData CraneTelemetryDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed around the gantry crane, acquired via Arduino"
    DTDFVocab:producedData CraneTelemetryDataTransmitted
]

instance MotorControllerStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reading the motor controller states (position, current) from the TMC4671‑Eval board"
    DTDFVocab:producedData CraneTelemetryDataTransmitted
]

// C4: Data transmitted from sensors
instance CraneTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder, Anemometer, MotorControllerStateSensor
]

// C10: Data (time‑series) stored in the database
instance CraneTelemetryData : DTDFVocab:Data [
    base:desc "Time‑series data of swing angle, wind speed and motor controller states"
    DTDFVocab:fromData CraneTelemetryDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C10: Models used by services
instance CraneCADModel : DTDFVocab:Model [
    base:desc "CAD geometry of the lab‑scale gantry crane (public GitHub repository)"
    DTDFVocab:inputTo TrajectoryGeneratorService, SimulationService
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model of the crane used to compute swing‑free trajectories"
    DTDFVocab:inputTo TrajectoryGeneratorService, SimulationService
]

instance CranePhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model reproducing crane dynamics and controllers"
    DTDFVocab:inputTo SimulationService
]

// C11: Enablers (tooling & infrastructure)
instance DockerComposeOrchestration : DTDFVocab:Enabler [
    base:desc "Docker‑Compose orchestrates all containerised Python services for one‑click deployment"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService,
                  DashboardService, DataLoggingService, MQTTBrokerService, DatabaseService
]

instance PythonRuntime : DTDFVocab:Enabler [
    base:desc "Python runtime executing the Physical Crane Interface, Control, Logging, HMI and all services"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService,
                  DashboardService, DataLoggingService, MQTTBrokerService, DatabaseService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Mosquitto MQTT broker providing publish/subscribe signalling between services"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService,
                  DataLoggingService, DashboardService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB (PostgreSQL extension) storing all time‑series data for logging, simulation and validation"
    DTDFVocab:enables DatabaseService
]

instance GrafanaVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana renders dashboards from TimescaleDB and visualises alerts and trajectory traces"
    DTDFVocab:enables DashboardService
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Generates optimal swing‑free motion plans using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight, SelectTrajectoryAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs real‑time physics simulation of the crane and can replay any generated trajectory"
    DTDFVocab:provides PredictionInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Continuously compares executed trajectories with simulated ones, computes distance metrics and raises alerts"
    DTDFVocab:provides ValidationAlertInsight, AcknowledgeAlertAction, ConfigureThresholdAction
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Grafana dashboard visualising historic and live data, alerts and confidence‑bounded trajectory traces"
    DTDFVocab:provides ValidationAlertInsight
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logging Application records all crane states continuously into TimescaleDB"
    DTDFVocab:provides SelectTrajectoryAction
]

instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "Mosquitto MQTT broker handling lightweight publish/subscribe communication among services"
]

instance DatabaseService : DTDFVocab:Service [
    base:desc "TimescaleDB instance acting as the central data store for timestamps, measurements and simulation results"
]

// C17: Insights
instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight delivering optimal motion plans that guarantee zero residual swing"
]

instance ValidationAlertInsight : DTDFVocab:Insight [
    base:desc "Insight raising visual alerts on the Grafana dashboard when distance‑metric scores exceed thresholds"
]

instance PredictionInsight : DTDFVocab:Insight [
    base:desc "Insight providing ‘what‑if’ predictions of alternative trajectories displayed as confidence‑bounded traces"
]

// C17: Actions
instance SelectTrajectoryAction : DTDFVocab:Action [
    base:desc "Operator selects an optimal trajectory via the Python‑based Human‑Machine Interface"
    DTDFVocab:IsAutomatic false
]

instance AcknowledgeAlertAction : DTDFVocab:Action [
    base:desc "Operator acknowledges a validation alert on the Grafana UI"
    DTDFVocab:IsAutomatic false
]

instance ConfigureThresholdAction : DTDFVocab:Action [
    base:desc "Operator configures the distance‑metric threshold that triggers validation alerts"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Component
instance StepperMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Stepper motor driving the hoist mechanism, controlled via TMC4671‑Eval motor controller"
]

// C9: Environment containing the components
instance GantryCraneLabEnvironment : DTDFVocab:Environment [
    base:contains StepperMotorActuator, SwingAngleEncoder, Anemometer, MotorControllerStateSensor
]

// C8: Generic Components (optional)
instance PhysicalCraneInterfaceComponent : DTDFVocab:Component [
    base:desc "Python‑based Physical Crane Interface communicating with the motor controller board"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application sends movement commands to the Physical Crane Interface, which translates them into controller signals for the cart and hoist motors (Stepper motors driven by TMC4671‑Eval controllers). Commands originate from higher‑level services such as the Trajectory Generator Service (optimal trajectories) and are issued as Python API calls to the interface. Feedback from the crane (position, swing angle) is provided back to the Logging Application and Continuous Validation Service. The documents do not detail command message formats, authentication, or explicit validation before actuation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital‑twin follows a container‑based orchestration pattern modelled with the C4 approach. Six Docker containers provide the twin’s core functions: a TimescaleDB database, a Grafana dashboard, a Trajectory Generator service (kinematics model), a Simulation service, a Continuous Validation service, and an MQTT broker for signalling between services. All containers are launched together with a single Docker‑Compose command, establishing a shared network. Python applications (Physical Crane Interface, Control Application, Logging Application, Human‑Machine Interface) run in separate containers or on the host, interacting with the crane controllers and the MQTT broker. Resource management relies on Docker container isolation, while persistent time‑series data is stored in TimescaleDB and visualised through Grafana."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is achieved by using a kinematic model that generates trajectories without residual swing, and a simulation model that reproduces the crane dynamics. Validation is performed continuously by the Continuous Validation Service, which compares logged sensor measurements of executed trajectories with the simulated trajectories, computes distance metrics, and checks them against a predefined threshold. If the threshold is exceeded, the operator is notified through the Grafana dashboard. The approach reuses model validation techniques described in prior publications and is further extended with time‑series classification for fault detection, providing quantitative assurance of model correctness."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All software components run on a single personal computer. Docker containers host the TimescaleDB database, the Eclipse Mosquitto MQTT broker and the Grafana dashboard; they communicate over the host’s network via MQTT and PostgreSQL connections. The Python services (Control Application, Logging Application, Simulation Service, etc.) run directly on the host and interact with the containers locally. No specific bandwidth, latency, redundancy or security protocol specifications are provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The exemplar is deployed on‑premise on a personal computer. Docker Compose is used to start the TimescaleDB, MQTT broker and Grafana containers automatically; the Python modules are installed with pip (gantrylib). Storage is provided by the TimescaleDB container; computational resources are those of the host PC. The deployment model is a single‑node Docker‑compose setup; scalability beyond this node is not discussed. Availability is supported by Docker Compose’s start‑up scripts that initialize the database and dashboard on first run."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with other components uses standard open‑source protocols. Inter‑service communication is performed via MQTT, and data persistence/visualisation rely on TimescaleDB and Grafana accessed through their native APIs. The Python programs communicate with the physical crane’s controllers via a custom interface (not further specified). No external enterprise systems, OPC‑UA, REST, or other interoperability standards are mentioned in the documents."
]