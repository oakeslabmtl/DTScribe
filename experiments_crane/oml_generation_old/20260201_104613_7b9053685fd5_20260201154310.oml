// C3: Physical Sensing Components
instance AirQualityCarbonDioxideSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry Pi-equipped sensor for real-time CO₂ monitoring in Air Quality Management exemplar"
    DTDFVocab:producedData AirQualitySensorDataTransmitted
]

instance AirQualityParticulateMatterSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry Pi-equipped sensor for real-time particulate matter monitoring in Air Quality Management exemplar"
    DTDFVocab:producedData AirQualitySensorDataTransmitted
]

instance AirQualityHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry Pi-equipped sensor for real-time humidity monitoring in Air Quality Management exemplar"
    DTDFVocab:producedData AirQualitySensorDataTransmitted
]

instance AirQualityTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Raspberry Pi-equipped sensor for real-time temperature monitoring in Air Quality Management exemplar"
    DTDFVocab:producedData AirQualitySensorDataTransmitted
]

instance CranePositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing crane position data for real-time trajectory validation in lab-scale gantry crane system"
    DTDFVocab:producedData CraneStateDataTransmitted
]

instance CraneVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing crane velocity data for real-time trajectory validation in lab-scale gantry crane system"
    DTDFVocab:producedData CraneStateDataTransmitted
]

instance CraneAccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing crane acceleration data for real-time trajectory validation in lab-scale gantry crane system"
    DTDFVocab:producedData CraneStateDataTransmitted
]

instance CraneOperationalStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing crane operational status (e.g., controller commands, system state) for validation"
    DTDFVocab:producedData CraneStateDataTransmitted
]

instance PuckPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing puck position data for trajectory validation in lab-scale gantry crane system"
    DTDFVocab:producedData CraneStateDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance AirQualitySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualityCarbonDioxideSensor, AirQualityParticulateMatterSensor,
                          AirQualityHumiditySensor, AirQualityTemperatureSensor
]

instance CraneStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CranePositionSensor, CraneVelocitySensor, CraneAccelerationSensor,
                          CraneOperationalStatusSensor, PuckPositionSensor
]

// C10: Models/Data
instance AutomationMLAirQualityModel : DTDFVocab:Model [
    base:desc "AutomationML-based structured representation of Air Quality Management system components and behaviors"
    DTDFVocab:inputTo AutomationMLEnabler, AzureAnalyticsEnabler
]

instance BehavioralAdaptationModel : DTDFVocab:Model [
    base:desc "Behavioral adaptation model for GreenhouseDT physical and digital twin systems"
    DTDFVocab:inputTo InfluxDBEnabler, ActiveMQEnabler
]

instance KinematicCraneModel : DTDFVocab:Model [
    base:desc "Mathematical model describing gantry crane motion and dynamics for simulation and control"
    DTDFVocab:inputTo OpenSourceSimulationEnabler, ROSEnabler
]

instance TimeSeriesAirQualityData : DTDFVocab:Data [
    base:desc "Historical and real-time air quality sensor data (CO₂, particulate matter, humidity, temperature) from Raspberry Pi"
    DTDFVocab:fromData AirQualitySensorDataTransmitted
    DTDFVocab:inputTo AzureAnalyticsEnabler, InfluxDBEnabler
]

instance CraneTrajectoryData : DTDFVocab:Data [
    base:desc "Time-series data of crane movements (position, velocity, acceleration) and puck trajectories for validation"
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, MQTTBrokerEnabler
]

instance HistoricalCraneOperationsData : DTDFVocab:Data [
    base:desc "Historical operational data including sensor readings, actuator commands, and environmental conditions"
    DTDFVocab:fromData CraneStateDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler
]

// C11: Enablers
instance AutomationMLEnabler : DTDFVocab:Enabler [
    base:desc "AutomationML framework enabling modular, component-based digital twin representation for Air Quality Management"
    DTDFVocab:enables AirQualitySimulationService, AirQualityPredictionService
]

instance AzureAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Microsoft Azure tools for processing and analyzing air quality data, supporting runtime visualization and prediction"
    DTDFVocab:enables AirQualityRuntimeVisualizationService, AirQualityPredictionService
]

instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database optimized for handling high-frequency sensor data from GreenhouseDT and Air Quality Management"
    DTDFVocab:enables HistoricalDataLoggingService, ContinuousValidationService
]

instance ActiveMQEnabler : DTDFVocab:Enabler [
    base:desc "Message broker facilitating event-driven data exchange between physical and digital components in GreenhouseDT"
    DTDFVocab:enables DataVisualizationService, FaultDetectionService
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database for storing crane state data with millisecond-level precision for trajectory validation"
    DTDFVocab:enables HistoricalDataLoggingService, ContinuousValidationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Lightweight MQTT broker enabling asynchronous, decoupled communication between crane services"
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, ContinuousValidationService
]

instance OpenSourceSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Open-source simulation frameworks (e.g., Python, MATLAB) for crane operation simulation and control strategy testing"
    DTDFVocab:enables SimulationService, OptimalControlService
]

instance ROSEnabler : DTDFVocab:Enabler [
    base:desc "Robot Operating System (ROS) for implementing crane control algorithms and service deployment"
    DTDFVocab:enables OptimalControlService, FaultDetectionService
]

instance DarTwinNotationEnabler : DTDFVocab:Enabler [
    base:desc "Framework for describing system evolution and changes in digital twin, enabling adaptability"
    DTDFVocab:enables ContinuousValidationService
]

// C6: Services
instance AirQualityRuntimeVisualizationService : DTDFVocab:Service [
    base:desc "Service providing real-time visualization of indoor air quality metrics (CO₂, particulate matter, humidity)"
    DTDFVocab:provides AirQualityVisualizationInsight
]

instance AirQualitySimulationService : DTDFVocab:Service [
    base:desc "Service simulating air quality dynamics under varying conditions using AutomationML models"
    DTDFVocab:provides AirQualitySimulationInsight
]

instance AirQualityPredictionService : DTDFVocab:Service [
    base:desc "Service predicting future air quality states based on current sensor data and historical patterns"
    DTDFVocab:provides AirQualityPredictionInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service providing algorithms for optimizing crane operations (energy efficiency, motion planning, load balancing)"
    DTDFVocab:provides OptimalTrajectoryInsight, EnergyEfficiencyInsight
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service recording operational data (sensor readings, actuator commands, environmental conditions) over time"
    DTDFVocab:provides HistoricalDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service visualizing real-time and historical crane data through interactive dashboards"
    DTDFVocab:provides CranePerformanceInsight, KinematicModelVisualizationInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service validating digital twin accuracy by comparing predictions with real-world crane data"
    DTDFVocab:provides ValidationAccuracyInsight, TrajectoryDiscrepancyAlert
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service simulating crane operations for testing control strategies before deployment"
    DTDFVocab:provides SimulationValidationInsight
]

instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Service generating optimal trajectories for crane movement based on kinematic models"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service monitoring crane system for anomalies (sensor failures, actuator malfunctions) and triggering alerts"
    DTDFVocab:provides FaultDetectionAlert, SystemHealthInsight
]

