// C3: Physical sensing components
instance PositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder sensor measuring the horizontal position of the gantry rail."
    DTDFVocab:producedData CraneTelemetryTransmitted
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the velocity of the gantry carriage during operation."
    DTDFVocab:producedData CraneTelemetryTransmitted
]

instance LoadCell : DTDFVocab:SensingComponent [
    base:desc "Load cell sensor measuring the payload weight carried by the crane."
    DTDFVocab:producedData CraneTelemetryTransmitted
]

instance SwingAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Angle sensor detecting the swinging motion of the crane carriage."
    DTDFVocab:producedData CraneTelemetryTransmitted
]

// C4: Physical‑to‑virtual interaction
instance CraneTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionEncoder, VelocitySensor, LoadCell, SwingAngleSensor
]

// C10: Models/Data
instance CraneTelemetryData : DTDFVocab:Data [
    base:desc "Persisted crane telemetry records in TimescaleDB including position, velocity, load, and swinging angle."
    DTDFVocab:inputTo TimescaleDBEnabler, ValidationEnabler
    DTDFVocab:fromData CraneTelemetryTransmitted
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Open‑source kinematic model representing the Cartesian motion degrees of freedom of the lab‑scale gantry crane."
    DTDFVocab:inputTo KinematicModelEnabler, ValidationEnabler
]

// C11: Enablers
instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB database enabler for persisting crane telemetry data continuously at high cadence."
    DTDFVocab:enables MonitoringService
]

instance KinematicModelEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source kinematic library enabling real‑time simulation of crane motions for trajectory planning."
    DTDFVocab:enables TrajectoryPlanningService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Validation enabler comparing live telemetry against the kinematic model to detect deviations."
    DTDFVocab:enables ValidationService
]

instance VisualRenderingEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source 3D rendering library enabling real‑time visualization of crane state, trajectories, and validation metrics."
    DTDFVocab:enables VisualizationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Fault detection enabler using sensor data and model predictions to flag abnormal behaviour."
    DTDFVocab:enables FaultDetectionService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous logging and monitoring of crane telemetry states (position, velocity, load, swinging angle)."
    DTDFVocab:provides TelemetryInsight
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Continuous validation comparing live telemetry against the kinematic model to detect model drift or deviations."
    DTDFVocab:provides ModelDeviationInsight
]

instance TrajectoryPlanningService : DTDFVocab:Service [
    base:desc "Generates optimal motion trajectories based on the kinematic model to produce safe and efficient motion requests."
    DTDFVocab:provides MotionCommand
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults using sensed data and model predictions, providing alerts."
    DTDFVocab:provides FaultAlertInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Renders real‑time 3D and 2D visualizations of crane state, trajectories, and validation metrics."
    DTDFVocab:provides VisualizationInsight
]

// C17: Insights/Actions
instance TelemetryInsight : DTDFVocab:Insight [
    base:desc "Provides real‑time telemetry overview of crane states for monitoring."
]

instance ModelDeviationInsight : DTDFVocab:Insight [
    base:desc "Highlights deviations between live telemetry and kinematic model predictions, indicating potential model drift."
]

instance FaultAlertInsight : DTDFVocab:Insight [
    base:desc "Alerts operators to detected faults in crane operation based on data and model analysis."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Displays real‑time visual renderings of crane position, trajectories, and validation metrics."
]

instance MotionCommand : DTDFVocab:Action [
    base:desc "Automated motion command generated by trajectory planning service to request new positions from the physical controller."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the Control Application, a Python script that constructs motion plans (e.g. a trajectory from the trajectory generator) and sends them to the Physical Crane Interface. The command payload format is not defined in the documentation, but it is communicated to the hardware controller through the same Python interface used for telemetry. Validation, authentication, conflict resolution, and execution confirmation are not described in the provided material."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The GreenhouseDT exemplar adopts a centralized orchestration model where the twin logic runs inside a virtual machine environment for easy deployment. Sensor readings from the greenhouse are published to an ActiveMQ message broker, which publishes the data asynchronously to the twin services. These services then write time‑series measurements into an InfluxDB database for efficient historical analysis. Coordination between the data ingestion layer, simulation module, and behavioral adaptation controller is achieved through broker topic subscriptions, ensuring that state updates propagate instantly across the twin stack. The overall design leverages containerization within the virtual machine images, simplifying scaling and versioning of the twin components."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Service inter‑communication relies on an MQTT broker that publishes and subscribes topics for state updates, trajectory commands, and validation results. The broker enables decoupled messaging among the Logging Application, Trajectory Generator Service, Simulation Service, Continuous Validation Service, and the dashboard. The networking environment is a local area network (LAN), with message transport over TCP/IP using MQTT. Bandwidth, latency, reliability, and security provisions (e.g., TLS, authentication) are not detailed in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital‑twin components are deployed on an on‑premise edge infrastructure. The Python applications (Control, Logging, Trajectory Generator, Simulation, Validation) run locally and share a common TimescaleDB instance. Computational requirements are implied by real‑time trajectory generation and simulation, but explicit CPU/memory or storage quotas are not presented. The architecture supports a single‑node deployment with potential to scale horizontally for additional cranes, although scalability mechanisms are not discussed."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is facilitated through the Microsoft Azure cloud platform, which is employed to funnel sensor data from a Raspberry‑Pi sensor node into the Air Quality Management pipeline. The Azure ecosystem (IoT Hub, Functions, and possibly other services) orchestrates data ingestion, simulation, and prediction tasks. The digital twin itself is represented using AutomationML, a standardized XML‑based plant description format, allowing interoperability with other engineering tools and enterprise systems. External communication with the twin is performed via standard HTTP/REST interfaces and agent protocols (AMQP/JMS for ActiveMQ, HTTP line protocol for InfluxDB), ensuring compatibility with a broad range of enterprise IT infrastructures."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Air‑Quality‑Management exemplar adopts AutomationML as the digital twin model representation, aligning with the established plant engineering data‑exchange standard. The overall stack employs Microsoft Azure IoT Hub, which implements and interoperates with industrial IoT protocols such as MQTT, AMQP, and OPC UA, thereby assuring connectivity compliance with common industrial standards. Other standard compliance or certifications (e.g., ISO 23247, ISO 23246, SAE E31) are not mentioned in the provided documents."
]