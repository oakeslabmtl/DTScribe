// C3: Physical Sensing Components
instance JointAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures real-time joint angles of the gantry crane for kinematic validation and trajectory planning. Connected via serial communication to the embedded controller."
    DTDFVocab:producedData JointAngleDataTransmitted
]

instance LoadForceSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors load forces applied to the crane's hook for safety validation and control optimization. Interfaces with the crane controller via CAN bus protocol."
