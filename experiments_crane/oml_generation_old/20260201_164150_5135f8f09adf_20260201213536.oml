]

instance EnvironmentalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Records ambient temperature data for environmental condition monitoring and potential impact analysis on crane operations."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance CraneStatusMonitor : DTDFVocab:SensingComponent [
    base:desc "Continuously logs operational states including crane status, controller inputs, and system health metrics for validation and fault detection."
    DTDFVocab:producedData StatusDataTransmitted
]

// C4: Physical-to-Virtual Data Transmission
instance JointAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointAngleEncoder
]

instance LoadForceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadForceSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
