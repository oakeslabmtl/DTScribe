// C2: Acting Components (none specified for the crane)

// C3: Physical sensing components
instance GantryActuatorPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Positions of the linear and rotational axes of the lab‑scale gantry crane, obtained via encoder feedback and motor controllers"
    DTDFVocab:producedData GantryStateDataTransmitted
]

// C4: Physical‑to‑virtual interaction (data transmission)
instance GantryStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GantryActuatorPositionSensor
]

// C6: Services
instance GantryMonitoringService : DTDFVocab:Service [
    base:desc "Continuous real‑time logging of actuator positions, velocities, and payload states, accessible through time‑series visualisations"
    DTDFVocab:provides CraneMonitoringInsight
]

instance KinematicVisualizationService : DTDFVocab:Service [
    base:desc "Graphical representation of the kinematic model tied to CAD geometry, allowing users to orbit, slice, and annotate the virtual structure"
    DTDFVocab:provides VisualizationInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Algorithmic optimisation routine generating motion sequences to reach target positions while minimising energy consumption or time"
    DTDFVocab:provides OptimalControlAction
]

instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Persistent storage of logged metrics in TimescaleDB for replay and audit purposes"
    DTDFVocab:provides HistoricalDataInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Automated comparison engine that sockets real‑time measurements to the simulation model and flags deviations for fault‑detection research"
    DTDFVocab:provides ValidationInsight
]

instance FaultDetectionSupportService : DTDFVocab:Service [
    base:desc "Digital twin used as a testbed for research methods that identify anomalies in sensor streams"
    DTDFVocab:provides FaultDetectionInsight
]

// C10: Models/Data
instance GantryStateData : DTDFVocab:Data [
    base:desc "Time‑series of actuator positions, velocities, and payload states logged into TimescaleDB by the Python Logging Application"
    DTDFVocab:inputTo CraneTwinEngagementEnabler
    DTDFVocab:fromData GantryStateDataTransmitted
]

instance GantryKinematicModel : DTDFVocab:Model [
    base:desc "CAD geometry–based kinematic representation of the gantry crane"
    DTDFVocab:inputTo CraneTwinEngagementEnabler
]

instance GantrySimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of the gantry crane used for continuous validation"
    DTDFVocab:inputTo CraneTwinEngagementEnabler
]

instance OptimalControlAlgorithm : DTDFVocab:Model [
    base:desc "Optimization routine that generates motion sequences for target trajectories, prioritising minimal energy consumption or time"
    DTDFVocab:inputTo CraneTwinEngagementEnabler
]

// C11: Enablers
instance CraneTwinEngagementEnabler : DTDFVocab:Enabler [
    base:desc "Handles data ingestion from TimescaleDB and orchestrates services such as monitoring, visualization, optimisation, historical logging, validation, and fault detection"
    DTDFVocab:enables GantryMonitoringService,
                   KinematicVisualizationService,
                   OptimalControlService,
                   HistoricalDataLoggingService,
                   ContinuousValidationService,
                   FaultDetectionSupportService
]

// C17: Insights / Actions
instance CraneMonitoringInsight : DTDFVocab:Insight [
    base:desc "Provides real‑time view of actuator positions, velocities, and payload states"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Live graphical rendering of the gantry crane’s kinematic model aligned with CAD geometry"
]

instance OptimalControlAction : DTDFVocab:Action [
    base:desc "Generates motion sequence to reach specified target positions while optimizing energy consumption or drive time"
    DTDFVocab:IsAutomatic true
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Access to persisted time‑series data for replay, audit, and trend analysis"
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Compares real‑time measurements from the crane to the simulation model and flags deviations"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects anomalies in sensor streams, supporting fault‑detection research"
]

// C3: Physical component
instance GantryCrane : DTDFVocab:Component [
    base:desc "Mechanically actuated gantry crane with linear and rotational axes used for industrial‑process simulation and educational demonstrations"
]

// Environment
instance LabScaleGantryCraneEnvironment : DTDFVocab:Environment [
    base:contains GantryCrane
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Control Application, implemented in Python, uses the Physical Crane Interface to send control commands to the crane's controllers. Commands are issued by the operator through the Human Machine Interface and then propagated via the Control Application to the interface, which translates them into the appropriate control signals for the physical hardware. No specific message format, authentication, or feedback mechanism is detailed in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "GreenhouseDT is orchestrated around a containerized deployment stack comprising an InfluxDB time‑series database for storing sensor telemetry, an ActiveMQ message broker that facilitates asynchronous event‑driven communication between the greenhouse Raspberry‑Pi sensors and the digital twin services, and modular virtual machine images that bundle the software components for rapid provisioning and scaling. The Air Quality Management exemplar adopts a cloud‑centric architecture in which the Raspberry‑Pi sensor suite publishes measurements that are processed through a pipeline of Microsoft Azure tools, with an AutomationML‑based digital twin representing the indoor environment and supporting runtime visualization, simulation, and prediction tasks."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Services within the digital twin communicate via an MQTT broker. MQTT is used as the messaging protocol for signaling among services such as the Trajectory Generator Service, Simulation Service, and Continuous Validation Service. The broker acts as a publish/subscribe message router; no further details on network topology, bandwidth, or security measures are given."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The systems integrate internally via ActiveMQ for publish/subscribe messaging and externally through InfluxDB for time‑series storage. In the Air Quality Management case, Microsoft Azure tools act as the integration layer, providing cloud‑based ingestion, analytics, and visualization services that consolidate telemetry from the physical sensors and the digital twin model, thereby enabling interoperability with enterprise cloud platforms."
]