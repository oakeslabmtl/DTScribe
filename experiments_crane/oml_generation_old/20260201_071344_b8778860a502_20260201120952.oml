// C3: Physical sensing components
instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor reading the horizontal carriage position via the crane controller interface"
    DTDFVocab:producedData PositionTelemetry
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Velocity sensor measuring the horizontal carriage velocity"
    DTDFVocab:producedData VelocityTelemetry
]

instance TensionSensor : DTDFVocab:SensingComponent [
    base:desc "Tension sensor monitoring the load tension on the crane hoist"
    DTDFVocab:producedData TensionTelemetry
]

// C4: Physical-to-virtual interaction
instance PositionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
    DTDFVocab:fromData PositionData
]

instance VelocityTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySensor
    DTDFVocab:fromData VelocityData
]

instance TensionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TensionSensor
    DTDFVocab:fromData TensionData
]

// C10: Models/Data
instance PositionData : DTDFVocab:Data [
    base:desc "Raw numeric position telemetry extracted from the crane controller at the update rate"
    DTDFVocab:fromData PositionTelemetry
]

instance VelocityData : DTDFVocab:Data [
    base:desc "Raw numeric velocity telemetry extracted from the crane controller at the update rate"
    DTDFVocab:fromData VelocityTelemetry
]

instance TensionData : DTDFVocab:Data [
    base:desc "Raw numeric tension telemetry extracted from the crane controller at the update rate"
    DTDFVocab:fromData TensionTelemetry
]

instance CraneStateData : DTDFVocab:Data [
    base:desc "Aggregated crane state data comprising position, velocity and load tension for modeling and control"
    DTDFVocab:fromData PositionData, VelocityData, TensionData
]

instance KinematicModel : DTDFVocab:Model [
    base:desc "AutomationML-based kinematic model of the gantry crane used for trajectory planning"
    DTDFVocab:inputTo CraneControlEnabler
]

// C11: Enablers
instance CraneLoggingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that logs real‑time crane telemetry to TimescaleDB"
    DTDFVocab:enables HistoricalDataLoggingService
]

instance CraneControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that processes crane state data to compute optimal control trajectories"
    DTDFVocab:enables OptimalControlService
]

instance CraneValidationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that compares live joint states against the kinematic model for fault detection"
    DTDFVocab:enables ContinuousValidationService
]

instance CraneVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that streams live crane state to web‑based dashboards for visualization"
    DTDFVocab:enables DataVisualizationService
]

// C6: Services
instance HistoricalDataLoggingService : DTDFVocab:Service [
    base:desc "Service that stores historical crane telemetry for analysis and visualization"
    DTDFVocab:provides LoggedStateInsight
]

instance OptimalControlService : DTDFVocab:Service [
    base:desc "Service that computes optimal or energy‑optimal crane trajectories and issues control commands"
    DTDFVocab:provides TrajectoryPredictionInsight, SendControlCommandsAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that validates real‑time joint states against the kinematic model and flags discrepancies"
    DTDFVocab:provides DiscrepancyDetectedInsight, LogDeviationAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service that renders the CAD model and overlays live state information and trajectory predictions"
    DTDFVocab:provides LiveStateInsight
]

// C17: Insights/Actions
instance LoggedStateInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing logged crane telemetry timestamps and values"
]

instance TrajectoryPredictionInsight : DTDFVocab:Insight [
    base:desc "Insight showing predicted optimal trajectories for the crane's payload"
]

instance SendControlCommandsAction : DTDFVocab:Action [
    base:desc "Automatic action that publishes computed control commands back to the crane controller"
    DTDFVocab:IsAutomatic true
]

instance DiscrepancyDetectedInsight : DTDFVocab:Insight [
    base:desc "Insight indicating joint state deviations beyond predefined thresholds"
]

instance LogDeviationAction : DTDFVocab:Action [
    base:desc "Automatic action that logs deviation events for offline fault‑detection analysis"
    DTDFVocab:IsAutomatic true
]

instance LiveStateInsight : DTDFVocab:Insight [
    base:desc "Live visualization of the crane's current state and overlayed trajectory predictions"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the Trajectory Generator Service, producing optimal velocity and position trajectories with no residual swing. These trajectories are sent through the Physical Crane Interface via Python to the crane controllers as low‑level actuation commands (likely a sequence of timed position‑velocity pairs in JSON or Python format). The Control Application initiates these commands, and the Continuous Validation Service compares executed trajectories with simulated ones for confirmation; no explicit authentication or conflict resolution mechanisms are detailed."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin system integrates a Raspberry‑Pi sensor node with an ActiveMQ message broker for real‑time telemetry publishing. Sensor data are stored in an InfluxDB time‑series database. Adaptation and simulation components run inside virtual machine images, which are pre‑configurable and distributed via GitHub repositories. The entire stack is deployed using containerization or virtualization technologies, and Microsoft Azure services are leveraged as part of the processing and visualization pipeline. This centralized, broker‑driven architecture provides a cohesive orchestration of physical data acquisition, digital modelling, and cloud‑based analytics."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication is mediated by an MQTT broker for signaling between the Trajectory Generator, Simulation, Continuous Validation services and the Logging Application. TimescaleDB and Grafana communicate via the PostgreSQL (TimescaleDB) protocol. The document does not specify network topology, bandwidth, latency, reliability, redundancy, or security protocols for these connections."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system is modeled as locally running Python containers with a TimescaleDB backend, Grafana dashboard, and MQTT broker. No specific hosting platform (cloud, edge, on‑premise), deployment model, computational or storage requirements, or scalability mechanisms are detailed in the document."
]