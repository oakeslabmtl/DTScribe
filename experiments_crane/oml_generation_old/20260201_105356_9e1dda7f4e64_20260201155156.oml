// C2: Acting Components
instance CartStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor controlling the cart movement of the gantry crane, interfaced with TMC4671-Eval motor controller for precise actuation."
]

instance HoistStepperMotor : DTDFVocab:ActingComponent [
    base:desc "Stepper motor controlling the hoisting movement of the gantry crane, interfaced with TMC4671-Eval motor controller for precise actuation."
]

instance CraneElectromagnet : DTDFVocab:ActingComponent [
    base:desc "Electromagnet at the end of the hoist for picking up containers, powered by the crane's PSU."
]

instance CranePowerSupplyUnit : DTDFVocab:ActingComponent [
    base:desc "Power Supply Unit providing electrical power to the crane's electronics and actuators."
]

// C3: Physical Sensing Components
instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Measures the swinging motion of the hoist to provide critical feedback for trajectory validation and fault detection."
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance CraneAnemometer : DTDFVocab:SensingComponent [
    base:desc "Measures wind speed affecting crane operations, interfaced via Arduino with custom KiCad-designed shield."
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance ArduinoSensorInterface : DTDFVocab:SensingComponent [
    base:desc "Custom Arduino-based interface with KiCad-designed shield collecting real-time sensor data for the digital twin."
    DTDFVocab:producedData SensorInterfaceDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CraneAnemometer
]

instance SensorInterfaceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoSensorInterface
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoSensorInterface
]

instance TrajectoryExecutionEvent : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ArduinoSensorInterface
]

// C10: Models/Data
instance CraneCADModel : DTDFVocab:Model [
    base:desc "3D representation of the crane created in Autodesk Fusion 360 for structural visualization."
    DTDFVocab:inputTo PythonEnabler, GrafanaEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator Service to compute optimal movement trajectories."
    DTDFVocab:inputTo TrajectoryGeneratorService
]

instance CraneSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model implemented in the Simulation Service to replicate crane dynamics for validation."
    DTDFVocab:inputTo SimulationService
]

instance CraneTimeSeriesData : DTDFVocab:Data [
    base:desc "Historical time-series data including sensor readings (swing angle, wind speed) and control inputs stored in TimescaleDB."
    DTDFVocab:fromData SwingAngleDataTransmitted, WindSpeedDataTransmitted, MotorPositionDataTransmitted
    DTDFVocab:inputTo TimescaleDBEnabler, GrafanaEnabler
]

instance TrajectoryOptimizationData : DTDFVocab:Data [
    base:desc "Optimal trajectory paths generated by the Trajectory Generator Service for minimizing residual swinging."
    DTDFVocab:inputTo ControlApplicationEnabler
]

instance FaultDetectionData : DTDFVocab:Data [
    base:desc "Time-series classification results identifying anomalies in crane operation (e.g., motor failures, sensor drifts)."
    DTDFVocab:inputTo GrafanaEnabler
]

// C11: Enablers
instance PythonEnabler : DTDFVocab:Enabler [
    base:desc "Core programming language for gantrylib module, Control Application, Logging Application, and HMI."
    DTDFVocab:enables TrajectoryGeneratorService, SimulationService, LoggingService, ControlApplicationService, ContinuousValidationService
]

instance DockerEnabler : DTDFVocab:Enabler [
    base:desc "Containerization platform orchestrating TimescaleDB, Grafana, and MQTT Broker via docker-compose."
    DTDFVocab:enables TimescaleDBEnabler, GrafanaEnabler, MQTTBrokerEnabler
]

instance TimescaleDBEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database optimized for SQL queries and high write/read throughput for crane state data storage."
    DTDFVocab:enables LoggingService, HistoricalAnalysisService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Visualization tool for real-time and historical data dashboards with simulated confidence bounds."
    DTDFVocab:enables DataVisualizationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Lightweight messaging protocol (Eclipse Mosquitto) for inter-service communication via event-based notifications."
    DTDFVocab:enables ContinuousValidationService
]

instance ArduinoKiCadInterface : DTDFVocab:Enabler [
    base:desc "Custom hardware interface combining Arduino with KiCad-designed shield for sensor interfacing and control."
    DTDFVocab:enables SensorInterfaceDataTransmitted
]

instance ControlApplicationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the Control Application Service processing state updates from physical crane interface."
    DTDFVocab:enables ControlApplicationService
]

// C6: Services
instance TrajectoryGeneratorService : DTDFVocab:Service [
    base:desc "Uses kinematic model to compute swing-free movement paths for optimal crane operation."
    DTDFVocab:provides TrajectoryOptimizationInsight, TrajectoryValidationAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Emulates crane behavior for offline testing and validation of control strategies."
    DTDFVocab:provides SimulationValidationInsight
]

instance LoggingService : DTDFVocab:Service [
    base:desc "Stores crane state data (motor positions, swing angles) in TimescaleDB for analysis."
    DTDFVocab:provides HistoricalDataInsight
]

instance ControlApplicationService : DTDFVocab:Service [
    base:desc "Processes state updates from physical crane interface to generate control commands."
    DTDFVocab:provides ControlCommandAction
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Compares executed trajectories with simulated ones using distance metrics and triggers alerts for deviations."
    DTDFVocab:provides ValidationAlertAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Displays real-time and historical crane data via Grafana dashboards with simulated confidence bounds."
    DTDFVocab:provides VisualizationInsight
]

instance HistoricalAnalysisService : DTDFVocab:Service [
    base:desc "Enables trend analysis for predictive maintenance or performance tuning using TimescaleDB."
    DTDFVocab:provides MaintenanceInsight
]

// C17: Insights/Actions
instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimal paths generated to minimize residual swinging during crane operations."
]

instance TrajectoryValidationAction : DTDFVocab:Action [
    base:desc "Validates trajectory execution against simulated paths using distance metrics."
    DTDFVocab:IsAutomatic true
]

instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results comparing simulated crane behavior with physical execution."
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Time-series data of crane operations for trend analysis and performance metrics."
]

instance FaultLocalizationInsight : DTDFVocab:Insight [
    base:desc "Identified anomalies in crane operation (motor failures, sensor drifts) through time-series classification."
]

instance ValidationAlertAction : DTDFVocab:Action [
    base:desc "Triggers Grafana notifications when simulated/executed trajectory deviations exceed thresholds."
    DTDFVocab:IsAutomatic true
]

instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Generates and sends control commands to stepper motors based on trajectory optimization."
    DTDFVocab:IsAutomatic true
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time and historical crane data visualization with simulated confidence bounds."
]

instance MaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance recommendations based on historical trend analysis."
]

// C12: Environments/Components
instance PhysicalCraneEnvironment : DTDFVocab:Environment [
    base:desc "Physical deployment environment containing the lab-scale gantry crane system."
    base:contains CartStepperMotor, HoistStepperMotor, CraneElectromagnet, CranePowerSupplyUnit,
                  SwingAngleEncoder, CraneAnemometer, ArduinoSensorInterface
]

instance VirtualCraneEnvironment : DTDFVocab:Environment [
    base:desc "Virtual deployment environment containing digital twin services and data storage."
    base:contains CraneCADModel, CraneKinematicModel, CraneSimulationModel, CraneTimeSeriesData,
                  TrajectoryOptimizationData, FaultDetectionData
]

instance ServiceContainerEnvironment : DTDFVocab:Environment [
    base:desc "Containerized service environment orchestrated via Docker."
    base:contains TimescaleDBEnabler, GrafanaEnabler, MQTTBrokerEnabler,
                  TrajectoryGeneratorService, SimulationService, LoggingService,
                  ControlApplicationService, ContinuousValidationService, DataVisualizationService,
                  HistoricalAnalysisService
]

instance ControlApplicationComponent : DTDFVocab:Component [
    base:desc "Python-based application processing state updates from physical crane interface."
    base:isContainedIn ServiceContainerEnvironment
]

instance LoggingApplicationComponent : DTDFVocab:Component [
    base:desc "Python-based application logging real-time sensor data to TimescaleDB."
    base:isContainedIn ServiceContainerEnvironment
]

instance HMIComponent : DTDFVocab:Component [
    base:desc "Human-Machine Interface for crane operator interaction and monitoring."
    base:isContainedIn ServiceContainerEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin influences the physical system through:
  - **Optimal trajectory commands** generated by the **Trajectory Generator Service** (using a kinematic model) and sent to the **Control Application** for execution.
  - **Control signals** from the **Control Application** to the **Physical Crane Interface**, which translates them into motor commands for the **TMC4671-Eval controllers**.
  - **Alerts and notifications** (e.g., threshold breaches in continuous validation) displayed on the **Grafana Dashboard** and relayed to operators via the **Human Machine Interface (HMI)**."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin operates in **real-time** for continuous validation and control, with:
  - **High-frequency sensor data logging** (e.g., swing angle, motor positions) at rates dependent on the crane's operational dynamics.
  - **Periodic validation checks** (e.g., trajectory comparisons) executed asynchronously via the **Continuous Validation Service**.
  - **Near-real-time data visualization** in Grafana, updated dynamically as new data is logged."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation follows a **C4 Model** architecture, structured as:
  - **Physical Layer**: Physical Crane (hardware), Crane Interface (Python), Control Application, Logging Application, HMI.
  - **Virtual Layer**: Database (TimescaleDB), Dashboard (Grafana), Trajectory Generator, Simulation Service, Continuous Validation Service, MQTT Broker.
  - **Deployment**: All components (except physical hardware) run on a **single personal computer**, with Docker managing virtual services. The **gantrylib** Python module encapsulates core functionalities for extensibility."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin covers the **as-operated** lifecycle phase, focusing on:
  - **Real-time monitoring and control** of the physical crane during operation.
  - **Post-mortem analysis** via historical data logging for fault detection and performance optimization.
  The exemplar does not explicitly model the **as-designed** or **as-manufactured** phases but could be extended to include CAD models (e.g., Autodesk Fusion 360) for these stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
  - **Continuous Validation**: The **Continuous Validation Service** compares executed trajectories with simulations using distance metrics (e.g., Euclidean distance) and thresholds to detect deviations.
  - **Simulation Bounds**: Grafana displays **upper/lower confidence bounds** derived from simulations to validate real-time data.
  - **Fault Detection**: Time-series classification techniques [6] are applied to logged data for anomaly detection.
  - **Uncertainty Handling**: No explicit uncertainty quantification is documented, but the system relies on **sensor accuracy** (e.g., swing angle encoder) and **model fidelity** (kinematic model)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Technical connections include:
  - **Network Protocols**: MQTT (Eclipse Mosquitto) for inter-service communication; no explicit mention of other protocols (e.g., OPC UA, HTTP).
  - **Data Flow**: Sensor data → Arduino → Python Interface → Logging Application → TimescaleDB; Control Commands → Trajectory Generator → Control Application → Crane Interface → Motors.
  - **Hardware Interface**: Arduino communicates with sensors (swing angle encoder, anemometer) and motor controllers (TMC4671-Eval) via custom KiCad shield."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is hosted and deployed on:
  - **Single Personal Computer**: All software components (except physical hardware) run locally.
  - **Docker Containers**: TimescaleDB, Grafana, and MQTT Broker are containerized via **docker-compose** for easy setup.
  - **Python Module (gantrylib)**: Core functionalities are packaged as a **pip-installable** module for reproducibility.
  - **GitHub Repository**: Open-source hosting with documentation (MkDocs) and CAD models (Autodesk Fusion 360)."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The exemplar adheres to:
  - **Open-Source Standards**: MIT License for software; no proprietary frameworks.
  - **Interoperability**: Uses **MQTT** (IETF standard) and **TimescaleDB** (PostgreSQL-compatible).
  - **Modeling**: CAD models in **Autodesk Fusion 360**; system architecture documented via **C4 Model**.
  No explicit mention of industry standards (e.g., AutomationML, Asset Administration Shell) beyond ad-hoc open-source tools."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety considerations include:
  - **No Remote Execution**: The digital twin does not autonomously execute operations on the physical crane; all actions require operator confirmation via the **HMI**.
  - **Local Deployment**: All components run on a **single personal computer**, reducing exposure to network-based attacks.
  - **Fault Detection**: Time-series classification [6] and continuous validation mitigate operational risks by alerting operators to anomalies.
  - **No Explicit Cybersecurity Measures**: No encryption, authentication, or access control mechanisms are documented for data transmission or system access."
]