// ----------------------------------------------------------
// C3: Physical sensing components
// ----------------------------------------------------------

instance SwingAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "Swing‑angle encoder measuring hoist sway"
    DTDFVocab:producedData SwingAngleDataTransmitted
]

instance Anemometer : DTDFVocab:SensingComponent [
    base:desc "Anemometer measuring wind speed"
    DTDFVocab:producedData WindSpeedDataTransmitted
]

instance CartMotorFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Controller feedback from the cart stepper motor driver"
    DTDFVocab:producedData CartMotorStateDataTransmitted
]

instance HoistMotorFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Controller feedback from the hoist stepper motor driver"
    DTDFVocab:producedData HoistMotorStateDataTransmitted
]

// ----------------------------------------------------------
// C4: Physical-to-virtual interaction (DataTransmitted)
// ----------------------------------------------------------

instance SwingAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SwingAngleEncoder
]

instance WindSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Anemometer
]

instance CartMotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CartMotorFeedbackSensor
]

instance HoistMotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HoistMotorFeedbackSensor
]

// ----------------------------------------------------------
// C10: Data (sensor‑derived)
// ----------------------------------------------------------

instance SwingAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped swing angle measurements"
    DTDFVocab:fromData SwingAngleDataTransmitted
    DTDFVocab:inputTo DataLoggingEnabler
]

instance WindSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped wind speed measurements"
    DTDFVocab:fromData WindSpeedDataTransmitted
    DTDFVocab:inputTo DataLoggingEnabler
]

instance CartMotorStateData : DTDFVocab:Data [
    base:desc "Time‑stamped cart motor state (position, current, voltage)"
    DTDFVocab:fromData CartMotorStateDataTransmitted
    DTDFVocab:inputTo DataLoggingEnabler
]

instance HoistMotorStateData : DTDFVocab:Data [
    base:desc "Time‑stamped hoist motor state (position, current, voltage)"
    DTDFVocab:fromData HoistMotorStateDataTransmitted
    DTDFVocab:inputTo DataLoggingEnabler
]

// ----------------------------------------------------------
// C10: Additional data (historical & validation)
// ----------------------------------------------------------

instance HistoricalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DataLoggingService
]

instance ValidationMetricsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContinuousValidationService
]

instance HistoricalTimeSeriesData : DTDFVocab:Data [
    base:desc "Historic time‑series data of crane operation stored in TimescaleDB"
    DTDFVocab:fromData HistoricalDataTransmitted
    DTDFVocab:inputTo ValidationEnabler
]

instance ValidationMetricsData : DTDFVocab:Data [
    base:desc "Metrics representing distance between measured and simulated trajectories"
    DTDFVocab:fromData ValidationMetricsDataTransmitted
    DTDFVocab:inputTo ValidationEnabler
]

// ----------------------------------------------------------
// C10: Models
// ----------------------------------------------------------

instance CraneCADModel : DTDFVocab:Model [
    base:desc "CAD geometry of the gantry crane (Fusion‑360)"
    DTDFVocab:inputTo VisualizationEnabler
]

instance CraneKinematicModel : DTDFVocab:Model [
    base:desc "Kinematic model used by the Trajectory Generator for swing‑free paths"
    DTDFVocab:inputTo TrajectoryGeneratorEnabler
]

instance CraneDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model of crane and its controllers"
    DTDFVocab:inputTo SimulationEnabler
]

// ----------------------------------------------------------
// C11: Enablers
// ----------------------------------------------------------

instance DataLoggingEnabler : DTDFVocab:Enabler [
    base:desc "TimescaleDB‑based enabler that persists incoming sensor data"
    DTDFVocab:enables DataLoggingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboard enabler that visualizes logged data and insights"
    DTDFVocab:enables DataVisualizationService
]

instance TrajectoryGeneratorEnabler : DTDFVocab:Enabler [
    base:desc "Python gantrylib module with kinematic model for generating optimal trajectories"
    DTDFVocab:enables TrajectoryGenerationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine using dynamic model of crane and controllers"
    DTDFVocab:enables SimulationService
]

instance ValidationEnabler : DTDFVocab:Enabler [
    base:desc "Continuous validation component comparing measured and simulated trajectories"
    DTDFVocab:enables ContinuousValidationService
]

instance HMIEnabler : DTDFVocab:Enabler [
    base:desc "Human‑Machine Interface enabling operator actions on the crane twin"
    DTDFVocab:enables HumanMachineInterfaceService
]

// ----------------------------------------------------------
// C6: Services
// ----------------------------------------------------------

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service that continuously logs sensor state to TimescaleDB"
    DTDFVocab:provides LoggedDataInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service that visualizes logged data and insights via a Grafana dashboard"
    DTDFVocab:provides DashboardVisualizationInsight
]

instance TrajectoryGenerationService : DTDFVocab:Service [
    base:desc "Service that generates optimal swing‑free crane trajectories using the kinematic model"
    DTDFVocab:provides OptimalTrajectoryInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs a dynamic digital replica of the crane and its controllers"
    DTDFVocab:provides SimulatedTrajectoryInsight
]

instance ContinuousValidationService : DTDFVocab:Service [
    base:desc "Service that compares measured vs simulated trajectories and raises alerts"
    DTDFVocab:provides DeviationAlertInsight
]

instance HumanMachineInterfaceService : DTDFVocab:Service [
    base:desc "Human‑Machine Interface allowing operators to adjust parameters or intervene"
    DTDFVocab:provides AdjustParametersAction
]

// ----------------------------------------------------------
// C17: Insights & Actions
// ----------------------------------------------------------

instance LoggedDataInsight : DTDFVocab:Insight [
    base:desc "Insight confirming that sensor data have been successfully recorded in TimescaleDB"
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight displayed on the Grafana dashboard for operator monitoring"
]

instance OptimalTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight providing the optimal swing‑free crane path generated by the trajectory service"
]

instance SimulatedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight presenting the simulated crane trajectory derived from the dynamic model"
]

instance DeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert insight triggered when measured trajectory deviates beyond the acceptable threshold"
]

instance AdjustParametersAction : DTDFVocab:Action [
    base:desc "Action allowing the operator to adjust trajectory parameters or intervene via the HMI"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control Application receives trajectory commands from the Trajectory Generator Service (and operator inputs from the Human‑Machine Interface) and forwards motion set‑points to the Physical Crane Interface, which drives the cart and hoist motor controllers and activates the electromagnet via the Arduino."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A C4‑model architecture where the physical crane is interfaced by a Python program, connected to a Control Application, Logging Application and Human‑Machine Interface; the digital side consists of a TimescaleDB, MQTT broker, Grafana dashboard and three core services (Trajectory Generator, Simulation, Continuous Validation) that exchange messages over MQTT and share the database."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the design stage (CAD models in Autodesk Fusion‑360), the manufacturing stage (physical crane hardware), and the operation stage (real‑time sensor data, logged trajectories, and validation during run‑time)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous Validation Service continuously compares executed trajectories with simulated ones, computes distance metrics, checks them against a predefined threshold, and raises alerts on the dashboard; the Simulation Service provides confidence bounds for trajectories, enabling quantitative fidelity assessment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑service communication uses MQTT (Eclipse Mosquitto) for signaling; sensor and command data are exchanged over MQTT topics; time‑series data are written to and read from TimescaleDB via standard PostgreSQL SQL; Grafana accesses the database over HTTP/SQL."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components run on a single personal computer; the database, MQTT broker and Grafana are Docker‑containerized; the remaining Python containers are installed via pip; orchestration is performed with a docker‑compose file that starts the full stack with a single command."
]