// C3: Physical sensing components
instance TemperatureSensorT1 : DTDFVocab:SensingComponent [
    base:desc "Three temperature sensors (T1-T3) placed in hottest, coldest, and average positions room temperature sensor (T1)"
]

instance TemperatureSensorT2 : DTDFVocab:SensingComponent [
    base:desc "Three temperature sensors (T1-T3) placed in hottest, coldest, and average positions room temperature sensor (T1)"
]

instance TemperatureSensorT3 : DTDFVocab:SensingComponent [
    base:desc "Three temperature sensors (T1-T3) placed in hottest, coldest, and average positions room temperature sensor (T1)"
]

instance RoomTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Room temperature sensor (T1) measuring ambient temperature"
]

// C4: Physical-to-virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT1, TemperatureSensorT2, TemperatureSensorT3, RoomTemperatureSensor
]

// C10: Models/Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Time-series temperature data from DS18S20 sensors with 0.5°C accuracy"
    DTDFVocab:fromData TemperatureDataTransmitted
]

instance ThermalModelA : DTDFVocab:Model [
    base:desc "2-parameter thermal behavior model with C_air=616.56 J/K, G_box=0.65 J/K"
    DTDFVocab:inputTo KalmanFilterEnabler, CoSimulationEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "4-parameter thermal inertia prediction model with C_air=486.12 J/K, G_box=0.856 J/K, C_heater=33.65 J/K, G_heater=0.87 J/K"
    DTDFVocab:inputTo KalmanFilterEnabler, CoSimulationEnabler
]

// C11: Enablers
instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker for real-time data transmission between controller, low-level driver, and simulation components"
    DTDFVocab:enables RealTimeVisualizationService, AnomalyDetectionService, WhatIfSimulationService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter algorithm for state estimation and fault detection with ±0.1°C precision"
    DTDFVocab:enables AnomalyDetectionService, HeatbedStateEstimationService
]

instance CoSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Co-simulation framework for what-if scenarios and controller optimization"
    DTDFVocab:enables WhatIfSimulationService
]

instance PythonSimulationFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Python-based simulation framework (SciPy 1.0) for Kalman filter algorithms and differential equations"
    DTDFVocab:enables KalmanFilterEnabler, CoSimulationEnabler
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Dashboard plotting of time-series data for incubator status visualization"
    DTDFVocab:provides RealTimeTemperatureInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection using Kalman filters and state estimation"
    DTDFVocab:provides KalmanFilterAccuracyInsight
]

instance HeatbedStateEstimationService : DTDFVocab:Service [
    base:desc "Heatbed state estimation via Kalman filter for thermal behavior analysis"
    DTDFVocab:provides HeatbedStateInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What-if simulations for controller optimization and adaptive system reconfiguration"
    DTDFVocab:provides ControllerOptimizationAction
]

// C17: Insights/Actions
instance RealTimeTemperatureInsight : DTDFVocab:Insight [
    base:desc "Real-time temperature visualization via dashboards"
]

instance KalmanFilterAccuracyInsight : DTDFVocab:Insight [
    base:desc "Confidence measures derived from Kalman filter accuracy and model calibration results"
]

instance HeatbedStateInsight : DTDFVocab:Insight [
    base:desc "Heatbed state estimation for thermal behavior analysis"
]

instance ControllerOptimizationAction : DTDFVocab:Action [
    base:desc "Controller optimization through what-if simulations for adaptive system reconfiguration"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heating element with bang-bang controller parameters: LL (lower temp limit), UL (upper temp limit), H (heating duration), C (waiting duration)"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan for air circulation with adjustable voltage (12V/18V) for airflow experiments"
]

// C1: Physical-to-virtual interaction
instance TemperatureDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT1, TemperatureSensorT2, TemperatureSensorT3, RoomTemperatureSensor
]

// C12: Environment
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:contains InsulatedStyrofoamBoxComponent, HeatbedComponent, FanComponent, TemperatureSensorT1, TemperatureSensorT2, TemperatureSensorT3, RoomTemperatureSensor, RaspberryPiControllerComponent
]

instance InsulatedStyrofoamBoxComponent : DTDFVocab:Component [
    base:desc "Insulated styrofoam box with volume 0.03 m³"
]

instance HeatbedComponent : DTDFVocab:Component [
    base:desc "Heatbed with thermal inertia prediction via simulation models"
]

instance FanComponent : DTDFVocab:Component [
    base:desc "Fan for air circulation with airflow ~0.02 m³/s"
]

instance RaspberryPiControllerComponent : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B controller with GPIO for control logic and wireless connectivity"
]


instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (heating duration H, waiting duration C) are sent via RabbitMQ to the low-level driver for actuator control. Command formats include binary signals for fan/heatbed activation. Validation occurs through safe protocol checks in the low-level driver. Feedback systems use temperature sensor data for state estimation. Conflict resolution is handled via controller statechart (Document 3). Command execution confirmation is achieved through RabbitMQ message acknowledgments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization via RabbitMQ with latency optimized for immediate data exchange; Kalman filter processes data in real-time for anomaly detection and heatbed state estimation; co-simulations relay historical/real-time data from Physical Twin (PT) with temporal granularity matching controller parameters (LL, UL, H, C)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated architecture with RabbitMQ as central communication hub; integrates Controller (bang-bang logic), Low-Level Driver (safe protocol), and Communication Server (synchronization); resource management includes Raspberry Pi GPIO for sensor/actuator control and optocouplers for signal decoupling; self-adaptation loop dynamically reconfigures Kalman filter and controller parameters."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle includes development stages such as model creation (two-parameter and four-parameter thermal models), calibration (using RabbitMQ for parameter estimation), and integration into the Physical Twin (PT). Representation types transition from simulation models to real-time data monitoring. Lifecycle governance involves open-source tooling (RabbitMQ, SciPy) and version control via public repositories. Transition management includes model re-calibration and self-adaptation loops triggered by anomalies."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity requires calibration experiments (e.g., 18V fan test reducing max temp discrepancy from 7°C to 6°C). Validation methods include Kalman filter anomaly detection and co-simulation with historical data. Uncertainty sources: sensor placement (T2/T3 positioning), fan airflow variability, and thermal inertia estimation. Error correction: automatic recalibration of Model B parameters when new objects (e.g., cold water bucket) alter system dynamics. Quality assurance processes involve iterative model refinement and real-time data monitoring."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication protocols: RabbitMQ (AMQP) for message brokering. Network topology: Edge (Raspberry Pi) - Cloud (RabbitMQ server) hybrid architecture. Bandwidth requirements: Lightweight for real-time data (Document 3). Latency: Optimized for low-latency control (Document 3). Reliability mechanisms: Persistent message queues and server-side acknowledgments. Security protocols: Standard AMQP encryption (implied by open-source deployment)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosting platforms: Edge (Raspberry Pi 4 Model B) and cloud (RabbitMQ server). Computational requirements: Raspberry Pi 4 (4-core Cortex-A53, 1.5GHz). Storage: Time-series database for logged sensor data. Scalability: Modular architecture supports additional sensors/actuators. Deployment models: Edge-first with cloud integration. Availability: Open-source components ensure redundancy (Document 1)."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Leverages RabbitMQ (AMQP protocol) for interoperability with external systems; integrates with cloud/on-premises deployments via open-source tools; uses Python Functional Mockup Units (FMUs) for co-simulation with external Digital Twins; data exchange protocols include 1-Wire bus for temperature sensors and MQTT for RabbitMQ messaging."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Complies with IEEE standards (e.g., [4] Digital Twin in Industry, [5] Digital Twin challenges). Uses open-source frameworks (RabbitMQ, SciPy) for interoperability. Certification requirements are not explicitly detailed, but adherence to IEEE and Industry 4.0 standards [10] is implied through reference to related work."
]