// C3: Physical sensing components
instance TemperatureSensorT1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire digital thermometer measuring room temperature with 0.5°C accuracy (-10°C to +85°C)"
]

instance TemperatureSensorT2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire digital thermometer monitoring hottest position in styrofoam box with 0.5°C accuracy"
]

instance TemperatureSensorT3 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire digital thermometer monitoring coldest position in styrofoam box with 0.5°C accuracy"
]

// C4: Physical-to-virtual interaction
instance TemperatureDataT1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT1
]

instance TemperatureDataT2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT2
]

instance TemperatureDataT3 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT3
]

// C10: Models/Data
instance ThermalModelA : DTDFVocab:Model [
    base:desc "2-parameter thermal model with C_air=616.56 J/K and G_box=0.65 J/K for incubator temperature prediction"
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "4-parameter thermal model with C_air=486.12 J/K, G_box=0.856 J/K, C_heater=33.65 J/K, G_heater=0.87 J/K for heatbed inertia prediction"
]

instance RealTimeTemperatureData : DTDFVocab:Data [
    base:desc "Time-series temperature readings from DS18S20 sensors (-55°C to +125°C, 0.5°C accuracy)"
    DTDFVocab:fromData TemperatureDataT1, TemperatureDataT2, TemperatureDataT3
]

instance ControlStateData : DTDFVocab:Data [
    base:desc "Binary control states for fan and heatbed actuation"
    DTDFVocab:fromData TemperatureDataT1, TemperatureDataT2, TemperatureDataT3
]

instance HistoricalTemperatureData : DTDFVocab:Data [
    base:desc "Historical temperature data for co-simulation and controller optimization"
    DTDFVocab:fromData TemperatureDataT1, TemperatureDataT2, TemperatureDataT3
]

// C11: Enablers
instance RabbitMQ : DTDFVocab:Enabler [
    base:desc "Open-source message broker for real-time data streaming between controller, low-level driver, and Digital Twin components"
    DTDFVocab:enables RealTimeVisualizationService, OnDemandCalibrationService, AnomalyDetectionService, WhatIfSimulationService, SelfAdaptationLoopService
]

instance KalmanFilter : DTDFVocab:Enabler [
    base:desc "State estimation algorithm correlating measured data to non-measured heatbed temperature for anomaly detection"
    DTDFVocab:enables AnomalyDetectionService, HeatbedStateEstimationAction
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Database for storing sensor data and dashboard visualization"
    DTDFVocab:enables RealTimeVisualizationService, ModelCalibrationService
]

instance GitHub : DTDFVocab:Enabler [
    base:desc "Version control system for managing hardware/software specifications and model calibration experiments"
    DTDFVocab:enables ModelCalibrationService, SelfAdaptationLoopService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Dashboard for real-time visualization of incubator status with time-series data from controller and low-level driver"
    DTDFVocab:provides RealTimeTemperatureInsight, ControlStateInsight
]

instance OnDemandCalibrationService : DTDFVocab:Service [
    base:desc "On-demand calibration using Model B (4-parameter thermal model) for parameter estimation"
    DTDFVocab:provides ModelCalibrationInsight, ParameterEstimationAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection & heatbed state estimation via Kalman filter correlating measured data to non-measured heatbed temperature"
    DTDFVocab:provides AnomalyDetectionInsight, HeatbedStateEstimationAction
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What-if simulations for controller optimization using co-simulations with historical/real-time PT data"
    DTDFVocab:provides SimulationScenarioInsight, ControllerOptimizationAction
]

instance SelfAdaptationLoopService : DTDFVocab:Service [
    base:desc "Self-adaptation loop enabling dynamic reconfiguration: detecting plant behavior changes, scheduling experiments, calibrating Model B, updating Kalman filters, and reconfiguring controllers for new scenarios"
    DTDFVocab:provides SystemAdaptationInsight, DynamicReconfigurationAction
]

// C17: Insights/Actions
instance RealTimeTemperatureInsight : DTDFVocab:Insight [
    base:desc "Real-time temperature visualization of incubator status with time-series data"
]

instance ControlStateInsight : DTDFVocab:Insight [
    base:desc "Visualization of control states for fan and heatbed actuation"
]

instance ModelCalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight from Model B calibration for parameter estimation"
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight from Kalman filter-based anomaly detection and heatbed state estimation"
]

instance SimulationScenarioInsight : DTDFVocab:Insight [
    base:desc "Insight from what-if simulations for controller optimization"
]

instance SystemAdaptationInsight : DTDFVocab:Insight [
    base:desc "Insight from self-adaptation loop for dynamic reconfiguration"
]

instance ParameterEstimationAction : DTDFVocab:Action [
    base:desc "Action for parameter estimation using Model B calibration"
    DTDFVocab:IsAutomatic true
]

instance HeatbedStateEstimationAction : DTDFVocab:Action [
    base:desc "Action for heatbed state estimation via Kalman filter"
    DTDFVocab:IsAutomatic true
]

instance ControllerOptimizationAction : DTDFVocab:Action [
    base:desc "Action for controller optimization through what-if simulations"
    DTDFVocab:IsAutomatic true
]

instance DynamicReconfigurationAction : DTDFVocab:Action [
    base:desc "Action for dynamic reconfiguration of controllers for new scenarios"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance AirCirculationFan : DTDFVocab:ActingComponent [
    base:desc "Fan with 0.02 m³/s airflow for uniform temperature distribution in styrofoam box"
]

instance HeatbedComponent : DTDFVocab:ActingComponent [
    base:desc "Heatbed with thermal inertia requiring predictive modeling for temperature regulation"
]

instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi 4 Model B implementing bang-bang control logic with GPIO interfaces"
]

// C1: Components
instance PhysicalTwin : DTDFVocab:Component [
    base:desc "Physical Twin (PT) comprising insulated styrofoam box, heatbed, fan, and temperature sensors"
    DTDFVocab:contains AirCirculationFan, HeatbedComponent, TemperatureSensorT1, TemperatureSensorT2, TemperatureSensorT3
]

instance DigitalTwin : DTDFVocab:Component [
    base:desc "Digital Twin (DT) comprising thermal models, data management systems, and control algorithms"
    DTDFVocab:contains ThermalModelA, ThermalModelB, TimeSeriesDatabase, KalmanFilter, RabbitMQ
]

// C12: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwin, DigitalTwin
]


instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control flows from digital to physical include commands for fan (on/off) and heatbed (heating duration). Message formats: structured commands via RabbitMQ (AMQP). Validation: low-level driver checks command validity before execution. Feedback systems: controller state updates sent to RabbitMQ, Kalman filter correlations for heatbed state estimation. Conflict resolution: priority given to safety protocols in low-level driver. Command execution confirmation: controller acknowledges actuation via RabbitMQ status updates."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization via RabbitMQ message brokering (100% latency-sensitive), with Kalman filter state estimation (10ms update interval), controller statechart transitions (2s fan cycle time), and self-adaptation loop (1s experiment scheduling interval). Temporal granularity for temperature sensing is 0.5°C resolution with 1s sampling frequency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated architecture with RabbitMQ as central message broker (AMQP protocol), integrated controller (bang-bang logic with H=5s, C=3s parameters), low-level driver (safe protocol for PT interaction), and calibrated models (Model B with 4 free parameters). System-wide coordination includes Kalman filter state estimation, co-simulation with PT data, and adaptive reconfiguration via self-loop mechanisms."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle includes development (model creation with 2/4 free parameters), calibration (Model B for thermal inertia prediction), operational phases (real-time monitoring via RabbitMQ and Kalman filter), and self-adaptation (dynamic reconfiguration upon anomalies). Transition management involves iterative calibration and model updates. Governance includes open-source repository maintenance and version control via GitHub."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity: Calibration experiments (Model A/B parameters) and Kalman filter integration for heatbed state estimation. Validation: Comparison of model predictions (e.g., temperature uniformity) with sensor data (e.g., 7°C discrepancy in baseline vs. 6°C with 18V fan). Uncertainty sources: sensor noise, environmental variations, and model parameter approximations. Error correction: Kalman filter for anomaly detection, automatic calibration workflows, and co-simulations with historical data. Quality assurance: Open-source hardware/software for reproducibility and parameter tuning via experiments."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Technical network infrastructure uses RabbitMQ (AMQP protocol) for bidirectional communication. Network topology: edge (Raspberry Pi) <-> cloud/on-premise RabbitMQ server. Bandwidth requirements: sufficient for real-time temperature data (0.02 m³/s airflow) and control signals. Latency: <2 seconds for fan/heatbed actuation. Reliability: redundant communication via RabbitMQ's message persistence. Security: open-source RabbitMQ with TLS/SSL for encrypted communication (implied by standard practices)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment infrastructure uses Raspberry Pi 4 Model B (edge device) as host. Computational requirements: 4A current handling via MOSFETs, real-time control logic (bang-bang algorithm). Storage: time-series database for temperature data (dashboard integration). Scalability: modular architecture allows adding sensors/actuators. Deployment models: edge (Raspberry Pi) + cloud (RabbitMQ server). Availability: 99.9% uptime via redundant communication and power supply."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability via RabbitMQ (open-source message broker), Raspberry Pi's Wi-Fi/Bluetooth for wireless deployment, and GitHub-hosted open-source repository. Integration patterns include: 1-Wire bus for temperature sensors, co-simulation with external systems, and model calibration using sensor data from PT. Dependencies on external systems include sensor networks and cloud-based data storage."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Complies with CPS frameworks (e.g., IEEE 1800-2015), open-source protocols (RabbitMQ, 1-Wire), and industry standards for IoT device communication. Interoperability is achieved through standardized messaging (AMQP) and modular component design (e.g., separable controller/low-level driver architecture)."
]