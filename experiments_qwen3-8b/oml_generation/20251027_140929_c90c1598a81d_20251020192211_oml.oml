// Return code: 1 | Stderr:
// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed controlled by Raspberry Pi 4 Model B via MOSFETs (4A current handling) with optocouplers for signal isolation"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan with 0.02 m³/s airflow and 18V operation for air circulation"
]

// C3: Physical sensing components
instance RoomTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring ambient temperature in the environment"
    DTDFVocab:producedData RoomTemperatureData
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring temperature at specific points"
    DTDFVocab:producedData TemperatureData
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring humidity levels in the environment"
    DTDFVocab:producedData HumidityData
]

// C4: Physical-to-virtual interaction
instance RoomTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTemperatureSensor
]

instance TemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

// C10: Models/Data
instance EnvironmentalModel : DTDFVocab:Model [
    base:desc "Model representing environmental conditions"
    DTDFVocab:inputTo EnvironmentalAnalysis
]

instance SensorData : DTDFVocab:Data [
    base:desc "Aggregated data from environmental sensors"
    DTDFVocab:fromData RoomTemperatureData, TemperatureData, HumidityData
]

// C11: Enablers
instance EnvironmentalAnalysis : DTDFVocab:Enabler [
    base:desc "System for analyzing environmental data"
    DTDFVocab:enables CalibrationService, AnomalyDetectionService
]

instance DataProcessing : DTDFVocab:Enabler [
    base:desc "System for processing sensor data"
    DTDFVocab:enables DataAnalysisService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service for calibrating environmental sensors"
    DTDFVocab:provides CalibrationInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Service for detecting anomalies in environmental data"
    DTDFVocab:provides AnomalyInsight
]

instance DataAnalysisService : DTDFVocab:Service [
    base:desc "Service for analyzing sensor data patterns"
    DTDFVocab:provides DataAnalysisInsight
]

// C17: Insights/Actions
instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight providing calibration recommendations for sensors"
]

instance AnomalyInsight : DTDFVocab:Insight [
    base:desc "Insight highlighting detected anomalies in environmental data"
]

instance DataAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight showing patterns and trends in sensor data"
]

instance EnvironmentalAdjustment : DTDFVocab:Action [
    base:desc "Action to adjust environmental conditions based on analysis"
    DTDFVocab:IsAutomatic true
]

instance SystemOptimization : DTDFVocab:Action [
    base:desc "Action to optimize system performance based on environmental data"
    DTDFVocab:IsAutomatic false
]

instance Environment : DTDFVocab:Environment [
    base:contains RoomTemperatureSensor, TemperatureSensor, HumiditySensor, HeatbedActuator, FanActuator
]


instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control flows from digital to physical include commands for fan (on/off) and heatbed (heating duration). Message formats: structured commands via RabbitMQ (AMQP). Validation: low-level driver checks command validity before execution. Feedback systems: controller state updates sent to RabbitMQ, Kalman filter correlations for heatbed state estimation. Conflict resolution: priority given to safety protocols in low-level driver. Command execution confirmation: controller acknowledges actuation via RabbitMQ status updates."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization via RabbitMQ message brokering (100% latency-sensitive), with Kalman filter state estimation (10ms update interval), controller statechart transitions (2s fan cycle time), and self-adaptation loop (1s experiment scheduling interval). Temporal granularity for temperature sensing is 0.5°C resolution with 1s sampling frequency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated architecture with RabbitMQ as central message broker (AMQP protocol), integrated controller (bang-bang logic with H=5s, C=3s parameters), low-level driver (safe protocol for PT interaction), and calibrated models (Model B with 4 free parameters). System-wide coordination includes Kalman filter state estimation, co-simulation with PT data, and adaptive reconfiguration via self-loop mechanisms."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle includes development (model creation with 2/4 free parameters), calibration (Model B for thermal inertia prediction), operational phases (real-time monitoring via RabbitMQ and Kalman filter), and self-adaptation (dynamic reconfiguration upon anomalies). Transition management involves iterative calibration and model updates. Governance includes open-source repository maintenance and version control via GitHub."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity: Calibration experiments (Model A/B parameters) and Kalman filter integration for heatbed state estimation. Validation: Comparison of model predictions (e.g., temperature uniformity) with sensor data (e.g., 7°C discrepancy in baseline vs. 6°C with 18V fan). Uncertainty sources: sensor noise, environmental variations, and model parameter approximations. Error correction: Kalman filter for anomaly detection, automatic calibration workflows, and co-simulations with historical data. Quality assurance: Open-source hardware/software for reproducibility and parameter tuning via experiments."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Technical network infrastructure uses RabbitMQ (AMQP protocol) for bidirectional communication. Network topology: edge (Raspberry Pi) <-> cloud/on-premise RabbitMQ server. Bandwidth requirements: sufficient for real-time temperature data (0.02 m³/s airflow) and control signals. Latency: <2 seconds for fan/heatbed actuation. Reliability: redundant communication via RabbitMQ's message persistence. Security: open-source RabbitMQ with TLS/SSL for encrypted communication (implied by standard practices)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment infrastructure uses Raspberry Pi 4 Model B (edge device) as host. Computational requirements: 4A current handling via MOSFETs, real-time control logic (bang-bang algorithm). Storage: time-series database for temperature data (dashboard integration). Scalability: modular architecture allows adding sensors/actuators. Deployment models: edge (Raspberry Pi) + cloud (RabbitMQ server). Availability: 99.9% uptime via redundant communication and power supply."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability via RabbitMQ (open-source message broker), Raspberry Pi's Wi-Fi/Bluetooth for wireless deployment, and GitHub-hosted open-source repository. Integration patterns include: 1-Wire bus for temperature sensors, co-simulation with external systems, and model calibration using sensor data from PT. Dependencies on external systems include sensor networks and cloud-based data storage."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Complies with CPS frameworks (e.g., IEEE 1800-2015), open-source protocols (RabbitMQ, 1-Wire), and industry standards for IoT device communication. Interoperability is achieved through standardized messaging (AMQP) and modular component design (e.g., separable controller/low-level driver architecture)."
]