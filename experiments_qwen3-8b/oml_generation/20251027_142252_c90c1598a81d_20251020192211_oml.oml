// C2: Acting Components
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan with 0.02 m³/s airflow and 18V operation for air circulation"
]

instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed controlled by Raspberry Pi 4 Model B via MOSFETs (4A current handling) with optocouplers for signal isolation"
]

// C3: Physical sensing components
instance RoomTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire digital thermometer measuring room temperature"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HotSpotTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire digital thermometer monitoring hottest position in box"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance ColdSpotTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire digital thermometer monitoring coldest position in box"
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTemperatureSensor, HotSpotTemperatureSensor, ColdSpotTemperatureSensor
]

// C10: Models/Data
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Thermal model with 2 parameters: C_air=616.56 J/K, G_box=0.65 J/K"
    DTDFVocab:inputTo KalmanFilterEnabler, ModelBEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Thermal model with 4 parameters: C_air=486.12 J/K, G_box=0.856 J/K, C_heater=33.65 J/K, G_heater=0.87 J/K"
    DTDFVocab:inputTo ModelBEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature readings from DS18S20 sensors (-55°C to +125°C, ±0.5°C accuracy)"
    DTDFVocab:fromData TemperatureDataTransmitted
]

instance HistoricalData : DTDFVocab:Data [
    base:desc "Historical temperature data for co-simulations"
    DTDFVocab:fromData TemperatureDataTransmitted
]

instance RabbitMQData : DTDFVocab:Data [
    base:desc "Real-time data streaming from RabbitMQ server"
    DTDFVocab:fromData TemperatureDataTransmitted
]

// C6: Services
instance ControlLogicService : DTDFVocab:Service [
    base:desc "Bang-bang control logic with parameters H (heating duration), C (waiting duration)"
    DTDFVocab:provides DynamicReconfigurationAction
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Dashboard for real-time visualization of incubator status with time-series data"
    DTDFVocab:provides TemperatureVisualizationInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "On-demand calibration using Model B (4-parameter thermal model) for parameter estimation"
    DTDFVocab:provides ModelCalibrationInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection and heatbed state estimation via Kalman filter"
    DTDFVocab:provides AnomalyDetectionInsight, HeatbedStateEstimationInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What-if simulations for controller optimization using co-simulations"
    DTDFVocab:provides SimulationInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Self-adaptation loop for dynamic reconfiguration of controllers"
    DTDFVocab:provides DynamicReconfigurationAction
]

// C11: Enablers
instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "Open-source message broker for communication between controller, low-level driver, and DT components"
    DTDFVocab:enables RealTimeVisualizationService, AnomalyDetectionService
]

instance RaspberryPiController : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B implementing bang-bang control logic with GPIO interfaces"
    DTDFVocab:enables CalibrationService, ControlLogicService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter for state estimation and confidence measure calculation"
    DTDFVocab:enables AnomalyDetectionService, HeatbedStateEstimationInsight
]

instance ModelBEnabler : DTDFVocab:Enabler [
    base:desc "4-parameter thermal model for predicting heatbed inertia and parameter estimation"
    DTDFVocab:enables CalibrationService, WhatIfSimulationService
]

instance TimeSeriesDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database for storing sensor data and dashboard visualization"
    DTDFVocab:enables RealTimeVisualizationService, ModelBEnabler
]

// C17: Insights/Actions
instance TemperatureVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time temperature visualization via dashboard with time-series data"
]

instance ModelCalibrationInsight : DTDFVocab:Insight [
    base:desc "Confidence measures derived from Kalman filter residuals and model calibration accuracy"
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection via Kalman filter correlating measured data to non-measured heatbed temperature"
]

instance HeatbedStateEstimationInsight : DTDFVocab:Insight [
    base:desc "Heatbed state estimation using Kalman filter residuals and model calibration accuracy"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Thermal behavior prediction and controller optimization through what-if simulations"
]

instance DynamicReconfigurationAction : DTDFVocab:Action [
    base:desc "Dynamic reconfiguration of controllers for new scenarios (e.g., introducing cold objects)"
    DTDFVocab:IsAutomatic true
]

// C1: Components
instance InsulatedContainer : DTDFVocab:Component [
    base:desc "Insulated styrofoam box with volume 0.03 m³"
]

instance HeatbedComponent : DTDFVocab:Component [
    base:desc "Heatbed with thermal inertia requiring predictive modeling"
]

instance FanComponent : DTDFVocab:Component [
    base:desc "Fan for air circulation with 0.02 m³/s airflow"
]

instance TemperatureSensorComponent : DTDFVocab:Component [
    base:desc "DS18S20 1-Wire digital thermometer with 64-bit serial codes"
]

// C12: Environments
instance ControlledEnvironment : DTDFVocab:Environment [
    base:contains InsulatedContainer, HeatbedComponent, FanComponent, TemperatureSensorComponent
]


instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control flows from digital to physical include commands for fan (on/off) and heatbed (heating duration). Message formats: structured commands via RabbitMQ (AMQP). Validation: low-level driver checks command validity before execution. Feedback systems: controller state updates sent to RabbitMQ, Kalman filter correlations for heatbed state estimation. Conflict resolution: priority given to safety protocols in low-level driver. Command execution confirmation: controller acknowledges actuation via RabbitMQ status updates."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization via RabbitMQ message brokering (100% latency-sensitive), with Kalman filter state estimation (10ms update interval), controller statechart transitions (2s fan cycle time), and self-adaptation loop (1s experiment scheduling interval). Temporal granularity for temperature sensing is 0.5°C resolution with 1s sampling frequency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated architecture with RabbitMQ as central message broker (AMQP protocol), integrated controller (bang-bang logic with H=5s, C=3s parameters), low-level driver (safe protocol for PT interaction), and calibrated models (Model B with 4 free parameters). System-wide coordination includes Kalman filter state estimation, co-simulation with PT data, and adaptive reconfiguration via self-loop mechanisms."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle includes development (model creation with 2/4 free parameters), calibration (Model B for thermal inertia prediction), operational phases (real-time monitoring via RabbitMQ and Kalman filter), and self-adaptation (dynamic reconfiguration upon anomalies). Transition management involves iterative calibration and model updates. Governance includes open-source repository maintenance and version control via GitHub."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity: Calibration experiments (Model A/B parameters) and Kalman filter integration for heatbed state estimation. Validation: Comparison of model predictions (e.g., temperature uniformity) with sensor data (e.g., 7°C discrepancy in baseline vs. 6°C with 18V fan). Uncertainty sources: sensor noise, environmental variations, and model parameter approximations. Error correction: Kalman filter for anomaly detection, automatic calibration workflows, and co-simulations with historical data. Quality assurance: Open-source hardware/software for reproducibility and parameter tuning via experiments."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Technical network infrastructure uses RabbitMQ (AMQP protocol) for bidirectional communication. Network topology: edge (Raspberry Pi) <-> cloud/on-premise RabbitMQ server. Bandwidth requirements: sufficient for real-time temperature data (0.02 m³/s airflow) and control signals. Latency: <2 seconds for fan/heatbed actuation. Reliability: redundant communication via RabbitMQ's message persistence. Security: open-source RabbitMQ with TLS/SSL for encrypted communication (implied by standard practices)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment infrastructure uses Raspberry Pi 4 Model B (edge device) as host. Computational requirements: 4A current handling via MOSFETs, real-time control logic (bang-bang algorithm). Storage: time-series database for temperature data (dashboard integration). Scalability: modular architecture allows adding sensors/actuators. Deployment models: edge (Raspberry Pi) + cloud (RabbitMQ server). Availability: 99.9% uptime via redundant communication and power supply."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability via RabbitMQ (open-source message broker), Raspberry Pi's Wi-Fi/Bluetooth for wireless deployment, and GitHub-hosted open-source repository. Integration patterns include: 1-Wire bus for temperature sensors, co-simulation with external systems, and model calibration using sensor data from PT. Dependencies on external systems include sensor networks and cloud-based data storage."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Complies with CPS frameworks (e.g., IEEE 1800-2015), open-source protocols (RabbitMQ, 1-Wire), and industry standards for IoT device communication. Interoperability is achieved through standardized messaging (AMQP) and modular component design (e.g., separable controller/low-level driver architecture)."
]