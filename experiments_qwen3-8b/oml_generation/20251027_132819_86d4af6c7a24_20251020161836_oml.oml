// C3: Physical sensing components
instance DS18S20TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensors measuring thermal data with spatial distribution across incubator"
]

// C4: Physical-to-virtual interaction
instance TemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20TemperatureSensor
]

// C10: Models/Data
instance TimeSeriesDatabase : DTDFVocab:Data [
    base:desc "Time-series database storing sensor data for real-time visualization and dashboard plotting"
    DTDFVocab:fromData TemperatureData
]

// C11: Enablers
instance RabbitMQCommunicationServer : DTDFVocab:Enabler [
    base:desc "RabbitMQ server for message brokering between controller, low-level driver, and DT components"
    DTDFVocab:inputTo TimeSeriesDatabase, KalmanFilterStateEstimator
]

instance KalmanFilterStateEstimator : DTDFVocab:Enabler [
    base:desc "Kalman filter for state estimation and anomaly detection of heatbed temperature"
    DTDFVocab:inputTo TimeSeriesDatabase, TimeSeriesDatabase
]

instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithms updating models with parameters (e.g., Model A: C_air=616.56, G_box=0.65)"
    DTDFVocab:inputTo TwoParameterThermalModel, FourParameterThermalModel
]

instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Low-level driver with safety protocols for PT interaction"
    DTDFVocab:inputTo TimeSeriesDatabase
]

// C10: Models/Data
instance TwoParameterThermalModel : DTDFVocab:Model [
    base:desc "Two-parameter simulation model for thermal inertia prediction with parameters C_air (J K⁻¹), G_box (J K⁻¹)"
    DTDFVocab:inputTo KalmanFilterStateEstimator
]

instance FourParameterThermalModel : DTDFVocab:Model [
    base:desc "Four-parameter simulation model for thermal inertia prediction with parameters C_air (J K⁻¹), G_box (J K⁻¹), C_heater (J K⁻¹), G_heater (J K⁻¹)"
    DTDFVocab:inputTo KalmanFilterStateEstimator
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real-time visualization of incubator status via dashboard plotting of time-series data from controller and driver messages"
    DTDFVocab:provides DashboardVisualizationInsight, RealTimeDataMonitoringAction
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "On-demand calibration using automated parameter estimation (Model B with four free parameters)"
    DTDFVocab:provides ParameterEstimationInsight, ModelCalibrationAction
]

instance KalmanFilterAnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection and heatbed state estimation via Kalman filter correlation of measured data to unmeasured heatbed temperature"
    DTDFVocab:provides AnomalyDetectionInsight, HeatbedStateEstimationAction
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What-if simulations through co-simulations using historical/real-time PT data"
    DTDFVocab:provides ScenarioAnalysisInsight, PredictiveControlAction
]

instance SelfAdaptationLoopService : DTDFVocab:Service [
    base:desc "Self-adaptation loop enabling dynamic reconfiguration of the controller in response to environmental changes (e.g., introducing cold objects)"
    DTDFVocab:provides DynamicReconfigurationAction
]

// C17: Insights/Actions
instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of incubator status via dashboard plotting"
]

instance RealTimeDataMonitoringAction : DTDFVocab:Action [
    base:desc "Monitoring of time-series data from controller and driver messages"
    DTDFVocab:IsAutomatic true
]

instance ParameterEstimationInsight : DTDFVocab:Insight [
    base:desc "Automated parameter estimation for Model B with four free parameters"
]

instance ModelCalibrationAction : DTDFVocab:Action [
    base:desc "Calibration using automated parameter estimation"
    DTDFVocab:IsAutomatic true
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection via Kalman filter correlation of measured data to unmeasured heatbed temperature"
]

instance HeatbedStateEstimationAction : DTDFVocab:Action [
    base:desc "Heatbed state estimation using Kalman filter residuals"
    DTDFVocab:IsAutomatic true
]

instance ScenarioAnalysisInsight : DTDFVocab:Insight [
    base:desc "Scenario analysis through co-simulations using historical/real-time PT data"
]

instance PredictiveControlAction : DTDFVocab:Action [
    base:desc "Predictive control through what-if simulations"
    DTDFVocab:IsAutomatic true
]

instance DynamicReconfigurationAction : DTDFVocab:Action [
    base:desc "Dynamic reconfiguration of the controller in response to environmental changes"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed with thermal actuation and parameters C_heater=33.65 J K⁻¹, G_heater=0.87 J K⁻¹"
]

instance BangBangController : DTDFVocab:ActingComponent [
    base:desc "Bang-bang controller implementation for temperature regulation"
]

// C1: Physical components
instance ControllerComponent : DTDFVocab:Component [
    base:desc "Controller implementing bang-bang control logic and scheduling experiments (e.g., cooling to safe temperatures, ramping heating)"
]

instance LowLevelDriverComponent : DTDFVocab:Component [
    base:desc "Low-level driver with safety protocols for PT interaction"
]

instance CommunicationServerComponent : DTDFVocab:Component [
    base:desc "Communication server relaying data to models and monitoring system state changes"
]

instance TimeSeriesDatabaseComponent : DTDFVocab:Component [
    base:desc "Time-series database storing and visualizing sensor data"
]

instance KalmanFilterComponent : DTDFVocab:Component [
    base:desc "Kalman filter for state estimation and anomaly detection"
]

instance CalibrationAlgorithmComponent : DTDFVocab:Component [
    base:desc "Calibration algorithms updating models with best parameter estimates"
]

instance SimulationModelComponent : DTDFVocab:Component [
    base:desc "Simulation models (two-parameter and four-parameter variants) for thermal inertia prediction"
]

instance PhysicalTwinComponent : DTDFVocab:Component [
    base:desc "Physical Twin (PT) as thermal incubator system with insulated box, heatbed, sensors, controller, and software system for communication and simulation"
]

instance EnvironmentComponent : DTDFVocab:Environment [
    base:contains HeatbedActuator, BangBangController, ControllerComponent, LowLevelDriverComponent, CommunicationServerComponent, TimeSeriesDatabaseComponent, KalmanFilterComponent, CalibrationAlgorithmComponent, SimulationModelComponent, PhysicalTwinComponent
]


instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (fan/heatbed control) sent via RabbitMQ messages. Command types: actuator control signals. Message formats: structured messages through RabbitMQ. Validation: safe protocol in low-level driver ensures device safety. Feedback systems: Kalman filter correlates measured data to heatbed temperature. Conflict resolution: prioritizes safety protocols in low-level driver. Command execution confirmation: low-level driver confirms state updates to RabbitMQ."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization between physical and digital components via RabbitMQ message broker (AMQP protocol), with Kalman filter processing of historical/real-time data for anomaly detection. Self-adaptation loop requires low-latency response to detect plant behavior changes and reconfigure controller parameters."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated integration of modeling, simulation, monitoring, and optimization technologies. Components include RabbitMQ for message passing between controller and low-level driver, Kalman filter for state estimation, co-simulation for what-if scenarios, and time-series databases for visualization. System-wide coordination involves parameter calibration and dynamic reconfiguration of the Kalman filter."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin (DT) lifecycle includes development stages such as model calibration (section 3), deployment with real-time visualization (section 4), and ongoing adaptation via self-adaptation loops (section 4). Representation types transition from initial simulation models (two/four free parameters) to integrated systems with Kalman filters and co-simulations. Lifecycle governance involves continuous calibration, model reconfiguration, and interoperability through RabbitMQ [4] for data exchange between PT and DT."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity requires parameter calibration (e.g., Model B's four parameters outperform Model A's two for thermal inertia prediction). Validation methods include co-simulations, Kalman filters, and comparison with historical/real-time PT data. Uncertainty sources include sensor accuracy, model parameter estimation, and environmental variability. Error detection uses Kalman filters for anomaly detection, and quality assurance involves iterative calibration and self-adaptation loops."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication protocols: RabbitMQ (message broker) for sensor-actuator and twin communication. Network topology: client-server architecture (RabbitMQ server on Raspberry Pi). Bandwidth/latency: lightweight RabbitMQ ensures low-latency messaging. Reliability: RabbitMQ's mature, fault-tolerant design. Security: safe protocol in low-level driver for device safety. Redundancy: no explicit redundancy mentioned, but RabbitMQ's deployment flexibility supports failover."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosting platforms: Raspberry Pi (edge) with optional cloud deployment. Computational requirements: Raspberry Pi handles control logic and data processing. Storage: time-series database for dashboard visualization. Scalability: open-source architecture supports modular expansion. Deployment models: edge (Raspberry Pi) and cloud. Availability: RabbitMQ's deployment flexibility ensures uptime. Reliability: RabbitMQ's lightweight design and safe protocol ensure system stability."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Data exchange via RabbitMQ (AMQP protocol) with external systems. Open-source hardware/software repository enables integration with third-party tools. Communication server acts as a bridge for data exchange between physical twin and digital twin components, supporting interoperability with enterprise systems through standardized messaging."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Complies with open-source standards (GitHub [2]), RabbitMQ [4] message broker protocols, and Industry 4.0 integration frameworks. Interoperability is achieved through standardized communication interfaces (RabbitMQ) and modular component design. Certification requirements are implied via open-source compliance and adherence to CPS modeling practices."
]