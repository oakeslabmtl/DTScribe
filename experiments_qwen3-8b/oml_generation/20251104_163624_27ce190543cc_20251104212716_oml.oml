// Return code: 1 | Stderr:
// C2: Acting Components
instance BangBangController : DTDFVocab:ActingComponent [
    base:desc "Bang-bang controller with parameters LL (lower limit), UL (upper limit), H (heating duration), and C (waiting duration)"
]

instance LowLevelDriver : DTDFVocab:ActingComponent [
    base:desc "Low-level driver for interacting with the Physical Twin, handling sensor/actuator interfacing"
]

// C3: Physical sensing components
instance T1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor (T1) placed in the incubator for spatial temperature distribution measurement"
    DTDFVocab:producedData TemperatureSensorData1
]

instance T2 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor (T2) placed in the incubator for spatial temperature distribution measurement"
    DTDFVocab:producedData TemperatureSensorData2
]

instance T3 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor (T3) placed in the incubator for spatial temperature distribution measurement"
    DTDFVocab:producedData TemperatureSensorData3
]

// C4: Physical-to-virtual interaction
instance TemperatureSensorData1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom T1
]

instance TemperatureSensorData2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom T2
]

instance TemperatureSensorData3 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom T3
]

instance TemperatureMeasurements : DTDFVocab:Data [
    base:desc "Temperature measurements (in °C) from DS18S20 sensors"
    DTDFVocab:fromData TemperatureSensorData1, TemperatureSensorData2, TemperatureSensorData3
    DTDFVocab:inputTo RabbitMQ, KalmanFilters
]

instance FanCommands : DTDFVocab:Data [
    base:desc "Fan/heatbed commands (on/off, speed) transmitted via RabbitMQ"
    DTDFVocab:fromData RabbitMQ
    DTDFVocab:inputTo KalmanFilters, CalibrationAlgorithms
]

instance SystemStatus : DTDFVocab:Data [
    base:desc "System status data (e.g., sensor health, communication status)"
    DTDFVocab:fromData RabbitMQ
    DTDFVocab:inputTo KalmanFilters, CalibrationAlgorithms
]

// C10: Models/Data
instance ModelA : DTDFVocab:Model [
    base:desc "Simulation model with 2 free parameters for thermal behavior prediction"
    DTDFVocab:inputTo KalmanFilters, CalibrationAlgorithms
]

instance ModelB : DTDFVocab:Model [
    base:desc "Simulation model with 4 free parameters for thermal behavior prediction, calibrated with C_air (616.56 J/K) and G_box (0.65 J/K)"
    DTDFVocab:inputTo KalmanFilters, CalibrationAlgorithms
]

instance ThermalInertiaModel : DTDFVocab:Model [
    base:desc "Analytical model for heatbed thermal inertia calculation"
    DTDFVocab:inputTo KalmanFilters, CalibrationAlgorithms
]

instance GeometricModel : DTDFVocab:Model [
    base:desc "CAD-based geometric model of the incubator enclosure"
    DTDFVocab:inputTo KalmanFilters, CalibrationAlgorithms
]

// C11: Enablers
instance RabbitMQ : DTDFVocab:Enabler [
    base:desc "Message broker for communication between physical and digital twin components"
    DTDFVocab:enables RealTimeVisualizationService, CalibrationService, AnomalyDetectionService
]

instance KalmanFilters : DTDFVocab:Enabler [
    base:desc "Kalman filter algorithms for state estimation and fault detection"
    DTDFVocab:enables AnomalyDetectionService, WhatIfSimulationService
]

instance CalibrationAlgorithms : DTDFVocab:Enabler [
    base:desc "Calibration algorithms for updating model parameters (e.g., C_air, G_box)"
    DTDFVocab:enables CalibrationService, WhatIfSimulationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real-time dashboard for visualizing incubator status (temperature, fan/heatbed commands)"
    DTDFVocab:provides AnomalyDetectionInsight, ReconfigureControllerAction
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "On-demand calibration of simulation models (e.g., Model B)"
    DTDFVocab:provides ModelBCalibrationInsight, UpdateModelAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection using Kalman filters and Model B for system behavior validation"
    DTDFVocab:provides AnomalyDetectionInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Co-simulation for what-if scenarios (e.g., changing environmental conditions)"
    DTDFVocab:provides WhatIfSimulationInsight, UpdateModelAction
]

instance SelfAdaptationLoopService : DTDFVocab:Service [
    base:desc "Self-adaptation loop for adjusting system behavior when PT behavior changes"
    DTDFVocab:provides SelfAdaptationInsight, ReconfigureControllerAction
]

// C17: Insights/Actions
instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight from Kalman filter analysis indicating system anomalies"
]

instance ModelBCalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight from Model B calibration indicating parameter updates (e.g., C_air, G_box)"
]

instance WhatIfSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from what-if simulations for controller optimization"
]

instance SelfAdaptationInsight : DTDFVocab:Insight [
    base:desc "Insight from self-adaptation loops indicating environmental changes (e.g., cold water addition)"
]

instance ReconfigureControllerAction : DTDFVocab:Action [
    base:desc "Action to reconfigure controller parameters (LL, UL, H, C) based on insights"
    DTDFVocab:IsAutomatic true
]

instance UpdateModelAction : DTDFVocab:Action [
    base:desc "Action to update simulation models (e.g., Model B) with new parameter estimates"
    DTDFVocab:IsAutomatic false
]

// C1: Components
instance InsulatedBox : DTDFVocab:Component [
    base:desc "Insulated enclosure of the thermal incubator"
]

instance Heatbed : DTDFVocab:Component [
    base:desc "Heatbed with thermal inertia properties (G_box = 0.65 J/K)"
]

instance Fan : DTDFVocab:Component [
    base:desc "Fan for air circulation with airflow rate 0.02 m³/s"
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B controller with GPIO for sensor/actuator interfacing"
]

instance CommunicationServer : DTDFVocab:Component [
    base:desc "RabbitMQ communication server for message passing between components"
]

instance LowLevelDriverComponent : DTDFVocab:Component [
    base:desc "Low-level driver for interacting with the Physical Twin, handling sensor/actuator interfacing"
]

// C18: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InsulatedBox, Heatbed, Fan, RaspberryPiController, CommunicationServer, LowLevelDriverComponent
]


instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands from the digital twin (e.g., temperature setpoints) are sent to the physical incubator via the RabbitMQ server. Command types include fan speed adjustments and heatbed activation. Control message format: binary or JSON over RabbitMQ. Validation: commands are checked against safe temperature limits (LL/UL parameters). Feedback systems: temperature sensor data is sent back to the digital twin. Conflict resolution: controller state machine ensures no conflicting commands. Command execution confirmation: RabbitMQ acknowledgments and controller state updates."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time data synchronization via RabbitMQ with a 2-second air circulation cycle (fan airflow: 0.02 m³/s, box volume: 0.03 m³). Kalman filter operates on measured temperature data with Model B for heatbed state estimation. Controller state transitions (Figure 8) have defined timing parameters (LL, UL, H, C)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Architecture includes: 1) Controller (Raspberry Pi 4 with GPIO), 2) Low-level driver (PT state management via RabbitMQ), 3) Communication server (RabbitMQ for message passing), 4) Temperature sensors (DS18S20), 5) Fan (0.02 m³/s airflow), 6) PCB with optocouplers and MOSFETs. Integration of simulation models (Model A/B), Kalman filter, and co-simulation for what-if scenarios."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin (DT) lifecycle includes development, deployment, and operation phases. During development, the incubator's physical twin (PT) is modeled with simulation tools (e.g., two thermal models with 2 and 4 parameters). Deployment involves integrating hardware (Raspberry Pi, RabbitMQ server) and software (controller, low-level driver) to monitor and control the PT. Operation includes real-time data collection, calibration, and adaptation. The self-adaptation loop (Document 5) is a key phase where the DT dynamically adjusts to changes (e.g., adding a cold water bucket), involving data gathering, model recalibration, and controller reconfiguration. Lifecycle governance involves integrating models into the DT framework and maintaining version control through calibration processes."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity requires parameters like C_air and G_box for accurate thermal predictions. Validation uses calibration experiments and comparison between Model A and B (Model B better for heatbed inertia). Uncertainty sources include sensor placement, fan voltage, and environmental factors. Error detection employs Kalman filters to correlate measured data with non-measured heatbed temperatures. Quality assurance involves repeated experiments, parameter calibration, and co-simulations for what-if scenarios."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Network infrastructure uses RabbitMQ (open-source message broker) for bidirectional communication. Topology: Raspberry Pi (controller) acts as a client, RabbitMQ server as central hub. Bandwidth: not specified, but RabbitMQ is lightweight. Latency: low due to RabbitMQ's efficiency. Reliability: message acknowledgments and redundancy in communication server. Security: not explicitly mentioned, but RabbitMQ supports TLS for secure data transmission."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosting platform: on-premise (Raspberry Pi 4 Model B and RabbitMQ server). Computational requirements: Raspberry Pi's GPIO and processing power. Storage: RabbitMQ server stores data. Scalability: not discussed, but designed for single incubator. Deployment models: on-premise with potential cloud integration (not explicitly stated). Availability: ensured by Raspberry Pi's reliability and RabbitMQ's robustness."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with RabbitMQ (open-source message broker) for real-time data exchange between physical (PT) and digital twins. Dependencies on time series database for visualization, external sensors (DS18S20), and communication protocols (1-Wire for sensors). No explicit mention of external systems beyond the incubator's own components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT adheres to IEEE standards for digital twin frameworks (e.g., [4][5]) and uses FMI (Functional Mockup Interface) for model interoperability (Document 6). RabbitMQ (Document 3) is a protocol for communication, and Python FMUs enable rapid prototyping. Calibration processes follow methodologies described in [15], and the DT integrates with industry standards for cyber-physical systems (CPS) [1]. The use of time series databases and formal methods (Document 7) ensures compliance with modeling and simulation standards. Interoperability is achieved through open-source tools (RabbitMQ, Python) and standardized data formats (e.g., FMI)."
]