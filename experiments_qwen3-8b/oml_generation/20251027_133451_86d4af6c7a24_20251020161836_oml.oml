// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Thermal actuation component for temperature regulation with heating parameters (C_heater=33.65 J K⁻¹)"
]

instance BangBangController : DTDFVocab:ActingComponent [
    base:desc "Cyber-physical interface implementing bang-bang control logic for temperature regulation"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature measurement device with J K⁻¹ unit, spatially distributed across incubator"
    DTDFVocab:producedData TemperatureData
]

// C4: Physical-to-virtual interaction
instance TemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C10: Models/Data
instance ThermalInertiaModel : DTDFVocab:Model [
    base:desc "Simulation model with parameters: C_air=486.12 J K⁻¹, G_box=0.856 J K⁻¹, C_heater=33.65 J K⁻¹, G_heater=0.87 J K⁻¹"
    DTDFVocab:inputTo KalmanFilterEnabler, ModelCalibrationEnabler
]

instance SensorData : DTDFVocab:Data [
    base:desc "Time-series sensor data stored in time-series database for visualization and dashboard plotting"
    DTDFVocab:fromData TemperatureData
]

instance CalibrationData : DTDFVocab:Data [
    base:desc "Calibrated parameter estimates used for model updates (e.g., Model B's thermal inertia prediction)"
    DTDFVocab:fromData TemperatureData
]

// C11: Enablers
instance RabbitMQCommunication : DTDFVocab:Enabler [
    base:desc "Message brokering server for communication between controller, low-level driver, and DT components"
    DTDFVocab:enables RealTimeVisualizationService, CoSimulationService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "State estimation and anomaly detection framework correlating measured data to unmeasured heatbed temperature"
    DTDFVocab:enables AnomalyDetectionService, HeatbedStateEstimationService
]

instance ModelCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Model calibration algorithms updating parameters (e.g., Model A: C_air=616.56, G_box=0.65)"
    DTDFVocab:enables OnDemandCalibrationService
]

instance CoSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Co-simulation framework for integrating physical and virtual system behaviors"
]

// Added Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real-time visualization of incubator status via dashboard plotting of time-series data from controller and driver messages"
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection and heatbed state estimation via Kalman filter correlation of measured data to unmeasured heatbed temperature"
]

instance HeatbedStateEstimationService : DTDFVocab:Service [
    base:desc "State estimation of heatbed temperature using Kalman filter correlation with measured data"
]

instance OnDemandCalibrationService : DTDFVocab:Service [
    base:desc "On-demand calibration using automated parameter estimation (Model B with four free parameters)"
]

instance CoSimulationService : DTDFVocab:Service [
    base:desc "Co-simulation framework for integrating physical and virtual system behaviors"
]


instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (fan/heatbed control) sent via RabbitMQ messages. Command types: actuator control signals. Message formats: structured messages through RabbitMQ. Validation: safe protocol in low-level driver ensures device safety. Feedback systems: Kalman filter correlates measured data to heatbed temperature. Conflict resolution: prioritizes safety protocols in low-level driver. Command execution confirmation: low-level driver confirms state updates to RabbitMQ."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization between physical and digital components via RabbitMQ message broker (AMQP protocol), with Kalman filter processing of historical/real-time data for anomaly detection. Self-adaptation loop requires low-latency response to detect plant behavior changes and reconfigure controller parameters."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated integration of modeling, simulation, monitoring, and optimization technologies. Components include RabbitMQ for message passing between controller and low-level driver, Kalman filter for state estimation, co-simulation for what-if scenarios, and time-series databases for visualization. System-wide coordination involves parameter calibration and dynamic reconfiguration of the Kalman filter."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin (DT) lifecycle includes development stages such as model calibration (section 3), deployment with real-time visualization (section 4), and ongoing adaptation via self-adaptation loops (section 4). Representation types transition from initial simulation models (two/four free parameters) to integrated systems with Kalman filters and co-simulations. Lifecycle governance involves continuous calibration, model reconfiguration, and interoperability through RabbitMQ [4] for data exchange between PT and DT."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity requires parameter calibration (e.g., Model B's four parameters outperform Model A's two for thermal inertia prediction). Validation methods include co-simulations, Kalman filters, and comparison with historical/real-time PT data. Uncertainty sources include sensor accuracy, model parameter estimation, and environmental variability. Error detection uses Kalman filters for anomaly detection, and quality assurance involves iterative calibration and self-adaptation loops."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication protocols: RabbitMQ (message broker) for sensor-actuator and twin communication. Network topology: client-server architecture (RabbitMQ server on Raspberry Pi). Bandwidth/latency: lightweight RabbitMQ ensures low-latency messaging. Reliability: RabbitMQ's mature, fault-tolerant design. Security: safe protocol in low-level driver for device safety. Redundancy: no explicit redundancy mentioned, but RabbitMQ's deployment flexibility supports failover."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosting platforms: Raspberry Pi (edge) with optional cloud deployment. Computational requirements: Raspberry Pi handles control logic and data processing. Storage: time-series database for dashboard visualization. Scalability: open-source architecture supports modular expansion. Deployment models: edge (Raspberry Pi) and cloud. Availability: RabbitMQ's deployment flexibility ensures uptime. Reliability: RabbitMQ's lightweight design and safe protocol ensure system stability."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Data exchange via RabbitMQ (AMQP protocol) with external systems. Open-source hardware/software repository enables integration with third-party tools. Communication server acts as a bridge for data exchange between physical twin and digital twin components, supporting interoperability with enterprise systems through standardized messaging."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Complies with open-source standards (GitHub [2]), RabbitMQ [4] message broker protocols, and Industry 4.0 integration frameworks. Interoperability is achieved through standardized communication interfaces (RabbitMQ) and modular component design. Certification requirements are implied via open-source compliance and adherence to CPS modeling practices."
]