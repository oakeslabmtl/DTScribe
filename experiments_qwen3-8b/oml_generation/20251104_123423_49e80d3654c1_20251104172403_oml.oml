// C3: Physical sensing components
instance TemperatureSensorT1 : DTDFVocab:SensingComponent [
    base:desc "3 temperature sensors (T1/T2/T3) with spatial distribution (hottest/coldest positions), room temperature sensor (T1)"
    DTDFVocab:producedData TemperatureData
]

instance TemperatureSensorT2 : DTDFVocab:SensingComponent [
    base:desc "3 temperature sensors (T1/T2/T3) with spatial distribution (hottest/coldest positions), room temperature sensor (T1)"
    DTDFVocab:producedData TemperatureData
]

instance TemperatureSensorT3 : DTDFVocab:SensingComponent [
    base:desc "3 temperature sensors (T1/T2/T3) with spatial distribution (hottest/coldest positions), room temperature sensor (T1)"
    DTDFVocab:producedData TemperatureData
]

// C4: Physical-to-virtual interaction
instance TemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT1, TemperatureSensorT2, TemperatureSensorT3
]

// C10: Models/Data
instance TemperatureDataData : DTDFVocab:Data [
    base:desc "Time series database for visualization"
    DTDFVocab:fromData TemperatureData
    DTDFVocab:inputTo KalmanFilterEnabler, TimeSeriesDatabaseEnabler
]

instance ModelA : DTDFVocab:Model [
    base:desc "Dynamic models (differential equations) for thermal behavior, simulation model A (2 free parameters)"
    DTDFVocab:inputTo KalmanFilterEnabler, FaultDetectorEnabler
]

instance ModelB : DTDFVocab:Model [
    base:desc "Dynamic models (differential equations) for thermal behavior, simulation model B (4 free parameters)"
    DTDFVocab:inputTo KalmanFilterEnabler, OptimizerEnabler
]

// C11: Enablers
instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ (message broker for communication server) enabling real-time data exchange between controller, low-level driver, and digital twin"
    DTDFVocab:enables DataTransmissionService, AnomalyDetectionService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter for state estimation"
    DTDFVocab:enables AnomalyDetectionService, HeatbedStateEstimationService
]

instance TimeSeriesDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Time series database for dashboard visualization"
    DTDFVocab:enables DataTransmissionService
]

instance FaultDetectorEnabler : DTDFVocab:Enabler [
    base:desc "Fault detectors for calibration (Model A parameters: C_air=616.56 J/K, G_box=0.65 J/K)"
    DTDFVocab:enables CalibrationService
]

instance OptimizerEnabler : DTDFVocab:Enabler [
    base:desc "Optimizers for calibration (Model B parameters: C_air=486.12 J/K, G_box=0.856 J/K, C_heater=33.65 J/K, G_heater=0.87 J/K)"
    DTDFVocab:enables CalibrationService
]

instance SelfAdaptationLoopEnabler : DTDFVocab:Enabler [
    base:desc "Self-adaptation loop enabling dynamic recalibration (e.g., adjusting to new objects like cold water buckets) through experiment scheduling, data collection, and model reconfiguration"
    DTDFVocab:enables CalibrationService
]

// C6: Services
instance DataTransmissionService : DTDFVocab:Service [
    base:desc "Real-time visualization of incubator status via dashboard (time-series data from controller/low-level driver)"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection and heatbed state estimation via Kalman filter"
    DTDFVocab:provides AnomalyDetectionInsight
]

instance HeatbedStateEstimationService : DTDFVocab:Service [
    base:desc "Heatbed state estimation via Kalman filter"
    DTDFVocab:provides HeatbedStateEstimationInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "On-demand calibration using Model B simulation"
    DTDFVocab:provides CalibrationAction
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What-if simulations for controller optimization using co-simulations with historical/real-time data"
    DTDFVocab:provides WhatIfSimulationInsight
]

// C17: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of temperature data via dashboards"
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection using Kalman filters"
]

instance HeatbedStateEstimationInsight : DTDFVocab:Insight [
    base:desc "Heatbed state estimation via Kalman filter accuracy"
]

instance CalibrationAction : DTDFVocab:Action [
    base:desc "On-demand calibration using Model B simulation"
    DTDFVocab:IsAutomatic false
]

instance WhatIfSimulationInsight : DTDFVocab:Insight [
    base:desc "What-if simulations for controller optimization using co-simulations"
]

// C12: Environment
instance IncubatorSystem : DTDFVocab:Environment [
    base:contains HeatbedComponent, FanComponent, TemperatureSensorT1, TemperatureSensorT2, TemperatureSensorT3, RaspberryPiControllerComponent, LowLevelDriverComponent, CommunicationServerComponent
]

instance HeatbedComponent : DTDFVocab:Component [
    base:desc "Insulated styrofoam box with a heatbed"
]

instance FanComponent : DTDFVocab:Component [
    base:desc "Fan for air circulation (airflow ~0.02 m³/s)"
]

instance RaspberryPiControllerComponent : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B controller with GPIO for sensor/fan actuation"
]

instance LowLevelDriverComponent : DTDFVocab:Component [
    base:desc "Low-level driver handling PT interaction"
]

instance CommunicationServerComponent : DTDFVocab:Component [
    base:desc "Communication server ensuring message routing between components"
]


instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (heating duration, fan control) are sent from the Digital Twin to the Raspberry Pi controller via RabbitMQ. Command formats include structured messages with parameters like H (heating duration) and C (waiting duration). Validation occurs through the low-level driver's safe protocol. Feedback systems use temperature sensor data for closed-loop control. Conflict resolution is handled via the controller's statechart (Fig. 8). Command execution confirmation is implied through system state updates and error handling in the communication server."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin synchronizes with the physical twin via RabbitMQ at real-time intervals, with controller parameters defining heating (H) and waiting (C) durations. Kalman filters process data in real-time for state estimation, and co-simulations use historical or real-time data from the physical twin. The fan circulates air within 2 seconds, and temperature sensors provide feedback at intervals dictated by the low-level driver's polling frequency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin integrates models (e.g., Model B for thermal inertia prediction), data from sensors, and algorithms (e.g., Kalman filters, calibration routines) within a layered architecture. The communication server (RabbitMQ) acts as a central hub for message exchange, while co-simulations and what-if scenarios enable system-wide coordination. Calibration algorithms dynamically update models based on real-time data, and the self-adaptation loop reconfigures the controller based on detected anomalies."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle includes development stages such as modeling (e.g., thermal inertia prediction with Model B), calibration (automated calibration process in section 3.3), and real-time monitoring. Representation types transition from simulation models (e.g., Model B with four free parameters) to operational data integration via RabbitMQ. Transition management involves self-adaptation loops (e.g., detecting plant behavior changes, scheduling experiments, reconfiguring controllers). Governance includes open-source platform maintenance and version control via GitHub."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity: Model B achieves 6°C max discrepancy vs 7°C for Model A. Validation: calibration experiments (18V fan test), Kalman filter correlation with non-measured heatbed temperature. Uncertainty sources: sensor placement, environmental factors (wind flow). Error detection: Kalman filter anomalies, deviation thresholds (7°C). Quality assurance: re-calibration after state changes, self-adaptation loop (experiment scheduling, parameter updating)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication protocols: RabbitMQ (AMQP) for message brokering. Network topology: Edge (Raspberry Pi) - Cloud/Server (RabbitMQ) architecture. Bandwidth requirements: Lightweight for real-time data streaming. Latency: Optimized for low-latency control (not quantified). Reliability: RabbitMQ's message persistence and acknowledgment. Redundancy: Not explicitly mentioned. Security: Safe protocol in low-level driver for data integrity."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosting platform: Edge (Raspberry Pi 4 Model B) with cloud integration via RabbitMQ. Computational requirements: Raspberry Pi's ARM Cortex-A53 for control logic and communication. Storage: Time series database for logged sensor data. Scalability: Not explicitly discussed. Deployment models: Edge-first with potential cloud extension. Availability: Ensured through redundant communication server and data replication mechanisms."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The system uses RabbitMQ (AMQP protocol) for interoperability with external systems, enabling data exchange between the physical twin and digital twin. Python Functional Mockup Units (FMUs) from Document 5 support rapid prototyping and integration with enterprise systems. The DT's calibration and simulation capabilities align with industry standards for model-driven development, facilitating collaboration with external tools and platforms."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Complies with IEEE standards (e.g., [4,5,15]) and industry specifications for Digital Twin frameworks. Adopted interoperability standards include RabbitMQ FMU (Functional Mockup Units) and Python Functional Mockup Units (FMUs) for self-adaptive systems. Certification requirements involve open-source toolchain compliance and adherence to simulation protocols (e.g., SciPy 1.0 for scientific computing)."
]