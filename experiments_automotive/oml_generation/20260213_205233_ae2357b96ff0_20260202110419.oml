// Sensors
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard LiDAR (Hokuyo UST‑10LX) producing point‑clouds for clustering and tracking"
    DTDFVocab:producedData LiDARPointCloudTransmit
]

instance DepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard Intel D435i depth camera generating depth maps for 3D perception"
    DTDFVocab:producedData CameraDepthMapTransmit
]

instance InertialOdometrySensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle inertial and odometry sensors yielding ego speed and steering angle"
    DTDFVocab:producedData VehicleStateTransmit
]

// Data Transmitted
instance LiDARPointCloudTransmit : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance CameraDepthMapTransmit : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DepthCameraSensor
]

instance VehicleStateTransmit : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InertialOdometrySensor
]

instance ObjectTracksTransmit : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

// Data Instances
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Point‑cloud data received from LiDAR sensor after serialization"
    DTDFVocab:inputTo DataTranslationFE
    DTDFVocab:fromData LiDARPointCloudTransmit
]

instance CameraDepthMapData : DTDFVocab:Data [
    base:desc "Depth map data received from Intel D435i depth camera"
    DTDFVocab:inputTo DataTranslationFE
    DTDFVocab:fromData CameraDepthMapTransmit
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle speed and steering angle measurements from inertial‑odometry sensors"
    DTDFVocab:inputTo DataTranslationFE
    DTDFVocab:fromData VehicleStateTransmit
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks generated by DBSCAN clustering and Kalman filter"
    DTDFVocab:inputTo DataCollectionFE
    DTDFVocab:fromData ObjectTracksTransmit
]

// Models/Data
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN‑based point‑cloud clustering model used for object detection"
    DTDFVocab:inputTo DataCollectionFE
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter tracking model used for maintaining object tracks"
    DTDFVocab:inputTo DataCollectionFE
]

instance ACCComputationModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control control model per ISO15622, performance class I"
    DTDFVocab:inputTo ActuationFE
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model for rendering vehicle state and object tracks"
    DTDFVocab:inputTo PresentationFE
]

instance SQLPersistenceModel : DTDFVocab:Model [
    base:desc "SQL database model for time‑series persistence of telemetry and reports"
    DTDFVocab:inputTo DataCollectionFE
]

// Enablers
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Data Translation Functional Entity that aligns units and performs serialization"
    DTDFVocab:enables RTDataMonitoringService, ACCComputationService
]

instance DataCollectionFE : DTDFVocab:Enabler [
    base:desc "Data Collection FE for ingesting sensor data, clustering, tracking, and persisting"
    DTDFVocab:enables RTDataMonitoringService, ReportingService, ACCComputationService
]

instance PresentationFE : DTDFVocab:Enabler [
    base:desc "Presentation FE handling 3‑D visualization and user interface interaction"
    DTDFVocab:enables VisualizationService, RemoteInterfaceService, RTDataMonitoringService
]

instance ActuationFE : DTDFVocab:Enabler [
    base:desc "Actuation FE converting ACC commands into motor voltage, steering servo, and emergency brake signals"
    DTDFVocab:enables ACCControlService
]

// Services
instance RTDataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time data monitoring and reporting of vehicle state over Wi‑Fi"
    DTDFVocab:provides MonitoringInsight, ACCInsight, VisualizationInsight
]

instance ACCComputationService : DTDFVocab:Service [
    base:desc "ACC computation and offloading service using leading vehicle detection and speed calculations"
    DTDFVocab:provides ACCInsight, ReportingInsight
]

instance RemoteInterfaceService : DTDFVocab:Service [
    base:desc "Remote management service for enabling/disabling ACC and modifying parameters via UI"
    DTDFVocab:provides EnableDisableACCAction, ModifyDesiredSpeedAction, IssueEmergencyBrakeAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3‑D visualization service rendering vehicle state and object tracks"
    DTDFVocab:provides VisualizationInsight
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Log‑based performance reporting stored in SQL database"
    DTDFVocab:provides ReportingInsight
]

instance ACCControlService : DTDFVocab:Service [
    base:desc "ACC control service sending speed, steering, and emergency brake drive commands"
]

// Insights
instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight into real‑time vehicle speed, steering angle, and object tracks"
]

instance ACCInsight : DTDFVocab:Insight [
    base:desc "Predicted ACC behavior including desired speed and leading vehicle detection"
]

instance ReportingInsight : DTDFVocab:Insight [
    base:desc "Performance report data generated from SQL database persistence"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Rendered 3‑D visualization of vehicle state and tracks"
]

// Actions
instance EnableDisableACCAction : DTDFVocab:Action [
    base:desc "Action to enable or disable ACC via the user interface"
    DTDFVocab:IsAutomatic false
]

instance ModifyDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to modify the desired ACC speed parameter remotely"
    DTDFVocab:IsAutomatic false
]

instance IssueEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to issue an emergency braking command from the Digital Twin"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital twin generates desired speed commands, safety braking actions, and ACC enable/disable signals which are transmitted via the Actuation FE to the PT’s motor drivers and steering servos; all control messages sent over the same Wi‑Fi link using the ROS 2 middleware."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with end‑to‑end latency ≤100 ms, clock synchronization within 100 ms accuracy; ACC loop and data acquisition occur at the vehicle’s perception cycle (≈30–60 Hz) with the DT processing and publishing outputs within a few milliseconds to satisfy R7."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated by the ISO 23247 RA with added Physical Twin Entity; the DT constellation includes the PT’s hardware, the edge server running the Digital Twin Entity, the client user interface host, and the cross‑system Data Translation component facilitating message serialization; all entities interact over ROS 2 topics over a Wi‑Fi network."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Engineering cycle comprising requirement definition (R1–R8), architectural design based on ISO 23247 reference architecture, implementation via ROS 2 packages and MATLAB/Simulink, deployment onto vehicle and edge server, and operational validation/testing of real‑time ACC off‑loading; the DT covers the vehicle’s operating phase (as operated)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity real‑time data acquisition and low latency ensures the DT behaves consistently with the PT; DBSCAN clustering and Kalman filter tracking provide confidence bounds; Data Translation guarantees unit consistency; compliance with ISO 15622 validates ACC control logic; no explicit statistical validation reported."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication occurs over a Wi‑Fi network using ROS 2 transport. Within entities, ROS 2 topics deliver packets between functional‑entity ROS 2 nodes. The Data Translation FE consistently serialises and aligns messages, but no DDS or NTP details are specified in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity physically embedded on the vehicle; Digital Twin Entity deployed on an external edge/server (CPU / GPU); User Entity runs on a client workstation; the Data Storage FE uses a cloud‑hosted SQL database; all components communicate over Wi‑Fi."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not explicitly described in the document; no integration to external information systems beyond the DT’s own UI and data streams."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture provides the DT structural template; ISO 15622 specifies the ACC control algorithm; ROS 2 is used as middleware; IEEE 3GPP 22.185 defines the 100 ms latency requirement for V2V communication."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical requirements: end‑to‑end latency ≤100 ms (R7), clock synchronization ≤100 ms (R8), ACC logic compliant with ISO 15622; emergency braking command provides fail‐safe override; however, explicit cybersecurity measures (authentication, encryption) are not detailed in the document."
]