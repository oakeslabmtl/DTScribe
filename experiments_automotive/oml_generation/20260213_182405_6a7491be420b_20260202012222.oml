// -----------------------------------------------------------------------------
// Digital Twin Entity (container for DT components)
// -----------------------------------------------------------------------------
instance DigitalTwinEntity : DTDFVocab:DigitalTwin [
    base:desc "Digital Twin entity hosting components, services, and enablers"
]

// -----------------------------------------------------------------------------
// Sensing Components
// -----------------------------------------------------------------------------
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor delivering point‑cloud data from the 1/10‑scale autonomous vehicle",
    DTDFVocab:producedData LiDARDataTransmitted
]

instance OnBoardCameraSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board camera used for visualisation of the vehicle and environment",
    DTDFVocab:producedData CameraDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑state sensors providing speed and position signals",
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// -----------------------------------------------------------------------------
// Acting Components
// -----------------------------------------------------------------------------
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Motor FE that controls vehicle propulsion"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering Servo FE that adjusts the steering angle"
]

// -----------------------------------------------------------------------------
// Data Transmitted (from sensors)
// -----------------------------------------------------------------------------
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance CameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OnBoardCameraSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// -----------------------------------------------------------------------------
// Data Instances (raw, processed, commands)
// -----------------------------------------------------------------------------
instance RawLiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw point‑cloud stream captured by the LiDAR sensor",
    DTDFVocab:fromData LiDARDataTransmitted,
    DTDFVocab:inputTo DataTranslationEnabler
]

instance RawCameraImageData : DTDFVocab:Data [
    base:desc "Raw image frames captured by the on‑board camera",
    DTDFVocab:fromData CameraDataTransmitted,
    DTDFVocab:inputTo DataTranslationEnabler
]

instance RawVehicleStateData : DTDFVocab:Data [
    base:desc "Raw vehicle‑state signals (speed, position) from vehicle sensors",
    DTDFVocab:fromData VehicleStateDataTransmitted,
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ProcessedObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks derived from LiDAR point‑cloud clustering (DBSCAN) and Kalman filtering",
    DTDFVocab:fromData LiDARDataTransmitted,
    DTDFVocab:inputTo ACCComputationEnabler,
    DTDFVocab:inputTo VisualizationEnabler
]

instance DesiredSpeedCommandData : DTDFVocab:Data [
    base:desc "Desired speed computed by the ACC algorithm and sent to the vehicle actuator",
    DTDFVocab:fromData LiDARDataTransmitted,
    DTDFVocab:inputTo ROS2NetworkEnabler
]

// -----------------------------------------------------------------------------
// Models
// -----------------------------------------------------------------------------
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Geometric model that clusters LiDAR point clouds (DBSCAN) and tracks objects with a Kalman filter",
    DTDFVocab:inputTo ACCComputationEnabler,
    DTDFVocab:inputTo VisualizationEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "ACC control model that detects lead vehicle, computes inter‑vehicle distance and derives a desired speed"
]

instance DataTranslationModel : DTDFVocab:Model [
    base:desc "Data Translation model that serialises streams, aligns message types and performs unit conversions",
    DTDFVocab:inputTo DataTranslationEnabler
]

// -----------------------------------------------------------------------------
// Enablers (functional entities & tech)
// -----------------------------------------------------------------------------
instance ROS2NetworkEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 network used for intra‑entity communication of data streams",
    DTDFVocab:enables DataMonitoringService,
    DTDFVocab:enables ComputationOffloadingService,
    DTDFVocab:enables RemoteManagementService,
    base:isContainedIn DigitalTwinEntity
]

instance WiFiUDPTransportEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi UDP transport layer for inter‑entity communication between Physical Twin, Digital Twin and User entities",
    DTDFVocab:enables RemoteManagementService,
    DTDFVocab:enables ComputationOffloadingService,
    base:isContainedIn DigitalTwinEntity
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation functional entity that serialises, aligns types and converts units for all streams",
    DTDFVocab:enables DataMonitoringService,
    base:isContainedIn DigitalTwinEntity
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "ACC functional entity that runs lead‑vehicle detection and desired‑speed computation in the digital twin",
    DTDFVocab:enables ComputationOffloadingService,
    base:isContainedIn DigitalTwinEntity
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D Visualization UI component that renders vehicle state, point‑clouds and object tracks",
    DTDFVocab:enables DataMonitoringService,
    base:isContainedIn DigitalTwinEntity
]

// -----------------------------------------------------------------------------
// Services
// -----------------------------------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time vehicle‑state visualisation, projected path and object‑track display supports data saving and report generation",
    DTDFVocab:provides VehicleStateInsight,
    DTDFVocab:provides ObjectTracksInsight,
    DTDFVocab:provides ExportReportAction,
    base:isContainedIn DigitalTwinEntity
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs the ACC algorithm in the digital twin and returns the desired speed to the vehicle for actuation",
    DTDFVocab:provides DesiredSpeedComputationAction,
    DTDFVocab:provides DesiredSpeedInsight,
    base:isContainedIn DigitalTwinEntity
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed and issue emergency‑brake commands via the UI over a low‑latency link",
    DTDFVocab:provides EnableACCAction,
    DTDFVocab:provides DisableACCAction,
    DTDFVocab:provides SetDesiredSpeedAction,
    DTDFVocab:provides EmergencyBrakeAction,
    DTDFVocab:provides ACCStatusInsight,
    base:isContainedIn DigitalTwinEntity
]

// -----------------------------------------------------------------------------
// Insights
// -----------------------------------------------------------------------------
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into vehicle speed, position and overall state as visualised in the 3D UI",
    base:isContainedIn DigitalTwinEntity
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Insight showing clustered and tracked objects derived from LiDAR point clouds",
    base:isContainedIn DigitalTwinEntity
]

instance DesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Insight reporting the speed value computed by the ACC algorithm",
    base:isContainedIn DigitalTwinEntity
]

instance ACCStatusInsight : DTDFVocab:Insight [
    base:desc "Insight indicating whether ACC is currently enabled or disabled",
    base:isContainedIn DigitalTwinEntity
]

// -----------------------------------------------------------------------------
// Actions
// -----------------------------------------------------------------------------
instance ExportReportAction : DTDFVocab:Action [
    base:desc "Action to export the current monitoring session as a report",
    DTDFVocab:IsAutomatic false,
    base:isContainedIn DigitalTwinEntity
]

instance DesiredSpeedComputationAction : DTDFVocab:Action [
    base:desc "Automatic computation of desired speed by the ACC model",
    DTDFVocab:IsAutomatic true,
    base:isContainedIn DigitalTwinEntity
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Manual action to enable Adaptive Cruise Control",
    DTDFVocab:IsAutomatic false,
    base:isContainedIn DigitalTwinEntity
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Manual action to disable Adaptive Cruise Control",
    DTDFVocab:IsAutomatic false,
    base:isContainedIn DigitalTwinEntity
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Manual action to set a target speed for the vehicle",
    DTDFVocab:IsAutomatic false,
    base:isContainedIn DigitalTwinEntity
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Manual action to trigger an emergency brake command",
    DTDFVocab:IsAutomatic false,
    base:isContainedIn DigitalTwinEntity
]

// -----------------------------------------------------------------------------
// Environment (overall system composition)
// -----------------------------------------------------------------------------
instance AutomotiveDigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains LiDARSensor,
    base:contains OnBoardCameraSensor,
    base:contains VehicleStateSensor,
    base:contains MotorActuator,
    base:contains SteeringServoActuator,
    base:contains ROS2NetworkEnabler,
    base:contains WiFiUDPTransportEnabler,
    base:contains DataTranslationEnabler,
    base:contains ACCComputationEnabler,
    base:contains VisualizationEnabler,
    base:contains DataMonitoringService,
    base:contains ComputationOffloadingService,
    base:contains RemoteManagementService
]

// -----------------------------------------------------------------------------
// High‑level Component (Digital Twin System)
// -----------------------------------------------------------------------------
instance AutomotiveDigitalTwinSystem : DTDFVocab:Component [
    base:desc "Digital Twin System built on ISO 23247 entity‑based architecture, composed of functional entities implemented as ROS2 packages and communicating via ROS2 and Wi‑Fi/UDP",
    DTDFVocab:hasEnvironment AutomotiveDigitalTwinEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity generates control commands via the ACC Controlling FE (lead‑vehicle detection and desired‑speed computation) and the User Interface FE (remote‑management commands such as enable/disable ACC, set desired speed, and emergency brake). Commands are transmitted over the ROS 2 network to the Actuation FE deployed on the Physical Twin Entity, where the Actuation component converts the desired speed into motor voltage commands and drives the steering servo. The actuation FE executes the commands on the vehicle; confirmation feedback is implied by the real‑time update of vehicle state data displayed in the UI, although explicit acknowledgement messages are not described."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DTS requires a clock synchronization accuracy of 100 ms between the vehicle’s on‑board sensors/actuators and the digital twin, as mandated by safety‑critical vehicular standards and limited by the hardware; all services (data monitoring, computation off‑loading and remote management) operate in real‑time with low end‑to‑end latency over a Wi‑Fi UDP link, and ROS2 intra‑entity messaging is assumed to be bounded within the same 100 ms window."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration follows the ISO 23247 reference architecture: software components (functional entities) are mapped to ROS2 nodes (FE) and packaged per entity; inter‑entity communication uses a UDP transport over Wi‑Fi, while intra‑entity messaging uses ROS2 DDS topics. The Data Translation FE serialises, aligns message types and performs unit conversions for every data stream, enabling the three services (data monitoring, off‑loading of the ACC algorithm, and remote management) to be composed from the underlying FEs. Resource management is achieved by off‑loading the ACC computation to an external compute node (cloud/edge) while actuation remains on the Physical Twin Entity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS relies on a hybrid network architecture: internal component communication uses ROS 2 packages (publish/subscribe pattern) and inter‑entity communication uses Wi‑Fi with UDP transport. The system requires clock synchronisation within 100 ms accuracy for safety‑critical off‑loading (as mandated by standards for vehicular applications). While specific bandwidth or latency figures are not listed, the requirement for low end‑to‑end latency is emphasised for remote management. No explicit reliability, redundancy, or security protocols (e.g., TLS) are described in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT offloads the ACC computation to a remote platform, which may be cloud‑based, but the documents do not specify the exact hosting environment, computational resources, storage architecture beyond an external SQL database, scalability mechanisms, or availability guarantees. Therefore, concrete hosting and deployment details are not provided."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DTS integrates external standards via the IEC 62541 OPC‑UA specification for the Data Translation FE (optional) and follows the ISO 23247 information‑exchange model. Data streams are exchanged over ROS2 DDS and UDP/Wi‑Fi, enabling interoperability with cloud or edge platforms for computation off‑loading. The architecture also allows optional integration with other enterprise systems through standard OPC‑UA or other middleware, as suggested by the mention of OPC‑UA as an implementation choice for FEs."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built to comply with the ISO 23247 Digital Twin Manufacturing Framework (parts 1‑4), which provides the overall development framework, reference architecture, digital representation of physical elements, and information‑exchange guidelines. Safety considerations are highlighted by recommending alignment with the automotive functional‑safety standard ISO 26262. The implementation also references AUTOSAR as a hardware‑agnostic software architecture model, and suggests the optional use of OPC Unified Architecture (IEC 62541) for the Data Translation FE. By adhering to these standards, the twin aims for interoperability with existing automotive tooling and certification processes, while leveraging the domain‑independent nature of ISO 23247 to integrate domain‑specific technologies such as ROS 2."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The documents address safety considerations for the automotive digital twin system: ISO 26262 functional safety standard is recommended to be promoted to a first‑class citizen for safety‑critical automotive DTs (Document 2), and the ACC functionality is implemented according to ISO 15622 performance class I requirements (Document 5, R6). No specific cybersecurity protocols, access control mechanisms, authentication systems, or threat mitigation strategies are described in the provided documents."
]