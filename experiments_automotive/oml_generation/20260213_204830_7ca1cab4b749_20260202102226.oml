// Sensing Components
instance HokuyoUTST10LxLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR that scans the environment for object detection"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera that captures vehicle state and depth information"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

// Data Transmitted
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUTST10LxLiDAR
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

// Processed Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Processed LiDAR point cloud data after serialization and unit conversion"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance DepthCameraData : DTDFVocab:Data [
    base:desc "Processed RGB and depth image data after serialization"
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

// Enabler
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data translation component serialises raw point cloud and vehicle state messages, aligns message types, performs unit conversions, and forwards the processed streams"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI that displays real‑time vehicle state data, projected driving path, detected object tracks; allows data saving and report generation"
    DTDFVocab:provides VehicleStateInsight, SaveDataAction, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC decision‑making to cloud servers, reducing on‑board ECU load; returns desired speed for actuation"
    DTDFVocab:provides ACCDecisionAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to remotely enable/disable ACC, set desired speed and issue emergency braking via UI with low‑latency communication"
    DTDFVocab:provides RemoteEnableAccAction, RemoteSetDesiredSpeedAction, RemoteEmergencyBrakeAction
]

// Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into vehicle state and surrounding environment derived from LiDAR and depth camera data"
]

// Actions
instance SaveDataAction : DTDFVocab:Action [
    base:desc "Action that saves real‑time data streams to storage"
    DTDFVocab:IsAutomatic false
]

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Action that generates report from saved data"
    DTDFVocab:IsAutomatic false
]

instance ACCDecisionAction : DTDFVocab:Action [
    base:desc "Computes desired speed based on ACC decision logic on cloud"
    DTDFVocab:IsAutomatic true
]

instance RemoteEnableAccAction : DTDFVocab:Action [
    base:desc "Action to remotely enable or disable ACC"
    DTDFVocab:IsAutomatic false
]

instance RemoteSetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to remotely set desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance RemoteEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to remotely issue emergency braking command"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originating from the User Interface FE (e.g., acceleration, brake, steering requests) are routed through the Digital Twin’s Actuation FE components (Motor Actuation FE and Steering Servo Actuation FE) using the ROS2 network. Prior to transmission, the Data Translation component re‑serialises the commands, ensuring consistent message format and units. The actuation commands are then sent to the physical actuators over the Wi‑Fi network with UDP transport. Feedback of updated vehicle state information returned by the Vehicle State FE provides confirmation of command execution, allowing the Digital Twin to reconcile command status with the real‑world response."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Time synchronization between the Physical Twin Entity and Digital Twin Entity is defined to achieve a 100 ms accuracy, meeting the hardware limitations while supporting safety‑critical vehicular applications. Each ROS2 package communicates timestamps using the ROS2 clock mechanism, and the system architecture ensures that control‑loop latency between sensor data acquisition, processing, and actuation stays within the 100 ms bound. No finer granular synchronisation or higher frequency coordination is specified."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The design follows the ISO 23247 reference architecture, mapping each Software Component (SW) to a Functional Entity (FE) and deploying each FE as an individual ROS2 package containing ROS2 nodes. The system is partitioned into three entities: the User Entity hosting the User Interface FE (split into 3D visualization and control panel), the Digital Twin Entity handling data management and control mechanisms, and the Physical Twin Entity encapsulating device communication, data preprocessing, actuation, and automotive functionality such as point‑cloud clustering and tracking. Resource management is handled through ROS2 middleware, which facilitates communication across distributed nodes, while a central entity aggregates data transformation and high‑level control, thereby coordinating the distributed twins."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin Service is built on a hybrid network architecture. Software components within the same physical host communicate via ROS 2 over an internal bus, while inter‑entity communication (between the vehicle and the virtual twin) takes place over a Wi-Fi network using UDP. The system must honour a maximum network latency of 100 ms, as specified by Requirement R7. Bandwidth and reliability requirements beyond this latency constraint are not explicitly quantified. No explicit encryption or authentication protocols are specified for the network traffic in the provided documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system aligns with the ISO 23247 – Digital twin framework for manufacturing. The reference architecture (Part 2 of the standard) specifies an entity‑based architecture comprising: Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity, and User Entity, each composed of Functional Entities (FEs). The architecture supports digital representation of physical manufacturing elements (Part 3) and information exchange procedures (Part 4). Compliance is demonstrated by referencing the standard parts and by implementing data collection and control via OPC Unified Architecture, an interoperability protocol adopted by the standard."
]