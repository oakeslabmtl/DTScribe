// ===========================
// C3: Physical sensing components
// ===========================

instance LiDARHokuyoUst10lxSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR providing 2‑D point clouds, sampled in real time on the Jetson Orin Nano."
    DTDFVocab:producedData LiDARPointCloudTx
]

instance DepthCameraIntelDeepSenseD435iSensor : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering 3‑D perception data, sampled in real time on the Jetson Orin Nano."
    DTDFVocab:producedData DepthCameraPointCloudTx
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring vehicle forward speed, sampled in real time on the Jetson Orin Nano."
    DTDFVocab:producedData VehicleSpeedTx
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring steering angle, sampled in real time on the Jetson Orin Nano."
    DTDFVocab:producedData SteeringAngleTx
]

// ===========================
// C4: Physical-to-virtual interaction (DataTransmitted)
// ===========================

instance LiDARPointCloudTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARHokuyoUst10lxSensor
]

instance DepthCameraPointCloudTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DepthCameraIntelDeepSenseD435iSensor
]

instance VehicleSpeedTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// ===========================
// C10: Data objects
// ===========================

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "2‑D point‑cloud data stream from the Hokuyo UST‑10LX LiDAR."
    DTDFVocab:fromData LiDARPointCloudTx
    DTDFVocab:inputTo ComputationOffloadingEnabler, VisualizationEnabler
    base:isContainedIn DigitalTwinEnvironment
]

instance DepthCameraPointCloudData : DTDFVocab:Data [
    base:desc "3‑D point‑cloud data stream from the Intel DeepSense D435i depth camera."
    DTDFVocab:fromData DepthCameraPointCloudTx
    DTDFVocab:inputTo ComputationOffloadingEnabler, VisualizationEnabler
    base:isContainedIn DigitalTwinEnvironment
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Real‑time vehicle speed measurement."
    DTDFVocab:fromData VehicleSpeedTx
    DTDFVocab:inputTo ComputationOffloadingEnabler, VisualizationEnabler
    base:isContainedIn DigitalTwinEnvironment
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Real‑time steering angle measurement."
    DTDFVocab:fromData SteeringAngleTx
    DTDFVocab:inputTo ComputationOffloadingEnabler, VisualizationEnabler
    base:isContainedIn DigitalTwinEnvironment
]

// ===========================
// C2: Acting components
// ===========================

instance VedderEscActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder electronic speed controller (ESC) driving the motor for speed actuation receives voltage commands from the Actuation FE."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Servo motor controlling front‑wheel steering angle receives position commands from the Actuation FE."
]

instance EmergencyBrakingActuator : DTDFVocab:ActingComponent [
    base:desc "ESC driven rapid reverse motor voltage implementing emergency braking command."
]

// ===========================
// C9: Models / Algorithms
// ===========================

instance AccControlModelIso15622 : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) model compliant with ISO 15622, performing lead‑vehicle detection and speed set‑point computation."
    DTDFVocab:inputTo ComputationOffloadingEnabler
    base:isContainedIn DigitalTwinEnvironment
]

instance PointCloudClusteringModelDbscan : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm applied to LiDAR and depth‑camera point clouds for object segmentation."
    DTDFVocab:inputTo ComputationOffloadingEnabler
    base:isContainedIn DigitalTwinEnvironment
]

instance ObjectTrackingModelKalmanFilter : DTDFVocab:Model [
    base:desc "Kalman‑filter based multi‑object tracking using clustered point‑cloud data."
    DTDFVocab:inputTo ComputationOffloadingEnabler
    base:isContainedIn DigitalTwinEnvironment
]

// ===========================
// C11: Enablers (software/processing units)
// ===========================

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 package executing ACC, clustering, and tracking models on off‑board compute receives sensor data via ROS2 DDS."
    DTDFVocab:enables ComputationOffloadingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 visualization node streaming speed, steering angle, object tracks and projected path to the UI workstation."
    DTDFVocab:enables DataMonitoringService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 service handling operator commands (ACC enable/disable, speed set‑point adjustment, emergency braking trigger) from the UI."
    DTDFVocab:enables RemoteManagementService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Cross‑system FE that serialises, unit‑converts and aligns ROS2 messages before delivery to the Digital Twin Entity."
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance ActuationEnabler : DTDFVocab:Enabler [
    base:desc "FE converting desired speed from the Digital Twin into motor voltage commands for the Vedder ESC."
    DTDFVocab:enables RemoteManagementService
]

// ===========================
// C6: Services
// ===========================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI service visualising vehicle speed, steering angle, object tracks and projected path stores reports in SQL database."
    DTDFVocab:provides VehicleStateInsight, ObjectTracksInsight, ProjectedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Off‑board execution of ACC algorithm provides ACC decision outputs to the Physical Twin."
    DTDFVocab:provides ActivateAccAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator‑driven service enabling ACC activation, speed set‑point adjustment, and emergency braking via UI."
    DTDFVocab:provides AdjustDesiredSpeedAction, TriggerEmergencyBrakingAction
]

// ===========================
// C17: Insights and Actions
// ===========================

instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Current vehicle speed and steering angle displayed to the operator."
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Detected surrounding objects with positions and velocities derived from clustering and tracking."
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected vehicle trajectory based on current speed, steering angle and ACC set‑point."
]

instance ActivateAccAction : DTDFVocab:Action [
    base:desc "Command to activate Adaptive Cruise Control in the Physical Twin."
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator adjusts the desired speed set‑point for ACC."
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking, causing rapid reverse motor voltage."
    DTDFVocab:IsAutomatic false
]

// ===========================
// Environments (Twin entities)
// ===========================

instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:contains VedderEscActuator, SteeringServoActuator, EmergencyBrakingActuator,
                 LiDARHokuyoUst10lxSensor, DepthCameraIntelDeepSenseD435iSensor,
                 VehicleSpeedSensor, SteeringAngleSensor
]

instance DigitalTwinEnvironment : DTDFVocab:DigitalTwin [
    base:contains ComputationOffloadingEnabler, VisualizationEnabler, RemoteManagementEnabler,
                 DataTranslationEnabler, ActuationEnabler,
                 AccControlModelIso15622, PointCloudClusteringModelDbscan, ObjectTrackingModelKalmanFilter,
                 DataMonitoringService, ComputationOffloadingService, RemoteManagementService,
                 VehicleStateInsight, ObjectTracksInsight, ProjectedPathInsight,
                 ActivateAccAction, AdjustDesiredSpeedAction, TriggerEmergencyBrakingAction
]

instance UserTwinEnvironment : DTDFVocab:Environment [
    base:desc "User twin containing UI workstation (implicit)."
]

instance CrossSystemEnvironment : DTDFVocab:Environment [
    base:contains DataTranslationEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends ACC control commands (desired speed) and remote‑management commands (enable/disable ACC, modify desired speed, emergency brake) back to the PT over ROS2/Wi‑Fi; Actuation FE on the Physical Twin Entity translates these commands into motor voltage and steering servo signals."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "End‑to‑end communication latency bounded to ≤100 ms (R7) with clock synchronisation accuracy of 100 ms (R8); data collection and ACC computation occur at real‑time rates sufficient for the perception‑control loop of the 1/10‑scale vehicle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated ISO 23247‑based architecture: Physical Twin Entity hosts sensors/actuators and Data Pre‑Processing/Actuation FEs; Digital Twin Entity hosts Data Collection, Presentation, Reporting, Controlling (ACC) FEs; User Entity hosts User Interface FE split into 3D visualization and control panel; Cross‑System Entity provides Data Translation FE linking the twins."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the operational stage (runtime monitoring, control and remote management) and the development/testing stage (data collection, ACC algorithm validation, UI prototyping)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity perception via LiDAR point‑cloud clustering (DBSCAN) and Kalman filtering; ACC logic adheres to ISO 15622 specifications; latency ≤100 ms and clock sync ≤100 ms ensure temporal fidelity; data stored externally to avoid on‑board storage limits; no explicit V&V procedures reported."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication over Wi‑Fi using ROS2/DDS; Data Translation FE handles message serialization and unit conversion; standardized communication interface enforced by requirement R1 (modular, loosely‑coupled ROS2 topics)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the Jetson Orin Nano on the vehicle; Digital Twin Entity runs on an external compute platform (e.g., cloud or workstation) hosting ROS2 nodes for ACC and data services; User Entity runs on a separate workstation providing the UI; each entity deployed on distinct hardware."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Implements ISO 23247 reference architecture (entities and Functional Entities), ISO 15622 for ACC behavior, ISO/IEC 30173:2023 concepts, and uses ROS2 (DDS) as a de‑facto standard for communication; optional OPC UA mentioned but not adopted."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical nature acknowledged; latency ≤100 ms and clock sync ≤100 ms required to maintain safe control; remote management commands are gated through the User Interface FE; no specific cybersecurity mechanisms (e.g., authentication, encryption) described."
]