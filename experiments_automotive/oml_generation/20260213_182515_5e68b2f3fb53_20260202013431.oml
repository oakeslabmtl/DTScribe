// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2‑D LiDAR providing raw point‑cloud data"
    DTDFVocab:producedData LiDARDataTransmitted
]

instance IntelRealSenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera providing depth images"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensors measuring ego speed and steering‑angle telemetry"
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseDepthCamera
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// C10: Data produced from sensors
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 3‑D point‑cloud stream from the LiDAR"
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames from the RealSense camera"
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance VehicleTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry containing ego speed and steering‑angle values"
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

// C10: Models/Data
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering followed by a Kalman filter for object track generation"
    DTDFVocab:inputTo DataTranslationFE
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "ISO‑15622 compliant ACC algorithm computing lead‑vehicle detection and speed set‑point"
    DTDFVocab:inputTo ComputationOffloadingFE
]

instance SqlDataStorageModel : DTDFVocab:Model [
    base:desc "Persistent storage of object tracks and vehicle state in a SQL database"
    DTDFVocab:inputTo ReportingFE
]

// C11: Enablers (Functional Entities)
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Data Translation functional entity performing serialization and unit conversion"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance ActuationFE : DTDFVocab:Enabler [
    base:desc "Actuation functional entity converting speed/brake commands to motor voltage and servo signals"
    DTDFVocab:enables RemoteManagementService
]

instance ComputationOffloadingFE : DTDFVocab:Enabler [
    base:desc "Enabler for cloud‑based computation of the ACC algorithm"
    DTDFVocab:enables ComputationOffloadingService
]

instance ReportingFE : DTDFVocab:Enabler [
    base:desc "Reporting functional entity generating time‑series reports stored in SQL"
    DTDFVocab:enables ReportingService
]

instance VisualizationFE : DTDFVocab:Enabler [
    base:desc "3‑D visualization functional entity rendering vehicle and environment"
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualizes real‑time speed, steering angle, object tracks and projected path"
    DTDFVocab:provides CurrentSpeedInsight, SteeringAngleInsight, NearbyObjectTracksInsight, PredictedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm runs in the cloud DT and returns desired speed set‑point"
    DTDFVocab:provides DesiredSpeedInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI lets operators enable/disable ACC, set target speed and trigger emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetTargetSpeedAction, EmergencyBrakingAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Automatic generation of time‑series reports stored in a SQL database"
    DTDFVocab:provides ReportGenerationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3‑D visualization of the vehicle and its environment"
    DTDFVocab:provides Environment3DVisualizationInsight
]

// C17: Insights
instance CurrentSpeedInsight : DTDFVocab:Insight [
    base:desc "Current ego speed displayed to the operator"
]

instance SteeringAngleInsight : DTDFVocab:Insight [
    base:desc "Current steering angle displayed to the operator"
]

instance NearbyObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Tracks of nearby objects derived from point‑cloud clustering"
]

instance PredictedPathInsight : DTDFVocab:Insight [
    base:desc "Predicted vehicle trajectory based on ACC model output"
]

instance DesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Desired speed set‑point computed by the ACC algorithm"
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Confirmation that a performance report has been generated and stored"
]

instance Environment3DVisualizationInsight : DTDFVocab:Insight [
    base:desc "Rendered 3‑D view of the vehicle and surrounding environment"
]

// C17: Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator enables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator disables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets a target speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends actuation commands back to the PT, including desired speed, enable/disable ACC, emergency‑brake signals, and steering adjustments. These commands are serialized and unit‑converted by the Data Translation FE and delivered over the same Wi‑Fi link to the Actuation FE, which drives the motor controller and steering servo."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates with a hard latency bound of ≤ 100 ms for the round‑trip vehicle‑to‑DT communication (requirement R7) and requires clock synchronization across all DTS components within 100 ms (requirement R8), ensuring near‑real‑time synchronization for ACC offloading."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of the three ISO 23247‑derived entities interconnected via a ROS 2 network internally and a Wi‑Fi link externally; each Functional Entity is realized as an independent ROS 2 package, providing modular, loosely‑coupled services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The case study focuses on the operational stage of the vehicle, where the DT is used for real‑time monitoring, control and maintenance; design‑time stages are not explicitly described."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "To guarantee fidelity, the DT enforces a ≤ 100 ms communication latency and clock sync, uses high‑fidelity sensor models (raw LiDAR point clouds) and validated ACC logic per ISO 15622. Real‑time validation is achieved by comparing DT‑computed speed commands against vehicle response."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication uses ROS 2 DDS over Wi‑Fi; the Data Translation FE serializes messages and performs unit conversions. The optional use of OPC UA is mentioned but not implemented."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the vehicle’s onboard Jetson Orin Nano; the Digital Twin Entity runs on external compute resources (cloud or workstation); the User Entity UI runs on a separate client machine. Each entity is packaged as its own ROS 2 node set."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) reference architecture, adopts ISO 15622 for ACC functionality, references ISO/IEC 30173:2023 for DT terminology, and utilizes the ROS 2 standard for middleware; OPC UA is cited as a possible implementation for the Data Translation FE."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The system is described as safety‑critical; latency and clock‑sync requirements support safe operation. Remote management commands are limited to enable/disable ACC, speed set‑point changes, and emergency braking, but explicit security mechanisms (authentication, encryption) are not detailed."
]