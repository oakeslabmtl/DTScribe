    base:desc "Time-series forecasting model for predicting physiological degradation (e.g., heart failure, sepsis) using historical physiological data"
    DTDFVocab:inputTo TimescaleDB
]

instance NeuralNetworkPredictor : DTDFVocab:Model [
    base:desc "Reinforcement learning-based neural network for adaptive control of cyber-physical systems in real-time"
    DTDFVocab:inputTo MATLABSimulink
]

