    base:desc "COMSOL Multiphysics simulation for cardiac electrophysiology modeling and closed-loop pacing optimization"
    DTDFVocab:inputTo COMSOLMultiphysics
]

instance FluidDynamicsModel : DTDFVocab:Model [
    base:desc "Computational fluid dynamics simulation for blood flow modeling in cyber-physical systems"
    DTDFVocab:inputTo COMSOLMultiphysics
]

