    base:desc "Noise-filtered, normalized physiological data ready for model processing"
    DTDFVocab:fromData ComprehensiveBiometricDataStream
    DTDFVocab:inputTo AnomalyDetectionAutoencoder, PhysiologicalDegradationModel
]

instance ControlParameters : DTDFVocab:Data [
    base:desc "Optimized control parameters for cyber-physical system adjustments (drug dosages, pacing settings)"
    DTDFVocab:fromData ClosedLoopOptimizer
    DTDFVocab:inputTo ImplantController, BiomechanicalActuator
]

instance RealTimeVisualizationData : DTDFVocab:Data [
    base:desc "Structured 3D/4D visualization data for real-time physiological state monitoring"
    DTDFVocab:fromData ProcessedBiometricData
    DTDFVocab:inputTo VisualizationService
]

instance HistoricalTrendData : DTDFVocab:Data [
    base:desc "Stored historical physiological data for trend analysis and model training"
    DTDFVocab:fromData TimescaleDB
