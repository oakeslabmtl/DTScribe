    DTDFVocab:producedData PressureDataStream
]

instance WearableBiometricSensor : DTDFVocab:SensingComponent [
    base:desc "Comprehensive wearable sensor suite combining multiple physiological metrics (ECG, EEG, glucose, temperature)"
