instance ECGDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ECGSensor
]

instance EEGDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EEGSensor
]

instance GlucoseDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BloodGlucoseMonitor
]

instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

