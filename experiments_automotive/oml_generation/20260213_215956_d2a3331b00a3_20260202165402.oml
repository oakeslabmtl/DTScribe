]

instance MQTTProtocol : DTDFVocab:Enabler [
    base:desc "Message Queuing Telemetry Transport for lightweight, low-latency communication between sensors and digital twins"
    DTDFVocab:enables DataAcquisitionService
]

instance 5GNetwork : DTDFVocab:Enabler [
    base:desc "Ultra-reliable low-latency communication (URLLC) infrastructure for critical cyber-physical applications"
    DTDFVocab:enables RealTimeOptimizationService
]

instance HyperledgerBlockchain : DTDFVocab:Enabler [
    base:desc "Immutable audit logging for digital twin interactions with zero-trust architecture implementation"
    DTDFVocab:enables SecurityService
]

instance AutoMLFramework : DTDFVocab:Enabler [
    base:desc "TensorFlow/PyTorch framework for deep learning-based physiological prediction and anomaly detection models"
    DTDFVocab:enables PredictionService
]

instance TimescaleDB : DTDFVocab:Enabler [
    base:desc "Time-series database for high-frequency physiological data storage with sub-millisecond query performance"
    DTDFVocab:inputTo PhysiologicalDegradationModel, AnomalyDetectionAutoencoder
]

instance COMSOLMultiphysics : DTDFVocab:Enabler [
    base:desc "Specialized simulation engine for physiology-specific modeling (cardiac electrophysiology, fluid dynamics)"
    DTDFVocab:inputTo CardiacElectrophysiologyModel, FluidDynamicsModel
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "Simulation and control system design platform for digital twin modeling and closed-loop control algorithms"
    DTDFVocab:inputTo NeuralNetworkPredictor, ClosedLoopOptimizer
]

instance GeneticAlgorithms : DTDFVocab:Enabler [
    base:desc "Multi-objective optimization framework for resource allocation in surgical robotics and wearable devices"
    DTDFVocab:inputTo ClosedLoopOptimizer
]

instance OPCUAProtocol : DTDFVocab:Enabler [
    base:desc "Open Platform Communications Unified Architecture for interoperability between industrial IoT and digital twins"
    DTDFVocab:enables DataIntegrationService
]

// C12: Data
instance RawPhysiologicalData : DTDFVocab:Data [
    base:desc "Unprocessed raw signals from physiological sensors (ECG, EEG, glucose, temperature)"
    DTDFVocab:fromData ECGDataStream, EEGDataStream, GlucoseDataStream, TemperatureDataStream
    DTDFVocab:inputTo DataPreProcessingFE
]

