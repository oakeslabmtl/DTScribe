{
    class Insight : base:Thing {
    }
    class Action : base:Thing {
        IsAutomatic : Boolean
    }
    class Service : base:Thing {
        provides : Insight | Action
    }
    class Enabler : base:Thing {
        enables : Service
    }
    class DataTransmitted : base:Thing {
        producedFrom : SensingComponent
    }
    class Data : base:Thing {
        fromData : DataTransmitted
        inputTo : Enabler
    }
    class Model : base:Thing {
        inputTo : Enabler
    }
    class SensingComponent : base:Thing {
        producedData : DataTransmitted
    }
    class ActingComponent : base:Thing {
    }
    class Component : base:Thing {
    }
    class Environment : base:Thing {
        base:contains : Component
    }
}