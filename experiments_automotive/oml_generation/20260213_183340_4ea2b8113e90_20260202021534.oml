import DTDFVocab from "http://example.org/DTDFVocab"

// ------------------------------------------------------------
// Physical Sensing Components
// ------------------------------------------------------------
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-110LX 2‑D LiDAR providing raw point‑cloud scans of the vehicle surroundings",
    DTDFVocab:producedData HokuyoLiDARTransmitted
]

instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera delivering RGB‑D images for perception",
    DTDFVocab:producedData IntelDepthCameraTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel‑based speed sensor reporting ego‑vehicle longitudinal speed",
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle encoder measuring current steering wheel position",
    DTDFVocab:producedData SteeringAngleTransmitted
]

// ------------------------------------------------------------
// Data Transmitted (Physical → Virtual)
// ------------------------------------------------------------
instance HokuyoLiDARTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance IntelDepthCameraTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// ------------------------------------------------------------
// Virtual Data
// ------------------------------------------------------------
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 2‑D LiDAR point‑cloud generated by HokuyoLiDARTransmitted",
    DTDFVocab:fromData HokuyoLiDARTransmitted,
    DTDFVocab:inputTo NVIDIAJetPackSDK
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image (RGB‑D) supplied by IntelDepthCameraTransmitted",
    DTDFVocab:fromData IntelDepthCameraTransmitted,
    DTDFVocab:inputTo NVIDIAJetPackSDK
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego‑vehicle longitudinal speed value from VehicleSpeedTransmitted",
    DTDFVocab:fromData VehicleSpeedTransmitted,
    DTDFVocab:inputTo MATLABSimulinkACCController
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering wheel angle from SteeringAngleTransmitted",
    DTDFVocab:fromData SteeringAngleTransmitted,
    DTDFVocab:inputTo MATLABSimulinkACCController
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Clustered and tracked object trajectories produced by DBSCAN clustering and Kalman‑filter tracking on LiDARPointCloudData",
    DTDFVocab:fromData HokuyoLiDARTransmitted,
    DTDFVocab:inputTo NVIDIAJetPackSDK
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Combined ego‑vehicle state (speed + steering) derived from VehicleSpeedData and SteeringAngleData",
    DTDFVocab:fromData VehicleSpeedTransmitted, SteeringAngleTransmitted,
    DTDFVocab:inputTo MATLABSimulinkACCController
]

instance ProjectedDrivingPathData : DTDFVocab:Data [
    base:desc "Planned longitudinal path generated by ACCDecisionModel based on VehicleStateData and ObjectTracksData",
    DTDFVocab:fromData VehicleStateData, ObjectTracksData,
    DTDFVocab:inputTo QtUserInterface
]

// ------------------------------------------------------------
// Models (Geometric, Analytical, Behavioral)
// ------------------------------------------------------------
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm applied to LiDARPointCloudData to produce raw object clusters",
    DTDFVocab:inputTo NVIDIAJetPackSDK
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based multi‑target tracker refining DBSCAN clusters into continuous object tracks",
    DTDFVocab:inputTo NVIDIAJetPackSDK
]

instance ACCDecisionModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control behavioral model that selects lead vehicle, computes following distance, and outputs desired speed set‑point",
    DTDFVocab:inputTo MATLABSimulinkACCController
]

instance LiDARGeometricModel : DTDFVocab:Model [
    base:desc "Geometric representation of LiDAR point‑cloud used for spatial reasoning in perception pipeline",
    DTDFVocab:inputTo NVIDIAJetPackSDK
]

// ------------------------------------------------------------
// Enablers (Middleware, SDKs, Tools, Infrastructure)
// ------------------------------------------------------------
instance ROS2DDSMiddleware : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware employing DDS for low‑latency, safety‑critical communication between physical vehicle and digital twin",
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance NVIDIAJetPackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack SDK providing GPU‑accelerated perception and model execution on edge/cloud resources",
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance MATLABSimulinkACCController : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment used for developing and auto‑code‑generating the ACC controller executed in the twin",
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService
]

instance QtUserInterface : DTDFVocab:Enabler [
    base:desc "Qt‑based graphical UI presenting real‑time vehicle state, object tracks, and projected paths also captures operator commands",
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance DockerContainer : DTDFVocab:Enabler [
    base:desc "Docker containerisation ensuring reproducible deployment of all twin services and models",
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "Relational SQL store persisting raw sensor streams, object tracks, vehicle state, and ACC results",
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

// ------------------------------------------------------------
// Services
// ------------------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Displays real‑time vehicle state, projected driving paths, and nearby object tracks allows users to view, save, and generate reports of ACC‑relevant data",
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTrackInsight, ProjectedPathInsight, SaveReportAction, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm (lead‑vehicle detection, distance‑based speed calculation) in the twin and returns speed command to the vehicle for actuation",
    DTDFVocab:provides ComputeSpeedCommandAction, ACCStatusInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to enable/disable ACC, set desired speed, and issue emergency‑brake commands remotely via the UI with low‑latency safety‑critical communication",
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction, ACCStatusInsight
]

// ------------------------------------------------------------
// Insights
// ------------------------------------------------------------
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Provides operators with up‑to‑date ego‑vehicle speed, steering angle, and pose as visualized in the UI"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Shows clustered and tracked surrounding objects, including position, velocity, and identity"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Visualizes the trajectory the ACC algorithm predicts for the ego‑vehicle given current traffic context"
]

instance ACCStatusInsight : DTDFVocab:Insight [
    base:desc "Indicates current ACC mode (enabled/disabled), desired speed set‑point, and any active safety overrides"
]

// ------------------------------------------------------------
// Actions
// ------------------------------------------------------------
instance SaveReportAction : DTDFVocab:Action [
    base:desc "User‑initiated command to persist current ACC‑relevant data snapshot to the SQL database",
    DTDFVocab:IsAutomatic false
]

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "User‑initiated command to produce a PDF/CSV report summarizing recent ACC performance",
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Remote command to activate the Adaptive Cruise Control functionality on the vehicle",
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Remote command to deactivate the Adaptive Cruise Control functionality on the vehicle",
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Remote command to set a new target speed for the ACC controller",
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Remote command that triggers an immediate brake actuation in the physical vehicle",
    DTDFVocab:IsAutomatic false
]

instance ComputeSpeedCommandAction : DTDFVocab:Action [
    base:desc "Automatically computed speed command generated by the ACCDecisionModel and sent to the vehicle",
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the Controlling FE (ACC) within the Digital Twin. Desired actuation values (e.g., target speed, steering angle) are formatted by the Data Translation FE, which serializes the command and applies required unit conversions. The command messages are transmitted over the same Wi‑Fi/UDP link to the Physical Twin where the Actuation FE receives them and converts the high‑level commands into low‑level actuator signals such as motor voltage commands or servo position commands. The document does not describe explicit validation, authentication, conflict‑resolution mechanisms, or acknowledgement messages; feedback on execution is implicit in the subsequent sensor measurements that are sent back to the Digital Twin."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires that all devices share a common notion of time to support computation offloading. Clock synchronization must achieve at least 100 ms accuracy (the chosen limit due to hardware constraints), although many safety‑critical vehicular standards mandate tighter bounds. This synchronization interval applies to the coordination between the Physical Twin Entity (sensors/actuators) and the Digital Twin Entity (data management and control)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows the ISO 23247 reference architecture (RA). Software components are first identified and then grouped into three ISO‑based entities: User Entity (User Interface FE), Digital Twin Entity (data management, control), and Physical Twin Entity (sensor/actuator preprocessing and device communication). Each functional element (FE) is implemented as an individual ROS 2 package containing one or more ROS 2 nodes, and each entity is deployed on separate hardware resources, enabling distributed execution. The overall orchestration relies on ROS 2 DDS for inter‑package communication and on the entity‑based hierarchy defined by ISO 23247 to coordinate services across the constellation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Internal communication among software components uses a ROS 2 middleware network (publish‑/subscribe model). Inter‑entity communication (Physical Twin Entity ↔ Digital Twin Entity ↔ User Entity) occurs over a Wi‑Fi network employing UDP at the transport layer. The Data Translation FE mediates all data streams, handling message type alignment and unit conversion. No bandwidth, latency, reliability, redundancy, or security protocol details are provided in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system follows ISO 23247 (Digital twin framework for manufacturing), particularly Part 2 which defines the entity‑based reference architecture (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity). Implementations may use OPC Unified Architecture as a communication protocol to achieve interoperability."
]