// C3: Physical sensing components
instance HokuyoUst10LXSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST10LX LiDAR sensor mounted on the vehicle, generating high-resolution point‑cloud data"
    DTDFVocab:producedData LiDARPointCloudUDP
]

instance IntelDeepSenseD435iSensor : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera providing RGB and depth data"
    DTDFVocab:producedData DepthImageUDP
]

instance VehicleTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor module collecting vehicle state telemetry (speed, acceleration, steering angle, motor torque) via CAN bus"
    DTDFVocab:producedData VehicleTelemetryUDP
]

instance ActuatorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing actuator status, including motor and steering servo signals"
    DTDFVocab:producedData ActuatorStatusUDP
]

// C4: Data transmitted over the vehicle's onboard Wi‑Fi (UDP)
instance LiDARPointCloudUDP : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUst10LXSensor
]

instance DepthImageUDP : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iSensor
]

instance VehicleTelemetryUDP : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleTelemetrySensor
]

instance ActuatorStatusUDP : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ActuatorStatusSensor
]

// C5: Data after translation to ISO 23247 schema
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "LiDAR point‑cloud data serialized into ISO 23247 Data Translation FE schema"
    DTDFVocab:fromData LiDARPointCloudUDP
    DTDFVocab:inputTo DataTranslationEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth camera image data translated to ISO 23247 schema"
    DTDFVocab:fromData DepthImageUDP
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehicleTelemetryData : DTDFVocab:Data [
    base:desc "Vehicle state telemetry translated to ISO 23247 schema"
    DTDFVocab:fromData VehicleTelemetryUDP
    DTDFVocab:inputTo DataTranslationEnabler
]

instance ActuatorStatusData : DTDFVocab:Data [
    base:desc "Actuator status data translated to ISO 23247 schema"
    DTDFVocab:fromData ActuatorStatusUDP
    DTDFVocab:inputTo DataTranslationEnabler
]

// C10: Models for perception and state understanding
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point‑cloud to generate obstacle primitives"
    DTDFVocab:inputTo PointCloudClusteringTrackingEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter associating obstacle primitives across frames to produce object tracks"
    DTDFVocab:inputTo PointCloudClusteringTrackingEnabler
]

instance SemanticEnhancementModel : DTDFVocab:Model [
    base:desc "Semantic enrichment of vehicle and object state for user interface"
    DTDFVocab:inputTo SemanticEnhancementEnabler
]

// C11: Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Component that serializes raw sensor data to ISO 23247 and performs unit conversions"
    DTDFVocab:enables DataMonitoringService
]

instance PointCloudClusteringTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Component performing DBSCAN clustering and Kalman filter tracking on LiDAR point‑cloud"
    DTDFVocab:enables ComputationOffloadingService
]

instance ROS2CommunicationEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware for internal component communication"
    DTDFVocab:enables DataMonitoringService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D visualization of processed state for monitoring"
    DTDFVocab:enables DataMonitoringService
]

instance UserInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Virtual cockpit user interface displaying real‑time data and generating reports"
    DTDFVocab:enables DataMonitoringService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for remote ACC enable/disable, speed set and emergency braking"
    DTDFVocab:enables RemoteManagementService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for offloading ACC computation to remote cloud logic"
    DTDFVocab:enables ComputationOffloadingService
]

instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "Time‑series database (InfluxDB) for sensor data logging"
    DTDFVocab:enables DataMonitoringService
]

instance PostgresEnabler : DTDFVocab:Enabler [
    base:desc "Relational database (PostgreSQL) for configuration and telemetry storage"
    DTDFVocab:enables DataMonitoringService
]

instance RoboRacerFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Integration with RoboRacer project for autonomous vehicle management"
    DTDFVocab:enables RemoteManagementService
]

instance ISO23247StandardEnabler : DTDFVocab:Enabler [
    base:desc "Enabler ensuring compliance with ISO 23247 Data Translation FE schema"
    DTDFVocab:enables DataMonitoringService
]

instance JetpackEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK for driver and library development"
    DTDFVocab:enables DataMonitoringService
]

instance SemanticEnhancementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for semantic enrichment of vehicle and object state for user interface"
    DTDFVocab:enables DataMonitoringService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service that provides real‑time vehicle state, projected driving path and object tracks via UI enables snapshot capture and report generation"
    DTDFVocab:provides LiveVehicleStateInsight, ObjectTrackInsight, PerformanceReportInsight, CaptureSnapshotAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service to offload ACC algorithm (lead‑vehicle detection, desired‑speed calculation, command transmission) to remote cloud infrastructure"
    DTDFVocab:provides ACCOffloadStatusInsight, OffloadACCComputationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service enabling operators to remotely enable/disable ACC, set desired speed, and issue emergency braking via UI with low end‑to‑end latency"
    DTDFVocab:provides RemoteCommandExecutionStatusInsight, EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance LiveVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Live display of vehicle speed, heading, and actuator positions"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Visualization of detected object tracks and projected driving path"
]

instance PerformanceReportInsight : DTDFVocab:Insight [
    base:desc "CSV/JSON reports of captured snapshots and system performance metrics"
]

instance ACCOffloadStatusInsight : DTDFVocab:Insight [
    base:desc "Status indicator of ACC computation offloading and confidence metric"
]

instance RemoteCommandExecutionStatusInsight : DTDFVocab:Insight [
    base:desc "Execution status of remote ACC enable/disable, speed set, and emergency brake commands"
]

// C17: Actions
instance CaptureSnapshotAction : DTDFVocab:Action [
    base:desc "Capture a snapshot of the current vehicle state for reporting"
    DTDFVocab:IsAutomatic false
]

instance OffloadACCComputationAction : DTDFVocab:Action [
    base:desc "Trigger offloading of ACC algorithm to remote cloud"
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control remotely"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control remotely"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set desired cruise speed via remote command"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issue emergency braking command remotely"
    DTDFVocab:IsAutomatic false
]

// C2: Physical components
instance PhysicalTwinVehicle : DTDFVocab:Component [
    base:desc "1/10‑scale autonomous vehicle chassis equipped with HokuyoUst10LX LiDAR, Intel DeepSense D435i depth camera, NVIDIA Jetson NX and Orin Nano, and Vedder Electronic Speed Controller"
]

instance ChassisLowerLevel : DTDFVocab:Component [
    base:desc "Lower chassis structure of the 1/10‑scale vehicle"
]

instance ChassisUpperLevel : DTDFVocab:Component [
    base:desc "Upper chassis structure supporting sensor mounting"
]

// Environment containing vehicle
instance VehicleEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinVehicle, ChassisLowerLevel, ChassisUpperLevel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Driving commands (desired vehicle speed and steering angle) are generated by the DT and sent to the vehicle via the Actuation FE. Commands are serialized into ROS 2 messages, transmitted over the local Wi‑Fi link, and received by the vehicle’s onboard firmware. The Actuation FE converts high‑level commands into low‑level actuation signals (e.g., motor voltage and steering servo signals). A minimal feedback loop is formed by reading updated vehicle state from the sensors after command execution, re‑transmitting this state back to the DT through the Data Translation component. No explicit authentication or conflict‑resolution mechanisms are specified in the provided text."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires clock synchronization between physically distributed devices with an accuracy better than 100 ms in order to support computation offloading. All time‑stamping and event ordering throughout the digital twin rely on a common notion of time satisfied at the 100 ms precision level, as mandated by the safety‑critical vehicular standards referenced. No further granular synchronization frequencies or lower latency bounds are specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin follows the ISO 23247 Reference Architecture, mapping functional elements onto ROS 2 packages that host one or more ROS 2 nodes per implementation. The swarm of packages is deployed across three logical entities: the User Entity (providing a 3‑D visualisation FE split into a 3D visualization and a control panel FE), the Digital Twin Entity (housing data‑management and control‑mechanism FEs), and the Physical Twin Entity (containing data pre‑processing, actuation, and parts of the device‑communication logic, and exposing general automotive functionality such as point‑cloud clustering and tracking). Each FE instance resides on a separate hardware node, thereby decentralising execution while keeping the overall system orchestrated via a ROS 2 master that coordinates message passing and resource registration across the entities."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT employs a dual‑layer network architecture. Internally, all software components communicate over a ROS 2 (DDS) network with configurable QoS policies for real‑time, reliable messaging. Inter‑entity traffic (vehicle↔DT) travels over a Wi‑Fi link using UDP as the transport protocol, yielding low‑latency communication. Control loops must maintain a maximum round‑trip latency of 100 ms, requiring at least 100 Mbps link speed. Reliability is enhanced via DDS reliability QoS, and the network topology is a star configuration centered on the DT edge node."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed on an edge computing platform situated adjacent to or onboard the vehicle. ACC logic and the Data Translation pipeline are offloaded to this edge node, while the vehicle retains its low‑level control loops. The edge node stores ego vehicle state data on an external local storage device for persistence. The deployment model is on‑premise, single‑site, and can scale horizontally by adding additional edge nodes for more vehicle pods."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin follows ISO 23247 – Digital twin framework for manufacturing, specifically its Part 2 reference‑architecture which mandates an entity‑based decomposition and delineates functional responsibilities. The reference architecture recommends (but does not mandate) the use of OPC UA for device control and data acquisition, thereby conforming to the OPC Foundation interoperability standard. Additionally, the publicly available demonstration links to a publicly accessible GitHub repository (https://github.com/McSCert/Automotive-Digital-Twin) and a YouTube demonstration, illustrating adherence to open‑source and automotive industry interoperability practices."
]