    base:desc "Resource demand forecasting for energy, materials, and operational planning"
]

instance AutonomousAdjustmentAction : DTDFVocab:Action [
    base:desc "Autonomous system adjustments based on real-time environmental conditions"
    DTDFVocab:IsAutomatic true
]

instance CyberPhysicalCoordinationAction : DTDFVocab:Action [
    base:desc "Closed-loop coordination between distributed cyber-physical systems"
    DTDFVocab:IsAutomatic true
]

instance 3DVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D/4D modeling of physical assets for spatial analysis"
]

instance DashboardMetricsInsight : DTDFVocab:Insight [
    base:desc "Real-time dashboard displaying performance KPIs and operational metrics"
]

instance LifecycleTrackingInsight : DTDFVocab:Insight [
    base:desc "End-to-end tracking of asset lifecycle from design to disposal"
]

