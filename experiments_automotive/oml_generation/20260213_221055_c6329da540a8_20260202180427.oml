// C2: Acting Components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Controls motor speed for Observable Manufacturing Elements (OME) actuation via voltage commands"
]

instance SteeringServo : DTDFVocab:Actuator [
    base:desc "Manages steering mechanisms in physical systems with ROS2-based control interfaces"
]

// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Provides 2D point cloud data for spatial mapping and obstacle detection with 0.4° angular resolution, 10m range, 10Hz sampling frequency"
    DTDFVocab:producedData HokuyoPointCloudData
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Generates 3D point clouds and depth maps with 1080p resolution, 30Hz frame rate, sub-millimeter precision"
    DTDFVocab:producedData DepthCameraPointCloudData
]

// C4: Data Transmitted
instance HokuyoPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
    DTDFVocab:format "ROS2 PointCloud2"
    DTDFVocab:frequency "10Hz"
]

instance DepthCameraPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
    DTDFVocab:format "ROS2 PointCloud2 with depth information"
    DTDFVocab:frequency "30Hz"
]

instance VehicleStateTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VedderElectronicSpeedController, SteeringServo
    DTDFVocab:format "ROS2 CustomMsg with speed, angle, voltage readings"
    DTDFVocab:frequency "100Hz"
]

// C5: Data
instance RawLiDARPointCloud : DTDFVocab:Data [
    base:desc "Raw 2D/3D point cloud data from Hokuyo UST-10LX LiDAR sensor"
    DTDFVocab:fromData HokuyoPointCloudData
    DTDFVocab:processingStage "Point Cloud Clustering & Tracking"
]

instance ProcessedEnvironmentMap : DTDFVocab:Data [
    base:desc "Processed 3D environmental map generated from depth camera point clouds with noise filtering"
    DTDFVocab:fromData DepthCameraPointCloudData
    DTDFVocab:processingStage "Data Pre-Processing FE"
]

instance VehicleOperationalMetrics : DTDFVocab:Data [
    base:desc "Structured telemetry streams including motor speed, steering angle, and battery status"
    DTDFVocab:fromData VehicleStateTelemetry
    DTDFVocab:processingStage "Data Translation component"
]

// C10: Models
instance CADBasedVehicleModel : DTDFVocab:Model [
    base:desc "Geometric CAD-based representation of physical vehicle assets for spatial modeling"
    DTDFVocab:inputTo IntelDeepsenseD435iDepthCamera, HokuyoUST10LXLiDAR
]

instance PhysicsBasedControlModel : DTDFVocab:Model [
    base:desc "Behavioral model implementing control logic for motor/servo actuation based on ISO 23247 FE architecture"
    DTDFVocab:inputTo VedderElectronicSpeedController, SteeringServo
]

instance PredictiveFailureModel : DTDFVocab:Model [
    base:desc "AI/ML model for forecasting system failures (component degradation, battery degradation) using historical and real-time data"
    DTDFVocab:inputTo VehicleOperationalMetrics, ProcessedEnvironmentMap
]

instance OptimizationPathPlanningModel : DTDFVocab:Model [
    base:desc "Dynamic optimization model for path planning and route optimization using ROS2-based edge computing"
    DTDFVocab:inputTo ProcessedEnvironmentMap, VehicleOperationalMetrics
]

// C11: Enablers
instance ROS2Network : DTDFVocab:Enabler [
    base:desc "Standardized communication framework for real-time data exchange between software components using ROS2 topics/services"
    DTDFVocab:enables VehicleStateTelemetry, HokuyoPointCloudData, DepthCameraPointCloudData
]

instance OPCUAProtocol : DTDFVocab:Enabler [
    base:desc "Standardized data exchange protocol for real-time data aggregation from IoT sensors and edge devices"
    DTDFVocab:enables VehicleOperationalMetrics
]

instance TensorFlowAIFramework : DTDFVocab:Enabler [
    base:desc "AI/ML framework for predictive analytics including failure forecasting and optimization algorithms"
    DTDFVocab:enables PredictiveFailureModel, OptimizationPathPlanningModel
]

instance ROS2TimeSynchronization : DTDFVocab:Enabler [
    base:desc "Network synchronization mechanism ensuring low-latency coordination between distributed components"
    DTDFVocab:enables VehicleStateTelemetry, HokuyoPointCloudData
]

instance EdgeComputingFramework : DTDFVocab:Enabler [
    base:desc "Apache Kafka/Kubernetes-based edge processing for real-time data processing before cloud integration"
    DTDFVocab:enables ProcessedEnvironmentMap, VehicleOperationalMetrics
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous real-time observation of physical system states (vehicle performance, machinery health, battery status) with anomaly detection"
    DTDFVocab:provides VehiclePerformanceInsight, AnomalyDetectionInsight
]

instance DynamicOptimizationService : DTDFVocab:Service [
    base:desc "Dynamic optimization of operational parameters (fuel efficiency, energy distribution) with resource allocation capabilities"
    DTDFVocab:provides ParameterOptimizationAction, ResourceAllocationAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Forecasting system failures and demand forecasting using historical and real-time data"
    DTDFVocab:provides FailurePredictionInsight, DemandForecastingInsight
]

instance AutonomousControlService : DTDFVocab:Service [
    base:desc "Autonomous decision-making for physical systems with closed-loop control capabilities"
    DTDFVocab:provides AutonomousAdjustmentAction, CyberPhysicalCoordinationAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "3D/4D modeling and real-time dashboards for performance metrics visualization"
    DTDFVocab:provides 3DVisualizationInsight, DashboardMetricsInsight
]

instance LifecycleManagementService : DTDFVocab:Service [
    base:desc "End-to-end asset lifecycle tracking with customizable phases for different operational stages"
    DTDFVocab:provides LifecycleTrackingInsight, RegulatoryComplianceAction
]

// C17: Insights/Actions
instance VehiclePerformanceInsight : DTDFVocab:Insight [
    base:desc "Continuous monitoring of physical system states including speed, health metrics, and battery status"
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
