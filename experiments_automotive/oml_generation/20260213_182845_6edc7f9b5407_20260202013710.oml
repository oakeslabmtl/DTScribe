// =============================
// Physical Sensing Components
// =============================

instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2D LiDAR providing real‑time point clouds of the vehicle surroundings."
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering depth images and supplemental point‑cloud data."
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board speed sensor measuring the ego‑vehicle longitudinal speed."
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor reporting the current wheel steering angle."
    DTDFVocab:producedData SteeringAngleTransmitted
]

// =============================
// Physical‑to‑Virtual Data Transmission
// =============================

instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ObjectTracksTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR, IntelRealSenseD435iDepthCamera
]

// =============================
// Data Artifacts
// =============================

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud frames captured at ≈10 Hz."
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler, JetPack5SDKEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth images generated by the RealSense D435i."
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler, JetPack5SDKEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego‑vehicle longitudinal speed values (m / s)."
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler, JetPack5SDKEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering‑angle measurements (degrees)."
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler, JetPack5SDKEnabler
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks derived from DBSCAN clustering and Kalman‑filter tracking."
    DTDFVocab:fromData ObjectTracksTransmitted
    DTDFVocab:inputTo JetPack5SDKEnabler
]

// =============================
// Analytical Models
// =============================

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering algorithm for detecting surrounding objects."
    DTDFVocab:inputTo JetPack5SDKEnabler
]

instance KalmanFilterTrackerModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based tracker that refines object trajectories over time."
    DTDFVocab:inputTo JetPack5SDKEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) algorithm conforming to ISO 15622 performance class I."
    DTDFVocab:inputTo JetPack5SDKEnabler
]

// =============================
// Enablers (Tooling & Runtime)
// =============================

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware handling intra‑entity publish/subscribe communication."
    DTDFVocab:enables DataMonitoringUIService, RemoteManagementUIService
]

instance WiFiLinkEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi network providing inter‑entity data links between physical twin, digital twin, and user workstation."
    DTDFVocab:enables DataMonitoringUIService, RemoteManagementUIService
]

instance JetPack5SDKEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK delivering GPU‑accelerated compute for perception and control algorithms."
    DTDFVocab:enables ComputationOffloadingACCService, ReportingService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment used for complex model development and verification."
    DTDFVocab:enables ComputationOffloadingACCService
]

instance Python38RuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime executing ROS 2 nodes and data‑processing scripts."
    DTDFVocab:enables ComputationOffloadingACCService
]

instance CppROS2NodeEnabler : DTDFVocab:Enabler [
    base:desc "C++ ROS 2 nodes providing high‑performance processing of sensor streams."
    DTDFVocab:enables ComputationOffloadingACCService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database backend used for persisting time‑series reports and raw telemetry."
    DTDFVocab:enables ReportingService
]

// =============================
// Services
// =============================

instance DataMonitoringUIService : DTDFVocab:Service [
    base:desc "Web‑based UI visualizing live speed, steering angle, object tracks and projected path."
    DTDFVocab:provides SpeedSteeringInsight, ObjectTracksInsight, ProjectedPathInsight
]

instance ComputationOffloadingACCService : DTDFVocab:Service [
    base:desc "Computation offloading service executing ACC lead‑vehicle detection and speed computation in the digital twin."
    DTDFVocab:provides ProjectedPathInsight
]

instance RemoteManagementUIService : DTDFVocab:Service [
    base:desc "Remote management UI allowing operators to enable/disable ACC, set desired speed, and trigger emergency braking."
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Reporting service generating time‑series mission reports stored in a SQL database."
    DTDFVocab:provides ReportGenerationInsight
]

// =============================
// Insights & Actions
// =============================

instance SpeedSteeringInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of ego‑vehicle speed and steering angle."
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Live display of detected object tracks around the vehicle."
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected future path of the ego vehicle based on ACC planning."
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Time‑series mission report summarizing speed, steering, and detected objects."
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets the desired cruise speed for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking of the vehicle."
    DTDFVocab:IsAutomatic false
]

// =============================
// Acting Components (Physical)
// =============================

instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller receiving voltage commands to regulate vehicle speed."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo providing steering‑angle commands to the vehicle chassis."
]

// =============================
// System Entities (Distributed Architecture)
// =============================

instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical twin hosted on‑board the 1/10‑scale autonomous vehicle, containing sensors and actuators."
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital twin executing perception, ACC, and reporting services on external compute (NVIDIA Jetson devices)."
]

instance UserEntity : DTDFVocab:Component [
    base:desc "Operator workstation delivering monitoring and remote‑management user interfaces."
]

instance CrossSystemEntity : DTDFVocab:Component [
    base:desc "Cross‑system entity responsible for data translation between ROS 2 messages and SQL storage."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity sends desired speed set‑points, ACC enable/disable commands, emergency‑brake signals, and steering adjustments back to the vehicle via the Actuation Functional Entity, which converts them into motor voltage and servo commands."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real‑time operation with end‑to‑end network latency bounded at ≤100 ms and clock synchronization accuracy of 100 ms across all DTS components, satisfying 3GPP TS 22.185 requirements."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A distributed constellation where sensor data flows from the Physical Twin Entity over Wi‑Fi to the Digital Twin Entity (ROS2 network), the Digital Twin processes data, generates control commands and visualizations, and the User Entity provides a UI on a separate workstation; a Cross‑System Data Translation FE harmonises message formats and units."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is used during the operational stage for monitoring, control, and remote management, and also during development/testing as a cyber‑physical experimentation platform for the ACC subsystem."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT maintains high fidelity by using raw LiDAR point clouds and real‑time vehicle state; validity is ensured through latency ≤100 ms, clock sync ≤100 ms, and compliance with ISO 15622 ACC specifications; reporting and SQL storage enable post‑run verification of model outputs."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication uses a Wi‑Fi network employing ROS 2 topics; the Data Translation FE serialises data, aligns message types and performs unit conversion; intra‑entity communication also relies on ROS 2 DDS transport."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity components run on the vehicle’s Jetson Orin Nano; Digital Twin Entity components run on an external compute platform (e.g., PC or cloud) hosting ROS 2 nodes for ACC, clustering, and visualization; User Entity UI runs on a workstation connected via the same Wi‑Fi network."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The design follows ISO 23247 reference architecture, uses ISO 15622 for ACC functionality, references ISO/IEC 30173 for digital‑twin concepts, and adopts 3GPP TS 22.185 for latency requirements; ROS 2 provides a standardized middleware layer."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by enforcing a hard latency bound (≤100 ms), clock synchronization (≤100 ms), and implementing emergency‑brake commands; the DT operates in a Human‑in‑the‑Loop fully autonomous mode, with remote actions limited to safety‑critical commands, though specific cybersecurity mechanisms are not detailed."
]