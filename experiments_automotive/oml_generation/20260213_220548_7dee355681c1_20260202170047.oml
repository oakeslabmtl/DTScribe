// C4: Data Transmission
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance MotorSpeedTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSpeedSensor
]

instance SteeringPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ServoPositionTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ServoPositionSensor
]

instance VehicleStateTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance TemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

instance VibrationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
]

instance ProcessedLiDARData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARClusteringTracker
]

instance FilteredSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom KalmanFilter
]

instance AnomalyDetectionResults : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AnomalyDetectionAI
]

instance DebrisClassificationResults : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DebrisCatalogClassifier
]

instance ThermalImageData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ThermalImagingSensor
]

instance OPCUADataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OPCUASensorInterface
]

instance CANBusTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CANBusInterface
]

instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance StructuralHealthMetrics : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralHealthMonitor
]

instance DriverBehaviorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TelematicsDataCollector
]

instance DetectedObjects : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARObjectDetection
]

instance RadarData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RadarSensor
]

instance CameraImageData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CameraSensor
]

// C5: Data Storage
instance RawSensorDataStore : DTDFVocab:Data [
    base:desc "Raw sensor data storage for historical analysis and reporting"
    DTDFVocab:fromData LiDARPointCloudData, MotorSpeedTelemetry, SteeringPositionData, ServoPositionTelemetry, VehicleStateTelemetry,
                        TemperatureData, PressureData, VibrationData, ProcessedLiDARData, FilteredSensorData,
                        AnomalyDetectionResults, DebrisClassificationResults, ThermalImageData, OPCUADataStream,
                        CANBusTelemetry, MotorCurrentData, StructuralHealthMetrics, DriverBehaviorData,
                        DetectedObjects, RadarData, CameraImageData
]

instance ProcessedDataStore : DTDFVocab:Data [
    base:desc "Processed sensor data store for real-time analysis and visualization"
    DTDFVocab:fromData ProcessedLiDARData, FilteredSensorData, AnomalyDetectionResults, DebrisClassificationResults,
                        ThermalImageData, StructuralHealthMetrics, DetectedObjects
    DTDFVocab:inputTo ROS2DataProcessingEnabler
]

instance TelemetryDashboardData : DTDFVocab:Data [
    base:desc "Real-time telemetry data for visualization dashboards"
    DTDFVocab:fromData VehicleStateTelemetry, MotorSpeedTelemetry, TemperatureData, PressureData, DriverBehaviorData
    DTDFVocab:inputTo GrafanaDashboardEnabler
]

instance SimulationResultsStore : DTDFVocab:Data [
    base:desc "Simulation results storage for validation and comparison"
    DTDFVocab:fromData ProcessedLiDARData, AnomalyDetectionResults, DebrisClassificationResults
    DTDFVocab:inputTo SimulationValidationEnabler
]

instance HistoricalFailureData : DTDFVocab:Data [
    base:desc "Historical failure data for predictive maintenance models"
    DTDFVocab:fromData AnomalyDetectionResults, VibrationData, StructuralHealthMetrics
]

// C10: Models
instance CyberPhysicalStateModel : DTDFVocab:Model [
    base:desc "Model predictive control (MPC) and Kalman filtering model for cyber-physical state synchronization"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance FaultDetectionModel : DTDFVocab:Model [
    base:desc "AI-driven anomaly detection model using autoencoders and GANs for fault detection"
