// C2: Acting Components
instance CyberPhysicalControlActuator : DTDFVocab:ActuatingComponent [
    base:desc "Real-time control actuators for cyber-physical systems using distributed consensus algorithms and adaptive control laws"
]

instance AutonomousVehicleSteeringActuator : DTDFVocab:ActuatingComponent [
    base:desc "Steering actuators for autonomous vehicles implementing AI-driven obstacle avoidance via deep reinforcement learning"
]

instance ManufacturingRoboticCellActuator : DTDFVocab:ActuatingComponent [
    base:desc "Autonomous robotic cell control system using ROS-based systems for collision avoidance and task assignment"
]

instance SpacecraftOrbitControlActuator : DTDFVocab:ActuatingComponent [
    base:desc "Autonomous reboost control system for satellite orbit maintenance using PID controllers with adaptive gains"
]

