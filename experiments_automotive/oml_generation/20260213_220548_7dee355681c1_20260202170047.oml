// C11: Enablers
instance ROS2DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware for real-time data processing and communication between software components"
    DTDFVocab:enables ProcessedDataStore, SimulationResultsStore
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink platform for hybrid simulation of complex cyber-physical dynamics"
    DTDFVocab:enables CyberPhysicalStateModel, OptimizationControlModel, FuelEfficiencyOptimization,
                        TrajectoryOptimization, PhysicsInformedNeuralNetwork
]

instance PythonMLEnabler : DTDFVocab:Enabler [
    base:desc "Python-based machine learning ecosystem for custom AI/ML models"
    DTDFVocab:enables MultivariateForecastingModel, PredictiveMaintenanceModel, RULPredictionModel,
                        WeatherAwareModel, CollisionRiskModel, BatteryDegradationModel,
                        ThermalRunawayPrediction, SOCEstimationModel
]

instance COMSOLMultiphysicsEnabler : DTDFVocab:Enabler [
    base:desc "COMSOL Multiphysics for multi-physics coupling in cyber-physical systems"
    DTDFVocab:enables PhysicsInformedNeuralNetwork, BatteryThermalModel
]

instance ANSYSStructuralEnabler : DTDFVocab:Enabler [
    base:desc "ANSYS structural analysis tools for aerospace applications"
    DTDFVocab:enables StructuralHealthMonitoringModel
]

instance ANSYSMechanicalEnabler : DTDFVocab:Enabler [
    base:desc "ANSYS Mechanical for finite element analysis in automotive applications"
    DTDFVocab:enables ChassisDynamicsModel
]

instance UnityVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unity/Unreal Engine platform for high-fidelity vehicle simulations and 3D visualizations"
    DTDFVocab:enables InteractiveVisualizationModel
]

instance ROS2ControlEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 platform for autonomous driving and robotic control systems"
    DTDFVocab:enables DecentralizedControlModel, AutonomousDrivingControl,
                        AutonomousRoboticControl, DigitalTwinProcessAutomation
]

instance NVIDIADriveEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA DRIVE platform for autonomous driving edge AI perception and localization"
    DTDFVocab:enables AdaptiveCruiseControl
]

instance OPCUAProcessingEnabler : DTDFVocab:Enabler [
    base:desc "OPC UA processing framework for industrial IoT sensor data integration"
    DTDFVocab:enables ProcessQualityModel
]

instance HyperledgerFabricEnabler : DTDFVocab:Enabler [
    base:desc "Hyperledger Fabric blockchain platform for supply chain traceability"
    DTDFVocab:enables SupplyChainTraceability
]

instance AnyLogicEnabler : DTDFVocab:Enabler [
    base:desc "AnyLogic platform for system dynamics modeling of manufacturing processes"
    DTDFVocab:enables ResourceSchedulingModel
]

instance GrafanaDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Grafana platform for real-time telemetry visualization dashboards"
    DTDFVocab:enables TelemetryDashboardData
]

instance SimulationValidationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation validation framework for comparing real-time data with simulation results"
    DTDFVocab:enables SimulationResultsStore
]

instance SlidingModeControlEnabler : DTDFVocab:Enabler [
    base:desc "Sliding-mode control implementation for adaptive control laws"
    DTDFVocab:enables AdaptiveControlLaw
]

instance PIDControlEnabler : DTDFVocab:Enabler [
    base:desc "PID controller implementation for battery thermal management"
    DTDFVocab:enables BatteryBalancingControl
]

instance TensorFlowPyTorchEnabler : DTDFVocab:Enabler [
    base:desc "TensorFlow/PyTorch framework for custom AI/ML models"
    DTDFVocab:enables FaultDetectionModel
]

instance PLCIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "PLC integration platform for digital twin process automation"
    DTDFVocab:enables DigitalTwinProcessAutomation
]

instance NVIDIAJetsonEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetson platform for edge AI inference in real-time control applications"
    DTDFVocab:enables AutonomousVehicleSteeringActuator, ManufacturingRoboticCellActuator
]

instance NISTCybersecurityEnabler : DTDFVocab:Enabler [
    base:desc "NIST Cybersecurity Framework for secure digital twin ecosystems"
    DTDFVocab:enables CyberPhysicalControlActuator, AutonomousVehicleSteeringActuator
]

instance ISO27001Enabler : DTDFVocab:Enabler [
    base:desc "ISO/IEC 27001 cybersecurity standards for digital twin security"
    DTDFVocab:enables CyberPhysicalControlActuator, AutonomousVehicleSteeringActuator
]

