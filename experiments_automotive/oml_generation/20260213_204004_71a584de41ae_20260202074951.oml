// -----------------------------------------------------------------------------
// Physical Sensing Components
// -----------------------------------------------------------------------------
instance HokuyoUst10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR for point‑cloud acquisition"
    DTDFVocab:producedData HokuyoLidarPCL_Transmit
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera for visual sensing"
    DTDFVocab:producedData IntelDepthImage_Transmit
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board odometry sensor measuring vehicle speed"
    DTDFVocab:producedData VehicleSpeedData_Transmit
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering controller sensor measuring steering angle"
    DTDFVocab:producedData SteeringAngleData_Transmit
]

// -----------------------------------------------------------------------------
// Physical‑to‑Virtual Data Transmitted
// -----------------------------------------------------------------------------
instance HokuyoLidarPCL_Transmit : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUst10LXLidar
]

instance IntelDepthImage_Transmit : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

instance VehicleSpeedData_Transmit : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleData_Transmit : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// -----------------------------------------------------------------------------
// Processed Data Transmitted (from model outputs)
// -----------------------------------------------------------------------------
instance ClusteredLidarPCL_Transmit : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUst10LXLidar
]

instance TrackedObjects_Transmit : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUst10LXLidar
]

instance DesiredSpeedCommand_Transmit : DTDFVocab:DataTransmitted [
    // Produced source omitted to avoid domain conflict
]

instance MotorVoltageCommand_Transmit : DTDFVocab:DataTransmitted [
    // Produced source omitted to avoid domain conflict
]

instance VisualizationState_Transmit : DTDFVocab:DataTransmitted [
    // Produced source omitted to avoid domain conflict
]

instance ReportCSV_Transmit : DTDFVocab:DataTransmitted [
    // Produced source omitted to avoid domain conflict
]

instance ReportJSON_Transmit : DTDFVocab:DataTransmitted [
    // Produced source omitted to avoid domain conflict
]

// -----------------------------------------------------------------------------
// Data
// -----------------------------------------------------------------------------
instance RawLiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw point‑cloud data from the Hokuyo UST‑10LX LiDAR"
    DTDFVocab:inputTo ClusteringEnabler
    DTDFVocab:fromData HokuyoLidarPCL_Transmit
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames from the Intel D435i camera"
    DTDFVocab:inputTo DataMonitoringEnabler
    DTDFVocab:fromData IntelDepthImage_Transmit
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed samples from the onboard odometry"
    DTDFVocab:inputTo DataMonitoringEnabler
    DTDFVocab:inputTo ComputationOffloadingEnabler
    DTDFVocab:fromData VehicleSpeedData_Transmit
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Vehicle steering angle samples from the steering controller"
    DTDFVocab:inputTo DataMonitoringEnabler
    DTDFVocab:inputTo ComputationOffloadingEnabler
    DTDFVocab:fromData SteeringAngleData_Transmit
]

instance ClusteredPointCloudData : DTDFVocab:Data [
    base:desc "LiDAR point‑cloud after DBSCAN clustering"
    DTDFVocab:inputTo TrackingEnabler
    DTDFVocab:fromData ClusteredLidarPCL_Transmit
]

instance TrackedObjectTracksData : DTDFVocab:Data [
    base:desc "Multi‑object tracks produced by Kalman filtering"
    DTDFVocab:inputTo ACCIsolateEnabler
    DTDFVocab:fromData TrackedObjects_Transmit
]

instance DesiredSpeedCommandData : DTDFVocab:Data [
    base:desc "Desired speed command computed by ISO 15622 ACC controller"
    DTDFVocab:inputTo ActuationEnabler
    DTDFVocab:fromData DesiredSpeedCommand_Transmit
]

instance MotorVoltageCommandData : DTDFVocab:Data [
    base:desc "Motor voltage command sent to the Vedder Electronic Speed Controller"
    DTDFVocab:fromData MotorVoltageCommand_Transmit
]

instance VisualizationStateData : DTDFVocab:Data [
    base:desc "Aggregated state for 3‑D virtual cockpit visualization"
    DTDFVocab:inputTo VisualizationEnabler
    DTDFVocab:fromData VisualizationState_Transmit
]

instance ReportCSVData : DTDFVocab:Data [
    base:desc "Human‑readable CSV report of vehicle state and tracks"
    DTDFVocab:inputTo ReportGenerationEnabler
    DTDFVocab:fromData ReportCSV_Transmit
]

instance ReportJSONData : DTDFVocab:Data [
    base:desc "Human‑readable JSON report of vehicle state and tracks"
    DTDFVocab:inputTo ReportGenerationEnabler
    DTDFVocab:fromData ReportJSON_Transmit
]

// -----------------------------------------------------------------------------
// Enablers
// -----------------------------------------------------------------------------
instance ClusteringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that activates the DBSCAN clustering ROS2 node"
    DTDFVocab:enables DataMonitoringService
]

instance TrackingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that activates the Kalman tracking ROS2 node"
    DTDFVocab:enables DataMonitoringService
]

instance ACCIsolateEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that activates the ISO 15622 ACC ROS2 node"
    DTDFVocab:enables ComputationOffloadingService
]

instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for real‑time monitoring of vehicle state and tracks"
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for remote offloading of ACC computations"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that provides remote enable/disable ACC and emergency stop actions"
    DTDFVocab:enables RemoteManagementService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that drives 3‑D virtual cockpit visualization"
    DTDFVocab:enables VisualizationService
]

instance ReportGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that generates CSV/JSON time‑series reports"
    DTDFVocab:enables ReportGenerationService
]

instance ActuationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that forwards desired speed commands to the motor voltage generator"
    DTDFVocab:enables RemoteManagementService
]

// -----------------------------------------------------------------------------
// Models (implemented as ROS2 nodes)
// -----------------------------------------------------------------------------
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of raw LiDAR point clouds"
    DTDFVocab:inputTo ClusteringEnabler
]

instance KalmanTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter for multi‑object track estimation"
    DTDFVocab:inputTo TrackingEnabler
]

instance ACCISO15622Model : DTDFVocab:Model [
    base:desc "ISO 15622 compliant adaptive cruise control controller"
    DTDFVocab:inputTo ACCIsolateEnabler
]

// -----------------------------------------------------------------------------
// Acting Components
// -----------------------------------------------------------------------------
instance DedicatedActuationFE : DTDFVocab:ActingComponent [
    base:desc "Converts desired speed command from the ACC controller into motor voltage commands for the Vedder Electronic Speed Controller"
]

instance SteeringActuationFE : DTDFVocab:ActingComponent [
    base:desc "Steering servo motor controlled by low‑level motor control on the Jetson Orin Nano"
]

// -----------------------------------------------------------------------------
// Services
// -----------------------------------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Continuous real‑time display of vehicle speed, steering, object tracks, and projected path"
    DTDFVocab:provides VehicleStateInsight, ObjectTrackingInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Remote execution of ISO 15622 ACC algorithm"
    DTDFVocab:provides DesiredSpeedInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator interface to enable/disable ACC, adjust desired speed, and issue emergency braking"
    DTDFVocab:provides ACCEnableAction, ACCDisableAction, EmergencyBrakeAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3‑D virtual cockpit displays vehicle state and surroundings"
    DTDFVocab:provides VisualStateInsight
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Human‑readable CSV/JSON time‑series reports of vehicle state and tracks stored in the SQL database"
    DTDFVocab:provides PerformanceIssueInsight
]

// -----------------------------------------------------------------------------
// Insights / Actions
// -----------------------------------------------------------------------------
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Realtime insight into vehicle speed and steering angle as reported by the PT"
]

instance ObjectTrackingInsight : DTDFVocab:Insight [
    base:desc "Realtime insight into multi‑object tracks produced by the Kalman filter"
]

instance DesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Realtime insight into the desired speed command computed by ISO 15622 ACC controller"
]

instance VisualStateInsight : DTDFVocab:Insight [
    base:desc "Realtime insight into the 3‑D visual state of the vehicle and its environment"
]

instance PerformanceIssueInsight : DTDFVocab:Insight [
    base:desc "Insight into performance issues detected through report analysis"
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Emergency braking command issued to the actuator via the motor voltage generator"
    DTDFVocab:IsAutomatic false
]

instance ACCEnableAction : DTDFVocab:Action [
    base:desc "Enable ISO 15622 ACC controller"
    DTDFVocab:IsAutomatic false
]

instance ACCDisableAction : DTDFVocab:Action [
    base:desc "Disable ISO 15622 ACC controller"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT via the Actuation FE. Desired speed values computed by the ACC controller are published on a ROS2 topic and translated by the Data Translation FE into motor voltage commands, which are then sent to the Vedder speed controller. Remote management commands (enable/disable ACC, change desired speed, emergency braking) are also transmitted over Wi‑Fi to the vehicle’s control interface."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates at a real‑time frequency matching the vehicle’s perception cycle (≈10 Hz). End‑to‑end communication latency is required to be ≤100 ms, as specified by 3GPP TSP 22.185 for V2V. Clock synchronization among all DT components is maintained to within 100 ms tolerance using ROS2 time utilities."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation is organized around the ISO 23247 reference architecture, with each Functional Entity (FE) mapped to a ROS2 package. The Physical Twin Entity hosts data pre‑processing and actuation FE; the Digital Twin Entity aggregates data collection, reporting, ACC control, and presentation FEs; the User Entity hosts a 3‑D visualization FE and a UI control panel FE; Cross‑System Entity implements Data Translation FE for inter‑entity communication. ROS2 topics serve as the internal message bus, while Wi‑Fi provides the external connectivity."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle covers the Operated phase of the physical vehicle. Design and requirement gathering (R1–R8) are performed at the top of the development cycle; architecture and implementation are performed subsequently; no manufacturing or as‑built representation is discussed. The DT is considered a virtual representation of an operating, manufactured vehicle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT’s fidelity is ensured by using validated clustering (DBSCAN) and tracking (Kalman filter) algorithms, an ISO 15622 ACC controller, and unit consistency via the Data Translation FE. Verification is performed by comparing DT outputs (vehicle speed, steering, track predictions) against ground truth from the PT; validation includes latency tests to confirm the 100 ms bound. Uncertainty in sensor data is mitigated via filtering, but explicit probabilistic error modeling is not described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication occurs over a standard Wi‑Fi network using the ROS2 communication stack. ROS2 nodes publish/subscribe on topics with DDS as the underlying transport, typically using UDP/TCP. The Data Translation FE handles serialization and unit conversion. Overall end‑to‑end latency is bounded by the 3GPP TSP 22.185 specification for V2V (≤100 ms)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity is deployed on a remote edge server (cloud or edge) accessible via Wi‑Fi from the vehicle. The Physical Twin Entity resides on the vehicle’s Jetson Orin Nano. The User Entity runs on a user workstation or a browser‑based interface hosted on a local server. All components are packaged as ROS2 nodes and containerized where appropriate."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system follows ISO 23247 (digital twin manufacturing framework) for architecture and entity mapping, ISO 15622 for ACC control logic, and ISO 30173 for terminology. It also employs ROS2 as the middleware standard and NVIDIA JetPack 5.0 for software stacks."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed for a safety‑critical automotive system; requirements specify a maximum latency of 100 ms and 100 ms clock synchronization for safe operation. No explicit cybersecurity protocols, authentication mechanisms, or fail‑safe architectures are described in the document."
]