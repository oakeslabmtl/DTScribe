// Physical Sensing Components
instance HokuyoUST10LxLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR sensor installed on the vehicle, provides 360° distance measurements at 10 Hz"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera capturing RGB‑D data at 30 fps"
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor mounted on lower chassis, measures wheel speed"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring wheel steering angle"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// Physical-to-Virtual Interaction (Data Transmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LxLiDAR
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Data Instances
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Serialized LiDAR point cloud data serialized and type‑aligned for the DT"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo MATLABEnabler, ROS2DDSEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image from D435i camera, serialized for the DT"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo MATLABEnabler, PythonEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Real‑time vehicle speed measurement"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo PythonEnabler, ROS2DDSEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Real‑time steering angle measurement"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo PythonEnabler, ROS2DDSEnabler
]

// Models
instance ACCControllerISO15622 : DTDFVocab:Model [
    base:desc "ACC controller complying with ISO 15622 (Performance Class I)"
    DTDFVocab:inputTo CppEnabler
]

instance DBSCANClusterer : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering algorithm for LiDAR data"
    DTDFVocab:inputTo MATLABEnabler
]

instance KalmanTracker : DTDFVocab:Model [
    base:desc "Kalman filter tracker for object tracks in LiDAR data"
    DTDFVocab:inputTo MATLABEnabler
]

instance SQLDataStorageSchema : DTDFVocab:Model [
    base:desc "SQL schema for storing telemetry and perception data"
    DTDFVocab:inputTo SQLDatabaseEnabler
]

instance F3DVisualizationModel : DTDFVocab:Model [
    base:desc "3D visualization model for vehicle and environment"
    DTDFVocab:inputTo MATLABEnabler
]

// Enablers
instance ROS2DDSEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware using DDS protocol for real‑time data transport"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, VisualizationService
]

instance PythonEnabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 environment for data collection, remote management, and visualization scripts"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService, VisualizationService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ ROS 2 node implementation for high‑performance vehicle control and model execution"
    DTDFVocab:enables ComputationOffloadingService
]

instance MATLABEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink runtime for DBSCAN clustering, Kalman filtering, and 3D visualization"
    DTDFVocab:enables ComputationOffloadingService, VisualizationService
]

instance JetPackEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK for GPU acceleration of perception and control algorithms"
    DTDFVocab:enables ComputationOffloadingService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database engine for data collection and storage"
    DTDFVocab:enables DataCollectionStorageService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI and reporting of vehicle telemetry and operational data"
    DTDFVocab:provides VehicleTelemetryInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC algorithm execution on the DT, including perception models"
    DTDFVocab:provides ACCDecisionReportInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to enable/disable ACC, adjust desired speed, and issue emergency braking"
    DTDFVocab:provides EmergencyBrakeAction, AdjustDesiredSpeedAction, DiagnosePerformanceAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D vehicle/environment view and control panel"
    DTDFVocab:provides VehicleEnvironmentInsight
]

instance DataCollectionStorageService : DTDFVocab:Service [
    base:desc "Collects and stores telemetry, perception, and event data in SQL database"
    DTDFVocab:provides DataStorageAction
]

// Insights
instance VehicleTelemetryInsight : DTDFVocab:Insight [
    base:desc "Real‑time vehicle speed, steering angle, and system health information"
]

instance ACCDecisionReportInsight : DTDFVocab:Insight [
    base:desc "ACC decision reports indicating desired speed and trajectory adjustments"
]

instance VehicleEnvironmentInsight : DTDFVocab:Insight [
    base:desc "3D visualization of vehicle position and surrounding objects"
]

// Actions
instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Command to trigger vehicle emergency braking"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to set desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance DiagnosePerformanceAction : DTDFVocab:Action [
    base:desc "Action to retrieve performance diagnostics and logs"
    DTDFVocab:IsAutomatic false
]

instance DataStorageAction : DTDFVocab:Action [
    base:desc "Action to save collected data to SQL database"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands—desired speed, steering angles, emergency brake signals—to the Physical Twin via the Actuation FE over the same Wi‑Fi link; the outputs are converted into motor voltage commands and steering servo signals to actuate the vehicle."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Operations run in real‑time with a maximum end‑to‑end latency of 100 ms and clock synchronization within 100 ms; sensor sampling and DT processing are performed at the perception cycle rate (≈10–20 Hz), while ACC decision updates are issued each perception cycle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates the Physical Twin Entity (sensing/actuation), Digital Twin Entity (data processing, ACC logic), and User Entity (UI visualisation), connected via Data Translation FE, with communication over ROS2 DDS on Wi‑Fi linking on‑board and cloud‑based components."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the Operated lifecycle stage, providing real‑time monitoring and remote control during vehicle operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time fidelity is constrained by a 100 ms latency budget; DBSCAN and Kalman‑filter algorithms provide proven clustering and tracking fidelity; ACC follows ISO 15622 specifications, while data integrity is preserved via synchronized clocks and type‑aligned data translation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication uses a Wi‑Fi network with underlying UDP over ROS2 DDS; intra‑entity communication occurs within the ROS2 network; data translation is handled by the Data Translation FE, ensuring message type and unit consistency."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT runs partially on the on‑board NVIDIA Jetson Orin Nano (edge compute) and partially in a cloud environment for ACC computation, both running Linux with ROS2 and NVIDIA JetPack."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Reference Architecture), ISO 15622 for ACC, and ROS2 middleware; OPC Unified Architecture (IEC 62541) is mentioned as a possible QoS/translation FE option."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical requirements include maintaining <100 ms latency, 100 ms clock synchronization (R7, R8), modular design per ISO 23247, and controlled remote command execution to prevent accidental human‑harm."
]