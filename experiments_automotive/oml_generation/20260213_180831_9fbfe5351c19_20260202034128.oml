// C1: Physical Twin Entity (ROS2 Package)
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "1/10-scale teleoperated autonomous vehicle ROS2 package hosting physical sensing and processing components for ADAS ACC system"
    base:contains LiDARPointCloudSensor, VehicleStateSensor, MotorSensor, SteeringSensor, PointCloudClusteringNode, PointCloudTrackingNode, DataTranslationNode
] // Fixed DataPreProcessingFE reference

// C2: Acting Components
instance AdaptiveCruiseControlSystem : DTDFVocab:ActingComponent [
    base:desc "Resource-constrained ACC system in physical vehicle requiring computation offloading to cloud for lead vehicle detection, speed calculation, and actuation commands"
]

instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Vehicle motor control system for adaptive cruise control actuation commands"
]

instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Vehicle steering servo system for adaptive cruise control path adjustments"
]

// C3: Physical sensing components
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor capturing point cloud data for object detection in ADAS ACC system"
    DTDFVocab:producedData RawLiDARData
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor providing real-time position, velocity, and acceleration data for ACC system"
    DTDFVocab:producedData VehicleStateData
]

instance MotorSensor : DTDFVocab:SensingComponent [
    base:desc "Motor speed and torque sensor for adaptive cruise control feedback"
    DTDFVocab:producedData MotorPerformanceData
]

instance SteeringSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle and servo position sensor for ACC path tracking"
    DTDFVocab:producedData SteeringFeedbackData
]

// C4: Data Transmitted
instance RawLiDARData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance MotorPerformanceData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSensor
]

instance SteeringFeedbackData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringSensor
]

// C5: Data Pre-Processing FE Components
instance PointCloudClusteringNode : DTDFVocab:Component [
    base:desc "ROS2 node implementing Point Cloud Clustering for raw LiDAR data processing in physical twin"
]

instance PointCloudTrackingNode : DTDFVocab:Component [
    base:desc "ROS2 node implementing Point Cloud Tracking for object detection and trajectory prediction in physical twin"
]

instance DataTranslationNode : DTDFVocab:Component [
    base:desc "ROS2 node performing data serialization, message type alignment, and unit conversions for inter-component communication"
]

// C6: Data Processing Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time data monitoring service providing vehicle state visualization, projected driving path, and detected object tracks via UI with data reporting capabilities"
    DTDFVocab:provides RealTimeVisualizationInsight, ObjectTrackingReport
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service transferring ACC system processing (lead vehicle detection, speed calculation, and actuation commands) to cloud-based resources"
    DTDFVocab:provides CloudProcessingAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management service enabling ACC control (enable/disable, speed adjustment, emergency braking) via cloud interface"
    DTDFVocab:provides RemoteEnableAction, SpeedAdjustAction, EmergencyBrakeAction
]

// C7: Data Models
instance LiDARProcessingModel : DTDFVocab:Model [
    base:desc "Model implementing Point Cloud Clustering & Tracking algorithms for raw LiDAR data processing"
    DTDFVocab:inputTo DataTranslationNode
]

instance VehicleStateModel : DTDFVocab:Model [
    base:desc "Model processing vehicle state data for ACC system operation"
    DTDFVocab:inputTo DataTranslationNode
]

// C8: Data
instance ProcessedLiDARData : DTDFVocab:Data [
    base:desc "Processed LiDAR data with clustered and tracked objects for ACC path planning"
    DTDFVocab:fromData RawLiDARData
    DTDFVocab:inputTo PointCloudClusteringNode, PointCloudTrackingNode
]

instance ProcessedVehicleState : DTDFVocab:Data [
    base:desc "Processed vehicle state data including position, velocity, and acceleration for ACC control"
    DTDFVocab:fromData VehicleStateData
    DTDFVocab:inputTo VehicleStateModel
]

instance CloudProcessedData : DTDFVocab:Data [
    base:desc "Offloaded ACC processing results from cloud for remote management"
    DTDFVocab:fromData ProcessedLiDARData, ProcessedVehicleState
]

// C9: Enablers
instance DataPreProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Data pre-processing enabler implementing Point Cloud Clustering & Tracking algorithms for LiDAR data"
    DTDFVocab:enables PointCloudClusteringNode, PointCloudTrackingNode
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data translation enabler performing serialization, message type alignment, and unit conversions"
    DTDFVocab:enables DataTranslationNode
]

instance ROS2CommunicationEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 communication enabler facilitating intra-component data exchange for real-time processing"
]

instance WiFiUDPEnabler : DTDFVocab:Enabler [
    base:desc "Wi-Fi UDP communication enabler facilitating inter-entity data transfer for real-time monitoring"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

// C10: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of vehicle state, projected driving path, and detected object tracks via UI"
]

instance ObjectTrackingReport : DTDFVocab:Insight [
    base:desc "Data reporting of detected object tracks and their trajectories for ACC system analysis"
]

instance CloudProcessingAction : DTDFVocab:Action [
    base:desc "Automatic offloading of ACC processing to cloud resources for lead vehicle detection and speed calculation"
    DTDFVocab:IsAutomatic true
]

instance RemoteEnableAction : DTDFVocab:Action [
    base:desc "Remote enable/disable of ACC system functionality"
    DTDFVocab:IsAutomatic false
]

instance SpeedAdjustAction : DTDFVocab:Action [
    base:desc "Remote adjustment of ACC system speed parameters"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Remote emergency braking activation for safety-critical situations"
    DTDFVocab:IsAutomatic false
]

// C11: Digital Twin Entity (ROS2 Package)
instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "ROS2 package implementing digital twin representation of physical vehicle for real-time monitoring and computation offloading"
    base:contains MonitoringDashboard, TroubleshootingTool
]

// C12: User Entity (ROS2 Package)
instance UserInterface : DTDFVocab:Component [
    base:desc "User interface package providing monitoring and management tools for ACC system operations"
    base:contains MonitoringDashboard, TroubleshootingTool
]

// C13: Hierarchical Relationships
instance PhysicalTwinEntityHierarchy : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity, DigitalTwinEntity, UserInterface
]

instance PhysicalSensingLayer : DTDFVocab:Layer [
    base:contains LiDARPointCloudSensor, VehicleStateSensor, MotorSensor, SteeringSensor
]

instance ProcessingLayer : DTDFVocab:Component [
    base:contains DataPreProcessingEnabler, DataTranslationEnabler
]

instance CloudProcessingLayer : DTDFVocab:Component [
    base:contains ComputationOffloadingService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands from the Controlling FE are processed by the Data Translation component for serialization and message alignment, then transmitted over ROS2 for internal software components and Wi-Fi UDP for inter-entity communication to physical actuators including Motor and Steering Servo."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Devices require 100 ms clock synchronization accuracy for computation offloading in safety-critical vehicular applications, as mandated by standards, with hardware limitations necessitating this specific latency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Architecture based on ISO 23247 RA, mapping software components to Functional Entities implemented as ROS2 packages; entities (Physical Twin, Digital Twin, User) organized by entity-based structure with each deployed on distinct hardware, though Physical Twin Entity extends beyond standard OME to include general automotive functionality like Point Cloud Clustering & Tracking."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between software components occurs within a ROS2 network, while inter-entity communication uses Wi-Fi with UDP transport layer protocol."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with ISO 23247 standard for Digital twin framework for manufacturing, which includes four parts: Overview and general principles, Reference architecture (Part 2), Digital representation of physical manufacturing elements, and Information exchange. Part 2 defines an entity-based reference architecture comprising Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity, User Entity, and Functional Entities responsible for tasks such as actuation, data transformation, and user interfacing."
]