// ------------------------------------------------------------
// Physical Sensing Components
// ------------------------------------------------------------

// LiDAR
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2‑D LiDAR providing up to 10 m range point clouds"
    DTDFVocab:producedData LiDARPointCloudTransmitted
    base:isContainedIn PhysicalTwinEnvironment
]

// Depth Camera
instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D images at 30 fps"
    DTDFVocab:producedData DepthImageTransmitted
    base:isContainedIn PhysicalTwinEnvironment
]

// Vehicle Speed Sensor
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel‑based speed sensor measuring ego‑vehicle longitudinal speed"
    DTDFVocab:producedData SpeedDataTransmitted
    base:isContainedIn PhysicalTwinEnvironment
]

// Steering Angle Sensor
instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Rotary encoder measuring the steering servo angle"
    DTDFVocab:producedData SteeringDataTransmitted
    base:isContainedIn PhysicalTwinEnvironment
]

// ------------------------------------------------------------
// Data Transmitted from Physical Twin to Digital Twin
// ------------------------------------------------------------

instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// ------------------------------------------------------------
// Raw Data Instances (originating from DataTransmitted)
// ------------------------------------------------------------

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 2‑D point cloud measurements from the Hokuyo LiDAR"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
    base:isContainedIn PhysicalTwinEnvironment
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames (RGB‑D) from the Intel RealSense camera"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
    base:isContainedIn PhysicalTwinEnvironment
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Current vehicle speed in meters per second"
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
    base:isContainedIn PhysicalTwinEnvironment
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering angle in degrees"
    DTDFVocab:fromData SteeringDataTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
    base:isContainedIn PhysicalTwinEnvironment
]

// ------------------------------------------------------------
// Models / Algorithms
// ------------------------------------------------------------

// DBSCAN Clustering
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point clouds to identify discrete objects"
    DTDFVocab:inputTo MATLABSimulinkEnabler
    base:isContainedIn DigitalTwinEnvironment
]

// Kalman Filter Tracking
instance KalmanTrackingModel : DTDFVocab:Model [
    base:desc "Multi‑target Kalman filter tracking of clustered objects over time"
    DTDFVocab:inputTo MATLABSimulinkEnabler
    base:isContainedIn DigitalTwinEnvironment
]

// ACC Control (ISO 15622, Performance Class I)
instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm conforming to ISO 15622, generating desired speed and brake commands"
    DTDFVocab:inputTo JetsonNXComputeEnabler
    base:isContainedIn DigitalTwinEnvironment
]

// ------------------------------------------------------------
// Model Output Data (used by downstream services)
// ------------------------------------------------------------

instance ObjectClustersData : DTDFVocab:Data [
    base:desc "Clustered object representations derived from LiDAR DBSCAN"
    DTDFVocab:inputTo MATLABSimulinkEnabler
    base:isContainedIn DigitalTwinEnvironment
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Temporal object tracks produced by Kalman filter tracking"
    DTDFVocab:inputTo MATLABSimulinkEnabler
    base:isContainedIn DigitalTwinEnvironment
]

instance ACCCommandData : DTDFVocab:Data [
    base:desc "Desired vehicle speed and emergency brake flag computed by ACC"
    DTDFVocab:inputTo ROS2MiddlewareEnabler
    base:isContainedIn DigitalTwinEnvironment
]

// ------------------------------------------------------------
// Enablers (middleware, toolchains, and communication)
// ------------------------------------------------------------

// ROS2 Middleware (messages, topics, lifecycle nodes)
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware (ROS2 packages) handling real‑time streaming, processing, and actuation"
    DTDFVocab:enables DataMonitoringService,
                     ComputationOffloadingService,
                     RemoteManagementService
    base:isContainedIn DigitalTwinEnvironment
]

// MATLAB/Simulink for clustering & tracking
instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment executing DBSCAN and Kalman filter algorithms"
    DTDFVocab:enables ComputationOffloadingService
    base:isContainedIn DigitalTwinEnvironment
]

// Jetson Orin Nano compute (JetPack SDK)
instance JetsonNXComputeEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack SDK on Jetson Orin Nano running ACC control logic"
    DTDFVocab:enables ComputationOffloadingService
    base:isContainedIn DigitalTwinEnvironment
]

// Wi‑Fi communication link (PT‑DT)
instance WiFiCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "802.11 Wi‑Fi link providing  100 ms latency and 100 ms clock synchronization"
    DTDFVocab:enables RemoteManagementService
    base:isContainedIn DigitalTwinEnvironment
]

// OPC‑UA data translation (optional)
instance OPCUADataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "OPC UA (IEC 62541) server/client for cross‑system data translation"
    DTDFVocab:enables DataMonitoringService
    base:isContainedIn DigitalTwinEnvironment
]

// ------------------------------------------------------------
// Services offered by the Digital Twin
// ------------------------------------------------------------

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI display of speed, steering angle, object tracks, projected path, and report generation"
    DTDFVocab:provides RealTimeSpeedInsight,
                     RealTimeSteeringInsight,
                     ObjectTracksInsight,
                     ProjectedPathInsight,
                     PostRunReportInsight
    base:isContainedIn DigitalTwinEnvironment
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Execution of ACC algorithm in the DT with results returned to the physical twin"
    DTDFVocab:provides ACCControlInsight
    base:isContainedIn DigitalTwinEnvironment
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator can enable/disable ACC, adjust desired speed, and trigger emergency braking"
    DTDFVocab:provides EnableACCAction,
                     DisableACCAction,
                     AdjustDesiredSpeedAction,
                     EmergencyBrakeAction
    base:isContainedIn DigitalTwinEnvironment
]

// ------------------------------------------------------------
// Insights (information provided to the operator)
// ------------------------------------------------------------

instance RealTimeSpeedInsight : DTDFVocab:Insight [
    base:desc "Current vehicle speed displayed in the UI"
    base:isContainedIn UserInterfaceEnvironment
]

instance RealTimeSteeringInsight : DTDFVocab:Insight [
    base:desc "Current steering angle displayed in the UI"
    base:isContainedIn UserInterfaceEnvironment
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Tracked objects (position, velocity) visualised in the UI"
    base:isContainedIn UserInterfaceEnvironment
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected vehicle trajectory based on ACC predictions"
    base:isContainedIn UserInterfaceEnvironment
]

instance PostRunReportInsight : DTDFVocab:Insight [
    base:desc "Generated report supporting post‑run analysis and parameter tuning"
    base:isContainedIn UserInterfaceEnvironment
]

instance ACCControlInsight : DTDFVocab:Insight [
    base:desc "ACC algorithm output (desired speed, brake flag) shown to the operator"
    base:isContainedIn UserInterfaceEnvironment
]

// ------------------------------------------------------------
// Actions (operator‑initiated commands)
// ------------------------------------------------------------

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
    base:isContainedIn UserInterfaceEnvironment
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
    base:isContainedIn UserInterfaceEnvironment
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Adjust the desired speed set‑point for ACC"
    DTDFVocab:IsAutomatic false
    base:isContainedIn UserInterfaceEnvironment
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Trigger emergency braking by reducing motor voltage"
    DTDFVocab:IsAutomatic false
    base:isContainedIn UserInterfaceEnvironment
]

// ------------------------------------------------------------
// Acting Component (actuation)
// ------------------------------------------------------------

instance VedderESCActuator : DTDFVocab:ActingComponent [
    base:desc "Actuation FE that converts DT‑computed desired speed into motor voltage commands for the Vedder ESC and drives the steering servo emergency brake command maps to motor voltage reduction"
    base:isContainedIn PhysicalTwinEnvironment
]

// ------------------------------------------------------------
// Environment (logical grouping)
// ------------------------------------------------------------

instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:contains HokuyoUST10LXLiDAR,
                 IntelRealSenseD435iDepthCamera,
                 VehicleSpeedSensor,
                 SteeringAngleSensor,
                 VedderESCActuator
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains ROS2MiddlewareEnabler,
                 MATLABSimulinkEnabler,
                 JetsonNXComputeEnabler,
                 WiFiCommunicationEnabler,
                 OPCUADataTranslationEnabler,
                 DataMonitoringService,
                 ComputationOffloadingService,
                 RemoteManagementService,
                 DBSCANClusteringModel,
                 KalmanTrackingModel,
                 ACCControlModel
]

instance UserInterfaceEnvironment : DTDFVocab:Environment [
    base:contains DataMonitoringService,
                 RemoteManagementService,
                 RealTimeSpeedInsight,
                 RealTimeSteeringInsight,
                 ObjectTracksInsight,
                 ProjectedPathInsight,
                 PostRunReportInsight,
                 EnableACCAction,
                 DisableACCAction,
                 AdjustDesiredSpeedAction,
                 EmergencyBrakeAction
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends motor voltage commands and steering‑servo setpoints generated by the Controlling FE (ACC) and Actuation FE, as well as remote‑management commands (enable/disable ACC, set desired speed, emergency brake) issued through the User Interface FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sub‑second real‑time operation with a hard end‑to‑end latency limit of 100 ms between PT and DT; component clocks are synchronized to within 100 ms accuracy."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The PT runs the Physical Twin Entity on its Jetson hardware, exposing sensor data over ROS 2; the Digital Twin Entity runs on separate compute (e.g., cloud/PC) and receives data via Wi‑Fi, performs ACC, reporting, and visualization preprocessing; the User Entity provides a 3D visualization and control panel UI; all entities inter‑communicate through ROS 2 topics and a Cross‑System Data Translation FE that serializes and converts units."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity sensor processing (DBSCAN, Kalman filter) ensures accurate object tracks; ACC follows ISO 15622 specifications; latency ≤100 ms and clock sync ≤100 ms guarantee timely and ordered data for safety‑critical operation; external SQL storage keeps a complete timeseries for validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bi‑directional Wi‑Fi link between PT and DT; ROS 2 publish/subscribe transports intra‑entity messages; Data Translation FE serializes data, aligns message types and performs unit conversions; optional OPC‑UA transport is mentioned as a possible implementation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity components execute on the vehicle’s Jetson Orin Nano; Digital Twin Entity components (data collection, ACC, reporting, visualization preprocessing) run on an external computing platform (e.g., cloud or workstation) accessed via Wi‑Fi; each FE is packaged as an independent ROS 2 node for modular deployment."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (reference architecture and functional entities), uses ISO 15622 for ACC functional specifications, references IEC 62541 OPC‑UA as a possible communication standard, and adopts 3GPP 22.185 latency requirements; ROS 2 and NVIDIA JetPack provide de‑facto industrial tooling standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The system is designed for safety‑critical operation with strict latency (≤100 ms) and clock‑sync (≤100 ms) constraints; remote management includes an emergency braking command; although explicit security mechanisms are not described, the architecture assumes safe operation of remote commands on a physical twin."
]