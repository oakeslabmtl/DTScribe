// ================================
// 1. Physical Sensing Components
// ================================
instance HokuyoLidarSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2‑D LiDAR providing real‑time point‑cloud data"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelRealSenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D images"
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of vehicle longitudinal speed from the Jetson controller"
    DTDFVocab:producedData SpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of steering wheel angle from the Jetson controller"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// ================================
// 2. Data Transmitted (Physical → Virtual)
// ================================
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLidarSensor
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseDepthCamera
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// ================================
// 3. Virtual Data Objects
// ================================
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image (RGB‑D) stream"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle longitudinal speed values (m·s⁻¹)"
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle values (deg)"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks generated by clustering and Kalman filtering"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance DesiredSpeedData : DTDFVocab:Data [
    base:desc "Desired speed command output by the ACC algorithm"
    DTDFVocab:inputTo ROS2Middleware
]

// ================================
// 4. Models / Algorithms
// ================================
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm for point‑cloud segmentation"
    DTDFVocab:inputTo ROS2Middleware, DBSCANLibrary, CppRuntime
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter for multi‑object tracking of clustered detections"
    DTDFVocab:inputTo ROS2Middleware, KalmanFilterLibrary, CppRuntime
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) algorithm compliant with ISO 15622 class I"
    DTDFVocab:inputTo ROS2Middleware, Python38Runtime, NVIDIAJetpackSDK, MATLABSimulinkTool
]

// ================================
// 5. Enablers (Tooling & Infrastructure)
// ================================
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware handling topic exchange over Wi‑Fi"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, VisualizationService, ReportGenerationService, DataStorageService
]

instance NVIDIAJetpackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK for GPU acceleration on Jetson Orin Nano"
]

instance Python38Runtime : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime used by ACC and data‑processing nodes"
]

instance CppRuntime : DTDFVocab:Enabler [
    base:desc "C++ runtime for high‑performance sensor drivers"
]

instance MATLABSimulinkTool : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for model‑in‑the‑loop verification"
]

instance DBSCANLibrary : DTDFVocab:Enabler [
    base:desc "Open‑source DBSCAN library used by the clustering model"
]

instance KalmanFilterLibrary : DTDFVocab:Enabler [
    base:desc "Kalman‑filter library for state estimation"
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Persistent SQL database storing all collected data and reports"
    DTDFVocab:enables ReportGenerationService, DataStorageService
]

instance WiFiConnectivityEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi link providing bidirectional communication between physical twin and DT"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, VisualizationService
]

// ================================
// 6. Services Offered by the Digital Twin
// ================================
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI display of speed, steering angle, object tracks and projected path"
    DTDFVocab:provides RealTimeVisualInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs the ACC algorithm in the DT and returns a desired speed command"
    DTDFVocab:provides ACCParameterTuningAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator UI to enable/disable ACC, adjust speed, and issue emergency brake"
    DTDFVocab:provides EmergencyBrakeAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3‑D rendering of the vehicle and its environment"
    DTDFVocab:provides RealTimeVisualInsight
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Time‑series reports of vehicle state and object tracks"
    DTDFVocab:provides ReportBasedDecisionInsight
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Persistent storage of all collected sensor streams and derived data"
    DTDFVocab:provides DataRetentionInsight
]

// ================================
// 7. Insights and Actions
// ================================
instance RealTimeVisualInsight : DTDFVocab:Insight [
    base:desc "Operator receives live visual feedback of speed, steering angle, object tracks and projected path"
]

instance ReportBasedDecisionInsight : DTDFVocab:Insight [
    base:desc "Reports enable decisions on ACC parameter tuning, system debugging and performance evaluation"
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediate braking command issued to the Vedder speed controller"
    DTDFVocab:IsAutomatic false
]

instance ACCParameterTuningAction : DTDFVocab:Action [
    base:desc "Adjustment of ACC control gains based on reported performance"
    DTDFVocab:IsAutomatic false
]

instance DataRetentionInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data and derived results are safely persisted in the SQL database"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin sends control commands back to the Physical Twin over the same Wi‑Fi/ROS 2 link: ACC enable/disable, desired speed set‑points, emergency‑brake commands, and actuation commands (motor voltage, steering angle) generated by the Controlling FE and Actuation FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates with a maximum end‑to‑end latency of 100 ms from vehicle to DT (R7) and requires clocks synchronised within 100 ms accuracy (R8). Data collection and ACC computation occur at the perception‑cycle rate (typically tens of Hz)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT system (DTS) comprises the Physical Twin Entity (sensors, actuators, point‑cloud processing), the Digital Twin Entity (data collection, ACC, visualization, reporting, storage), the User Entity (3‑D UI and control panel), and a Cross‑System Data Translation Entity. Communication between entities uses ROS 2 intra‑node messages and Wi‑Fi inter‑entity links."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is used during design/development (cyber‑physical experimentation), testing (validation of ACC behavior), and operational phases (monitoring, remote management and health‑monitoring) as described in the case study."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by using high‑frequency sensor data, latency ≤100 ms, clock synchronisation ≤100 ms, and validated tracking algorithms (DBSCAN + Kalman). The ACC algorithm follows ISO 15622, and safety‑critical constraints are respected during off‑loading and remote command execution."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication uses a Wi‑Fi network; intra‑entity communication uses ROS 2 topics/services; data is serialised and unit‑converted by the Data Translation FE. No specific protocol such as OPC UA is employed in the implementation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the on‑board NVIDIA Jetson Orin Nano; Digital Twin Entity is hosted on external compute (cloud or workstation) reachable via Wi‑Fi; User Entity runs on an operator workstation providing the UI."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture is based on ISO 23247 (Digital Twin Manufacturing Framework) reference architecture; the ACC control logic follows ISO 15622; ISO/IEC 30173:2023 concepts are acknowledged."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT respects the safety‑critical nature of ACC by enforcing a ≤100 ms latency, clock synchronisation, and providing remote emergency‑brake capability. No explicit security mechanisms (e.g., authentication, encryption) are described in the document."
]