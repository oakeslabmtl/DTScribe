import DTDFVocab
instance RealTimeSensorDataInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of sensor data including vehicle state and object tracks"
]
instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Capabilities to save and generate reports from monitored data"
]
instance ComputationOffloadingInsight : DTDFVocab:Insight [
    base:desc "Analytics processing via distributed systems to alleviate on-board ECU constraints"
]
instance EnableDisableAction : DTDFVocab:Action [
    base:desc "Enable or disable ACC functionality",
    DTDFVocab:IsAutomatic false
]
instance SetSpeedAction : DTDFVocab:Action [
    base:desc "Set desired speed for Adaptive Cruise Control",
    DTDFVocab:IsAutomatic false
]
instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Send emergency braking command to vehicle",
    DTDFVocab:IsAutomatic false
]
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of vehicle state, projected driving path, and detected object tracks with report generation capabilities",
    DTDFVocab:provides RealTimeSensorDataInsight, ReportGenerationInsight
]
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC system tasks (lead vehicle detection, speed computation, actuation commands) to cloud/edge resources",
    DTDFVocab:provides ComputationOffloadingInsight
]
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "User interface for enabling/disabling ACC, setting desired speed, and sending emergency braking commands",
    DTDFVocab:provides EnableDisableAction, SetSpeedAction, EmergencyBrakingAction
]
instance PointCloudClusteringTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Processes raw LiDAR data to generate structured object tracks using DBSCAN and Kalman filter",
    DTDFVocab:enables DataMonitoringService
]
instance ACCEnabler : DTDFVocab:Enabler [
    base:desc "Handles ACC computations including lead vehicle detection and speed calculation",
    DTDFVocab:enables ComputationOffloadingService
]
instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Provides real-time data visualization and monitoring capabilities",
    DTDFVocab:enables DataMonitoringService
]
instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Offloads ACC computation tasks to cloud resources",
    DTDFVocab:enables ComputationOffloadingService
]
instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Handles user commands for remote management of ACC system",
    DTDFVocab:enables RemoteManagementService
]
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR sensor for acquiring point cloud data",
    DTDFVocab:producedData LiDARRawPointCloudTransmitted
]
instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i Depth Camera for capturing depth information",
    DTDFVocab:producedData DepthCameraDepthTransmitted
]
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for measuring vehicle speed",
    DTDFVocab:producedData VehicleSpeedTransmitted
]
instance LiDARRawPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]
instance DepthCameraDepthTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]
instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]
instance ProjectedDrivingPathTransmitted : DTDFVocab:DataTransmitted [
]
instance ObjectTracksTransmitted : DTDFVocab:DataTransmitted [
]
instance LiDARRawPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data from Hokuyo UST-10LX",
    DTDFVocab:fromData LiDARRawPointCloudTransmitted,
    DTDFVocab:inputTo PointCloudClusteringTrackingEnabler
]
instance DepthCameraDepthData : DTDFVocab:Data [
    base:desc "Depth data from Intel Deepsense D435i",
    DTDFVocab:fromData DepthCameraDepthTransmitted
]
instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Structured object tracks from processed LiDAR point clouds",
    DTDFVocab:fromData ObjectTracksTransmitted,
    DTDFVocab:inputTo ACCEnabler
]
instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed data",
    DTDFVocab:fromData VehicleSpeedTransmitted,
    DTDFVocab:inputTo DataMonitoringEnabler
]
instance ProjectedDrivingPathData : DTDFVocab:Data [
    base:desc "Projected driving path data for ACC system",
    DTDFVocab:fromData ProjectedDrivingPathTransmitted,
    DTDFVocab:inputTo ACCEnabler
]
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm for raw LiDAR point cloud processing",
    DTDFVocab:inputTo PointCloudClusteringTrackingEnabler
]
instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter for tracking object tracks",
    DTDFVocab:inputTo PointCloudClusteringTrackingEnabler
]
instance ACCModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model for lead vehicle detection and speed computation",
    DTDFVocab:inputTo ACCEnabler
]
instance ThreeDVisualization : DTDFVocab:Component [
    base:desc "3D visualization subcomponent of User Interface Functional Entity"
]
instance ControlPanel : DTDFVocab:Component [
    base:desc "Control Panel subcomponent of User Interface Functional Entity"
]
instance SQLDatabase : DTDFVocab:Component [
    base:desc "SQL database for storing object tracks and ego vehicle state"
]
instance ActuationSoftware : DTDFVocab:Component [
    base:desc "Converts desired speed commands into precise motor voltage signals for vehicle dynamics control"
]
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller interfacing with DC motor for propulsion control"
]
instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Steering servo for directional adjustment"
]
instance UserEntity : DTDFVocab:Entity [
    base:desc "User Entity deployed on separate hardware for interaction"
]
instance DigitalTwinEntity : DTDFVocab:Entity [
    base:desc "Digital Twin Entity deployed on separate hardware"
]
instance PhysicalTwinEntity : DTDFVocab:Entity [
    base:desc "Physical Twin Entity deployed on separate hardware, hosting general automotive functionality such as Point Cloud Clustering & Tracking"
]
instance NVIDIAJetsonNX : DTDFVocab:Enabler [
    base:desc "Edge computing hardware for processing sensor data and models"
]
instance NVIDIAJetsonOrinNano : DTDFVocab:Enabler [
    base:desc "Edge computing hardware for high-performance processing"
]
instance ROS2 : DTDFVocab:Enabler [
    base:desc "Middleware framework for intra-component communication"
]
instance NVIDIAJetpack50 : DTDFVocab:Enabler [
    base:desc "GPU acceleration software stack for edge computing"
]
instance Python : DTDFVocab:Enabler [
    base:desc "Programming language for application development"
]
instance CPlusPlus : DTDFVocab:Enabler [
    base:desc "Programming language for performance-critical components"
]
instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "Modeling and simulation tool for system design"
]
instance ISO23247Compliance : DTDFVocab:Standard [
    base:desc "Compliance with ISO 23247 architectural standards for digital twin systems"
]
instance VehicleEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity, UserEntity, DigitalTwinEntity, ThreeDVisualization, ControlPanel, SQLDatabase, ActuationSoftware, VedderElectronicSpeedController, SteeringServo
]
instance VehicleSystem : DTDFVocab:SystemUnderStudy [
    base:desc "A 1/10-scale teleoperated autonomous vehicle retrofitted with advanced sensor and control technology, featuring lower and upper chassis layers and autonomy elements",
    DTDFVocab:hasEnvironment VehicleEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "ACC-related control commands for motor and steering actuators are processed through the ACC Controlling FE and Actuation FE components. Data Translation serializes control signals, aligns message formats, and performs unit conversions before transmission via ROS2 for internal component communication and UDP over Wi-Fi for inter-entity communication."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Clock synchronization requirement of 100 ms accuracy for computation offloading in safety-critical vehicular applications, mandated by industry standards and constrained by hardware limitations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "ISO 23247 Reference Architecture (RA) used for design, mapping software components to Functional Entities (FEs) implemented as ROS2 packages on vehicle hardware; entity structure includes User Entity (3D Visualization, Control Panel), Digital Twin Entity (data management, control mechanisms), Physical Twin Entity (sensors, actuators, Point Cloud Clustering & Tracking), each on separate hardware."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Internal communication between software components uses ROS2, while inter-entity communication occurs over Wi-Fi. Requirement R7 specifies a maximum network latency of 100 ms. Bandwidth requirements, redundancy mechanisms, and security protocols are not explicitly detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Each entity is deployed on separate hardware components, including NVIDIA Jetson Orin Nano. Data storage is maintained on a device external to the vehicle as per Requirement R3. Computational requirements, scalability mechanisms, and deployment models are not explicitly detailed beyond these specifics."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The ISO 23247 standard for Digital Twin framework in manufacturing specifies a reference architecture in Part 2, consisting of Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity, and User Entity. Functional Entities (FEs) within this architecture may implement OPC Unified Architecture for data collection and device control."
]