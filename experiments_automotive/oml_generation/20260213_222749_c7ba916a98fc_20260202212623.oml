// C3: Physical Sensing Components
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded LiDAR sensor providing raw point cloud data for object detection and tracking in automotive environments. Operates at ≥10Hz for real-time monitoring."
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded sensor system collecting real-time vehicle state metrics including speed, acceleration, and steering angles for dynamic path tracking."
    DTDFVocab:producedData VehicleStateDataTransmitted
]

instance MotorServoSensor : DTDFVocab:SensingComponent [
    base:desc "High-precision sensor monitoring motor and servo actuation signals for powertrain control and trajectory optimization."
    DTDFVocab:producedData MotorServoDataTransmitted
]

instance BatteryHealthSensor : DTDFVocab:SensingComponent [
    base:desc "Specialized sensor suite tracking battery state metrics including voltage, current, temperature, and degradation indicators for SoC/SoH prediction."
    DTDFVocab:producedData BatteryHealthDataTransmitted
]

instance IndustrialTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Precision temperature sensor deployed in industrial environments for process monitoring and anomaly detection in manufacturing systems."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Accelerometer-based vibration sensor for machinery health monitoring and predictive maintenance in industrial applications."
    DTDFVocab:producedData VibrationDataTransmitted
]

instance AerospaceRadarSensor : DTDFVocab:SensingComponent [
    base:desc "Space-based radar system for debris detection and orbital tracking in aerospace collision avoidance applications."
    DTDFVocab:producedData RadarTrackingDataTransmitted
]

instance PressureTransducer : DTDFVocab:SensingComponent [
    base:desc "High-accuracy pressure transducer for monitoring critical system parameters in industrial and automotive environments."
    DTDFVocab:producedData PressureDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance MotorServoDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorServoSensor
]

instance BatteryHealthDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BatteryHealthSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndustrialTemperatureSensor
]

instance VibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
]

instance RadarTrackingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AerospaceRadarSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureTransducer
]

instance ObjectTrackDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
    base:desc "Processed data resulting from point cloud clustering and tracking algorithms converting raw LiDAR data into structured object representations."
]

instance DrivingPathDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor, MotorServoSensor
    base:desc "Projected driving paths derived from vehicle state and servo actuation data for trajectory optimization."
]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "AI/ML-based model implementing clustering and tracking algorithms to convert raw LiDAR point clouds into structured object representations."
    DTDFVocab:inputTo ROS2DataProcessingEnabler
]

instance VehicleDynamicsModel : DTDFVocab:Model [
    base:desc "Physics-based model simulating vehicle dynamics including kinematics, powertrain behavior, and control system responses."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance BatteryThermalModel : DTDFVocab:Model [
    base:desc "Electrochemical model simulating battery thermal behavior and degradation patterns for state-of-charge/state-of-health prediction."
    DTDFVocab:inputTo BatterySimulationEnabler
]

instance OrbitalMechanicsModel : DTDFVocab:Model [
    base:desc "High-fidelity physics-based model for orbital mechanics used in aerospace collision avoidance and debris tracking."
    DTDFVocab:inputTo AerospaceSimulationEnabler
]

instance ManufacturingProcessModel : DTDFVocab:Model [
    base:desc "Discrete-event simulation model representing manufacturing processes for optimization and predictive maintenance."
    DTDFVocab:inputTo ProcessOptimizationEnabler
]

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw point cloud data from LiDAR sensor containing 3D spatial information of the environment."
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
    DTDFVocab:inputTo PointCloudClusteringModel
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Real-time vehicle state metrics including speed, acceleration, and steering angles."
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo VehicleDynamicsModel
]

instance MotorServoData : DTDFVocab:Data [
    base:desc "Actuation signals from motor and servo systems for powertrain control."
    DTDFVocab:fromData MotorServoDataTransmitted
    DTDFVocab:inputTo VehicleDynamicsModel
]

instance BatteryHealthData : DTDFVocab:Data [
    base:desc "Comprehensive battery state metrics including voltage, current, temperature, and degradation indicators."
    DTDFVocab:fromData BatteryHealthDataTransmitted
    DTDFVocab:inputTo BatteryThermalModel
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Precision temperature measurements from industrial environments for process monitoring."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo ManufacturingProcessModel
]

instance VibrationData : DTDFVocab:Data [
    base:desc "Vibration measurements from machinery for health monitoring and predictive maintenance."
    DTDFVocab:fromData VibrationDataTransmitted
    DTDFVocab:inputTo ManufacturingProcessModel
]

instance RadarTrackingData : DTDFVocab:Data [
    base:desc "Space-based radar data for debris detection and orbital tracking in aerospace applications."
    DTDFVocab:fromData RadarTrackingDataTransmitted
    DTDFVocab:inputTo OrbitalMechanicsModel
]

instance ProcessedObjectTracks : DTDFVocab:Data [
    base:desc "Structured object representations derived from point cloud clustering and tracking algorithms."
    DTDFVocab:fromData ObjectTrackDataTransmitted
    DTDFVocab:inputTo ROS2DataProcessingEnabler
]

instance ProjectedDrivingPaths : DTDFVocab:Data [
    base:desc "Computed driving paths based on vehicle state and servo actuation data for trajectory optimization."
    DTDFVocab:fromData DrivingPathDataTransmitted
    DTDFVocab:inputTo VehicleDynamicsModel
]

// C11: Enablers
instance ROS2DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2-based framework for software component communication and data processing in the digital twin system."
    DTDFVocab:enables PointCloudClusteringService, ObjectTrackingService
]

instance WiFiUDPTransportEnabler : DTDFVocab:Enabler [
    base:desc "Wi-Fi with UDP protocol stack for high-frequency data transmission between physical and digital layers at ≥10Hz."
    DTDFVocab:enables DataSynchronizationService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity responsible for serializing data, aligning message types, and performing unit conversions for standardized data exchange."
    DTDFVocab:enables DataStandardizationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Physics-based simulation engine (e.g., Simulink, STK) for modeling vehicle dynamics, orbital mechanics, and manufacturing processes."
