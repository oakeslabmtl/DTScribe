]

instance EdgeComputingEnabler : DTDFVocab:Enabler [
    base:desc "Edge computing platform (e.g., NVIDIA Jetson clusters) for low-latency data processing and control in industrial IoT environments."
    DTDFVocab:enables EdgeControlService, EdgeOptimizationService
]

instance TimeSeriesDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database (e.g., InfluxDB, TimescaleDB) for storing and querying sensor telemetry and digital twin state data."
    DTDFVocab:enables DataStorageService, AnomalyDetectionService
]

instance GraphDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Graph database (e.g., Neo4j) for modeling relationships between physical assets, sensors, and digital twin services."
    DTDFVocab:enables RelationshipModelingService
]

instance OPCUACommunicationEnabler : DTDFVocab:Enabler [
    base:desc "OPC Unified Architecture implementation for standardized industrial communication and device control."
    DTDFVocab:enables DeviceControlService, InteroperabilityService
]

instance AIMLTrainingEnabler : DTDFVocab:Enabler [
    base:desc "AI/ML training framework (e.g., TensorFlow, PyTorch) for developing predictive models within the digital twin system."
    DTDFVocab:enables PredictionService
]

instance PhysicsInformedNNEnabler : DTDFVocab:Enabler [
    base:desc "Physics-informed neural network framework for high-fidelity cyber-biophysical simulations."
    DTDFVocab:enables SimulationAugmentationService
]

instance FederatedLearningEnabler : DTDFVocab:Enabler [
    base:desc "Federated learning platform enabling distributed digital twin collaboration across multiple systems."
    DTDFVocab:enables CollaborativeOptimizationService
]

