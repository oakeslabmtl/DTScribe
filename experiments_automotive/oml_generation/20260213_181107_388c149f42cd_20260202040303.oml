// C2: Acting Components
instance VehicleMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Converts desired speed commands to voltage signals for motor actuation as part of the Physical Twin Entity's Actuation FE"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Implements steering control by converting angle commands to servo motor actuation within the Physical Twin Entity"
]

// C3: Physical sensing components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "High-resolution 2D LiDAR sensor providing point cloud data for environment perception"
    DTDFVocab:producedData LidarPointCloudDataTransmitted
]

instance IntelDeepsenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Depth camera providing RGB-D visual data for object detection and scene understanding"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring ego vehicle speed in real-time for state monitoring"
    DTDFVocab:producedData VehicleSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing steering wheel angle for vehicle state tracking"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// C4: Physical-to-virtual interaction
instance LidarPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iCamera
]

instance VehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm applied to LiDAR point clouds for object segmentation"
    DTDFVocab:inputTo NVIDIAJetpack50Enabler, MATLABSimulinkEnabler
]

instance KalmanFilterModel : DTDFVocab:Model [
    base:desc "Kalman filter implementation for tracking object trajectories from sensor data"
    DTDFVocab:inputTo NVIDIAJetpack50Enabler, MATLABSimulinkEnabler
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "ISO 15622 Class I compliant ACC logic for desired speed calculation and vehicle following"
    DTDFVocab:inputTo Python38Enabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Aggregated vehicle state information including speed, steering angle, and timestamp"
    DTDFVocab:fromData VehicleSpeedDataTransmitted, SteeringAngleDataTransmitted
    DTDFVocab:inputTo SQLDatabaseEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Processed object tracks generated from LiDAR point clouds using DBSCAN and Kalman filtering"
    DTDFVocab:fromData LidarPointCloudDataTransmitted
    DTDFVocab:inputTo SQLDatabaseEnabler, ThreeDVisualizationService
]

instance EnvironmentPointCloudData : DTDFVocab:Data [
    base:desc "Raw and processed 3D environment representation from LiDAR and depth camera data"
    DTDFVocab:fromData LidarPointCloudDataTransmitted, DepthCameraDataTransmitted
    DTDFVocab:inputTo SQLDatabaseEnabler, ThreeDVisualizationService
]

// C11: Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 framework enabling component integration and data communication across distributed hardware"
    DTDFVocab:enables ROS2DataCollectionService, ROS2ComputationOffloadingService, ROS2RemoteManagementService
]

instance NVIDIAJetpack50Enabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK providing GPU acceleration for real-time processing on Jetson NX/Orin Nano"
    DTDFVocab:enables ROS2DataCollectionService, PointCloudClusteringModel, KalmanFilterModel
]

instance Python38Enabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime environment for script-based processing and model execution"
    DTDFVocab:enables ROS2DataCollectionService, AdaptiveCruiseControlModel
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database system for persistent storage of vehicle state and object track data"
    DTDFVocab:enables DataMonitoringService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for advanced point cloud processing and algorithm development"
    DTDFVocab:enables PointCloudClusteringModel, KalmanFilterModel
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time display, saving, and reporting of vehicle state through SQL database integration"
    DTDFVocab:provides VehicleStateInsight, SystemDiagnosticsReport
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Remote execution of ACC logic on external compute resources to reduce onboard processing load"
    DTDFVocab:provides ACCDecisionInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "User interface for command issuance and remote control of the autonomous vehicle system"
    DTDFVocab:provides RemoteCommandAction
]

instance ThreeDVisualizationService : DTDFVocab:Service [
    base:desc "3D visualization of the vehicle's environment using processed point cloud data"
    DTDFVocab:provides EnvironmentVisualizationInsight
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generation of system performance reports for diagnostics and analysis"
    DTDFVocab:provides SystemDiagnosticsReport
]

instance ROS2DataCollectionService : DTDFVocab:Service [
    base:desc "ROS2-based data collection framework aggregating sensor data for processing"
    DTDFVocab:provides VehicleStateData, ObjectTrackData, EnvironmentPointCloudData
]

instance ROS2ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ROS2 service enabling remote computation of ACC logic"
    DTDFVocab:provides ACCDecisionInsight
]

instance ROS2RemoteManagementService : DTDFVocab:Service [
    base:desc "ROS2 interface for remote management commands"
    DTDFVocab:provides RemoteCommandAction
]

// C17: Insights/Actions
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of current vehicle speed and steering angle"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Real-time display of detected object tracks in the vehicle's environment"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Visualization of the vehicle's projected path based on current state and ACC logic"
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "Display of adaptive cruise control decision logic including desired speed calculation"
]

instance EnvironmentVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization of the vehicle's surrounding environment using processed sensor data"
]

instance SystemDiagnosticsReport : DTDFVocab:Insight [
    base:desc "Comprehensive report of system performance metrics and diagnostic information"
]

instance ComputationOffloadingAction : DTDFVocab:Action [
    base:desc "Automatic offloading of ACC computation to remote processing units"
    DTDFVocab:IsAutomatic true
]

instance RemoteCommandAction : DTDFVocab:Action [
    base:desc "Execution of commands received through the remote management interface"
    DTDFVocab:IsAutomatic false
]

// C1: Physical Twin Entity
instance AutonomousVehiclePhysicalTwin : DTDFVocab:Environment [
    base:desc "1/10-scale autonomous vehicle built from Traxxas Slash 4x4 with NVIDIA Jetson NX/Orin Nano onboard compute"
    base:contains HokuyoUST10LXLiDAR, IntelDeepsenseD435iCamera,
                   VehicleSpeedSensor, SteeringAngleSensor,
                   VehicleMotorActuator, SteeringServoActuator,
                   ROS2MiddlewareEnabler, NVIDIAJetpack50Enabler,
                   ROS2DataCollectionService, ROS2RemoteManagementService
]

// C12: Digital Twin Entity
instance AutonomousVehicleDigitalTwin : DTDFVocab:Environment [
    base:desc "Cloud-hosted digital representation of the autonomous vehicle system including all processed data and models"
    base:contains SQLDatabaseEnabler, ROS2ComputationOffloadingService,
                   ThreeDVisualizationService, ReportGenerationService,
                   VehicleStateData, ObjectTrackData, EnvironmentPointCloudData,
                   PointCloudClusteringModel, KalmanFilterModel,
                   AdaptiveCruiseControlModel
]

// C13: User Entity
instance VehicleOperatorUser : DTDFVocab:Environment [
    base:desc "Human operator interface for remote management and visualization of the autonomous vehicle system"
    base:contains RemoteManagementService, ThreeDVisualizationService
]

// C14: Cross-System Entity
instance DataTranslationCrossSystem : DTDFVocab:Environment [
    base:desc "System component handling data translation between physical and digital twin entities"
    base:contains ROS2MiddlewareEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "ACC system computes desired speed based on lead vehicle distance and sends motor voltage commands and steering commands; remote commands for emergency braking, ACC enable/disable, and desired speed modification."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time operation with end-to-end latency ≤100 ms (per 3GPP TS 22.185) and clock synchronization accuracy of 100 ms for event ordering and coordination."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated entities: Physical Twin Entity (sensors, actuators), Digital Twin Entity (ACC, data processing), User Entity (visualization, control panel), Cross-System Entity (Data Translation FE), with ROS2-based intra-entity and Wi-Fi inter-entity communication."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design phase (cyber-physical experimentation, compliance validation) and operational phase (real-time monitoring, optimization, health monitoring)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "ACC implementation adheres to ISO 15622 Class I specifications; latency and clock sync requirements (100 ms) ensure safety-critical operation; no explicit V&V beyond compliance with standards."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "ROS2 network for intra-component communication, Wi-Fi for inter-entity communication; Data Translation FE handles serialization, message alignment, and unit conversions; latency ≤100 ms and clock sync 100 ms."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity on vehicle-mounted Jetson NX/Orin Nano; Digital Twin Entity potentially cloud-hosted for computation offloading; User Entity on separate machine; cross-system components deployed as needed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture for DT structure; ISO 15622 for ACC system functionality; 3GPP TS 22.185 for V2V communication latency requirements."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety-critical system with requirements for end-to-end latency ≤100 ms and clock synchronization accuracy of 100 ms to ensure operational safety; specific cybersecurity measures not detailed in document."
]