namespace DTDFVocab = "http://example.com/dtdf/vocab#"
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor capturing raw point cloud data for obstacle detection",
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]
instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor system providing vehicle state information including speed, acceleration, and yaw rate",
    DTDFVocab:producedData VehicleStateDataTransmitted
]
instance MotorCommandSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor control signal commands for throttle and brake",
    DTDFVocab:producedData MotorCommandDataTransmitted
]
instance SteeringCommandSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring steering servo command signals",
    DTDFVocab:producedData SteeringCommandDataTransmitted
]
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]
instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]
instance MotorCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCommandSensor
]
instance SteeringCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringCommandSensor
]
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data transmitted via Wi-Fi UDP",
    DTDFVocab:fromData LiDARPointCloudDataTransmitted,
    DTDFVocab:inputTo PointCloudClusteringAndTracking, ISO23247DataTranslation
]
instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state information including speed, acceleration, and yaw rate data",
    DTDFVocab:fromData VehicleStateDataTransmitted,
    DTDFVocab:inputTo ISO23247DataTranslation, ACCComputationEnabler
]
instance MotorCommandData : DTDFVocab:Data [
    base:desc "Motor control signal commands for throttle and brake",
    DTDFVocab:fromData MotorCommandDataTransmitted,
    DTDFVocab:inputTo ISO23247DataTranslation
]
instance SteeringCommandData : DTDFVocab:Data [
    base:desc "Steering servo control signal commands",
    DTDFVocab:fromData SteeringCommandDataTransmitted,
    DTDFVocab:inputTo ISO23247DataTranslation
]
instance PointCloudClusteringAndTracking : DTDFVocab:Enabler [
    base:desc "Software component processing raw LiDAR data into clustered and tracked objects",
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]
instance TrackedObjectsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]
instance TrackedObjectsData : DTDFVocab:Data [
    base:desc "Clustered and tracked objects derived from LiDAR point cloud data",
    DTDFVocab:fromData TrackedObjectsDataTransmitted,
    DTDFVocab:inputTo ISO23247DataTranslation, ACCComputationEnabler
]
instance ISO23247DataTranslation : DTDFVocab:Enabler [
    base:desc "ISO 23247 compliant component serializing data streams, aligning message types, and performing unit conversions",
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]
instance SerializedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]
instance SerializedData : DTDFVocab:Data [
    base:desc "Serialized data streams after ISO 23247 translation for real-time monitoring",
    DTDFVocab:fromData SerializedDataTransmitted,
    DTDFVocab:inputTo ThreeDVisualization, ControlPanel
]
instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Cloud-based component for ACC computation including lead vehicle detection, speed calculation, and actuation commands",
    DTDFVocab:enables ComputationOffloadingService
]
instance ACCMotorCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCommandSensor
]
instance ACCMotorCommandData : DTDFVocab:Data [
    base:desc "Motor actuation commands generated by ACC computation",
    DTDFVocab:fromData ACCMotorCommandDataTransmitted
]
instance ACCSteeringCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringCommandSensor
]
instance ACCSteeringCommandData : DTDFVocab:Data [
    base:desc "Steering actuation commands generated by ACC computation",
    DTDFVocab:fromData ACCSteeringCommandDataTransmitted
]
instance SetDesiredSpeedCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]
instance SetDesiredSpeedCommandData : DTDFVocab:Data [
    base:desc "Command to set desired speed for ACC system",
    DTDFVocab:fromData SetDesiredSpeedCommandDataTransmitted,
    DTDFVocab:inputTo ACCComputationEnabler
]
instance EnableACCCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]
instance EnableACCCommandData : DTDFVocab:Data [
    base:desc "Command to enable ACC system",
    DTDFVocab:fromData EnableACCCommandDataTransmitted,
    DTDFVocab:inputTo ACCComputationEnabler
]
instance DisableACCCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]
instance DisableACCCommandData : DTDFVocab:Data [
    base:desc "Command to disable ACC system",
    DTDFVocab:fromData DisableACCCommandDataTransmitted,
    DTDFVocab:inputTo ACCComputationEnabler
]
instance EmergencyBrakingCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]
instance EmergencyBrakingCommandData : DTDFVocab:Data [
    base:desc "Emergency braking command signal",
    DTDFVocab:fromData EmergencyBrakingCommandDataTransmitted
]
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Physical actuator controlling vehicle throttle and brake systems"
]
instance SteeringActuator : DTDFVocab:ActingComponent [
    base:desc "Physical actuator controlling vehicle steering system"
]
instance ThreeDVisualization : DTDFVocab:Enabler [
    base:desc "3D visualization component displaying real-time vehicle state, object tracks, and projected driving path",
    DTDFVocab:enables DataMonitoringService
]
instance ControlPanel : DTDFVocab:Enabler [
    base:desc "User interface component for remote ACC control and management",
    DTDFVocab:enables RemoteManagementService
]
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real-time monitoring of vehicle state, object tracks, and driving path with data saving and report generation",
    DTDFVocab:provides RealTimeVehicleStateInsight, ProjectedDrivingPathInsight, DetectedObjectTracksInsight, SaveDataAction, GenerateReportAction
]
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service offloading ACC computation from vehicle ECUs to cloud resources",
    DTDFVocab:provides ACCComputationResultInsight
]
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service enabling remote control of ACC system including enable/disable, speed setting, and emergency braking",
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakingAction
]
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real-time display of vehicle speed, acceleration, and yaw rate"
]
instance ProjectedDrivingPathInsight : DTDFVocab:Insight [
    base:desc "Visualized projected driving path based on current trajectory"
]
instance DetectedObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Tracked objects from LiDAR data displayed in 3D environment"
]
instance SaveDataAction : DTDFVocab:Action [
    base:desc "User-initiated action to save real-time monitoring data",
    DTDFVocab:IsAutomatic false
]
instance GenerateReportAction : DTDFVocab:Action [
    base:desc "User-initiated action to generate diagnostic reports",
    DTDFVocab:IsAutomatic false
]
instance ACCComputationResultInsight : DTDFVocab:Insight [
    base:desc "Computed desired speed and actuation commands for ACC system"
]
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Remote command to enable ACC functionality",
    DTDFVocab:IsAutomatic false
]
instance DisableACCAction : DTDFVocab:Action [
    base:desc "Remote command to disable ACC functionality",
    DTDFVocab:IsAutomatic false
]
instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Remote command to set target speed for ACC",
    DTDFVocab:IsAutomatic false
]
instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Remote command to trigger emergency braking",
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals (e.g., ACC commands, steering adjustments, motor actuation) are generated by the ACC Controlling FE, serialized, and converted by the ISO 23247 Data Translation component. These commands are transmitted over Wi-Fi using UDP to physical actuators, with real-time vehicle state feedback displayed in the 3D Visualization to confirm execution."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system requires 100 ms clock synchronization accuracy for device coordination during computation offloading, as mandated by safety-critical vehicular application standards, with hardware limitations necessitating this specific timing constraint."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows ISO 23247 RA, mapping software components to Function Entities (FEs) implemented as individual ROS2 packages, each containing one or more ROS2 nodes. Entities are deployed on distinct hardware, with the Physical Twin Entity deviating from the standard by hosting general automotive functionality (e.g., Point Cloud Clustering & Tracking) instead of resource-specific OME functions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between software components occurs within a ROS2 network, while inter-entity communication occurs over a Wi-Fi network using UDP in the transport layer. No additional details on network topology, bandwidth, latency, reliability mechanisms, or security protocols are provided in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliant with ISO 23247 standard, which includes four parts covering overview, reference architecture, digital representation of physical manufacturing elements, and information exchange. Interoperability is achieved through OPC Unified Architecture (OPC UA) for data collection and device control."
]