// C2: Acting Components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller converting desired speed commands from the Controlling Functional Entity into motor voltage commands for propulsion via the Physical Twin Entity."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "ROS2-controlled servo mechanism adjusting the autonomous vehicle's steering angle based on commands from the Digital Twin Entity's control logic."
]

// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "High-resolution 3D LiDAR sensor capturing point clouds for object detection and tracking in the vehicle's proximity, feeding raw data to the Physical Twin Entity."
    DTDFVocab:producedData HokuyoLiDARPointCloudData
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "RGB-D depth camera providing environmental perception data for object state estimation, integrated with the Physical Twin Entity's perception pipeline."
    DTDFVocab:producedData DepthCameraRGBData
]

instance WheelEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard wheel encoder measuring vehicle speed and providing ego state data to the Physical Twin Entity for state estimation."
    DTDFVocab:producedData WheelEncoderSpeedData
]

instance IMUSensor : DTDFVocab:SensingComponent [
    base:desc "Inertial Measurement Unit capturing vehicle orientation and acceleration data for ego state estimation in the Physical Twin Entity."
    DTDFVocab:producedData IMUOrientationData
]

// C4: Physical-to-Virtual Interaction
instance HokuyoLiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraRGBData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]

instance WheelEncoderSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelEncoderSensor
]

instance IMUOrientationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IMUSensor
]

instance ProcessedObjectTracksData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DataTranslationFunctionalEntity
]

instance EgoVehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DataTranslationFunctionalEntity
]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN-based clustering algorithm for processing raw LiDAR point clouds into object clusters within the Physical Twin Entity."
    DTDFVocab:inputTo NVIDIAJetsonOrinNano
]

instance KalmanFilterStateEstimation : DTDFVocab:Model [
    base:desc "Kalman filter model for tracking object states (position, velocity) using processed sensor data in the Physical Twin Entity."
    DTDFVocab:inputTo NVIDIAJetsonOrinNano
]

instance ActuationConversionModel : DTDFVocab:Model [
    base:desc "Model converting desired speed commands from the Controlling Functional Entity into motor voltage commands for the Vedder Electronic Speed Controller."
    DTDFVocab:inputTo NVIDIAJetsonOrinNano
]

instance RawLiDARPointCloud : DTDFVocab:Data [
    base:desc "Unprocessed 3D point cloud data from Hokuyo UST-10LX LiDAR sensor."
    DTDFVocab:fromData HokuyoLiDARPointCloudData
    DTDFVocab:inputTo PointCloudClusteringModel
]

instance ProcessedObjectTracks : DTDFVocab:Data [
    base:desc "Detected objects with state estimates (size, position, velocity) generated via DBSCAN clustering and Kalman filtering in the Physical Twin Entity."
    DTDFVocab:fromData ProcessedObjectTracksData
    DTDFVocab:inputTo DigitalTwinEntity
]

instance EgoVehicleState : DTDFVocab:Data [
    base:desc "Real-time vehicle state data including speed, steering angle, and timestamps processed by the Physical Twin Entity."
    DTDFVocab:fromData EgoVehicleStateData
    DTDFVocab:inputTo DigitalTwinEntity
]

instance SQLAggregatedTimeseries : DTDFVocab:Data [
    base:desc "Aggregated timeseries data of object tracks and vehicle state stored in SQL database for external analysis and reporting."
    DTDFVocab:fromData DigitalTwinEntityDataStorage
]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 (Robot Operating System 2) providing intra-system communication and node lifecycle management across all functional entities."
    DTDFVocab:enables DataCollectionFunctionalEntity,
                 DataTranslationFunctionalEntity,
                 ControllingFunctionalEntity,
                 PresentationFunctionalEntity,
                 ReportingFunctionalEntity
]

instance NVIDIAJetsonOrinNano : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetson Orin Nano microcomputer hosting the Physical Twin Entity for onboard processing of sensor data and actuation commands."
    DTDFVocab:enables PhysicalTwinEntity
]

instance ExternalComputeResources : DTDFVocab:Enabler [
    base:desc "External compute infrastructure hosting the Digital Twin Entity for control logic, visualization, and reporting services."
    DTDFVocab:enables DigitalTwinEntity
]

instance NVIDIAJetpack50SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK providing programming environment and drivers for Jetson Orin Nano development."
    DTDFVocab:enables PhysicalTwinEntity
]

instance DataTranslationFunctionalEntity : DTDFVocab:Component [
    base:desc "Custom Data Translation Functional Entity responsible for serialization, unit conversion, and message alignment across Physical and Digital Twin Entities."
    DTDFVocab:inputTo NVIDIAJetsonOrinNano
]

instance WiFiCommunicationProtocol : DTDFVocab:Enabler [
    base:desc "Wi-Fi (UDP/TCP) protocol enabling inter-entity communication between Physical Twin Entity and Digital Twin Entity with 100ms latency."
    DTDFVocab:enables DataTranslationFunctionalEntity
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "3D Visualization User Interface providing real-time visualization of ego vehicle state, detected object tracks, and projected driving path."
    DTDFVocab:provides RealTimeMonitoringInsight,
                 VisualPathProjectionInsight
]

instance AdaptiveCruiseControlService : DTDFVocab:Service [
    base:desc "Computation offloading service for ACC system where Controlling Functional Entity computes desired speed based on lead vehicle distance (ISO 15622 Performance Class I compliant)."
    DTDFVocab:provides ACCOptimizationInsight,
                 EmergencyBrakingAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote control interface enabling enabling/disabling of ACC, setting desired speed, and issuing emergency braking commands via Control Panel UI."
    DTDFVocab:provides RemoteControlAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Service generating human-readable reports of timeseries data (object tracks and vehicle state) for analysis."
    DTDFVocab:provides PredictiveMaintenanceInsight,
                 TroubleshootingReportInsight
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Service aggregating object tracks and ego vehicle state data into SQL database for external storage and analysis."
    DTDFVocab:provides DataAnalysisInsight
]

// C17: Insights/Actions
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Visualization of object tracks, vehicle state, and projected driving path enabling performance assessment and safety monitoring."
]

instance VisualPathProjectionInsight : DTDFVocab:Insight [
    base:desc "Real-time display of projected driving path based on ACC computations for operator verification."
]

instance ACCOptimizationInsight : DTDFVocab:Insight [
    base:desc "Computed desired speed based on lead vehicle distance supporting adaptive cruise control decisions."
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Automatic emergency braking command issued by the Controlling Functional Entity when safety thresholds are exceeded."
    DTDFVocab:IsAutomatic true
]

instance RemoteControlAction : DTDFVocab:Action [
    base:desc "Remote enabling/disabling of ACC system and speed setting commands issued via Control Panel UI."
    DTDFVocab:IsAutomatic false
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Aggregated data analysis identifying potential maintenance needs based on object collision risks and sensor degradation patterns."
]

instance TroubleshootingReportInsight : DTDFVocab:Insight [
    base:desc "Generated reports containing diagnostic information for remote troubleshooting of sensor failures or control logic errors."
]

instance DataAnalysisInsight : DTDFVocab:Insight [
    base:desc "SQL-based analysis of aggregated timeseries data supporting external research and validation activities."
]

// C12: Entities
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "ROS2 package processing sensor data and generating processed object tracks and vehicle state data."
    base:isContainedIn PhysicalTwinEnvironment
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "ROS2 package implementing control logic, visualization, and reporting services."
    base:isContainedIn DigitalTwinEnvironment
]

instance UserEnvironment : DTDFVocab:Environment [
    base:contains RealTimeVisualizationService,
                 RemoteManagementService,
                 ReportingService,
                 DataStorageService
]

instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:contains VedderElectronicSpeedController,
                 SteeringServoActuator,
                 HokuyoUST10LXLiDAR,
                 IntelDeepsenseD435iDepthCamera,
                 WheelEncoderSensor,
                 IMUSensor,
                 PointCloudClusteringModel,
                 KalmanFilterStateEstimation,
                 ActuationConversionModel,
                 RawLiDARPointCloud,
                 ProcessedObjectTracks,
                 EgoVehicleState,
                 PhysicalTwinEntity
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains ControllingFunctionalEntity,
                 PresentationFunctionalEntity,
                 ReportingFunctionalEntity,
                 DataStorageService,
                 ProcessedObjectTracksData,
                 EgoVehicleStateData,
                 SQLAggregatedTimeseries,
                 DigitalTwinEntity
]

// C13: Functional Entities (ROS2 Packages)
instance DataCollectionFunctionalEntity : DTDFVocab:Component [
    base:desc "ROS2 package collecting raw sensor data and preprocessing it for transmission to the Data Translation Functional Entity."
    base:isContainedIn PhysicalTwinEnvironment
]

instance ControllingFunctionalEntity : DTDFVocab:Component [
    base:desc "ROS2 package implementing ISO 15622 compliant ACC control logic computing desired speed based on lead vehicle distance."
    base:isContainedIn DigitalTwinEnvironment
]

instance PresentationFunctionalEntity : DTDFVocab:Component [
    base:desc "ROS2 package providing 3D visualization and user interface for real-time monitoring of vehicle state and object tracks."
    base:isContainedIn DigitalTwinEnvironment
]

instance ReportingFunctionalEntity : DTDFVocab:Component [
    base:desc "ROS2 package generating human-readable reports of timeseries data for analysis and troubleshooting."
    base:isContainedIn DigitalTwinEnvironment
]

// C14: Data Storage
instance DigitalTwinEntityDataStorage : DTDFVocab:Enabler [
    base:desc "SQL database aggregating object tracks and ego vehicle state data for external storage and analysis."
    DTDFVocab:enables DataStorageService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The interactions from the virtual world to the physical world include:
  - **Desired speed commands** computed by the **ACC Controlling FE** in the Digital Twin Entity, sent to the Physical Twin Entity for actuation via the **Actuation FE**.
  - **Emergency braking commands** and **ACC enable/disable signals** transmitted from the **User Entity** (Control Panel) to the Physical Twin Entity.
  - **Actuation commands** (motor voltage, steering servo signals) generated by the Physical Twin Entity's **Actuation FE** and sent to the vehicle's hardware via ROS2 nodes.
  Communication between entities uses **ROS2** for intra-system messaging and **Wi-Fi (UDP/TCP)** for inter-entity communication, with clock synchronization maintained to **±100 ms** for distributed system coordination."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin operates on a **real-time, millisecond-scale** time synchronization framework with the following specifics:
  - **End-to-end latency**: ≤100 ms (mandated by 3GPP TS 22.185 for V2V communication).
  - **Clock synchronization**: ±100 ms accuracy across distributed components (ROS2 clock synchronization).
  - **Perception cycle**: Object tracks updated every cycle (LiDAR/Depth Camera frame rate dependent; typically 10–30 Hz).
  - **Control loop**: ACC computation and actuation occur at a rate aligned with vehicle dynamics (e.g., 10–50 Hz).
  The DT ensures **tight coupling** between virtual and physical environments for real-time decision-making."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated as a **three-tier, entity-based architecture** aligned with ISO 23247, with the following components:
  - **Physical Twin Entity**: Hosts sensor data processing (LiDAR/Depth Camera), point cloud clustering, tracking, and actuation (motor/steering servo).
  - **Digital Twin Entity**: Hosts control logic (ACC Controlling FE), data collection, reporting, and visualization preprocessing.
  - **User Entity**: Provides **3D Visualization UI** (object tracks, vehicle state) and **Control Panel UI** (remote management commands).
  - **Cross-System Entity**: **Data Translation FE** ensures seamless data exchange between entities via ROS2 and Wi-Fi.
  The system follows a **modular, loosely coupled design** with clear separation of concerns, enabling scalability and maintainability. Deployment occurs on **distributed hardware** (Jetson Orin Nano for PT, external servers for DT/User Entities)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin operates across **multiple lifecycle stages** of the physical twin, primarily:
  - **Design/Development Phase**: Used as a **cyber-physical experimentation facility** for ACC system validation and testing (e.g., compliance with ISO 15622).
  - **Operation Phase**: Deployed for **real-time monitoring, remote management, and predictive maintenance** of the ACC system during vehicle operation.
  The DT represents the **as-operated** state of the physical twin, enabling continuous feedback loops for optimization and troubleshooting. No explicit mention of **as-manufactured** or **as-designed** phases is provided, but the DT is clearly integrated into the **operational lifecycle** of the autonomous vehicle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT incorporates the following fidelity and validity considerations:
  - **Model Fidelity**:
    - **Point Cloud Processing**: DBSCAN clustering and Kalman filtering ensure high-fidelity object detection and state estimation.
    - **Actuation Fidelity**: Direct mapping of DT-derived commands to physical actuators (motor/steering servo) with minimal latency.
  - **Validation Mechanisms**:
    - **Compliance Testing**: ACC logic validated against **ISO 15622 (Performance Class I)** requirements.
    - **Latency Testing**: End-to-end latency verified to be ≤100 ms (per 3GPP TS 22.185).
    - **Clock Synchronization**: ±100 ms accuracy enforced via ROS2 clock synchronization.
  - **Uncertainty Sources**:
    - **Sensor Noise**: LiDAR/Depth Camera data may introduce tracking errors in object state estimates.
    - **Network Jitter**: Wi-Fi communication could introduce variability in inter-entity latency.
  - **Verification**: No explicit mention of formal verification (e.g., model checking) is provided, but empirical validation via real-world testing is implied."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection between the PT and DT includes:
  - **Network Protocols**:
    - **Intra-system communication**: **ROS2 topics/services** (UDP-based) for intra-entity messaging.
    - **Inter-entity communication**: **Wi-Fi (UDP/TCP)** over a dedicated network link.
  - **Data Formats**:
    - **ROS2 message types** for internal communication (e.g., sensor_msgs/PointCloud2 for LiDAR data).
    - **Custom serialization** via **Data Translation FE** for cross-entity data exchange (unit conversion, message alignment).
  - **Latency Requirements**:
    - **End-to-end latency**: ≤100 ms (mandated by 3GPP TS 22.185 for V2V communication).
    - **Clock synchronization**: ±100 ms accuracy across distributed components (ROS2 clock synchronization).
  - **Security Considerations**: Not explicitly detailed, but Wi-Fi communication could be secured via **TLS/SSL** or **V2X security protocols** (not mentioned in the document)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted and deployed as follows:
  - **Physical Twin Entity**: Deployed on the **NVIDIA Jetson Orin Nano** onboard the autonomous vehicle, running **ROS2** and **Jetpack 5.0**.
  - **Digital Twin Entity**: Hosted on **external compute resources** (not specified; likely cloud or edge servers) running ROS2 for control logic, data processing, and reporting.
  - **User Entity**: Hosted on **external devices** (e.g., laptops, tablets) running a **web-based UI** (3D visualization and control panel) connected via Wi-Fi.
  - **Data Storage**: **SQL database** hosted externally (location unspecified) for storing aggregated timeseries data.
  The architecture follows a **distributed deployment model**, with clear separation of compute-intensive tasks (e.g., point cloud processing on Jetson) and user-facing services (e.g., visualization on external devices)."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT demonstrates **limited horizontal integration** with external systems as per the provided documents:
  - **No explicit integration** with other Digital Twins, enterprise systems (e.g., PLM, MES), or external IoT platforms is mentioned.
  - **Potential future integration points**:
    - **AI Simulation**: Could integrate with external AI training pipelines (e.g., synthetic data generation for ACC agents).
    - **Vehicle Telematics**: Could connect to **OEM telematics systems** for fleet-wide data aggregation (not implemented in this case study).
  - **Data Exchange**: Primarily confined to **ROS2-based internal communication** and **Wi-Fi-based inter-entity messaging**."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "The documents do not explicitly address **data ownership and privacy**, but the following can be inferred:
  - **Data Ownership**: Likely owned by the **vehicle operator/developer** (e.g., McMaster University in the case study), given the context of a research project. No mention of third-party data providers or cloud service ownership.
  - **Privacy Considerations**:
    - **Sensitive Data**: Object tracks and vehicle state data could contain **location/identity information** if deployed in real-world scenarios.
    - **No explicit privacy policies** are outlined (e.g., GDPR compliance, anonymization techniques).
    - **Access Control**: Remote management UI suggests **authenticated access**, but no details on **role-based access control (RBAC)** or **data encryption** are provided.
  - **Ethical Implications**: The DT enables **remote control of autonomous vehicles**, raising questions about **accountability** in case of accidents (not addressed in the document)."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT adheres to the following standards:
  - **ISO 23247**: **Digital Twin Manufacturing Framework (Part 2: Reference Architecture)** serves as the foundational architecture, with adaptations for automotive use (e.g., introduction of **Physical Twin Entity**).
  - **ISO 15622**: **Road Vehicles – Adaptive Cruise Control (ACC) Systems** compliance for the ACC logic (Performance Class I).
  - **3GPP TS 22.185**: **Service Requirements for V2V Communication**, mandating ≤100 ms end-to-end latency.
  - **IEC 62541 (OPC UA)**: Not explicitly used, but **ROS2** could be integrated with OPC UA for industrial interoperability (mentioned as a potential alternative in ISO 23247).
  - **ROS2**: **Robot Operating System 2** as the middleware standard for intra-system communication.
  The DT leverages **automotive-specific standards** (ISO 15622) alongside **general DT frameworks** (ISO 23247)."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT incorporates the following security and safety considerations:
  - **Safety**:
    - **Real-time Constraints**: End-to-end latency ≤100 ms and clock synchronization (±100 ms) ensure **deterministic behavior** critical for autonomous vehicle safety.
    - **ACC Compliance**: Adherence to **ISO 15622** guarantees safe following distance control.
    - **Remote Actuation**: Emergency braking commands are transmitted via the DT, requiring **fail-safe mechanisms** (not explicitly detailed).
  - **Security**:
    - **Network Security**: Wi-Fi communication could be vulnerable to **man-in-the-middle attacks** or **denial-of-service (DoS)** attacks (not mitigated in the document).
    - **Authentication**: Remote management UI suggests **user authentication**, but no details on **secure communication protocols** (e.g., TLS, V2X security) are provided.
    - **Data Integrity**: **ROS2 clock synchronization** and **Data Translation FE** ensure consistency, but no **cryptographic hashing** or **immutable logging** is mentioned.
  - **Ethical Risks**:
    - **Remote Control**: Enables **off-site actuation**, raising liability questions in case of accidents (not addressed).
    - **Privacy**: Real-time tracking data could be misused if not properly secured (e.g., GDPR violations).
  - **Mitigations**: The document does not detail **formal security certifications** (e.g., ISO 27001) or **safety certifications** (e.g., ISO 26262), focusing instead on functional requirements."
]