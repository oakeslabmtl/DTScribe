namespace DTDFVocab = "http://example.org/dtdf#"
namespace base = "http://www.w3.org/2000/01/rdf-schema#"

instance HokuyoUST10LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR sensor providing raw point cloud data for object detection"
]

instance IntelRealSenseD435i : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera providing stereo images and depth data"
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor measuring current speed of the Traxxas Slash platform"
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring current steering angle of the vehicle"
]

instance LiDARPointcloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LX
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435i
]

instance VehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance LiDARPointcloudData : DTDFVocab:Data [
    base:desc "Raw point cloud data from Hokuyo UST-10LX LiDAR",
    DTDFVocab:fromData LiDARPointcloudDataTransmitted
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image data from Intel RealSense D435i camera",
    DTDFVocab:fromData DepthImageTransmitted
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Real-time vehicle speed data",
    DTDFVocab:fromData VehicleSpeedDataTransmitted
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Real-time steering angle data",
    DTDFVocab:fromData SteeringAngleDataTransmitted
]

instance ClusteredPointcloudData : DTDFVocab:Data [
    base:desc "Clustered point cloud data from DBSCAN processing",
    DTDFVocab:fromData LiDARPointcloudDataTransmitted
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks from Kalman filter tracking",
    DTDFVocab:fromData LiDARPointcloudDataTransmitted
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Combined vehicle state data including speed and steering angle",
    DTDFVocab:fromData VehicleSpeedDataTransmitted, SteeringAngleDataTransmitted
]

instance ACCControlCommandData : DTDFVocab:Data [
    base:desc "Desired speed command from ACC control logic",
    DTDFVocab:fromData VehicleSpeedDataTransmitted
]

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN-based point-cloud clustering algorithm for object detection",
    DTDFVocab:inputTo MATLABSimulink
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter-based object tracking model for maintaining object trajectories",
    DTDFVocab:inputTo MATLABSimulink
]

instance ACCControlLogicModel : DTDFVocab:Model [
    base:desc "ACC control logic conforming to ISO 15622 performance class I",
    DTDFVocab:inputTo ROS2Middleware
]

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for communication between functional entities",
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService, DataMonitoringService
]

instance NVIDIAJetPack5_0 : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK for hardware acceleration and software stack"
]

instance Python3_8 : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime for scripting and integration"
]

instance CppROS2NodeLifecycle : DTDFVocab:Enabler [
    base:desc "C++ implementation for ROS2 node lifecycle management"
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for point-cloud clustering and object tracking",
    DTDFVocab:enables DataMonitoringService
]

instance WiFiCommunication : DTDFVocab:Enabler [
    base:desc "Wi-Fi link for physical-to-digital twin communication"
]

instance OPCUA : DTDFVocab:Enabler [
    base:desc "OPC UA (IEC 62541) for standardized data translation"
]

instance DataCollectionEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity for collecting sensor data from physical twin"
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity for translating data across system entities"
]

instance SQLStorageEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for persistent storage of vehicle state in SQL database",
    DTDFVocab:enables DataMonitoringService
]

instance ActuationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for converting control commands to actuator signals",
    DTDFVocab:enables ActuationService
]

instance VedderESCACTUATOR : DTDFVocab:ActingComponent [
    base:desc "Vedder electronic speed controller converting voltage commands to motor control"
]

instance SteeringServoACTUATOR : DTDFVocab:ActingComponent [
    base:desc "Steering servo for adjusting vehicle steering angle"
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time UI display of speed, steering, object tracks, projected path, and report generation",
    DTDFVocab:provides RealTimeSpeedInsight, RealTimeSteeringAngleInsight, ObjectTracksInsight, ProjectedPathInsight, ReportGenerationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm executed in the DT and results returned to the PT",
    DTDFVocab:provides ACCControlCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator can enable/disable ACC, adjust desired speed, and trigger emergency braking",
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakingAction
]

instance ActuationService : DTDFVocab:Service [
    base:desc "Converts DT-computed commands to physical actuator signals",
    DTDFVocab:provides MotorVoltageCommandAction, SteeringServoCommandAction
]

instance RealTimeSpeedInsight : DTDFVocab:Insight [
    base:desc "Real-time speed display for operator monitoring"
]

instance RealTimeSteeringAngleInsight : DTDFVocab:Insight [
    base:desc "Real-time steering angle display for operator monitoring"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Real-time object tracks visualization"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected path visualization for autonomous navigation"
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Generated reports for post-run analysis and parameter tuning"
]

instance ACCControlCommandAction : DTDFVocab:Action [
    base:desc "ACC control command generated by DT and sent to PT",
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable ACC system",
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable ACC system",
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator command to adjust desired ACC speed",
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator command to trigger emergency braking",
    DTDFVocab:IsAutomatic false
]

instance MotorVoltageCommandAction : DTDFVocab:Action [
    base:desc "Motor voltage command for Vedder ESC",
    DTDFVocab:IsAutomatic true
]

instance SteeringServoCommandAction : DTDFVocab:Action [
    base:desc "Steering servo command for adjusting steering angle",
    DTDFVocab:IsAutomatic true
]

instance PhysicalTwinEntity : DTDFVocab:Environment [
    base:desc "Hosts sensors, actuators, and low-level processing",
    base:contains HokuyoUST10LX, IntelRealSenseD435i, VehicleSpeedSensor, SteeringAngleSensor, VedderESCACTUATOR, SteeringServoACTUATOR
]

instance DigitalTwinEntity : DTDFVocab:Environment [
    base:desc "Data collection, ACC control, reporting, visualization pre-processing",
    base:contains ROS2Middleware, MATLABSimulink, SQLStorageEnabler, DataCollectionEnabler, DataTranslationEnabler
]

instance UserEntity : DTDFVocab:Environment [
    base:desc "3D visualization and control-panel UI"
]

instance CrossSystemEntity : DTDFVocab:Environment [
    base:desc "Provides Data Translation services across entities",
    base:contains OPCUA, DataTranslationEnabler
]

instance AutonomousVehicleSystem : DTDFVocab:SystemUnderStudy [
    base:desc "1/10-scale autonomous vehicle system",
    DTDFVocab:hasEnvironment PhysicalTwinEntity, DigitalTwinEntity, UserEntity, CrossSystemEntity
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends motor voltage commands and steering‑servo setpoints generated by the Controlling FE (ACC) and Actuation FE, as well as remote‑management commands (enable/disable ACC, set desired speed, emergency brake) issued through the User Interface FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sub‑second real‑time operation with a hard end‑to‑end latency limit of 100 ms between PT and DT; component clocks are synchronized to within 100 ms accuracy."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The PT runs the Physical Twin Entity on its Jetson hardware, exposing sensor data over ROS 2; the Digital Twin Entity runs on separate compute (e.g., cloud/PC) and receives data via Wi‑Fi, performs ACC, reporting, and visualization preprocessing; the User Entity provides a 3D visualization and control panel UI; all entities inter‑communicate through ROS 2 topics and a Cross‑System Data Translation FE that serializes and converts units."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity sensor processing (DBSCAN, Kalman filter) ensures accurate object tracks; ACC follows ISO 15622 specifications; latency ≤100 ms and clock sync ≤100 ms guarantee timely and ordered data for safety‑critical operation; external SQL storage keeps a complete timeseries for validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bi‑directional Wi‑Fi link between PT and DT; ROS 2 publish/subscribe transports intra‑entity messages; Data Translation FE serializes data, aligns message types and performs unit conversions; optional OPC‑UA transport is mentioned as a possible implementation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity components execute on the vehicle’s Jetson Orin Nano; Digital Twin Entity components (data collection, ACC, reporting, visualization preprocessing) run on an external computing platform (e.g., cloud or workstation) accessed via Wi‑Fi; each FE is packaged as an independent ROS 2 node for modular deployment."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (reference architecture and functional entities), uses ISO 15622 for ACC functional specifications, references IEC 62541 OPC‑UA as a possible communication standard, and adopts 3GPP 22.185 latency requirements; ROS 2 and NVIDIA JetPack provide de‑facto industrial tooling standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The system is designed for safety‑critical operation with strict latency (≤100 ms) and clock‑sync (≤100 ms) constraints; remote management includes an emergency braking command; although explicit security mechanisms are not described, the architecture assumes safe operation of remote commands on a physical twin."
]