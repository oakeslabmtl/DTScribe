// C2: Acting Components
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Sends commanded motor voltage via Vedder Electronic Speed Controller to the drive motor on the 1/10‑scale vehicle"
]
instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Controls steering servo via onboard servo controller to adjust vehicle heading"
]
instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Transmits emergency braking command to vehicle braking actuator when needed"
]

// C3: Physical sensing components
instance HokuyoUST10LxLiDAR : DTDFVocab:SensingComponent [
    base:desc "Generate raw LiDAR point clouds using Hokuyo UST 10LX LiDAR"
    DTDFVocab:producedData LiDARPointCloudTransmission
]
instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Provides RGB‑D images using Intel D435i depth camera"
    DTDFVocab:producedData RGBDImageTransmission
]
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Measures vehicle speed using on‑board speed sensor"
    DTDFVocab:producedData SpeedMeasurementTransmission
]
instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Measures steering shaft angle using steering angle sensor"
    DTDFVocab:producedData SteeringAngleMeasurementTransmission
]

// C4: Physical‑to‑virtual interaction (Data transmitted)
instance LiDARPointCloudTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LxLiDAR
]
instance RGBDImageTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]
instance SpeedMeasurementTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]
instance SteeringAngleMeasurementTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C10: Models/Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "LiDAR point cloud data collected from sensor"
    DTDFVocab:fromData LiDARPointCloudTransmission
    DTDFVocab:inputTo ComputationEnabler, DatabaseEnabler
]
instance RGBDImageData : DTDFVocab:Data [
    base:desc "RGB‑D image data collected from depth camera"
    DTDFVocab:fromData RGBDImageTransmission
    DTDFVocab:inputTo ComputationEnabler, DatabaseEnabler
]
instance SpeedMeasurementData : DTDFVocab:Data [
    base:desc "Vehicle speed measurement data collected from speed sensor"
    DTDFVocab:fromData SpeedMeasurementTransmission
    DTDFVocab:inputTo ComputationEnabler, DatabaseEnabler
]
instance SteeringAngleMeasurementData : DTDFVocab:Data [
    base:desc "Steering angle measurement data collected from steering sensor"
    DTDFVocab:fromData SteeringAngleMeasurementTransmission
    DTDFVocab:inputTo ComputationEnabler, DatabaseEnabler
]
instance VehicleDynamicsStateSpaceModel : DTDFVocab:Model [
    base:desc "State‑space model of vehicle dynamics used for ACC simulation"
    DTDFVocab:inputTo ComputationEnabler
]
instance DBSCANLidarClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point clouds to identify obstacles"
    DTDFVocab:inputTo ComputationEnabler
]
instance KalmanTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter tracking of detected objects for collision avoidance"
    DTDFVocab:inputTo ComputationEnabler
]
instance Visual3DRenderingModel : DTDFVocab:Model [
    base:desc "3‑D rendering model for visualizing vehicle state and tracked objects in UI"
    DTDFVocab:inputTo VisualizationEnabler
]
instance SQLDatabaseStorageModel : DTDFVocab:Model [
    base:desc "SQL database model for persistent storage of state and track time‑series"
    DTDFVocab:inputTo DatabaseEnabler
]

// C11: Enablers
instance ComputationEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 node that processes vehicle state, sensor data, and runs ACC algorithm on remote host"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]
instance DatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Database component that persists data from all sensors and models"
    DTDFVocab:enables DataMonitoringService
]
instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Visualization engine that renders 3‑D models and object tracks in real time"
    DTDFVocab:enables VisualizationService
]
instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Remote management interface handling user requests from UI to control ACC operation"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time UI display, data logging, and report generation for vehicle operation"
    DTDFVocab:provides SpeedInsight, SteeringAngleInsight, ObjectTrackInsight, PathProjectionInsight
]
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm on Digital Twin and sends motor voltage and steering commands to Physical Twin"
    DTDFVocab:provides ExecuteACCControlAction
]
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Handles enabling/disabling ACC, setting target speed, and triggering emergency braking from user interface" // TODO: Fix the error on this line using the following error message: 'Couldn't resolve reference to Entity 'DTDFvocab:Service'.'
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, TriggerEmergencyBrakeAction
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Renders 3‑D visualization of vehicle state, projected path, and detected object tracks in real time"
    DTDFVocab:provides VehicleStateVisualizationInsight
]

