// C3: Physical sensing components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2‑D LiDAR providing 270° scan of surroundings"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D frames"
    DTDFVocab:producedData LiDARPointCloudTransmitted   // depth data merged into point cloud stream
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑onboard wheel speed sensor reporting ego speed in m/s"
    DTDFVocab:producedData SpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle encoder providing current steering wheel angle in degrees"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR, IntelRealSenseD435iDepthCamera
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C10: Models/Data
instance ACCControlModelISO15622 : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) logic complying with ISO 15622 performance‑class I"
    DTDFVocab:inputTo ROS2Middleware
]

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm for LiDAR point‑cloud segmentation"
    DTDFVocab:inputTo MATLABSimulinkClusteringTracking
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter based multi‑object tracking on clustered point clouds"
    DTDFVocab:inputTo MATLABSimulinkClusteringTracking
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Detected and tracked object trajectories derived from LiDAR point clouds"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo MATLABSimulinkClusteringTracking
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Current ego vehicle state composed of speed and steering angle"
    DTDFVocab:fromData SpeedDataTransmitted, SteeringAngleDataTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware handling real‑time message exchange over Wi‑Fi"
    DTDFVocab:enables ComputationOffloadingService, DataMonitoringService, RemoteManagementService
]

instance NVIDIAJetPack5SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK providing GPU acceleration on Jetson platforms"
    DTDFVocab:enables ComputationOffloadingService
]

instance MATLABSimulinkClusteringTracking : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment executing DBSCAN clustering and Kalman filtering"
    DTDFVocab:enables Visualization3DService, ReportGenerationService
]

instance Python38Runtime : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime used by ACC and data‑processing scripts"
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService
]

instance CppRuntime : DTDFVocab:Enabler [
    base:desc "C++ runtime for high‑performance components"
    DTDFVocab:enables ComputationOffloadingService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI displaying speed, steering angle, object tracks and projected path"
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTracksVisualizationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm and trajectory prediction on the digital twin"
    DTDFVocab:provides ProjectedPathInsight, AdjustMotorVoltageAction, AdjustSteeringAngleAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, or trigger emergency brake"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

instance Visualization3DService : DTDFVocab:Service [
    base:desc "3‑D visualization of clustered objects and tracks in a virtual environment"
    DTDFVocab:provides ThreeDVisualizationInsight
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generates time‑series CSV reports from vehicle state and tracking data"
    DTDFVocab:provides ReportGenerationInsight
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Live visualization of ego vehicle speed and steering angle"
]

instance ObjectTracksVisualizationInsight : DTDFVocab:Insight [
    base:desc "Display of detected object tracks overlaid on LiDAR point cloud"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Predicted future path of the autonomous vehicle based on ACC logic"
]

instance ThreeDVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3‑D rendering of the environment with objects and trajectories"
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "CSV report summarizing vehicle state and object tracking over time"
]

// C17: Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set the desired cruising speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Trigger an immediate emergency brake"
    DTDFVocab:IsAutomatic true
]

instance AdjustMotorVoltageAction : DTDFVocab:Action [
    base:desc "Adjust motor voltage command to achieve target speed"
    DTDFVocab:IsAutomatic true
]

instance AdjustSteeringAngleAction : DTDFVocab:Action [
    base:desc "Adjust steering servo position based on trajectory planning"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT sends ACC‑computed desired speed, enable/disable ACC commands, and emergency‑brake signals back to the PT over Wi‑Fi; Data Translation FE serializes and unit‑converts these commands, which are applied by the Actuation FE to the motor and steering actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with end‑to‑end network latency limited to ≤100 ms (R7) and clock synchronization accuracy of 100 ms (R8)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An ISO 23247‑based architecture mapping Physical Twin Entity (OME analogue), Digital Twin Entity (data collection, reporting, ACC control), User Entity (UI FE), and Cross‑System Entity (data translation), realized as ROS 2 packages across vehicle and external host."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Compliance with ISO 15622 ACC specification; real sensor data used for object tracking; latency ≤100 ms and clock sync ≤100 ms to maintain temporal fidelity; data stored in SQL database for validation; reporting FE generates human‑readable logs."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional Wi‑Fi link between PT and DT; ROS 2 topics for intra‑entity communication; Data Translation FE performs serialization, message‑type alignment, and unit conversion across the network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the on‑board NVIDIA Jetson Orin Nano; Digital Twin Entity and User Entity run on external compute (e.g., cloud or workstation) connected via Wi‑Fi; each functional entity is packaged as an independent ROS 2 node."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Designed according to ISO 23247 reference architecture; ACC functionality follows ISO 15622; concepts from ISO/IEC 30173:2023 and optional OPC UA (IEC 62541) mentioned for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "System is designed for safety‑critical operation with latency ≤100 ms and synchronized clocks; remote management commands are acknowledged but specific security mechanisms are not detailed in the document."
]