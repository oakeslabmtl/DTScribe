// -----------------------------------------------------------------------------
// Hierarchical Entities (multiplicities)
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical Twin Entity hosts sensors, actuators, and compute resources for the 1/10‑scale autonomous vehicle"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital Twin Entity provides data‑management, ACC computation, and remote‑control logic in the cloud"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User Entity supplies the operator/developer UI for monitoring, off‑loading and remote management"
]

// -----------------------------------------------------------------------------
// Physical Sensing Components
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor on the physical vehicle that streams raw point‑cloud data"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance MotorStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reading motor speed and torque of the physical vehicle"
    DTDFVocab:producedData MotorStateTransmitted
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor exposing the steering servo angular position"
    DTDFVocab:producedData SteeringServoTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Aggregated vehicle‑state sensor providing speed, heading and GPS location"
    DTDFVocab:producedData VehicleStateTransmitted
]

// -----------------------------------------------------------------------------
// Physical‑to‑Virtual Data Transmission
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance MotorStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStateSensor
]

instance SteeringServoTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// -----------------------------------------------------------------------------
// Data Instances (post‑transmission)
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ACCComputationEnabler, DataTranslationEnabler
]

instance MotorStateData : DTDFVocab:Data [
    base:desc "Motor speed and torque values"
    DTDFVocab:fromData MotorStateTransmitted
    DTDFVocab:inputTo RemoteControlEnabler, DataTranslationEnabler
]

instance SteeringServoData : DTDFVocab:Data [
    base:desc "Steering servo angular position"
    DTDFVocab:fromData SteeringServoTransmitted
    DTDFVocab:inputTo RemoteControlEnabler, DataTranslationEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle speed, heading and GPS location"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo ACCComputationEnabler, DataTranslationEnabler
]

// -----------------------------------------------------------------------------
// Enablers (functional entities)
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247 Data Translation FE: serialises streams, aligns message types and performs unit conversions"
    DTDFVocab:enables DataMonitoringService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "ACC Computation FE: executes Adaptive Cruise Control algorithm (lead‑vehicle identification & desired‑speed computation) in the cloud"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Remote‑Control FE: processes operator commands to enable/disable ACC, set target speed and trigger emergency brake"
    DTDFVocab:enables RemoteManagementService
]

// -----------------------------------------------------------------------------
// Services (core DT services)
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI streams real‑time vehicle state, projected path and detected object tracks permits view, save and report generation"
    DTDFVocab:provides DataMonitoringInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC logic in the digital twin and returns a speed set‑point to the vehicle for actuation"
    DTDFVocab:provides ComputationOffloadingInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI lets operators enable/disable ACC, set desired speed and issue an emergency‑brake command"
    DTDFVocab:provides RemoteManagementInsight,
                     RemoteManagementActionEnableACC,
                     RemoteManagementActionDisableACC,
                     RemoteManagementActionSetSpeed,
                     RemoteManagementActionEmergencyBrake
]

// -----------------------------------------------------------------------------
// Insights
instance DataMonitoringInsight : DTDFVocab:Insight [
    base:desc "Operators can view live data, save snapshots and generate performance reports"
]

instance ComputationOffloadingInsight : DTDFVocab:Insight [
    base:desc "Off‑loaded ACC reduces load on vehicle ECUs and provides a computed desired speed based on lead‑vehicle detection"
]

instance RemoteManagementInsight : DTDFVocab:Insight [
    base:desc "Operators gain remote control over ACC state and can intervene with emergency braking"
]

// -----------------------------------------------------------------------------
// Actions (remote management commands)
instance RemoteManagementActionEnableACC : DTDFVocab:Action [
    base:desc "Command to enable Adaptive Cruise Control remotely"
    DTDFVocab:IsAutomatic false
]

instance RemoteManagementActionDisableACC : DTDFVocab:Action [
    base:desc "Command to disable Adaptive Cruise Control remotely"
    DTDFVocab:IsAutomatic false
]

instance RemoteManagementActionSetSpeed : DTDFVocab:Action [
    base:desc "Command to set the target speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance RemoteManagementActionEmergencyBrake : DTDFVocab:Action [
    base:desc "Command to trigger emergency braking on the physical vehicle"
    DTDFVocab:IsAutomatic false
]

// -----------------------------------------------------------------------------
// Physical Acting Components
instance VehicleActuatorComponent : DTDFVocab:ActingComponent [
    base:desc "Functional Entity in Physical Twin that actuates throttle, brake and steering via a ROS2 package"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Dedicated actuator for emergency braking controlled by RemoteManagement actions"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin issues control commands back to the Physical Twin via the Actuation FE. Commands include ACC enable/disable, desired speed set‑points, and emergency braking signals, which are consumed by the vehicle’s actuation modules (motor, steering servo). The messages are formatted according to the Data Translation FE specifications and transmitted over the same Wi‑Fi / UDP link. The vehicle acknowledges command execution through updated vehicle state feedback displayed in the 3D visualization."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires clock synchronization between physical and digital components with an accuracy of 100 ms, as mandated by safety‑critical vehicular standards; devices share a common notion of time to enable computation offloading."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 reference architecture, organizing software components into entity‑based functional entities that are implemented as individual ROS2 packages; each package hosts ROS2 nodes that realize the FE, enabling integration and resource management across the three entities."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication between the physical twin and the DTS uses a Wi‑Fi network with UDP transport. Internally, DTS software components communicate over a ROS 2 middleware network. The architecture is designed to meet low end‑to‑end latency requirements needed for safety‑critical ACC operation, but the documents do not specify exact bandwidth, latency values, redundancy mechanisms, or security protocols."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "ACC computation is offloaded from the resource‑constrained vehicle to the Digital Twin hosted on cloud resources, providing higher‑performance compute for the ACC algorithm. The DTS includes UI components for monitoring, data collection, reporting, and remote management, implying a cloud‑based deployment model with sufficient storage for vehicle state logs and scalability to handle additional data streams. Availability is addressed by the requirement for low‑latency communication, but explicit redundancy or fault‑tolerance mechanisms are not specified."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built to comply with the ISO 23247 Digital Twin framework for manufacturing (parts 1–4). The reference architecture is adopted as the primary guideline for defining entities and functional entities. For inter‑device communication the design can employ OPC Unified Architecture (OPC UA) as suggested by the standard. Runtime components are realised as ROS 2 packages, which rely on the DDS (Data Distribution Service) specification for publish‑subscribe communication, providing interoperability with other DDS‑compliant tools. The implementation respects vehicular‑safety clock‑synchronisation requirements of ≤100 ms accuracy, a constraint referenced as a typical mandate of safety‑critical vehicular standards."
]