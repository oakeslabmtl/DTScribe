// C2: Acting Components
instance VedderSpeedControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder electronic speed controller receiving voltage commands derived from speed set‑points"
]

instance ChassisControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Lower‑level chassis controller commanding steering angle and vehicle speed"
]

// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor on the physical twin providing raw point‑cloud data"
    DTDFVocab:producedData LiDARDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor providing speed, pose and CAN‑bus information"
    DTDFVocab:producedData VehicleStateDataTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Motor status sensor reporting motor voltage and current"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

instance SteeringServoStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Steering servo status sensor providing steering angle feedback"
    DTDFVocab:producedData SteeringServoStatusDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance SteeringServoStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoStatusSensor
]

// C5: Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud captured by LiDARSensor"
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state data (speed, pose) from VehicleStateSensor"
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo ACCProcessingEnabler
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Motor status data (voltage, current) from MotorStatusSensor"
    DTDFVocab:fromData MotorStatusDataTransmitted
    DTDFVocab:inputTo ACCProcessingEnabler
]

instance SteeringServoStatusData : DTDFVocab:Data [
    base:desc "Steering servo status (angle feedback) from SteeringServoStatusSensor"
    DTDFVocab:fromData SteeringServoStatusDataTransmitted
    DTDFVocab:inputTo ACCProcessingEnabler
]

// C10: Models
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN algorithm for clustering raw LiDAR point clouds"
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance ObjectTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter based tracking of clustered objects"
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "ACC model determining lead vehicle and safe following speed"
    DTDFVocab:inputTo ACCProcessingEnabler
]

// C11: Enablers
instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 package implementing DBSCAN clustering and Kalman filter tracking"
    DTDFVocab:enables DataMonitoringService
]

instance ACCProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Cloud‑based ACC computation using vehicle state and actuator status"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 service interface allowing operators to enable/disable ACC and issue emergency brake"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Displays real‑time vehicle state, projected path and detected object tracks; enables saving and reporting"
    DTDFVocab:provides VehicleStateVisualizationInsight, ObjectTrackVisualizationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm off‑board in the cloud and returns speed commands to the vehicle"
    DTDFVocab:provides SafeFollowingSpeedInsight, ApplySpeedCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to remotely enable/disable ACC, set desired speed, and issue emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights / Actions
instance VehicleStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of ego‑vehicle state and projected driving path"
]

instance ObjectTrackVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of object tracks generated from LiDAR clustering and tracking"
]

instance SafeFollowingSpeedInsight : DTDFVocab:Insight [
    base:desc "Computed safe following speed based on lead vehicle detection and inter‑vehicle distance"
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set desired cruising speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediate emergency braking command via ROS2 service"
    DTDFVocab:IsAutomatic false
]

instance ApplySpeedCommandAction : DTDFVocab:Action [
    base:desc "Apply speed command computed by ACC to the vehicle actuator"
    DTDFVocab:IsAutomatic true
]

// Additional Components (Entities)
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical Twin Entity hosting sensors, actuators and perception functional entities"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital Twin Entity hosting ROS2 packages for processing, models and services"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User Entity providing UI functional entity with visualization and control panel"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin computes Adaptive Cruise Control decisions (lead‑vehicle identification, desired speed) and sends control commands back to the vehicle over the same Wi‑Fi UDP link. Commands are packaged by the Data Translation FE into the vehicle’s actuation message format (e.g., desired speed set‑point, ACC enable/disable, emergency brake). The vehicle’s control unit receives the command, validates it, executes the corresponding actuation on motor and steering hardware, and provides implicit acknowledgment through subsequent state updates."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires clock synchronization between devices with an accuracy of 100 ms, which is the maximum tolerance imposed by hardware limitations; this synchronisation frequency is used to enable safe computation off‑loading in the vehicular context."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration follows the ISO 23247 reference architecture, mapping each Functional Entity to a ROS 2 package; each package contains one or more ROS 2 nodes that implement the entity’s functionality. Communication between the Physical Twin Entity (hosting compute, sensors, actuators and services such as Point Cloud Clustering & Tracking), the Digital Twin Entity (handling data pre‑processing, storage and control), and the User Entity (providing 3D visualization and control panels) is realised through ROS 2 publish/subscribe and service mechanisms, enabling component integration and resource management across the distributed hardware."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The architecture requires that all distributed components maintain a common notion of time with a synchronization accuracy of at most 100 ms, as dictated by hardware constraints and safety‑critical timing requirements. Consequently, the communication infrastructure must guarantee clock alignment within this bound, and any computation off‑loading between devices is designed to respect the 100 ms latency ceiling. Temporal fidelity is therefore a primary validation criterion for the twin’s operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Intra‑digital‑twin communication between software components uses ROS 2 (DDS) middleware. Communication between the physical twin and the digital twin occurs over a Wi‑Fi network with UDP as the transport protocol. The topology is a logical client‑server exchange where the vehicle streams sensor data to the DT and receives control messages in return. The system is required to sustain low end‑to‑end latency for safety‑critical ACC operation, but the documents do not give quantitative latency, bandwidth, reliability, redundancy or security protocol details."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The ACC functionality is off‑loaded from the resource‑constrained ECU to the Digital Twin, which can be executed on cloud‑based compute resources or any platform capable of running ROS 2 services. The DT requires sufficient processing power for point‑cloud clustering, tracking, and ACC decision logic, as well as storage for collected vehicle state data and generated reports. The system is designed to maintain low end‑to‑end latency for remote management, though specific hardware, scalability mechanisms, and availability guarantees are not detailed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built on the ISO 23247 Digital Twin framework (parts 1–4), explicitly adopting its entity‑based reference architecture (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity). It acknowledges vehicular safety‑critical clock‑synchronization standards that mandate ≤100 ms accuracy, and mentions the possibility of using OPC Unified Architecture for device communication. The implementation uses ROS2 packages (leveraging DDS) to meet interoperability requirements."
]