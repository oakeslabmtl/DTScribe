// C1: System Under Study
instance AutonomousVehicleDigitalTwinSystem : DTDFVocab:SystemUnderStudy [
    base:desc "1/10-scale autonomous vehicle retrofitted with autonomy components for Adaptive Cruise Control (ACC) Digital Twin implementation. Physical twin consists of Traxxas Slash 4x4 Premium vehicle with lower-level chassis (steering/speed control) and upper-level chassis hosting NVIDIA Jetson Orin Nano, NVIDIA Jetson NX antenna, Hokuyo UST-10LX LiDAR, Intel Deepsense D435i Depth Camera, and Vedder Electronic Speed Controller. Operates under ROS2 middleware and NVIDIA Jetpack 5.0 SDK, adhering to ISO 15622 for ACC functionality (performance class I)."
]

// C2: Acting Components
instance SpeedControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller converting desired speed (voltage commands) into physical movement for the autonomous vehicle's motor actuation"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Servo mechanism adjusting steering angle based on ACC commands from the Digital Twin"
]

instance EmergencyBrakingActuator : DTDFVocab:ActingComponent [
    base:desc "Direct actuation component for emergency braking commands transmitted from Digital Twin to Physical Twin, overriding normal ACC operations"
]

// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing 3D point cloud data for object detection and tracking"
]

instance IntelDeepsenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i Depth Camera capturing RGB-D images for environmental perception"
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor measuring ego vehicle speed for ACC control"
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor measuring steering angle for ACC control"
]

// C4: Physical-to-Virtual Interaction
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance CameraRGBDDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iCamera
]

instance VehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ProcessedObjectTracksDataTransmitted : DTDFVocab:DataTransmitted [
]

// C10: Models/Data
instance PointCloudClusteringAndTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering and Kalman filtering implementation for processing raw LiDAR data into object tracks (ID, position, velocity) using MATLAB/Simulink and Python 3.8"
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "ISO 15622 compliant Adaptive Cruise Control logic for speed adjustment and emergency braking"
]

instance VehicleStateTimeseriesData : DTDFVocab:Data [
    base:desc "Timeseries data containing ego vehicle state (speed, steering angle) and object tracks"
    DTDFVocab:fromData VehicleSpeedDataTransmitted, SteeringAngleDataTransmitted
]

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw and processed 3D point cloud data from Hokuyo UST-10LX LiDAR"
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
]

instance CameraRGBDData : DTDFVocab:Data [
    base:desc "RGB-D image data from Intel Deepsense D435i camera for environmental perception"
    DTDFVocab:fromData CameraRGBDDataTransmitted
]

instance DrivingPathProjectionData : DTDFVocab:Data [
    base:desc "Projected driving path data generated from ACC control model and object tracks"
]

// C11: Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for inter-component communication and node lifecycle management between Digital Twin and Physical Twin entities"
]

instance NVIDIAJetpack50SDKEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for Jetson hardware integration and optimization"
]

instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Custom implementation of DBSCAN clustering and Kalman filtering for point cloud processing using MATLAB/Simulink and Python 3.8"
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "ISO 15622 compliant ACC logic execution environment for computation offloading"
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Custom Data Translation Functional Entity handling serialization, unit conversion, and message alignment between ROS2 and UDP protocols"
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "SQL database for storing timeseries data (vehicle state, object tracks) with 100ms clock synchronization accuracy"
]

instance DataVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D CAD-based visualization tools for rendering vehicle, environment, and projected driving path"
]

instance EnvironmentalPerceptionEnabler : DTDFVocab:Enabler [
    base:desc "RGB-D image processing pipeline for environmental perception using Intel Deepsense D435i camera data"
]

instance CREOSimulateIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "CREO Simulate integration for predictive maintenance and health monitoring of vehicle components (e.g., brake systems)"
]

instance WiFiUDPNetworkEnabler : DTDFVocab:Enabler [
    base:desc "Wi-Fi UDP network protocol for inter-entity communication with maximum 100ms latency requirement (3GPP TS 22.185 compliant)"
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of ego vehicle state (speed, steering angle), object tracks, and projected driving path via 3D Visualization UI"
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC logic execution in Digital Twin (cloud/edge) with results sent back to Physical Twin for actuation, reducing onboard computational load"
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote enabling/disabling of ACC, desired speed adjustment, and emergency braking via Control Panel"
]

instance DataReportingService : DTDFVocab:Service [
    base:desc "Generation of human-readable reports (timeseries) of object tracks and vehicle state via Reporting Frontend"
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Integration with CREO Simulate for health monitoring of vehicle systems (e.g., brake systems) and anomaly detection"
]

instance ObjectTrackingService : DTDFVocab:Service [
    base:desc "Processing of LiDAR point clouds and camera data into object tracks (ID, position, velocity) using DBSCAN and Kalman filtering"
]

instance DataCollectionService : DTDFVocab:Service [
    base:desc "Real-time collection of sensor data (LiDAR, camera, vehicle state) from Physical Twin to Digital Twin via Wi-Fi UDP"
]

instance ActuationService : DTDFVocab:Service [
    base:desc "Execution of actuation commands (speed, steering, braking) on Physical Twin's lower-level chassis"
]

// C17: Insights/Actions
instance EgoVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of ego vehicle state including speed and steering angle for ACC performance analysis"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Processed object tracks (ID, position, velocity) from LiDAR and camera data for situational awareness"
]

instance DrivingPathVisualizationAction : DTDFVocab:Action [
    base:desc "Visualization of projected driving path based on ACC logic and object tracks"
    DTDFVocab:IsAutomatic true
]

instance ACCComputationInsight : DTDFVocab:Insight [
    base:desc "Performance metrics and behavior analysis of ISO 15622 compliant ACC logic execution"
]

instance ComputationOffloadingAction : DTDFVocab:Action [
    base:desc "Transmission of ACC computation results from Digital Twin to Physical Twin for actuation"
    DTDFVocab:IsAutomatic true
]

instance RemoteControlInsight : DTDFVocab:Insight [
    base:desc "Current state of remote management capabilities (ACC enabled/disabled, current speed settings)"
]

instance ACCEnableDisableAction : DTDFVocab:Action [
    base:desc "Remote enabling or disabling of Adaptive Cruise Control functionality"
    DTDFVocab:IsAutomatic false
]

instance DesiredSpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjustment of desired speed parameter for ACC operation"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Initiation of emergency braking command from Digital Twin to Physical Twin"
    DTDFVocab:IsAutomatic true
]

instance DataReportInsight : DTDFVocab:Insight [
    base:desc "Generated human-readable reports containing timeseries data of vehicle state and object tracks"
]

instance ReportGenerationAction : DTDFVocab:Action [
    base:desc "Automatic generation of data reports from stored timeseries information"
    DTDFVocab:IsAutomatic true
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection results and health monitoring data from CREO Simulate integration"
]

instance HealthMonitoringAction : DTDFVocab:Action [
    base:desc "Execution of predictive maintenance checks using simulator data"
    DTDFVocab:IsAutomatic true
]

instance ObjectDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of objects in environment with position, velocity, and classification information"
]

instance ObjectTrackingDataAction : DTDFVocab:Action [
    base:desc "Generation and maintenance of object tracks from raw sensor data"
    DTDFVocab:IsAutomatic true
]

instance DataCollectionInsight : DTDFVocab:Insight [
    base:desc "Current status of real-time data collection from Physical Twin sensors"
]

instance DataTransmissionAction : DTDFVocab:Action [
    base:desc "Transmission of sensor data from Physical Twin to Digital Twin via Wi-Fi UDP"
    DTDFVocab:IsAutomatic true
]

instance ActuationInsight : DTDFVocab:Insight [
    base:desc "Status of actuation commands executed on Physical Twin"
]

instance SpeedControlAction : DTDFVocab:Action [
    base:desc "Adjustment of vehicle speed via Electronic Speed Controller"
    DTDFVocab:IsAutomatic true
]

instance SteeringControlAction : DTDFVocab:Action [
    base:desc "Adjustment of steering angle via servo mechanism"
    DTDFVocab:IsAutomatic true
]

// C12: Environments/Components
instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Centralized Digital Twin Entity hosting core ACC computation, data collection, and reporting logic"
]

instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical Twin Entity deployed on NVIDIA Jetson Orin Nano handling data preprocessing, actuation, and LiDAR tracking"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User Entity deployed on separate hardware (cloud/edge server) for 3D Visualization and Control Panel"
]

instance LowerLevelChassis : DTDFVocab:Component [
    base:desc "Lower-level chassis of Traxxas Slash 4x4 Premium vehicle hosting steering and speed control actuation components"
]

instance UpperLevelChassis : DTDFVocab:Component [
    base:desc "Upper-level chassis hosting autonomy elements including NVIDIA Jetson Orin Nano, sensors, and communication interfaces"
]

instance ROS2PackageEnvironment : DTDFVocab:Environment [
    base:contains DigitalTwinEntity
]

instance JetsonHardwareEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity, LowerLevelChassis, UpperLevelChassis
]

instance CloudEdgeEnvironment : DTDFVocab:Environment [
    base:contains UserEntity
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT influences the PT through the following outputs: **1) Desired speed commands**: Computed by the **ACC Controlling FE** and sent to the **Actuation FE** in the **Physical Twin Entity**, which converts them into motor voltage commands. **2) Remote management commands**: Includes **enable/disable ACC**, **modify desired speed**, and **emergency braking** via the **Control Panel** (User Entity). **3) Actuation signals**: Transmitted over **ROS2** (for onboard components) and **Wi-Fi** (for remote commands) with **100 ms synchronization accuracy** (clock synchronization)."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates with the following time-scale constraints: **1) Real-time synchronization**: Data collection and actuation must adhere to a **100 ms end-to-end latency** (PT to DT and vice versa) as per **3GPP TS 22.185**. **2) Clock synchronization**: Devices must maintain **100 ms accuracy** for event ordering and coordination. **3) Perception cycle**: Object tracking updates occur at the **LiDAR/camera frame rate** (e.g., 10 Hz for LiDAR). **4) Control loop**: ACC computations are executed at a frequency sufficient to meet the **100 ms latency requirement**, with actuation commands sent in real-time."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation follows an **entity-based architecture** inspired by **ISO 23247**, with the following orchestration: **1) Physical Twin Entity**: Hosts **sensors (LiDAR, camera)**, **actuators (motor, steering servo)**, and **data pre-processing** (e.g., point cloud clustering). **2) Digital Twin Entity**: Executes **ACC logic**, **data collection**, **reporting**, and **data storage** (SQL). **3) User Entity**: Provides **3D Visualization** and **Control Panel** for remote management. **4) Cross-System Entity**: **Data Translation FE** ensures interoperability between entities. **5) Deployment**: Components are distributed across **onboard (Jetson Orin Nano)** and **external (cloud/edge) hardware**. The constellation enables **computation offloading**, **real-time monitoring**, and **remote control** while adhering to **100 ms latency** and **synchronization** constraints."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the following lifecycle stages: **1) Design Phase**: Used as a **cyber-physical experimentation facility** for ACC development, leveraging **3D CAD design** and **simulators** (e.g., **CREO Simulate**). **2) Validation Phase**: Validates compliance with **ISO 15622** (ACC performance class I) and **3GPP latency requirements**. **3) Operation Phase**: Enables **real-time monitoring**, **remote management**, and **predictive maintenance** during vehicle operation. **4) Product Lifecycle Management**: Supports **digital threads** for end-to-end information flow (e.g., data collection for fleet optimization). The DT represents the PT **as operated**, not as designed or manufactured."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through: **1) Real-time data synchronization**: **100 ms latency** and **clock synchronization** for accurate event ordering. **2) Model validation**: **ACC logic** adheres to **ISO 15622** (performance class I). **3) Sensor fusion**: **LiDAR + camera** data is processed via **DBSCAN (clustering)** and **Kalman filtering (tracking)** for high-fidelity object tracks. **4) Verification**: **ROS2 middleware** ensures deterministic communication. **5) Uncertainty management**: **Data Translation FE** handles unit conversions and message alignment to mitigate data inconsistencies. **6) Safety validation**: **Emergency braking** commands override normal operations to ensure safety."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT uses the following technical connections: **1) Onboard Communication**: **ROS2** for inter-node communication (e.g., between **Point Cloud Clustering** and **Actuation**). **2) Inter-Entity Communication**: **Wi-Fi (UDP protocol)** for data exchange between **Physical Twin Entity**, **Digital Twin Entity**, and **User Entity**. **3) Latency Requirements**: **≤100 ms end-to-end** (per **3GPP TS 22.185**). **4) Clock Synchronization**: Devices synchronized to **±100 ms accuracy** for event ordering. **5) Data Serialization**: **Data Translation FE** standardizes message formats and units. **6) Network Architecture**: **Star topology** with the **Digital Twin Entity** as the central hub."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed across the following hosting environments: **1) Onboard Hardware**: **NVIDIA Jetson Orin Nano** (runs **Physical Twin Entity** and **Digital Twin Entity** components). **2) External Hardware**: **Cloud/edge server** hosts **User Entity** (3D Visualization, Control Panel) and **SQL database**. **3) Software Deployment**: Each **Functional Entity (FE)** is implemented as an **independent ROS2 package**, enabling modular upgrades. **4) Middleware**: **ROS2** manages node lifecycle and inter-process communication. **5) Network Deployment**: **Wi-Fi** connects onboard and external components with **≤100 ms latency**."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT enables horizontal integration with external systems through: **1) Data Export**: **Reporting FE** generates **human-readable timeseries reports** for external analysis. **2) Simulator Integration**: Supports **CREO Simulate** for predictive maintenance (e.g., brake systems). **3) Cloud/Edge Connectivity**: **Digital Twin Entity** can interface with **external databases** or **AI agents** via **User Entity**. **4) Standardized Interfaces**: **Data Translation FE** ensures compatibility with external systems using **OPC UA** or custom protocols. **5) Digital Threads**: Enables **end-to-end information flow** for product lifecycle management (PLM)."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership and privacy considerations are not explicitly detailed in the document. However, the system implies: **1) Data Collection**: Vehicle state and sensor data are **collected by the PT owner** (e.g., autonomous vehicle operator). **2) Data Storage**: Stored in an **external SQL database**, raising potential **privacy concerns** if not secured. **3) Remote Management**: **Control Panel** allows remote access, requiring **authentication/authorization** for security. **4) Compliance**: No explicit mention of **GDPR** or **automotive-specific privacy standards** (e.g., **ISO/SAE 21434**)."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT adheres to the following standards: **1) Architectural Standard**: **ISO 23247** (Digital Twin Manufacturing Framework, Part 2) as the reference architecture, with deviations (e.g., **Physical Twin Entity** addition). **2) ACC Standard**: **ISO 15622** for performance class I ACC implementation. **3) Communication Standard**: **ROS2** for middleware and **UDP over Wi-Fi** for inter-entity communication. **4) Latency Standard**: **3GPP TS 22.185** (≤100 ms end-to-end latency for V2V communication). **5) Clock Synchronization**: **±100 ms accuracy** (aligned with hardware limitations). **6) Terminology**: **ISO/IEC 30173:2023** for DT concepts."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety are addressed through: **1) Safety Mechanisms**: **Emergency braking** commands override normal operations to prevent accidents. **2) Latency Guarantees**: **≤100 ms end-to-end** ensures real-time responsiveness. **3) Clock Synchronization**: **±100 ms accuracy** prevents event ordering issues. **4) Remote Management**: **Control Panel** requires secure authentication for **enable/disable ACC** and **emergency braking**. **5) Data Integrity**: **Data Translation FE** validates message formats and units. **6) Hardware Redundancy**: **NVIDIA Jetson Orin Nano** provides compute resources for critical operations. **7) Compliance**: Adheres to **ISO 15622** for ACC safety. **Limitations**: No explicit mention of **cybersecurity protocols** (e.g., encryption, intrusion detection) or **fail-safe mechanisms** for remote operations."
]