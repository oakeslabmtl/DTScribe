// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor that provides raw point‑cloud data for perception."
    DTDFVocab:producedData LiDARDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑state sensors supplying speed, position, and steering angle."
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// C2: Acting components
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Drive motor actuator that receives speed commands for vehicle propulsion."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator that receives steering angle commands."
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
    base:desc "Data transmitted over Wi‑Fi UDP containing raw LiDAR point clouds."
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
    base:desc "Data transmitted over Wi‑Fi UDP containing vehicle speed and steering state."
]

// C10: Data entities
instance LiDARPointCloudData : DTDFVocab:Data [
    DTDFVocab:fromData LiDARDataTransmitted
    base:desc "Raw LiDAR point‑cloud captured from the physical twin."
    DTDFVocab:inputTo DataTranslationFE
]

instance VehicleStateData : DTDFVocab:Data [
    DTDFVocab:fromData VehicleStateDataTransmitted
    base:desc "Vehicle speed and steering angle data sampled from vehicle‑state sensors."
    DTDFVocab:inputTo DataTranslationFE
]

// C10: Models/Data
instance ACCBehavioralModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) behavioral model that determines lead vehicle, computes desired speed based on inter‑vehicle distance, and outputs speed command."
    DTDFVocab:inputTo ACCComputationFE
]

instance ObjectTrackModel : DTDFVocab:Model [
    base:desc "Object‑track model derived from LiDAR point clouds, assigning IDs and state estimates (size, position, velocity) for each detected object."
    DTDFVocab:inputTo PresentationFE
]

instance LiDARClusteringTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering and Kalman‑filter tracking algorithm that transforms raw LiDAR data into clustered object tracks."
    DTDFVocab:inputTo DataCollectionFE
]

// C11: Enablers (Functional Entities)
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that serialises streams, aligns message types and performs unit conversions for every data stream."
    DTDFVocab:enables DataMonitoringService
]

instance LiDARClusteringTrackingFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that implements DBSCAN clustering and Kalman‑filter tracking on LiDAR point clouds."
    DTDFVocab:enables DataMonitoringService
]

instance DataCollectionFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that acquires vehicle state, LiDAR, and ACC data for further processing."
    DTDFVocab:enables DataMonitoringService
]

instance ReportingFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that generates data reports."
    DTDFVocab:enables DataMonitoringService
]

instance PresentationFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that visualises pre‑processed data in a 3D UI."
    DTDFVocab:enables DataMonitoringService
]

instance MotorActuationFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that commands the vehicle’s drive motor."
    DTDFVocab:enables RemoteManagementService
]

instance SteeringServoActuationFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that commands the steering servo."
    DTDFVocab:enables RemoteManagementService
]

instance ACCComputationFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that executes the ACC algorithm on the digital twin and produces desired speed commands."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementFE : DTDFVocab:Enabler [
    base:desc "Functional Entity that enables remote enable/disable of ACC, setting desired speed, and issuing emergency brake commands."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service that displays real‑time vehicle state, projected path, and detected object tracks, and allows users to view, save, and generate reports."
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service that offloads ACC computation to the digital twin and sends back desired speed commands for actuation."
    DTDFVocab:provides ComputeDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service that allows operators to remotely manage ACC, set speed, and issue emergency braking via the UI."
    DTDFVocab:provides RemoteACCControlAction
]

// C17: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time visualization of vehicle state and object tracks."
]

instance ComputeDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action that computes desired vehicle speed based on ACC algorithm and distance to lead vehicle."
    DTDFVocab:IsAutomatic true
]

instance RemoteACCControlAction : DTDFVocab:Action [
    base:desc "Action that remotely enables/disables ACC, sets speed, or triggers emergency brake."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin generates control commands (ACC desired speed, enable/disable ACC, emergency‑brake request, and modified speed set‑points) through the Controlling FE (ACC) and sends them over the same Wi‑Fi UDP channel. Commands are formatted by the Data Translation FE (serialization, message type alignment, unit conversion) and received by the Actuation FE on the physical twin, which converts the desired speed into motor voltage commands and activates the steering and brake actuators. Remote‑management commands issued from the UI Control Panel are also routed through the Data Translation FE before execution on the vehicle. Execution confirmation is provided by the vehicle state feedback loop back to the DT."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Clock synchronization between the vehicle and the digital twin must achieve 100 ms accuracy, as required by hardware limitations and safety‑critical vehicular standards. Real‑time services (Data Monitoring, Computation Offloading, Remote Management) rely on low end‑to‑end latency communication, though the exact latency bound is not quantified. Temporal granularity includes continuous vehicle state updates, real‑time LiDAR point‑cloud processing, and rapid actuation feedback via ROS2 nodes."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system adopts the ISO‑23247 entity‑based reference architecture, extended by a Physical Twin Entity. Each Functional Entity is implemented as a distinct ROS2 package containing one or more ROS2 nodes. Intra‑entity communication uses ROS2 publish/subscribe; inter‑entity communication employs Wi‑Fi with UDP transport. Core services (Data Monitoring, Computation Offloading, Remote Management) are composed of Data Translation FE and other FEs, with resource management achieved by mapping FEs to specific compute hardware across the three entities."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is governed by safety‑critical latency requirements; the system mandates a maximum clock‑synchronisation error of 100 ms to ensure timely ACC computation and actuation. The Data Translation FE ensures unit consistency and message alignment, contributing to data validity. Real‑time visualisation of vehicle state, projected path, and object tracks, together with generated reports, serve as verification artefacts. No explicit uncertainty quantification or formal validation procedures are described in the provided documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS uses a hybrid network architecture: intra‑entity software components communicate via a ROS2 middleware layer, while inter‑entity communication (Physical Twin ↔ Digital Twin ↔ User Entity) occurs over a Wi‑Fi network using UDP at the transport layer. The system requires clock synchronisation with ≤ 100 ms accuracy. Low end‑to‑end latency is a design goal to support safety‑critical ACC functions, though exact latency numbers are not specified. Reliability is supported by ROS2’s QoS settings and the use of UDP; security mechanisms are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "dt_hosting_deployment"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external components is realized through ROS2 middleware for internal component interaction and UDP over Wi‑Fi for vehicle‑to‑twin data exchange. The Data Translation FE handles serialization, message type alignment, and unit conversion. While OPC UA is cited as an example protocol for implementing Data Translation, it is not used in this deployment. No direct interfaces to enterprise systems are described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built on the ISO 23247‑2 reference architecture for digital twins, adopting its entity‑based structure (Data Collection and Device Control Entity, Digital Twin Entity, User Entity). It leverages OPC Unified Architecture (OPC UA, IEC 62541) for data translation, and ROS 2 as the middleware for implementing functional entities. The authors argue that ISO 23247 alone is insufficient for safety‑critical automotive applications and recommend integrating ISO 26262 safety processes and AUTOSAR for automotive software architecture. Interoperability with other standards is intended through domain‑agnostic design and use of widely adopted protocols."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The case study notes that the ISO 23247 reference architecture (RA) is inadequate for safety‑critical automotive digital twins and therefore safety must be treated as a first‑class concern. It recommends incorporating the functional‑safety standard ISO 26262 into the DT, using its hazard analysis, risk‑assessment, safety‑case, and SIL allocation procedures for critical functions such as Adaptive Cruise Control (implemented per ISO 15622). Consequently, safety‑critical components should be designed with ISO 26262‑compliant fail‑safe mechanisms, redundancy, and verification activities. Although security issues are highlighted as important, the documents do not provide specific cybersecurity protocols, authentication, or access‑control measures."
]