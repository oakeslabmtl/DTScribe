// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR sensor providing 3D point cloud data for environment perception"
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera capturing RGB-D data for object detection and scene understanding"
    DTDFVocab:producedData DepthCameraData
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor derived from chassis providing real-time ego-vehicle velocity measurements"
    DTDFVocab:producedData EgoVehicleSpeedData
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring the current steering wheel position and angle"
    DTDFVocab:producedData SteeringAngleData
]

// C4: Physical-to-Virtual Interaction
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
    base:desc "LiDAR point cloud data transmitted in real-time over Wi-Fi using ROS2 topics with 100ms latency"
]

instance DepthCameraData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
    base:desc "Depth camera RGB-D data transmitted in real-time over Wi-Fi using ROS2 topics with 100ms latency"
]

instance EgoVehicleSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
    base:desc "Ego-vehicle speed data transmitted in real-time over Wi-Fi using ROS2 topics with 100ms latency"
]

instance SteeringAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
    base:desc "Steering angle data transmitted in real-time over Wi-Fi using ROS2 topics with 100ms latency"
]

instance DerivedObjectTracks : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera, HokuyoUST10LXLiDAR
    base:desc "Derived object tracks computed from sensor fusion (LiDAR + depth camera) transmitted over Wi-Fi using ROS2 topics with 100ms latency"
]

// C10: Models and Data
instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) model implementing lead-vehicle detection and speed set-point computation per ISO 15622 standard"
    DTDFVocab:inputTo ROS2Middleware
]

instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN-based point cloud clustering model for object segmentation in LiDAR data"
    DTDFVocab:inputTo ROS2Middleware
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter-based tracking model for maintaining consistent object trajectories across time"
    DTDFVocab:inputTo ROS2Middleware
]

instance ThreeDVisualizationModel : DTDFVocab:Model [
    base:desc "3D visualization model rendering vehicle and environment using sensor data and object tracks"
    DTDFVocab:inputTo ROS2Middleware
]

instance VehicleStateTimeSeries : DTDFVocab:Data [
    base:desc "Time-series database storing vehicle state (speed, steering, timestamps) in SQL format"
    DTDFVocab:fromData EgoVehicleSpeedData, SteeringAngleData
    DTDFVocab:inputTo ROS2Middleware
]

instance ObjectTracksTimeSeries : DTDFVocab:Data [
    base:desc "Time-series database storing object tracks (positions, velocities, IDs) in SQL format"
    DTDFVocab:fromData DerivedObjectTracks
    DTDFVocab:inputTo ROS2Middleware
]

instance GeneratedReports : DTDFVocab:Data [
    base:desc "Structured reports generated from vehicle state and object track analysis for performance evaluation"
    DTDFVocab:fromData VehicleStateTimeSeries, ObjectTracksTimeSeries
    DTDFVocab:inputTo ROS2Middleware
]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware facilitating real-time communication between physical and digital twin components with message serialization and unit conversion"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, ThreeDVisualizationService, ReportingService
]

instance NVIDIAJetPack50SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK enabling GPU-accelerated perception and control algorithms on Jetson hardware"
]

instance Python38Runtime : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime environment executing application modules and data processing pipelines"
]

instance CppRuntime : DTDFVocab:Enabler [
    base:desc "C++ runtime environment for performance-critical components like sensor drivers and control loops"
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for model-based design and algorithm prototyping"
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time UI visualization service displaying speed, steering angle, object tracks, and projected path"
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTrackVisualizationInsight, ProjectedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service executing ACC algorithm in the digital twin to offload computation from the physical vehicle"
    DTDFVocab:provides ACCControlAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service enabling remote enable/disable of ACC, speed adjustment, and emergency brake triggering"
    DTDFVocab:provides ACCEnableDisableAction, SpeedAdjustmentAction, EmergencyBrakeAction
]

instance ThreeDVisualizationService : DTDFVocab:Service [
    base:desc "Service providing 3D visualization of the vehicle and environment using sensor data"
    DTDFVocab:provides EnvironmentVisualizationInsight
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Service generating performance reports from vehicle state and object track data"
    DTDFVocab:provides PerformanceReportInsight
]

// C17: Insights and Actions
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real-time display of ego-vehicle speed and steering angle for operator awareness"
]

instance ObjectTrackVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of detected and tracked objects with bounding boxes and IDs"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projection of future vehicle path based on current state and ACC control inputs"
]

instance EnvironmentVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization of the vehicle and surrounding environment using sensor fusion"
]

instance PerformanceReportInsight : DTDFVocab:Insight [
    base:desc "Generated reports analyzing vehicle performance, object tracking accuracy, and ACC behavior"
]

instance ACCControlAction : DTDFVocab:Action [
    base:desc "Automatic computation of speed set-points for ACC based on lead vehicle detection"
    DTDFVocab:IsAutomatic true
]

instance ACCEnableDisableAction : DTDFVocab:Action [
    base:desc "Remote enable/disable of the ACC system"
    DTDFVocab:IsAutomatic false
]

instance SpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjustment of the desired speed set-point for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Triggering of emergency braking when obstacles are detected"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller receiving voltage commands to actuate vehicle motors"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator receiving angle commands to control vehicle steering"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency braking system receiving commands to apply brakes when required"
]

// C1: System Under Study
instance AutonomousVehiclePhysicalTwin : DTDFVocab:Component [
    base:desc "1/10-scale autonomous vehicle built from Traxxas Slash 4x4 chassis retrofitted with NVIDIA Jetson NX antenna and Jetson Orin Nano microcomputer"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital twin entity deployed on external edge/cloud compute hosting the ACC control model and visualization services"
]

instance UserWorkstationEntity : DTDFVocab:Component [
    base:desc "User entity deployed on a workstation providing remote monitoring and management interfaces"
]

// C1: System Under Study (continued)
instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:desc "Physical environment containing the autonomous vehicle with all sensing and acting components"
    base:contains AutonomousVehiclePhysicalTwin, HokuyoUST10LXLiDAR, IntelRealSenseD435iDepthCamera,
                 VehicleSpeedSensor, SteeringAngleSensor, VedderElectronicSpeedController,
                 SteeringServoActuator, EmergencyBrakeActuator
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:desc "Digital twin environment containing all virtual models and services"
    base:contains DigitalTwinEntity, ACCControlModel, PointCloudClusteringModel, KalmanFilterTrackingModel,
                 ThreeDVisualizationModel, VehicleStateTimeSeries, ObjectTracksTimeSeries, GeneratedReports,
                 DataMonitoringService, ComputationOffloadingService, RemoteManagementService,
                 ThreeDVisualizationService, ReportingService
]

instance UserWorkstationEnvironment : DTDFVocab:Environment [
    base:desc "User workstation environment providing monitoring and management interfaces"
    base:contains UserWorkstationEntity
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends desired speed set‑points, ACC enable/disable commands, desired speed adjustments, and emergency‑brake commands to the PT; an Actuation functional entity converts these into motor voltage or servo commands transmitted over the same Wi‑Fi/ROS2 link."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with an end‑to‑end communication latency requirement of ≤ 100 ms and clock‑synchronization accuracy of 100 ms; sensor data are captured at the perception‑cycle rate of the autonomous vehicle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Entity‑based architecture derived from ISO 23247 consisting of a Physical Twin Entity (sensors and actuators), a Digital Twin Entity (data collection, ACC, reporting, visualization pre‑processing), a User Entity (3D visualization and control panel UI), and a cross‑system Data Translation entity; inter‑entity communication occurs over Wi‑Fi using ROS2."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Development (requirements capture R1‑R8, ROS2 package implementation), deployment, and operational runtime (monitoring, remote management) of the DT, supporting the operational stage of the physical twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity sensor data (LiDAR, depth camera) mirrored in the DT; temporal fidelity ensured by ≤ 100 ms latency and clock sync; ACC algorithm conforms to ISO 15622; no explicit V&V methodology described beyond these constraints."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Wi‑Fi network carrying ROS2 messages; Data Translation functional entity handles serialization, message type alignment and unit conversion; a standardized communication interface is mandated (R1); OPC UA is noted as a possible alternative but not employed."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the Jetson Orin Nano mounted on the vehicle; Digital Twin Entity components are hosted on external edge or cloud compute reachable via Wi‑Fi; User Entity UI runs on a workstation; each functional entity is packaged as a ROS2 node."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture, ISO 15622 functional specification for ACC, ISO/IEC 30173 digital‑twin terminology, IEC 62541 OPC UA (mentioned as optional), ROS2 as an open‑source middleware standard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical ACC implemented per ISO 15622; latency ≤ 100 ms and clock sync ≤ 100 ms enforced to maintain safe operation; remote commands (ACC enable/disable, emergency brake) designed with a human‑in‑the‑loop; no explicit cybersecurity mechanisms detailed."
]