// C3: Physical sensing components
instance HokuyoLidar10LX_Sensing : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR for 3D point‑cloud perception"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDeepSenseD435i_Sensing : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera for RGB‑D imaging"
    DTDFVocab:producedData DepthCameraRGBDTransmitted
]

instance ESCspeedAngle_Sensing : DTDFVocab:SensingComponent [
    base:desc "Electronic Speed Controller embedded speed and steering‑angle sensors"
    DTDFVocab:producedData SpeedSteeringTransmitted
]

// C4: Physical‑to‑virtual interaction (data transmitted over Wi‑Fi)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLidar10LX_Sensing
]

instance DepthCameraRGBDTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435i_Sensing
]

instance SpeedSteeringTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ESCspeedAngle_Sensing
]

// C5: Data instances
instance LiDARPointCloud : DTDFVocab:Data [
    base:desc "LiDAR point‑cloud from Hokuyo UST‑10LX"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ROS2Messaging, PythonDataProcessor
]

instance DepthCameraRGBDFrame : DTDFVocab:Data [
    base:desc "RGB‑D frames from Intel DeepSense D435i"
    DTDFVocab:fromData DepthCameraRGBDTransmitted
    DTDFVocab:inputTo ROS2Messaging, MATLABSimulink
]

instance VehicleSpeedSteering : DTDFVocab:Data [
    base:desc "Real‑time vehicle speed and steering‑angle telemetry"
    DTDFVocab:fromData SpeedSteeringTransmitted
    DTDFVocab:inputTo ROS2Messaging, CppVehicleController
]

// C10: Models/Data (core models)
instance DBSCANPointCloudClusterer : DTDFVocab:Model [
    base:desc "DBSCAN‑based point‑cloud clustering module"
    DTDFVocab:inputTo PythonDataProcessor
]

instance KalmanObjectTracker : DTDFVocab:Model [
    base:desc "Kalman filter tracker producing object tracks"
    DTDFVocab:inputTo PythonDataProcessor
]

instance ACCControlUnit : DTDFVocab:Model [
    base:desc "ACC controller implementing ISO‑15622 P‑class I logic mapping to desired speed"
    DTDFVocab:inputTo CloudACCOffload
]

instance DataLogger : DTDFVocab:Model [
    base:desc "Data logging component storing vehicle state and object tracks in SQL database"
    DTDFVocab:inputTo PythonDataProcessor, SQLDatabase
]

// C11: Enablers
instance ROS2Messaging : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware for message passing over Wi‑Fi between vehicle, edge server, and user workstation"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance PythonDataProcessor : DTDFVocab:Enabler [
    base:desc "Python 3.8 environment executing ROS 2 nodes and data transformations"
    DTDFVocab:enables DataMonitoringService, ReportGenerationService
]

instance CppVehicleController : DTDFVocab:Enabler [
    base:desc "C++ implementation of low‑level vehicle command generation for electric motor and steering servo"
    DTDFVocab:enables RemoteManagementService, EmergencyBrakingService
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink used for advanced point‑cloud clustering and tracking"
    DTDFVocab:enables VisualizationService
]

instance JetpackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for Jetson Orin Nano programming"
    /* removed enables ACCControlUnit to avoid type conflict */
]

instance CloudACCOffload : DTDFVocab:Enabler [
    base:desc "Cloud compute resources for ACC offloading"
    DTDFVocab:enables ComputationOffloadingService
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "External SQL database for time‑series logging of vehicle state and object tracks"
    DTDFVocab:enables ReportGenerationService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time display, storage, and reporting of vehicle state and object tracks"
    DTDFVocab:provides InsightPerformanceEvaluation, InsightSpeedDecision, ReportGenerationAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Delegation of the ACC decision loop to DT hardware"
    DTDFVocab:provides InsightACCPerformance, ActionEnableACC, ActionDisableACC
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote enabling/disabling of ACC, manual desired speed setting, emergency‑brake commands"
    DTDFVocab:provides ActionSetDesiredSpeed, ActionEmergencyBrake
]

instance EmergencyBrakingService : DTDFVocab:Service [
    base:desc "Emergency braking command execution"
    DTDFVocab:provides ActionEmergencyBrake
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D rendering of the vehicle, environment, and projected path"
    DTDFVocab:provides InsightVisualization
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Time‑series SQL export of tracked data for analysis"
    DTDFVocab:provides ReportGenerationAction
]

// C17: Insights
instance InsightPerformanceEvaluation : DTDFVocab:Insight [
    base:desc "Evaluation of ACC performance using historical SQL‑based vehicle state and object tracks"
]

instance InsightSpeedDecision : DTDFVocab:Insight [
    base:desc "Decision support for choosing speed set‑points based on ACC logic"
]

instance InsightACCPerformance : DTDFVocab:Insight [
    base:desc "Insight into latency and correctness of ACC decision outputs"
]

instance InsightVisualization : DTDFVocab:Insight [
    base:desc "Visual representation of vehicle and environment for analysis"
]

// C17: Actions
instance ActionEnableACC : DTDFVocab:Action [
    base:desc "Automatically enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic true
]

instance ActionDisableACC : DTDFVocab:Action [
    base:desc "Automatically disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic true
]

instance ActionSetDesiredSpeed : DTDFVocab:Action [
    base:desc "Manually set desired speed via remote management"
    DTDFVocab:IsAutomatic false
]

instance ActionEmergencyBrake : DTDFVocab:Action [
    base:desc "Issue emergency brake command from remote management"
    DTDFVocab:IsAutomatic false
]

instance ActionTuneParameters : DTDFVocab:Action [
    base:desc "Tune vehicle or ACC parameters based on insights"
    DTDFVocab:IsAutomatic false
]

instance ReportGenerationAction : DTDFVocab:Action [
    base:desc "Generate time‑series SQL export of tracked data"
    DTDFVocab:IsAutomatic false
]

// C1: Physical Twin Entity
instance VehiclePhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical twin running on the Traxxas vehicle hardware"
]

// C1: Digital Twin Entity
instance DigitalTwinServerEntity : DTDFVocab:Component [
    base:desc "Digital twin server running on NVIDIA Jetson Orin Nano"
]

// C1: User Entity
instance UserWorkstationEntity : DTDFVocab:Component [
    base:desc "User workstation for monitoring, control, and visualization"
]

// C14: Environment
instance AutonomousVehicleEnvironment : DTDFVocab:Environment [
    base:contains VehiclePhysicalTwinEntity, DigitalTwinServerEntity, UserWorkstationEntity
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT’s Control FE computes desired speeds and emergency‑braking commands and publishes them on ROS2 topics that are received by the Vehicle Actuation FE; the FE converts these commands into motor‑voltage and steering‑angle signals that are dispatched over the same Wi‑Fi link to the vehicle’s motor driver and steering servo for actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in near‑real‑time with end‑to‑end communication latency capped at 100 ms (R7) and all system clocks synchronized within 100 ms (R8), thereby enabling timely ACC computations and control actions that honor automotive safety‑critical timing constraints."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates the Physical Twin, Digital Twin, and User entities as functional entities (FEs) mapped to specific ROS2 packages, linked via ROS2 DDS topics over Wi‑Fi; an inter‑entity Data Translation FE serializes and converts units, while the User interface is split into 3D visualization and control‑panel FEs; all components collaborate to provide monitoring, control, and reporting services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin focuses on the Operated lifecycle stage: it monitors, controls, and reports on a running vehicle; the holistic digital thread (design → manufacturing → operation) is implied, but the current implementation primarily covers the Operated phase through real‑time data acquisition and control."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured through real‑time sensor fusion, DBSCAN clustering accuracy, Kalman‑filter state estimation, and compliance with ISO 15622 ACC control logic; validation of safety‑critical timings is performed by measuring end‑to‑end latency (≤ 100 ms) and ensuring clock synchronization within 100 ms as required by R7 and R8; however, explicit formal verification procedures are not detailed in the document."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The vehicle and DT components communicate over a Wi‑Fi network using ROS 2 transport. ROS 2 nodes publish and subscribe to topics across entities; the Data Translation FE serialises the payloads. Between entities, inter‑entity communication is performed via the Wi‑Fi network, while intra‑entity micro‑services communicate locally on the same compute node."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin runs on an edge or cloud platform (e.g., local server) that processes ACC decisions and hosts the ROS2 middleware; the vehicle hosts the Physical Twin Entity on an NVIDIA Jetson Orin Nano, while the user interface runs on a separate workstation; all components are containerized or packaged as ROS2 nodes and deployed via launch files on their respective hardware."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to ISO 23247 reference architecture (entity‑based, functional‑entity mapping), ISO 15622 P‑class I ACC control logic, and ROS2 DDS middleware; optional OPC UA considered for data translation but not implemented."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The system satisfies safety requirements by enforcing a maximum 100 ms latency and 100 ms clock synchronisation, providing human‑in‑the‑loop functionality, and performing real‑time status monitoring. No specific authentication or encryption mechanisms are detailed in the provided document, but the low‑latency, time‑synchronised operations are addressed as safety critical. The DT operates on a human‑controlled vehicle, ensuring that remote commands are moderated through safe‐state transitions and emergency braking controls."
]