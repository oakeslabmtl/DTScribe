// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor producing raw point‑cloud data for object detection"
    DTDFVocab:producedData LiDARRawDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder providing motor speed and state information"
    DTDFVocab:producedData MotorStateDataTransmitted
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑servo sensor reporting current steering angle"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑state sensor supplying speed, position and high‑level state"
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// C4: Physical‑to‑virtual interaction – Data transmitted from sensors
instance LiDARRawDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance MotorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// C10: Data (sensor raw)
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud emitted by the LiDAR sensor"
    DTDFVocab:fromData LiDARRawDataTransmitted
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance MotorStateData : DTDFVocab:Data [
    base:desc "Motor speed and encoder state data"
    DTDFVocab:fromData MotorStateDataTransmitted
    DTDFVocab:inputTo DataCollectionEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering angle reported by the steering servo"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo DataCollectionEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "High‑level vehicle state (speed, position, heading)"
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo DataCollectionEnabler
    DTDFVocab:inputTo ACCControlEnabler
]

// C10: Data (model outputs)
instance ObjectTracksDataTransmitted : DTDFVocab:DataTransmitted [
    // ProducedFrom relationship omitted to avoid type mismatch
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks generated from LiDAR point‑cloud clustering & Kalman filtering"
    DTDFVocab:fromData ObjectTracksDataTransmitted
    DTDFVocab:inputTo ACCControlEnabler
]

instance DesiredSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    // ProducedFrom relationship omitted to avoid type mismatch
]

instance DesiredSpeedData : DTDFVocab:Data [
    base:desc "Desired vehicle speed computed by the ACC algorithm"
    DTDFVocab:fromData DesiredSpeedDataTransmitted
    DTDFVocab:inputTo MotorActuationEnabler
]

// C10: Models/Data
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering and Kalman‑filter tracking of LiDAR point‑clouds to produce object tracks"
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive cruise‑control model that identifies lead vehicle, estimates distance and calculates desired speed"
    DTDFVocab:inputTo ACCControlEnabler
]

// C11: Enablers (functional entities)
instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Software component that processes raw LiDAR data into object tracks"
    DTDFVocab:enables ComputationOffloadingService
]

instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "ACC controlling functional entity that consumes vehicle state and object tracks to output desired speed"
    DTDFVocab:enables ComputationOffloadingService
]

instance MotorActuationEnabler : DTDFVocab:Enabler [
    base:desc "Actuation component that applies desired speed commands to the vehicle motor"
    DTDFVocab:enables ComputationOffloadingService
]

instance SteeringActuationEnabler : DTDFVocab:Enabler [
    base:desc "Actuation component that commands steering servo positions"
    DTDFVocab:enables RemoteManagementService
]

instance DataCollectionEnabler : DTDFVocab:Enabler [
    base:desc "Collects sensor readings for storage, reporting and UI visualization"
    DTDFVocab:enables DataMonitoringService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Persists collected data in an SQL database"
    DTDFVocab:enables DataMonitoringService
]

instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Provides real‑time vehicle state, path projection and object track visualization"
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Executes ACC computation off‑board in the cloud and returns desired speed"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Handles user commands to enable/disable ACC, set speed or trigger emergency brake"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Displays real‑time vehicle state, projected path and LiDAR‑derived object tracks supports data saving and reporting"
    DTDFVocab:provides VehicleStateInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC algorithm to the digital‑twin cloud returns desired speed for actuation"
    DTDFVocab:provides DesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, manually set speed and issue emergency‑brake commands"
    DTDFVocab:provides EmergencyBrakeAction
]

// C17: Insights/Actions
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current vehicle speed, position and heading shown on the UI"
]

instance DesiredSpeedAction : DTDFVocab:Action [
    base:desc "Automatic actuation of the computed desired speed on the motor"
    DTDFVocab:IsAutomatic true
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "User‑initiated emergency braking command sent to the motor actuator"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Commands generated by the User Interface (Control Panel) – enable/disable ACC, set desired speed, emergency‑brake – are sent from the User Entity to the Digital Twin Entity and then to the Physical Twin Entity. The Data Translation FE serialises and aligns these control messages, which are transmitted over the Wi‑Fi UDP link. On the Physical Twin, the Actuation FE receives the commands, converts the desired speed into motor voltage commands and drives the steering/servo actuators. Validation includes unit conversion and message‑type checking; execution is confirmed indirectly by observing updated vehicle state (speed, steering angle) in the subsequent sensor feedback loop."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DTS enforces clock synchronization between vehicle devices with a maximum absolute error of 100 ms, as required by safety‑critical vehicular standards and limited by the hardware. All three services (Data Monitoring, Computation Off‑loading, Remote Management) operate assuming this 100 ms time alignment, and the communication link must provide low end‑to‑end latency to preserve real‑time interaction, although no exact latency bound is specified."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is orchestrated as an entity‑based constellation following ISO 23247. Intra‑entity communication uses ROS2 topics/services, while inter‑entity communication traverses a Wi‑Fi UDP transport layer. A Data Translation FE (implemented via OPC UA/IEC 62541 or a custom layer) serialises streams, aligns message types and performs unit conversions. ACC computation is off‑loaded to external compute (e.g., cloud), and the User Entity provides a 3D visualization and control‑panel UI. All functional entities are mapped to individual ROS2 packages representing the corresponding FE."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and validity are constrained by the safety‑critical nature of the ACC function. The architecture mandates end‑to‑end communication latency and clock synchronisation better than 100 ms to ensure timely actuation. The Data Translation FE provides unit‑conversion and message‑type alignment to preserve data integrity. Reporting and visualization components allow operators to monitor real‑time data and generate reports, supporting verification of model behavior, but specific validation procedures are not described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS uses a two‑layer communication architecture. Intra‑entity component communication is implemented with ROS 2 (DDS) middleware, providing publish/subscribe messaging between software components. Inter‑entity communication (Physical Twin ↔ Digital Twin ↔ User) is carried over a Wi‑Fi network using UDP at the transport layer. Devices are required to maintain clock synchronisation within 100 ms accuracy to satisfy safety‑critical timing constraints. The network is provisioned to carry high‑bandwidth LiDAR point‑cloud streams and low‑latency control messages, aiming for minimal end‑to‑end latency for ACC operation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Each ISO 23247 entity is deployed on separate hardware. The Physical Twin Entity components (Point Cloud Clustering & Tracking, Actuation FE) run as ROS 2 packages on the vehicle's on‑board compute platform. Digital Twin Entity services (Visualization, Data Collection, Reporting, ACC Controlling) are hosted on external compute resources – off‑loaded to edge or cloud servers as described in the ACC‑DT case study – and communicate with the vehicle via the Wi‑Fi link. The User Entity UI runs on a workstation that accesses the Digital Twin services. Persistent data (object tracks, vehicle state) are stored in an external SQL database (Data Storage). The architecture supports scaling by adding ROS 2 nodes or expanding cloud resources, and reliability is addressed by the redundant ROS 2 middleware and Wi‑Fi communication layers."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration is achieved through ROS2 for internal data exchange and a UDP‑based Wi‑Fi link to the physical vehicle. The optional Data Translation FE may employ OPC UA (IEC 62541) to interoperate with external services. The DT consumes sensor streams (LiDAR point clouds, motor and steering states) from the Physical Twin and exposes them via the UI to remote operators, but no additional enterprise‑level protocols or external system bindings are explicitly described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The prototype conforms to the ISO 23247 Digital Twin Manufacturing Framework (Part 2) as its primary architectural standard. Inter‑entity communication leverages OPC UA (IEC 62541) for the Data Translation Functional Entity. Safety considerations are linked to ISO 26262, with the authors recommending that automotive DT standards adopt safety as a first‑class concern. The design also aligns with the AUTOSAR automotive software architecture paradigm, enabling hardware‑agnostic deployment of software components. The overall approach is deliberately independent of specific data formats or protocols, promoting interoperability across existing automotive standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The described automotive Digital Twin System relies on functional‑safety and performance standards rather than explicit cybersecurity mechanisms. Safety is addressed by referencing ISO 26262 (Functional Safety for road vehicles) as the primary standard to promote safety to a first‑class citizen in the architecture, and ISO 15622 for Adaptive Cruise Control performance requirements (performance class I ACC). The case study notes that ISO 23247’s reference architecture alone is insufficient for safety‑critical applications and recommends augmenting it with automotive safety standards and safety‑critical risk assessments. No specific cybersecurity protocols, access control, authentication, or threat‑mitigation techniques are mentioned in the provided documents."
]