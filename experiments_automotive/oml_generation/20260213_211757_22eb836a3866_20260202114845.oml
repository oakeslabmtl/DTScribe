// Entities

instance PhysicalTwinComponent : DTDFVocab:Component [
    base:desc "Physical Twin on the 1/10‑Scale Traxxas Slash 4x4 platform, interfacing with LiDAR, depth camera, speed and steering sensors, and actuating motor and steering servos."
]

instance DigitalTwinComponent : DTDFVocab:Component [
    base:desc "Digital Twin on an edge server running ROS2, responsible for sensor data processing, ACC decision logic offloading, and data monitoring."
]

instance UserComponent : DTDFVocab:Component [
    base:desc "Remote User Interface client communicating over Wi‑Fi via ROS2, allowing operators to monitor state, visualize trajectories, and issue ACC control actions."
]

// Acting components

instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Voltage command actuator for the drive motor controlled by the DT."
]

instance SteeringActuator : DTDFVocab:ActingComponent [
    base:desc "Servo actuator for vehicle steering controlled by the DT."
]

// Physical sensing components

instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR providing real‑time point‑cloud data at 10 Hz."
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera capturing RGB‑D frames at 30 Hz."
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor on the PT reporting wheel speed at 20 Hz."
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor on the PT reporting steering angle at 20 Hz."
    DTDFVocab:producedData SteeringAngleTransmitted
]

// Data transmitted from PT to DT

instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
    DTDFVocab:producedFrom LiDARSensor
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCameraSensor
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Virtual data stored in the DT

instance LiDARPointCloud : DTDFVocab:Data [
    base:desc "Processed point cloud representing the vehicle environment, stored for clustering and tracking."
    DTDFVocab:fromData LiDARPointCloudTransmitted
]

instance DepthImage : DTDFVocab:Data [
    base:desc "Processed depth image for feature extraction."
    DTDFVocab:fromData DepthImageTransmitted
]

instance VehicleSpeed : DTDFVocab:Data [
    base:desc "Vehicle speed state used for ACC logic."
    DTDFVocab:fromData VehicleSpeedTransmitted
]

instance SteeringAngle : DTDFVocab:Data [
    base:desc "Vehicle heading state used for ACC logic."
    DTDFVocab:fromData SteeringAngleTransmitted
]

// Enablers

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware over Wi‑Fi facilitating DDS communication between Physical Twin and Digital Twin."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteACCManagementService
]

instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler aggregating DBSCAN clustering and Kalman filtering of the LiDAR point cloud."
    DTDFVocab:enables DataMonitoringService
]

instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler executing the controlled ACC model following ISO 15622."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Data translation enabler aligning units and message formats for remote ACC management."
    DTDFVocab:enables RemoteACCManagementService
]

// Models

instance PointCloudTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering followed by Kalman filtering to generate object tracks from LiDAR point clouds."
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Model of ACC decision logic compliant with ISO 15622, producing acceleration and brake commands."
    DTDFVocab:inputTo ACCControlEnabler
]

instance ThreeDVisualizationModel : DTDFVocab:Model [
    base:desc "3D rendering model for real‑time vehicle state and predicted path visualization."
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance TimeSeriesReportingModel : DTDFVocab:Model [
    base:desc "Model generating time‑series reports of vehicle state for predictive maintenance."
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

// Services

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI and reporting service displaying vehicle state, projected path, and object tracks."
    DTDFVocab:provides ACCParameterAdjustmentInsight, ACCTroubleshootInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation offloading service executing ACC logic on the edge server."
    DTDFVocab:provides EnableACCAction, DisableACCAction, ModifyDesiredSpeedAction, EmergencyBrakeAction
]

instance RemoteACCManagementService : DTDFVocab:Service [
    base:desc "Service allowing remote enable/disable of ACC, modify desired speed, and trigger emergency brake."
    DTDFVocab:provides EnableACCAction, DisableACCAction, ModifyDesiredSpeedAction, EmergencyBrakeAction
]

// Insights

instance ACCParameterAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Alerts operators that ACC parameters can be adjusted based on real‑time vehicle state."
]

instance ACCTroubleshootInsight : DTDFVocab:Insight [
    base:desc "Logs detailed data for developers to troubleshoot and fine‑tune the ACC system."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Provides predictive maintenance recommendations derived from offline time‑series analysis."
]

// Actions

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable the ACC system on the vehicle."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable the ACC system on the vehicle."
    DTDFVocab:IsAutomatic false
]

instance ModifyDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Modify the desired speed parameter of the ACC system."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Trigger an emergency brake on the vehicle."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT issues desired‑speed commands and steering‐force commands (via motor voltage and steering servo control) back to the PT, and remote control signals such as enable/disable ACC, set desired speed, and emit emergency braking via ROS2 messages."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with a maximum end‑to‑end latency of 100 ms from PT to DT, and clock synchronization accuracy of 100 ms across all devices; all DT services (ACC logic, UI updates, reporting) operate within this sub‑100 ms time scale."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An ISO 23247 entity‑based constellation where Sensor/actuator interfaces form the Physical Twin Entity, data collection, processing, ACC logic, and reporting form the Digital Twin Entity, and a 3D visualization plus control‑panel UI compose the User Entity; all FEs are deployed across vehicle hardware, edge server, and remote UI, communicating via ROS2 over Wi‑Fi, with a Cross‑System Data Translation FE bridging formats."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design and requirements definition (R1–R8), development and implementation (ROS2 packages, mapping to ISO 23247 FEs), validation and testing (low‑latency compliance, safety‑critical ACC behavior meeting ISO 15622), operation and remote management, and ongoing maintenance/upgrades (e.g., decompose User Interface FE, extend to other ADAS)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "ACC logic constrained by ISO 15622 (performance class I), real‑time latency requirement of ≤100 ms, clock synchronization within 100 ms, validation of sensor fusion accuracy, and unit‑conversion via Data Translation FE to ensure consistency, with implicit V&V implied through compliance with ISO standards."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The PT communicates with the DT over a Wi‑Fi (802.11) link; inter‑entity communication uses ROS 2 which employs DDS over UDP/TCP; the data‑translation FE serializes messages into ROS 2 topics; the DT hosts ROS 2 nodes on a remote server or local PC."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity runs on an external server/cloud platform (or local PC) connected via Wi‑Fi; ROS 2 nodes manage data collection, ACC computation, and UI; the Physical Twin Entity runs on the vehicle’s Jetson Orin Nano."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 RA (entity‑based RA for DT) and incorporates ISO 15622 for ACC control logic; software follows ROS 2 standards; use of OPC UA not implemented but possible."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "DT handles safety‑critical ACC logic with 100 ms latency; actors can remotely execute operations (ACC enable/disable) and emergency braking; safety compliance guided by ISO 15622 and ISO 23247; no explicit cybersecurity mechanisms described, but low‑latency and safety constraints emphasized."
]