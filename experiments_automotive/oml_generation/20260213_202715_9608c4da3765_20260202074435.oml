// Sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR sensor generating 10 Hz point‑clouds with 32k points each"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance DepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera capturing 30 Hz RGB‑D frames at 1920×1080 resolution"
    DTDFVocab:producedData DepthImageTransmitted
]

instance WheelSpeedEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel‑speed encoders providing vehicle speed samples at 100 Hz"
    DTDFVocab:producedData WheelSpeedSampleTransmitted
]

instance SteeringAnglePotentiometerSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle potentiometer reporting steering angle at 100 Hz"
    DTDFVocab:producedData SteeringAngleSampleTransmitted
]

instance CANBusSensor : DTDFVocab:SensingComponent [
    base:desc "CAN‑bus interface transmitting vehicle telemetry (speed, torque, etc.)"
    DTDFVocab:producedData VehicleTelemetryTransmitted
]

// Derived processing FE as a sensing component for tracking outputs
instance TrackingFE : DTDFVocab:SensingComponent [
    base:desc "Point‑cloud clustering (DBSCAN) and Kalman‑filter tracking FE producing object‑track vectors"
    DTDFVocab:producedData ObjectTrackVectorTransmitted
]

// DataTransmitted instances
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DepthCameraSensor
]

instance WheelSpeedSampleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedEncoderSensor
]

instance SteeringAngleSampleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAnglePotentiometerSensor
]

instance VehicleTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CANBusSensor
]

instance ObjectTrackVectorTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TrackingFE
]

// Data instances fed to enablers
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data stream"
    DTDFVocab:inputTo MonitoringProcessingEnabler
    DTDFVocab:fromData LiDARPointCloudTransmitted
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Raw depth‑camera image data stream"
    DTDFVocab:inputTo MonitoringProcessingEnabler
    DTDFVocab:fromData DepthImageTransmitted
]

instance WheelSpeedSampleData : DTDFVocab:Data [
    base:desc "Vehicle wheel‑speed sample data at 100 Hz"
    DTDFVocab:inputTo MonitoringProcessingEnabler
    DTDFVocab:fromData WheelSpeedSampleTransmitted
]

instance SteeringAngleSampleData : DTDFVocab:Data [
    base:desc "Vehicle steering‑angle sample data at 100 Hz"
    DTDFVocab:inputTo MonitoringProcessingEnabler
    DTDFVocab:fromData SteeringAngleSampleTransmitted
]

instance VehicleTelemetryData : DTDFVocab:Data [
    base:desc "Vehicle telemetry from CAN bus (speed, torque, etc.)"
    DTDFVocab:inputTo MonitoringProcessingEnabler, AccOffloadingEnabler
    DTDFVocab:fromData VehicleTelemetryTransmitted
]

instance ObjectTrackVectorData : DTDFVocab:Data [
    base:desc "Object‑track state vectors from clustering + Kalman filtering"
    DTDFVocab:inputTo MonitoringProcessingEnabler, AccOffloadingEnabler
    DTDFVocab:fromData ObjectTrackVectorTransmitted
]

instance TrajectoryLogData : DTDFVocab:Data [
    base:desc "Logged vehicle trajectory for trend analysis"
    DTDFVocab:inputTo AnalyticsEnabler
    DTDFVocab:fromData VehicleTelemetryTransmitted
]

// Models
instance AccControllerModel : DTDFVocab:Model [
    base:desc "ISO 15622 ACC controller computing desired speed from lead‑vehicle distance"
    DTDFVocab:inputTo AccOffloadingEnabler
]

instance TrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering and Kalman‑filter tracking pipeline"
    DTDFVocab:inputTo MonitoringProcessingEnabler
]

instance DataStorageModel : DTDFVocab:Model [
    base:desc "SQL schema storing vehicle state, object‑tracks, timestamps"
    DTDFVocab:inputTo AnalyticsEnabler
]

instance ReportingModel : DTDFVocab:Model [
    base:desc "Generating time‑series human‑readable logs for reporting FE"
    DTDFVocab:inputTo MonitoringProcessingEnabler
]

// Enablers
instance MonitoringProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Edge compute FE processing vehicle telemetry and perception data for monitoring"
    DTDFVocab:enables DataMonitoringService
]

instance AccOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Compute offloading FE executing C++ ISO 15622 logic on Jetson Orin"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Operator‑UI FE enabling remote ACC control, speed adjustment, emergency braking"
    DTDFVocab:enables RemoteManagementService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D CAD rendering FE using ROS2 DDS over Wi‑Fi, consuming perception streams"
    DTDFVocab:enables VisualizationService
]

instance AnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "SQL‑based analytics FE logging trajectories for trend analysis"
    DTDFVocab:enables AnalyticsService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI displays speed, steering, object tracks, projected path logs data"
    DTDFVocab:provides InsightAccelerationBrakePrediction, InsightHistoricalTrendAnalysis, InsightAccDiagnostics
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC logic executing ISO 15622 on DT to compute desired speed from lead distance"
    DTDFVocab:provides InsightAlertLeadVehicleDistance
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator commands to enable/disable ACC, modify speed, trigger emergency braking"
    DTDFVocab:provides ActionRecommendAccParameterTuning, ActionRemotePolicyAdjustment
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D CAD visualisation FE rendering vehicle and environment"
    DTDFVocab:provides InsightObjectTrackVisualization
]

instance AnalyticsService : DTDFVocab:Service [
    base:desc "Analytics FE logging trajectories and generating trend reports"
    DTDFVocab:provides InsightHistoricalTrendAnalysis
]

// Insights
instance InsightAccelerationBrakePrediction : DTDFVocab:Insight [
    base:desc "Real‑time acceleration/brake command prediction based on vehicle state"
]

instance InsightAlertLeadVehicleDistance : DTDFVocab:Insight [
    base:desc "Alert when lead‑vehicle following distance exceeds safe threshold"
]

instance InsightAccDiagnostics : DTDFVocab:Insight [
    base:desc "Diagnostics of ACC performance via reported speed error"
]

instance InsightHistoricalTrendAnalysis : DTDFVocab:Insight [
    base:desc "Historical trend analysis of vehicle trajectories from stored data"
]

instance InsightObjectTrackVisualization : DTDFVocab:Insight [
    base:desc "Visualization of object tracks in 3D rendering"
]

// Actions
instance ActionRecommendAccParameterTuning : DTDFVocab:Action [
    base:desc "Recommend ACC controller parameter tuning based on performance analytics"
    DTDFVocab:IsAutomatic false
]

instance ActionRemotePolicyAdjustment : DTDFVocab:Action [
    base:desc "Enables remote policy adjustment (enable/disable ACC) without vehicle proximity"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT outputs include desired speed commands transmitted to the ESC (via CAN over Wi‑Fi), emergency‑brake commands, and ACC enable/disable flags directed to the vehicle’s ECU. These messages are formatted by the Data Translation FE and sent as low‑latency packets (≤100 ms) to the PT’s on‑board controllers, which then actuate the motor and steering mechanisms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All DT services are executed in real‑time with an end‑to‑end latency target of ≤100 ms from PT to DT; sensor data, control decisions, and actuator commands are synchronized to a global clock with an accuracy of ≤100 ms. The DT processes perception cycles at 10 Hz (LiDAR) and 30 Hz (depth camera) and updates control decisions at the same rates."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DTS is orchestrated by four entities: (1) Physical Twin Entity hosting sensor‑data acquisition and low‑level actuation FE; (2) Digital Twin Entity (ACC controller, data‑collection, reporting, storage, visualization FEs); (3) User Entity (3D visualization FE, control‑panel FE); (4) Cross‑System Entity providing Data Translation FE. Communication flows over a Wi‑Fi network using DDS (UDP) between entities and ROS 2 topics within each entity."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle spans (1) Design/Requirements (R1–R8) establishing communication, data gathering, and control constraints; (2) Development/Implementation (mapping SW components to ISO 23247 FEs, coding ROS 2 packages, integrating third‑party tools); (3) Validation/Testing (latency verification, ACC correctness, safety‑critical compliance); (4) Deployment/Operation (continuous data collection during vehicle runs, remote management by operators); (5) Monitoring/Iteration (generating reports, refining ACC parameters)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by employing high‑fidelity sensors (LiDAR, depth camera), low‑latency Wi‑Fi communication, and a validated ACC model per ISO 15622. Validation includes end‑to‑end latency measurement (≤100 ms), sensor‑to‑decision timing checks, and functional correctness testing of ACC logic under various traffic scenarios. Uncertainty is mitigated through sensor fusion (LiDAR + depth camera) and Kalman‑filter tracking. Safety compliance is addressed by adhering to ISO 15622 control logic and maintaining a human‑in‑the‑loop operator interface."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT communicates with the PT over an IEEE 802.11 (based on Wi‑Fi) link; data serialization is handled by the Data Translation FE. ROS 2 nodes exchange messages via DDS over UDP, enabling multicast of sensor data and control commands between entities. The end‑to‑end latency is measured and constrained to ≤100 ms."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The PHYSICAL TWIN ENTITY runs on the vehicle’s integrated NVIDIA Jetson Orin Nano and ESC controllers; the DIGITAL TWIN ENTITY operates on the same edge node (NVIDIA Jetson Orin) or a nearby cloud placeholder, hosting ROS 2 master, data‑collection, ACC, and visualization services; the USER ENTITY is hosted on an operator workstation (Windows/Linux) via a web‑based UI served by the control‑panel FE."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT design follows ISO 23247 (Digital Twin Manufacturing Framework) for reference architecture, ISO 15622 for ACC safety logic, ROS 2 as middleware adhering to DDS/OPC UA interoperability, and optional OPC UA standard for data translation. Communication relies on open‑source Wi‑Fi (IEEE 802.11) and industry‑standard CAN‑bus interfaces."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The system is safety‑critical; end‑to‑end latency ≤100 ms and 100 ms clock sync ensure timely response. The ACC logic conforms to ISO 15622 safety guidelines. Human‑in‑the‑loop operator interface allows emergency brake overrides. No explicit cybersecurity measures (e.g., encryption, authentication) are detailed in the source documents."
]