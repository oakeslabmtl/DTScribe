// C3: Physical Sensing Components
instance EgoSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On-board measurement of vehicle speed via physical twin's embedded system"
    DTDFVocab:producedData EgoSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On-board measurement of steering angle via physical twin's embedded system"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing external perception data for object detection"
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance IntelDeepSenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera providing external perception data for object detection"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance JetsonPerceptionFusion : DTDFVocab:SensingComponent [
    base:desc "NVIDIA Jetson platform fusing LiDAR and camera data into processed object tracks"
    DTDFVocab:producedData ProcessedObjectTracksDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance EgoSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iCamera
]

instance ProcessedObjectTracksDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JetsonPerceptionFusion
]

instance CombinedVehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoSpeedSensor, SteeringAngleSensor, JetsonPerceptionFusion
]

// C10: Models/Data
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "Point-cloud clustering model using DBSCAN algorithm to process LiDAR data into object clusters"
    DTDFVocab:inputTo JetsonPerceptionFusion
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman-filter tracking model applied to clustered objects for smooth trajectory estimation"
    DTDFVocab:inputTo JetsonPerceptionFusion
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model following ISO 15622 Performance Class I to compute desired speed"
    DTDFVocab:inputTo DataTranslationFE
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Real-time ego vehicle state including speed, steering angle, and processed object tracks"
    DTDFVocab:fromData CombinedVehicleStateDataTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Kalman-filtered object tracks with speed profiles and spatial trajectories"
    DTDFVocab:fromData ProcessedObjectTracksDataTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance DesiredSpeedData : DTDFVocab:Data [
    base:desc "Computed desired speed output from ACC algorithm for physical twin actuation"
    DTDFVocab:fromData ACCControlModel
    DTDFVocab:inputTo DataTranslationFE
]

instance TimeSeriesReportsData : DTDFVocab:Data [
    base:desc "Human-readable time-series reports of object tracks and speed profiles"
    DTDFVocab:fromData ObjectTrackData, VehicleStateData
    DTDFVocab:inputTo DataTranslationFE
]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for inter-process communication between physical and digital twin entities"
    DTDFVocab:enables DataTranslationFE, RemoteManagementService
]

instance NVIDIAJetPackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK for Jetson hardware acceleration and ROS2 integration"
    DTDFVocab:enables JetsonPerceptionFusion
]

instance Python38Environment : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime environment for implementing ROS2 nodes and data processing pipelines"
    DTDFVocab:enables DataTranslationFE
]

instance CppROS2Lifecycle : DTDFVocab:Enabler [
    base:desc "C++ ROS2 node lifecycle management for robust component initialization and shutdown"
    DTDFVocab:enables JetsonPerceptionFusion
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for implementing clustering and tracking algorithms"
    DTDFVocab:enables DBSCANClusteringModel, KalmanFilterTrackingModel
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL database for persistent storage of ego state and object track data"
    DTDFVocab:enables DataTranslationFE
]

instance WiFiNetworking : DTDFVocab:Enabler [
    base:desc "Wi-Fi link for transmitting processed vehicle state data from physical to digital twin"
    DTDFVocab:enables DataTranslationFE
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Cross-system data translation functional entity mediating inter-entity communication and unit conversion"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of vehicle state, projected path, and object tracks with downloadable reports"
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTrackVisualizationInsight, DownloadableReportsInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Execution of ACC algorithm in digital twin to free physical twin's limited ECU resources"
    DTDFVocab:provides ACCDecisionInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator interface for enabling/disabling ACC, setting target speed, and issuing emergency braking"
    DTDFVocab:provides ACCEnableDisableAction, TargetSpeedAdjustmentAction, EmergencyBrakeAction
]

// C17: Insights/Actions
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real-time visual feedback of vehicle state including speed, steering, and trajectory"
]

instance ObjectTrackVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of detected objects with spatial trajectories and speed profiles"
]

instance DownloadableReportsInsight : DTDFVocab:Insight [
    base:desc "Human-readable reports of object tracks and speed profiles for post-analysis"
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "Automated ACC decisions including desired speed and adaptive following behavior"
]

instance ACCEnableDisableAction : DTDFVocab:Action [
    base:desc "Operator-controlled activation/deactivation of adaptive cruise control functionality"
    DTDFVocab:IsAutomatic false
]

instance TargetSpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Remote adjustment of target speed for ACC system"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediate emergency braking command issued remotely"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance VedderESCActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder electronic speed controller receiving motor voltage commands from digital twin"
]

instance ServoSteeringActuator : DTDFVocab:ActingComponent [
    base:desc "Servo actuator receiving steering angle commands from digital twin"
]

// C1: System Under Study
instance AutonomousVehiclePhysicalTwin : DTDFVocab:Component [
    base:desc "1/10-scale autonomous vehicle with upper chassis housing Jetson NX/Orin Nano, LiDAR, camera, and ESC lower chassis provides actuation"
    base:isContainedIn JetsonHardwareEnvironment
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "External compute hosting digital twin with visualization, control, and reporting capabilities"
    base:isContainedIn ExternalComputeEnvironment
]

instance UserInterfaceEntity : DTDFVocab:Component [
    base:desc "Operator interface providing visualization and remote management controls"
    base:isContainedIn UserInterfaceEnvironment
]

instance JetsonHardwareEnvironment : DTDFVocab:Environment [
    base:desc "Physical twin's embedded environment with NVIDIA Jetson NX and Orin Nano processors"
    base:contains AutonomousVehiclePhysicalTwin
]

instance ExternalComputeEnvironment : DTDFVocab:Environment [
    base:desc "Cloud or workstation hosting digital twin components"
    base:contains DigitalTwinEntity
]

instance UserInterfaceEnvironment : DTDFVocab:Environment [
    base:desc "Operator workstation providing visualization and control interfaces"
    base:contains UserInterfaceEntity
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity sends computed Desired Speed values back to the PT for motor actuation, and transmits remote‑management commands (enable/disable ACC, modify Desired Speed, emergency brake) that are interpreted by the Actuation FE on the PT to drive the motor controller and steering servo."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates at sub‑second time‑scale with a maximum end‑to‑end network latency requirement of 100 ms (R7) and clock synchronization accuracy of 100 ms (R8), ensuring real‑time data collection and control loop closure."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates the Physical Twin Entity (sensing and actuation), Digital Twin Entity (data collection, ACC computation, reporting, visualization), User Entity (3D visualization and control panel UI), and a Cross‑System Data Translation FE. Intra‑entity communication uses ROS 2 topics; inter‑entity communication uses Wi‑Fi with serialized messages via the Data Translation FE."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is used during the operational stage of the vehicle for monitoring, control, and reporting, and also supports design‑time experimentation (e.g., virtual testing of ACC) as indicated by the discussion of DTs as cyber‑physical experimentation facilities."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT maintains fidelity by adhering to real‑time latency (<100 ms) and clock sync (<100 ms) constraints, using high‑fidelity sensor data (LiDAR, depth camera) and validated ACC algorithms per ISO 15622. Safety‑critical aspects are addressed by limiting ACC to Performance Class I and by ensuring deterministic off‑loading of computation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual data is transmitted over a Wi‑Fi network using ROS 2 messages serialized by the Data Translation FE; virtual‑to‑physical commands follow the same Wi‑Fi link back to the PT where they are deserialized and applied via ROS 2 subscribers in the Actuation FE."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the vehicle’s Jetson Orin Nano; the Digital Twin Entity is hosted on an external compute platform (e.g., a workstation or cloud server) that runs the ACC, visualization, and reporting services; the User Entity (UI) runs on a user workstation. Each FE is packaged as an independent ROS 2 module."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) reference architecture, adopts ISO 15622 for ACC functionality, references ISO/IEC 30173:2023 for DT concepts, and mentions optional use of OPC UA (IEC 62541) for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The design acknowledges safety‑critical constraints by imposing a maximum 100 ms latency, requiring clock synchronization within 100 ms, and limiting ACC to a non‑road‑curvature (Performance Class I) implementation. Remote commands are mediated through the User Interface FE, and the system relies on standardized communication interfaces to reduce integration risks."
]