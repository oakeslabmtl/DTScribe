// ---------------------------------------------------------------
// Functional Entities
// ---------------------------------------------------------------
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical twin entity instantiated once on the vehicle hardware."
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital twin entity instantiated once on edge compute hardware."
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User entity providing UI interaction for monitoring and control."
]

// ---------------------------------------------------------------
// Sensing Components
// ---------------------------------------------------------------
instance HokuyoUST10LXLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2‑D LiDAR providing range measurements used for point‑cloud generation.",
    producedData LiDARPointCloudTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera supplying 3‑D perception data.",
    producedData DepthCameraFrameTransmitted
]

instance VehicleSpeedTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle telemetry component providing ego speed data.",
    producedData SpeedTelemetryTransmitted
]

instance VehicleSteeringAngleTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle telemetry component providing steering angle data.",
    producedData SteeringAngleTelemetryTransmitted
]

// ---------------------------------------------------------------
// Data Transmitted (Physical → Virtual)
// ---------------------------------------------------------------
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    producedFrom HokuyoUST10LXLiDARSensor
]

instance DepthCameraFrameTransmitted : DTDFVocab:DataTransmitted [
    producedFrom IntelDeepSenseD435iDepthCamera
]

instance SpeedTelemetryTransmitted : DTDFVocab:DataTransmitted [
    producedFrom VehicleSpeedTelemetrySensor
]

instance SteeringAngleTelemetryTransmitted : DTDFVocab:DataTransmitted [
    producedFrom VehicleSteeringAngleTelemetrySensor
]

// ---------------------------------------------------------------
// Raw Sensor Data (Virtual)
// ---------------------------------------------------------------
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud frames received from the LiDAR sensor.",
    fromData LiDARPointCloudTransmitted,
    inputTo DataTranslationEnabler
]

instance DepthCameraData : DTDFVocab:Data [
    base:desc "Raw depth‑camera frames received from the depth camera.",
    fromData DepthCameraFrameTransmitted,
    inputTo DataTranslationEnabler
]

instance SpeedTelemetryData : DTDFVocab:Data [
    base:desc "Ego speed telemetry values.",
    fromData SpeedTelemetryTransmitted,
    inputTo DataTranslationEnabler
]

instance SteeringAngleTelemetryData : DTDFVocab:Data [
    base:desc "Steering angle telemetry values.",
    fromData SteeringAngleTelemetryTransmitted,
    inputTo DataTranslationEnabler
]

// ---------------------------------------------------------------
// Models
// ---------------------------------------------------------------
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "Point Cloud Clustering model using DBSCAN algorithm to produce object clusters.",
    inputTo PointCloudProcessingEnabler
]

instance KalmanTrackingModel : DTDFVocab:Model [
    base:desc "Tracking model applying a Kalman filter to maintain object tracks over time.",
    inputTo ACCComputationEnabler
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "ACC model determines lead vehicle and computes appropriate following speed.",
    inputTo ACCComputationEnabler
]

// ---------------------------------------------------------------
// Model Output Transmission
// ---------------------------------------------------------------
instance ClusteringOutputTransmitted : DTDFVocab:DataTransmitted [
    producedFrom DBSCANClusteringModel
]

instance TrackingOutputTransmitted : DTDFVocab:DataTransmitted [
    producedFrom KalmanTrackingModel
]

instance ACCOutputTransmitted : DTDFVocab:DataTransmitted [
    producedFrom AdaptiveCruiseControlModel
]

// ---------------------------------------------------------------
// Model Output Data
// ---------------------------------------------------------------
instance ObjectClustersData : DTDFVocab:Data [
    base:desc "Object clusters generated by the DBSCAN clustering model.",
    fromData ClusteringOutputTransmitted,
    inputTo PointCloudProcessingEnabler
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Tracked objects produced by the Kalman tracking model.",
    fromData TrackingOutputTransmitted,
    inputTo ACCComputationEnabler
]

instance DesiredSpeedCommandData : DTDFVocab:Data [
    base:desc "Desired speed command computed by the ACC model.",
    fromData ACCOutputTransmitted,
    inputTo RemoteManagementEnabler
]

// ---------------------------------------------------------------
// Enablers (Tools, Middleware, Compute)
// ---------------------------------------------------------------
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation functional entity serializes streams, aligns message types and performs unit conversions.",
    enables DataMonitoringService
]

instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Component processes raw point‑cloud frames for clustering and tracking using ROS2 DDS.",
    enables DataMonitoringService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that runs ACC computation off‑loaded to cloud and provides desired speed output.",
    enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that provides UI for operators to enable/disable ACC, set speed, and issue emergency‑brake commands.",
    enables RemoteManagementService
]

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for sensor integration and intra‑DT messaging.",
    enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance JetsonOrinNanoComputeEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetson Orin Nano module providing hardware‑accelerated compute via Jetpack 5.0 SDK.",
    enables ComputationOffloadingService, RemoteManagementService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Relational SQL database persisting object tracks and vehicle state for analytics.",
    enables DataMonitoringService, ComputationOffloadingService
]

// ---------------------------------------------------------------
// Services
// ---------------------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualises real‑time vehicle state, projected driving paths, and detected object tracks allows view, save, and generate reports.",
    provides InsightVehicleStateVisualization, ActionGenerateReport
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm executed on the digital twin computed desired speed sent back to vehicle for actuation.",
    provides ActionOffloadACCComputation
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI enables operators to remotely enable/disable ACC, set desired speed, and issue emergency‑brake commands.",
    provides ActionEnableACC, ActionSetDesiredSpeed, ActionEmergencyBrake
]

// ---------------------------------------------------------------
// Insights and Actions
// ---------------------------------------------------------------
instance InsightVehicleStateVisualization : DTDFVocab:Insight [
    base:desc "Visualization of real‑time vehicle state, projected paths, and object tracks."
]

instance ActionGenerateReport : DTDFVocab:Action [
    base:desc "Generate and save reports on collected ACC‑relevant data.",
    IsAutomatic false
]

instance ActionOffloadACCComputation : DTDFVocab:Action [
    base:desc "Execute ACC algorithm on the digital twin and send desired speed to the vehicle.",
    IsAutomatic true
]

instance ActionEnableACC : DTDFVocab:Action [
    base:desc "Remotely enable or disable Adaptive Cruise Control.",
    IsAutomatic false
]

instance ActionSetDesiredSpeed : DTDFVocab:Action [
    base:desc "Set desired speed for ACC via the user interface.",
    IsAutomatic false
]

instance ActionEmergencyBrake : DTDFVocab:Action [
    base:desc "Issue an emergency‑brake command to the vehicle.",
    IsAutomatic false
]

// ---------------------------------------------------------------
// Environments (optional grouping)
// ---------------------------------------------------------------
instance VehicleEnvironment : DTDFVocab:Environment [
    base:contains HokuyoUST10LXLiDARSensor, IntelDeepSenseD435iDepthCamera, VehicleSpeedTelemetrySensor, VehicleSteeringAngleTelemetrySensor
]

instance EdgeComputeEnvironment : DTDFVocab:Environment [
    base:contains JetsonOrinNanoComputeEnabler, ROS2MiddlewareEnabler, DataTranslationEnabler, PointCloudProcessingEnabler, ACCComputationEnabler, RemoteManagementEnabler, SQLDatabaseEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The ACC Controlling functional entity runs in the DT, determines the lead vehicle and computes a desired speed. The computed speed is packaged by the Data Translation FE and sent back to the vehicle over the same Wi‑Fi UDP link. On the physical side the Actuation FE receives the command and drives the motor and steering servo to achieve the requested speed. The documents do not detail command message schemas, authentication, conflict resolution, or explicit execution acknowledgments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires a clock synchronization accuracy of 100 ms between physical and digital components, as imposed by hardware limitations. This accuracy is needed for safe vehicular operation and aligns with standards that demand stricter (<100 ms) synchronization for safety‑critical tasks. All functional entities share this common time base to enable computation off‑loading and coordinated control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The orchestration follows the ISO 23247 reference architecture, mapping each functional entity to a ROS 2 package that contains one or more ROS 2 nodes implementing the entity's functionality. The Physical Twin Entity hosts sensor, actuator, and compute resources (e.g., point‑cloud clustering & tracking); the Digital Twin Entity provides data management and control mechanisms; the User Entity contains the split User Interface FE (visualization and control panel). Entities are deployed on distinct hardware, and system‑wide coordination is realized through ROS 2 publish/subscribe and service calls across the packages, respecting the entity‑based structure of ISO 23247."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and system validity are governed by explicit requirements. Requirement R6 mandates that the Digital Twin implement the ACC functionality in accordance with ISO 15622, ensuring compliance with an established automotive control standard. Requirement R7 limits end‑to‑end network latency to a maximum of 100 ms, while Requirement R8 requires clock synchronization across system components to within 100 ms accuracy. These constraints serve as validation criteria for timing fidelity and synchronization integrity, providing a basis for verification of the Digital Twin’s real‑time performance."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS uses a two‑layer communication architecture: intra‑entity component communication occurs on a ROS2 network, while inter‑entity (physical‑digital) communication is carried out over Wi‑Fi using UDP at the transport layer. No specific bandwidth, latency, reliability, redundancy, or security protocol details are provided in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin System is deployed on edge hardware rather than a central cloud. The physical twin runs on an on‑board NVIDIA Jetson Orin Nano microcomputer that hosts the sensors, low‑level motor and steering control, and the Actuation functional entity. The digital twin entity is hosted on a separate edge node equipped with an NVIDIA Jetson NX (including an antenna for Wi‑Fi communication) where the ACC Controlling, Data Translation, Point Cloud Clustering & Tracking, and visualization services execute. The user interface runs on a workstation or remote console that accesses the digital twin over the same Wi‑Fi link. Each entity is therefore instantiated on its own compute platform, allowing independent scaling of CPU/GPU resources and storage (local SSD for data logging). The documents mention that each entity has been deployed on a different hardware component, indicating a distributed edge deployment model."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system follows the ISO 23247 standard for digital twins in manufacturing. ISO 23247 Part 2 defines an entity‑based reference architecture composed of the Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity, and User Entity, each built from Functional Entities that perform tasks such as actuation, data transformation, and user interfacing. The standard permits implementation using protocols such as OPC Unified Architecture (OPC UA)."
]