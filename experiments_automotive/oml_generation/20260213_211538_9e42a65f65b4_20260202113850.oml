// C2: Acting Components
instance MotorControllerActuation : DTDFVocab:ActingComponent [
    base:desc "Motor controller receiving desired speed commands that are converted into motor voltage signals"
]

instance SteeringServoActuation : DTDFVocab:ActingComponent [
    base:desc "Steering servo controller receiving steering angle commands to actuate steering"
]

instance EmergencyBrakeActuation : DTDFVocab:ActingComponent [
    base:desc "Emergency braking system accessible via ACC-generated brake‑apply signals"
]

// C3: Physical Sensing Components
instance HokuyoUST10LxLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR producing dense point clouds for object detection and tracking"
    DTDFVocab:producedData LiDARPointCloudData
]

instance RealsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Realsense D435i depth camera providing depth images of the environment"
    DTDFVocab:producedData DepthImageData
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑embedded speed sensor reporting ego vehicle speed to the DT"
    DTDFVocab:producedData EgoSpeedData
]

instance VehicleSteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑embedded sensor reporting steering angle to the DT"
    DTDFVocab:producedData EgoSteeringAngleData
]

// C4: Data Transmitted
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LxLiDAR
]

instance DepthImageData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RealsenseD435iDepthCamera
]

instance EgoSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance EgoSteeringAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSteeringAngleSensor
]

// C10: Models/Data
instance ACCControllerModel : DTDFVocab:Model [
    base:desc "ACC algorithm implementing performance class I per ISO 15622 using ego speed, steering angle, object tracks, and projected path"
]

instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Point‑cloud clustering and tracking model using DBSCAN followed by Kalman filtering to generate object tracks"
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D rendering model for real‑time visualization of vehicle and surrounding objects"
]

instance LiDARPointCloud : DTDFVocab:Data [
    base:desc "Point cloud data received from Hokuyo UST‑10LX LiDAR"
    DTDFVocab:fromData LiDARPointCloudData
]

instance DepthImage : DTDFVocab:Data [
    base:desc "Depth image data received from Intel Realsense D435i"
    DTDFVocab:fromData DepthImageData
]

instance EgoSpeed : DTDFVocab:Data [
    base:desc "Ego vehicle speed value sampled at high frequency"
    DTDFVocab:fromData EgoSpeedData
]

instance EgoSteeringAngle : DTDFVocab:Data [
    base:desc "Ego steering angle value sampled at high frequency"
    DTDFVocab:fromData EgoSteeringAngleData
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Tracked object positions and velocities generated by PointCloudClusteringTrackingModel"
]

instance ProjectedPathData : DTDFVocab:Data [
    base:desc "Projected flight path computed by ACCControllerModel"
]

instance DesiredSpeedCommandData : DTDFVocab:Data [
    base:desc "Desired speed command produced by ACC controller to be sent to motor controller"
]

instance DesiredSteeringCommandData : DTDFVocab:Data [
    base:desc "Desired steering angle command produced by ACC controller to be sent to steering servo"
]

instance EmergencyBrakeCommandData : DTDFVocab:Data [
    base:desc "Emergency brake activation command generated by ACC logic for an immediate stop"
]

instance ACCStatusData : DTDFVocab:Data [
    base:desc "Current ACC status (enabled/disabled) and configuration parameters"
]

// C11: Enablers
instance DataCollectionFE : DTDFVocab:Enabler [
    base:desc "Data Collection Functional Entity handling raw sensor data ingestion"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, VisualizationService, ReportingService
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Data Translation Functional Entity serializing and unit‑converting inbound telemetry"
    DTDFVocab:enables DataMonitoringService
]

instance ReportingFE : DTDFVocab:Enabler [
    base:desc "Reporting Functional Entity responsible for time‑series export and SQL persistence"
    DTDFVocab:enables ReportingService
]

instance ACCComputationFE : DTDFVocab:Enabler [
    base:desc "ACC Computation Functional Entity executing real‑time adaptive cruise control"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteCommandFE : DTDFVocab:Enabler [
    base:desc "Remote Command Functional Entity allowing operator commands for ACC adjustment and emergency actions"
    DTDFVocab:enables RemoteManagementService
]

instance VisualizationFE : DTDFVocab:Enabler [
    base:desc "Visualization Functional Entity managing 3‑D rendering"
    DTDFVocab:enables VisualizationService
]

instance ActuationFE : DTDFVocab:Enabler [
    base:desc "Actuation Functional Entity applying commanded actions to physical actuators"
    DTDFVocab:enables ActuationService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Live display of speed, steering, object tracks, and projected path via ROS2 DDS"
    DTDFVocab:provides LiveSpeedInsight, LiveSteeringInsight, LiveObjectTracksInsight, LiveProjectedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm runs on Digital Twin, computing desired speed and issuing speed command"
    DTDFVocab:provides ApplyDesiredSpeedCommandAction, ApplyDesiredSteeringCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management enabling enable/disable ACC, adjust speed, and trigger emergency braking"
    DTDFVocab:provides ACCEnableInsight, ACCStatusInsight, EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, TriggerEmergencyBrakeAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3‑D visualization of vehicle and environment for operator situational awareness"
    DTDFVocab:provides VisualizationRenderInsight
]

instance ReportingService : DTDFVocab:Service [
    base:desc "SQL and time‑series reporting of vehicle telemetry"
    DTDFVocab:provides ReportingTimeSeriesInsight
]

instance ActuationService : DTDFVocab:Service [
    base:desc "Command application to motor controller, steering servo, and emergency brake actuator"
    DTDFVocab:provides ApplyDesiredSpeedCommandAction, ApplyDesiredSteeringCommandAction, TriggerEmergencyBrakeAction
]

// C17: Insights / Actions
instance LiveSpeedInsight : DTDFVocab:Insight [
    base:desc "Live speed of the vehicle displayed on the operator interface"
]

instance LiveSteeringInsight : DTDFVocab:Insight [
    base:desc "Live steering angle of the vehicle displayed on the operator interface"
]

instance LiveObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Live object tracks visualized in the operator dashboard"
]

instance LiveProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Live projected path of the vehicle displayed to the operator"
]

instance ACCEnableInsight : DTDFVocab:Insight [
    base:desc "Status of ACC enable/disable presented to the operator"
]

instance ACCStatusInsight : DTDFVocab:Insight [
    base:desc "Current ACC operational parameters reported to the operator"
]

instance ReportingTimeSeriesInsight : DTDFVocab:Insight [
    base:desc "Time‑series report of the vehicle telemetry exported to the database"
]

instance VisualizationRenderInsight : DTDFVocab:Insight [
    base:desc "Rendered 3‑D visualization of the vehicle and environment"
]

instance ApplyDesiredSpeedCommandAction : DTDFVocab:Action [
    base:desc "Automatically applied desired speed command to the motor controller"
    DTDFVocab:IsAutomatic true
]

instance ApplyDesiredSteeringCommandAction : DTDFVocab:Action [
    base:desc "Automatically applied desired steering angle command to the steering servo"
    DTDFVocab:IsAutomatic true
]

instance TriggerEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Automatically triggers emergency braking system when commanded by ACC logic"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable adaptive cruise control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable adaptive cruise control"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator command to manually adjust the desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Computed control actions (desired speed, steering commands, emergency brake) are emitted by the Control FE of the Digital Twin Entity, serialized by the Data Translation FE, and sent over the Wi‑Fi network via ROS2 topics to the Physical Twin Entity which translates the commands into motor‑voltage and steering‑servo actuation on the vehicle."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All DT services operate in real‑time; data is streamed at each perception cycle with an end‑to‑end latency requirement of ≤100 ms. Clock synchronization across devices is maintained to within 100 ms to guarantee event ordering and command safety."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The distributed twin constellation orchestrates ROS2 nodes across four entities: Physical Twin (sensors/actuators), Digital Twin (data collection, control, storage), User Entity (3‑D visualization, control panel), Cross‑System Entity (Data Translation). Communication flows via ROS2 topics over Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "1) Requirement elicitation (R1–R8) 2) Architectural design (mapping ISO 23247 RA to software components) 3) Implementation (ROS2 nodes in Python/C++/MATLAB) 4) Testing and verification (latency, unit conversions) 5) Deployment (embedded Jetson, Wi‑Fi network, UI client) 6) Evaluation – assessing ISO 23247 fitness for automotive DTs."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time constraint enforcement (≤100 ms latency, ≤100 ms clock sync), use of DBSCAN + Kalman filter for accurate tracking, ACC validation against ISO 15622 specifications, Data Translation FE providing unit conversion and message integrity, SQL storage ensuring precise time‑series data fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication is conducted over a Wi‑Fi network; internal component messaging uses ROS 2 (DDS‑based). The Data Translation FE performs serialization and unit conversion for all networked data. No explicit WAN or external protocols are employed."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin compute runs primarily on the NVIDIA Jetson Orin Nano mounted on the vehicle for on‑board services, with optional offloading of ACC logic to a local edge server or cloud node; all components are packaged as ROS 2 nodes running on Linux. The User Entity operates on a remote workstation with the same ROS 2 stack for interface rendering."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to ISO 23247 reference architecture for DT, ISO 15622 for ACC algorithms, ROS2 middleware standards, NVIDIA JetPack 5.0 firmware, and standard ROS2 distribution packages."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by maintaining ≤ 100 ms end‑to‑end latency, achieving ± 100 ms clock synchronization, and implementing ACC in compliance with ISO 15622 safety class I. No specific cybersecurity safeguards (encryption, authentication) are indicated in the document."
]