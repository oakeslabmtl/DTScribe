// C3: Physical sensing components
instance LiDAR : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor generating 3D point clouds on the physical twin vehicle"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Motor status sensor providing RPM and torque information"
    DTDFVocab:producedData MotorStatusTransmitted
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Steering servo position sensor reporting angular position"
    DTDFVocab:producedData SteeringServoTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor aggregating speed, heading, and GPS position"
    DTDFVocab:producedData VehicleStateTransmitted
]

// C4: Physical-to-virtual interaction
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDAR
]

instance MotorStatusTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance SteeringServoTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// C10: Data instances
instance PointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud frames transmitted over UDP"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Motor RPM and torque status data"
    DTDFVocab:fromData MotorStatusTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance SteeringServoData : DTDFVocab:Data [
    base:desc "Steering servo angular position data"
    DTDFVocab:fromData SteeringServoTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Aggregated vehicle state: speed, heading, and GPS coordinates"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

// C11: Enablers (Functional Entities)
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation FE serialises streams, aligns message types, and performs unit conversions for incoming sensor data"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "User‑interface visualising real‑time vehicle state, projected path, and detected object tracks; allows viewing, saving, and report generation"
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTrackingInsight, DataReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC control logic (lead‑vehicle detection, speed set‑point calculation) in the digital twin and returns the desired speed to the physical twin"
    DTDFVocab:provides ComputationOffloadInsight, DesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to remotely enable/disable ACC, set a desired speed, and issue an emergency brake via the UI"
    DTDFVocab:provides RemoteControlInsight, EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Live visualization of vehicle speed, heading, and position"
]

instance ObjectTrackingInsight : DTDFVocab:Insight [
    base:desc "Clusters and tracks objects derived from LiDAR point clouds"
]

instance ComputationOffloadInsight : DTDFVocab:Insight [
    base:desc "Result of ACC computation off‑loaded to the digital twin"
]

instance RemoteControlInsight : DTDFVocab:Insight [
    base:desc "Confirmation of remote command execution status"
]

// C17: Actions
instance DataReportAction : DTDFVocab:Action [
    base:desc "Generates and saves a report of collected vehicle data"
    DTDFVocab:IsAutomatic false
]

instance DesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sends the computed desired speed from the digital twin to the physical twin for actuation"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Command to enable Adaptive Cruise Control on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Command to disable Adaptive Cruise Control on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Command to set a specific target speed for the vehicle"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Emergency brake command issued to stop the vehicle immediately"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the ACC Controlling FE (e.g., desired speed set‑point, enable/disable ACC, emergency braking) are packaged by the Data Translation FE, transmitted via the same Wi‑Fi UDP link to the physical twin, and received by the Actuation FE which drives the motor and steering servo actuators. Commands follow the internal ROS2 message format defined for actuation, and the vehicle provides feedback by updating its state sensors, which are sent back through the monitoring data path. Validation is limited to the Data Translation FE’s message alignment; explicit authentication or conflict‑resolution mechanisms are not described in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin requires a shared notion of time between physical vehicle devices and digital components to enable computation offloading; synchronization accuracy is limited to 100 ms, which satisfies the hardware constraints while meeting the less‑strict requirement compared to safety‑critical standards that demand tighter than 100 ms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall constellation is built on the ISO 23247 reference architecture. Software components identified in the design phase are mapped to functional entities and then encapsulated as ROS 2 packages; each package runs on the hardware allocated to its owning entity. Communication between entities occurs via ROS 2 topics/services, providing runtime coordination and resource management across compute, sensor, and actuator resources. The architecture thus combines an entity‑based RA with a ROS 2‑centric integration layer."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle begins with an architectural design phase that adopts the ISO 23247 reference architecture. During this phase the key software components are identified (Table I), mapped onto functional entities (FE) and realized as ROS 2 packages. Each FE becomes a ROS 2 node and is deployed on the hardware component that hosts the corresponding entity (Physical Twin Entity, Digital Twin Entity, User Entity). After implementation the packages are integrated, tested and put into operation, where the User Entity provides monitoring and control. Lifecycle governance follows the ISO 23247 four‑part framework (overview, reference architecture, digital representation, information exchange)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS uses a two‑layer network architecture: intra‑entity communication runs on a ROS2 middleware network (DDS‑based) connecting SW components as ROS2 nodes, while inter‑entity communication (between Physical Twin Entity, Digital Twin Entity and User Entity) occurs over a Wi‑Fi network using UDP at the transport layer. The system is designed for low end‑to‑end latency to satisfy safety‑critical ACC requirements, with a clock‑synchronisation accuracy of 100 ms mandated across devices. No specific bandwidth, reliability, redundancy or security protocols beyond the use of UDP are detailed in the supplied documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Each functional element (FE) is implemented as an independent ROS2 package and deployed on the hardware component that hosts its corresponding entity (Physical Twin resources, Digital Twin compute resources, or User Interface hardware). The ACC computation is off‑loaded from the vehicle to the Digital Twin, which may run on cloud or edge infrastructure as implied by the discussion of “better‑suited equipment, e.g., in the cloud.” Storage for collected data and reporting is provided by a Data Storage component, though its deployment details are not mapped to a specific FE. Scalability, deployment models and explicit availability guarantees are not further specified."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT is built to comply with the ISO 23247 digital‑twin framework for manufacturing (parts 1–4), adopting its entity‑based reference architecture (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity). Where appropriate, OPC Unified Architecture is mentioned as a possible protocol for device coordination. Time‑synchronisation requirements follow automotive safety standards that demand synchronization tighter than 100 ms; the implementation targets a 100 ms accuracy due to hardware limits. These standards ensure interoperability across entities and alignment with industry certification requirements."
]