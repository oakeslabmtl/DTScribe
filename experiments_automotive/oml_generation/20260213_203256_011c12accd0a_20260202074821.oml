// C3: Physical sensing components
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR streaming raw point clouds."
    DTDFVocab:producedData LiDARPointCloudTransmission
]
instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera providing depth image frames."
    DTDFVocab:producedData DepthImageTransmission
]
instance VedderElectronicSpeedController : DTDFVocab:SensingComponent [
    base:desc "Vedder electronic speed controller outputting wheel speed measurements."
    DTDFVocab:producedData WheelSpeedTransmission
]
instance SteeringEncoder : DTDFVocab:SensingComponent [
    base:desc "Steering encoder measuring steering angle."
    DTDFVocab:producedData SteeringAngleTransmission
]

// C4: Physical-to-virtual interaction
instance LiDARPointCloudTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]
instance DepthImageTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]
instance WheelSpeedTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VedderElectronicSpeedController
]
instance SteeringAngleTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringEncoder
]

// C11: Enablers
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Data Translation functional entity converting ROS2 sensor streams to unit‑converted data."
    // DTDFVocab:enables DataTranslationService  // No corresponding service defined removed
]
instance ClusteringTrackingFE : DTDFVocab:Enabler [
    base:desc "Point‑cloud clustering and tracking functional entity performing DBSCAN and Kalman filtering."
    DTDFVocab:enables ClusteringTrackingService
]
instance AccControlFE : DTDFVocab:Enabler [
    base:desc "ACC control functional entity executing ISO 15622 logic."
    DTDFVocab:enables AccControlService
]
instance RemoteManagementFE : DTDFVocab:Enabler [
    base:desc "Remote management functional entity handling enable/disable ACC, set desired speed, and emergency brake."
    DTDFVocab:enables RemoteManagementService
]
instance ComputationOffloadingFE : DTDFVocab:Enabler [
    base:desc "Computation offloading functional entity transferring ACC computation results to the vehicle."
    DTDFVocab:enables ComputationOffloadingService
]
instance VisualizationFE : DTDFVocab:Enabler [
    base:desc "Visualization functional entity streaming processed data to a 3D UI."
    DTDFVocab:enables VisualizationService
]
instance ReportGenerationFE : DTDFVocab:Enabler [
    base:desc "Report generation functional entity producing timeseries reports."
    DTDFVocab:enables ReportGenerationService
]

// C10: Models/Data
instance DBSCANPointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN algorithm for clustering raw point clouds."
    DTDFVocab:inputTo ClusteringTrackingFE
]
instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter for tracking clustered objects over time."
    DTDFVocab:inputTo ClusteringTrackingFE
]
instance ACCControllerModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control controller implementing ISO 15622 Class I logic."
    DTDFVocab:inputTo AccControlFE
]

// C10: Data
instance RawLiDARPointCloud : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data streamed from Hokuyo UST‑10LX."
    DTDFVocab:fromData LiDARPointCloudTransmission
    DTDFVocab:inputTo ClusteringTrackingFE
]
instance RawDepthImage : DTDFVocab:Data [
    base:desc "Raw depth image frames from Intel DeepSense D435i."
    DTDFVocab:fromData DepthImageTransmission
    DTDFVocab:inputTo ClusteringTrackingFE
]
instance WheelSpeedData : DTDFVocab:Data [
    base:desc "Wheel speed measurements from Vedder electronic speed controller."
    DTDFVocab:fromData WheelSpeedTransmission
    DTDFVocab:inputTo AccControlFE
]
instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle readings from the steering encoder."
    DTDFVocab:fromData SteeringAngleTransmission
]
instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Processed object tracks after DBSCAN clustering and Kalman filtering."
    DTDFVocab:inputTo VisualizationFE
    DTDFVocab:inputTo ReportGenerationFE
]
instance DTReportData : DTDFVocab:Data [
    base:desc "Timeseries report of object tracks and vehicle state generated by reporting service."
    DTDFVocab:inputTo ReportGenerationFE
]
instance TrackedObjectsSQLData : DTDFVocab:Data [
    base:desc "Tracked objects stored in the SQL database for predictive maintenance."
    DTDFVocab:inputTo ReportGenerationFE
]

// C2: Acting Components
instance MotorActuationFE : DTDFVocab:ActingComponent [
    base:desc "Motor Actuation Function Entity converting desired speed into motor voltage commands."
]
instance SteeringActuationFE : DTDFVocab:ActingComponent [
    base:desc "Steering Actuation Function Entity sending torque commands to the steering servo."
]
instance EmergencyBrakeActuation : DTDFVocab:ActingComponent [
    base:desc "Emergency braking function entity issuing brake commands to the vehicle."
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time display, saving, and reporting of vehicle sensor data."
    DTDFVocab:provides VehicleStateInsight
    DTDFVocab:provides ObjectTrackInsight
]
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC computation from the vehicle and returns results via ROS2 topics."
]
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables enable/disable ACC, set desired speed, and emergency brake commands."
    DTDFVocab:provides EnableACCAction
    DTDFVocab:provides SetDesiredSpeedAction
    DTDFVocab:provides ExecuteEmergencyBrakeAction
]
instance ClusteringTrackingService : DTDFVocab:Service [
    base:desc "Processes raw point clouds to produce object tracks."
]
instance AccControlService : DTDFVocab:Service [
    base:desc "Generates ACC commands based on current vehicle state and target speed."
    DTDFVocab:provides ACCPerformanceInsight
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides 3D visualization of vehicle and surrounding object tracks."
    DTDFVocab:provides ObjectTrackInsight
    DTDFVocab:provides VehicleStateInsight
]
instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generates timeseries reports of object tracks and vehicle state."
    DTDFVocab:provides ACCTimingInsight
]

// C17: Insights/Actions
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into current vehicle speed and steering angle."
]
instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Insight into detected object tracks surrounding the vehicle."
]
instance ACCPerformanceInsight : DTDFVocab:Insight [
    base:desc "Performance insight of the ACC controller, including desired vs. actual speed."
]
instance ACCTimingInsight : DTDFVocab:Insight [
    base:desc "Insight into computation latency for ACC offloading."
]
instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to set a desired cruising speed for the vehicle."
    DTDFVocab:IsAutomatic false
]
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable or disable the Adaptive Cruise Control module."
    DTDFVocab:IsAutomatic false
]
instance ExecuteEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to trigger an emergency braking maneuver."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends desired speed, ACC enable/disable flags, emergency braking commands, and steering corrections back to the PT through ROS 2 services/topics; these are consumed by the Actuation FE on the Jetson Orin Nano, which drives the motor voltage and steering servo actuators, and triggers the braking subsystem."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time vehicle state is sampled at the perception cycle (typical 30–60 Hz); end‑to‑end communication latency from vehicle to DT must not exceed 100 ms, and all clocks are synchronised to within 100 ms (as specified in R7 and R8)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation follows the ISO 23247 entity architecture: Observable Manufacturing Element analogue (Physical Twin), Digital Twin Entity, User Entity, each consisting of a set of Functional Entities (Data Translation, Data Collection, Presentation, Reporting, Controlling, Actuation). Communication flows over ROS 2 topics/services within the DT and over Wi‑Fi between PT and DT, with Data Translation serving as the cross‑system glue."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT operates in the ‘Operated’ phase of the vehicle lifecycle, providing real‑time monitoring and remote control after manufacturing; it also supports design validation via simulation during development, but the case study focuses on operational use."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is achieved through high‑fidelity sensor data processing (DBSCAN, Kalman filter), real‑time latency constraints (≤100 ms), clock synchronisation (≤100 ms accuracy), and compliance with ISO 15622 control logic. Validation involves comparing real‑time vehicle state against DT reports, ensuring that AC commands produced by the DT match expected behavior under varying lead vehicle distances."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication uses ROS 2 DDS over Wi‑Fi; within the DT, ROS 2 nodes communicate via DDS topics; between PT and DT, data is transmitted over UDP/TCP (ROS 2 transport) over a Wi‑Fi network, with a dedicated Data Translation FE handling serialization."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The PT runs the Physical Twin Entity on an NVIDIA Jetson Orin Nano; the Digital Twin Entity and User Entity are hosted on a local workstation or cloud edge node (not explicitly specified) and are packaged as ROS 2 containers or executables. The system is orchestrated via ROS 2 launch files that spin up each entity on its respective hardware."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 Part 2 (Reference Architecture) is the primary guideline; ISO 15622 defines ACC control logic; ROS 2 follows DDS communication standard; OPC UA mentioned but not used. All software follows open‑source licensing under the project repository."
]