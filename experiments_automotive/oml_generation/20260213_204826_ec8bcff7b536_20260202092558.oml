// Sensing Components
instance HokuyoUst10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR emits a laser beam sweep to capture range data within its field of view."
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivers dense 3‑D point‑cloud data via stereo vision."
    DTDFVocab:producedData DepthCameraPointCloudData
]

// Acting Components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller converts commanded wheel speed into voltage signals for the drive motor, with safety interlocks that terminate actuation in case of over‑speed or over‑steer faults."
]

instance VedderHighTorqueSteeringServo : DTDFVocab:ActingComponent [
    base:desc "High‑torque steering servo motor controls lateral vehicle motion by adjusting steering wheel angle, powered by low‑current analog outputs from the Device Control Entity."
]

// Physical‑to‑virtual transmitted data
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUst10LXLidar
]

instance DepthCameraPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

// Data instances produced by models
instance ObjectClusterData : DTDFVocab:Data [
    base:desc "Clusters of detected obstacles extracted from LiDAR point‑clouds using DBSCAN."
    DTDFVocab:inputTo DataPreProcessingEnabler
    DTDFVocab:fromData LiDARPointCloudData
]

instance ObjectTrackingData : DTDFVocab:Data [
    base:desc "Tracks of moving objects updated by a Kalman filter over successive LiDAR scans."
    DTDFVocab:inputTo DataPreProcessingEnabler
    DTDFVocab:fromData LiDARPointCloudData
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Ego‑vehicle pose, velocity, and acceleration derived from established vehicle dynamics."
    DTDFVocab:inputTo DataPreProcessingEnabler
    DTDFVocab:fromData LiDARPointCloudData
]

instance AccControlCommandData : DTDFVocab:Data [
    base:desc "Desired wheel speed commands generated by the ACC algorithm."
    DTDFVocab:inputTo ComputationOffloadingEnabler
    DTDFVocab:fromData LiDARPointCloudData
]

instance TrackedTrajectoryData : DTDFVocab:Data [
    base:desc "Persisted trajectories of tracked objects for analytics."
    DTDFVocab:inputTo DataStorageEnabler
    /* DTDFVocab:fromData ObjectTrackingData removed to avoid type conflict */
]

instance VehicleTrajectoryData : DTDFVocab:Data [
    base:desc "Persisted ego‑vehicle trajectory."
    DTDFVocab:inputTo DataStorageEnabler
    /* DTDFVocab:fromData VehicleStateData removed to avoid type conflict */
]

// Models
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Processes raw LiDAR point‑clouds, applies DBSCAN clustering, and uses Kalman filtering to track object positions and velocities."
    DTDFVocab:inputTo DataPreProcessingEnabler
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "Monitors inter‑vehicle distance and relative velocity to compute desired following speed for ACC."
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

// Enablers
instance DataPreProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Performs data pre‑processing, clustering, tracking, and unit normalisation before transmitting data to services."
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Offloads ACC algorithmic computations to cloud infrastructure and returns control commands to the vehicle."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Allows operators to enable/disable ACC, set desired speeds, or issue emergency brake commands via a low end‑to‑end latency channel."
    DTDFVocab:enables RemoteManagementService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Aggregates high‑level data streams into a SQL database for persistence and analytics."
    DTDFVocab:enables DataPersistenceService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time visualization of vehicle state, projected path, and surrounding object tracks via a user interface data can be saved and exported."
    DTDFVocab:provides ObjectTrackInsight, VehicleStateInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm on cloud infrastructure, returning desired speed commands to the vehicle."
    DTDFVocab:provides DesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Facilitates remote enable/disable of ACC, speed setting, and emergency braking."
    DTDFVocab:provides EmergencyBrakeAction
]

instance DataPersistenceService : DTDFVocab:Service [
    base:desc "Stores trajectory and vehicle state information into a SQL database."
    DTDFVocab:provides DataPersistAction
]

// Insights
instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Provides tracked object positions and velocities for visual monitoring."
]

instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Provides real‑time vehicle pose, speed, and acceleration for situational awareness."
]

// Actions
instance DesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets the desired following speed for the ACC system."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Abruptly initiates braking in response to imminent collision or operator command."
    DTDFVocab:IsAutomatic false
]

instance DataPersistAction : DTDFVocab:Action [
    base:desc "Persists current vehicle and object trajectory data into storage."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control flow from the digital twin to the physical twin is mediated by the Actuation FE component. Commands such as ACC enable/disable, desired ACC speed adjustment, and emergency‑brake activation are generated by the Control Panel UI (user entity) and serialized by the Data Translation component. The resulting messages are forwarded over the ROS 2 network as topics to Actuation nodes linked to the vehicle motor, steering, and servo actuators. The document does not describe explicit authentication or validation mechanisms; confirmation of command execution is inferred from periodic feedback of updated vehicle state (speed, position, steering angle) published by the Vehicle State FE back to the digital twin. No conflict resolution strategy is documented."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin operates with a strict clock synchronization requirement of ≤ 100 ms between the physical vehicle sensors/actuators and the digital simulation, as mandated by safety‑critical vehicular standards and hardware limitations. Computation offloading relies on this shared notion of time to ensure consistent state updates, and the twin’s services adhere to sub‑100 ms latency budgets for real‑time decision making."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Architecture follows ISO 23247 Reference Architecture. Functional Elements (FEs) are mapped onto ROS 2 packages, each containing one or more ROS 2 nodes that implement the twin logic. The system is distributed across three logical entities: 1) Physical Twin Entity (hosted on on‑board vehicle hardware, managing raw sensor data, point‑cloud clustering, actuation); 2) Digital Twin Entity (hosted on edge/edge core, responsible for data processing, state estimation, control algorithms, data storage); 3) User Entity (providing a User Interface FE split into 3D Visualization and Control Panel). Each FE communicates via ROS 2 DDS middleware, providing publish‑subscribe message passing, whereas point‑cloud clustering may be implemented using PCL and tracking with OpenCV. Resource management is achieved by deploying each FE to specific compute nodes, enabling realistic scaling and fault isolation. The absence of a dedicated FE for the Data Storage component illustrates the flexible mapping approach permitted by ISO 23247."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All intra‑vehicle software components communicate using a ROS2 middleware network. Inter‑entity communication—between the vehicle (Physical Twin Entity) and the Digital Twin Entity—is performed over the vehicle’s Wi‑Fi link. The system must satisfy a network latency requirement of at most 100 ms from the vehicle to the DT Entity (Requirement R7). The exact transport layer protocol (e.g., TCP or UDP) is not specified beyond the use of the Wi‑Fi network. Bandwidth, latency guarantees beyond the 100 ms target, redundancy, reliability or security protocols (such as encryption or authentication) are not mentioned in the documents.

"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment occurs at the edge: each logical entity (Physical Twin, Digital Twin, User Entity) is instantiated on a distinct hardware node, as described in Section IV.B. The primary compute node hosting the Digital Twin services runs on an NVIDIA Jetson Orin Nano, providing GPU‑accelerated point‑cloud processing and ROS 2 execution. Data Storage and Reporting FEs persist event logs and telemetry into a SQL relational database, presumably on a separate local or cloud server. The document provides no explicit scalability, fail‑over, or cloud‑integration details; deployment is therefore constrained to the referenced on‑premise edge platform and the associated databases."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system complies with ISO 23247 – Digital twin framework for manufacturing, specifically Part 2 – Reference Architecture. This standard prescribes an entity‑based framework that groups functionality into four main entities: the Observable Manufacturing Element (OME) representing the physical asset; the Data Collection and Device Control Entity, which gathers data from and issues control commands to the OME; the Digital Twin Entity, which provides the digital representation of the OME; and the User Entity, which offers user interfaces for monitoring and interacting with the Digital Twin. Each of these entities is further decomposed into functional entities (FEs) responsible for tasks such as data transformation, actuating the OME, providing human‑interpretable formats, or interfacing with the user. ISO 23247 does not mandate specific implementation mechanisms; however, the document cites OPC Unified Architecture as a potential protocol for integration. The system’s architecture, as described, follows the ISO 23247 reference architecture, ensuring that the DT can interoperate within the broader industrial digital twin ecosystem and adhere to the prescribed standards for manufacturing digital twins."
]