// C3: Physical sensing components
instance HokuyoLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-110LX LiDAR providing 2‑D laser scans for obstacle detection."
    DTDFVocab:producedData LiDARDataTransmitted
]

instance DepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering RGB‑D image streams."
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel‑encoder measurement of forward vehicle speed."
    DTDFVocab:producedData VehicleSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Servo‑feedback sensor reporting current steering angle."
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARSensor
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DepthCameraSensor
]

instance VehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C10: Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Point‑cloud stream generated from Hokuyo LiDAR scans."
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo ObjectTrackingFE, UIVisualizationFE
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames from Intel D435i camera."
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo UIVisualizationFE
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Real‑time vehicle speed measurement (m/s)."
    DTDFVocab:fromData VehicleSpeedDataTransmitted
    DTDFVocab:inputTo ACCComputationFE, UIVisualizationFE
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering angle (degrees)."
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo ACCComputationFE, UIVisualizationFE
]

// C10: Models
instance ObjectTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering and Kalman‑filter tracking of objects from LiDAR point clouds."
    DTDFVocab:inputTo ObjectTrackingFE
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm implementing ISO 15622 class I logic."
    DTDFVocab:inputTo ACCComputationFE
]

instance VisualizationModel : DTDFVocab:Model [
    base:desc "3‑D visualization model rendering vehicle state, projected path, and object tracks."
    DTDFVocab:inputTo UIVisualizationFE
]

// C11: Enablers
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Serializes, unit‑converts, and transmits sensor streams over Wi‑Fi ROS 2 topics."
    DTDFVocab:enables DataMonitoringService
]

instance ObjectTrackingFE : DTDFVocab:Enabler [
    base:desc "Consumes LiDAR point clouds, performs DBSCAN clustering and Kalman‑filter tracking, and outputs object tracks."
    DTDFVocab:enables DataMonitoringService
]

instance ACCComputationFE : DTDFVocab:Enabler [
    base:desc "Runs the ACC algorithm on external compute, providing speed set‑points per ISO 15622."
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService
]

instance UIVisualizationFE : DTDFVocab:Enabler [
    base:desc "User‑interface front‑end visualizing vehicle state, projected path, and object tracks; accepts operator commands."
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance SQLDatabaseFE : DTDFVocab:Enabler [
    base:desc "SQL database back‑end storing telemetry, object tracks, and generated reports."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time UI monitoring of vehicle speed, steering angle, projected path, and object tracks."
    DTDFVocab:provides RealTimeVehicleStateInsight, ProjectedPathInsight, ObjectTracksInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Off‑loads the ACC algorithm from the physical twin to the digital twin."
    DTDFVocab:provides ACCPerformanceInsight, OffloadACCComputationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, and trigger emergency braking via the UI."
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Displays current vehicle speed and steering angle in real time."
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Shows the predicted trajectory of the autonomous vehicle."
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Presents detected object tracks generated from LiDAR clustering."
]

instance ACCPerformanceInsight : DTDFVocab:Insight [
    base:desc "Reports ACC computed speed set‑point and lead‑vehicle detection status per ISO 15622."
]

// C17: Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets desired speed set‑point for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking, overriding all motion commands."
    DTDFVocab:IsAutomatic false
]

instance OffloadACCComputationAction : DTDFVocab:Action [
    base:desc "Automatic off‑loading of ACC computation to the digital twin."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity sends control commands (enable/disable ACC, modify desired speed, emergency‑brake command, and computed desired speed) back to the PT over the same Wi‑Fi/ROS 2 link. Commands are received by the Actuation FE on the Physical Twin Entity, which converts them to motor‑voltage and steering‑servo signals."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is designed for real‑time operation with an end‑to‑end network latency bound of ≤100 ms (per 3GPP TS 22.185) and clock synchronization accuracy of 100 ms across all DTS components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation follows the ISO 23247 reference architecture extended with a Physical Twin Entity (analogous to the OME). Functional Entities (Data Collection, Data Translation, Presentation, Controlling, Reporting, Actuation) are realized as separate ROS 2 packages deployed across the three physical hosts, communicating via ROS 2 topics over Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed primarily during the operational stage of the vehicle for monitoring, control, and remote management, and is also used in the development and testing phases to troubleshoot ACC behavior."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time fidelity is enforced by the ≤100 ms latency and clock‑sync constraints. Model validity is addressed by using established algorithms (DBSCAN, Kalman filter, ISO 15622 ACC logic) and by storing raw sensor data for offline verification. Safety‑critical operation mandates that the DT respect these timing bounds."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange between PT and DT occurs over a Wi‑Fi network using ROS 2 messaging. The Data Translation FE performs serialization, message‑type alignment, and unit conversion. No other transport protocol is specified; OPC UA is mentioned only as a possible alternative."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the Jetson Orin Nano on the vehicle. The Digital Twin Entity (ACC computation, data collection, reporting) runs on external compute hardware (e.g., a cloud server or workstation) hosting ROS 2 nodes and the SQL database. The User Entity (UI) runs on an operator workstation displaying 3‑D visualizations."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The design follows ISO 23247 (Digital Twin Manufacturing Framework) for the layered reference architecture, ISO 15622 for ACC functionality, ISO/IEC 30173 for digital‑twin concepts, and adopts the 3GPP TS 22.185 latency guideline. OPC UA (IEC 62541) is cited as an optional communication standard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations include the requirement for ≤100 ms end‑to‑end latency, 100 ms clock synchronization, and adherence to ISO 15622 ACC specifications for safe vehicle control. Specific cybersecurity mechanisms are not detailed in the document."
]