// C2: Acting Components
instance MotorActuationController : DTDFVocab:ActingComponent [
    base:desc "Converts desired speed commands into motor voltage commands via the Vedder Electronic Speed Controller, interfacing with the vehicle's motor."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Controls the steering angle of the vehicle, integrated into the lower-level chassis."
]

instance EmergencyBrakingSystem : DTDFVocab:ActingComponent [
    base:desc "Executes remote braking commands via the Digital Twin's Control Panel, sending halt signals to the vehicle's motor."
]

instance AdaptiveCruiseControlActuator : DTDFVocab:ActingComponent [
    base:desc "Adjusts the ego vehicle's speed based on lead vehicle detection, implemented via the Actuation Functional Entity in the Physical Twin Entity."
]

// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Captures 3D point clouds of the vehicle's environment using Hokuyo UST-10LX LiDAR sensor."
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelDeepsenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Provides depth perception and object detection using Intel Deepsense D435i Depth Camera."
    DTDFVocab:producedData CameraDepthData
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Continuously monitors ego vehicle speed, steering angle, and motor/servo states."
    DTDFVocab:producedData EgoVehicleStateData
]

instance JetsonOrinNanoAntenna : DTDFVocab:SensingComponent [
    base:desc "Facilitates wireless communication between the Physical Twin and Digital Twin via NVIDIA Jetson NX antenna."
    DTDFVocab:producedData NetworkCommunicationData
]

// C4: Physical-to-Virtual Interaction
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance ProcessedObjectTracksData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance CameraDepthData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iCamera
]

instance EgoVehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance NetworkCommunicationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JetsonOrinNanoAntenna
]

instance ACCRelevantEventsData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR, IntelDeepsenseD435iCamera, VehicleStateSensor
]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Implements DBSCAN clustering and Kalman filtering for object detection and tracking from LiDAR point clouds."
    DTDFVocab:inputTo ROS2Middleware, MATLABSimulinkEnabler
]

instance AdaptiveCruiseControlLogicModel : DTDFVocab:Model [
    base:desc "ISO 15622 compliant ACC logic for performance class I, executed in the Digital Twin."
    DTDFVocab:inputTo ROS2Middleware, Python38Enabler
]

instance EgoVehicleStateDataModel : DTDFVocab:Data [
    base:desc "Real-time data including speed, steering angle, and motor/servo states transmitted via ROS2 topics."
    DTDFVocab:fromData EgoVehicleStateData
    DTDFVocab:inputTo ROS2Middleware, DataStorageEnabler
]

instance ObjectTracksDataModel : DTDFVocab:Data [
    base:desc "Processed object tracks (size, position, velocity) from point cloud clustering and tracking."
    DTDFVocab:fromData ProcessedObjectTracksData
    DTDFVocab:inputTo ROS2Middleware, DataStorageEnabler
]

instance LiDARPointCloudDataModel : DTDFVocab:Data [
    base:desc "Raw 3D point clouds from Hokuyo UST-10LX LiDAR for visualization preprocessing."
    DTDFVocab:fromData LiDARPointCloudData
    DTDFVocab:inputTo ROS2Middleware, DataStorageEnabler
]

instance CameraDepthDataModel : DTDFVocab:Data [
    base:desc "Depth perception data from Intel Deepsense D435i camera for object detection."
    DTDFVocab:fromData CameraDepthData
    DTDFVocab:inputTo ROS2Middleware, DataStorageEnabler
]

instance ACCRelevantEventsDataModel : DTDFVocab:Data [
    base:desc "Events like lead vehicle detection and proximity alerts forwarded to the Digital Twin for decision-making."
    DTDFVocab:fromData ACCRelevantEventsData
    DTDFVocab:inputTo ROS2Middleware, DataStorageEnabler
]

instance PredictiveMaintenanceModel : DTDFVocab:Model [
    base:desc "Health monitoring of brake systems and motor wear via CREO Simulate integration."
    DTDFVocab:inputTo CREOSimulateEnabler, MATLABSimulinkEnabler
]

instance ThreeDVisualizationModel : DTDFVocab:Model [
    base:desc "3D representation of the vehicle and environment for real-time monitoring in the Digital Twin."
    DTDFVocab:inputTo ROS2Middleware, Python38Enabler
]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "Robot Operating System 2 (ROS2) middleware for inter-component communication and node lifecycle management."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, DataReportingService
]

instance NVIDIAJetpack50SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for Jetson Orin Nano development and deployment."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance Python38Enabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 for rapid prototyping and complex tasks like point cloud processing."
    DTDFVocab:enables DataMonitoringService, DataReportingService, ThreeDVisualizationService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ for high-performance ROS2 nodes and real-time control."
    DTDFVocab:enables ComputationOffloadingService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for complex systems like point cloud clustering and predictive maintenance."
]

instance CREOSimulateEnabler : DTDFVocab:Enabler [
    base:desc "CREO Simulate for offline analysis and predictive maintenance of vehicle components."
    DTDFVocab:enables PredictiveMaintenanceService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "SQL-based database for storing time-series data (vehicle state, object tracks)."
]

instance WiFiNetworkProtocol : DTDFVocab:Enabler [
    base:desc "Wi-Fi network with UDP/TCP protocols for inter-entity communication via ROS2 bridges."
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of ego vehicle state (speed, steering angle), object tracks, and projected driving path via 3D Visualization UI."
    DTDFVocab:provides EgoVehicleStateInsight, ObjectTrackVisualizationInsight, DrivingPathProjectionInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC logic in the Digital Twin (cloud/edge) to reduce Physical Twin computational load, with results sent back for actuation."
    DTDFVocab:provides ACCParameterOptimizationAction, ComputationalLoadReductionInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables enable/disable ACC, desired speed adjustment, and emergency braking via the Control Panel."
    DTDFVocab:provides ACCControlAction, EmergencyBrakingAction, DesiredSpeedAdjustmentAction
]

instance DataReportingService : DTDFVocab:Service [
    base:desc "Generates human-readable reports of vehicle state and object tracks as time-series data via the Reporting Functional Entity."
    DTDFVocab:provides VehicleStateReportInsight, ObjectTrackReportInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Supports health monitoring (e.g., brake systems) via simulator integration (e.g., CREO Simulate)."
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance ThreeDVisualizationService : DTDFVocab:Service [
    base:desc "Provides 3D visualization of the vehicle and environment for real-time monitoring."
    DTDFVocab:provides ThreeDEnvironmentVisualizationInsight
]

// C17: Insights/Actions
instance EgoVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of ego vehicle speed, steering angle, and motor/servo states."
]

instance ObjectTrackVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of processed object tracks (size, position, velocity) in the 3D environment."
]

instance DrivingPathProjectionInsight : DTDFVocab:Insight [
    base:desc "Projection of the vehicle's driving path based on current and predicted states."
]

instance ACCParameterOptimizationAction : DTDFVocab:Action [
    base:desc "Adjusts desired speed, following distance, and braking thresholds based on real-time data."
    DTDFVocab:IsAutomatic true
]

instance ComputationalLoadReductionInsight : DTDFVocab:Insight [
    base:desc "Reduction of computational load on the Physical Twin by offloading ACC logic to the Digital Twin."
]

instance ACCControlAction : DTDFVocab:Action [
    base:desc "Enables or disables the Adaptive Cruise Control system remotely."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Executes emergency braking commands remotely via the Digital Twin's Control Panel."
    DTDFVocab:IsAutomatic false
]

instance DesiredSpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjusts the desired speed of the ego vehicle based on user or system input."
    DTDFVocab:IsAutomatic false
]

instance VehicleStateReportInsight : DTDFVocab:Insight [
    base:desc "Human-readable reports of vehicle state (speed, steering angle, motor/servo states) as time-series data."
]

instance ObjectTrackReportInsight : DTDFVocab:Insight [
    base:desc "Human-readable reports of object tracks (position, velocity, size) as time-series data."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Health monitoring insights for brake systems and motor wear via CREO Simulate integration."
]

instance ThreeDEnvironmentVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization of the vehicle and its environment for real-time monitoring and decision support."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of object track deviations or vehicle state anomalies triggering alerts."
]

instance DriverAssistanceInsight : DTDFVocab:Insight [
    base:desc "Transparency reports (e.g., projected driving path) improving ADAS trust."
]

instance RemoteDiagnosticsInsight : DTDFVocab:Insight [
    base:desc "Data monitoring enabling developers to troubleshoot ACC logic without physical access."
]

// C1: System Under Study
instance AutonomousVehicleDigitalTwinSystem : DTDFVocab:SystemUnderStudy [
    base:desc "1/10th-scale autonomous vehicle retrofitted with autonomy components for Adaptive Cruise Control (ACC) Digital Twin development. Physical Twin consists of a Traxxas Slash 4x4 Premium vehicle modified with lower-level (steering/speed control) and upper-level (autonomy elements) chassis."
    DTDFVocab:hasEnvironment Environment
]

instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "On-vehicle component hosting NVIDIA Jetson Orin Nano, LiDAR, camera, and actuation systems."
    base:isContainedIn Environment
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Cloud/edge component hosting ACC logic, data collection, visualization, and remote management services."
    base:isContainedIn Environment
]

instance UserEntity : DTDFVocab:Component [
    base:desc "Remote user interface for monitoring and controlling the Digital Twin."
    base:isContainedIn Environment
]

instance Environment : DTDFVocab:Environment [
    base:desc "Operational environment for the autonomous vehicle Digital Twin system."
    base:contains AutonomousVehicleDigitalTwinSystem, PhysicalTwinEntity, DigitalTwinEntity, UserEntity
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Data transmitted from the DT to the PT includes: **1) Desired speed commands** computed by the **ACC Controlling FE** and sent to the **Actuation FE** for motor voltage conversion. **2) Remote management commands** (enable/disable ACC, set desired speed, emergency braking) via the **Control Panel User Interface FE**. **3) Actuation signals** for steering and motor control, synchronized with the PT’s clock (100 ms accuracy). **4) Data Storage FE** logs (via SQL database) are not directly sent to the PT but used for offline analysis."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates with **real-time synchronization** constrained by **R7 (100 ms end-to-end latency)** for ACC control and **R8 (100 ms clock synchronization accuracy)**. Services like **Data Monitoring** and **Remote Management** require **sub-second latency** (<100 ms) to maintain safety-critical operation. **Data Storage** and **Report Generation** are non-real-time, operating asynchronously. The **Physical-to-Virtual interaction** (sensor data) occurs at **perception cycle rates** (e.g., LiDAR/camera refresh rates), while **Virtual-to-Physical interaction** (actuation commands) aligns with **ACC control loops** (typically <100 ms)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation follows an **entity-based architecture** inspired by **ISO 23247**, comprising: **1) Physical Twin Entity**: Hosts **Point Cloud Clustering & Tracking** (Data Pre-Processing FE), **Actuation** (Actuation FE), and **Vehicle State** sensors. **2) Digital Twin Entity**: Hosts **ACC logic** (Controlling FE), **Data Collection** (Data Collecting FE), **Report Generation** (Reporting FE), and **Visualization Pre-Processing** (Presentation FE). **3) User Entity**: Hosts **3D Visualization** and **Control Panel** (both mapped to User Interface FE). **4) Cross-System Entity**: **Data Translation FE** for serialization and unit conversion. The constellation is **distributed** across hardware: PT (on-vehicle), DT (cloud/edge), and UI (remote)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers **design, development, and operation** stages of the PT’s lifecycle. **1) Design Phase**: Used as a **cyber-physical experimentation facility** for ACC algorithm validation via **3D CAD integration** and **simulator components** (e.g., MATLAB/Simulink). **2) Development Phase**: Supports **troubleshooting** via **data monitoring** and **remote management** for developers. **3) Operation Phase**: Enables **real-time optimization** (e.g., fuel economy via spark ignition DT), **health monitoring** (e.g., brake systems), and **predictive maintenance**. The DT represents the PT **as operated**, not as designed or manufactured."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through: **1) Real-Time Constraints**: **100 ms end-to-end latency** (3GPP V2V compliant) and **100 ms clock synchronization** for event ordering. **2) Data Accuracy**: **LiDAR + Camera fusion** for object tracking (DBSCAN + Kalman filter). **3) Validation**: **ISO 15622 compliance** for ACC logic (performance class I). **4) Verification**: **ROS2 node lifecycle management** ensures deterministic behavior. **5) Uncertainty Handling**: **Data Translation FE** performs unit conversions and error checking. **6) Safety**: **Emergency braking** overrides ACC commands for fail-safe operation. **7) Simulation Integration**: **CREO Simulate** for offline validation of predictive maintenance models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT-PT connection uses: **1) Network Protocol**: **Wi-Fi** for inter-entity communication (DT ↔ PT). **2) Intra-System Protocol**: **ROS2 topics** (UDP/TCP) for intra-entity data exchange. **3) Data Translation**: **Data Translation FE** serializes data, aligns message types, and performs unit conversions (e.g., motor voltage commands). **4) Synchronization**: **Clock synchronization** (100 ms accuracy) via **NTP-like mechanisms** (not specified in detail). **5) Latency**: **<100 ms end-to-end latency** (3GPP V2V compliant) enforced via **Wi-Fi + ROS2 optimizations**. **6) Security**: Not explicitly detailed but implied via **remote management authentication** (e.g., Control Panel access control)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed across **three hardware layers**: **1) Physical Twin (On-Vehicle)**: **NVIDIA Jetson Orin Nano** (compute), **LiDAR/Camera** (sensors), and **Vedder ESC** (actuation). **2) Digital Twin (Cloud/Edge)**: Hosts **ACC logic**, **Data Collection**, and **Reporting FEs** on external servers. **3) User Interface (Remote)**: **3D Visualization** and **Control Panel** accessed via web/mobile interfaces. **4) Data Storage**: **SQL database** (external to vehicle) for time-series data. The **Physical Twin Entity** is deployed on-vehicle, while the **Digital Twin Entity** is offloaded to cloud/edge for computation offloading."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration includes: **1) External Data Sources**: **3D CAD models** (for design phase validation) and **simulator data** (e.g., CREO Simulate). **2) Standardized Interfaces**: **ROS2 topics** and **ISO 23247 FEs** enable interoperability with other DTs or systems. **3) Cloud/Edge Services**: **Computation offloading** to external servers for ACC logic. **4) Product Lifecycle Management**: **Digital thread** integration for end-to-end vehicle data flow. **5) Third-Party Tools**: **MATLAB/Simulink** for complex algorithm development. **6) V2V/V2X Standards**: **3GPP V2V latency requirements** guide network design."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT adheres to the following standards: **1) ISO 23247**: Reference architecture for **entity-based DT design** (mapped to automotive use case). **2) ISO 15622**: **ACC system requirements** (performance class I compliance). **3) 3GPP TS 22.185**: **V2V communication latency** (<100 ms). **4) ROS2**: **Middleware standard** for inter-component communication. **5) IEC 62541 (OPC UA)**: Potential for **Data Translation FE** implementation (not explicitly used). The architecture also draws from **automotive IoT** and **cyber-physical systems** best practices."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety measures include: **1) Safety-Critical Constraints**: **100 ms latency/clock sync** for real-time operation. **2) Fail-Safe Mechanisms**: **Emergency braking** overrides ACC commands. **3) Remote Management Safeguards**: **Authentication** for Control Panel access (implied). **4) Data Integrity**: **Clock synchronization** ensures event ordering. **5) Redundancy**: **LiDAR + Camera fusion** for robust object tracking. **6) Compliance**: **ISO 15622** ensures ACC safety. **7) Network Security**: **Wi-Fi encryption** (not detailed) for DT-PT communication. **8) Human-in-the-Loop**: **Fully Autonomous Digital Twin** with **operator oversight** (per David & Bork taxonomy). Risks include **remote operation accidents** if latency exceeds 100 ms or clock sync fails."
]