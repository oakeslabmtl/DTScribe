// FulloeoDT: Digital Twin for 1/10‑scale autonomous vehicle

// Sensing components
instance HokuyoLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑110LX LiDAR producing raw point cloud data streams" 
    DTDFVocab:producedData LiDARDataTransmitted
]
instance IntelD435iDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera supplying RGB‑depth frames" 
    DTDFVocab:producedData DepthCameraDataTransmitted
]
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor sampling propulsion speed from the Jetson Orin Nano" 
    DTDFVocab:producedData SpeedDataTransmitted
]
instance VehicleSteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor sampling servo position from the Jetson Orin Nano" 
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// Physical‑to‑virtual transmitted data
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARSensor
]
instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCameraSensor
]
instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]
instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSteeringAngleSensor
]

// Data managed by the DT
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Processed LiDAR point cloud clusters for obstacle detection" 
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo DataCollectionEnabler, VisualizationEnabler
]
instance DepthFrameData : DTDFVocab:Data [
    base:desc "Processed depth camera frames for 3‑D mapping" 
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo DataCollectionEnabler, VisualizationEnabler
]
instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Time‑stamped vehicle speed telemetry" 
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo DataCollectionEnabler, VisualizationEnabler
]
instance VehicleSteeringAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped vehicle steering angle telemetry" 
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo DataCollectionEnabler, VisualizationEnabler
]
instance AccTelemetryData : DTDFVocab:Data [
    base:desc "ACC controller state data stored for analysis" 
    DTDFVocab:inputTo DataStorageEnabler
]

// Functional Models
instance AccControllerModel : DTDFVocab:Model [
    base:desc "ISO15622 compliant Adaptive Cruise Control controller" 
    DTDFVocab:inputTo AccControllerEnabler
]
instance DataCollectionModel : DTDFVocab:Model [
    base:desc "Data collection pipeline for LiDAR and camera streams" 
    DTDFVocab:inputTo DataCollectionEnabler
]
instance VisualizationModel : DTDFVocab:Model [
    base:desc "3‑D visualization engine rendering vehicle telemetry" 
    DTDFVocab:inputTo VisualizationEnabler
]
instance ReportingModel : DTDFVocab:Model [
    base:desc "Time‑series reporting engine generating performance logs" 
    DTDFVocab:inputTo ReportingEnabler
]
instance ActuationModel : DTDFVocab:Model [
    base:desc "Actuation FE translating desired speed to motor voltage commands" 
    DTDFVocab:inputTo ActuationEnabler
]
instance DataStorageModel : DTDFVocab:Model [
    base:desc "SQL‑based data storage for telemetry logs" 
    DTDFVocab:inputTo DataStorageEnabler
]

// Enablers
instance DataCollectionEnabler : DTDFVocab:Enabler [
    base:desc "Enables data collection services on the vehicle" 
    DTDFVocab:enables MonitoringService
]
instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enables real‑time 3‑D visualization of vehicle state" 
    DTDFVocab:enables VisualizationService
]
instance ReportingEnabler : DTDFVocab:Enabler [
    base:desc "Enables generation of time‑series reports for performance analysis" 
    DTDFVocab:enables ReportingService
]
instance ActuationEnabler : DTDFVocab:Enabler [
    base:desc "Enables remote actuation of vehicle steering and throttle" 
    DTDFVocab:enables RemoteManagementService
]
instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Enables off‑loaded SQL data storage for telemetry" 
    DTDFVocab:enables DataStorageService
]
instance AccControllerEnabler : DTDFVocab:Enabler [
    base:desc "Enables computation offloading of the ACC algorithm to the cloud" 
    DTDFVocab:enables ComputationOffloadingService
]
instance DebuggingEnabler : DTDFVocab:Enabler [
    base:desc "Enables remote debugging and performance analysis of the ACC system" 
    DTDFVocab:enables DebuggingService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitors vehicle telemetry and object tracks for real‑time analysis" 
    DTDFVocab:provides TimeSeriesReportInsight, ACCAccuracyPerformanceMetricInsight
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time 3‑D visualization and control panel UI" 
    DTDFVocab:provides ThreeDVisualizationInsight
]
instance ReportingService : DTDFVocab:Service [
    base:desc "Generates time‑series performance reports for operators and developers" 
    DTDFVocab:provides TimeSeriesReportInsight
]
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Manages ACC subsystem remotely; enables configuration changes" 
    DTDFVocab:provides AdjustDesiredSpeedAction, TriggerEmergencyBrakingAction, TuneControlParametersAction, EnableACCAction, DisableACCAction
]
instance DataStorageService : DTDFVocab:Service [
    base:desc "Stores telemetry data in an external SQL database" 
    DTDFVocab:provides TelemetryStorageInsight
]
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC computation to cloud or edge servers" 
    DTDFVocab:provides ComputationOffloadInsight
]
instance DebuggingService : DTDFVocab:Service [
    base:desc "Provides debugging and performance analysis for the ACC control law" 
    DTDFVocab:provides DebuggingInsight
]

// Insights
instance ThreeDVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides contextual 3‑D visualization of vehicle state and object tracks"
]
instance TimeSeriesReportInsight : DTDFVocab:Insight [
    base:desc "Provides time‑series reports of vehicle telemetry for performance analysis"
]
instance ACCAccuracyPerformanceMetricInsight : DTDFVocab:Insight [
    base:desc "Provides performance metric for ACC accuracy (deviation from desired speed)"
]
instance TelemetryStorageInsight : DTDFVocab:Insight [
    base:desc "Indicates successful storage of telemetry data in SQL database"
]
instance ComputationOffloadInsight : DTDFVocab:Insight [
    base:desc "Indicates successful offloading of ACC computation to the cloud"
]
instance DebuggingInsight : DTDFVocab:Insight [
    base:desc "Provides diagnostics and performance metrics for debugging the ACC system"
]

// Actions
instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Adjusts the desired speed setpoint for the ACC subsystem"
    DTDFVocab:IsAutomatic false
]
instance TriggerEmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Triggers emergency braking via the Actuation FE"
    DTDFVocab:IsAutomatic true
]
instance TuneControlParametersAction : DTDFVocab:Action [
    base:desc "Tunes control parameters of the ACC algorithm"
    DTDFVocab:IsAutomatic false
]
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables the Adaptive Cruise Control subsystem"
    DTDFVocab:IsAutomatic false
]
instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disables the Adaptive Cruise Control subsystem"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends ACC outputs and remote management commands back to the vehicle over Wi‑Fi. The Virtual‑to‑Physical FE transmits desired speed, enable/disable ACC flags, desired‑speed modifiers, and emergency‑braking commands. These are received by the Physical Twin Entity on the Jetson Orin Nano which actuates the vehicle via the ESC and steering servo."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in real‑time with an end‑to‑end latency requirement of ≤100 ms; all clocks are synchronized within 100 ms to ensure event ordering and timing consistency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "DT’s overall architecture follows the ISO 23247 entity‑based reference: Physical Twin Entity (carrying raw data and actuation), Digital Twin Entity (housing analysis, ACC control, data collection), User Entity (UI and remote commands), and Cross‑System Entity (data translation). ROS2 packages implement each Functional Entity; the Data Translation FE serializes and aligns messages; all entities are connected through a Wi‑Fi network and ROS2 DDS topics, orchestrating data flow from PT to DT and back."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (requirements R1–R8), architecture mapping to ISO 23247 RA, implementation as ROS2 nodes, validation against latency and functional requirements, deployment, and ongoing operation/telemetry; future upgrades are noted but not detailed."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT’s fidelity is ensured by maintaining 100 ms latency and 100 ms clock sync, allowing real‑time ACC execution. Validity of the ACC model is benchmarked against ISO 15622 behavior; data collection components are verified via on‑board monitoring and explicit reporting to operators. Uncertainty in LiDAR clustering is reduced by DBSCAN and Kalman filter; however, the paper acknowledges limitations in control fidelity at high‑speed scenarios since the PT is a 1/10‑scale prototype."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Intra‑entity communication uses ROS2 publish/subscribe over TCP‑ROS or UDP; inter‑entity communication between vehicle and DT occurs over a Wi‑Fi link, with Data Translation FE performing serialization, unit conversion, and message alignment; the connection is identified as a wireless V2X‑like 802.11n network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Distributed deployment: on‑board components (Physical Twin Entity, part of Digital Twin Entity) run on the Jetson Orin Nano; off‑load processing and user interfaces run on a remote edge or cloud server accessed over Wi‑Fi. The hosting infrastructure uses ROS2 deployment via containers or native binaries and an external SQL database for persistent storage."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 (Digital Twin Manufacturing Framework) defines the reference architecture and entity composition; ISO 15622 specifies the adaptive cruise control algorithm; ROS2 (DDS) provides middleware standard; optional OPC UA was mentioned as an alternative communication layer."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The system operates in a safety‑critical automotive context. Real‑time latency ≤ 100 ms and 100 ms clock synchronization support timely emergency braking. The ACC design follows ISO 15622, ensuring acceptable decision logic. The DT’s remote command channel is initiated over Wi‑Fi but explicit cybersecurity measures (e.g., authentication, encryption) are not described in the document."
]