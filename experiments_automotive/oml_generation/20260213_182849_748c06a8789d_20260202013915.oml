// C3: Physical sensing components
instance HokuyoUST110LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑110LX LiDAR generating 3‑D point clouds up to 40 Hz"
    DTDFVocab:producedData LiDARDataTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera providing RGB‑D frames up to 30 Hz"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST110LXLiDAR
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

// C10: Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 3‑D point‑cloud stream from LiDAR"
    DTDFVocab:fromData LiDARDataTransmitted
]

instance DepthCameraRGBDData : DTDFVocab:Data [
    base:desc "RGB‑D frames from depth camera"
    DTDFVocab:fromData DepthCameraDataTransmitted
]

// C10: Models/Data
instance PointCloudClusteringAndTrackingModel : DTDFVocab:Model [
    base:desc "Geometric processing of LiDAR point clouds for clustering and tracking objects"
]

instance DataTranslationModel : DTDFVocab:Model [
    base:desc "Serialises, aligns message types and performs unit conversions for transmitted streams"
]

instance ACCAlgorithmModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm (lead‑vehicle detection, speed‑setpoint calculation) executed in cloud"
]

// C11: Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS‑2 DDS middleware network interconnecting all ROS‑2 nodes and topics"
    DTDFVocab:enables DataMonitoringService,
                     ComputationOffloadingService,
                     RemoteManagementService
]

instance SQLStorageEnabler : DTDFVocab:Enabler [
    base:desc "Relational SQL database for persistent logging and report generation"
    DTDFVocab:enables DataMonitoringService
]

instance WiFiCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi radio link providing low‑latency bidirectional UDP transport between vehicle and DT"
    DTDFVocab:enables DataMonitoringService,
                     ComputationOffloadingService,
                     RemoteManagementService
]

instance CloudACCComputeEnabler : DTDFVocab:Enabler [
    base:desc "Containerised ACC service hosted on cloud compute resources"
    DTDFVocab:enables ComputationOffloadingService
]

instance WebDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard UI for real‑time visualization and operator controls"
    DTDFVocab:enables DataMonitoringService,
                     RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Streams real‑time vehicle state, projected path and nearby object tracks allows view, save and report generation"
    DTDFVocab:provides VehicleStateInsight,
                     ProjectedPathInsight,
                     ObjectTrackInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm in cloud and returns desired speed to vehicle for actuation"
    DTDFVocab:provides ACCSpeedSetpointInsight,
                     ActuationCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator UI enables/disables ACC, sets desired speed, and issues emergency brake"
    DTDFVocab:provides EnableACCAction,
                     DisableACCAction,
                     SetDesiredSpeedAction,
                     EmergencyBrakeAction
]

// C17: Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Current vehicle state (speed, position, heading) derived from sensor streams"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected driving path visualized in the 3‑D UI"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Tracks of nearby objects generated by the clustering model"
]

instance ACCSpeedSetpointInsight : DTDFVocab:Insight [
    base:desc "Desired speed setpoint calculated by the ACC algorithm"
]

// C17: Actions
instance ActuationCommandAction : DTDFVocab:Action [
    base:desc "Command sent to vehicle actuators to achieve desired speed"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets a specific desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance VehicleActuationComponent : DTDFVocab:ActingComponent [
    base:desc "Translates desired speed commands into voltage for Vedder ESC and PWM for steering servo, publishing on ROS‑2 topics"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin sends control commands back to the vehicle over the same Wi‑Fi/UDP link. Commands include the desired speed calculated by the off‑loaded ACC service, ACC enable/disable switches, and an emergency‑braking command. These messages are formatted by the Data Translation FE and routed through ROS 2 to the Actuation FE, which drives motor and steering actuators. The vehicle acknowledges execution via updated vehicle‑state messages, closing the feedback loop."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT requires that all participating devices maintain a shared notion of time for computation offloading. Clock synchronization must achieve an accuracy of 100 ms, which is the limit imposed by the hardware; standards for safety‑critical vehicular applications demand stricter synchronization, but the implemented system settles on the 100 ms bound. This synchronization interval defines the temporal granularity of data exchange between the Physical Twin Entity and the Digital Twin Entity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration is achieved by mapping each Functional Entity to an individual ROS 2 package; a package contains one or more ROS 2 nodes that implement the FE’s functionality. Inter‑entity communication leverages ROS 2 middleware, providing runtime coordination across the three entities deployed on distinct hardware. The design follows the ISO 23247 reference architecture, with the Physical Twin Entity exposing sensor/actuator resources, the Digital Twin Entity processing and representing them, and the User Entity offering 3‑D visualization and control panels. Resource management is implicit in the ROS 2 node lifecycle and the separate hardware allocation per entity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Intra‑twin software components communicate via a ROS 2 network (publish/subscribe), while inter‑entity communication between the physical twin and the digital twin uses a Wi‑Fi LAN with UDP at the transport layer. The network topology consists of a single ROS 2 domain on the DT side and a Wi‑Fi point‑to‑point link to the vehicle. No explicit bandwidth, latency, redundancy, or security mechanisms are described in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The ISO 23247 framework permits the use of standard data‑exchange protocols such as OPC Unified Architecture (OPC UA) for integration with external enterprise systems, although the presented automotive DT does not explicitly instantiate such a protocol. Consequently, external integration is conceptually supported via OPC UA, but no concrete external system connection is described in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is explicitly based on ISO 23247 (parts 1‑4), adopting its entity‑based reference architecture (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity, and Functional Entities). Device coordination may employ OPC Unified Architecture, and the design requires clock synchronization with an accuracy of 100 ms, satisfying safety‑critical vehicular application standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The case study notes that the ISO 23247 reference architecture does not cover safety‑critical requirements; it recommends elevating safety to a first‑class concern by adopting the automotive functional‑safety standard ISO 26262. Security aspects are identified as needing further research and alignment with existing automotive standards, but no concrete security mechanisms are described."
]