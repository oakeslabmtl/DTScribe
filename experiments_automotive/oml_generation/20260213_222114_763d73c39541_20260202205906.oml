]

instance PhysiologicalData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysiologicalSensor
]

// C10: Models/Data
instance DigitalTwinEntity : DTDFVocab:Model [
    base:desc "Entity-based digital representation of physical systems following ISO 23247 architecture, integrating geometric, behavioral, and analytical models for each Observable Manufacturing Element"
    DTDFVocab:inputTo DataPreProcessingFunctionalEntity, DigitalTwinSimulationEngine
]

