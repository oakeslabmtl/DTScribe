// C2: Acting Components
instance PowertrainActuator : DTDFVocab:ActingComponent [
    base:desc "Remote control interface for powertrain actuation via standardized protocols (e.g., OPC UA) with safety constraints managed through entity-based framework for bidirectional control with ECUs"
]

