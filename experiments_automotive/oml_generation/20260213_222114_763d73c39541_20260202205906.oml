    base:desc "Autonomous collision avoidance actuator for satellite propulsion systems, controlled via digital twin-driven trajectory prediction and real-time command execution"
]

instance RoboticArmPIDController : DTDFVocab:ActingComponent [
    base:desc "Self-tuning PID controller for robotic arms using digital twin feedback loops for adaptive control in industrial IoT applications"
]

instance BatteryThermalManagementActuator : DTDFVocab:ActingComponent [
    base:desc "Thermal management actuator for battery systems, integrating digital twin SoC/SoH estimation with real-time stress modeling for efficiency optimization"
]

// C3: Physical Sensing Components
instance LidarSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency LiDAR sensor for automotive vehicle state monitoring, producing raw point cloud data at 1kHz+ for ACC and path projection"
    DTDFVocab:producedData LidarPointCloudData
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Comprehensive sensor suite capturing motor actuation, steering servo angles, and vehicle state metrics for real-time digital twin synchronization"
