]

instance BatterySoCHSensor : DTDFVocab:SensingComponent [
    base:desc "High-precision state-of-charge/state-of-health sensor for battery systems with integrated thermal and electrical stress monitoring"
    DTDFVocab:producedData BatteryTelemetryData
]

instance SatelliteTrajectorySensor : DTDFVocab:SensingComponent [
    base:desc "Space-based sensor suite for satellite trajectory tracking and debris cloud detection, enabling real-time collision avoidance simulations"
    DTDFVocab:producedData SatelliteOrbitData
]

instance ManufacturingProcessSensor : DTDFVocab:SensingComponent [
    base:desc "Industrial IoT sensor network for manufacturing process monitoring, capturing discrete-event and continuous process data for predictive maintenance"
    DTDFVocab:producedData ProcessTelemetryData
]

instance PhysiologicalSensor : DTDFVocab:SensingComponent [
    base:desc "Biomedical sensor suite for cyber-biophysical systems capturing ECG, EEG, and other physiological metrics for real-time digital twin modeling"
    DTDFVocab:producedData PhysiologicalData
]

// C4: Physical-to-Virtual Interaction
instance LidarPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LidarSensor
]

instance VehicleStateTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance BatteryTelemetryData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BatterySoCHSensor
]

instance SatelliteOrbitData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SatelliteTrajectorySensor
]

instance ProcessTelemetryData : DTDFVocab:DataTransmitted [
