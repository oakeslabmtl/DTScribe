// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST 10LX LiDAR sensor providing raw point‑cloud data at 10 Hz"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]
instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera delivering RGB‑D frames for environment perception"
    DTDFVocab:producedData DepthImageTransmitted
]
instance VehicleStateReceiver : DTDFVocab:SensingComponent [
    base:desc "Vehicle ECU interface emitting speed, acceleration and steering angle over CAN"
    DTDFVocab:producedData VehicleStateTransmitted
]

// C4: Physical‑to‑Virtual Interaction
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]
instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]
instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateReceiver
]

// C10: Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud captured by Hokuyo UST 10LX"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, PreProcessingEnabler, ROS2NetworkEnabler
]
instance DepthImageData : DTDFVocab:Data [
    base:desc "RGB‑D frames from Intel Deepsense D435i"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, ROS2NetworkEnabler
]
instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle speed, acceleration and steering angle from ECU"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, ROS2NetworkEnabler
]

// C11: Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247 Data Translation FE that serialises and unit‑converts vehicle data streams"
    DTDFVocab:enables ComputationOffloadingService
]
instance PreProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Point Cloud Clustering & Tracking Data Pre‑Processing FE that denoises and tracks LiDAR data"
    DTDFVocab:enables DataMonitoringService
]
instance ROS2NetworkEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware facilitating UDP/Wi‑Fi based intra‑vehicle communication"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]
instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D Visualization FE rendering vehicle state, projected path and obstacle tracks on the Virtual Cockpit"
    DTDFVocab:enables DataMonitoringService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Displays real‑time vehicle state, projected driving path and detected object tracks in the Virtual Cockpit"
    DTDFVocab:provides LiveVehicleStateInsight, LiveObjectTrackInsight
]
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Transfers ACC algorithm to the cloud, computes desired speed from lead vehicle distance and streams the result back"
    DTDFVocab:provides ComputeDesiredSpeedAction
]
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables remote ACC control: enable/disable ACC, set desired speed, and issue emergency braking"
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance LiveVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into vehicle speed, acceleration and heading for operator awareness"
]
instance LiveObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Insight into tracked obstacles and their predicted motion for visualization"
]

// C17: Actions
instance ComputeDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Computes desired speed to maintain safe following distance using ACC logic"
    DTDFVocab:IsAutomatic true
]
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables the Adaptive Cruise Control module on the vehicle"
    DTDFVocab:IsAutomatic false
]
instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets desired speed value for ACC operation"
    DTDFVocab:IsAutomatic false
]
instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issues emergency braking command to vehicle actuators"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance VedderESCActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller driving vehicle propulsion, accepts throttle commands from ACC"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control flows from the Digital Twin to the Physical Twin are issued through the Motor Actuation FE and Steering Servo Actuation FE components, which send actuation commands to the vehicle’s motors and steering servos. The message format, validation or authentication mechanisms, conflict‑resolution strategies, or command‑execution confirmation protocols are not described in the document."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin maintains a shared notion of time across its physical and digital layers, with a synchronization accuracy target of 100 ms to satisfy safety‑critical vehicular standards. This precision is mandated by hardware limitations and aligns with external timing standards that require sub‑100 ms coherence between physical devices and their digital replicas."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows the ISO 23247 reference architecture, mapping each software component to a Functional Element (FE) and implementing each FE as a separate ROS 2 package containing one or more ROS 2 nodes. The architecture partitions the twin into three primary entities—User, Digital Twin, and Physical Twin—each mapped to dedicated hardware components. The Digital Twin Entity houses data management, control logic, and high‑level analytics; the Physical Twin Entity encapsulates sensor interfaces, data pre‑processing, point‑cloud clustering, and actuation; the User Entity hosts the User Interface FE, split into visualization and control panels. This entity‑based, ROS 2‑centric orchestration allows for fine‑grained resource allocation and execution across heterogeneous compute nodes, while deviating from ISO 23247 by making the Physical Twin Entity host general automotive functionality beyond the standard’s scope."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Software components communicate internally via a ROS 2 middleware network, while inter‑entity communication between the Digital Twin and the Physical Twin occurs over a Wi‑Fi link using UDP as the transport protocol. The document does not specify the network topology, bandwidth, latency requirements, reliability or redundancy mechanisms, or security protocols for this communication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The deployment architecture is illustrated in Figure 2, but the document contains no explicit details on hosting platforms (cloud/edge/on‑premise), computational or storage requirements, scalability mechanisms, supported deployment models, or availability/reliability assurance. Not in Document"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with ISO 23247 (Digital twin framework for manufacturing). The system follows the reference architecture defined in Part 2 of ISO 23247, comprising four entities: the Observable Manufacturing Element (OME), the Data Collection and Device Control Entity, the Digital Twin Entity, and the User Entity, each of which is further subdivided into Functional Entities (FEs). While ISO 23247 does not prescribe specific implementation technologies, it encourages the use of standardized industrial protocols such as OPC Unified Architecture (OPC UA). The provided implementation demonstrates the use of an OPC UA‑based data gateway in a GitHub repository (https://github.com/McSCert/Automotive-Digital-Twin) and a public demonstration video on YouTube (https://youtu.be/Rv-sJJQc3WU). The system therefore adheres to industry‑grade interoperability standards and indicates potential certification pathways through ISO 23247."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The design complies with ISO 26262‑1:2018 for functional safety of road vehicles, explicitly addressing the safety‑critical nature of the adaptive cruise control (ACC) subsystem. It also conforms to ISO 15622:2018, which specifies the performance requirements and test procedures for ACC systems. For V2X interoperability, the system follows the 3GPP TS 22.185 service‑requirements specification, which defines message latency limits, payload constraints and related service parameters for vehicular communications."
]