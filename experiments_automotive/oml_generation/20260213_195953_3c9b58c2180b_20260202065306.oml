// Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR for point cloud data"
    DTDFVocab:producedData HokuyoPointCloudDataTransmitted
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i Depth Camera for depth perception"
    DTDFVocab:producedData IntelD435iDepthDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor for vehicle speed measurement"
    DTDFVocab:producedData VehicleSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor for steering angle measurement"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// Data Transmitted
instance HokuyoPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance IntelD435iDepthDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]

instance VehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Data Instances
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data from Hokuyo UST-10LX"
    DTDFVocab:fromData HokuyoPointCloudDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkPointCloudProcessing
]

instance DepthCameraData : DTDFVocab:Data [
    base:desc "Depth perception data from Intel D435i"
    DTDFVocab:fromData IntelD435iDepthDataTransmitted
    DTDFVocab:inputTo NVIDIAJetpackSDK
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed measurements transmitted to digital twin"
    DTDFVocab:fromData VehicleSpeedDataTransmitted
    DTDFVocab:inputTo SQLDatabase, ROS2Middleware
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle measurements transmitted to digital twin"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo SQLDatabase, ROS2Middleware
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Tracked object positions and velocities from Kalman filter"
    DTDFVocab:fromData HokuyoPointCloudDataTransmitted
    DTDFVocab:inputTo SQLDatabase, ROS2Middleware
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Current vehicle speed and steering angle state data"
    DTDFVocab:fromData VehicleSpeedDataTransmitted, SteeringAngleDataTransmitted
    DTDFVocab:inputTo SQLDatabase
]

// Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN algorithm for point cloud clustering into objects"
    DTDFVocab:inputTo MATLABSimulinkPointCloudProcessing
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter for tracking object motion and maintaining tracks"
    DTDFVocab:inputTo MATLABSimulinkPointCloudProcessing
]

instance ACCControlLogicModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control logic based on ISO 15622 standard"
    DTDFVocab:inputTo ACCComputationEnabler
]

// Enablers
instance MATLABSimulinkPointCloudProcessing : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for point cloud processing and DBSCAN clustering"
    DTDFVocab:enables DataMonitoringService
]

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for real-time communication between physical and virtual components"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService, ComputationOffloadingService
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL database for storing vehicle state and object tracks"
    DTDFVocab:enables DataMonitoringService
]

instance NVIDIAJetpackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for AI processing on Jetson Orin Nano"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Python/C++ implementation of ISO 15622-based ACC control logic"
    DTDFVocab:enables ComputationOffloadingService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization, saving, and reporting of vehicle state data"
    DTDFVocab:provides ObjectTracksInsight, DrivingPathInsight, VehicleStateDataInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Execution of Adaptive Cruise Control system on digital twin"
    DTDFVocab:provides ACCControlAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management via UI for enabling/disabling ACC, setting speed, and emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakingAction
]

// Insights
instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Real-time display of detected object tracks for driver awareness"
]

instance DrivingPathInsight : DTDFVocab:Insight [
    base:desc "Projected driving path based on object tracks and vehicle state"
]

instance VehicleStateDataInsight : DTDFVocab:Insight [
    base:desc "Current vehicle speed, steering angle, and other state data visualization"
]

// Actions
instance ACCControlAction : DTDFVocab:Action [
    base:desc "Automatic control of vehicle speed and following distance via ACC system"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control via remote UI"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control via remote UI"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set desired speed for ACC via remote UI"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Trigger emergency braking via remote UI"
    DTDFVocab:IsAutomatic false
]

// Physical Acting Components
instance VedderESC : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller converting desired speed to motor voltage commands"
]

instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Steering servo for controlling vehicle direction"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Transmission of motor voltage commands for speed control, steering angle commands, and emergency braking signals to the physical vehicle."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Network latency ≤100 ms between vehicle and DT Entity, with clock synchronization accuracy of 100 ms across all components per 3GPP V2V communication requirements."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Structured into Physical Twin Entity (not in ISO 23247), Digital Twin Entity, User Entity, and Cross-System Entity (Data Translation FE), with each Functional Entity implemented as ROS2 packages."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational phase (as operated) for ACC system monitoring and control during vehicle operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "ROS2 network for intra-component communication, Wi-Fi for inter-entity communication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity deployed on vehicle-mounted Jetson Orin Nano; Digital Twin Entity and User Entity hosted externally with data stored in cloud-based SQL database."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 Digital Twin Manufacturing Framework reference architecture adapted for automotive systems."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety-critical requirements include 100 ms network latency and clock synchronization; ACC implemented per ISO 15622 Performance Class I. No specific cybersecurity measures detailed."
]