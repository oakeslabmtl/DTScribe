// C1: Physical Sensing Components
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Real-time streaming sensor for vehicle speed data (e.g., speedometer readings) via ROS2 topics"
]

instance AccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency sensor measuring vehicle acceleration (0-100 m/s² range) for state monitoring"
]

instance EnvironmentalObstacleSensor : DTDFVocab:SensingComponent [
    base:desc "Obstacle detection sensor (likely LiDAR) providing environmental awareness data for state visualization"
]

instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing spatial mapping data (≤100ms latency requirement) via ROS2 topics"
]

instance DepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera for multimodal spatial mapping integration"
]

instance MotorVoltageSensor : DTDFVocab:SensingComponent [
    base:desc "Motor actuation voltage/current sensor providing feedback for closed-loop control"
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Steering servo position sensor for precise steering command verification"
]

// C2: Produced Data Types
instance VehicleSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance AccelerationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AccelerationSensor
]

instance ObstacleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalObstacleSensor
]

instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance DepthCameraData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DepthCameraSensor
]

instance MotorFeedbackData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorVoltageSensor
]

instance SteeringFeedbackData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
]

// C3: Data Storage Components
instance VehicleStateDatabase : DTDFVocab:Data [
    base:desc "Structured SQL database storing aggregated vehicle state data (speed, acceleration, position) for historical analysis"
    DTDFVocab:fromData VehicleSpeedData, AccelerationData, ObstacleData
]

instance PointCloudDatabase : DTDFVocab:Data [
    base:desc "SQL database storing processed LiDAR point cloud data for spatial mapping analysis"
    DTDFVocab:fromData LiDARPointCloudData
]

instance ActuationFeedbackDatabase : DTDFVocab:Data [
    base:desc "Database storing motor and steering feedback data for closed-loop control validation"
    DTDFVocab:fromData MotorFeedbackData, SteeringFeedbackData
]

instance RealTimeTelemetryDatabase : DTDFVocab:Data [
    base:desc "Real-time SQL database for streaming vehicle telemetry data via ROS2 topics"
]

// C4: Functional Entities
instance DataTranslationFE : DTDFVocab:FunctionalEntity [
    base:desc "Data Translation Functional Entity serializing and aligning ROS2 message types with unit conversions"
]

instance PointCloudClusteringFE : DTDFVocab:FunctionalEntity [
    base:desc "Point Cloud Clustering & Tracking FE processing LiDAR data via DBSCAN clustering algorithm"
    DTDFVocab:inputTo DBSCANClustering
]

instance ActuationFeedbackFE : DTDFVocab:FunctionalEntity [
    base:desc "Actuation Feedback Functional Entity validating motor/steering response data"
]

instance DataCollectingFE : DTDFVocab:FunctionalEntity [
    base:desc "Data Collection Functional Entity managing ROS2-based data collection pipeline"
]

instance ReportingFE : DTDFVocab:FunctionalEntity [
    base:desc "Reporting Functional Entity generating structured reports from processed data"
]

// C5: Enablers/Technical Tools
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "Robot Operating System 2 middleware enabling modular communication between sensors, AI modules, and DT components"
    DTDFVocab:enables DataTranslationFE, DataCollectingFE
    DTDFVocab:inputTo DBSCANClustering
]

instance NVIDIAJetpack : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK optimizing AI workloads on Jetson devices for low-latency processing"
    DTDFVocab:inputTo ComputationalOffloadingService
]

instance PythonScripting : DTDFVocab:Enabler [
    base:desc "Python 3.8 scripting environment for data processing and control logic implementation"
    DTDFVocab:inputTo DataTranslationFE
]

instance CPlusPlus : DTDFVocab:Enabler [
    base:desc "C++ development environment for performance-critical sensor fusion pipelines"
    DTDFVocab:inputTo PointCloudClusteringFE
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink platform for AI model prototyping and digital twin simulation validation"
    DTDFVocab:inputTo SimulationOptimizationService
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL database management system for structured storage of vehicle telemetry and DT state data"
    DTDFVocab:inputTo VehicleStateDatabase, ActuationFeedbackDatabase
]

instance DBSCANClustering : DTDFVocab:Enabler [
    base:desc "DBSCAN clustering algorithm for point cloud processing and dynamic object tracking"
    DTDFVocab:inputTo PointCloudClusteringFE
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time streaming and aggregation of sensor data (speed, acceleration, obstacles) via ROS2 for state visualization and anomaly detection"
    DTDFVocab:provides RealTimeStateInsight
]

instance ComputationalOffloadingService : DTDFVocab:Service [
    base:desc "Offloading heavy computational tasks (e.g., ACC algorithm execution) to edge devices for low-latency processing"
    DTDFVocab:provides LowLatencyProcessingAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote activation/deactivation of ACC features and dynamic speed setting via cloud-based interfaces"
    DTDFVocab:provides RemoteControlAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance alerts for sensor degradation detection and system health monitoring"
    DTDFVocab:provides MaintenanceAlertInsight
]

instance SimulationOptimizationService : DTDFVocab:Service [
    base:desc "Simulation-driven optimization of autonomous driving parameters using digital twin simulation"
    DTDFVocab:provides ParameterOptimizationAction
]

// C7: Models
instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "ACC (Adaptive Control Coefficient) analytical model for real-time speed regulation and obstacle avoidance"
]

instance PointCloudTrackingModel : DTDFVocab:Model [
    base:desc "Geometric model for LiDAR point cloud clustering and dynamic object tracking using DBSCAN algorithm"
]

instance VehicleBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model implementing closed-loop control algorithms for motor/steering actuation"
]

// C8: Insights/Actions
instance RealTimeStateInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of vehicle state parameters (speed, acceleration, position) for operational monitoring"
]

instance LowLatencyProcessingAction : DTDFVocab:Action [
    base:desc "Automatic execution of heavy computational tasks on edge devices with 100ms latency"
    DTDFVocab:IsAutomatic true
]

instance MaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance alerts triggered by sensor degradation detection in the digital twin"
]

instance ParameterOptimizationAction : DTDFVocab:Action [
    base:desc "Automated optimization of autonomous driving parameters through simulation-based tuning"
    DTDFVocab:IsAutomatic true
]

instance RemoteControlAction : DTDFVocab:Action [
    base:desc "Remote activation/deactivation of ACC features via cloud interface with user confirmation"
    DTDFVocab:IsAutomatic false
]

// C9: Physical Twin Entity Components
instance VehicleChassis : DTDFVocab:Component [
    base:desc "Physical chassis subsystem including engine, transmission, and drivetrain components"
    base:contains PowertrainSubsystem
]

instance PowertrainSubsystem : DTDFVocab:Component [
    base:desc "Engine and transmission components managing power delivery to wheels"
    base:contains MotorDriver, TransmissionController
]

instance MotorDriver : DTDFVocab:Component [
    base:desc "Motor driver controlling speed via voltage commands for powertrain actuation"
]

instance TransmissionController : DTDFVocab:Component [
    base:desc "Transmission controller managing gear ratios for optimal power delivery"
]

instance SteeringSystem : DTDFVocab:Component [
    base:desc "Steering servo mechanism for precise lane-keeping control"
]

instance SensorPerceptionUnit : DTDFVocab:Component [
    base:desc "Sensing and perception unit containing LiDAR, depth cameras, and radar for environmental awareness"
    base:contains LiDARUnit, CameraUnit
]

instance LiDARUnit : DTDFVocab:Component [
    base:desc "Hokuyo UST-10LX LiDAR system providing spatial mapping data (≤100ms latency)"
]

instance CameraUnit : DTDFVocab:Component [
    base:desc "Intel Deepsense D435i depth camera for multimodal spatial mapping integration"
]

instance ControlElectronics : DTDFVocab:Component [
    base:desc "Embedded processors and microcontrollers managing ACC algorithms and system control"
    base:contains ACCAlgorithmController, SafetyFirmware
]

instance ACCAlgorithmController : DTDFVocab:Component [
    base:desc "Microcontroller implementing adaptive cruise control algorithms"
]

instance SafetyFirmware : DTDFVocab:Component [
    base:desc "Embedded firmware enforcing safety constraints for critical actuation systems"
]

// C12: Digital Twin Entity Components
instance DataManagementComponent : DTDFVocab:Component [
    base:desc "Centralized data management component handling data aggregation and processing"
    base:contains DataAggregationModule, DataValidationModule
]

instance DataAggregationModule : DTDFVocab:Component [
    base:desc "Module aggregating real-time sensor data for state visualization"
]

instance DataValidationModule : DTDFVocab:Component [
    base:desc "Module validating data quality through consistency checks and error correction"
]

instance ControlComponent : DTDFVocab:Component [
    base:desc "Control component implementing ACC algorithms and actuation commands"
    base:contains ACCController, ActuationCoordinator
]

instance ACCController : DTDFVocab:Component [
    base:desc "Adaptive Cruise Control controller implementing speed regulation algorithms"
]

instance ActuationCoordinator : DTDFVocab:Component [
    base:desc "Component coordinating actuation commands between digital twin and physical system"
]

// C13: User Interface Components
instance MonitoringDashboard : DTDFVocab:Component [
    base:desc "3D visualization interface showing real-time vehicle state and environmental data"
    base:contains StateVisualizationPanel, ObstacleVisualizationPanel
]

instance StateVisualizationPanel : DTDFVocab:Component [
    base:desc "Panel displaying vehicle speed, acceleration, and position metrics"
]

instance ObstacleVisualizationPanel : DTDFVocab:Component [
    base:desc "Panel showing detected obstacles and spatial mapping data"
]

instance ControlPanel : DTDFVocab:Component [
    base:desc "User interface for remote activation/deactivation of ACC features and speed settings"
