// ---------------------------------------------------------------
// C2: Acting Components
// ---------------------------------------------------------------
instance MotorVoltageCommandActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage command interface that drives vehicle speed, realized in the Actuation Functional Entity of the Physical Twin"
]

instance SteeringServoCommandActuator : DTDFVocab:ActingComponent [
    base:desc "Steering‑servo command interface for steering angle control, realized in the Actuation Functional Entity of the Physical Twin"
]

// ---------------------------------------------------------------
// C3: Physical Sensing Components
// ---------------------------------------------------------------
instance HokuyoLiDARUST10LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2‑D LiDAR providing raw point‑cloud scans over ROS2 topics"
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering depth images via ROS2 topics"
    DTDFVocab:producedData DepthImageDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board vehicle state sensor measuring instantaneous speed, published on a ROS2 topic"
    DTDFVocab:producedData VehicleSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring steering wheel angle, published on a ROS2 topic"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// ---------------------------------------------------------------
// C4: Physical‑to‑Virtual Interaction (Data Transmitted)
// ---------------------------------------------------------------
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARUST10LX
]

instance DepthImageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

instance VehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// ---------------------------------------------------------------
// C10: Data Instances
// ---------------------------------------------------------------
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data used for object detection and tracking"
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames used for scene understanding"
    DTDFVocab:fromData DepthImageDataTransmitted
    DTDFVocab:inputTo DepthProcessingEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed measurement feeding ego‑state estimation and ACC"
    DTDFVocab:fromData VehicleSpeedDataTransmitted
    DTDFVocab:inputTo VehicleStateEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle measurement feeding ego‑state estimation and ACC"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo VehicleStateEnabler
]

// ---------------------------------------------------------------
// C10: Models
// ---------------------------------------------------------------
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering algorithm implemented in MATLAB/Simulink for object segmentation"
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance KalmanTrackerModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based multi‑object tracker implemented in C++ for maintaining object tracks"
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) control model compliant with ISO 15622 performance class I"
    DTDFVocab:inputTo VehicleStateEnabler
]

// ---------------------------------------------------------------
// C11: Enablers (Processing & Tooling)
// ---------------------------------------------------------------
instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing FE that consumes LiDAR point‑cloud and depth data, applies DBSCAN clustering and Kalman tracking"
    DTDFVocab:enables DataMonitoringService
]

instance DepthProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Depth‑image processing FE (e.g., for obstacle distance extraction) supporting monitoring visualisation"
    DTDFVocab:enables DataMonitoringService
]

instance VehicleStateEnabler : DTDFVocab:Enabler [
    base:desc "FE that fuses speed, steering angle and processed object data to produce ego‑state and ACC decisions"
    DTDFVocab:enables ComputationOffloadingService
]

instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware providing publish/subscribe communication between all functional entities"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database storing collected sensor data, clustering/tracking results, and ACC logs for reporting"
    DTDFVocab:enables RemoteManagementService
]

// ---------------------------------------------------------------
// C6: Services
// ---------------------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI displaying speed, steering angle, object tracks and projected path"
    DTDFVocab:provides VehicleStateInsight, ObjectTracksInsight, ProjectedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm runs in the DT and returns desired speed to the Physical Twin"
    DTDFVocab:provides DesiredSpeedInsight, AdjustSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI enables operators to enable/disable ACC, set target speed, trigger emergency brake, and generate reports"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetTargetSpeedAction, EmergencyBrakeAction, ReportGenerationInsight
]

// ---------------------------------------------------------------
// C17: Insights
// ---------------------------------------------------------------
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight showing current vehicle speed and steering angle in real time"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Insight presenting clustered object tracks derived from LiDAR point‑clouds"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Insight visualising the projected future path of the vehicle based on current state"
]

instance DesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the speed command computed by the ACC control model"
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight providing post‑mission analysis reports derived from stored SQL data"
]

// ---------------------------------------------------------------
// C17: Actions
// ---------------------------------------------------------------
instance AdjustSpeedAction : DTDFVocab:Action [
    base:desc "Action to set the vehicle's desired speed as output by the ACC algorithm"
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable the Adaptive Cruise Control subsystem"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Action to disable the Adaptive Cruise Control subsystem"
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Action allowing the operator to set a target speed for the ACC controller"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action that triggers an immediate emergency brake command via the motor voltage actuator"
    DTDFVocab:IsAutomatic false
]

// ---------------------------------------------------------------
// Environment & Components (Physical Twin Entity)
// ---------------------------------------------------------------
instance PhysicalTwinComponent : DTDFVocab:Component [
    base:desc "Physical Twin Entity deployed on NVIDIA Jetson NX/Orin Nano, containing all sensing and acting hardware"
]

instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:contains MotorVoltageCommandActuator, SteeringServoCommandActuator,
                 HokuyoLiDARUST10LX, IntelDeepSenseD435iDepthCamera,
                 VehicleSpeedSensor, SteeringAngleSensor,
                 PhysicalTwinComponent
]

// ---------------------------------------------------------------
// Environment & Components (Digital Twin Entity)
// ---------------------------------------------------------------
instance DigitalTwinComponent : DTDFVocab:Component [
    base:desc "Digital Twin Entity hosted on cloud/edge server, running ROS 2 packages for data collection, translation, ACC and UI services"
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains DigitalTwinComponent
]

// ---------------------------------------------------------------
// Environment & Components (User Entity)
// ---------------------------------------------------------------
instance UserWorkstationComponent : DTDFVocab:Component [
    base:desc "User Entity providing UI for monitoring, remote management and decision support"
]

instance UserWorkstationEnvironment : DTDFVocab:Environment [
    base:contains UserWorkstationComponent
]

// ---------------------------------------------------------------
// Environment & Components (Cross‑System Entity)
// ---------------------------------------------------------------
instance CrossSystemComponent : DTDFVocab:Component [
    base:desc "Cross‑System Entity handling message serialization, unit conversion and alignment between Physical and Digital Twins"
]

instance CrossSystemEnvironment : DTDFVocab:Environment [
    base:contains CrossSystemComponent
]

// ---------------------------------------------------------------
// Additional Enabler for Data Translation (Cross‑System)
// ---------------------------------------------------------------
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247 Data Translation functional entity that serialises, unit‑converts and aligns ROS2 messages before delivering them to the Digital Twin"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT, including desired speed values, ACC enable/disable, emergency‑brake signals, and steering adjustments; these are received by the Actuation FE which converts them to motor voltage and servo commands."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is required to maintain end‑to‑end network latency ≤ 100 ms and clock synchronisation accuracy of 100 ms, enabling sub‑100 ms update cycles for sensor acquisition, ACC computation and actuation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall architecture follows the ISO 23247 reference architecture with a Physical Twin Entity (sensors/actuators), Digital Twin Entity (data collection, ACC, reporting, storage), User Entity (visualisation and control UI) and a Cross‑System Data Translation component linking them via ROS2 intra‑entity and Wi‑Fi inter‑entity links."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is used during design‑time for cyber‑physical experimentation, during testing for validation of ACC behaviour, and during operation for real‑time monitoring, remote management and data logging."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Safety‑critical operation is ensured by meeting the ≤ 100 ms latency and clock sync constraints, adhering to ISO 15622 ACC specifications, and using validated perception algorithms (DBSCAN, Kalman filter). Real‑time testing validates model fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses a Wi‑Fi network transporting ROS 2 messages; the Data Translation FE serialises data and performs unit conversion, fulfilling requirement R1 for a standardized communication interface."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the on‑board Jetson Orin Nano, the Digital Twin Entity (ACC, data collection, storage, reporting) runs on a cloud/edge server, and the User Entity UI runs on a separate workstation or laptop. All components are packaged as ROS 2 nodes."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) reference architecture, uses ISO 15622 for ACC behavior, and references ISO/IEC 30173:2023 for digital‑twin terminology; optional OPC UA is mentioned as a possible protocol for Data Translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations include strict latency (≤ 100 ms) and clock synchronisation (≤ 100 ms), compliance with ISO 15622 ACC performance class I, and remote management commands that can affect vehicle motion; no explicit security mechanisms (e.g., authentication) are described in the document."
]