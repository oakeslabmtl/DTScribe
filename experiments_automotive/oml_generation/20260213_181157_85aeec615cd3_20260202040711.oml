// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor providing real-time point cloud data for environment mapping via ROS2 network"
    DTDFVocab:producedData LidarPointCloudDataTransmitted
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera capturing 3D environmental data for object detection"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor measuring real-time speed data transmitted via ROS2"
    DTDFVocab:producedData VehicleSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state sensor measuring real-time steering angle data transmitted via ROS2"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// C2: Acting Components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller for motor actuation based on ACC system commands"
]

instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Steering servo for autonomous vehicle control based on processed steering commands"
]

// C4: Physical-to-Virtual Interaction
instance LidarPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

instance VehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ObjectTrackDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR, IntelD435iDepthCamera
]

// C10: Models/Data
instance DBSCANPointCloudClusterer : DTDFVocab:Model [
    base:desc "DBSCAN algorithm for real-time point cloud clustering and noise removal"
    DTDFVocab:inputTo ROS2NetworkEnabler, PythonProcessingEnabler
]

instance KalmanFilterObjectTracker : DTDFVocab:Model [
    base:desc "Kalman filter implementation for object tracking and state estimation"
    DTDFVocab:inputTo ROS2NetworkEnabler, PythonProcessingEnabler
]

instance ISO15622AccControlModel : DTDFVocab:Model [
    base:desc "ISO 15622 compliant Adaptive Cruise Control model for speed regulation"
    DTDFVocab:inputTo ROS2NetworkEnabler, MATLABSimulationEnabler
]

instance VehicleStateDatabase : DTDFVocab:Data [
    base:desc "SQL database storing historical vehicle state data including speed, steering, and timestamps"
    DTDFVocab:fromData VehicleSpeedDataTransmitted, SteeringAngleDataTransmitted
    DTDFVocab:inputTo ReportGenerationEnabler, DecisionMakingEnabler
]

instance ObjectTrackDatabase : DTDFVocab:Data [
    base:desc "SQL database storing object tracks and detection data for environment analysis"
    DTDFVocab:fromData ObjectTrackDataTransmitted
    DTDFVocab:inputTo ReportGenerationEnabler, DecisionMakingEnabler
]

// C11: Enablers
instance ROS2NetworkEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 network infrastructure enabling real-time communication between physical and digital twins via Wi-Fi"
    DTDFVocab:enables RealTimeVisualizationService, AccComputationService, RemoteManagementService, ThreeDVisualizationService
]

instance PythonProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 processing environment for DBSCAN clustering and Kalman filtering"
    DTDFVocab:enables PointCloudProcessingService, ObjectTrackingService
]

instance MATLABSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for ACC model simulation and validation"
    DTDFVocab:enables AccControlSimulationService
]

instance ReportGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Python-based report generation system creating human-readable vehicle state and object track reports"
    DTDFVocab:enables ReportGenerationService
]

instance DecisionMakingEnabler : DTDFVocab:Enabler [
    base:desc "Python-based decision making system for ACC speed adjustment based on lead vehicle distance"
    DTDFVocab:enables AccDecisionService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real-time visualization of LiDAR point clouds, vehicle state, and object tracks"
    DTDFVocab:provides VisualizationInsight
]

instance DataSavingService : DTDFVocab:Service [
    base:desc "Data saving functionality for storing processed vehicle and environment data"
    DTDFVocab:provides DataStorageInsight
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generation of human-readable reports for vehicle state and object tracks"
    DTDFVocab:provides VehicleStateReportInsight
]

instance AccComputationService : DTDFVocab:Service [
    base:desc "Computation offloading of ACC system calculations to digital twin"
    DTDFVocab:provides AccComputationInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management enabling/disabling of ACC and setting desired speed via digital twin"
    DTDFVocab:provides RemoteManagementAction
]

instance EmergencyBrakingService : DTDFVocab:Service [
    base:desc "Emergency braking functionality triggered through digital twin interface"
    DTDFVocab:provides EmergencyBrakingAction
]

instance ThreeDVisualizationService : DTDFVocab:Service [
    base:desc "3D visualization of vehicle environment combining LiDAR and depth camera data"
    DTDFVocab:provides EnvironmentVisualizationInsight
]

instance PointCloudProcessingService : DTDFVocab:Service [
    base:desc "Real-time processing of LiDAR point clouds using DBSCAN clustering"
    DTDFVocab:provides ProcessedPointCloudInsight
]

instance ObjectTrackingService : DTDFVocab:Service [
    base:desc "Real-time object tracking using Kalman filter implementation"
    DTDFVocab:provides ObjectTrackInsight
]

instance AccControlSimulationService : DTDFVocab:Service [
    base:desc "Simulation of ACC control model using MATLAB/Simulink"
    DTDFVocab:provides SimulationResultsInsight
]

instance AccDecisionService : DTDFVocab:Service [
    base:desc "ACC decision making for speed adjustment based on lead vehicle distance"
    DTDFVocab:provides SpeedAdjustmentAction
]

// C17: Insights/Actions
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of vehicle environment and state parameters"
]

instance DataStorageInsight : DTDFVocab:Insight [
    base:desc "Verification of data storage integrity and completeness"
]

instance VehicleStateReportInsight : DTDFVocab:Insight [
    base:desc "Human-readable report containing vehicle speed, steering angle, and timestamp data"
]

instance AccComputationInsight : DTDFVocab:Insight [
    base:desc "Verification of ACC computation results and performance metrics"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Visual representation of detected objects and their trajectories"
]

instance ProcessedPointCloudInsight : DTDFVocab:Insight [
    base:desc "Visualization of processed point cloud data after DBSCAN clustering"
]

instance SimulationResultsInsight : DTDFVocab:Insight [
    base:desc "Results from ACC model simulation showing control performance"
]

instance EnvironmentVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization combining LiDAR and depth camera data for environment understanding"
]

instance RemoteManagementAction : DTDFVocab:Action [
    base:desc "Remote enable/disable of ACC system and setting of desired speed"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Emergency braking command execution"
    DTDFVocab:IsAutomatic true
]

instance SpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic speed adjustment based on lead vehicle distance"
    DTDFVocab:IsAutomatic true
]

// C1: System Under Study
instance AutonomousVehicleSystem : DTDFVocab:System [
    base:desc "1/10-scale autonomous vehicle built by retrofitting Traxxas Slash 4x4 with NVIDIA Jetson NX/Orin Nano, LiDAR, depth camera, and control components"
    DTDFVocab:hasEnvironment VehicleEnvironment
]

// C5: Physical Twin Entity
instance PhysicalTwinEntity : DTDFVocab:PhysicalEntity [
    base:desc "Physical implementation of autonomous vehicle including all sensing and acting components"
    base:contains HokuyoUST10LXLiDAR, IntelD435iDepthCamera, VehicleSpeedSensor, SteeringAngleSensor,
                 VedderElectronicSpeedController, SteeringServo, NvidiaJetsonNX, NvidiaJetsonOrinNano
]

// C7: Digital Twin Entity
instance DigitalTwinEntity : DTDFVocab:DigitalTwin [
    base:desc "Digital representation of autonomous vehicle environment and state with real-time processing capabilities"
    base:contains ROS2NetworkEnabler, PythonProcessingEnabler, MATLABSimulationEnabler,
                 ReportGenerationEnabler, DecisionMakingEnabler,
                 DBSCANPointCloudClusterer, KalmanFilterObjectTracker, ISO15622AccControlModel,
                 VehicleStateDatabase, ObjectTrackDatabase
]

// C8: User Entity
instance UserEntity : DTDFVocab:User [
    base:desc "Human operator interface for remote management and visualization of autonomous vehicle operations"
    base:interactsWith RemoteManagementService, RealTimeVisualizationService, ReportGenerationService
]

// C12: Components
instance NvidiaJetsonNX : DTDFVocab:Component [
    base:desc "NVIDIA Jetson NX module providing computational power for real-time processing"
    base:isContainedIn VehicleEnvironment
]

instance NvidiaJetsonOrinNano : DTDFVocab:Component [
    base:desc "NVIDIA Jetson Orin Nano module for advanced AI processing of sensor data"
    base:isContainedIn VehicleEnvironment
]

// C13: Environment
instance VehicleEnvironment : DTDFVocab:Environment [
    base:desc "Physical environment surrounding the autonomous vehicle including dynamic objects"
    base:contains NvidiaJetsonNX, NvidiaJetsonOrinNano
]

// C14: Data Flows
instance PointCloudDataFlow : DTDFVocab:DataFlow [
    DTDFVocab:from HokuyoUST10LXLiDAR
    DTDFVocab:to ROS2NetworkEnabler
]

instance DepthDataFlow : DTDFVocab:DataFlow [
    DTDFVocab:from IntelD435iDepthCamera
    DTDFVocab:to ROS2NetworkEnabler
]

instance StateDataFlow : DTDFVocab:DataFlow [
    DTDFVocab:from VehicleSpeedSensor, SteeringAngleSensor
    DTDFVocab:to ROS2NetworkEnabler
]

instance ControlDataFlow : DTDFVocab:DataFlow [
    DTDFVocab:from DigitalTwinEntity
    DTDFVocab:to VedderElectronicSpeedController, SteeringServo
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Transmission of ACC control commands (desired speed, emergency braking) and steering commands to the vehicle's motor and steering servo."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time operation with end-to-end latency of at most 100 ms and clock synchronization accuracy of 100 ms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Entity-based structure with Physical Twin Entity (sensors, actuators), Digital Twin Entity (data processing, ACC), User Entity (visualization, control), and Cross-System Data Translation FE; communication via ROS2 and Wi-Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design phase (cyber-physical experimentation), validation of requirements, and operational phase for monitoring and optimization."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "ROS2 network for intra-entity communication, Wi-Fi for inter-entity communication with ≤100 ms latency."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin components on NVIDIA Jetson Orin Nano (vehicle), Digital Twin Entity and User Entity deployed on external hardware (cloud or separate system), Data Storage external to vehicle."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture for digital twin framework and ISO 15622 for ACC control strategy."
]