// C3: Physical sensing components
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor producing 3‑D point cloud data for the autonomous vehicle"
    DTDFVocab:producedData LiDARDataTransmitted
]

instance MotorFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor providing motor feedback such as RPM and torque"
    DTDFVocab:producedData MotorFeedbackDataTransmitted
]

instance SteeringServoStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor delivering steering servo status information"
    DTDFVocab:producedData SteeringServoDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor aggregating overall vehicle state (position, orientation, speed)"
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance MotorFeedbackDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorFeedbackSensor
]

instance SteeringServoDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoStatusSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// C5: Raw Data instances
instance LiDARRawPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud measurements collected from the vehicle"
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance MotorFeedbackRawData : DTDFVocab:Data [
    base:desc "Raw motor feedback measurements (RPM, torque)"
    DTDFVocab:fromData MotorFeedbackDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance SteeringServoRawData : DTDFVocab:Data [
    base:desc "Raw steering servo status data"
    DTDFVocab:fromData SteeringServoDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance VehicleStateRawData : DTDFVocab:Data [
    base:desc "Raw vehicle state data (position, orientation, speed)"
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

// C10: Models
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Point‑cloud clustering and tracking algorithm that supports the 3‑D visualization component"
    DTDFVocab:inputTo VisualizationEnabler
]

instance ACCAlgorithmModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm (lead‑vehicle detection, distance‑based speed computation, desired‑speed output) executed on cloud resources"
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

// C11: Model‑derived Data
instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks generated by the clustering and tracking algorithm"
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo VisualizationEnabler
]

instance DesiredSpeedData : DTDFVocab:Data [
    base:desc "Desired speed output from ACC algorithm for vehicle actuation"
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo RemoteControlEnabler
]

// C11: Enablers
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 nodes that preprocess sensor streams, perform unit conversion, serialization, and publish on the ROS2 middleware bus"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Component that renders 3‑D visualization and displays object tracks in the UI"
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Offloads ACC computation to cloud resources and returns desired speed"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Enables remote management commands such as enable/disable ACC, set speed, and emergency brake"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Graphical UI displays real‑time vehicle state, projected driving path, and detected object tracks; allows viewing, saving, and generating reports of historical data"
    DTDFVocab:provides DataVisualizationInsight, HistoricalReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm on cloud, transmits computed speed back to vehicle for actuation"
    DTDFVocab:provides DesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can remotely enable/disable ACC, set desired speed, and issue emergency braking via UI"
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of vehicle state, projected path, and object tracks"
]

instance HistoricalReportInsight : DTDFVocab:Insight [
    base:desc "Generation of historical data reports from stored vehicle telemetry"
]

// C17: Actions
instance DesiredSpeedAction : DTDFVocab:Action [
    base:desc "Apply computed desired speed to vehicle actuators"
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable ACC function on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set desired speed value for ACC operation"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issue emergency braking command to vehicle"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the ACC Controlling FE (e.g., desired speed, enable/disable ACC, emergency braking) are packaged by the Data Translation FE, transmitted over the same Wi‑Fi UDP link to the Physical Twin Entity, and received by the Actuation FE which drives the motor, steering and servo actuators. The command messages follow the format defined by the Data Translation component (aligned with ISO 23247). Validation occurs within the Data Translation and Actuation FE before actuation; feedback of execution status is sent back through the same channel to the DTS."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires clock synchronization between devices with a maximum error of 100 ms; this bound is imposed because hardware can only support 100 ms accuracy, whereas safety‑critical vehicular standards often demand tighter sync (<100 ms). The synchronization interval is therefore set to maintain ≤100 ms offset, enabling computation off‑loading between the physical twin and its digital counterpart."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration follows the ISO 23247 reference architecture: functional entities are mapped to ROS 2 packages, each package containing one or more ROS 2 nodes that realize the FE functionality. The three entities are deployed on distinct compute nodes (e.g., vehicle ECU, sensor processor) and communicate via ROS 2 topics/services, providing system‑wide coordination of data collection, actuation, and user interaction. This component‑based integration implements the Digital Twin Entity for data management, the Physical Twin Entity for sensor/actuator handling, and the User Entity for 3D visualization and control panel."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The system requires a shared notion of time across devices with a synchronization accuracy of 100 ms, as mandated by hardware limitations and safety‑critical vehicular application constraints. This timing requirement underpins the validity of actuation and data fusion in the Digital Twin. No additional model validation, uncertainty quantification, or quality assurance procedures are described in the source materials."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS employs a two‑layer communication architecture: (1) an internal ROS 2 (DDS) network for all software component interactions, and (2) an external Wi‑Fi network using UDP for bi‑directional data exchange between the Physical Twin and the Digital Twin. The system is required (Requirement R7) to maintain end‑to‑end network latency of at most 100 ms, and (Requirement R8) to provide clock synchronization between the twin entities (e.g., via NTP or ROS 2 time sync). Reliability is supported by ROS 2’s QoS policies, while security mechanisms are not explicitly detailed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture explicitly follows the ISO 23247 reference architecture, adopting its entity‑based model (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity) and mapping software components to Functional Entities. Implementation of Functional Entities is realized as ROS 2 packages, each containing one or more ROS 2 nodes. The documents note that OPC Unified Architecture (OPC UA) can be used for communication, reflecting adherence to industrial interoperability standards. Additionally, timing requirements reference vehicular safety standards that mandate clock synchronization accuracy better than 100 ms, indicating compliance with relevant time‑synchronization specifications."
]