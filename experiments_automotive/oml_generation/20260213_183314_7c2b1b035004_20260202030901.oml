// C2: Acting Components
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Actuation FE on PT converts desired speed commands into motor voltage signals via Vedder electronic speed controller"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuation for steering angle control on PT"
]

instance EmergencyBrakingActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency‑braking command issued remotely through the PT actuation interface"
]

// C3: Physical sensing components
instance HokuyoUST110LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑110LX LiDAR providing 2D laser scans for environment perception"
    DTDFVocab:producedData LidarDataTransmitted
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering RGB‑D frames for 3‑D perception"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed obtained from lower‑level chassis control interface"
    DTDFVocab:producedData SpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle obtained from chassis control interface"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LidarDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST110LXLidar
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ObjectTrackDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST110LXLidar, IntelDeepsenseD435iDepthCamera
]

// C10: Models/Data
instance LidarPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud scans transmitted from PT to DT"
    DTDFVocab:fromData LidarDataTransmitted
    DTDFVocab:inputTo ROS2DDSMiddlewareEnabler
]

instance DepthCameraFrameData : DTDFVocab:Data [
    base:desc "Raw depth‑camera frames transmitted from PT to DT"
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo ROS2DDSMiddlewareEnabler
]

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed value transmitted from PT to DT"
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo ROS2DDSMiddlewareEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Ego steering angle value transmitted from PT to DT"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo ROS2DDSMiddlewareEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Derived object tracks generated by DBSCAN clustering and Kalman‑filter tracking on PT sensor streams"
    DTDFVocab:fromData ObjectTrackDataTransmitted
    DTDFVocab:inputTo MatlabSimulinkEnabler
]

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point clouds for object segmentation"
    DTDFVocab:inputTo MatlabSimulinkEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter tracking of clustered objects to produce continuous object tracks"
    DTDFVocab:inputTo MatlabSimulinkEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "ACC control model compliant with ISO 15622 for lead‑vehicle detection and speed‑set‑point computation"
    DTDFVocab:inputTo NvidiaJetpack5Enabler
]

// C11: Enablers
instance ROS2DDSMiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 DDS middleware handling real‑time message transport over Wi‑Fi"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, ReportingService
]

instance MatlabSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment executing DBSCAN clustering and Kalman‑filter tracking pipelines"
    DTDFVocab:enables DataMonitoringService
]

instance NvidiaJetpack5Enabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK providing GPU‑accelerated compute on Jetson platforms"
    DTDFVocab:enables ComputationOffloadingService
]

instance SqlDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database storing sensor data, object tracks, and generated reports"
    DTDFVocab:enables ReportingService
]

instance WiFiNetworkEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi network linking PT and DT for ROS 2 DDS messages"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, ReportingService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualises real‑time vehicle state, projected path, and object tracks; stores periodic reports"
    DTDFVocab:provides RealTimeVehicleStateInsight, ProjectedPathInsight, ObjectTracksInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC algorithm in DT to compute desired speed set‑point for the PT"
    DTDFVocab:provides ComputeDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI permits operators to enable/disable ACC, modify speed set‑points, and trigger emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, ModifySpeedSetpointAction, TriggerEmergencyBrakingAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Creates human‑readable timeseries reports stored in the SQL database"
    DTDFVocab:provides TimeseriesReportInsight, GenerateTimeseriesReportAction
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Provides operators with live vehicle speed and steering angle values"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Shows projected driving path based on current speed and steering angle"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Displays surrounding object tracks detected by clustering and tracking pipeline"
]

instance TimeseriesReportInsight : DTDFVocab:Insight [
    base:desc "Presents aggregated timeseries of vehicle state and events for post‑run analysis"
]

// C17: Actions
instance ComputeDesiredSpeedAction : DTDFVocab:Action [
    base:desc "ACC algorithm computes desired speed set‑point based on lead‑vehicle detection"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator enables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator disables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance ModifySpeedSetpointAction : DTDFVocab:Action [
    base:desc "Operator modifies ACC speed set‑point"
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator issues emergency braking command to the PT"
    DTDFVocab:IsAutomatic false
]

instance GenerateTimeseriesReportAction : DTDFVocab:Action [
    base:desc "Generate human‑readable timeseries report and store it in the SQL database"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT issues ROS2 command messages over the same Wi‑Fi link to the PT. Commands include the ACC‑computed desired speed, enable/disable ACC flags, user‑requested speed set‑points, and emergency‑braking signals. The Actuation FE on the PT receives these messages and drives the motor controller and steering servo accordingly."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sub‑100 ms end‑to‑end latency is required for PT‑to‑DT communication (R7). Clock synchronization across all DTS components must be accurate to within 100 ms (R8). Data are collected and processed in real time at the perception cycle rate of the vehicle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A distributed constellation where the Physical Twin Entity (sensors, actuation, point‑cloud processing) runs on the vehicle’s Jetson Orin Nano, the Digital Twin Entity (data collection, ACC computation, visualization preprocessing, reporting) runs on external compute, and the User Entity (3D visualization UI, control‑panel UI) runs on a operator workstation. Data Translation FE provides a common data model across entities. Communication uses ROS2 topics over Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during design (as a cyber‑physical experimentation platform), development (for troubleshooting and validation), and operation (for real‑time monitoring, remote management, and performance reporting)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity perception is achieved through DBSCAN clustering of LiDAR points and Kalman‑filter tracking, providing accurate object tracks. The ACC control model follows ISO 15622 specifications for performance class I. Real‑time validation is performed by the UI reporting vehicle state and by measuring end‑to‑end latency (≤100 ms). Clock synchronization (≤100 ms) supports consistent event ordering."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication between PT and DT over a Wi‑Fi network using ROS2 (DDS) transport. Data are marshalled by the Data Translation FE, which handles serialization, message‑type alignment, and unit conversion. No OPC UA is employed in the implementation, although it is mentioned as an optional standard."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the vehicle’s NVIDIA Jetson Orin Nano (ROS2 packages). Digital Twin Entity and User Entity are hosted on external compute resources (e.g., a workstation or cloud server) also running ROS2. Each Functional Entity is encapsulated in its own ROS2 package for modular deployment."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Primary use of ISO 23247 (Digital Twin Manufacturing Framework) reference architecture; ACC functional model follows ISO 15622 (Adaptive Cruise Control). ISO/IEC 30173 is referenced for terminology but not applied. No other standards are explicitly used."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed for safety‑critical operation with a maximum 100 ms latency and synchronized clocks (±100 ms) to ensure timely actuation. Remote management commands include emergency braking. While specific cybersecurity mechanisms are not detailed, the architecture respects safety constraints by limiting latency and ensuring real‑time control as per ISO 15622."
]