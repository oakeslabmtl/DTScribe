// Sensing components
instance HokuyoUST10LXLidarSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard Hokuyo UST-10LX LiDAR delivering high-frequency point‑cloud data"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Onboard Intel D435i depth camera providing RGB‑D frames for depth perception"
    DTDFVocab:producedData DepthCameraFrameTransmitted
]

instance WheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle wheel‑speed sensors measuring lateral wheel RPM"
    DTDFVocab:producedData WheelSpeedMetricsTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring vehicle steering position"
    DTDFVocab:producedData SteeringAngleMetricsTransmitted
]

// Physical to virtual interaction (DataTransmitted)
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidarSensor
]

instance DepthCameraFrameTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]

instance WheelSpeedMetricsTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedSensor
]

instance SteeringAngleMetricsTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedSensor, SteeringAngleSensor
]

// Virtual data instances
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Real‑time point cloud data received from LiDARPointCloudTransmitted"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, DataStorageEnabler
]

instance DepthCameraFrameData : DTDFVocab:Data [
    base:desc "RGB‑D frame data received from DepthCameraFrameTransmitted"
    DTDFVocab:fromData DepthCameraFrameTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, DataStorageEnabler
]

instance WheelSpeedMetricsData : DTDFVocab:Data [
    base:desc "Wheel speed metrics data received from WheelSpeedMetricsTransmitted"
    DTDFVocab:fromData WheelSpeedMetricsTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, DataStorageEnabler
]

instance SteeringAngleMetricsData : DTDFVocab:Data [
    base:desc "Steering angle metrics data received from SteeringAngleMetricsTransmitted"
    DTDFVocab:fromData SteeringAngleMetricsTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, DataStorageEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state data aggregating speed and steering values from VehicleStateTransmitted"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, DataStorageEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Kalman‑filtered object tracks derived from LiDAR point cloud data"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, DataStorageEnabler
]

// Acting components
instance MotorVoltageCommandActuator : DTDFVocab:ActingComponent [
    base:desc "Actuation FE generating motor voltage commands sent to vehicle’s electronic speed controller via ROS2 messages"
]

instance SteeringServoCommandActuator : DTDFVocab:ActingComponent [
    base:desc "Actuation FE generating steering servo commands sent to vehicle steering actuator via ROS2 messages"
]

instance EmergencyBrakeSignalActuator : DTDFVocab:ActingComponent [
    base:desc "Actuation FE sending emergency braking signals to vehicle controller via ROS2 messages"
]

instance ACCDesiredSpeedCommandActuator : DTDFVocab:ActingComponent [
    base:desc "Actuation FE sending ISO 15622 derived desired speed back to vehicle via ROS2 messages"
]

// Enablers
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler performing data processing for clustering and tracking models, enabling ACC computation offload and real‑time monitoring services"
    DTDFVocab:enables AccComputationOffloadService, RealTimeMonitoringService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Enabler storing SQL database time‑series, enabling data storage service"
    DTDFVocab:enables DataStorageService
]

instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler routing ACC controller outputs to remote control panel, enabling remote management service"
    DTDFVocab:enables RemoteManagementService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real‑time data monitoring, visualization, and 3‑D rendering"
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTrackVisualizationInsight
]

instance AccComputationOffloadService : DTDFVocab:Service [
    base:desc "Service computing ACC logic offloading lead‑vehicle detection and speed computation per ISO 15622"
    DTDFVocab:provides PerformanceMetricInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service providing remote management via control panel (enable/disable ACC, set desired speed, trigger emergency brake)"
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, TriggerEmergencyBrakeAction
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Service storing collected data in external SQL database"
]

// Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight displaying real‑time vehicle state inside visualization interface"
]

instance ObjectTrackVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight rendering object tracks derived from LiDAR clustering in 3‑D view"
]

instance PerformanceMetricInsight : DTDFVocab:Insight [
    base:desc "Insight providing performance metrics of ACC controller"
]

// Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable or disable the ACC subsystem"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to set desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to trigger emergency braking"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin outputs desired speed commands, steering adjustments, and emergency braking commands via the Actuation FE to the vehicle’s controller, and forwards ACC‑control decisions and remote‑management commands received from the UI to the vehicle over the same Wi‑Fi network."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data acquisition and processing with an end‑to‑end latency target of ≤100 ms from vehicle to Digital Twin; data updates occur on the perception cycle (~50–200 ms for LiDAR processing); the DT operates at synchronous timestamps synced to ±100 ms clock precision."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is orchestrated as a distributed system: Vehicle (Physical Twin Entity) hosts sensor acquisition nodes; Digital Twin Entity runs on an external server or edge device providing data processing, ACC computation, reporting, and actuation; User Entity hosts a 3‑D visualization and control‑panel UI; all communicate via ROS2 topics over a Wi‑Fi network, with Data Translation FE ensuring protocol and unit consistency."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT undergoes design (conceptual modeling and mapping to ISO 23247 entities), implementation (ROS2 node development), validation (simulation and real‑world testing of ACC per ISO 15622), deployment (real‑time operation with cloud offloading), and operation (ongoing monitoring, remote management, and iterative refinement)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity achieved by using actual on‑board sensors and real‑time LiDAR processing; validity ensured by adhering to ISO 15622 for ACC control and ISO 23247 for architectural structure; latency measurements confirm <100 ms end‑to‑end; validation via real‑vehicle ACC operations and automated data logging."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange uses ROS2 over a Wi‑Fi link; Data Translation FE serializes ROS2 messages, aligns signal types, and performs unit conversions; inter‑entity communication follows ISO 23247 entity interfaces, while intra‑entity communication uses ROS2 topics and services."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital Twin runs on external compute (edge or cloud) with ROS2 master; Physical Twin entities run on the vehicle’s Jetson devices; the Whole system can be deployed across distributed nodes connected by Wi‑Fi; optional cloud hosting not specified, but offload implied."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adopts ISO 23247 reference architecture with Functional Entities, ISO 15622 ACC control strategy, and ROS 2 middleware; data translation may leverage OPC UA as per ISO 23247 optional guidance."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is safety‑critical, mandating ≤100 ms latency and accurate clock synchronization (≤100 ms). It implements real‑time control of vehicle actuators (speed, steering), with the capability for emergency braking. No explicit cybersecurity or safety certification procedures are described; the design relies on secure Wi‑Fi communication and standard industrial protocols (ROS 2, OPC UA)."
]