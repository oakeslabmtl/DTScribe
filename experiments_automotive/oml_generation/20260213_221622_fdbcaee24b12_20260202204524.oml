// C2: Acting Components
instance SteeringServoActuation : DTDFVocab:Actuator [
    base:desc "Manages steering commands for the vehicle's steering system adhering to ISO 15622 for ACC performance class I (no road curvature handling)."
]

instance MotorActuation : DTDFVocab:Actuator [
    base:desc "Converts desired speed commands into motor voltage commands for controlling the vehicle's speed via the Vedder Electronic Speed Controller."
]

// C3: Physical Sensing Components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing point cloud data for object detection and tracking in the vehicle's proximity."
]

instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i Depth Camera capturing 3D environmental data for object detection and ego-vehicle state estimation."
]

instance EgoSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor collecting real-time ego vehicle speed data for ACC operation."
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor collecting real-time steering angle data for ACC operation."
]

// C4: Physical-to-Virtual Data Transmission
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthCameraData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]

instance EgoSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoSpeedSensor
]

instance SteeringAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance MotorCommandData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorActuation
]

// C5: Data Storage and Representation
instance ObjectTrackDatabase : DTDFVocab:Data [
    base:desc "SQL database storing historical object tracks and vehicle state data externally to the vehicle (cloud-based storage)."
]

instance EgoVehicleStateDatabase : DTDFVocab:Data [
    base:desc "SQL database storing historical ego vehicle state data (speed, steering) for analysis."
]

instance PointCloudClusteringData : DTDFVocab:Data [
    base:desc "Processed point cloud data from LiDAR after DBSCAN clustering for object tracking."
]

instance KalmanFilteredTracks : DTDFVocab:Data [
    base:desc "Object tracks filtered through Kalman filtering for accurate position/velocity estimation."
]

instance ROSLaserScanTopic : DTDFVocab:Data [
    base:desc "Standardized ROS2 topic format (sensor_msgs/LaserScan) for LiDAR point cloud transmission."
]

instance ROSOdometryTopic : DTDFVocab:Data [
    base:desc "Standardized ROS2 topic format (nav_msgs/Odometry) for ego vehicle state transmission."
]

instance ROSImageTopic : DTDFVocab:Data [
    base:desc "Standardized ROS2 topic format (sensor_msgs/Image) for depth camera data transmission."
]

// C6: Models
instance LiDARPointCloudModel : DTDFVocab:Model [
    base:desc "Model processing raw LiDAR point clouds via DBSCAN clustering for object detection and tracking."
    DTDFVocab:inputTo ROS2Middleware
]

instance KalmanFilterModel : DTDFVocab:Model [
    base:desc "Kalman filtering model for refining object tracks from clustered point clouds."
    DTDFVocab:inputTo ROS2Middleware
]

instance EgoVehicleDynamicsModel : DTDFVocab:Model [
    base:desc "Model simulating speed/steering interactions based on ISO 15622 ACC standards."
    DTDFVocab:inputTo ROS2Middleware
]

// C10: Data Processing Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "Robot Operating System 2 middleware facilitating component communication, node lifecycle management, and message serialization (UDP-based Wi-Fi communication)."
    DTDFVocab:enables DataCollectionFE, VisualizationFE, ReportingFE, ACCComputingFE
]

instance PythonPrototyping : DTDFVocab:Enabler [
    base:desc "Python 3.8 environment for rapid prototyping of digital twin components."
]

// C11: Digital Twin Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of ego vehicle speed, steering angle, object tracks, and projected driving path via 3D Visualization (User Entity)."
    DTDFVocab:provides EgoSpeedMonitoringInsight, SteeringAngleMonitoringInsight, ObjectTrackVisualizationAction
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generates human-readable reports of object tracks and vehicle state as timeseries data (Reporting FE)."
    DTDFVocab:provides HistoricalReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC computations (lead vehicle detection, speed calculation) from NVIDIA Jetson Orin Nano to cloud-based Digital Twin Entity for performance optimization."
    DTDFVocab:provides ACCPerformanceOptimizationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables remote control of ACC via Control Panel UI including enable/disable, desired speed setting, and emergency braking commands."
    DTDFVocab:provides ACCRemoteControlAction
]

// C12: Insights and Actions
instance EgoSpeedMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of ego vehicle speed for ACC performance optimization."
]

instance SteeringAngleMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of steering angle for ACC state validation."
]

instance ObjectTrackVisualizationAction : DTDFVocab:Action [
    base:desc "3D visualization of detected object tracks and projected driving path for user interaction."
    DTDFVocab:IsAutomatic false
]

instance HistoricalReportInsight : DTDFVocab:Insight [
    base:desc "Generated timeseries report of historical object tracks and vehicle state data."
]

instance ACCPerformanceOptimizationAction : DTDFVocab:Action [
    base:desc "Adjusts ACC computation parameters for performance optimization via cloud offloading."
    DTDFVocab:IsAutomatic true
]

instance ACCRemoteControlAction : DTDFVocab:Action [
    base:desc "Remote enable/disable, speed setting, and emergency braking commands for ACC system."
    DTDFVocab:IsAutomatic false
]

// C13: Digital Twin Entity Components
instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Single central Digital Twin Entity hosting Data Collection, Reporting, ACC Controlling, and Visualization FE components."
]

instance DataCollectionFE : DTDFVocab:Component [
    base:desc "ROS2 node receiving and processing data from physical twin sensors (LiDAR, camera, onboard sensors)."
]

instance ReportingFE : DTDFVocab:Component [
    base:desc "ROS2 node generating human-readable reports from processed data and storing in SQL databases."
]

instance ACCComputingFE : DTDFVocab:Component [
    base:desc "ROS2 node performing lead vehicle detection and speed calculation computations."
]

instance VisualizationFE : DTDFVocab:Component [
    base:desc "ROS2 node containing Presentation and User Interface components for 3D visualization."
    DTDFVocab:contains PresentationLayer, UserInterfaceLayer
]

instance PresentationLayer : DTDFVocab:Component [
    base:desc "Internal visualization layer processing data for display in User Interface."
]

instance UserInterfaceLayer : DTDFVocab:Component [
    base:desc "Control Panel UI for remote management of ACC system (enable/disable, speed setting, emergency braking)."
]

// C14: Physical Twin Components
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Multi-instantiated Physical Twin Entity components including Point Cloud Clustering & Tracking and Actuation FE."
    DTDFVocab:contains PointCloudProcessingUnit, MotorControlUnit, SteeringControlUnit
]

instance PointCloudProcessingUnit : DTDFVocab:Component [
    base:desc "ROS2 package implementing point cloud clustering (DBSCAN) and tracking (Kalman filtering) for object detection."
]

instance MotorControlUnit : DTDFVocab:Component [
    base:desc "ROS2 package managing motor voltage commands via Vedder Electronic Speed Controller."
]

instance SteeringControlUnit : DTDFVocab:Component [
    base:desc "ROS2 package managing steering commands for vehicle steering system."
]

// C15: Environment
instance AutomotiveEnvironment : DTDFVocab:Environment [
    base:contains TraxxasVehiclePlatform, RoboRacerAutonomyFramework
]

instance TraxxasVehiclePlatform : DTDFVocab:Component [
    base:desc "Base platform (Traxxas teleoperated vehicle) hosting the 1/10th-scale autonomous vehicle chassis."
]

instance RoboRacerAutonomyFramework : DTDFVocab:Component [
    base:desc "Autonomy development framework integrating with the digital twin system for ACC implementation."
]

// C16: Hardware Components
instance NVIDIAJetsonOrinNano : DTDFVocab:Hardware [
    base:desc "NVIDIA Jetson Orin Nano microcomputer hosting onboard autonomy components."
]

instance NVIDIAJetsonNX : DTDFVocab:Hardware [
    base:desc "NVIDIA Jetson NX antenna providing wireless communication for inter-entity data transfer."
]

instance VedderSpeedController : DTDFVocab:Hardware [
    base:desc "Vedder Electronic Speed Controller interfacing with vehicle motors for speed control."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends commands to the physical twin via **ROS2 nodes** and **Wi-Fi network** (UDP) to execute ACC functions:
  - **Desired Speed Adjustment**: Computed by the **ACC Controlling FE** (Digital Twin Entity) and sent back to the vehicle’s **Motor Actuation FE** for actuation via the **Vedder Speed Controller**.
  - **Emergency Braking**: Triggered via the **Control Panel UI** (User Entity) and propagated through the **Data Translation FE** to the **Actuation FE** for immediate braking.
  - **ACC Enable/Disable**: Managed via the **Control Panel UI**, with commands routed to the **Actuation FE** to toggle ACC functionality."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin operates on a **real-time, event-driven time scale**:
  - **Perception Cycle Rate**: Object tracking and ego-vehicle state updates occur at **~10–20 Hz** (adjustable based on sensor latency).
  - **End-to-End Latency Constraint**: **≤100 ms** from vehicle to DT Entity (3GPP 22.185 compliance for V2V communication).
  - **Clock Synchronization**: Devices are synchronized to **±100 ms accuracy** (critical for distributed systems and event ordering)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellation consists of:
  - **Physical Twin (PT)**: The **1/10th-scale autonomous vehicle** with embedded sensors/actuators.
  - **Digital Twin Entity (DTE)**: Centralized cloud-based system hosting **Data Collection**, **Reporting**, **ACC Controlling**, and **Visualization FE**.
  - **User Entity**: **3D Visualization** (User Interface FE) and **Control Panel** (User Interface FE) for remote management.
  - **Physical Twin Entity (PTE)**: Onboard components like **Point Cloud Clustering & Tracking**, **Data Pre-Processing**, and **Actuation FE**.
  - **Cross-System Entity**: **Data Translation FE** (ISO 23247) for inter-entity data alignment (e.g., unit conversions, message serialization)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin spans the following lifecycle stages:
  - **Design Phase**: Used for **cyber-physical experimentation** with **3D CAD/Simulink** integration for system validation.
  - **Manufacturing Phase**: Enables **real-time monitoring** of ACC performance during prototyping (e.g., LiDAR calibration, sensor fusion).
  - **Operational Phase**: Provides **health monitoring**, **predictive maintenance**, and **remote management** of the autonomous vehicle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
  - **Verification**:
    - **Latency Testing**: End-to-end latency ≤100 ms (3GPP 22.185 compliance).
    - **Clock Synchronization**: ±100 ms accuracy for distributed systems.
  - **Validation**:
    - **ACC Compliance**: Adherence to **ISO 15622** (performance class I) for speed control.
    - **Sensor Fusion**: **Kalman filtering** for accurate object tracking from LiDAR/depth camera data.
  - **Uncertainty Handling**: Data preprocessing (e.g., DBSCAN clustering) mitigates noise in raw LiDAR point clouds."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin uses the following technical connections:
  - **Inter-Entity Communication**: **Wi-Fi (UDP)** for low-latency data exchange between **Physical Twin Entity** and **Digital Twin Entity**.
  - **Onboard Communication**: **ROS2 topics/messages** (e.g., `sensor_msgs/LaserScan`, `nav_msgs/Odometry`) for intra-entity data flow.
  - **Data Translation**: **ISO 23247 Data Translation FE** ensures compatibility between heterogeneous data formats (e.g., LiDAR raw data → object tracks)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin is deployed as follows:
  - **Physical Twin Entity**: Hosted on **NVIDIA Jetson Orin Nano** (onboard ECU) for real-time processing.
  - **Digital Twin Entity**: Deployed on **cloud infrastructure** (offboard compute) for computation offloading.
  - **User Entity**: Accessible via **web-based UI** (3D Visualization/Control Panel) for remote management."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin integrates horizontally with:
  - **Vehicle-to-Vehicle (V2V) Systems**: Compliance with **3GPP 22.185** for low-latency communication with other autonomous vehicles.
  - **Cloud-Based Fleet Coordination**: Offloads ACC computations to cloud infrastructure for scalability.
  - **External Data Systems**: Potential integration with **road infrastructure APIs** (e.g., traffic data) for enhanced ACC decision-making."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership is not explicitly defined in the documents. The system specifies storing data 'external to the vehicle' (R3) but does not address roles (e.g., PT Owner vs. Service Provider), privacy measures (e.g., encryption), or compliance with data protection regulations (e.g., GDPR). The focus is on technical requirements rather than ethical or privacy considerations."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin adheres to the following standards:
  - **ISO 23247**: Reference architecture for **entity-based DT design** (adapted for automotive).
  - **ISO 15622**: ACC performance standards (performance class I).
  - **ROS2**: Middleware for component communication and message serialization.
  - **3GPP 22.185**: V2V communication latency requirements (≤100 ms)."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety are addressed through: (1) **Human-in-the-Loop**: Critical operations (e.g., emergency braking) require explicit user confirmation; (2) **Real-Time Constraints**: Latency ≤100 ms and clock synchronization (±100 ms) ensure safe operation; (3) **Latency/Safety-Criticality**: The system prioritizes safety-critical paths with verified control logic (ISO 15622). However, the documents do not mention encryption (TLS/SSL), authentication, or formal verification protocols for cybersecurity."
]