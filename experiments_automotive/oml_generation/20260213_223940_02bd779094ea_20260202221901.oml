// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "3D perception LiDAR sensor for autonomous vehicles, providing spatial mapping and obstacle detection with industry-standard sub-centimeter precision in structured environments. Implemented with ROS2 integration for real-time data acquisition."
    DTDFVocab:producedData LiDARPointCloudData
    base:isContainedIn PhysicalTwinEntity
]

instance IntelRealsenseD435IDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Depth camera for 3D environmental perception in autonomous systems, optimized for spatial distribution with vehicle-specific tasks. Provides high-resolution depth data for obstacle avoidance and navigation."
    DTDFVocab:producedData DepthCameraData
    base:isContainedIn PhysicalTwinEntity
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard sensor suite capturing real-time vehicle dynamics including motor actuation, steering servo actuation, speed, and trajectory data for autonomous control systems."
    DTDFVocab:producedData VehicleStateData
    base:isContainedIn PhysicalTwinEntity
]

// C4: Physical-to-Virtual Interaction
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    base:desc "Raw 3D point cloud data from Hokuyo UST-10LX LiDAR processed through Point Cloud Clustering & Tracking SW component to generate structured object tracks and vehicle state information."
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraData : DTDFVocab:DataTransmitted [
    base:desc "3D environmental perception data from Intel RealSense D435i depth camera, processed for obstacle detection and spatial mapping in autonomous navigation systems."
    DTDFVocab:producedFrom IntelRealsenseD435IDepthCamera
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    base:desc "Real-time vehicle dynamics data including motor actuation, steering servo actuation, speed, and trajectory metrics transmitted continuously for autonomous control systems."
    DTDFVocab:producedFrom VehicleStateSensor
]

instance ObjectTracksData : DTDFVocab:DataTransmitted [
    base:desc "Processed LiDAR data identifying environmental objects (obstacles, pedestrians) with spatial-temporal attributes for autonomous system decision-making."
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance ProjectedDrivingPathData : DTDFVocab:DataTransmitted [
    base:desc "Computed autonomous vehicle trajectories derived from sensor inputs and vehicle state data for real-time control and navigation."
    DTDFVocab:producedFrom VehicleStateSensor, HokuyoUST10LXLiDAR
]

// C10: Models/Data
instance PointCloudClusteringAndTrackingModel : DTDFVocab:Model [
    base:desc "Software component converting raw 2D plane LiDAR point clouds into structured object tracks and vehicle state data for autonomous systems."
    DTDFVocab:inputTo ROS2SimulationEnvironment
]

instance DataPreProcessingFunctionalEntity : DTDFVocab:Model [
    base:desc "Functional entity standardizing and aligning sensor data (LiDAR, motor, steering) for downstream processing and consistency across data streams."
    DTDFVocab:inputTo DataTranslationFunctionalEntity
    DTDFVocab:fromData LiDARPointCloudData, DepthCameraData, VehicleStateData
]

instance DataTranslationFunctionalEntity : DTDFVocab:Model [
    base:desc "Software component serializing data, aligning message types, and performing unit conversions for all data streams to ensure consistency in the Digital Twin system."
    DTDFVocab:inputTo DataCollectingFunctionalEntity
    DTDFVocab:fromData DataPreProcessingFunctionalEntity
]

instance DigitalTwinGeometricModel : DTDFVocab:Model [
    base:desc "High-fidelity geometric representation of the 1/10-scale autonomous vehicle and its environment, serving as the computational core for simulation and control."
    DTDFVocab:inputTo ROS2SimulationEnvironment
    DTDFVocab:inputTo MATLABSimulationEngine
]

instance AutonomousVehicleBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model implementing AI/ML algorithms for autonomous driving, including adaptive cruise control and obstacle avoidance based on real-time sensor data."
    DTDFVocab:inputTo ROS2SimulationEnvironment
    DTDFVocab:fromData ObjectTracksData, ProjectedDrivingPathData
]

instance ProcessedLiDARData : DTDFVocab:Data [
    base:desc "Structured LiDAR data after preprocessing, containing clustered point clouds and tracked objects for visualization and control applications."
    DTDFVocab:fromData LiDARPointCloudData
    DTDFVocab:inputTo DataCollectingFunctionalEntity
    DTDFVocab:inputTo ThreeDVisualizationUserInterface
]

instance VehicleStateMetrics : DTDFVocab:Data [
    base:desc "Real-time vehicle dynamics metrics including speed, trajectory, motor actuation, and steering data processed for monitoring and control."
    DTDFVocab:fromData VehicleStateData
    DTDFVocab:inputTo DataCollectingFunctionalEntity
    DTDFVocab:inputTo AutonomousControlSystem
]

instance ObjectDetectionResults : DTDFVocab:Data [
    base:desc "Processed object detection results from LiDAR and depth camera data, identifying environmental objects with spatial-temporal attributes for situational awareness."
    DTDFVocab:fromData ObjectTracksData
    DTDFVocab:inputTo DataCollectingFunctionalEntity
    DTDFVocab:inputTo CollisionRiskAssessment
]

// C11: Enablers
instance ROS2SimulationEnvironment : DTDFVocab:Enabler [
    base:desc "Robot Operating System 2 framework enabling real-time data acquisition, sensor fusion, and control in autonomous systems with high-frequency communication capabilities."
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:enables ComputationOffloadingService
    DTDFVocab:inputTo DigitalTwinGeometricModel
    DTDFVocab:inputTo AutonomousVehicleBehaviorModel
]

instance NVIDIAJetsonOrinNano : DTDFVocab:Enabler [
    base:desc "Edge AI microcomputer for real-time processing of sensor data (LiDAR, IMU) with NVIDIA CUDA acceleration, enabling onboard AI inference and low-latency control."
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:enables AutonomousControlSystem
]

instance MATLABSimulationEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for modeling, simulation, and control system design, supporting AI-driven simulations for autonomous driving and manufacturing processes."
    DTDFVocab:enables SimulationBasedOptimizationService
    DTDFVocab:inputTo AutonomousVehicleBehaviorModel
    DTDFVocab:inputTo DigitalTwinGeometricModel
]

instance GazeboSimulationEnvironment : DTDFVocab:Enabler [
    base:desc "ROS2-compatible simulation environment for testing and validating autonomous vehicle behaviors in virtual environments with realistic physics modeling."
    DTDFVocab:enables SimulationBasedOptimizationService
    DTDFVocab:inputTo AutonomousVehicleBehaviorModel
]

instance CloudEdgeDatabase : DTDFVocab:Enabler [
    base:desc "Distributed database system for storing and processing time-series sensor data and simulation results, enabling predictive analytics and historical data analysis."
    DTDFVocab:enables PredictiveAnalyticsService
    DTDFVocab:fromData DataCollectingFunctionalEntity
]

instance MQTTCommunicationProtocol : DTDFVocab:Enabler [
    base:desc "Secure IoT communication protocol for transmitting sensor data and control commands between physical and digital twin components with low-latency requirements."
    DTDFVocab:enables RemoteManagementService
    DTDFVocab:enables DataMonitoringService
]

instance DockerContainerization : DTDFVocab:Enabler [
    base:desc "Containerization framework for deploying Digital Twin services and microservices architecture, ensuring modularity and scalability across edge and cloud environments."
    DTDFVocab:enables ComputationOffloadingService
    DTDFVocab:enables RemoteManagementService
]

instance ISO23247DigitalTwinFramework : DTDFVocab:Enabler [
    base:desc "Standardized architectural framework for designing and implementing Digital Twins in automotive and industrial IoT contexts, providing entity-based decomposition and interoperability standards."
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:enables ComputationOffloadingService
    DTDFVocab:enables RemoteManagementService
    DTDFVocab:enables SimulationBasedOptimizationService
    DTDFVocab:enables PredictiveAnalyticsService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time collection, aggregation, and visualization of sensor data (LiDAR, IMU, vehicle state) from the physical twin for operational health tracking and anomaly detection in autonomous systems."
    DTDFVocab:provides RealTimeInsights
    DTDFVocab:provides AnomalyDetectionAlerts
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloading computationally intensive tasks (simulation, AI inference) from the physical twin to edge or cloud platforms to reduce latency and conserve onboard resources in real-time control systems."
    DTDFVocab:provides OptimizedComputationResults
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables remote configuration, debugging, and over-the-air (OTA) updates for the physical twin across distributed environments, supporting remote diagnostics and system management."
    DTDFVocab:provides RemoteConfigurationUpdates
    DTDFVocab:provides RemoteDiagnosticsReports
]

instance SimulationBasedOptimizationService : DTDFVocab:Service [
    base:desc "AI-driven simulation environment for optimizing autonomous driving behaviors and manufacturing processes through high-fidelity modeling and predictive analytics."
    DTDFVocab:provides OptimizedSimulationParameters
    DTDFVocab:provides PerformanceForecasts
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service for failure forecasting and performance optimization in cyber-biophysical systems using historical and real-time data."
    DTDFVocab:provides FailureForecastAlerts
    DTDFVocab:provides PerformanceOptimizationRecommendations
]

// C17: Insights/Actions
instance RealTimeInsights : DTDFVocab:Insight [
    base:desc "Monitoring dashboards providing real-time ego vehicle state data (speed, sensor readings) and surrounding vehicle tracks for situational awareness in autonomous systems."
]

instance AnomalyDetectionAlerts : DTDFVocab:Insight [
    base:desc "Automated alerts identifying operational anomalies in sensor data or system behavior, enabling proactive maintenance and fault detection."
    DTDFVocab:IsAutomatic true
]

instance OptimizedComputationResults : DTDFVocab:Action [
    base:desc "Processed results from offloaded computational tasks (simulation, AI inference) returned to the physical twin for real-time control decision-making."
    DTDFVocab:IsAutomatic true
]

instance RemoteConfigurationUpdates : DTDFVocab:Action [
    base:desc "Remote configuration changes applied to the physical twin's control parameters, sensor calibration, or system settings via OTA updates."
    DTDFVocab:IsAutomatic false
]

instance RemoteDiagnosticsReports : DTDFVocab:Insight [
    base:desc "Detailed diagnostic reports generated remotely for system health assessment, performance metrics, and maintenance recommendations."
]

instance OptimizedSimulationParameters : DTDFVocab:Action [
    base:desc "Optimized parameters for simulation environments derived from AI-driven analytics, improving autonomous system performance and safety."
    DTDFVocab:IsAutomatic true
]

instance PerformanceForecasts : DTDFVocab:Insight [
    base:desc "Predictive forecasts of system performance metrics, including failure probabilities and operational efficiency indicators."
]

instance FailureForecastAlerts : DTDFVocab:Insight [
    base:desc "Automated alerts predicting potential system failures based on predictive analytics models and historical data patterns."
    DTDFVocab:IsAutomatic true
]

instance PerformanceOptimizationRecommendations : DTDFVocab:Action [
    base:desc "Actionable recommendations for optimizing system performance based on predictive analytics, including parameter adjustments and operational strategies."
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller interfacing with autonomous vehicle motors, enabling precise actuation and control of vehicle propulsion systems within specified torque and speed limits."
]

instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "High-precision steering servo for autonomous vehicle navigation, implementing real-time control commands with defined actuation ranges and safety constraints."
]

// C1: Environments
instance AutonomousVehicleEnvironment : DTDFVocab:Environment [
    base:desc "Operational environment for the 1/10-scale autonomous vehicle including structured testing areas, obstacle courses, and dynamic traffic scenarios for validation."
    base:contains HokuyoUST10LXLiDAR
    base:contains IntelRealsenseD435IDepthCamera
    base:contains VehicleStateSensor
    base:contains VedderElectronicSpeedController
    base:contains SteeringServo
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:desc "Computational environment hosting the Digital Twin system including edge computing nodes, simulation engines, and cloud databases for real-time processing."
    base:contains ROS2SimulationEnvironment
    base:contains MATLABSimulationEngine
    base:contains GazeboSimulationEnvironment
    base:contains CloudEdgeDatabase
]

// C5: Functional Entities
instance DataCollectingFunctionalEntity : DTDFVocab:Component [
    base:desc "Functional entity aggregating raw and processed data for storage and reporting, serving as the interface between sensing components and data processing systems."
    base:isContainedIn DigitalTwinEntity
    DTDFVocab:fromData ProcessedLiDARData
    DTDFVocab:fromData VehicleStateMetrics
    DTDFVocab:fromData ObjectDetectionResults
]

instance ReportingFunctionalEntity : DTDFVocab:Component [
    base:desc "Functional entity generating reports from integrated data streams including vehicle state, object tracks, and driving paths for operational analysis."
    base:isContainedIn DigitalTwinEntity
    DTDFVocab:fromData DataCollectingFunctionalEntity
]

instance PresentationFunctionalEntity : DTDFVocab:Component [
    base:desc "3D visualization user interface component rendering processed data including vehicle and environmental visualizations for situational awareness."
    base:isContainedIn DigitalTwinEntity
    DTDFVocab:fromData ProcessedLiDARData
    DTDFVocab:fromData VehicleStateMetrics
]

instance AutonomousControlSystem : DTDFVocab:Component [
    base:desc "Control system implementing real-time decision-making algorithms for autonomous vehicle navigation based on sensor data and behavioral models."
    base:isContainedIn DigitalTwinEntity
    DTDFVocab:fromData AutonomousVehicleBehaviorModel
    DTDFVocab:fromData ObjectDetectionResults
    DTDFVocab:fromData ProjectedDrivingPathData
]

instance CollisionRiskAssessment : DTDFVocab:Component [
    base:desc "Functional entity assessing collision risk based on object detection results and vehicle state data, providing safety alerts for autonomous systems."
    base:isContainedIn DigitalTwinEntity
    DTDFVocab:fromData ObjectDetectionResults
    DTDFVocab:fromData VehicleStateMetrics
]

// C7: Digital Twin Entity Structure
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical twin entity representing the 1/10-scale autonomous vehicle hardware including sensors, actuators, and onboard computing resources for real-time interaction."
    base:isContainedIn DigitalTwinSystem
    base:contains HokuyoUST10LXLiDAR
    base:contains IntelRealsenseD435IDepthCamera
    base:contains VehicleStateSensor
    base:contains VedderElectronicSpeedController
    base:contains SteeringServo
    base:contains NVIDIAJetsonOrinNano
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital twin entity serving as the computational core hosting high-fidelity models, simulation engines, and processing components for autonomous system control."
    base:isContainedIn DigitalTwinSystem
    base:contains DataCollectingFunctionalEntity
    base:contains ReportingFunctionalEntity
    base:contains PresentationFunctionalEntity
    base:contains AutonomousControlSystem
    base:contains CollisionRiskAssessment
    base:contains PointCloudClusteringAndTrackingModel
    base:contains DataPreProcessingFunctionalEntity
    base:contains DataTranslationFunctionalEntity
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User interface entity providing human-machine interaction capabilities including monitoring dashboards, configuration tools, and remote management interfaces."
    base:isContainedIn DigitalTwinSystem
    base:contains PresentationFunctionalEntity
    base:contains ThreeDVisualizationUserInterface
    base:contains ControlPanelFunctionalEntity
]

instance DigitalTwinSystem : DTDFVocab:Component [
    base:desc "Complete Digital Twin system following ISO 23247 entity-centric methodology with Physical Twin Entity, Digital Twin Entity, and User Entity components."
    base:contains PhysicalTwinEntity
    base:contains DigitalTwinEntity
    base:contains UserEntity
]

instance ThreeDVisualizationUserInterface : DTDFVocab:Component [
    base:desc "3D visualization component rendering processed data including vehicle and environmental visualizations for situational awareness and monitoring."
    base:isContainedIn UserEntity
    DTDFVocab:fromData ProcessedLiDARData
    DTDFVocab:fromData VehicleStateMetrics
]

instance ControlPanelFunctionalEntity : DTDFVocab:Component [
    base:desc "User interface component providing remote configuration, debugging, and system management capabilities for the Digital Twin system."
    base:isContainedIn UserEntity
    DTDFVocab:fromData RemoteManagementService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "
The **Virtual-to-Physical Interaction** in this DTS involves control commands generated by the Digital Twin Entity being transmitted to the Physical Twin Entity (e.g., vehicle) for actuation. Key components include:

1. **Command Types**:
   - **ACC (Adaptive Cruise Control) Commands**: Generated by the **Controlling FE** to regulate vehicle speed and trajectory based on real-time data (e.g., object tracks, driving path projections).
   - **Actuation Commands**: Motor and steering servo actuation signals derived from control logic (e.g., **Actuation FE** processes commands for physical actuators).

2. **Control Message Formats**:
   - **Data Translation FE**: Serializes and aligns control messages (e.g., ACC commands) with standardized formats for transmission.
   - **Unit Conversions**: Ensures compatibility between digital control signals and physical actuator requirements (e.g., voltage, torque, angle).

3. **Validation and Authentication Mechanisms**:
   - Not explicitly detailed in the document. Assumed to rely on **Data Translation FE** for message integrity (e.g., serialization/deserialization checks) but no explicit authentication protocols (e.g., encryption, digital signatures) are mentioned.

4. **Feedback Systems**:
   - **Closed-Loop Control**: The system uses real-time feedback from **Vehicle State** and **Object Tracks** to adjust control commands dynamically (e.g., ACC recalculates trajectory based on new sensor inputs).
   - **Visualization Feedback**: **3D Visualization FE** displays projected driving paths and object interactions, aiding human-in-the-loop validation (e.g., driver/operator oversight).

5. **Conflict Resolution**:
   - Not explicitly described. Implied to rely on **Controlling FE** logic to prioritize commands (e.g., emergency braking over speed adjustments) based on sensor data prioritization rules.

6. **Command Execution Confirmation**:
   - Not explicitly detailed. Assumed to be inferred via **Vehicle State** updates (e.g., motor/steering responses) and **Object Track** consistency checks in the Digital Twin.
"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system enforces a **100 ms clock synchronization accuracy** between physical and digital components to enable computation offloading and coordination. This temporal constraint is mandated due to hardware limitations, ensuring precise synchronization for safety-critical vehicular applications. The system relies on strict time alignment between devices to maintain consistency in data processing, actuation, and sensor feedback loops. Latency requirements for real-time services (e.g., *Point Cloud Clustering & Tracking*) are implicitly constrained by this synchronization, though explicit latency thresholds for individual services are not detailed in the documents. Temporal granularity is dictated by the ROS2-based execution model, where each *Functional Entity (FE)* operates as an independent ROS2 node with millisecond-scale precision for inter-node communication via ROS2 topics."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin System adopts a **ROS2-based microservices architecture**, where each *Functional Entity (FE)* is implemented as an independent ROS2 package containing one or more ROS2 nodes. This design adheres to the *ISO 23247 Reference Architecture (RA)* for automotive Digital Twins but introduces deviations: the *Physical Twin Entity* extends beyond OME’s scope to include general automotive functionalities (e.g., *Point Cloud Clustering & Tracking*), while the *User Entity* splits the *User Interface FE* into *3D Visualization* and *Control Panel* components. Orchestration relies on ROS2’s **topic-based pub/sub communication** for inter-node coordination, with no explicit mention of higher-level orchestration frameworks (e.g., Kubernetes, Docker Swarm). Resource management is implicit, tied to hardware deployment constraints (e.g., separate hardware per FE), and system-wide coordination is achieved through ROS2’s **time-synchronized node execution** and clock synchronization protocols."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "
The lifecycle of the Digital Twin (DT) system described in the provided documents adheres to the **ISO 23247 Digital Twin Framework for Manufacturing**, specifically Part 2 of the standard, which defines an **entity-based reference architecture (RA)**. The lifecycle is structured around **Observable Manufacturing Elements (OMEs)**, which include physical items such as equipment, facilities, products, personnel, or processes. Each OME is paired with a **Digital Twin Entity (DTE)** that provides its digital representation, while **Functional Entities (FEs)** decompose tasks such as data collection, transformation, or user interaction. Transition management between lifecycle phases is implied through the **entity-based modularity**, where each entity (OME, DTE, or FE) operates independently but collaboratively. However, explicit lifecycle phases (e.g., development, operationalization, maintenance, decommissioning) are not detailed in the documents. Governance approaches are not specified beyond the standard’s **entity-based RA framework**, which mandates clear separation of responsibilities (e.g., data collection via *Data Collection and Device Control Entity*). The standard does not prescribe lifecycle governance mechanisms but allows flexibility in implementation, such as using **OPC Unified Architecture (UA)** for interoperability between entities.

No explicit mention of lifecycle governance, transition protocols, or phase-specific representations (e.g., conceptual, virtual, or digital models) is provided in the documents.
"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
The Digital Twin system is described as a **high-fidelity computational reflection** of OMEs, with fidelity requirements tied to **real-time latency constraints** for critical applications (e.g., autonomous manufacturing). Validation and verification methods are not explicitly detailed, though the ISO 23247 framework implies **entity-based consistency checks** between OME observations and Digital Twin representations. Uncertainty sources are inferred to include **sensor noise, model parameter drift, and communication delays**, but no quantification methods (e.g., statistical testing, Bayesian inference) or error detection algorithms (e.g., machine learning models) are mentioned. Error correction mechanisms are unspecified, though the modular **Functional Entity (FE)** architecture may support pluggable validation modules. Quality assurance processes are aligned with **ISO 23247 standards**, emphasizing **traceability and reproducibility** of digital representations but lacking concrete metrics or auditing procedures.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "
The **technical network infrastructure** of this DTS is designed for **low-latency, real-time communication** between entities. **Communication protocols** include **ROS2** for intra-entity software communication (e.g., between *Data Pre-Processing FE* and *Visualization FE*) and **Wi-Fi with UDP transport** for inter-entity communication (e.g., Physical Twin Entity ↔ Digital Twin Entity). The system explicitly references **UDP** in the truncated sentence ('using U'), though no explicit bandwidth or reliability guarantees (e.g., retransmission) are documented.

**Network topology** follows a **distributed architecture**, with separate hardware components for Physical Twin, Digital Twin, and User Entities (as implied by Fig. 2). **Latency requirements** are inferred from **Requirement R7** (not fully shown), which likely mandates **≤100 ms end-to-end latency** for critical control/data paths. **Reliability mechanisms** are not detailed, though the use of **ROS2 QoS policies** (implied by the judge feedback) may underpin some guarantees. **Security protocols** are not mentioned in the provided documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "
The **deployment infrastructure** of this DTS leverages a **hybrid hardware architecture** with distinct entities hosted on separate components: the *Physical Twin Entity* (onboard vehicle hardware), the *Digital Twin Entity* (likely edge/on-premise servers), and the *User Entity* (user interface devices). **Hosting platforms** are not explicitly stated, but the mention of **ROS2** and **Wi-Fi/UDP communication** suggests an **on-premise/edge deployment** model, with no cloud integration implied.

**Computational requirements** include processing for *Point Cloud Clustering & Tracking* (likely CPU-intensive) and *Data Translation FE* (serialization/unit conversion). **Storage** is managed via a **SQL database** (as per Table I), though no specifics on scalability (e.g., sharding, replication) or **GPU acceleration** are provided. **Scalability mechanisms** are not detailed, nor are **availability/reliability assurances** (e.g., failover, redundancy). The system supports **deployment models** for Physical Twin (vehicle-mounted) and Digital Twin (centralized), but no multi-tenant or cloud-native deployment is referenced."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to the **ISO 23247 standard**, a **four-part framework** for manufacturing Digital Twins. **Part 2 (Reference Architecture)** defines an **entity-based RA** with **Observable Manufacturing Elements (OMEs)**, **Data Collection and Device Control Entities**, **Digital Twin Entities (DTEs)**, and **User Entities**, ensuring structured interoperability. The standard mandates **OPC Unified Architecture (OPC UA)** as a recommended protocol for FE implementation, though it does not enforce compliance. **Certification requirements** are not mentioned, but the modular FE design aligns with **interoperability standards** like **ISO/IEC 62264 (Enterprise-Control System Integration)** and **IEC 62424 (Industrial Data Objects)**. Compliance frameworks are not explicitly outlined, but the RA’s entity decomposition supports **modular certification** of individual FEs. The standard emphasizes **information exchange** (Part 4) but lacks explicit mention of **industry-specific certifications** (e.g., IEC 61508 for safety-critical systems)."
]