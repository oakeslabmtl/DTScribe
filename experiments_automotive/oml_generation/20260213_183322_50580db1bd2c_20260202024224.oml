// ---------- Sensing Components ----------
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2‑D LiDAR providing distance measurements for obstacle detection."
]

instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera delivering synchronized RGB‑D streams for scene understanding."
]

instance VehicleCANBusTelemetry : DTDFVocab:SensingComponent [
    base:desc "CAN bus telemetry interface providing motor status, steering servo position, and overall vehicle state."
]

// ---------- Data Transmitted (raw sensor streams) ----------
instance LiDARRawPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthCameraRawRGBDTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]

instance CANBusRawTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleCANBusTelemetry
]

// ---------- Data (raw) ----------
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data generated by the Hokuyo UST‑10LX sensor."
    DTDFVocab:fromData LiDARRawPointCloudTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance DepthCameraRGBDData : DTDFVocab:Data [
    base:desc "RGB‑D frames from the Intel Deepsense D435i depth camera."
    DTDFVocab:fromData DepthCameraRawRGBDTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance CANBusTelemetryData : DTDFVocab:Data [
    base:desc "Vehicle CAN bus telemetry providing motor status, steering position, and vehicle state."
    DTDFVocab:fromData CANBusRawTelemetryTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

// ---------- Models ----------
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "Point Cloud Clustering using the DBSCAN algorithm to group LiDAR points into individual objects."
    DTDFVocab:inputTo DataProcessingEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Object tracking using a Kalman filter on clustered point cloud data to generate continuous object tracks."
    DTDFVocab:inputTo DataProcessingEnabler
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "ACC logic that consumes tracked object data and ego vehicle state to compute desired speed set‑points."
    DTDFVocab:inputTo ACCComputationEnabler
]

// ---------- Data Transmitted (model outputs) ----------
instance ClusteredPointCloudTransmitted : DTDFVocab:DataTransmitted [
    // No producedFrom relationship (models are not SensingComponents)
]

instance ObjectTracksTransmitted : DTDFVocab:DataTransmitted [
    // No producedFrom relationship (models are not SensingComponents)
]

instance DesiredSpeedSetpointTransmitted : DTDFVocab:DataTransmitted [
    // No producedFrom relationship (models are not SensingComponents)
]

// ---------- Data (processed) ----------
instance ClusteredPointCloudData : DTDFVocab:Data [
    base:desc "Clustered point cloud representing individual objects after DBSCAN processing."
    DTDFVocab:fromData ClusteredPointCloudTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Tracked object positions and velocities generated by the Kalman filter."
    DTDFVocab:fromData ObjectTracksTransmitted
    DTDFVocab:inputTo ACCComputationEnabler
]

instance DesiredSpeedSetpointData : DTDFVocab:Data [
    base:desc "Desired speed set‑point computed by the ACC algorithm for the ego vehicle."
    DTDFVocab:fromData DesiredSpeedSetpointTransmitted
    DTDFVocab:inputTo RemoteControlEnabler
]

// ---------- Enablers ----------
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing enabler that executes clustering and tracking models within the ROS 2/DDS middleware."
    DTDFVocab:enables DataMonitoringService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that runs ACC logic on cloud compute resources and returns a desired speed set‑point."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that translates ACC set‑points into actuator commands for the ESC and steering servo."
    DTDFVocab:enables RemoteManagementService
]

// ---------- Services ----------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of vehicle state, projected path, and nearby object tracks supports data export and reporting."
    DTDFVocab:provides VehicleStateInsight, ObjectTrackInsight, PathProjectionInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads the ACC algorithm to cloud resources and delivers the computed desired speed set‑point back to the vehicle."
    DTDFVocab:provides GenerateDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to activate/deactivate ACC, set target speeds, and issue emergency brake commands via low‑latency bi‑directional communication."
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// ---------- Insights ----------
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into the current ego vehicle speed, position, and heading derived from CAN bus telemetry."
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Insight displaying positions and velocities of tracked surrounding objects."
]

instance PathProjectionInsight : DTDFVocab:Insight [
    base:desc "Insight projecting the future vehicle trajectory based on current speed and ACC set‑point."
]

// ---------- Actions ----------
instance GenerateDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Automatically computes and sends the desired speed set‑point to the vehicle."
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Allows an operator to enable or disable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Allows an operator to manually set a target speed for ACC operation."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Commands an immediate stop via the ESC for safety."
    DTDFVocab:IsAutomatic false
]

// ---------- Acting Components ----------
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder ESC drives the propulsion motor, receiving voltage commands from the digital twin."
]

instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Servo provides lateral steering control, receiving angle commands from the digital twin."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the User Interface FE (Control Panel) and are routed through the Controlling FE (ACC) to the Actuation FE. The Actuation FE translates high‑level commands such as desired speed, steering angle or braking request into motor voltage or servo position commands, which are sent to the physical vehicle actuators. Command messages are formatted according to the ROS 2 data model and are passed through the Data Translation FE to ensure correct units and message alignment before reaching the physical actuators. Execution confirmation is provided by feedback streams of actuator status that are fed back into the monitoring pipeline."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires device clock synchronization with a maximum error of 100 ms, mandated by hardware limitations and safety-critical vehicular standards. This synchronization granularity is applied to all computation‑offloading interactions between physical and digital components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin follows the ISO 23247 Reference Architecture: software components are organized into three Functional Entities (FEs) – User Entity, Digital Twin Entity, and Physical Twin Entity – each deployed on separate hardware. Every FE is realized as an individual ROS2 package containing one or more ROS2 nodes that implement the FE's functionality. The mapping of software components to FEs provides a clear orchestration layer, while the Physical Twin Entity hosts resource‑specific functions (e.g., sensors, actuators, point‑cloud clustering) and the Digital Twin Entity handles data management and control. This entity‑based decomposition dictates system‑wide coordination and resource allocation across the distributed hardware."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin System uses a two‑layer network architecture: intra‑entity communication is realized with ROS 2 (DDS‑based) on the local computational platform, and inter‑entity communication employs a Wi‑Fi network using UDP at the transport layer. The system is designed to satisfy a maximum end‑to‑end latency of 100 ms (Requirement R7). Reliability is supported by ROS 2’s built‑in QoS policies; redundancy is achieved by deploying each functional entity on separate hardware components. Security is confined to the network layer, with Wi‑Fi providing link‑level protection; no additional security protocols are described in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Each functional entity of the DTS (Data Monitoring, Actuation, Control, Visualization, etc.) is deployed on dedicated hardware components, allowing a distributed edge deployment of the twin. Persistent vehicle state data are stored on a storage device external to the vehicle (Requirement R3). The deployment model supports on‑premise edge nodes with the possibility of cloud integration for long‑term storage and analytics, and includes scalability by adding further hardware nodes for additional sensor or processing workloads. Availability is addressed by the separation of entities across hardware, which isolates failures and maintains system operation."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin conforms to the ISO 23247 series (published 2021), specifically leveraging Part 2 (Reference Architecture) which defines an entity‑based architecture composed of Observable Manufacturing Elements, Data Collection and Device Control Entities, Digital Twin Entities, and User Entities, each subdivided into Functional Entities. The implementation may employ OPC Unified Architecture (OPC UA) for data collection, device control, and interoperability, aligning with the information‑exchange principles of Part 4 of ISO 23247."
]