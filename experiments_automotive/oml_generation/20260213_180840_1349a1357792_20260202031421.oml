// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2-D LiDAR sensor providing raw point cloud data for object detection and tracking"
    DTDFVocab:producedData HokuyoLiDARPointCloudData
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera capturing RGB-D frames for environmental perception and object reconstruction"
    DTDFVocab:producedData DepthCameraFramesData
]

instance OnBoardOdometry : DTDFVocab:SensingComponent [
    base:desc "On-board odometry system providing ego-vehicle speed and steering angle measurements via wheel encoders and IMU fusion"
    DTDFVocab:producedData VehicleStateData
]

instance JetsonOrinNanoSensorInterface : DTDFVocab:SensingComponent [
    base:desc "NVIDIA Jetson Orin Nano microcomputer capturing and preprocessing sensor streams (LiDAR, camera, odometry) for transmission to the Digital Twin"
    DTDFVocab:producedData PreprocessedSensorData
]

// C4: Physical-to-Virtual Interaction
instance HokuyoLiDARPointCloudData : DTDFVocab:DataTransmitted [
    base:desc "Raw LiDAR point cloud data serialized and published over ROS2 topics with unit conversion from meters to millimeters"
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraFramesData : DTDFVocab:DataTransmitted [
    base:desc "Depth camera frames serialized as ROS2 Image messages with aligned RGB-D data and timestamp synchronization"
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    base:desc "Ego-vehicle speed and steering angle measurements serialized as ROS2 Twist messages with unit conversion (m/s to km/h, radians to degrees)"
    DTDFVocab:producedFrom OnBoardOdometry
]

instance PreprocessedSensorData : DTDFVocab:DataTransmitted [
    base:desc "Aggregated sensor data (LiDAR, camera, odometry) serialized as ROS2 SensorData message with aligned timestamps and message type conversion"
    DTDFVocab:producedFrom JetsonOrinNanoSensorInterface
]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm for segmenting LiDAR point clouds into object clusters with configurable epsilon and minPoints parameters"
    DTDFVocab:inputTo SensorDataProcessingEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter for tracking detected objects across frames with state estimation (position, velocity, acceleration) and uncertainty propagation"
    DTDFVocab:inputTo SensorDataProcessingEnabler
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "ACC control model following ISO 15622 standard for lead-vehicle identification, time-gap calculation, and speed set-point adjustment"
    DTDFVocab:inputTo ControlAlgorithmEnabler
]

instance VehicleStateTimeSeriesData : DTDFVocab:Data [
    base:desc "Time-series database of vehicle state (speed, steering, acceleration) with 10Hz sampling rate for reporting and visualization"
    DTDFVocab:fromData VehicleStateData
    DTDFVocab:inputTo DataVisualizationEnabler
]

instance ObjectTrackTimeSeriesData : DTDFVocab:Data [
    base:desc "Time-series database of object tracks (position, velocity, class) generated from clustered point clouds with 5Hz update rate"
    DTDFVocab:fromData PreprocessedSensorData
    DTDFVocab:inputTo DataVisualizationEnabler
]

instance ProjectedPathData : DTDFVocab:Data [
    base:desc "Predicted vehicle trajectory based on current state and ACC model outputs, updated at 1Hz for path visualization"
    DTDFVocab:fromData VehicleStateData
    DTDFVocab:inputTo DataVisualizationEnabler
]

// C11: Enablers
instance SensorDataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2-based pipeline for sensor data deserialization, unit conversion, and alignment using Python 3.8 and C++ lifecycle management"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance ControlAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink implementation of ACC algorithm with real-time execution on edge server via ROS2 service calls"
    DTDFVocab:enables ComputationOffloadingService
]

instance DataVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D visualization framework using ROS2 RViz2 for real-time rendering of vehicle state, object tracks, and projected paths"
    DTDFVocab:enables DataMonitoringService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 action server interface for operator commands (ACC enable/disable, speed adjustment, emergency braking) with Wi-Fi connectivity"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization service displaying 3D object tracks, projected vehicle path, and generating time-series reports of vehicle state"
    DTDFVocab:provides RealTimeVisualInsight, TimeSeriesReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service offloading ACC algorithm execution from on-board ECU to Digital Twin Entity for reduced on-vehicle computational load"
    DTDFVocab:provides ACCControlAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator interface for remote enabling/disabling of ACC, adjusting desired speed, and triggering emergency braking"
    DTDFVocab:provides ACCEnableAction, SpeedAdjustmentAction, EmergencyBrakeAction
]

// C17: Insights/Actions
instance RealTimeVisualInsight : DTDFVocab:Insight [
    base:desc "3D visualization of vehicle state (position, speed), detected objects (tracks, classes), and projected path with ROS2 RViz2"
]

instance TimeSeriesReportInsight : DTDFVocab:Insight [
    base:desc "Generated reports of vehicle state time-series data (speed, steering, acceleration) with configurable time windows and export formats"
]

instance ACCControlAction : DTDFVocab:Action [
    base:desc "Automatic adaptive cruise control execution with lead-vehicle detection and speed set-point adjustment"
    DTDFVocab:IsAutomatic true
]

instance ACCEnableAction : DTDFVocab:Action [
    base:desc "Remote command to enable or disable the ACC system based on operator input"
    DTDFVocab:IsAutomatic false
]

instance SpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Remote adjustment of desired speed set-point for the ACC system with validation checks"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediate emergency braking command triggered by operator or system detection of critical conditions"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance ElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Vedder electronic speed controller receiving motor voltage commands from the Actuation Functional Entity for speed control"
]

instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Steering servo mechanism receiving angle commands from the Actuation Functional Entity for path following"
]

// C1: Environment
instance AutonomousVehiclePhysicalTwin : DTDFVocab:Environment [
    base:desc "1/10-scale autonomous vehicle platform with retrofitted upper chassis hosting autonomy hardware and lower chassis for actuation"
    base:contains JetsonOrinNanoSensorInterface, OnBoardOdometry, HokuyoUST10LXLiDAR, IntelRealSenseD435iDepthCamera, ElectronicSpeedController, SteeringServo
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:desc "Cloud/edge server deployment for the Digital Twin Entity with ROS2 middleware and NVIDIA JetPack 5.0 SDK"
    base:contains SensorDataProcessingEnabler, ControlAlgorithmEnabler, DataVisualizationEnabler, RemoteManagementEnabler
]

instance UserWorkstationEnvironment : DTDFVocab:Environment [
    base:desc "Operator workstation for visualization and remote management with Wi-Fi connectivity to the Digital Twin"
    base:contains DataMonitoringService, RemoteManagementService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity sends control commands back to the PT through the Actuation FE: (1) desired speed values that are converted to motor voltage commands, (2) enable/disable ACC flags, (3) modified speed set‑points, and (4) emergency‑brake commands. These messages travel over a Wi‑Fi link and are applied by the vehicle’s electronic speed controller and steering servo."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in real time with stringent timing: network latency between PT and DT must not exceed 100 ms (R7) and clocks on all components are synchronised to within 100 ms (R8). This ensures that off‑loaded ACC computations and control commands are delivered within a sub‑100 ms window."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation follows the ISO 23247 reference architecture: the Physical Twin Entity hosts sensor acquisition and actuation FEs; the Digital Twin Entity contains Data Collection, Presentation, Reporting, and Controlling FEs; the User Entity provides the 3D Visualization and Control Panel UI FEs; and a Cross‑System Data Translation FE mediates data exchange. Intra‑entity communication uses ROS 2 topics, while inter‑entity links use Wi‑Fi and the Data Translation layer."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is used across multiple lifecycle stages: (i) design and testing – as a cyber‑physical experimentation platform with high‑fidelity simulation, (ii) production/validation – to verify compliance with ISO 15622 ACC specifications, and (iii) operation – for real‑time monitoring, remote management, and performance analytics of the running vehicle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity is achieved by using raw sensor streams (LiDAR, camera) and real‑time clustering/tracking. Model validity is ensured by adhering to ISO 15622 for ACC behavior and by meeting the 100 ms latency and clock‑sync requirements, which are verified experimentally. The DBSCAN‑Kalman pipeline provides quantitative tracking accuracy, and the SQL‑based data storage enables post‑run validation against ground truth."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication between PT and DT occurs over a Wi‑Fi network using ROS 2 messages (DDS underneath). The Data Translation FE serialises messages, performs unit conversion, and ensures type compatibility across the ROS 2 middleware. No additional application‑layer protocol is specified beyond ROS 2."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the on‑board NVIDIA Jetson Orin Nano (Linux); the Digital Twin Entity (ACC computation, data processing, reporting) is deployed on a cloud or edge server accessible via Wi‑Fi; the User Entity UI runs on a separate workstation or laptop. All components are packaged as ROS 2 nodes and launched via ROS 2 launch files."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture and development follow ISO 23247 (Digital Twin Manufacturing Framework) as the primary reference architecture, ISO 15622 for ACC functional requirements, and cite ISO/IEC 30173 for digital‑twin terminology. OPC UA (IEC 62541) is mentioned as a possible implementation for the Data Translation FE, though not used in the case study."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed through real‑time latency (≤100 ms) and clock synchronization (≤100 ms) to guarantee timely control actions, compliance with ISO 15622 ACC specifications, and the inclusion of an emergency‑brake command that can be issued remotely. No explicit cybersecurity mechanisms (e.g., authentication, encryption) are described in the document."
]