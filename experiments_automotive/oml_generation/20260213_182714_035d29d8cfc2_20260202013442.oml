// -------------------------------------------------
// C3: Physical sensing components
// -------------------------------------------------
instance HokuyoUST110LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑110LX LiDAR providing high‑frequency 2‑D point clouds for environment perception"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D frames for 3‑D perception"
    DTDFVocab:producedData DepthCameraFrameTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring ego‑vehicle longitudinal speed"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring steering wheel angle"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// -------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// -------------------------------------------------
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST110LXLiDAR
]

instance DepthCameraFrameTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ObjectTrackTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST110LXLiDAR, IntelRealSenseD435iDepthCamera
]

// -------------------------------------------------
// C5: Data assets
// -------------------------------------------------
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream transmitted from the Physical Twin"
    DTDFVocab:fromData LiDARPointCloudTransmitted
]

instance DepthCameraFrameData : DTDFVocab:Data [
    base:desc "Raw depth‑camera RGB‑D frames transmitted from the Physical Twin"
    DTDFVocab:fromData DepthCameraFrameTransmitted
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego‑vehicle speed measurements streamed from the Physical Twin"
    DTDFVocab:fromData VehicleSpeedTransmitted
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering‑angle measurements streamed from the Physical Twin"
    DTDFVocab:fromData SteeringAngleTransmitted
]

instance ProcessedObjectTrackData : DTDFVocab:Data [
    base:desc "Object tracks after DBSCAN clustering and Kalman‑filter tracking"
    DTDFVocab:fromData ObjectTrackTransmitted
]

instance ACCSetpointData : DTDFVocab:Data [
    base:desc "Adaptive Cruise Control speed set‑points generated by the ACC model"
    // No direct fromData link because the source is a processed Data, not a DataTransmitted
]

instance VisualizationData : DTDFVocab:Data [
    base:desc "3‑D visualization primitives for UI rendering"
    DTDFVocab:fromData ObjectTrackTransmitted
]

instance SqlReportData : DTDFVocab:Data [
    base:desc "Aggregated vehicle‑state reports stored in the SQL database"
    DTDFVocab:fromData VehicleSpeedTransmitted, SteeringAngleTransmitted, ObjectTrackTransmitted
]

// -------------------------------------------------
// C10: Models
// -------------------------------------------------
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering module for segmenting LiDAR point clouds into obstacle clusters"
]

instance KalmanFilterTrackerModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based multi‑target tracker that refines DBSCAN clusters into continuous object tracks"
]

instance ACCModel : DTDFVocab:Model [
    base:desc "ISO‑15622 compliant Adaptive Cruise Control model performing lead‑vehicle detection and set‑point generation"
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D rendering model that converts vehicle state and object tracks into UI visualizations"
]

// -------------------------------------------------
// C11: Enablers
// -------------------------------------------------
instance ROS2NodeLiDARProcessing : DTDFVocab:Enabler [
    base:desc "ROS 2 node (DDS middleware) executing DBSCAN and Kalman‑filter on incoming LiDAR data"
]

instance ROS2NodeDepthProcessing : DTDFVocab:Enabler [
    base:desc "ROS 2 node handling depth‑camera frame preprocessing"
]

instance ROS2NodeACC : DTDFVocab:Enabler [
    base:desc "ROS 2 node running the ACC algorithm and exposing set‑point services"
]

instance ROS2NodeVisualization : DTDFVocab:Enabler [
    base:desc "ROS 2 node generating 3‑D visualization data for the UI"
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database backend storing time‑series vehicle data and generated reports"
]

instance WiFiCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi link enabling bidirectional communication between PT, DT, and UI workstation"
]

instance JetsonComputeEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetson hardware providing GPU‑accelerated compute for perception and control"
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink runtime used for complex ACC algorithm validation"
]

// -------------------------------------------------
// C6: Services
// -------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of vehicle state, projected path, and object tracks with UI visualizations and reporting"
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes the ACC algorithm off‑board, producing lead‑vehicle detection and speed set‑points"
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, and trigger emergency braking via UI"
]

// -------------------------------------------------
// C17: Insights / Actions
// -------------------------------------------------
instance SituationalAwarenessInsight : DTDFVocab:Insight [
    base:desc "Operators gain situational awareness through real‑time UI visualizations and reports"
]

instance FaultAnalysisInsight : DTDFVocab:Insight [
    base:desc "Developers use collected data for fault analysis and parameter tuning"
]

instance ParameterTuningInsight : DTDFVocab:Insight [
    base:desc "Insights derived from historic data enable tuning of ACC parameters"
]

instance ACCPerformanceInsight : DTDFVocab:Insight [
    base:desc "Evaluation of ACC performance, latency, and usability from case‑study results"
]

instance AdjustACCSetpointAction : DTDFVocab:Action [
    base:desc "Adjusts the ACC speed set‑point based on operator input"
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Triggers immediate vehicle braking in emergency situations"
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables the Adaptive Cruise Control function"
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disables the Adaptive Cruise Control function"
]

// -------------------------------------------------
// C2: Acting components
// -------------------------------------------------
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller converting desired speed commands into motor voltage signals"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo receiving position commands to actuate vehicle steering"
]

// -------------------------------------------------
// C9: Internal twin entities (Components)
// -------------------------------------------------
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical Twin entity hosting sensors, actuators, Jetson compute, and ROS‑2 nodes on‑board"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital Twin entity responsible for data collection, ACC computation, reporting, and storage on external compute"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User entity providing UI for monitoring, control, and management"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT, including desired speed values for the motor controller, enable/disable ACC commands, emergency‑brake signals, and steering adjustments. These commands are issued by the Controlling FE (ACC) and the User Interface FE and executed by the Actuation FE on the vehicle."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is required to maintain end‑to‑end network latency ≤ 100 ms (R7) and clock synchronization accuracy of 100 ms across all DTS components (R8), ensuring real‑time operation of ACC offloading and remote control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of the Physical Twin Entity (on‑board Jetson/NVIDIA hardware), the Digital Twin Entity (hosted on external compute and containing Data Collecting, Controlling, Reporting, and Presentation FEs), the User Entity (UI with 3‑D visualization and control panel), and a Cross‑System Data Translation FE that mediates data exchange across entities via ROS 2 and Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT operates primarily in the operational stage of the vehicle lifecycle, providing real‑time monitoring, control, and off‑board computation during vehicle use; it is also used during development for troubleshooting and validation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by meeting a ≤ 100 ms latency budget and clock sync of 100 ms, using high‑fidelity sensor data (LiDAR, depth camera) and validated tracking (DBSCAN + Kalman). Safety‑critical compliance follows ISO 15622 for ACC functionality, and real‑time constraints are strictly enforced to avoid control divergences."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication uses ROS 2 over a Wi‑Fi network (IEEE 802.11), with DDS handling publish/subscribe messaging. The Data Translation FE serializes and normalizes messages, and optional OPC UA could be employed for standardized data exchange (mentioned as a possible implementation)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity and its services are hosted on external compute hardware (e.g., a workstation or cloud instance) separate from the vehicle’s on‑board Jetson NX/Orin Nano. The User Entity runs on a user workstation, while the Physical Twin Entity resides on the vehicle."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture conforms to ISO 23247 (Digital Twin Manufacturing Framework) reference architecture, utilizes ISO 15622 for ACC functionality, references ISO/IEC 30173 for digital‑twin terminology, and mentions optional use of OPC UA (IEC 62541) for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations are highlighted by the requirement for ≤ 100 ms latency and synchronized clocks to ensure deterministic control. The DT implements remote emergency braking and ACC enable/disable commands, adhering to ISO 15622 safety requirements. No explicit cybersecurity mechanisms are described in the document."
]