// C2: Acting Components
instance VehicleSpeedActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder electronic speed controller (ESC) for motor drive receiving voltage commands to control vehicle speed"
]

instance VehicleSteeringActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo receiving angle commands to control vehicle steering"
]

// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2-D LiDAR for distance measurements providing raw point-cloud data"
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelDeepSenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera for visual perception providing raw depth data"
    DTDFVocab:producedData DepthCameraData
]

instance ChassisEncoders : DTDFVocab:SensingComponent [
    base:desc "Chassis encoders providing ego-vehicle speed and steering angle measurements"
    DTDFVocab:producedData VehicleStateData
]

// C4: Physical-to-Virtual Interaction
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iCamera
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChassisEncoders
]

// C10: Models/Data
instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) model compliant with ISO 15622 (Performance Class I) for off-board computation"
    DTDFVocab:inputTo ROS2Middleware
]

instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Point-cloud clustering model using DBSCAN algorithm for object detection"
    DTDFVocab:inputTo ROS2Middleware
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter for tracking detected objects from clustered point-cloud data"
    DTDFVocab:inputTo ROS2Middleware
]

instance ThreeDVisualizationModel : DTDFVocab:Model [
    base:desc "3-D visualization model for real-time projection of vehicle state and object tracks"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance EgoVehicleStateData : DTDFVocab:Data [
    base:desc "Time-series data of ego-vehicle state including speed and steering angle"
    DTDFVocab:fromData VehicleStateData
    DTDFVocab:inputTo ROS2Middleware, SQLDatabaseEnabler
]

instance ObjectTrackTimeSeriesData : DTDFVocab:Data [
    base:desc "Time-series data of detected and tracked objects from point-cloud processing"
    DTDFVocab:fromData ProcessedPointCloudData
    DTDFVocab:inputTo ROS2Middleware, SQLDatabaseEnabler
]

instance ProcessedPointCloudData : DTDFVocab:Data [
    base:desc "Processed point-cloud data after clustering (DBSCAN) and tracking (Kalman filter)"
    DTDFVocab:fromData LiDARPointCloudData, DepthCameraData
    DTDFVocab:inputTo ROS2Middleware
]

instance GeneratedReportsData : DTDFVocab:Data [
    base:desc "Automated reports of vehicle state and object tracks in structured format"
    DTDFVocab:fromData EgoVehicleStateData, ObjectTrackTimeSeriesData
    DTDFVocab:inputTo SQLDatabaseEnabler
]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware implementing Functional Entities as individual packages with Python 3.8 for rapid prototyping and C++ for node lifecycle management"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for implementing complex algorithms including 3-D visualization"
    DTDFVocab:enables DataMonitoringService
]

instance CloudComputeEnabler : DTDFVocab:Enabler [
    base:desc "External compute (cloud/edge) infrastructure for off-board ACC algorithm execution"
    DTDFVocab:enables ComputationOffloadingService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database for storing ego-vehicle state, object tracks, and generated reports"
    DTDFVocab:enables RemoteManagementService
]

instance NVIDIAJetPackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK for Jetson NX/Orin Nano hardware integration"
]

instance WiFiNetworkingEnabler : DTDFVocab:Enabler [
    base:desc "Wi-Fi networking for real-time data transmission between Physical Twin and Digital Twin Entities"
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time UI visualization of vehicle state, projected path, and object tracks"
    DTDFVocab:provides VehicleStateVisualizationInsight, ObjectTrackVisualizationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Off-board execution of ACC algorithm with results returned to Physical Twin Entity"
    DTDFVocab:provides ACCControlDecisionInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI-driven remote management of ACC enable/disable, speed adjustment, and emergency brake activation"
    DTDFVocab:provides ACCEnableDisableAction, SpeedAdjustmentAction, EmergencyBrakeAction
]

// C17: Insights/Actions
instance VehicleStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of ego-vehicle state including speed and steering angle"
]

instance ObjectTrackVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of detected and tracked objects with 3-D projection"
]

instance ACCControlDecisionInsight : DTDFVocab:Insight [
    base:desc "Computed ACC control decisions based on off-board algorithm execution"
]

instance ACCEnableDisableAction : DTDFVocab:Action [
    base:desc "Remote enable/disable of Adaptive Cruise Control functionality"
    DTDFVocab:IsAutomatic false
]

instance SpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Remote adjustment of desired vehicle speed"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Remote activation of emergency brake system"
    DTDFVocab:IsAutomatic false
]

// C1: Physical Twin Entity Components
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "On-board vehicle hardware layer integrating NVIDIA Jetson NX/Orin Nano, Hokuyo UST-10LX LiDAR, Intel DeepSense D435i camera, and actuation components"
]

instance LowerLevelChassis : DTDFVocab:Component [
    base:desc "Lower-level chassis handling steering and speed control via ESC and servo"
]

instance UpperLevelChassis : DTDFVocab:Component [
    base:desc "Upper-level chassis mounting autonomy components including sensors and compute modules"
]

instance AutonomyElectronics : DTDFVocab:Component [
    base:desc "Autonomy electronics layer including NVIDIA Jetson NX/Orin Nano and associated power systems"
]

// C1: Digital Twin Entity Components
instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "External compute infrastructure hosting ACC algorithm, object tracking, and visualization models"
]

// C1: User Entity Components
instance UserWorkstation : DTDFVocab:Component [
    base:desc "Operator workstation providing visualization and remote management interfaces"
]

// C1: Cross-System Entity
instance CrossSystemDataTranslator : DTDFVocab:Component [
    base:desc "Data translation layer between Physical Twin, Digital Twin, and User Entities following ISO 23247 principles"
]

// C1: Environments
instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity, LowerLevelChassis, UpperLevelChassis, AutonomyElectronics
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains DigitalTwinEntity
]

instance UserEnvironment : DTDFVocab:Environment [
    base:contains UserWorkstation
]

instance CrossSystemEnvironment : DTDFVocab:Environment [
    base:contains CrossSystemDataTranslator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT: desired speed values for the ESC, enable/disable ACC flags, emergency‑brake commands, and steering adjustments. These commands are issued by the Controlling Functional Entity (ACC) and the Actuation Functional Entity on the Physical Twin Entity."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates in real‑time with a hard end‑to‑end latency bound of ≤100 ms (per 3GPP TS 22.185) and clock synchronization accuracy of 100 ms across all DTS components; data collection and ACC computation occur at each perception cycle (on the order of tens of milliseconds)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates a Physical Twin Entity (sensor acquisition and actuation), a Digital Twin Entity (data collection, ACC computation, visualization, reporting), a User Entity (UI for monitoring and remote commands), and a Cross‑System Data Translation Entity; intra‑entity messaging uses ROS 2 topics, inter‑entity communication uses Wi‑Fi over standardized interfaces."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during the design and development phase as a high‑fidelity simulation/experiment platform, and during operation as a monitoring, optimization and remote‑control platform for the running vehicle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High fidelity is achieved by using raw sensor data (LiDAR, camera) and real‑time processing; validity is ensured through latency ≤100 ms, clock sync ≤100 ms, compliance with ISO 15622 ACC safety class, and continuous UI reporting for operator verification."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Components communicate via a standardized interface (R1) implemented with ROS 2 messages within the DT and Wi‑Fi links for PT‑DT exchange; the Data Translation FE handles serialization, message‑type alignment and unit conversion, and OPC UA is suggested as an optional transport protocol."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity runs on external compute resources (cloud or edge server), the Physical Twin Entity executes on the vehicle‑mounted NVIDIA Jetson Orin Nano, and the User Entity UI runs on a workstation or browser client; each entity is packaged as ROS 2 nodes deployed on its respective hardware."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system follows ISO 23247 reference architecture, ISO 15622 for ACC functional requirements, ISO/IEC 30173:2023 for digital‑twin terminology, and leverages 3GPP TS 22.185 latency guidelines; optional OPC UA (IEC 62541) may be used for data exchange."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations include adherence to ISO 15622 ACC class‑I requirements, strict latency (≤100 ms) and clock‑sync (≤100 ms) constraints, and remote command validation via the UI. Security measures are not explicitly described in the document."
]