// Sensing Components
instance HokuyoLidarUST10LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR sensor measuring 3‑D point clouds"
    DTDFVocab:producedData LidarPointCloudTx
]

instance IntelD435iDepthCam : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera capturing RGB‑D data"
    DTDFVocab:producedData DepthImageTx
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor measuring wheel rotational speed"
    DTDFVocab:producedData EgoSpeedTx
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor capturing joint rotation"
    DTDFVocab:producedData SteeringAngleTx
]

// Data Transmitted
instance LidarPointCloudTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLidarUST10LX
]

instance DepthImageTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCam
]

instance EgoSpeedTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ObjectTrackTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLidarUST10LX, IntelD435iDepthCam
]

// Data
instance LidarPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data streamed over ROS2"
    DTDFVocab:inputTo DataStorageFE, DataTranslationFE
    DTDFVocab:fromData LidarPointCloudTx
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Raw depth image data streamed over ROS2"
    DTDFVocab:inputTo DataStorageFE, DataTranslationFE
    DTDFVocab:fromData DepthImageTx
]

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed data streamed over ROS2"
    DTDFVocab:inputTo DataStorageFE, DataTranslationFE
    DTDFVocab:fromData EgoSpeedTx
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Ego steering angle data streamed over ROS2"
    DTDFVocab:inputTo DataStorageFE, DataTranslationFE
    DTDFVocab:fromData SteeringAngleTx
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Object tracks derived from LiDAR and depth data"
    DTDFVocab:inputTo DataStorageFE, OffloadingFE
    DTDFVocab:fromData ObjectTrackTx
]

// Models
instance PointCloudClusterModel : DTDFVocab:Model [
    base:desc "DBSCAN‑based point‑cloud clustering for obstacle segmentation"
    DTDFVocab:inputTo DataTranslationFE
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter‐based tracking for maintaining object trajectories"
    DTDFVocab:inputTo OffloadingFE
]

instance ACCControlAlgorithmModel : DTDFVocab:Model [
    base:desc "ISO 15622 ACC control algorithm for adaptive cruise control"
    DTDFVocab:inputTo OffloadingFE
]

// Enablers
instance DataCollectionFE : DTDFVocab:Enabler [
    base:desc "Collects ROS2 sensor topics and forwards data to DT"
    DTDFVocab:enables DataMonitoringService, ReportingGenerationService
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Serializes ROS2 data via OPC‑UA for DT consumption"
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService
]

instance DataStorageFE : DTDFVocab:Enabler [
    base:desc "Stores time‑series data in an SQL database"
    DTDFVocab:enables ReportingGenerationService
]

instance OffloadingFE : DTDFVocab:Enabler [
    base:desc "Computes ACC logic on Jetson and returns control signals"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteControlFE : DTDFVocab:Enabler [
    base:desc "Handles remote operator commands via ROS2"
    DTDFVocab:enables RemoteManagementService
]

instance VisualizationFE : DTDFVocab:Enabler [
    base:desc "Renders 3‑D vehicle and environment for monitoring"
    DTDFVocab:enables VisualizationService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of speed, steering, and tracked objects"
    DTDFVocab:provides RealTimeTelemetryInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC computation to DT and sends command results"
    DTDFVocab:provides ACCResultInsight, SendACCResultAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management of ACC enable/disable, desired speed, and emergency braking"
    DTDFVocab:provides EnableACCAction, ModifyDesiredSpeedAction, EmergencyBrakeAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3‑D visualization of vehicle and environment with tracked objects"
    DTDFVocab:provides LaunchVisualizationAction
]

instance ReportingGenerationService : DTDFVocab:Service [
    base:desc "Generates time‑series human‑readable reports of vehicle state and tracks"
    DTDFVocab:provides HumanReadableReportInsight
]

// Insights
instance RealTimeTelemetryInsight : DTDFVocab:Insight [
    base:desc "Insight displaying live telemetry (speed, steering, object tracks)"
]

instance ACCResultInsight : DTDFVocab:Insight [
    base:desc "Insight showing ACC control inputs computed on DT"
]

instance HumanReadableReportInsight : DTDFVocab:Insight [
    base:desc "Human‑readable time‑series report of vehicle state and object tracks"
]

// Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable or disable adaptive cruise control on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance ModifyDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Modify the desired speed setpoint for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Trigger emergency braking command"
    DTDFVocab:IsAutomatic false
]

instance LaunchVisualizationAction : DTDFVocab:Action [
    base:desc "Launch 3‑D visualization session"
    DTDFVocab:IsAutomatic false
]

instance SendACCResultAction : DTDFVocab:Action [
    base:desc "Send offloaded ACC control output back to vehicle motor driver"
    DTDFVocab:IsAutomatic true
]

// Environment
instance VehicleEnvironment : DTDFVocab:Environment [
    base:contains HokuyoLidarUST10LX, IntelD435iDepthCam, VehicleSpeedSensor,
             SteeringAngleSensor, ElectronicSpeedControllerComponent, MotorDriverComponent,
             SteeringServoComponent, EmergencyBrakingSystemComponent
]

// Physical Components
instance ElectronicSpeedControllerComponent : DTDFVocab:Component [
    base:desc "Electronic speed controller driving the vehicle motor"
]

instance MotorDriverComponent : DTDFVocab:Component [
    base:desc "Motor driver interfacing with the vehicle engine"
]

instance SteeringServoComponent : DTDFVocab:Component [
    base:desc "Servo controlling steering function"
]

instance EmergencyBrakingSystemComponent : DTDFVocab:Component [
    base:desc "Emergency braking system for vehicle safety"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT outputs desired speed, steering adjustments, and emergency braking commands to the PT; these are translated by the Data Translation FE and routed to the vehicle’s actuation mechanisms (motor voltage, steering servo, braking) via the Actuation FE, typically over a CAN bus or Ethernet."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with an end‑to‑end latency constraint of ≤100 ms for vehicle–DT communication; continuous sensor data ingestion at LiDAR update rates (~10–20 Hz), with ACC computations performed within this latency bound, and periodic reporting at lower rates."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT system consists of the Physical Twin Entity (sensor/actuator interfaces), Digital Twin Entity (data collection, processing, ACC algorithm), User Entity (3D visualization, control panel UI), and Cross‑System Entity (Data Translation FE); these entities are orchestrated through ROS2 topics on a Wi‑Fi network, with the Data Translation FE mediating between physical and virtual layers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers creation (design and simulation), validation (offline and online testing of ACC, data consistency, safety), and operation stages; it is instantiated in a concrete physical embodiment (1/10 scale vehicle) and evolves through iterative refinements based on the requirements R1–R8."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT guarantees real‑time fidelity via ≤100 ms end‑to‑end latency and 100 ms clock synchronization (R8), uses DBSCAN/Kalman for accurate perception, and follows ISO 23247 guidelines; validation includes comparing DT outputs against vehicle telemetry and offline simulation, but specific uncertainty quantification is not described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical–to‑virtual communication occurs over Wi‑Fi utilizing ROS2 DDS topics; Data Translation FE serializes and aligns message types, handles unit conversions; inter‑entity communication also uses UART/Serial or Ethernet where applicable."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Onboard deployment: NVIDIA Jetson Orin Nano hosts most FEs (Data Collection, ACC control, Data Translation); off‑board deployment: a remote workstation or cloud node hosts the User Entity UI and 3D visualization; communication across Wi‑Fi ensures connectivity, with potential edge computing for offline components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Follows ISO 23247 reference architecture; adheres to ISO/IEC 30173 for terminology; applies ISO 15622 for ACC implementation; uses ROS 2 as middleware and NVIDIA JetPack SDK; implements OPC UA for data translation (optional)."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical DD: end‑to‑end latency limited to 100 ms (R7), clock synchronization within 100 ms (R8), remote control authorized via command interface, emergency braking capability; compliance with 3GPP 22.185 for V2V service, yet detailed safety analysis and cybersecurity measures are not elaborated."
]