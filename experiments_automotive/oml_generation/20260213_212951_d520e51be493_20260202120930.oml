    DTDFVocab:inputTo OrbitalSimulationEnabler
]

// C11: Enablers
instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2-based point cloud clustering and tracking pipeline for autonomous navigation."
    DTDFVocab:enables MonitoringService, PredictionService
]

instance VehicleControlEnabler : DTDFVocab:Enabler [
    base:desc "Real-time vehicle state processing and control logic for autonomous systems."
    DTDFVocab:enables ControlService, OptimizationService
]

instance ActuationValidationEnabler : DTDFVocab:Enabler [
    base:desc "Feedback validation and actuation correction mechanism for closed-loop control."
    DTDFVocab:enables ControlService
]

instance EnvironmentalSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Environmental context simulation for autonomous path planning and obstacle avoidance."
    DTDFVocab:enables PredictionService, ControlService
]

instance BatteryHealthPredictionEnabler : DTDFVocab:Enabler [
    base:desc "AI/ML-based battery health prediction and degradation forecasting."
    DTDFVocab:enables MonitoringService, OptimizationService
]

instance BatteryThermalManagementEnabler : DTDFVocab:Enabler [
    base:desc "Thermal management optimization for battery charging and cooling."
    DTDFVocab:enables ControlService, OptimizationService
]

instance OrbitalSimulationEnabler : DTDFVocab:Enabler [
    base:desc "High-fidelity orbital mechanics simulation for collision avoidance and mission planning."
    DTDFVocab:enables PredictionService, ControlService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Middleware ensuring seamless data integration and format standardization across components."
    DTDFVocab:enables MonitoringService, VisualizationService, PredictionService, ControlService
]

instance ROS2CommunicationEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 network facilitating asynchronous communication between software components."
    DTDFVocab:enables MonitoringService, OptimizationService, PredictionService, ControlService, VisualizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time and historical monitoring of physical systems using digital twins."
    DTDFVocab:provides VehicleHealthInsight, EnvironmentalConditionInsight, BatteryHealthInsight, AnomalyDetectionInsight
]

