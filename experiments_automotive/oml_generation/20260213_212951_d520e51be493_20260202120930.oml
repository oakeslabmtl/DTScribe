// C3: Physical Sensing Components
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor capturing raw point cloud data for object detection and tracking in autonomous systems."
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor suite capturing motor, steering, servo actuation states, and overall vehicle status."
    DTDFVocab:producedData VehicleStateDataTransmitted
]

instance ActuationFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors monitoring motor, steering, and servo system responses to physical actions."
    DTDFVocab:producedData ActuationFeedbackDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors capturing object tracks, projected driving paths, and surrounding environment representations."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

instance BatteryHealthSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors monitoring battery state-of-health (SoH), voltage, current, and temperature."
    DTDFVocab:producedData BatteryHealthDataTransmitted
]

instance BatteryThermalSensor : DTDFVocab:SensingComponent [
    base:desc "Thermal sensors measuring battery cell and pack temperatures for thermal management."
    DTDFVocab:producedData BatteryThermalDataTransmitted
]

instance OrbitalMechanicsSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors capturing satellite position, velocity, and orbital parameters for collision avoidance."
    DTDFVocab:producedData OrbitalMechanicsDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance ActuationFeedbackDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ActuationFeedbackSensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance BatteryHealthDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BatteryHealthSensor
]

instance BatteryThermalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BatteryThermalSensor
]

instance OrbitalMechanicsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OrbitalMechanicsSensor
]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "AI/ML model converting raw LiDAR point clouds into clustered and tracked objects for autonomous navigation."
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance VehicleStateModel : DTDFVocab:Model [
    base:desc "Digital representation of vehicle dynamics including motor, steering, and servo states."
    DTDFVocab:inputTo VehicleControlEnabler
]

instance ActuationFeedbackModel : DTDFVocab:Model [
    base:desc "Model validating and processing feedback from motor, steering, and servo systems."
    DTDFVocab:inputTo ActuationValidationEnabler
]

instance EnvironmentalModel : DTDFVocab:Model [
    base:desc "Spatial model representing object tracks, driving paths, and surrounding environment."
    DTDFVocab:inputTo EnvironmentalSimulationEnabler
]

instance BatteryHealthModel : DTDFVocab:Model [
    base:desc "Electrochemical-thermal coupled model predicting battery degradation and state-of-health."
    DTDFVocab:inputTo BatteryHealthPredictionEnabler
]

instance BatteryThermalModel : DTDFVocab:Model [
    base:desc "Thermal management model optimizing battery charging and cooling strategies."
    DTDFVocab:inputTo BatteryThermalManagementEnabler
]

instance OrbitalMechanicsModel : DTDFVocab:Model [
    base:desc "High-fidelity orbital mechanics simulation for collision avoidance and mission planning."
    DTDFVocab:inputTo OrbitalSimulationEnabler
]

