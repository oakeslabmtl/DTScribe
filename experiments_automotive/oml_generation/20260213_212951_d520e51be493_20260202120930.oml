]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive and interactive visualization of digital twin data."
    DTDFVocab:provides RealTimeVisualizationInsight, ARVRVisualizationInsight, CustomDashboardInsight
]

instance AutomotiveSpecificService : DTDFVocab:Service [
    base:desc "Services tailored to automotive digital twins including performance tuning and supply chain digitalization."
    DTDFVocab:provides VehiclePerformanceAction, SupplyChainOptimizationAction, CustomerExperienceAction
]

instance AerospaceSpecificService : DTDFVocab:Service [
    base:desc "Services for aerospace digital twins including collision avoidance and mission planning."
