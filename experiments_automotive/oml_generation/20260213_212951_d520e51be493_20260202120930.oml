    base:desc "Raw and processed point cloud data from LiDAR sensors for object detection."
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Real-time vehicle state data including motor, steering, and servo actuation states."
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo VehicleControlEnabler
]

instance ActuationFeedbackData : DTDFVocab:Data [
    base:desc "Feedback data from motor, steering, and servo systems reflecting physical actions."
    DTDFVocab:fromData ActuationFeedbackDataTransmitted
    DTDFVocab:inputTo ActuationValidationEnabler
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Environmental context data including object tracks and projected driving paths."
