    base:desc "Data-driven optimization of system performance and resource allocation."
    DTDFVocab:provides ProcessOptimizationAction, EnergyOptimizationAction, LogisticsOptimizationAction
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Forecasting system behavior, failures, or external impacts using digital twins."
    DTDFVocab:provides FailurePredictionInsight, DemandForecastingInsight, CollisionRiskInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Automated or semi-automated control of physical systems via digital twins."
