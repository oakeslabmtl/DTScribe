// Sensing components in the Physical Twin
instance LiDARPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR point‑cloud sensor mounted on the vehicle, sampling at 10 Hz"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance SteeringPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor providing real‑time steering state"
    DTDFVocab:producedData SteeringStateTransmitted
]

instance MotorActuationStateSensor : DTDFVocab:SensingComponent [
    base:desc "Motor actuation state sensor reporting throttle and brake positions"
    DTDFVocab:producedData MotorActuationTransmitted
]

instance VehicleDynamicSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle dynamics sensor delivering speed, acceleration, and yaw rate"
    DTDFVocab:producedData VehicleDynamicTransmitted
]

instance PointCloudClusteringTrackingComponent : DTDFVocab:ActingComponent [
    base:desc "Preprocesses raw LiDAR scans producing object tracklets and projected driving paths"
    // DTDFVocab:producedData ObjectTrackletsTransmitted, ProjectedDrivingPathTransmitted
]

// Data transmitted from the Physical Twin to the Digital Twin
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARPointCloudSensor
]

instance SteeringStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringPositionSensor
]

instance MotorActuationTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorActuationStateSensor
]

instance VehicleDynamicTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleDynamicSensor
]

instance ObjectTrackletsTransmitted : DTDFVocab:DataTransmitted [
    /* producedFrom removed due to type mismatch */
]

instance ProjectedDrivingPathTransmitted : DTDFVocab:DataTransmitted [
    /* producedFrom removed due to type mismatch */
]

// Data within the Digital Twin
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Point‑cloud data translated from ISO 23247 format"
    DTDFVocab:inputTo DataTranslationFE
]

instance SteeringStateData : DTDFVocab:Data [
    base:desc "Transformed steering state data"
    DTDFVocab:inputTo DataTranslationFE
]

instance MotorActuationData : DTDFVocab:Data [
    base:desc "Transformed motor actuation state"
    DTDFVocab:inputTo DataTranslationFE
]

instance VehicleDynamicData : DTDFVocab:Data [
    base:desc "Transformed vehicle dynamic data"
    DTDFVocab:inputTo DataTranslationFE
]

instance ObjectTrackletsData : DTDFVocab:Data [
    base:desc "Translated object tracklet data from LiDAR clustering"
    DTDFVocab:inputTo DataTranslationFE
]

instance ProjectedDrivingPathData : DTDFVocab:Data [
    base:desc "Transformed projected driving path data"
    DTDFVocab:inputTo DataTranslationFE
]

// Enabler responsible for translation and integration
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Data Translation Front‑End (ISO 23247) that aligns message types and performs unit conversions"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

// Digital Twin services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization, logging, and diagnostic reporting of vehicle state data"
    DTDFVocab:provides RealTimeVisualizationInsight, LogTelemetryDataInsight, GenerateDiagnosticReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC logic to the cloud, stream controls back to the vehicle for actuation"
    DTDFVocab:provides ExecuteACCLogicInCloudAction, StreamControlCommandsAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables operators to remotely enable/disable ACC, set desired cruise speed, and trigger emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredCruiseSpeedAction, TriggerEmergencyBrakingAction
]

// Insights offered by Data Monitoring
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time graphical display of vehicle state, projected trajectories, and sensor‑derived object tracks"
]

instance LogTelemetryDataInsight : DTDFVocab:Insight [
    base:desc "Logs vehicle telemetry for post‑mission analysis"
]

instance GenerateDiagnosticReportInsight : DTDFVocab:Insight [
    base:desc "Automatically generates diagnostic reports from captured data"
]

// Actions available through the Digital Twin services
instance ExecuteACCLogicInCloudAction : DTDFVocab:Action [
    base:desc "Executes adaptive cruise control logic in the cloud"
    DTDFVocab:IsAutomatic true
]

instance StreamControlCommandsAction : DTDFVocab:Action [
    base:desc "Streams actuation commands generated by cloud ACC back to the vehicle"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables adaptive cruise control on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disables adaptive cruise control on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredCruiseSpeedAction : DTDFVocab:Action [
    base:desc "Sets the desired cruise speed for adaptive cruise control"
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Triggers emergency braking via low‑latency network links"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the User Entity’s Control Panel and are routed to the Digital Twin’s Control Front‑End, then transmitted over the same Wi‑Fi UDP link to the Physical Twin Entity. Command payloads are formatted according to the ISO 23247 data translation schema and include ACC enable/disable directives, steering servo position set‑points, and motor torque commands. After receipt, the Physical Twin’s Actuation Front‑End validates the command, dispatches it to the vehicle’s actuator hardware, and relays an execution confirmation back to the Digital Twin via the Wi‑Fi network. The system does not define an explicit authentication or conflict resolution mechanism within the provided documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin enforces a 100 ms clock‑synchronisation tolerance between all physical and digital components, as required by safety‑critical vehicular standards; computation off‑loading and other time‑critical services must operate within this 100 ms bound. No additional service‑level time scales are specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows the ISO 23247 reference architecture and implements each Functional Entity as a separate ROS2 package comprising one or more ROS2 nodes. The Digital Twin entity hosts data management and control mechanisms; the Physical Twin entity contains data pre‑processing, actuation, and device‑communication functions (e.g., point‑cloud clustering and tracking); the User entity hosts visualization and control panels. Processes and data ownership are therefore distributed across distinct physical nodes, and coordination is achieved through ROS2 middleware, enabling capability sharing and state synchronization across the twin constellation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin’s internal communication relies on a ROS‑2 middleware (based on DDS) running in a local network; inter‑entity exchanges occur over a Wi‑Fi radio using the UDP transport layer. The system is designed to sustain a round‑trip latency of at most 100 ms for control and telemetry. No bandwidth requirements or redundancy mechanisms are specified; the network topology is a flat bus between the vehicle, digital twin server, and user interface devices."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Each component of the Digital Twin system is deployed on separate physical hardware. The Physical Twin Entity runs on the vehicle’s on‑board computer, the Digital Twin Entity executes on a server located outside the vehicle (edge or on‑premise), and the User Entity is typically accessed via a remote workstation or mobile device. Persisted telemetry, such as vehicle state history, is stored on an external storage device connected to the server. No cloud-based hosting, scaling strategies, or high‑availability measures are described in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to ISO 23247 – Digital Twin Framework for Manufacturing (Part 2 – Reference Architecture). It adopts the entity‑based reference architecture defined in the standard, consisting of an Observable Manufacturing Element (OME), a Data Collection and Device Control Entity, a Digital Twin Entity, and a User Entity. Functional Entities (FEs), which implement specific sub‑functions such as actuating the OME or transforming data, may use OPC Unified Architecture (OPC UA) for device‑to‑device and device‑to‑digital‑twin communication. The compliance framework ensures interoperability with manufacturing equipment by adopting standard OPC UA information models and secure transport mechanisms (e.g., TLS). The system’s adherence to ISO 23247 provides a structured approach for governance, versioning, and integration within a broader manufacturing ecosystem."
]