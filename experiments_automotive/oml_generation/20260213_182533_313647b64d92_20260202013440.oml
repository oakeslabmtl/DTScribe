// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2‑D LiDAR providing point‑cloud data"
    DTDFVocab:producedData LiDARDataTransmitted
]

instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering depth images"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of ego vehicle speed derived from chassis sensors"
    DTDFVocab:producedData SpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board measurement of steering angle derived from chassis sensors"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

instance ObjectTrackProcessor : DTDFVocab:SensingComponent [
    base:desc "Processor that derives object‑track information from LiDAR and camera streams"
    DTDFVocab:producedData ObjectTrackDataTransmitted
]

// C4: Physical-to-virtual interaction – Data transmitted
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ObjectTrackDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ObjectTrackProcessor
]

// C5: Data items
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Point‑cloud stream from Hokuyo LiDAR"
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, VisualizationEngineEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image stream from Intel DeepSense D435i"
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, VisualizationEngineEnabler
]

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed (m/s) measured on‑board"
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, SQLDatabaseEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle (rad) measured on‑board"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, SQLDatabaseEnabler
]

instance DetectedObjectTrackData : DTDFVocab:Data [
    base:desc "Derived object‑track information (position, velocity, ID) from sensor fusion"
    DTDFVocab:fromData ObjectTrackDataTransmitted
    DTDFVocab:inputTo ACCComputationEnabler, VisualizationEngineEnabler, SQLDatabaseEnabler
]

// C11: Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware packaging each Functional Entity as an individual ROS 2 package"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Custom ROS 2‑based Data Translation FE that serializes, unit‑converts and forwards sensor streams over Wi‑Fi"
    DTDFVocab:enables DataMonitoringService
]

instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "3‑D visualization engine for rendering object tracks, projected paths and vehicle state"
    DTDFVocab:enables DataMonitoringService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "ACC algorithm (ISO 15622 compliant) that processes object tracks to compute lead‑vehicle identification and speed set‑point"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Remote‑management UI enabling operators to control ACC, set desired speed, and issue emergency‑brake commands"
    DTDFVocab:enables RemoteManagementService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "External SQL database storing ego speed, steering angle, and object‑track data for reporting"
    DTDFVocab:enables DataMonitoringService
]

instance WiFiTransportEnabler : DTDFVocab:Enabler [
    base:desc "Wi‑Fi transport layer used to forward ROS 2 messages from the Physical Twin to the Digital Twin"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring UI visualizes real‑time speed, steering angle, object tracks, projected path and generates reports"
    DTDFVocab:provides RealTimeVisualizationInsight, ReportGenerationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation Offloading runs the ACC algorithm on the Digital Twin instead of the on‑board ECU"
    DTDFVocab:provides LeadVehicleIdentificationInsight, SpeedSetpointCalculationInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management UI allows operators to enable/disable ACC, set desired speed, and issue emergency‑brake commands"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualizations of vehicle state, object tracks and projected paths"
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Generation of human‑readable reports summarizing vehicle performance and events"
]

instance LeadVehicleIdentificationInsight : DTDFVocab:Insight [
    base:desc "Identification of lead vehicle from object tracks as required by ISO 15622 ACC"
]

instance SpeedSetpointCalculationInsight : DTDFVocab:Insight [
    base:desc "Computation of desired speed set‑point based on lead‑vehicle distance and speed"
]

// C17: Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets the desired cruising speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator issues an emergency‑brake command transmitted to the speed controller"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT over Wi‑Fi using ROS 2 topics: (1) desired speed computed by the ACC Controlling FE, (2) enable/disable ACC, (3) emergency‑brake command, and (4) steering adjustments if needed. These commands are translated by the Data Translation FE and applied by the Actuation FE on the vehicle’s motor controller and steering servo."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system enforces an end‑to‑end network latency of ≤ 100 ms between PT and DT (requirement R7) and requires clock synchronization across components with an accuracy of 100 ms (requirement R8), supporting near‑real‑time operation of the ACC service."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates the Physical Twin Entity (sensors, actuators, point‑cloud processing), the Digital Twin Entity (data collection, ACC computation, reporting, visualization), the User Entity (3‑D UI and control panel), and a Cross‑System Data Translation FE. Communication between entities occurs over ROS 2 topics on a Wi‑Fi network, while intra‑entity communication uses ROS 2 intra‑process messaging."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is exercised primarily in the operational stage for runtime monitoring, remote control, and off‑loaded computation, while it also supports the development stage by providing a cyber‑physical experimentation platform for developers to troubleshoot and collect data."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity perception is achieved by clustering raw LiDAR points with DBSCAN and tracking with a Kalman filter. The ACC controller complies with ISO 15622 specifications for performance class I. Real‑time constraints (≤ 100 ms latency, 100 ms clock sync) ensure temporal validity of sensor data and control commands. Data storage in SQL preserves the full time‑series for offline validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The PT and DT communicate over a Wi‑Fi network using ROS 2 messaging. The Data Translation FE serializes messages, aligns types, and performs unit conversions. The standardized communication interface (requirement R1) is realized by ROS 2 topics and services across the entities."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the NVIDIA Jetson Orin Nano on the vehicle. The Digital Twin Entity is deployed on an external compute platform (cloud or workstation) that hosts the ROS 2 nodes for ACC, data collection, and visualization. The User Entity runs on a user workstation presenting the UI."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) for entity and functional entity structuring, ISO 15622 for ACC behavior, and utilizes ROS 2 as a de‑facto standard middleware. The optional use of OPC UA for data translation is mentioned but not implemented."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations include the 100 ms latency bound, 100 ms clock synchronization, compliance with ISO 15622 ACC specifications, and human‑in‑the‑loop operation for remote commands. Security aspects such as authentication, encryption, or intrusion detection are not described in the document."
]