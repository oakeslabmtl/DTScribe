// =========================
// Physical Sensing Components
// =========================
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2D LiDAR providing raw point‑clouds of the environment"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering depth images and IMU data"
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring ego vehicle speed (m/s) for telemetry"
    DTDFVocab:producedData SpeedTelemetryTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering encoder providing real‑time steering angle (deg) telemetry"
    DTDFVocab:producedData SteeringAngleTelemetryTransmitted
]

// =========================
// Physical‑to‑Virtual Interaction (Data Transmitted)
// =========================
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]

instance SpeedTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// =========================
// Data Instances
// =========================
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 2‑D point‑cloud stream from Hokuyo LiDAR"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataMonitoringEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames from Intel RealSense D435i"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo DataMonitoringEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed telemetry (m/s)"
    DTDFVocab:fromData SpeedTelemetryTransmitted
    DTDFVocab:inputTo DataMonitoringEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Ego vehicle steering angle telemetry (degrees)"
    DTDFVocab:fromData SteeringAngleTelemetryTransmitted
    DTDFVocab:inputTo DataMonitoringEnabler
]

// =========================
// Models / Algorithms
// =========================
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering applied to LiDAR point‑clouds for object segmentation"
    DTDFVocab:inputTo DBSCANClusteringEnabler
]

instance KalmanTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking of clustered objects over time"
    DTDFVocab:inputTo KalmanTrackingEnabler
]

instance ACCModelISO15622 : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model implementing lead‑vehicle selection and speed‑set‑point per ISO 15622"
    DTDFVocab:inputTo ACCComputationEnabler
]

instance PersistentSQLDatabase : DTDFVocab:Model [
    base:desc "SQL database persisting time‑series vehicle state and object‑track data"
    DTDFVocab:inputTo DatabasePersistenceEnabler
]

// =========================
// Enablers (Tooling & Processing)
// =========================
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware handling distributed communication between PT, DT and User entities"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance JetsonJetPack5Enabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK enabling GPU‑accelerated perception and control on Jetson devices"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance MATLABSimulinkClusteringEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink implementation of DBSCAN and Kalman filtering for clustering/tracking"
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:inputTo DBSCANClusteringEnabler, KalmanTrackingEnabler
]

instance DBSCANClusteringEnabler : DTDFVocab:Enabler [
    base:desc "Executes DBSCAN model on incoming LiDAR point‑clouds"
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:inputTo KalmanTrackingEnabler
]

instance KalmanTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Runs Kalman filter on clustered objects to produce tracked trajectories"
    DTDFVocab:enables DataMonitoringService
    DTDFVocab:inputTo ACCComputationEnabler
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Computes ACC set‑point using ISO 15622 model based on tracked lead vehicle"
    DTDFVocab:enables ComputationOffloadingService
    DTDFVocab:inputTo DatabasePersistenceEnabler
]

instance DatabasePersistenceEnabler : DTDFVocab:Enabler [
    base:desc "Writes vehicle state and object‑track data to persistent SQL database"
    DTDFVocab:enables ComputationOffloadingService
]

instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Aggregates sensor data, perception outputs, and ACC decisions for UI visualization"
    DTDFVocab:enables DataMonitoringService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Handles operator commands (enable/disable ACC, set speed, emergency brake) from UI"
    DTDFVocab:enables RemoteManagementService
]

// =========================
// Services
// =========================
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time UI showing speed, steering angle, object tracks, projected path and report generation"
    DTDFVocab:provides RealTimeVehicleStateInsight, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC control algorithm in the Digital Twin, reducing load on the vehicle ECU"
    DTDFVocab:provides RunACCAlgorithmAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, and issue emergency‑brake commands"
    DTDFVocab:provides OperatorControlInsight, EnableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// =========================
// Insights
// =========================
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "UI insight displaying live speed, steering angle, detected object tracks and projected vehicle path"
]

instance OperatorControlInsight : DTDFVocab:Insight [
    base:desc "Shows current ACC status and allows operator to adjust ACC parameters"
]

// =========================
// Actions
// =========================
instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Generates saved report of vehicle run including telemetry and object track history"
    DTDFVocab:IsAutomatic false
]

instance RunACCAlgorithmAction : DTDFVocab:Action [
    base:desc "Executes ACC control algorithm in the Digital Twin"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables Adaptive Cruise Control on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets the operator‑desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issues an emergency‑brake command cutting motor power immediately"
    DTDFVocab:IsAutomatic false
]

// =========================
// Physical Acting Components
// =========================
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage command sent to the electronic speed controller for speed control"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo command sent to the steering mechanism for directional control"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency‑brake command that cuts motor power via the electronic speed controller"
]

// =========================
// System Entities (Multiplicity)
// =========================
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical Twin Entity hosted on the 1/10‑scale vehicle hardware"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital Twin Entity running on a more powerful compute platform (e.g., workstation)"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User Entity residing on the operator workstation"
]

// =========================
// Environment (Hardware Composition)
// =========================
instance VehicleHardwareEnvironment : DTDFVocab:Environment [
    base:contains HokuyoLiDAR, IntelDepthCamera, VehicleSpeedSensor, SteeringAngleSensor,
                MotorVoltageActuator, SteeringServoActuator, EmergencyBrakeActuator,
                PhysicalTwinEntity
]

// =========================
// Additional Tooling Enablers (Reference)
// =========================
instance Python38Enabler : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime used for rapid prototyping of perception and UI modules"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance CPPNodeLifecycleEnabler : DTDFVocab:Enabler [
    base:desc "C++ ROS 2 node lifecycle management for deterministic node states"
    DTDFVocab:enables ComputationOffloadingService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Controlling FE in the Digital Twin Entity computes the desired speed according to the ACC algorithm and sends speed set‑points, ACC enable/disable commands, desired‑speed adjustments, and emergency‑braking signals back to the PT via the Actuation FE over the same ROS 2/Wi‑Fi channel."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates in real‑time with a maximum end‑to‑end network latency of 100 ms (per 3GPP TS 22.185) and clock synchronization accuracy of 100 ms across all DT components, enabling tight coupling between PT and DT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 reference model: a Physical Twin Entity (sensors, actuation), a Digital Twin Entity (data collection, ACC logic, reporting, visualization preprocessing), a User Entity (3D visualization UI and control panel), and a Cross‑System Data Translation FE that mediates all inter‑entity message formats. Communication within the DT uses ROS 2/DDS; PT‑DT communication uses Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is used during the operational stage for monitoring, remote control, and performance analysis, and also during development/debugging phases where developers exploit the monitoring and data‑collection capabilities."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity is achieved by using raw LiDAR point clouds and real‑time vehicle telemetry; validity is ensured by adhering to ISO 15622 ACC functional requirements, meeting the 100 ms latency bound, and synchronising clocks within 100 ms. The tracking model is validated through DBSCAN clustering followed by Kalman filtering to maintain accurate object tracks."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange between PT and DT occurs over a Wi‑Fi network using ROS 2 messages (DDS transport). Within the DT, components communicate via ROS 2 topics and services. The Data Translation FE serialises, aligns message types, and performs unit conversion to ensure interoperability."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the vehicle’s Jetson Orin Nano; the Digital Twin Entity runs on a separate compute platform (e.g., a laptop or cloud instance) hosting the ACC logic and database; the User Entity runs on an operator workstation displaying the 3D visualization and control panel. Each entity is packaged as a ROS 2 node set."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT architecture is based on ISO 23247 (Digital Twin Manufacturing Framework) and uses ISO 15622 for ACC functionality. Communication latency follows 3GPP TS 22.185 specifications, and ISO/IEC 30173:2023 is referenced for twin terminology. Optional OPC UA (IEC 62541) is mentioned as a possible data‑translation layer."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed as a safety‑critical system with a hard latency bound of 100 ms, clock synchronization of 100 ms, and compliance with ISO 15622 ACC safety requirements. Remote management commands (enable/disable ACC, emergency brake) are executed only after validation by the Controlling FE, but no specific cybersecurity mechanisms are described in the document."
]