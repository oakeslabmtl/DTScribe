// ==================== C3: Physical sensing components ====================
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor providing point‑cloud data of the vehicle environment"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor suite reporting vehicle speed, position, and orientation"
    DTDFVocab:producedData VehicleStateTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor exposing the status (rpm, current) of the propulsion motor"
    DTDFVocab:producedData MotorStatusTransmitted
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring steering servo position and effort"
    DTDFVocab:producedData SteeringServoTransmitted
]

// ==================== C4: Physical-to-virtual interaction ====================
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance MotorStatusTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance SteeringServoTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
]

// ==================== C10: Models/Data ====================
// Raw sensor data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream transmitted from the physical twin"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler, JetPack5GPUSDKEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state data (speed, pose) transmitted from the physical twin"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Motor status information transmitted from the physical twin"
    DTDFVocab:fromData MotorStatusTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance SteeringServoData : DTDFVocab:Data [
    base:desc "Steering servo position and effort transmitted from the physical twin"
    DTDFVocab:fromData SteeringServoTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

// Processing models
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm grouping LiDAR points into object candidates"
    DTDFVocab:inputTo JetPack5GPUSDKEnabler, ROS2MiddlewareEnabler
]

instance ObjectTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based state estimator tracking clustered objects over time"
    DTDFVocab:inputTo JetPack5GPUSDKEnabler, ROS2MiddlewareEnabler
]

instance VehicleEnvironmentGeometricModel : DTDFVocab:Model [
    base:desc "Geometric model representing static environment geometry built from clustered point clouds"
    DTDFVocab:inputTo JetPack5GPUSDKEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink ACC controller (lead‑vehicle detection, distance‑based speed calculation, desired‑speed generation)"
    DTDFVocab:inputTo MatlabSimulinkACCEnabler, CloudACCComputeEnabler
]

// ==================== C11: Enablers ====================
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware (DDS over Ethernet) providing publish/subscribe communication"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService, ComputationOffloadingService
]

instance JetPack5GPUSDKEnabler : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK enabling GPU‑accelerated processing of point‑cloud clustering and tracking"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance MatlabSimulinkACCEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment used for model‑based design of the ACC controller"
    DTDFVocab:enables ComputationOffloadingService
]

instance CloudACCComputeEnabler : DTDFVocab:Enabler [
    base:desc "Cloud compute node executing off‑loaded ACC algorithm and returning desired speed"
    DTDFVocab:enables ComputationOffloadingService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Relational SQL database persisting historic trajectories, configuration parameters and generated reports"
    DTDFVocab:enables DataMonitoringService
]

// ==================== C6: Services ====================
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Graphical UI streams real‑time vehicle state, projected path, and detected object tracks; allows viewing, saving and reporting collected data"
    DTDFVocab:provides VisualizationAction, DataReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes the ACC algorithm in the cloud, sending the computed desired speed back to the vehicle for actuation"
    DTDFVocab:provides DesiredSpeedAction, AccComputationInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, manually set desired speed, and issue an emergency‑braking command via the UI"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakingAction
]

// ==================== C17: Insights / Actions ====================
instance VisualizationAction : DTDFVocab:Action [
    base:desc "Render real‑time vehicle state, projected path and object tracks in the monitoring UI"
    DTDFVocab:IsAutomatic true
]

instance DataReportAction : DTDFVocab:Action [
    base:desc "Generate, save and export reports from collected monitoring data"
    DTDFVocab:IsAutomatic false
]

instance DesiredSpeedAction : DTDFVocab:Action [
    base:desc "Transmit computed desired speed from the cloud ACC service to the vehicle actuator"
    DTDFVocab:IsAutomatic true
]

instance AccComputationInsight : DTDFVocab:Insight [
    base:desc "Provides execution status and performance metrics of the off‑loaded ACC computation"
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable the Adaptive Cruise Control functionality on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable the Adaptive Cruise Control functionality on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Manually set a desired speed value for the vehicle via the UI"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Issue an emergency‑braking command to immediately stop the vehicle"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin sends control commands back to the vehicle, including the desired speed computed by the off‑loaded ACC algorithm, ACC enable/disable flags, speed set‑points, and emergency‑brake commands. Commands are formatted by the Data Translation FE (serialization, unit conversion) and transmitted over the same Wi‑Fi UDP link to the vehicle’s actuation FE, where they are applied by the motor and steering servo actuators. The vehicle’s response (updated vehicle state) is fed back to the DT for confirmation. Specific validation, authentication or conflict‑resolution mechanisms are not described."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Device coordination requires a shared notion of time; the system mandates clock synchronization accuracy of 100 ms (the limit imposed by hardware) to support computation offloading between devices."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 reference model, mapping each functional entity (FE) to an individual ROS 2 package; each package contains one or more ROS 2 nodes that implement the FE’s functionality. Entities are organized as Physical Twin, Digital Twin, and User entities, with the User Interface FE split into visualization and control‑panel sub‑components, and a Data Storage component that does not align to any FE. This ROS 2‑based, entity‑centric deployment coordinates the software components across the vehicle hardware."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication between the physical and digital twins uses a Wi‑Fi network with UDP as the transport protocol. Internally, software components within the DT communicate via a ROS 2 publish/subscribe network. The architecture relies on the ISO 23247 Data Translation functional element to ensure consistent message formats. The system requires low end‑to‑end latency for ACC remote management, but exact bandwidth, latency, reliability, redundancy or security protocol specifications are not provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built on the ISO 23247 Digital Twin framework for manufacturing, using its entity‑based reference architecture (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity). Functional Entities are implemented as ROS 2 packages, aligning with the ROS 2 ecosystem standards. For time synchronization, the design follows vehicular safety‑critical standards that demand clock synchronization tighter than 100 ms; the implementation targets a 100 ms synchronization accuracy due to hardware limitations."
]