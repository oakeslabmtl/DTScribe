// C11: Enablers
instance ROS2PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2-based software framework for processing LiDAR point clouds and depth data. Implements Point Cloud Clustering & Tracking algorithms for real-time environmental perception."
    DTDFVocab:enables LiDARObjectTrackingService, VehicleEnvironmentalMappingService
]

instance BatteryManagementSystemEnabler : DTDFVocab:Enabler [
    base:desc "Software platform for battery management including SoC/SoH estimation, thermal management, and predictive analytics. Integrates with electrochemical models and IoT sensors."
    DTDFVocab:enables BatteryHealthMonitoringService, BatteryOptimizationService
]

instance SpaceDebrisTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Integration of orbital mechanics simulators (e.g., STK, GMAT) and space debris tracking systems (e.g., LeoLabs). Provides real-time collision risk assessment and mitigation strategies."
    DTDFVocab:enables SpaceDebrisCollisionAvoidanceService, OrbitalMissionPlanningService
]

instance VehicleSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine (e.g., ANSYS, MATLAB/Simulink) for high-fidelity vehicle modeling. Supports real-time simulation of mechanical, electrical, and software systems."
    DTDFVocab:enables VehicleDesignOptimizationService, AutonomousDrivingControlService
]

instance ManufacturingOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Digital twin platform (e.g., Siemens MindSphere) for manufacturing process optimization. Integrates IoT data, AI/ML, and simulation tools for Industry 4.0 applications."
    DTDFVocab:enables ManufacturingProcessOptimizationService, PredictiveMaintenanceService
]

instance ClinicalDecisionSupportEnabler : DTDFVocab:Enabler [
    base:desc "Clinical Decision Support System (CDSS) integrating patient data, physiological models, and predictive analytics. Supports personalized treatment planning and healthcare monitoring."
    DTDFVocab:enables PatientMonitoringService, TreatmentPredictionService
]

instance EnvironmentalMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Biophysical simulation engines (e.g., COMSOL, AnyLogic) for modeling environmental systems. Integrates IoT sensors and edge computing for real-time ecosystem management."
    DTDFVocab:enables EnvironmentalConditionMonitoringService, ClimateImpactPredictionService
]

instance IoTDataIngestionEnabler : DTDFVocab:Enabler [
    base:desc "IoT platform (e.g., AWS IoT, Azure IoT Hub) for real-time data ingestion from heterogeneous sensors. Supports device management and connectivity for digital twin applications."
]

instance EdgeComputingEnabler : DTDFVocab:Enabler [
    base:desc "Edge computing framework enabling localized digital twin operations with reduced latency. Supports real-time processing of sensor data at the edge."
]

