// Sensing Components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Paysor LiDAR sensor mounted on upper chassis, emitting 3D point clouds at 10–20 Hz"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance DepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Depth camera on upper chassis capturing RGB–D imagery for obstacle registration"
    DTDFVocab:producedData DepthCameraImageTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Integrated vehicle state sensor suite (speed, steering angle, throttle, brake pressure) sampling at 50 Hz"
    DTDFVocab:producedData VehicleStateMetricsTransmitted
]

instance ObjectTrackingAlgorithm : DTDFVocab:SensingComponent [
    base:desc "On‑board object‑tracking algorithm generating live object track messages and projected paths"
    DTDFVocab:producedData ObjectTrackMessagesTransmitted
]

// Data Transmitted
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance DepthCameraImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DepthCameraSensor
]

instance VehicleStateMetricsTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance ObjectTrackMessagesTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ObjectTrackingAlgorithm
]

// Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Binary packet of LiDAR point‑cloud data after ROS2 publication and translation"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationFrontEnd, AccComputationEnabler
]

instance DepthCameraImageData : DTDFVocab:Data [
    base:desc "Compressed depth camera imagery transmitted via ROS2 and forwarded to the digital twin"
    DTDFVocab:fromData DepthCameraImageTransmitted
    DTDFVocab:inputTo DataTranslationFrontEnd
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Telemetry package of vehicle speed, steering, throttle, and brake dynamics"
    DTDFVocab:fromData VehicleStateMetricsTransmitted
    DTDFVocab:inputTo DataTranslationFrontEnd, AccComputationEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Steered object‑track and projected path messages from object‑tracking algorithm"
    DTDFVocab:fromData ObjectTrackMessagesTransmitted
    DTDFVocab:inputTo DataTranslationFrontEnd, AccComputationEnabler
]

// Enablers
instance DataTranslationFrontEnd : DTDFVocab:Enabler [
    base:desc "Data Translation Front‑End serialises binary ROS2 payloads, performs unit conversion, and forwards via Wi‑Fi UDP"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance AccComputationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that feeds vehicle telemetry and object‑track data into the ACC algorithm executing in the cloud"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteCommandExecutionEnabler : DTDFVocab:Enabler [
    base:desc "Processes operator commands from Remote Management Service and actuates ACC control nodes on the vehicle"
    DTDFVocab:enables RemoteManagementService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service that renders live vehicle state streams, projected driving path, and detected object tracks, enabling operators to view, save, and generate reports"
    DTDFVocab:provides LiveVehicleStateInsight, ObjectTrackInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service that exposes ACC enable/disable, target speed setting, and emergency brake trigger to operators"
    DTDFVocab:provides EnableACCAction, SetTargetSpeedAction, TriggerEmergencyBrakeAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service that offloads ACC computation to cloud and returns desired vehicle speed to the vehicle"
    DTDFVocab:provides ACCDesiredSpeedInsight
]

// Insights
instance LiveVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Displays real‑time vehicle state data (speed, steering angle, throttle, brake pressure) on the operator UI"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Visualises live object track messages and projected path overlays in the UI"
]

instance ACCDesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Shows the ACC algorithm‑derived target speed sent back to the vehicle for actuation"
]

// Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables or disables the Adaptive Cruise Control system aboard the vehicle"
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Sets desired target speed for the ACC system"
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Immediately initiates an emergency braking routine on the vehicle"
    DTDFVocab:IsAutomatic false
]

// Components
instance DigitalTwinComponent : DTDFVocab:Component [
    base:desc "Digital representation of the 1/10‑scale test vehicle, hosting monitoring and computation services"
]

instance PhysicalTwinComponent : DTDFVocab:Component [
    base:desc "The real vehicle equipped with chassis layers, embedded ECS, and ROS2‑based sensors and algorithms"
]

instance OperatorUserComponent : DTDFVocab:Component [
    base:desc "Operator interface providing access to monitoring, remote management, and offloading services"
]

// Environment
instance VehicleTestTrackEnvironment : DTDFVocab:Environment [
    base:contains DigitalTwinComponent, PhysicalTwinComponent, OperatorUserComponent
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin enforces a shared notion of time across all computation devices, requiring clock synchronization accuracy better than 100 ms; this 100 ms time‑stamping granularity is imposed on data exchanged between physical and digital layers to satisfy safety‑critical vehicular standards."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Architecture is derived from ISO 23247 Reference Architecture, mapping software components to functional entities and deploying each entity on separate hardware. Functional entities are organized into ROS 2 packages, with each package containing ROS 2 nodes implementing the FE’s responsibilities. The Digital Twin Entity aggregates data management and control modules, while the Physical Twin Entity encapsulates vehicle resources and general automotive functions such as point‑cloud clustering/tracking. The User Entity contains visualization and control panel sub‑components. System‑wide coordination is achieved via ROS 2 middleware, enabling inter‑entity messaging, shared data topics, and service calls."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All software components of the Digital Twin Service (DTS) are connected over an internal ROS 2 network that uses the Data Distribution Service (DDS) as transport layer, enabling low‑latency intra‑computer communication. Cross‑entity communication, i.e., between the vehicle’s physical twin and the DTS running on the cloud/edge cluster, is performed over Wi‑Fi using UDP sockets, as specified for the inter‑entity link in ISO 23247. The Data Translation FE serialises messages and executes unit conversion before the packets are sent over UDP. The network topology thus consists of (i) a micro‑service mesh of ROS 2 nodes on the edge computer, (ii) a Wi‑Fi gateway that bridges to the DTS central node, and (iii) optionally a redundant second wireless link for reliability. Bandwidth requirements are dictated by the LiDAR stream: transmitting high‑resolution point‑clouds (≈ 30 MB/s at 20 Hz) and vehicle state updates (≈ 200 kbps). Latency tolerance for real‑time monitoring is ≤ 50 ms, while control commands from the virtual twin are required to be delivered within 10 ms. Reliability is enhanced by UDP checksum verification, packet sequence numbers, and automatic retransmission requests for critical control messages."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Complies with ISO 23247 – Digital Twin Framework for Manufacturing (parts 1‑4). Employs the entity‑based reference architecture comprising the Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity and User Entity. Functional Entities (FEs) are defined for specific tasks such as actuating the OME, data transformation and user interaction. Communication between FEs may be implemented using OPC Unified Architecture (OPC UA) as an explicit example, thereby ensuring interoperability with industrial automation systems."
]