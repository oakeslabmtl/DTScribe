// C3: Physical sensing components
instance LidarSensor : DTDFVocab:SensingComponent [
    base:desc "High‑resolution 3D LiDAR mounted on the upper chassis collects raw point‑clouds."
    DTDFVocab:producedData LidarPointCloudDataTransmitted
]

instance MotorTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Motor telemetry sensor measures RPM of the propulsion system."
    DTDFVocab:producedData MotorRPMDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor records the steering wheel position in degrees."
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

instance VehicleStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle status sensor transmits speed and position telemetry."
    DTDFVocab:producedData VehicleStatusDataTransmitted
]

instance OperatorCommandSensor : DTDFVocab:SensingComponent [
    base:desc "Operator command sensor captures user inputs from the workstation control panel."
    DTDFVocab:producedData OperatorCommandDataTransmitted
]

// C4: Physical‑to‑virtual interaction – Data transmitted
instance LidarPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LidarSensor
]

instance MotorRPMDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorTelemetrySensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance VehicleStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStatusSensor
]

instance OperatorCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperatorCommandSensor
]

// Datatypes fed to the DT
instance LidarPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data transmitted to the digital twin."
    DTDFVocab:fromData LidarPointCloudDataTransmitted
]

instance MotorRPMData : DTDFVocab:Data [
    base:desc "Motor RPM telemetry data transmitted to the digital twin."
    DTDFVocab:fromData MotorRPMDataTransmitted
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle data received in degrees by the digital twin."
    DTDFVocab:fromData SteeringAngleDataTransmitted
]

instance VehicleStatusData : DTDFVocab:Data [
    base:desc "Vehicle speed and position telemetry data received by the digital twin."
    DTDFVocab:fromData VehicleStatusDataTransmitted
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

instance OperatorCommandData : DTDFVocab:Data [
    base:desc "Operator command data received from the remote control workstation."
    DTDFVocab:fromData OperatorCommandDataTransmitted
    DTDFVocab:inputTo RemoteCommandEnabler
]

instance ValidatedObjectTrackData : DTDFVocab:Data [
    base:desc "Validated object tracks and projected trajectories after clustering and tracking."
    DTDFVocab:inputTo VisualizationEnabler
]

// C10: Models and train
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Point‑cloud clustering and Kalman‑based tracking SW processes raw Lidar point‑clouds into validated object tracks and trajectories."
    DTDFVocab:inputTo ValidationOutputEnabler
]

instance ValidationOutputEnabler : DTDFVocab:Enabler [
    base:desc "Enables the transition from clustering results to visualization."
    DTDFVocab:enables DataMonitoringService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D Visualization Front‑end renders live updates from the digital twin."
    DTDFVocab:enables DataMonitoringService
]

// C11: Enablers for other services
instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Offloads ACC computation to cloud/edge, returns desired speed to vehicle."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteCommandEnabler : DTDFVocab:Enabler [
    base:desc "Processes operator commands and routes them to remote management functions."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Web‑based UI displays real‑time vehicle state, projected driving path, and detected object tracks allows viewing, saving, and report generation."
    DTDFVocab:provides VehicleStateInsight, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computes desired ACC speed in the cloud/edge and returns it to the vehicle."
    DTDFVocab:provides ReturnDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to activate/deactivate ACC, set desired speed, and issue emergency brake commands."
    DTDFVocab:provides ActivateACCAction, DeactivateACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights and Actions
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current vehicle state derived from live sensor data."
]

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Generate detailed reports on vehicle state and trajectory."
    DTDFVocab:IsAutomatic false
]

instance ReturnDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Return desired speed computed by ACC."
    DTDFVocab:IsAutomatic true
]

instance ActivateACCAction : DTDFVocab:Action [
    base:desc "Activate Adaptive Cruise Control on the vehicle."
    DTDFVocab:IsAutomatic false
]

instance DeactivateACCAction : DTDFVocab:Action [
    base:desc "Deactivate ACC."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set desired speed for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issue emergency brake command."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals such as steering angle, throttle level, and servo positions are produced by the Virtual Cockpit UI and sent as ROS2 action messages over the local middleware to the Actuation FE. The Actuation FE validates the command payload (ensuring correct format and acceptable ranges) before transmitting it to the vehicle’s on‑board control system via a UDP socket over the same Wi‑Fi link used for sensor data. The on‑board system replies with a simple ACK containing the sequence identifier, which the Actuation FE forwards to the virtual twin to close the feedback loop."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin synchronizes the virtual and physical subsystems to a shared notion of time with a maximum relative deviation of 100 ms. This 100 ms accuracy is mandated by hardware constraints and meets the stricter synchronization thresholds of safety‑critical vehicular standards. All ROS2 messages and sensor data timestamps are aligned to this accuracy, ensuring that time granularity for critical safety services is 100 ms and that end‑to‑end latency from sensor acquisition to actuation remains below this bound."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is orchestrated following ISO 23247 RA, mapping each software component to a Functional Entity (FE). Each FE is implemented as a dedicated ROS2 package containing one or more ROS2 nodes. The User Interface FE is split into two sub‑components—3D Visualization and Control Panel—both instantiated within the User Entity. Data management, control logic and pre‑processing reside in the Digital Twin Entity, while actuation and sensor interfacing are handled by the Physical Twin Entity. Inter‑entity communication is performed over ROS2 publish‑subscribe and client‑server topics, ensuring resource allocation, component integration, and system‑wide coordination across the distributed hardware deployment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All intra‑software component communication is implemented atop ROS2 using the Data‑Distribution Service (DDS) over UDP. Inter‑entity connections between the vehicle and the Digital Twin server are established over a Wi‑Fi 802.11n network using UDP sockets. Each message includes a sequence number and checksum to guarantee ordering and data integrity. The network topology is a flat, distributed structure with no dedicated encryption or VPN layers specified in the source document."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "The 3GPP TS 22.185 service‑requirements specification for vehicle‑to‑everything (V2X) communications mandates compliance with the EU General Data Protection Regulation (GDPR). It requires explicit user consent before any personal data is shared, mandates pseudonymisation or anonymisation of identifiers in vehicular messages, enforces data‑minimisation limits, and defines data‑sharing agreements between mobile and roadside infrastructures. Encryption of V2X traffic must use TLS 1.3 or an equivalent PKI‑based scheme, and TLS certificates must be signed by a trusted certificate authority as part of the authentication and access‑control mechanisms. The spec also recommends periodic data‑retention reviews and deletion of data after the necessary lifecycle for safety analytics, ensuring that any aggregated data used for digital‑twin model training is anonymised and stored in a secure, role‑based access environment."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adheres to the ISO 23247 – Digital twin framework for manufacturing (part 2: reference architecture). The standard defines the entity hierarchy and functional responsibilities, but does not stipulate additional certifications or interoperability specifications beyond providing this reference framework. No mention of compliance with other industry standards or certification requirements is present."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "ISO 26262‑1:2018 specifies the functional‑safety framework for road vehicles, requiring hazard analysis and risk assessment (HARA), classification of safety‑integrity levels (ASIL), safety concept and functional‑hazard design, and verification & validation of safety‑critical functions. The guideline stresses the implementation of a fail‑safe approach where ACC systems must detect abnormal operation, downgrade the system behaviour to a safe state, and trigger a driver alert. ISO 15622 further requires performance‑test procedures for adaptive cruise‑control systems, including validation of maintaining a minimum safe following distance under diverse traffic densities and emergency braking scenarios, with a statistical confidence level of 99.9%. These safety standards lay the foundation for secure digital‑twin architectures, while 3GPP TS 22.185 mandates cybersecurity protocols such as authentication, authorization, and encryption to protect V2X data exchanges."
]