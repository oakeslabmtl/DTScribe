prefix base: http://www.w3.org/2000/01/rdf-schema#
prefix DTDFVocab: http://example.org/dtdf

instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR for point cloud data",
    DTDFVocab:producedData LiDARPointCloudsDataTransmitted,
    base:isContainedIn AutonomousVehicleSystem
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel D435i Depth Camera for depth perception",
    DTDFVocab:producedData DepthCameraFeedsDataTransmitted,
    base:isContainedIn AutonomousVehicleSystem
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor",
    DTDFVocab:producedData VehicleSpeedDataTransmitted,
    base:isContainedIn AutonomousVehicleSystem
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor",
    DTDFVocab:producedData SteeringAngleDataTransmitted,
    base:isContainedIn AutonomousVehicleSystem
]

instance ObjectTrackingSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for object tracks from point cloud clustering",
    DTDFVocab:producedData ObjectTracksDataTransmitted,
    base:isContainedIn AutonomousVehicleSystem
]

instance LiDARPointCloudsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR,
    base:isContainedIn AutonomousVehicleSystem
]

instance DepthCameraFeedsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera,
    base:isContainedIn AutonomousVehicleSystem
]

instance VehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor,
    base:isContainedIn AutonomousVehicleSystem
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor,
    base:isContainedIn AutonomousVehicleSystem
]

instance ObjectTracksDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ObjectTrackingSensor,
    base:isContainedIn AutonomousVehicleSystem
]

instance LiDARPointCloudsData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data",
    DTDFVocab:fromData LiDARPointCloudsDataTransmitted,
    base:isContainedIn AutonomousVehicleSystem
]

instance DepthCameraFeedsData : DTDFVocab:Data [
    base:desc "Depth camera feeds",
    DTDFVocab:fromData DepthCameraFeedsDataTransmitted,
    base:isContainedIn AutonomousVehicleSystem
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed data",
    DTDFVocab:fromData VehicleSpeedDataTransmitted,
    base:isContainedIn AutonomousVehicleSystem
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle data",
    DTDFVocab:fromData SteeringAngleDataTransmitted,
    base:isContainedIn AutonomousVehicleSystem
]

instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks data",
    DTDFVocab:fromData ObjectTracksDataTransmitted,
    base:isContainedIn AutonomousVehicleSystem
]

instance PointCloudClusteringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for point cloud clustering and tracking",
    DTDFVocab:enables [DataMonitoring, ThreeDVisualization],
    base:isContainedIn AutonomousVehicleSystem
]

instance ACCEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for ACC control",
    DTDFVocab:enables [ComputationOffloading, RemoteManagement],
    base:isContainedIn AutonomousVehicleSystem
]

instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN for clustering, Kalman filter for tracking",
    DTDFVocab:inputTo PointCloudClusteringEnabler,
    base:isContainedIn AutonomousVehicleSystem
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "ISO 15622 Performance Class I",
    DTDFVocab:inputTo ACCEnabler,
    base:isContainedIn AutonomousVehicleSystem
]

instance NVIDIAJetpack50SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for hardware acceleration",
    DTDFVocab:enables [DataMonitoring, ComputationOffloading, ThreeDVisualization],
    base:isContainedIn AutonomousVehicleSystem
]

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for inter-process communication",
    DTDFVocab:enables [DataMonitoring, ComputationOffloading, RemoteManagement, ThreeDVisualization],
    base:isContainedIn AutonomousVehicleSystem
]

instance Python38 : DTDFVocab:Enabler [
    base:desc "Python 3.8 for scripting and node implementation",
    DTDFVocab:enables [DataMonitoring, ComputationOffloading, RemoteManagement, ThreeDVisualization],
    base:isContainedIn AutonomousVehicleSystem
]

instance CPlusPlusForROS2NodeLifecycleManagement : DTDFVocab:Enabler [
    base:desc "C++ for ROS2 node lifecycle management",
    DTDFVocab:enables [DataMonitoring, ComputationOffloading, RemoteManagement, ThreeDVisualization],
    base:isContainedIn AutonomousVehicleSystem
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for point cloud processing",
    DTDFVocab:enables [DataMonitoring, ThreeDVisualization],
    base:isContainedIn AutonomousVehicleSystem
]

instance SQL : DTDFVocab:Enabler [
    base:desc "SQL database for data storage",
    DTDFVocab:enables [DataMonitoring],
    base:isContainedIn AutonomousVehicleSystem
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of object tracks, vehicle state, and projected path",
    base:isContainedIn AutonomousVehicleSystem
]

instance HumanReadableReportsInsight : DTDFVocab:Insight [
    base:desc "Human-readable reports for troubleshooting and performance analysis",
    base:isContainedIn AutonomousVehicleSystem
]

instance ACCComputeDesiredSpeedAction : DTDFVocab:Action [
    base:desc "ACC computes desired speed based on lead vehicle distance",
    DTDFVocab:IsAutomatic true,
    base:isContainedIn AutonomousVehicleSystem
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable ACC",
    DTDFVocab:IsAutomatic false,
    base:isContainedIn AutonomousVehicleSystem
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable ACC",
    DTDFVocab:IsAutomatic false,
    base:isContainedIn AutonomousVehicleSystem
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set desired speed",
    DTDFVocab:IsAutomatic false,
    base:isContainedIn AutonomousVehicleSystem
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Emergency braking",
    DTDFVocab:IsAutomatic false,
    base:isContainedIn AutonomousVehicleSystem
]

instance DataMonitoring : DTDFVocab:Service [
    base:desc "real-time UI visualization of vehicle state, object tracks, and projected path report generation",
    DTDFVocab:provides [RealTimeVisualizationInsight, HumanReadableReportsInsight],
    base:isContainedIn AutonomousVehicleSystem
]

instance ComputationOffloading : DTDFVocab:Service [
    base:desc "ACC system execution on DT to reduce on-board ECU load",
    DTDFVocab:provides [ACCComputeDesiredSpeedAction],
    base:isContainedIn AutonomousVehicleSystem
]

instance RemoteManagement : DTDFVocab:Service [
    base:desc "enable/disable ACC, set desired speed, emergency braking via UI",
    DTDFVocab:provides [EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakingAction],
    base:isContainedIn AutonomousVehicleSystem
]

instance ThreeDVisualization : DTDFVocab:Service [
    base:desc "real-time object tracking and environmental rendering",
    DTDFVocab:provides [RealTimeVisualizationInsight],
    base:isContainedIn AutonomousVehicleSystem
]

instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical Twin Entity on vehicle Jetson Orin Nano",
    base:isContainedIn AutonomousVehicleSystem
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital Twin Entity on cloud/server",
    base:isContainedIn AutonomousVehicleSystem
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User Entity on remote machine",
    base:isContainedIn AutonomousVehicleSystem
]

instance CrossSystemDataTranslationFE : DTDFVocab:Component [
    base:desc "Cross-System Data Translation Functional Entity handling inter-entity communication",
    base:isContainedIn AutonomousVehicleSystem
]

instance AutonomousVehicleSystem : DTDFVocab:Environment [
    base:desc "Autonomous vehicle system environment",
    base:contains [PhysicalTwinEntity, DigitalTwinEntity, UserEntity, CrossSystemDataTranslationFE, HokuyoUST10LXLiDAR, IntelD435iDepthCamera, VehicleSpeedSensor, SteeringAngleSensor, ObjectTrackingSensor, LowerLevelChassis, UpperLevelChassis, NVIDIAJetsonNX, JetsonOrinNano, Motor, SteeringServo, VedderElectronicSpeedController]
]

instance LowerLevelChassis : DTDFVocab:Component [
    base:desc "Lower-level chassis for steering/speed control",
    base:isContainedIn AutonomousVehicleSystem
]

instance UpperLevelChassis : DTDFVocab:Component [
    base:desc "Upper-level chassis with NVIDIA Jetson NX and Orin Nano microcomputers",
    base:isContainedIn AutonomousVehicleSystem
]

instance NVIDIAJetsonNX : DTDFVocab:Component [
    base:desc "NVIDIA Jetson NX microcomputer",
    base:isContainedIn AutonomousVehicleSystem
]

instance JetsonOrinNano : DTDFVocab:Component [
    base:desc "Jetson Orin Nano microcomputer",
    base:isContainedIn AutonomousVehicleSystem
]

instance Motor : DTDFVocab:Component [
    base:desc "Motor controlled via Vedder Electronic Speed Controller for speed regulation",
    base:isContainedIn AutonomousVehicleSystem
]

instance SteeringServo : DTDFVocab:Component [
    base:desc "Steering servo for steering adjustments",
    base:isContainedIn AutonomousVehicleSystem
]

instance VedderElectronicSpeedController : DTDFVocab:Component [
    base:desc "Vedder Electronic Speed Controller for converting desired speed commands to motor voltage signals",
    base:isContainedIn AutonomousVehicleSystem
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "ACC control commands (desired speed, emergency braking signals) and steering adjustments generated by the Controlling FE and Actuation FE, transmitted over Wi-Fi to the Physical Twin Entity for motor voltage conversion and servo control."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "End-to-end latency ≤100 ms (per 3GPP TS 22.185 V2V requirements) and clock synchronization accuracy of 100 ms for distributed system coordination, ensuring real-time operation for safety-critical ACC functions."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Entity-based orchestration with Physical Twin Entity (vehicle sensors/actuators), Digital Twin Entity (ACC, Data Collection, Reporting), User Entity (3D Visualization, Control Panel), and Cross-System Data Translation FE; ROS2 for intra-entity communication, Wi-Fi for inter-entity data flow with serialization and unit conversion."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design phase (cyber-physical experimentation, compliance validation) and operation phase (optimization, health monitoring), covering 'as designed' (ACC logic per ISO 15622) and 'as operated' (real-time vehicle state tracking) representation phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "ACC implementation adheres to ISO 15622 Performance Class I (no road curvature); latency and clock sync requirements (100 ms) constrained by hardware limitations; no explicit verification/validation mechanisms detailed beyond compliance with standards."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "ROS2 network for intra-component communication; Wi-Fi for inter-entity communication; Data Translation FE serializes data, aligns message types, and performs unit conversions for all data streams."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity on NVIDIA Jetson Orin Nano (vehicle); Digital Twin Entity (ACC, Data Storage) on cloud/server; User Entity on remote machine; Data Storage external to vehicle per requirement R3."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture for DT design; ISO 15622 for ACC functionality; 3GPP TS 22.185 for V2V communication latency requirements."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety-critical system requiring ≤100 ms latency and clock synchronization for real-time operation; no specific cybersecurity protocols detailed in document."
]