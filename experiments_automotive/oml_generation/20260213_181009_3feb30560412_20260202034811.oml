// C2: Acting Components
instance LowerLevelChassisActuator : DTDFVocab:ActingComponent [
    base:desc "Controls lower chassis components (e.g., suspension, steering servo) for adaptive cruise control operations in resource-constrained automotive ECUs"
]

instance UpperLevelAutonomyActuator : DTDFVocab:ActingComponent [
    base:desc "Manages upper-level autonomy functions (e.g., lead vehicle detection, speed calculation) offloaded to cloud infrastructure for safety-critical operations"
]

// C3: Physical Sensing Components (derived from DT_Sensing_Components)
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "3D LiDAR sensor providing raw point cloud data for object detection and environmental mapping in ACC system"
    DTDFVocab:producedData RawPointCloudData
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Onboard vehicle state sensor capturing real-time metrics (speed, position, acceleration) for ACC system"
    DTDFVocab:producedData VehicleStateData
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Steering servo sensor tracking steering angle and feedback for adaptive cruise control adjustments"
    DTDFVocab:producedData SteeringFeedbackData
]

// C4: Data Transmission Components
instance RawPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
    DTDFVocab:format "PointCloud"
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
    DTDFVocab:format "VehicleStateMsg"
]

instance SteeringFeedbackData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
    DTDFVocab:format "SteeringDataMsg"
]

// C5: Data Processing Components
instance DataCollectingFE : DTDFVocab:Feature [
    base:desc "ROS2-based frontend module collecting raw sensor data from LiDAR, vehicle state, motor, and steering servo components"
]

instance DataPreProcessing : DTDFVocab:Feature [
    base:desc "Pre-processes raw sensor data (normalization, filtering) before point cloud conversion and clustering operations"
]

instance PointCloudClusteringTracking : DTDFVocab:Feature [
    base:desc "Converts 3D point cloud data to 2D plane representations and performs object detection/tracking using clustering algorithms"
    DTDFVocab:inputTo DataTranslation
    DTDFVocab:outputTo ObjectTrackData
]

instance DataTranslation : DTDFVocab:Feature [
    base:desc "Serializes data, aligns message types, and performs unit conversions (meters to inches, Hz to kHz) for all data streams"
    DTDFVocab:inputTo WiFiCommunication
    DTDFVocab:outputTo ObjectTrackData, ProjectedDrivingPath
]

instance WiFiCommunication : DTDFVocab:Communication [
    base:desc "Wi-Fi enabled communication layer using UDP transport protocol for inter-entity communication between ROS2 nodes"
    DTDFVocab:inputTo DataTranslation
]

// C6: Models/Data
instance PointCloud2DRepresentationModel : DTDFVocab:Model [
    base:desc "Converts 3D LiDAR point cloud data into 2D plane representations for simplified processing and visualization"
    DTDFVocab:inputTo DataTranslation
]

instance ObjectDetectionModel : DTDFVocab:Model [
    base:desc "Machine learning model for real-time object detection and tracking from point cloud data"
    DTDFVocab:inputTo PointCloudClusteringTracking
]

instance VehicleStateDatabase : DTDFVocab:Data [
    base:desc "Historical database storing vehicle state metrics for off-board analysis and trend detection"
    DTDFVocab:inputTo DataMonitoringService
    DTDFVocab:fromData VehicleStateData
]

instance ObjectTrackDatabase : DTDFVocab:Data [
    base:desc "Centralized database storing detected object tracks for real-time monitoring and analysis"
    DTDFVocab:inputTo DataMonitoringService
    DTDFVocab:fromData ObjectTrackData
]

// C7: Multiplicity Entities
instance UserEntity : DTDFVocab:Entity [
    base:desc "User-facing entity containing 3D visualization components and control panel for interactive Digital Twin operations"
]

instance DigitalTwinEntity : DTDFVocab:Entity [
    base:desc "Core Digital Twin entity managing data management, control mechanisms, and service orchestration"
]

instance PhysicalTwinEntity : DTDFVocab:Entity [
    base:desc "Physical twin entity hosting automotive functionality including point cloud processing components"
]

// C8: Enablers
instance ROS2Network : DTDFVocab:Enabler [
    base:desc "ROS2-based distributed computing framework enabling inter-node communication between vehicle components and Digital Twin services"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance WiFiUDPTransport : DTDFVocab:Enabler [
    base:desc "Wi-Fi enabled UDP transport layer for inter-entity communication between Digital Twin components"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance CloudComputingPlatform : DTDFVocab:Enabler [
    base:desc "Off-board cloud infrastructure handling computationally intensive ACC processing tasks (lead vehicle detection, speed calculation)"
    DTDFVocab:enables ComputationOffloadingService
]

// C9: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time data monitoring service providing visualization of vehicle state data, projected driving paths, and detected object tracks with reporting capabilities"
    DTDFVocab:provides RealTimeVisualizationInsight, HistoricalTrendAnalysisInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Cloud-based computation offloading service transferring ACC system processing (lead vehicle detection, speed calculation based on distance) to cloud infrastructure to alleviate resource-constrained on-board ECUs"
    DTDFVocab:provides LeadVehicleDetectionAction, SpeedCalculationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management service enabling operators to control ACC functions (enable/disable, set speed, emergency braking) from remote locations"
    DTDFVocab:provides EnableDisableAction, SpeedAdjustmentAction, EmergencyBrakeAction
]

// C10: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of vehicle state data (speed, position), projected driving paths, and detected object tracks for immediate driver situational awareness"
]

instance HistoricalTrendAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analysis of historical vehicle state data to identify patterns, anomalies, and performance trends for ACC system optimization"
]

instance LeadVehicleDetectionAction : DTDFVocab:Action [
    base:desc "Cloud-based processing of lead vehicle detection using LiDAR data to determine safe following distance and speed"
    DTDFVocab:IsAutomatic true
]

instance SpeedCalculationAction : DTDFVocab:Action [
    base:desc "Dynamic speed calculation based on distance to lead vehicle, traffic conditions, and vehicle capabilities"
    DTDFVocab:IsAutomatic true
]

instance EnableDisableAction : DTDFVocab:Action [
    base:desc "Remote enable/disable control of ACC system functionality from operator interface"
    DTDFVocab:IsAutomatic false
]

instance SpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Remote adjustment of ACC system target speed with validation against vehicle capabilities"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Emergency braking activation triggered by operator or system safety protocols"
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires 100 ms clock synchronization accuracy for computation offloading in safety-critical vehicular applications, as mandated by hardware limitations despite some standards requiring stricter synchronization (less than 100 ms)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows ISO 23247 RA, mapping software components to Functional Entities (FEs) implemented as individual ROS2 packages with ROS2 nodes. The system organizes components into User, Digital Twin, and Physical Twin Entities, with the Physical Twin Entity deviating from ISO 23247 by hosting general automotive functionality beyond resource-specific tasks, and communication between entities is managed via ROS2-based node interactions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between software components occurs within a ROS2 network, and inter-entity communication uses Wi-Fi with UDP as the transport layer protocol."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with ISO 23247:2021 standard, which includes four parts: Overview and general principles, Reference architecture (defining Observable Manufacturing Elements (OME), Data Collection and Device Control Entity, Digital Twin Entity, and User Entity), Digital representation of physical manufacturing elements, and Information exchange. Interoperability is supported through OPC Unified Architecture for data collection and device control operations."
]