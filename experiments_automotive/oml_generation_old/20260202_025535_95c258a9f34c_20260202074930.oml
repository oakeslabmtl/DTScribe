// ------------------------------------------------ // Return code: 1 | Stderr:
//  C3: Physical sensing components (Vehicle sensors)
// ------------------------------------------------
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor measuring ego vehicle speed"
    DTDFVocab:producedData EgoVehicleSpeedMsg
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring ego vehicle steering angle"
    DTDFVocab:producedData SteeringAngleMsg
]

instance HokuyoUST10LxLaserSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR sensor providing dense 3‑D point clouds"
    DTDFVocab:producedData LiDARPointCloudMsg
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera providing depth images"
    DTDFVocab:producedData DepthImageMsg
]

// ------------------------------------------------
//  C4: Data transmitted from sensors
// ------------------------------------------------
instance EgoVehicleSpeedMsg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleMsg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance LiDARPointCloudMsg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LxLaserSensor
]

instance DepthImageMsg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

// ------------------------------------------------
//  C10: Models/Data
// ------------------------------------------------
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN‑based clustering of LiDAR point clouds to identify potential vehicle‑centered objects"
    DTDFVocab:inputTo DataProcessingFE
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter‑based tracking of detected objects across time"
    DTDFVocab:inputTo DataProcessingFE
]

instance Iso15622ACCControlAlgorithmModel : DTDFVocab:Model [
    base:desc "ISO 15622 Adaptive Cruise Control algorithm computing desired speed and rate of change"
    DTDFVocab:inputTo ComputationOffloadingFE
]

// ------------------------------------------------
//  Data: Raw sensor data (input to DataCollectionFE)
// ------------------------------------------------
instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed data derived from ROS2 topic"
    DTDFVocab:inputTo DataCollectionFE
    DTDFVocab:fromData EgoVehicleSpeedMsg
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Ego steering angle data derived from ROS2 topic"
    DTDFVocab:inputTo DataCollectionFE
    DTDFVocab:fromData SteeringAngleMsg
]

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data from Hokuyo UST‑10LX sensor"
    DTDFVocab:inputTo DataCollectionFE
    DTDFVocab:fromData LiDARPointCloudMsg
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Raw depth image data from Intel D435i camera"
    DTDFVocab:inputTo DataCollectionFE
    DTDFVocab:fromData DepthImageMsg
]

// ------------------------------------------------
//  Data: Processed data (output of models)
// ------------------------------------------------
instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Detected object tracks generated from clustering and tracking models"
    DTDFVocab:inputTo DataProcessingFE, DataStorageFE
    DTDFVocab:fromData LiDARPointCloudData, DepthImageData
]

instance ACCControlData : DTDFVocab:Data [
    base:desc "ACC control command and status data generated by ISO 15622 model"
    DTDFVocab:inputTo ComputationOffloadingFE, DataStorageFE
    DTDFVocab:fromData VehicleSpeedData, SteeringAngleData, LiDARPointCloudData
]

// ------------------------------------------------
//  Enablers
// ------------------------------------------------
instance DataCollectionFE : DTDFVocab:Enabler [
    base:desc "Data Collection FE aggregating sensor data via ROS2 topics"
    DTDFVocab:enables DataMonitoringService
]

instance DataProcessingFE : DTDFVocab:Enabler [
    base:desc "Data Processing FE performing clustering, tracking, and ACC inference"
    DTDFVocab:enables ObjectTrackingService
]

instance ComputationOffloadingFE : DTDFVocab:Enabler [
    base:desc "Computation Offloading FE executing ACC algorithm on DT and returning results"
    DTDFVocab:enables ComputationOffloadingService
]

instance MonitoringFE : DTDFVocab:Enabler [
    base:desc "Monitoring FE delivering real‑time UI of vehicle state and ACC performance"
    DTDFVocab:enables DataMonitoringService
]

instance RemoteControlFE : DTDFVocab:Enabler [
    base:desc "Remote Control FE handling remote command execution (ACC enable/disable, desired speed, emergency brake)"
    DTDFVocab:enables RemoteManagementService
]

instance VisualizationFE : DTDFVocab:Enabler [
    base:desc "Visualization FE rendering 3‑D vehicle and environment"
    DTDFVocab:enables VisualizationService
]

instance ReportingFE : DTDFVocab:Enabler [
    base:desc "Reporting FE generating time‑series human‑readable reports from logged data"
    DTDFVocab:enables ReportingService
]

instance DataStorageFE : DTDFVocab:Enabler [
    base:desc "Data Storage FE handling persistence of processed data into SQL database"
]

// ------------------------------------------------
//  Services
// ------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real‑time UI monitoring of vehicle speed, steering angle, ACC status and performance"
    DTDFVocab:provides VehicleStateMonitoringInsight, ACCPerformanceMonitoringInsight, HumanReadableVehicleStateReport
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service performing ACC control computation offloaded to DT and transmitting commands to vehicle"
    DTDFVocab:provides ACCCommandInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Service allowing remote operators to enable/disable ACC, modify desired speed, and trigger emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, ModifyDesiredSpeedAction, EmergencyBrakeAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service providing 3‑D visualization of vehicle, environment, and detected object tracks"
    DTDFVocab:provides ThreeDVisualizationInsight, ObjectTrackVisualizationInsight
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Service generating time‑series reports from logged data"
    DTDFVocab:provides TimeSeriesReportInsight, HumanReadableObjectTrackReport
]

instance ObjectTrackingService : DTDFVocab:Service [
    base:desc "Service producing object track data for visualization"
    DTDFVocab:provides ObjectTrackVisualizationInsight
]

// ------------------------------------------------
//  Insights
// ------------------------------------------------
instance VehicleStateMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring insight for vehicle state variables (speed, steering angle, ACC status)"
]

instance ACCPerformanceMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing Adaptive Cruise Control performance metrics and behavior"
]

instance DriverBehaviorDiagnosisInsight : DTDFVocab:Insight [
    base:desc "Insight derived from time‑series data diagnosing driver behavior patterns"
]

instance HumanReadableVehicleStateReport : DTDFVocab:Insight [
    base:desc "Human‑readable report summarizing current vehicle speed, steering angle, and ACC status"
]

instance HumanReadableObjectTrackReport : DTDFVocab:Insight [
    base:desc "Human‑readable report of detected object tracks around the ego vehicle"
]

instance TimeSeriesReportInsight : DTDFVocab:Insight [
    base:desc "Time‑series report generated from logged vehicle and environment data"
]

instance ThreeDVisualizationInsight : DTDFVocab:Insight [
    base:desc "3‑D visualization insight of vehicle and surrounding environment"
]

instance ObjectTrackVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of detected object tracks in 3‑D space"
]

instance ACCCommandInsight : DTDFVocab:Insight [
    base:desc "Insight representing ACC control commands sent to vehicle"
]

// ------------------------------------------------
//  Actions
// ------------------------------------------------
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control (ACC) function on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control (ACC) function on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance ModifyDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Modify desired speed parameter for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Initiate emergency braking command"
    DTDFVocab:IsAutomatic false
]

// ------------------------------------------------
//  C2: Acting Components
// ------------------------------------------------
instance VehicleMotorActuationFE : DTDFVocab:ActingComponent [
    base:desc "Actuation FE converting desired speed into motor voltage commands for vehicle's motor driver over CAN bus"
]

instance SteeringActuationFE : DTDFVocab:ActingComponent [
    base:desc "Actuation FE converting steering commands into servo positions via vehicle's hydraulic system"
]

instance EmergencyBrakingActuationFE : DTDFVocab:ActingComponent [
    base:desc "Actuation FE handling emergency braking commands via vehicle's braking system"
]

// ------------------------------------------------
//  Physical twin environment
// ------------------------------------------------
instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:contains VehicleSpeedSensor, SteeringAngleSensor, HokuyoUST10LxLaserSensor, IntelD435iDepthCamera, VehicleMotorActuationFE, SteeringActuationFE, EmergencyBrakingActuationFE
]

// ------------------------------------------------
//  Digital twin environment (compute node)
// ------------------------------------------------
instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains DataCollectionFE, DataProcessingFE, ComputationOffloadingFE, MonitoringFE, RemoteControlFE, VisualizationFE, ReportingFE
]

// ------------------------------------------------
//  User interface environment
// ------------------------------------------------
instance UserInterfaceEnvironment : DTDFVocab:Environment [
    base:contains RemoteControlFE, MonitoringFE, VisualizationFE, ReportingFE
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT outputs desired speed, steering adjustments, and emergency braking commands to the PT; these are translated by the Data Translation FE and routed to the vehicle’s actuation mechanisms (motor voltage, steering servo, braking) via the Actuation FE, typically over a CAN bus or Ethernet."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with an end‑to‑end latency constraint of ≤100 ms for vehicle–DT communication; continuous sensor data ingestion at LiDAR update rates (~10–20 Hz), with ACC computations performed within this latency bound, and periodic reporting at lower rates."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT system consists of the Physical Twin Entity (sensor/actuator interfaces), Digital Twin Entity (data collection, processing, ACC algorithm), User Entity (3D visualization, control panel UI), and Cross‑System Entity (Data Translation FE); these entities are orchestrated through ROS2 topics on a Wi‑Fi network, with the Data Translation FE mediating between physical and virtual layers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers creation (design and simulation), validation (offline and online testing of ACC, data consistency, safety), and operation stages; it is instantiated in a concrete physical embodiment (1/10 scale vehicle) and evolves through iterative refinements based on the requirements R1–R8."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT guarantees real‑time fidelity via ≤100 ms end‑to‑end latency and 100 ms clock synchronization (R8), uses DBSCAN/Kalman for accurate perception, and follows ISO 23247 guidelines; validation includes comparing DT outputs against vehicle telemetry and offline simulation, but specific uncertainty quantification is not described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical–to‑virtual communication occurs over Wi‑Fi utilizing ROS2 DDS topics; Data Translation FE serializes and aligns message types, handles unit conversions; inter‑entity communication also uses UART/Serial or Ethernet where applicable."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Onboard deployment: NVIDIA Jetson Orin Nano hosts most FEs (Data Collection, ACC control, Data Translation); off‑board deployment: a remote workstation or cloud node hosts the User Entity UI and 3D visualization; communication across Wi‑Fi ensures connectivity, with potential edge computing for offline components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Follows ISO 23247 reference architecture; adheres to ISO/IEC 30173 for terminology; applies ISO 15622 for ACC implementation; uses ROS 2 as middleware and NVIDIA JetPack SDK; implements OPC UA for data translation (optional)."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical DD: end‑to‑end latency limited to 100 ms (R7), clock synchronization within 100 ms (R8), remote control authorized via command interface, emergency braking capability; compliance with 3GPP 22.185 for V2V service, yet detailed safety analysis and cybersecurity measures are not elaborated."
]