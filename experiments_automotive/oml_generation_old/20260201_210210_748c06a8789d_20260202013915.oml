// ---------- Sensing Components ----------
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR generating 3‑D point clouds up to 40 Hz, streamed to the Point Cloud Clustering & Tracking ROS2 node"
    DTDFVocab:producedData LidarPointCloudTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera providing RGB‑D frames up to 30 Hz for perception tasks"
    DTDFVocab:producedData DepthCameraFrameTransmitted
]

instance MotorPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting the electric motor position (speed) of the vehicle"
    DTDFVocab:producedData MotorPositionTransmitted
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting the steering servo angular position"
    DTDFVocab:producedData SteeringServoPositionTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑state sensor suite (e.g., IMU, battery, etc.) delivering overall state information"
    DTDFVocab:producedData VehicleStateTransmitted
]

// ---------- Data Transmitted ----------
instance LidarPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthCameraFrameTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

instance MotorPositionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionSensor
]

instance SteeringServoPositionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// ---------- Raw Data ----------
instance LidarPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream as received over Wi‑Fi (UDP) via ROS2 DDS"
    DTDFVocab:fromData LidarPointCloudTransmitted
    DTDFVocab:inputTo PointCloudClusteringTrackingModel
]

instance DepthCameraFrameData : DTDFVocab:Data [
    base:desc "Raw RGB‑D image frames from the depth camera"
    DTDFVocab:fromData DepthCameraFrameTransmitted
    DTDFVocab:inputTo PointCloudClusteringTrackingModel
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Current motor speed feedback used for closed‑loop actuation"
    DTDFVocab:fromData MotorPositionTransmitted
    DTDFVocab:inputTo RemoteManagementEnabler
]

instance SteeringServoPositionData : DTDFVocab:Data [
    base:desc "Current steering angle feedback used for closed‑loop actuation"
    DTDFVocab:fromData SteeringServoPositionTransmitted
    DTDFVocab:inputTo RemoteManagementEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Aggregated vehicle state (pose, velocity, battery) needed for monitoring and ACC"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo DataMonitoringEnabler
]

// ---------- Processed Data ----------
instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Higher‑level perception result: clustered and tracked object tracks derived from LiDAR and depth data"
    DTDFVocab:fromData LidarPointCloudTransmitted
    DTDFVocab:inputTo DataMonitoringEnabler
]

instance ACCDesiredSpeedData : DTDFVocab:Data [
    base:desc "Computed desired speed set‑point from the off‑loaded ACC algorithm"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

// ---------- Models ----------
instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Geometric processing model that clusters LiDAR point clouds and tracks objects in real time"
    DTDFVocab:inputTo DataMonitoringEnabler
]

instance ACCComputationModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm executed in the cloud container, generating speed set‑points"
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

// ---------- Enablers ----------
instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 middleware plus web‑based dashboard that visualizes vehicle state, projected path and object tracks"
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Cloud compute container hosting the ACC service; receives vehicle telemetry and returns speed commands"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Bidirectional Wi‑Fi communication stack (UDP) coupled with ROS2 topics for remote command and actuation"
    DTDFVocab:enables RemoteManagementService
]

// ---------- Services ----------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Graphical UI streams real‑time vehicle state, projected path and nearby object tracks; users can view, save and generate reports"
    DTDFVocab:provides ObjectTracksInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Off‑loaded ACC computation performed in the cloud; delivers desired speed set‑point back to the vehicle"
    DTDFVocab:provides RemoteSetSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "User interface enables operators to enable/disable ACC, set desired speed, and issue emergency braking"
    DTDFVocab:provides EnableACCAction,
                     SetDesiredSpeedAction,
                     EmergencyBrakeAction
]

// ---------- Insights ----------
instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Higher‑level perception insight: list of tracked objects with positions and velocities"
]

// ---------- Actions ----------
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator‑initiated command to activate the Adaptive Cruise Control function"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator‑initiated command to set a target cruising speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator‑initiated immediate stop command (emergency brake)"
    DTDFVocab:IsAutomatic false
]

instance RemoteSetSpeedAction : DTDFVocab:Action [
    base:desc "Automatically applied speed command generated by the ACC computation model"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin sends control commands back to the vehicle over the same Wi‑Fi/UDP link. Commands include the desired speed calculated by the off‑loaded ACC service, ACC enable/disable switches, and an emergency‑braking command. These messages are formatted by the Data Translation FE and routed through ROS 2 to the Actuation FE, which drives motor and steering actuators. The vehicle acknowledges execution via updated vehicle‑state messages, closing the feedback loop."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT requires that all participating devices maintain a shared notion of time for computation offloading. Clock synchronization must achieve an accuracy of 100 ms, which is the limit imposed by the hardware; standards for safety‑critical vehicular applications demand stricter synchronization, but the implemented system settles on the 100 ms bound. This synchronization interval defines the temporal granularity of data exchange between the Physical Twin Entity and the Digital Twin Entity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration is achieved by mapping each Functional Entity to an individual ROS 2 package; a package contains one or more ROS 2 nodes that implement the FE’s functionality. Inter‑entity communication leverages ROS 2 middleware, providing runtime coordination across the three entities deployed on distinct hardware. The design follows the ISO 23247 reference architecture, with the Physical Twin Entity exposing sensor/actuator resources, the Digital Twin Entity processing and representing them, and the User Entity offering 3‑D visualization and control panels. Resource management is implicit in the ROS 2 node lifecycle and the separate hardware allocation per entity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Intra‑twin software components communicate via a ROS 2 network (publish/subscribe), while inter‑entity communication between the physical twin and the digital twin uses a Wi‑Fi LAN with UDP at the transport layer. The network topology consists of a single ROS 2 domain on the DT side and a Wi‑Fi point‑to‑point link to the vehicle. No explicit bandwidth, latency, redundancy, or security mechanisms are described in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The ISO 23247 framework permits the use of standard data‑exchange protocols such as OPC Unified Architecture (OPC UA) for integration with external enterprise systems, although the presented automotive DT does not explicitly instantiate such a protocol. Consequently, external integration is conceptually supported via OPC UA, but no concrete external system connection is described in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is explicitly based on ISO 23247 (parts 1‑4), adopting its entity‑based reference architecture (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity, and Functional Entities). Device coordination may employ OPC Unified Architecture, and the design requires clock synchronization with an accuracy of 100 ms, satisfying safety‑critical vehicular application standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The case study notes that the ISO 23247 reference architecture does not cover safety‑critical requirements; it recommends elevating safety to a first‑class concern by adopting the automotive functional‑safety standard ISO 26262. Security aspects are identified as needing further research and alignment with existing automotive standards, but no concrete security mechanisms are described."
]