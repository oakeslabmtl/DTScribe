// C3: Physical sensing components
instance HokuyoLiDAR2D : DTDFVocab:SensingComponent [
    base:desc "Onboard Hokuyo UST-10LX 2‑D LiDAR providing up‑to‑10 Hz range measurements"
    DTDFVocab:producedData LiDARRawDataTransmitted
]

instance IntelDepthCameraRGBD : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera delivering RGB‑D frames at up to 30 Hz"
    DTDFVocab:producedData DepthCameraRawDataTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor reporting ego speed at native sampling rate"
    DTDFVocab:producedData SpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring servo position for vehicle heading"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor exposing drive‑motor current and voltage status for health monitoring"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance LiDARRawDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR2D
]

instance DepthCameraRawDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCameraRGBD
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

// C10: Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 2‑D LiDAR point‑cloud streamed at up to 10 Hz"
    DTDFVocab:fromData LiDARRawDataTransmitted
    DTDFVocab:inputTo DataTranslationComponent
]

instance DepthCameraRGBDData : DTDFVocab:Data [
    base:desc "RGB‑D image data captured by the Intel depth camera at up to 30 Hz"
    DTDFVocab:fromData DepthCameraRawDataTransmitted
    DTDFVocab:inputTo DataTranslationComponent
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego speed value (m/s) sampled by the vehicle speed sensor"
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo DataTranslationComponent
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle (degrees) sampled by the steering sensor"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo DataTranslationComponent
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Motor current and voltage status variables for diagnostics"
    DTDFVocab:fromData MotorStatusDataTransmitted
    DTDFVocab:inputTo DataTranslationComponent
]

// C10: Models
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering model that groups LiDAR points into object clusters"
    DTDFVocab:inputTo DataTranslationComponent
]

instance KalmanTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter tracking model that maintains object tracks over time"
    DTDFVocab:inputTo DataTranslationComponent
]

instance AdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "ACC algorithm that detects the lead vehicle and computes a desired speed set‑point"
    DTDFVocab:inputTo CloudACCComputeEnabler
]

// C11: Enablers
instance DataTranslationComponent : DTDFVocab:Enabler [
    base:desc "Software component that serialises, aligns messages to ISO 23247 types and performs unit conversions"
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService, DataMonitoringService
]

instance ROS2IntraProcessNetwork : DTDFVocab:Enabler [
    base:desc "ROS 2 DDS intra‑process network for real‑time communication between DT software components"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance CloudACCComputeEnabler : DTDFVocab:Enabler [
    base:desc "Cloud server hosting the Adaptive Cruise Control algorithm and returning desired speed"
    DTDFVocab:enables ComputationOffloadingService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring UI streams real‑time vehicle state, projected path and object tracks; enables report generation"
    DTDFVocab:provides VehicleStateInsight, PathProjectionInsight, ObjectTrackInsight, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation Offloading executes the ACC algorithm on external compute resources and sends the desired speed back to the vehicle"
    DTDFVocab:provides SetDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management UI lets operators enable/disable ACC, set desired speed and issue emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, IssueEmergencyBrakeAction
]

// C17: Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Continuous insight into vehicle speed, position, heading and motor status for operators"
]

instance PathProjectionInsight : DTDFVocab:Insight [
    base:desc "Projected driving path generated from perception pipeline and visualised in the UI"
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Real‑time object tracks derived from LiDAR clustering and Kalman tracking"
]

// C17: Actions
instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Generates and saves a report of collected telemetry and analysis"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets the vehicle's desired speed based on ACC computation"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables Adaptive Cruise Control operation"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disables Adaptive Cruise Control operation"
    DTDFVocab:IsAutomatic false
]

instance IssueEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issues an emergency braking command to the vehicle"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin generates control commands for the vehicle’s Adaptive Cruise Control (ACC) subsystem. Command types include enabling/disabling ACC, setting a desired speed value, and issuing an emergency braking request. These commands are formatted by the Data Translation FE (serialised, type‑aligned and unit‑converted) and transmitted to the vehicle over the same Wi‑Fi UDP link used for sensor data. Upon receipt, the Actuation functional element on the physical side decodes the messages and forwards the desired speed or brake command to the vehicle’s motor and steering actuators. The system provides execution confirmation through feedback of the updated vehicle state (e.g., actual speed), which is again processed by the Data Translation FE and sent back to the DT for monitoring. No explicit authentication or conflict‑resolution mechanisms are described in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT requires a shared notion of time across the physical and digital sides to support computation offloading; clock synchronization must achieve 100 ms accuracy (the system limits its sync to 100 ms, whereas many safety‑critical vehicular standards demand tighter bounds). This synchronization interval defines the temporal granularity for services such as sensor data acquisition, point‑cloud clustering, and actuation commands."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration relies on the ISO 23247 reference architecture: functional entities are mapped to ROS 2 packages, each containing one or more ROS 2 nodes that implement the required functionality. The Physical Twin Entity hosts resource‑specific functions (e.g., point‑cloud clustering and tracking), the Digital Twin Entity provides data‑management and control mechanisms, and the User Entity supplies the 3D visualization and control‑panel interfaces. Coordination between entities is achieved through ROS 2 communication middleware and the 100 ms clock‑synchronisation layer, ensuring consistent execution across distributed hardware."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT components communicate internally via the ROS 2 middleware, forming a publish/subscribe network on the hosting compute platform. Communication between the physical twin and the digital twin occurs over a wireless Wi‑Fi network using UDP as the transport protocol. The architecture thus comprises a local ROS 2 mesh for intra‑DT component interaction and an external Wi‑Fi link for inter‑entity exchange. Specific bandwidth, latency, reliability, redundancy, or security mechanisms (e.g., encryption, QoS) are not detailed in the provided documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin services are implemented as software components that can be deployed on compute resources external to the vehicle, such as cloud or edge platforms, enabling off‑loading of the ACC algorithm from the resource‑constrained ECU. Data collected from the vehicle are stored on an external device or storage service separate from the on‑board hardware. The modular service composition (Data Translation, Data Monitoring, Computation Offloading, Remote Management) allows scaling by adding more compute nodes as needed, but the documents do not specify concrete hosting platforms, scalability mechanisms, or availability guarantees."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system complies with ISO 23247, the International Standards Organization’s Digital Twin framework for manufacturing. It adopts Part 2 (Reference Architecture), which prescribes an entity‑based architecture comprising an Observable Manufacturing Element (OME), a Data Collection and Device Control Entity, a Digital Twin Entity, and a User Entity. Each entity is further decomposed into Functional Entities that handle specific tasks such as actuation, data transformation, and user interfacing. While ISO 23247 does not dictate concrete implementation techniques, the document notes that standards‑based communication protocols such as OPC Unified Architecture (OPC UA) can be employed for data exchange and control."
]