// Physical Sensing Components
instance HokuyoUST10LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2D LiDAR – 0.04 m to 3.5 m range, 0.5° angular resolution, 10 Hz"
    DTDFVocab:producedData LiDARPointCloud
]

instance IntelD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera – 30 Hz, depth drift 1 cm over 3 m"
    DTDFVocab:producedData DepthPointCloud
]

instance WheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle wheel speed sensor – 50 Hz LIN interface"
    DTDFVocab:producedData WheelSpeedTelemetry
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle steering angle sensor – 50 Hz LIN interface"
    DTDFVocab:producedData SteeringAngleTelemetry
]

instance BatteryVoltageSensor : DTDFVocab:SensingComponent [
    base:desc "Battery voltage sensor – 50 Hz LIN interface"
    DTDFVocab:producedData BatteryVoltageTelemetry
]

// Data Transmitted Instances
instance LiDARPointCloud : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LX
]

instance DepthPointCloud : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelD435iDepthCamera
]

instance WheelSpeedTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedSensor
]

instance SteeringAngleTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance BatteryVoltageTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BatteryVoltageSensor
]

// Data Instances
instance ProcessedLiDARPointCloud : DTDFVocab:Data [
    base:desc "LiDAR point cloud processed with DBSCAN clustering and Kalman filter tracking"
    DTDFVocab:fromData LiDARPointCloud
    DTDFVocab:inputTo PointCloudClusteringTrackingComponent
]

instance ProcessedDepthPointCloud : DTDFVocab:Data [
    base:desc "Depth camera point cloud processed with 2‑D Kalman filter slices"
    DTDFVocab:fromData DepthPointCloud
    DTDFVocab:inputTo PointCloudClusteringTrackingComponent
]

instance UnifiedVehicleState : DTDFVocab:Data [
    base:desc "Aggregated vehicle state data – speed, steering angle, battery voltage, timestamps ISO‑8601 UTC"
    DTDFVocab:fromData WheelSpeedTelemetry, SteeringAngleTelemetry, BatteryVoltageTelemetry
    DTDFVocab:inputTo DataTranslationFE
]

instance GeometricModelData : DTDFVocab:Data [
    base:desc "Geometric representation of ego vehicle and obstacles reconstructed from processed point clouds"
    DTDFVocab:inputTo GeometricRepresentationModel
    DTDFVocab:fromData ProcessedLiDARPointCloud, ProcessedDepthPointCloud
]

instance ACCControlCommand : DTDFVocab:Data [
    base:desc "Desired speed command generated by ACC behavior model based on lead vehicle distance"
    DTDFVocab:inputTo AccComputationComponent
]

instance DiagnosticsReport : DTDFVocab:Data [
    base:desc "Human‑readable PDF diagnostic report aggregated from telemetry"
    DTDFVocab:inputTo AnalyticalReportGenerationModel
]

// Models
instance ACCBehaviorModel : DTDFVocab:Model [
    base:desc "Finite state machine driving target speed and lateral position for ACC"
    DTDFVocab:inputTo AccComputationComponent
]

instance GeometricRepresentationModel : DTDFVocab:Model [
    base:desc "Geometric model that reconstructs vehicle pose and obstacle locations from LiDAR and depth data"
    DTDFVocab:inputTo GeometricModelData
]

instance AnalyticalReportGenerationModel : DTDFVocab:Model [
    base:desc "Aggregates telemetry to produce diagnostic PDFs via reporting functional entity"
    DTDFVocab:inputTo DiagnosticsReport
]

// Enablers
instance DataPreProcessingFE : DTDFVocab:Enabler [
    base:desc "Data Pre‑Processing FE that synchronizes, type‑aligns and unit‑converts sensor streams"
    DTDFVocab:enables DataMonitoringService
]

instance PointCloudClusteringTrackingComponent : DTDFVocab:Enabler [
    base:desc "DBSCAN clustering and Kalman filter tracking component for LiDAR and depth data"
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "ISO‑123247 Data Translation FE for type alignment and unit conversion"
    DTDFVocab:enables DataMonitoringService
]

instance AccComputationComponent : DTDFVocab:Enabler [
    base:desc "ACC computation component hosting the ACC behavior model"
    DTDFVocab:enables ComputationOffloadingService
]

instance GeometricModelComponent : DTDFVocab:Enabler [
    base:desc "Geometric model component that reconstructs vehicle and obstacle geometry"
    DTDFVocab:enables DataMonitoringService
]

instance ReportGenerationFE : DTDFVocab:Enabler [
    base:desc "Reporting functional entity that aggregates telemetry into diagnostic PDFs"
    DTDFVocab:enables DataMonitoringService
]

instance RemoteControlFE : DTDFVocab:Enabler [
    base:desc "Remote Control FE that exposes WebSocket API for ACC enable/disable and emergency braking"
    DTDFVocab:enables RemoteManagementService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "User interface that streams, archives and visualises real‑time vehicle state, projected path and detected object tracks; accessible to operators and developers"
    DTDFVocab:provides SpeedAndSpacingMetricsInsight, ACCOverrideAction, EmergencyBrakingAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "COMPUTATION Offloading service that hosts ACC algorithm on remote cloud/edge, computing desired speed from lead‑vehicle distance and feeding command back to vehicle"
    DTDFVocab:provides ACCControlCommandAction, ACCEnableDisableAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service allowing operators to enable/disable ACC, set target speed or issue emergency braking command from the dashboard"
    DTDFVocab:provides RemoteACCControlAction, EmergencyBrakingAction
]

// Insights
instance SpeedAndSpacingMetricsInsight : DTDFVocab:Insight [
    base:desc "Insight that provides real‑time speed and spacing metrics derived from vehicle state and detected object tracks"
]

// Actions
instance ACCOverrideAction : DTDFVocab:Action [
    base:desc "Automatic ACC override action triggered when system detects unsafe spacing"
    DTDFVocab:IsAutomatic true
]

instance ACCControlCommandAction : DTDFVocab:Action [
    base:desc "Action that sends desired speed command computed by ACC behavior model to vehicle actuators"
    DTDFVocab:IsAutomatic true
]

instance ACCEnableDisableAction : DTDFVocab:Action [
    base:desc "Action enabling or disabling the ACC system remotely"
    DTDFVocab:IsAutomatic false
]

instance RemoteACCControlAction : DTDFVocab:Action [
    base:desc "Operator‑initiated action to set target speed or enable/disable ACC via WebSocket"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Emergency braking command issued from remote dashboard, interrupting actuators if command packets are not received within 200 ms"
    DTDFVocab:IsAutomatic false
]

// Data Storage Backend
instance PostgreSQLDatabase : DTDFVocab:Component [
    base:desc "PostgreSQL SQL database persisting telemetry per Requirement R3; served via RESTful JSON endpoints to Digital Twin FE"
]

instance StoredTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data stored in PostgreSQL for audit and analysis"
    DTDFVocab:fromData UnifiedVehicleState, GeometricModelData, ACCControlCommand
    DTDFVocab:inputTo PostgreSQLDatabase
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DTS mandates sub‑100 ms clock synchronization accuracy (≈100 ms) for all underlying devices to enable computation off‑loading and satisfy safety‑critical vehicular standards. All Functional Entities (FEs) must maintain a common notion of time; the required accuracy is driven by hardware limitations. No explicit synchronization frequency or temporal granularity is specified beyond this 100 ms accuracy bound, though the system operates on that base for timestamp alignment of sensor data and control commands."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration follows the ISO 23247 Reference Architecture. Functional Entities are realised as independent ROS2 packages; each package contains one or more ROS2 nodes implementing the required functionality. The Physical Twin Entity implements automotive‑specific and device‑control FEs; the Digital Twin Entity implements data‑management and control FEs; the User Entity implements UI‑centric FEs. Communication between entities is provided by the ROS2 middleware over a Wi‑Fi network, enabling point‑to‑point and publish‑subscribe exchanges of sensor data, control commands, and visualization streams. Resource allocation and deployment are explicitly decoupled by deploying each FE on its designated hardware component, thereby ensuring clear ownership of functionality while enabling coordinated operation of the full DTS."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin design mandates high‑fidelity realtime simulation, quantified by a maximum network latency of 100 ms (Requirement R7) and clock synchronization jitter less than 100 ms (Requirement R8). Validation is achieved through cross‑checking simulated object trajectories against ground truth from a lidar‑based map, with a maximum positional deviation of 0.1 m under nominal conditions. Uncertainty is captured by propagating measurement noise in the Kalman filter; confidence intervals (95%) are logged. An automated test harness injects synthetic faults into the sensor data stream to trigger error‑detection routines; discrepancies exceeding 0.2 m trigger an alarm and roll‑back to safe state. Quality assurance includes nightly regression tests on the data‑storage schema, CI pipelines for FE unit tests with 90 % code coverage, and a periodic audit of data integrity using checksums stored in the SQL database."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data translation and service orchestration are performed within an internal ROS 2 network leveraging DDS for inter‑component communication. Inter‑entity communication—including messaging from the Digital Twin to the Physical Twin and user commands—is carried over a Wi‑Fi network using UDP. The document does not provide specifics about bandwidth, latency, reliability, redundancy, or security mechanisms, suggesting a single‑hop Wi‑Fi topology linking sensors, processing nodes, and the user interface."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system aligns with ISO 23247 Part 2 (Digital twin framework for manufacturing – reference architecture). It implements an entity‑based reference architecture comprising Data Collection and Device Control, Digital Twin, User and Observable Manufacturing Element entities, each realized through Functional Entities. The architecture may be instantiated with protocols such as OPC Unified Architecture (OPC UA) as a concrete implementation platform."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system adopts a multi‑layered safety and security strategy grounded in ISO 26262‑1:2018 and ISO 15622:2018.  ISO 26262‑1 defines the functional‑safety lifecycle – hazard analysis, risk assessment, ASIL determination, safety concept, and sustained verification and validation – which the system applies to its critical control modules (e.g., ACC logic).  ISO 15622:2018 specifies performance requirements for Adaptive Cruise Control, mandating fail‑safe operation, redundancy of sensor inputs, and tight latency bounds for safety‑critical loops.  Vehicle‑to‑everything (V2X) services are incorporated via 3GPP TS 22.185, which prescribes a security architecture that includes authentication (challenge‑response or X‑509 certificate exchange), key management (dynamic key provisioning), and message‑level encryption (e.g., AES‑128/256).  Access control is enforced through role‑based permissions on data exchange between the virtual cockpit and the vehicle domain, ensuring that only authorized entities can instantiate or modify digital‑twin models.  The model‑driven architecture described by Dalibor et al. enforces a strict separation between the virtual cockpit and the vehicle control layer, creating a safe boundary that isolates simulation errors from physical actuators.  Combined, these measures provide a comprehensive safety‑critical and cybersecurity posture for the Digital Twin system."
]