// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-110LX LiDAR providing 2‑D point‑clouds of the environment."
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering depth images."
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor measuring ego‑vehicle longitudinal speed."
    DTDFVocab:producedData SpeedStateTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor capturing steering wheel angle of the ego vehicle."
    DTDFVocab:producedData SteeringAngleTransmitted
]

instance WheelEncoder : DTDFVocab:SensingComponent [
    base:desc "On‑board wheel encoder providing incremental position for speed estimation."
    DTDFVocab:producedData EncoderStateTransmitted
]

// C4: Physical‑to‑virtual interaction
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]

instance SpeedStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor, WheelEncoder
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance EncoderStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelEncoder
]

// C10: Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream."
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Raw depth‑image stream from the Intel D435i."
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Time‑series vehicle speed values (m/s)."
    DTDFVocab:fromData SpeedStateTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, ACCComputationEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle measurements (degrees)."
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo DataTranslationEnabler, ACCComputationEnabler
]

// C10: Models
instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control (ACC) algorithm conforming to ISO 15622 performance‑class I."
    DTDFVocab:inputTo ACCComputationEnabler
]

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering applied to LiDAR point clouds for object segmentation."
    DTDFVocab:inputTo ObjectProcessingEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracker merging clustered detections into object tracks."
    DTDFVocab:inputTo ObjectProcessingEnabler
]

// C11: Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 based Data Translation Functional Entity that serializes, unit‑converts and republishes sensor streams."
    DTDFVocab:enables DataMonitoringService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "Compute Enabler hosting the ACC Control Model on off‑board compute."
    DTDFVocab:enables ACCComputationService
]

instance ObjectProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing Enabler executing DBSCAN clustering and Kalman tracking."
    DTDFVocab:enables DataMonitoringService
]

instance UIEnabler : DTDFVocab:Enabler [
    base:desc "User‑Interface Enabler delivering Remote Management Service via ROS 2 topics."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI visualization of vehicle state, object tracks, and projected path with reporting and data export."
    DTDFVocab:provides VehicleStateInsight, ObjectTracksInsight, PlannedPathInsight
]

instance ACCComputationService : DTDFVocab:Service [
    base:desc "Computation off‑loading service that runs the ACC algorithm in the Digital Twin, producing lead‑vehicle detection and speed set‑points."
    DTDFVocab:provides ACCControlInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service allowing operators to enable/disable ACC, adjust desired speed, and trigger emergency braking."
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight displaying current vehicle speed and steering angle on the UI."
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Insight showing tracked objects with positions and velocities derived from clustering and Kalman filtering."
]

instance PlannedPathInsight : DTDFVocab:Insight [
    base:desc "Insight visualizing the projected vehicle path based on ACC set‑point calculations."
]

instance ACCControlInsight : DTDFVocab:Insight [
    base:desc "Insight reporting ACC lead‑vehicle detection status and computed speed set‑point."
]

// C17: Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable the Adaptive Cruise Control algorithm."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Action to disable the Adaptive Cruise Control algorithm."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to modify the desired cruising speed for ACC."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to trigger an immediate emergency brake command."
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage actuator (Vedder ESC) receiving speed commands from the Digital Twin."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator receiving steering‑angle commands from the Digital Twin."
]

// Optional: Command transmission from DT to PT
instance ACCCommandTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorVoltageActuator, SteeringServoActuator
]

instance ACCCommandData : DTDFVocab:Data [
    base:desc "Command data containing desired speed and brake signals sent to the physical twin."
    DTDFVocab:fromData ACCCommandTransmitted
    DTDFVocab:inputTo MotorVoltageActuator, SteeringServoActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin issues control commands over ROS2/Wi‑Fi to the physical twin, including desired speed values, enable/disable ACC signals, emergency‑brake commands, and any steering adjustments; these are executed by the Actuation FE on the physical twin."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates with a maximum end‑to‑end network latency of 100 ms (R7) and clock synchronization accuracy of 100 ms (R8), supporting near‑real‑time update rates sufficient for ACC control loops."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A distributed architecture where the Physical Twin Entity hosts sensors and actuators, the Digital Twin Entity hosts data collection, ACC computation, visualization preprocessing, and reporting, the User Entity provides a 3D visualization and control‑panel UI, and a Cross‑System Entity handles data translation; communication uses ROS 2 intra‑entity and Wi‑Fi inter‑entity links."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during the operation stage of the vehicle lifecycle, providing runtime monitoring, control, and remote management of the ACC function."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Latency ≤ 100 ms and clock sync ≤ 100 ms guarantee temporal fidelity; ACC behavior adheres to ISO 15622 (performance class I); perception fidelity is ensured by DBSCAN clustering and Kalman‑filter tracking of LiDAR point clouds; data are stored in a SQL database for auditability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bi‑directional communication over a Wi‑Fi network using ROS 2 messages; the Data Translation FE serializes data, aligns message types, and performs unit conversions; all links are designed to meet the 100 ms latency requirement."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the onboard NVIDIA Jetson Orin Nano; the Digital Twin Entity is hosted on external compute (cloud/edge) accessible via Wi‑Fi; UI components of the User Entity run on a separate workstation accessed by operators."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built on the ISO 23247 reference architecture, complies with ISO 15622 for ACC functionality, and utilizes ROS 2 as a standardized middleware; optional OPC UA is mentioned as a possible transport layer."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The design acknowledges the safety‑critical nature of ACC, enforces a maximum 100 ms latency and synchronized clocks to ensure reliable control; however, specific cybersecurity mechanisms are not described in the document."
]