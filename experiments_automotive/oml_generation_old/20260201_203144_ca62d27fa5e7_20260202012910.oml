// ======================
// Physical Twin Sensors
// ======================

instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor on the 1/10‑scale autonomous vehicle generating 3‑D point clouds"
    DTDFVocab:producedData LiDARDataTransmitted
]

instance MotorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting the motor torque and speed status of the vehicle"
    DTDFVocab:producedData MotorStatusDataTransmitted
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor providing the current position of the steering servo"
    DTDFVocab:producedData SteeringServoDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Composite sensor exposing overall vehicle state (pose, velocity, battery level)"
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// ======================
// Data Transmitted from Physical Twin
// ======================

instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance MotorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStatusSensor
]

instance SteeringServoDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// ======================
// Raw Data Objects inside Digital Twin
// ======================

instance LiDARRawData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud stream received via UDP"
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance MotorStatusData : DTDFVocab:Data [
    base:desc "Motor torque and speed values received via UDP"
    DTDFVocab:fromData MotorStatusDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance SteeringServoData : DTDFVocab:Data [
    base:desc "Steering servo angle stream received via UDP"
    DTDFVocab:fromData SteeringServoDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle pose, velocity and battery level data received via UDP"
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

// ======================
// Models (Functional Entities)
// ======================

instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Algorithm that clusters and tracks 3‑D LiDAR points to detect objects and generate tracks"
    DTDFVocab:inputTo DataProcessingEnabler
]

// ======================
// Enablers (Functional Entities & Communication)
// ======================

instance UDPTransportLink : DTDFVocab:Enabler [
    base:desc "UDP transport over Wi‑Fi used to stream sensor data from the physical twin to the digital twin"
    DTDFVocab:enables DataProcessingEnabler
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2‑based functional entity that performs data translation, unit conversion, and point‑cloud processing"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance RemoteCommandEnabler : DTDFVocab:Enabler [
    base:desc "OPC UA interface that carries remote control commands (ACC enable/disable, speed setpoint, emergency brake) back to the vehicle"
    DTDFVocab:enables RemoteManagementService
]

// ======================
// Services
// ======================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides a UI that visualises real‑time vehicle state, projected path, and detected object tracks; allows report generation"
    DTDFVocab:provides RealTimeVehicleStateInsight, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes the adaptive cruise control algorithm in the cloud and returns the desired speed to the vehicle"
    DTDFVocab:provides ACCDecisionInsight, DesiredSpeedComputationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set a desired speed, and issue emergency‑braking commands via the UI"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakingAction
]

// ======================
// Insights
// ======================

instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight into the current pose, speed and sensor status of the autonomous vehicle"
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "Result of the ACC algorithm indicating the computed safe following speed"
]

// ======================
// Actions
// ======================

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Generates and saves a PDF report of ACC‑relevant data"
    DTDFVocab:IsAutomatic false
]

instance DesiredSpeedComputationAction : DTDFVocab:Action [
    base:desc "Computes desired speed based on lead‑vehicle distance and sends it to the vehicle"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables the adaptive cruise control function on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disables the adaptive cruise control function on the vehicle"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets a manual desired speed set‑point for the vehicle"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Issues an immediate brake command to stop the vehicle"
    DTDFVocab:IsAutomatic false
]

// ======================
// Top‑Level Entity Components
// ======================

instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Observable Manufacturing Element representing the 1/10‑scale autonomous vehicle"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital twin host that runs ROS 2 packages, ACC computation and data services"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "Operator/developer workstation providing the user interface for monitoring and control"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin Entity – e.g., the desired speed computed by the off‑loaded ACC algorithm, enable/disable ACC commands, speed‑setpoints, and emergency‑brake requests – are sent back to the Physical Twin Entity over the same Wi‑Fi UDP channel. Commands pass through the Data Translation FE for serialization and unit conversion before reaching the Actuation FE, which forwards them to the vehicle actuators (motor, steering servo). The system provides execution confirmation by observing updated vehicle state data via the monitoring feedback loop, but explicit authentication or conflict‑resolution mechanisms are not described in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT requires that all participating devices maintain a shared notion of time with a maximum clock offset of 100 ms; this accuracy is imposed to satisfy hardware limitations while supporting computation offloading and coordinated operation across devices. Synchronization is therefore performed at a frequency sufficient to keep drift under 100 ms, and the architecture assumes sub‑100 ms latency between physical and digital components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration is realized by mapping the ISO 23247 functional entities onto ROS2 packages; each FE becomes a ROS2 node that communicates over the ROS2 middleware, enabling loose‑coupled interaction between the three entities. Resource‑specific functionality (e.g., point‑cloud clustering and tracking) resides in the Physical Twin Entity, while data preprocessing and control logic are in the Digital Twin Entity, and visualization/control panels are in the User Entity. The overall constellation follows an entity‑centric architectural pattern with distributed execution, where ROS2 topics/services provide the system‑wide coordination and resource management across the hardware‑distributed components."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The architecture mandates a shared notion of time across all devices with a synchronization accuracy of 100 ms, dictated by hardware limitations for safety‑critical vehicular applications. This timing precision serves as a core validity requirement for coordinated actuation and sensing in the Digital Twin. Conformance to the ISO 23247 entity‑based reference architecture is used as a structural validation check. No additional model verification or uncertainty quantification methods are described in the documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS uses a hybrid network architecture: internal software components are linked through a ROS 2 publish/subscribe network, while communication between the three ISO 23247‑based entities (Physical Twin, Digital Twin, User) occurs over a Wi‑Fi network employing UDP at the transport layer. Clock synchronization of all devices is required with a maximum error of 100 ms to satisfy safety‑critical timing constraints. The design emphasizes low end‑to‑end latency for remote management and computation off‑loading, although exact bandwidth figures are not provided. Security considerations are limited to the use of UDP over Wi‑Fi; no additional security protocols are detailed."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin services are implemented as independent ROS 2 packages (functional entities) that can be deployed on separate hardware platforms. Computation off‑loading of the ACC algorithm is demonstrated by executing the ACC logic on a more capable platform (e.g., cloud or edge server) while the physical vehicle retains only sensing and actuation capabilities. The architecture supports deployment across heterogeneous nodes (vehicle‑mounted hardware for the Physical Twin Entity, remote compute resources for the Digital Twin Entity, and a user workstation for the User Entity). Specific scalability mechanisms, storage capacities, or availability guarantees are not enumerated in the supplied documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin system is explicitly built on the ISO 23247 reference architecture, employing its entity‑based model (Observable Manufacturing Element, Data Collection and Device Control Entity, Digital Twin Entity, User Entity) and mapping functional entities to ROS 2 packages. The design mentions that functional entities could be implemented using OPC Unified Architecture for device coordination, and notes that safety‑critical vehicular applications require clock‑synchronization accuracy of 100 ms or better, indicating alignment with relevant automotive timing standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The case study follows the ISO 23247 reference architecture but states that the RA alone is insufficient for safety‑critical automotive digital twins. To address safety, the authors recommend promoting safety to a first‑class concern by integrating the functional‑safety framework of ISO 26262 (ISO 26262‑1:2018), applying its hazard analysis, risk assessment, safety‑goal definition, and ASIL (Automotive Safety Integrity Level) assignment to DT components. The document does not provide concrete cybersecurity protocols, access‑control mechanisms, or authentication methods; it merely notes that security (along with data management) is an identified topic for future research."
]