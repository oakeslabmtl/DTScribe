// Sensors
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST10LX LiDAR providing 3D point cloud streams"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance DepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera providing depth images"
    DTDFVocab:producedData DepthImageTransmitted
]

instance WheelEncoderSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel encoder measuring vehicle speed"
    DTDFVocab:producedData VehicleSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring steering angle"
    DTDFVocab:producedData SteeringAngleTransmitted
]

// DataTransmitted
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DepthCameraSensor
]

instance VehicleSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelEncoderSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data streamed for perception"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo PerceptionEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Raw depth image data from Intel D435i used for perception"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo PerceptionEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed time-series data collected via wheel encoders"
    DTDFVocab:fromData VehicleSpeedTransmitted
    DTDFVocab:inputTo ACCOffloadingEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle time-series data collected from steering sensor"
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo ACCOffloadingEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Derived object tracks obtained from DBSCAN clustering and Kalman-filter tracking"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo PerceptionEnabler
]

instance ReportData : DTDFVocab:Data [
    base:desc "Generated reports of vehicle-state time-series for analysis"
    DTDFVocab:fromData VehicleSpeedTransmitted, SteeringAngleTransmitted
    DTDFVocab:inputTo ReportingEnabler
]

// Actions
instance ACCApplyDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to transmit ACC desired speed to the vehicle"
    DTDFVocab:IsAutomatic false
]

instance ACCParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Action to adjust ACC parameters remotely"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to trigger remote emergency braking"
    DTDFVocab:IsAutomatic true
]

// Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Handles serialization and unit conversion of telemetry over ROS2"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance PerceptionEnabler : DTDFVocab:Enabler [
    base:desc "Runs DBSCAN clustering and Kalman-filter tracking for perception"
    DTDFVocab:enables DataMonitoringService
]

instance ACCOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Offloads ACC algorithm execution to the Digital Twin"
    DTDFVocab:enables ACCComputationOffloadService
]

instance ReportingEnabler : DTDFVocab:Enabler [
    base:desc "Stores vehicle-state, object tracks, and generated reports in SQL database"
    DTDFVocab:enables ReportGenerationService
]

instance VizEnabler : DTDFVocab:Enabler [
    base:desc "Provides 3D visualization of virtual cockpit using model data"
    DTDFVocab:enables ThreeDVisualizationService
]

// Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering model for point-cloud clustering in perception"
    DTDFVocab:inputTo PerceptionEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman-filter tracking model for object trajectory estimation"
    DTDFVocab:inputTo PerceptionEnabler
]

instance ACCControlModelISO15622 : DTDFVocab:Model [
    base:desc "ACC control model compliant with ISO 15622 standards"
    DTDFVocab:inputTo ACCOffloadingEnabler
]

instance VirtualCockpitVizModel : DTDFVocab:Model [
    base:desc "3D visualization model for the virtual cockpit display"
    DTDFVocab:inputTo VizEnabler
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring and reporting of vehicle state and perception data"
    DTDFVocab:provides RemoteMonitoringInsight
]

instance ThreeDVisualizationService : DTDFVocab:Service [
    base:desc "3D visualization of the virtual cockpit and sensor data"
    DTDFVocab:provides TrajectorySafetyInsight
]

instance ACCComputationOffloadService : DTDFVocab:Service [
    base:desc "Computational offloading of ACC algorithm to the Digital Twin"
    DTDFVocab:provides ACCApplyDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote enable/disable ACC, parameter tuning, emergency braking"
    DTDFVocab:provides ACCParameterAdjustmentAction, EmergencyBrakeAction
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generation of vehicle-state time-series reports"
    DTDFVocab:provides HistoricalAnalysisInsight
]

// Insights
instance RemoteMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight from remote monitoring informing operators about vehicle performance"
]

instance TrajectorySafetyInsight : DTDFVocab:Insight [
    base:desc "Visualization insight aiding decision making about vehicle trajectory and safety"
]

instance HistoricalAnalysisInsight : DTDFVocab:Insight [
    base:desc "Historical analysis of vehicle-state time-series enabling ACC parameter adjustments"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital Twin outputs include ACC‑derived desired speed and emergency‑braking commands transmitted via the Actuation FE to the vehicle; User‑Entity Control Panel FE sends remote commands (enable/disable ACC, modify desired speed, emergency brake); DT also issues motor‑voltage signals to motor and steering‑servo actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Millisecond‑level real‑time operation; end‑to‑end latency ≤ 100 ms; clock synchronization accuracy ≤ 100 ms enforced across distributed nodes; ACC control decisions executed within this latency budget."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Configured per ISO 23247 reference architecture: entities Physical Twin, Digital Twin, User, and Cross‑System, each with Functional Entities (Data Collection, Presentation, Reporting, ACC Control, Actuation, User Interface, Data Translation) deployed across vehicle and cloud and orchestrated via ROS2 and Wi‑Fi inter‑entity links."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational stage only: the DT is built and used during vehicle operation; the study focuses on operation and real‑time monitoring, without manufacturer or design phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Real‑time fidelity ensured by meeting 100 ms latency and clock‑sync accuracy; implicit validation via comparison of DT‑generated reports with ground truth; ACC algorithm per ISO 15622 provides safety consistency; perception models (DBSCAN, Kalman filter) tuned to sensor specifications; no explicit uncertainty quantification reported."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication over Wi‑Fi; sensor and actuator data streamed via ROS2 over DDS (UDP/TCP transports); Data Translation and serialization performed within ROS2 layers; end‑to‑end latency maintained ≤ 100 ms."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Onboard NVIDIA Jetson Orin Nano hosts Physical Twin Entity components; Digital Twin and User Entity services run on a cloud or edge server with ROS2 networking; external SQL database stores vehicle state; user interface accessed via web/desktop client; deployment uses ROS2 packages as compiled binaries."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 (Digital Twin Manufacturing Framework reference architecture), ISO 15622 (ACC standard), ROS2 (open‑source middleware), IEEE 62541 OPC UA referenced for Data Translation FE; standardized communication interface per R1."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical application; enforced network latency ≤ 100 ms; clock sync ≤ 100 ms; remote actuation commands must be authenticated (implied); safety considerations align with ISO 15622 ACC safety requirements; no explicit cybersecurity mechanisms described."
]