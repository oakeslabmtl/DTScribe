instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "High-resolution 3D point cloud acquisition"
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Stereo vision depth measurements"
    DTDFVocab:producedData DepthCameraData
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Measures vehicle speed via CAN bus interface"
    DTDFVocab:producedData VehicleSpeedData
]

instance VehicleSteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Measures steering angle via CAN bus interface"
    DTDFVocab:producedData SteeringAngleData
]

instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]

instance VehicleSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSteeringAngleSensor
]

instance LiDARDataInSQL : DTDFVocab:Data [
    base:desc "LiDAR point cloud data stored in SQL database"
    DTDFVocab:inputTo SQLDatabase
    DTDFVocab:fromData LiDARPointCloudData
]

instance DepthCameraDataInSQL : DTDFVocab:Data [
    base:desc "Stereo depth data stored in SQL database"
    DTDFVocab:inputTo SQLDatabase
    DTDFVocab:fromData DepthCameraData
]

instance VehicleSpeedDataInSQL : DTDFVocab:Data [
    base:desc "Vehicle speed data stored in SQL database"
    DTDFVocab:inputTo SQLDatabase
    DTDFVocab:fromData VehicleSpeedData
]

instance SteeringAngleDataInSQL : DTDFVocab:Data [
    base:desc "Steering angle data stored in SQL database"
    DTDFVocab:inputTo SQLDatabase
    DTDFVocab:fromData SteeringAngleData
]

instance LiDARDataForClustering : DTDFVocab:Data [
    base:desc "LiDAR point cloud data for spatial pattern recognition"
    DTDFVocab:inputTo Python38Modules
    DTDFVocab:fromData LiDARPointCloudData
]

instance StateEstimationData : DTDFVocab:Data [
    base:desc "State estimation data for trajectory tracking"
    DTDFVocab:inputTo Python38Modules
    DTDFVocab:fromData VehicleSpeedData, SteeringAngleData
]

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN algorithm for spatial pattern recognition in LiDAR data"
    DTDFVocab:inputTo Python38Modules
]

instance KalmanFilterModel : DTDFVocab:Model [
    base:desc "Kalman filter for state estimation and trajectory tracking"
    DTDFVocab:inputTo Python38Modules
]

instance NVIDIAJetpack50SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for low-latency communication and system management"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for intra-component communication and data handling"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance Python38Modules : DTDFVocab:Enabler [
    base:desc "Python 3.8 application modules for data processing and computational models"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance CppModules : DTDFVocab:Enabler [
    base:desc "C++ application modules for high-performance data processing"
    DTDFVocab:enables ComputationOffloadingService
]

instance MATLABSimulinkModules : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink application modules for simulation and modeling"
    DTDFVocab:enables ComputationOffloadingService
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL database for structured data storage and management"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "User interface displaying real-time vehicle state data, projected driving paths, and detected object tracks, with data saving and reporting capabilities"
    DTDFVocab:provides RealTimeVehicleStateInsight, ProjectedDrivingPathInsight, ObjectTracksInsight, SaveDataAction, GenerateReportAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Processes ACC system's lead vehicle detection, speed computation, and actuation commands externally to alleviate resource-constrained ECUs"
    DTDFVocab:provides LeadVehicleDetectionAction, SpeedComputationAction, EmergencyBrakingAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, and issue emergency braking commands"
    DTDFVocab:provides EnableDisableACCAction, SetDesiredSpeedAction, EmergencyBrakingAction
]

instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real-time display of vehicle speed, steering angle, and other state data"
]

instance ProjectedDrivingPathInsight : DTDFVocab:Insight [
    base:desc "Visualization of projected driving paths based on ACC system calculations"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Detected object tracks from LiDAR data"
]

instance SaveDataAction : DTDFVocab:Action [
    base:desc "Saves sensor data for later analysis"
    DTDFVocab:IsAutomatic false
]

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Generates reports from stored data"
    DTDFVocab:IsAutomatic false
]

instance LeadVehicleDetectionAction : DTDFVocab:Action [
    base:desc "Detects lead vehicles for ACC system"
    DTDFVocab:IsAutomatic true
]

instance SpeedComputationAction : DTDFVocab:Action [
    base:desc "Computes appropriate speed for ACC"
    DTDFVocab:IsAutomatic true
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Issues emergency braking commands"
    DTDFVocab:IsAutomatic true
]

instance EnableDisableACCAction : DTDFVocab:Action [
    base:desc "Enables or disables ACC system"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Converts desired speed into motor voltage commands for speed regulation"
]

instance SteeringActuator : DTDFVocab:ActingComponent [
    base:desc "Regulates chassis steering angle via lower-level control mechanisms"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User entity for monitoring and control"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital Twin entity hosting computational models and services"
]

instance PhysicalEntity : DTDFVocab:Component [
    base:desc "Physical entity representing the actual vehicle"
]

instance UserInterface3DVisualization : DTDFVocab:Component [
    base:desc "3D Visualization component of User Interface Functional Entity"
]

instance UserInterfaceControlPanel : DTDFVocab:Component [
    base:desc "Control Panel component of User Interface Functional Entity"
]

instance PointCloudClusteringTracking : DTDFVocab:Component [
    base:desc "Point Cloud Clustering & Tracking functionality hosted by Physical Twin Entity"
]

instance VehicleSystem : DTDFVocab:Component [
    base:desc "1/10-scale teleoperated autonomous vehicle retrofitted with advanced sensors and control technology"
]

instance ACCSystemEnvironment : DTDFVocab:Environment [
    base:desc "Operational domain for Adaptive Cruise Control (ACC) systems within automotive ADAS"
    base:contains VehicleSystem, HokuyoUST10LXLiDAR, IntelDeepsenseD435iDepthCamera, VedderElectronicSpeedController, SteeringActuator
]

instance UserHardware : DTDFVocab:Environment [
    base:desc "Hardware component for User Entity deployment"
    base:contains UserEntity, UserInterface3DVisualization, UserInterfaceControlPanel
]

instance DigitalTwinHardware : DTDFVocab:Environment [
    base:desc "Hardware component for Digital Twin Entity deployment"
    base:contains DigitalTwinEntity
]

instance PhysicalHardware : DTDFVocab:Environment [
    base:desc "Hardware component for Physical Entity deployment"
    base:contains PhysicalEntity, PointCloudClusteringTracking
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands such as enabling/disabling ACC, setting target speed, and emergency braking are generated by the Controlling FE and User Interface FE. These commands are serialized and translated via the Data Translation component, then processed by the Actuation FE which converts desired speed into motor voltage commands for physical actuation. Remote management of ACC is enabled through the UI, with validation occurring during data translation for correct message formatting and unit consistency."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Clock synchronization accuracy requirement of 100 ms for safety-critical vehicular applications due to hardware limitations, aligning with industry standards mandating stricter than 100 ms synchronization."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Architectural design based on ISO 23247 RA, with software components mapped to Functional Entities (FEs) implemented as ROS2 packages; User Entity contains 3D Visualization and Control Panel, Digital Twin Entity handles data management and control, Physical Twin Entity manages hardware resources and automotive functions like Point Cloud Clustering & Tracking, though Physical Twin Entity's scope deviates from the standard by including general automotive functionality."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin maintains high-fidelity real-time replication through Requirement R7 (maximum network latency of 100 ms) and Requirement R8 (clock synchronization accuracy of 100 ms), ensuring precise temporal alignment between physical and digital states."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Intra-component communication uses ROS2 middleware. Inter-entity communication occurs over Wi-Fi with unspecified transport protocol due to truncated documentation. The system must maintain network latency of at most 100 ms per requirement R7. Reliability, redundancy, and security protocols are not detailed in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Entities are deployed across separate hardware components, with vehicle-mounted hardware handling onboard processing and external storage devices managing ego vehicle state data due to limited onboard storage capacity. Deployment is edge-based, with data storage external to the vehicle for scalability and capacity reasons. Specific cloud providers or detailed scalability mechanisms are not mentioned."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Compliance with industry clock synchronization standards requiring 100 ms accuracy for safety-critical vehicular applications, though specific data exchange protocols and external system dependencies are not detailed in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with ISO 23247 standard, which includes four parts: Overview and general principles, Reference architecture (Part 2), Digital representation of physical manufacturing elements, and Information exchange. The standard defines an entity-based reference architecture comprising Observable Manufacturing Elements (OME), Data Collection and Device Control Entity, Digital Twin Entity, and User Entity. Functional Entities (FEs) within these entities handle specific tasks like data transformation and user interaction, with OPC Unified Architecture (OPC UA) cited as an example implementation for Data Collection and Device Control Entities."
]