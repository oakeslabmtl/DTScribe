// C3: Physical Sensing Components
instance LidarPointCloudSensor : DTDFVocab:SensingComponent [
    base:desc "Collects raw 2D/3D LiDAR point cloud data for vehicle state tracking and object detection in real-time automotive applications"
    DTDFVocab:producedData LidarPointCloudDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors motor actuation signals, steering servo inputs, and vehicle dynamics parameters for powertrain control and trajectory analysis"
    DTDFVocab:producedData VehicleStateDataTransmitted
]

instance BatteryHealthSensor : DTDFVocab:SensingComponent [
    base:desc "Measures State of Charge (SoC) and State of Health (SoH) metrics for battery packs in electric vehicles, providing real-time degradation indicators"
    DTDFVocab:producedData BatteryHealthDataTransmitted
]

instance ThermalManagementSensor : DTDFVocab:SensingComponent [
    base:desc "Tracks temperature profiles across battery cells and cooling systems to prevent thermal runaway conditions in high-energy battery applications"
    DTDFVocab:producedData ThermalManagementDataTransmitted
]

instance SatelliteTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Collects orbital position, velocity, and collision avoidance sensor data for on-orbit satellite systems to enable real-time debris tracking"
    DTDFVocab:producedData SatelliteTelemetryDataTransmitted
]

instance AssemblyLineSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors CNC machine operational parameters, robotic arm performance, and assembly cell conditions for predictive maintenance in manufacturing"
    DTDFVocab:producedData AssemblyLineDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance LidarPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LidarPointCloudSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance BatteryHealthDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BatteryHealthSensor
]

instance ThermalManagementDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ThermalManagementSensor
]

instance SatelliteTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SatelliteTelemetrySensor
]

instance AssemblyLineDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AssemblyLineSensor
]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Processes raw LiDAR point clouds into structured object tracks and driving path projections through clustering algorithms"
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance VehicleStateTrackingModel : DTDFVocab:Model [
    base:desc "Simulates vehicle dynamics and trajectory prediction based on motor actuation and steering inputs for autonomous control systems"
    DTDFVocab:inputTo VehicleControlEnabler
]

instance BatteryDegradationModel : DTDFVocab:Model [
    base:desc "AI-driven model predicting Remaining Useful Life (RUL) and degradation patterns in battery cells using historical SoC/SoH data"
    DTDFVocab:inputTo BatteryManagementEnabler
]

instance ThermalManagementModel : DTDFVocab:Model [
    base:desc "Multi-physics simulation model optimizing cooling strategies to maintain battery pack temperatures within safe operational limits"
    DTDFVocab:inputTo ThermalControlEnabler
]

instance OrbitalDebrisModel : DTDFVocab:Model [
    base:desc "Space debris tracking and collision avoidance simulation model integrating satellite telemetry with orbital mechanics calculations"
    DTDFVocab:inputTo SatelliteControlEnabler
]

instance ManufacturingProcessModel : DTDFVocab:Model [
    base:desc "Digital twin model simulating assembly line operations, equipment performance, and production bottlenecks for optimization"
    DTDFVocab:inputTo ManufacturingEnabler
]

instance LidarPointCloudData : DTDFVocab:Data [
    base:desc "Structured 3D point cloud data representing vehicle surroundings and object trajectories after preprocessing"
    DTDFVocab:fromData LidarPointCloudDataTransmitted
    DTDFVocab:inputTo PointCloudVisualizationEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Processed vehicle state parameters including motor torque, steering angles, and acceleration vectors for control algorithms"
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo AdaptiveControlEnabler
]

instance BatteryHealthData : DTDFVocab:Data [
    base:desc "Time-series battery health metrics including SoC, SoH, and degradation rates for predictive maintenance applications"
