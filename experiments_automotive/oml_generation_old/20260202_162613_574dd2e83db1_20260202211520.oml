// C3: Physical Sensing Components
instance LidarSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor capturing 2D/3D point cloud data for vehicle environment perception with real-time clustering and tracking capabilities"
    DTDFVocab:producedData LidarPointCloudData
]

instance MotorSensor : DTDFVocab:SensingComponent [
    base:desc "Motor state sensor measuring actuation parameters including torque, RPM, and current draw for vehicle dynamics monitoring"
    DTDFVocab:producedData MotorStateData
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Steering servo sensor tracking angular positions and control signals for vehicle path tracking and trajectory analysis"
    DTDFVocab:producedData SteeringServoData
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Comprehensive vehicle state sensor collecting speed, acceleration, and orientation data for dynamic system monitoring"
    DTDFVocab:producedData VehicleStateData
]

instance BiologicalSensor : DTDFVocab:SensingComponent [
    base:desc "Biophysical sensor measuring EEG/ECG signals for operator stress/fatigue assessment in human-machine interaction systems"
    DTDFVocab:producedData BiophysicalData
]

// C4: Physical-to-Virtual Interaction
instance LidarPointCloudData : DTDFVocab:DataTransmitted [
    base:desc "Raw 2D/3D point cloud data from LiDAR sensor with clustering and tracking outputs for object representation"
    DTDFVocab:producedFrom LidarSensor
]

instance MotorStateData : DTDFVocab:DataTransmitted [
    base:desc "Real-time motor actuation parameters including torque, RPM, and current draw for vehicle dynamics analysis"
    DTDFVocab:producedFrom MotorSensor
]

instance SteeringServoData : DTDFVocab:DataTransmitted [
    base:desc "Steering servo angular positions and control signals for vehicle path trajectory analysis"
    DTDFVocab:producedFrom SteeringServoSensor
]

instance VehicleStateData : DTDFVocab:DataTransmitted [
    base:desc "Comprehensive vehicle state metrics including speed, acceleration, and orientation for dynamic system monitoring"
    DTDFVocab:producedFrom VehicleStateSensor
]

instance BiophysicalData : DTDFVocab:DataTransmitted [
    base:desc "Biological sensor data including EEG/ECG signals for operator stress/fatigue assessment in cyber-biophysical systems"
    DTDFVocab:producedFrom BiologicalSensor
]

instance ObjectTrackData : DTDFVocab:DataTransmitted [
    base:desc "Processed object tracks derived from point cloud clustering/tracking for real-time environment perception"
    DTDFVocab:producedFrom LidarSensor
]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Machine learning model for clustering and tracking point cloud data to derive meaningful object representations"
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance VehicleDynamicsModel : DTDFVocab:Model [
    base:desc "Physics-based model simulating vehicle dynamics including motor actuation and steering responses"
    DTDFVocab:inputTo ControlSimulationEnabler
]

instance BiophysicalFeedbackModel : DTDFVocab:Model [
    base:desc "Neural network model processing EEG/ECG data to assess operator stress/fatigue levels in human-machine systems"
    DTDFVocab:inputTo BiophysicalAnalysisEnabler
]

instance LidarPointCloudDataProcessed : DTDFVocab:Data [
    base:desc "Filtered and structured point cloud data after preprocessing through clustering and tracking algorithms"
    DTDFVocab:fromData LidarPointCloudData
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance VehicleStateMetrics : DTDFVocab:Data [
    base:desc "Processed vehicle state metrics including speed, acceleration, and orientation for real-time monitoring"
    DTDFVocab:fromData VehicleStateData
    DTDFVocab:inputTo ControlSimulationEnabler
]

instance BiophysicalMetrics : DTDFVocab:Data [
    base:desc "Processed biological metrics including stress/fatigue indicators derived from raw EEG/ECG signals"
    DTDFVocab:fromData BiophysicalData
    DTDFVocab:inputTo BiophysicalAnalysisEnabler
]

instance ObjectRepresentationData : DTDFVocab:Data [
    base:desc "Digital representations of objects derived from point cloud clustering/tracking for environment perception"
    DTDFVocab:fromData ObjectTrackData
    DTDFVocab:inputTo VisualizationEnabler
]

// C11: Enablers
instance DataPreProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity executing clustering and tracking algorithms on raw point cloud data to derive meaningful object representations"
    DTDFVocab:enables PointCloudVisualizationService, ObjectTrackingService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity serializing, aligning message types, and performing unit conversions for all data streams to ensure system compatibility"
    DTDFVocab:enables DataIntegrationService, CommunicationService
]

instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity implementing point cloud clustering and tracking algorithms for object representation"
    DTDFVocab:enables ObjectTrackingService, EnvironmentVisualizationService
]

instance ControlSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity simulating vehicle dynamics and control responses using physics-based models"
    DTDFVocab:enables AutonomousControlService, TrajectoryOptimizationService
]

instance BiophysicalAnalysisEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity processing biological sensor data to assess operator stress/fatigue levels"
    DTDFVocab:enables BiophysicalFeedbackService, ErgonomicOptimizationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity providing 3D visualization and real-time dashboards for system monitoring and analysis"
    DTDFVocab:enables ThreeDVisualizationService, RealTimeDashboardService
]

instance ROS2CommunicationEnabler : DTDFVocab:Enabler [
    base:desc "ROS2-based communication framework enabling intra-entity data exchange with high-frequency transmission capabilities"
    DTDFVocab:enables IntraEntityCommunicationService
]

instance UDPCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "UDP over Wi-Fi communication protocol for inter-entity data propagation with real-time requirements"
    DTDFVocab:enables InterEntityCommunicationService
]

instance OPCUAIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "OPC Unified Architecture integration layer enabling standardized data exchange with manufacturing systems"
    DTDFVocab:enables ManufacturingIntegrationService
]

// C6: Services
instance PointCloudVisualizationService : DTDFVocab:Service [
    base:desc "Service providing 3D visualization of processed point cloud data for real-time environment perception"
    DTDFVocab:provides EnvironmentVisualizationInsight
]

instance ObjectTrackingService : DTDFVocab:Service [
    base:desc "Service tracking objects in real-time using point cloud data for autonomous navigation and collision avoidance"
    DTDFVocab:provides ObjectTrackingInsight
]

instance AutonomousControlService : DTDFVocab:Service [
    base:desc "Service implementing AI-driven control algorithms for autonomous vehicle operation based on real-time sensor data"
    DTDFVocab:provides AutonomousControlAction
]

instance TrajectoryOptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing vehicle trajectories using predictive models and real-time state data"
    DTDFVocab:provides TrajectoryOptimizationInsight
]

instance BiophysicalFeedbackService : DTDFVocab:Service [
    base:desc "Service providing real-time feedback on operator stress/fatigue levels based on biological sensor data"
    DTDFVocab:provides BiophysicalFeedbackInsight
]

instance ErgonomicOptimizationService : DTDFVocab:Service [
    base:desc "Service dynamically adjusting human-machine interaction parameters based on biological feedback"
    DTDFVocab:provides ErgonomicOptimizationAction
]

instance ThreeDVisualizationService : DTDFVocab:Service [
    base:desc "Service rendering immersive 3D visualizations of the digital twin for operator training and troubleshooting"
    DTDFVocab:provides VisualizationInsight
]

instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Service providing IoT-enabled dashboards for real-time monitoring of system performance metrics"
    DTDFVocab:provides DashboardInsight
]

instance IntraEntityCommunicationService : DTDFVocab:Service [
    base:desc "Service enabling high-frequency communication between functional entities using ROS2 framework"
    DTDFVocab:provides CommunicationInsight
]

instance InterEntityCommunicationService : DTDFVocab:Service [
    base:desc "Service facilitating inter-entity data propagation using UDP over Wi-Fi for real-time system coordination"
    DTDFVocab:provides InterEntityCommunicationInsight
]

instance ManufacturingIntegrationService : DTDFVocab:Service [
    base:desc "Service integrating digital twin with manufacturing systems using OPC UA standardized protocols"
    DTDFVocab:provides IntegrationInsight
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Service ensuring data compatibility across system components through serialization and unit conversion"
    DTDFVocab:provides DataCompatibilityInsight
]

instance CommunicationService : DTDFVocab:Service [
    base:desc "Service managing data transmission protocols and ensuring real-time system communication"
    DTDFVocab:provides CommunicationReliabilityInsight
]

// C17: Insights/Actions
instance EnvironmentVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time 3D visualization of the vehicle environment derived from processed point cloud data"
]

instance ObjectTrackingInsight : DTDFVocab:Insight [
    base:desc "Real-time tracking of objects in the vehicle environment for navigation and collision avoidance"
]

instance AutonomousControlAction : DTDFVocab:Action [
    base:desc "Automated control commands executed on the physical vehicle based on digital twin simulations"
    DTDFVocab:IsAutomatic true
]

instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized vehicle trajectories generated through predictive modeling and real-time state data analysis"
]

instance BiophysicalFeedbackInsight : DTDFVocab:Insight [
    base:desc "Real-time assessment of operator stress/fatigue levels based on biological sensor data analysis"
]

instance ErgonomicOptimizationAction : DTDFVocab:Action [
    base:desc "Dynamic adjustments to human-machine interaction parameters based on biological feedback analysis"
    DTDFVocab:IsAutomatic true
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive 3D visualizations of the digital twin system for operator training and troubleshooting"
]

