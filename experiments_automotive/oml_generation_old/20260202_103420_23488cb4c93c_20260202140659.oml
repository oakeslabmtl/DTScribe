// C3: Physical sensing components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR sensor collecting raw point cloud data for environment mapping and object detection."
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelDeepsenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera capturing 3D spatial data for vehicle and environment perception."
    DTDFVocab:producedData DepthCameraData
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring ego vehicle speed for real-time state monitoring and control."
    DTDFVocab:producedData VehicleSpeedData
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring steering angle for vehicle state tracking and path planning."
    DTDFVocab:producedData SteeringAngleData
]

instance MotorStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring motor parameters (e.g., RPM, torque) for vehicle state and actuation feedback."
    DTDFVocab:producedData MotorStateData
]

instance ServoStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor monitoring servo parameters for steering and actuation control."
    DTDFVocab:producedData ServoStateData
]

// C4: Physical-to-virtual interaction
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    base:desc "Raw point cloud data from LiDAR sensors processed into individual points on a 2D plane."
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DepthCameraData : DTDFVocab:DataTransmitted [
    base:desc "3D spatial data from depth camera for environment perception and object detection."
    DTDFVocab:producedFrom IntelDeepsenseD435iCamera
]

instance VehicleSpeedData : DTDFVocab:DataTransmitted [
    base:desc "Ego vehicle speed data for real-time state monitoring and control."
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleData : DTDFVocab:DataTransmitted [
    base:desc "Steering angle data for vehicle state tracking and path planning."
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance MotorStateData : DTDFVocab:DataTransmitted [
    base:desc "Motor state parameters (RPM, torque) for vehicle state and actuation feedback."
    DTDFVocab:producedFrom MotorStateSensor
]

instance ServoStateData : DTDFVocab:DataTransmitted [
    base:desc "Servo state parameters for steering and actuation control."
    DTDFVocab:producedFrom ServoStateSensor
]

instance ObjectTracksData : DTDFVocab:DataTransmitted [
    base:desc "Processed object tracks derived from raw LiDAR data for real-time visualization and collision avoidance."
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance DrivingPathData : DTDFVocab:DataTransmitted [
    base:desc "Processed driving path data from raw LiDAR for real-time visualization and path planning."
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
]

instance ActuationFeedbackData : DTDFVocab:DataTransmitted [
    base:desc "Actuation feedback elements (e.g., motor actuation, steering servo actuation) for system state updates."
    DTDFVocab:producedFrom MotorStateSensor, ServoStateSensor
]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Model converting raw LiDAR points into structured object tracks for collision avoidance and path planning."
    DTDFVocab:inputTo PointCloudClusteringEnabler
]

instance DataTranslationModel : DTDFVocab:Model [
    base:desc "Model serializing data, aligning message types, and performing unit conversions for system consistency."
    DTDFVocab:inputTo DataTranslationEnabler
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Aggregated vehicle state data including motor, steering, and servo parameters for real-time monitoring."
    DTDFVocab:fromData VehicleSpeedData, SteeringAngleData, MotorStateData, ServoStateData
    DTDFVocab:inputTo DataCollectingEnabler
]

instance ProcessedObjectTracksData : DTDFVocab:Data [
    base:desc "Structured object tracks processed from raw LiDAR data for real-time visualization and decision-making."
    DTDFVocab:fromData ObjectTracksData
    DTDFVocab:inputTo PointCloudClusteringEnabler
]

instance ProcessedDrivingPathData : DTDFVocab:Data [
    base:desc "Processed driving path data for real-time visualization and path planning."
    DTDFVocab:fromData DrivingPathData
    DTDFVocab:inputTo VisualizationEnabler
]

instance ActuationCommandData : DTDFVocab:Data [
    base:desc "Low-level actuation commands derived from desired operational parameters (e.g., speed, steering angle)."
    DTDFVocab:fromData ActuationFeedbackData
    DTDFVocab:inputTo ActuationEnabler
]

// C11: Enablers
instance PointCloudClusteringEnabler : DTDFVocab:Enabler [
    base:desc "Software component performing point cloud clustering and tracking to convert raw LiDAR data into object tracks."
    DTDFVocab:enables RealTimeObjectTrackingService, CollisionAvoidanceService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Component serializing data, aligning message types, and performing unit conversions for system consistency."
    DTDFVocab:enables DataIntegrationService, SystemInteroperabilityService
]

instance DataCollectingEnabler : DTDFVocab:Enabler [
    base:desc "Component aggregating raw data from sensors (LiDAR, motor, steering) into a unified format."
    DTDFVocab:enables VehicleStateMonitoringService, DataReportingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Component preprocessing data for 3D visualization (e.g., rendering vehicle and environment in real-time)."
    DTDFVocab:enables RealTimeVisualizationService, DrivingPathVisualizationService
]

instance ActuationEnabler : DTDFVocab:Enabler [
    base:desc "Component converting desired operational parameters into low-level actuation commands for physical actuators."
    DTDFVocab:enables AdaptiveCruiseControlService, SteeringControlService
]

instance ROS2NetworkEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 network enabling modular and interoperable data exchange between software components."
    DTDFVocab:enables InternalComponentCommunicationService
]

instance WiFiUDPCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "Wi-Fi with UDP protocol for inter-entity communication (e.g., between Physical Twin and Digital Twin)."
    DTDFVocab:enables ExternalEntityCommunicationService
]

// C6: Services
instance RealTimeObjectTrackingService : DTDFVocab:Service [
    base:desc "Service providing real-time tracking of objects derived from processed LiDAR data."
    DTDFVocab:provides ObjectTrackingInsight
]

instance CollisionAvoidanceService : DTDFVocab:Service [
    base:desc "Service enabling collision avoidance based on processed object tracks and driving path data."
    DTDFVocab:provides CollisionAvoidanceAction
]

instance VehicleStateMonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring real-time vehicle state including motor, steering, and servo parameters."
    DTDFVocab:provides VehicleStateInsight
]

instance DataReportingService : DTDFVocab:Service [
    base:desc "Service generating structured reports (e.g., vehicle state summaries) for visualization or further processing."
    DTDFVocab:provides VehicleStateReportInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Service providing real-time 3D visualization of vehicle and environment."
    DTDFVocab:provides EnvironmentVisualizationInsight
]

instance DrivingPathVisualizationService : DTDFVocab:Service [
    base:desc "Service visualizing processed driving path data for path planning and monitoring."
    DTDFVocab:provides DrivingPathInsight
]

instance AdaptiveCruiseControlService : DTDFVocab:Service [
    base:desc "Service enabling adaptive cruise control through real-time actuation adjustments."
    DTDFVocab:provides AdaptiveCruiseControlAction
]

instance SteeringControlService : DTDFVocab:Service [
    base:desc "Service controlling steering servo based on real-time data and path planning."
    DTDFVocab:provides SteeringControlAction
]

instance InternalComponentCommunicationService : DTDFVocab:Service [
    base:desc "Service enabling modular and interoperable communication within ROS2 network."
    DTDFVocab:provides ComponentCommunicationInsight
]

instance ExternalEntityCommunicationService : DTDFVocab:Service [
    base:desc "Service enabling inter-entity communication via Wi-Fi UDP protocol."
    DTDFVocab:provides EntityCommunicationInsight
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Service ensuring compatibility between heterogeneous data streams (e.g., sensor data and control signals)."
    DTDFVocab:provides DataIntegrationInsight
]

instance SystemInteroperabilityService : DTDFVocab:Service [
    base:desc "Service maintaining system interoperability through data translation and unit conversion."
    DTDFVocab:provides SystemInteroperabilityInsight
]

// C17: Insights/Actions
instance ObjectTrackingInsight : DTDFVocab:Insight [
    base:desc "Insight into real-time object positions and movements derived from processed LiDAR data."
]

instance CollisionAvoidanceAction : DTDFVocab:Action [
    base:desc "Action triggering collision avoidance maneuvers based on object tracking data."
    DTDFVocab:IsAutomatic true
]

