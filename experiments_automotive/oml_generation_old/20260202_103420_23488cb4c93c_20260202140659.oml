    base:desc "Insight into current vehicle state including motor, steering, and servo parameters."
]

instance VehicleStateReportInsight : DTDFVocab:Insight [
    base:desc "Structured report summarizing vehicle state for visualization or further processing."
]

instance EnvironmentVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time 3D visualization of vehicle and surrounding environment."
]

instance DrivingPathInsight : DTDFVocab:Insight [
    base:desc "Visual representation of processed driving path for path planning and monitoring."
]

