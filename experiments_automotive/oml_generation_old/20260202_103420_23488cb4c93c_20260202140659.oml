    base:desc "Insight into modular communication between software components via ROS2 network."
]

instance EntityCommunicationInsight : DTDFVocab:Insight [
    base:desc "Insight into inter-entity communication via Wi-Fi UDP protocol."
]

instance DataIntegrationInsight : DTDFVocab:Insight [
    base:desc "Insight into compatibility and integration of heterogeneous data streams."
]

