// ---------------------------------------------------
// Entities
// ---------------------------------------------------
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "1/10‑scale autonomous vehicle (Traxxas Slash) equipped with Jetson NX, Hokuyo LiDAR, RealSense D435i, and Vedder ESC"
    base:contains HokuyoLiDAR, IntelRealSenseCamera, VehicleSpeedSensor, SteeringAngleSensor,
                MotorVoltageActuator, SteeringServoActuator, EmergencyBrakeActuator
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Off‑board compute node hosting ROS2 services, models and enablers for the Digital Twin"
    base:contains ROS2Middleware, Python38Runtime, CppRuntime, MATLABSimulink,
                NVIDIAJetpackSDK, WiFiNetwork, DataTranslationEnabler,
                RemoteManagementEnabler, ReportGenerationEnabler,
                ACCDecisionModel, DBSCANClusteringModel, KalmanFilterTrackingModel,
                Visualization3DModel, ReportGenerationModel
]

instance UserEntity : DTDFVocab:Component [
    base:desc "Operator workstation providing UI for monitoring and remote management"
    base:contains DataMonitoringService, RemoteManagementService
]

// ---------------------------------------------------
// Physical Sensing Components
// ---------------------------------------------------
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2‑D LiDAR providing raw point‑cloud scans of the environment"
    DTDFVocab:producedData RawLiDARPointCloud
]

instance IntelRealSenseCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering depth images"
    DTDFVocab:producedData DepthImageData
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor reporting ego‑vehicle longitudinal speed"
    DTDFVocab:producedData EgoSpeedData
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor reporting front wheel angle"
    DTDFVocab:producedData SteeringAngleData
]

// ---------------------------------------------------
// Physical Acting Components
// ---------------------------------------------------
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller providing motor voltage actuation"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Servo actuator controlling wheel steering angle"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator issuing an emergency brake signal to the vehicle"
]

// ---------------------------------------------------
// Data Transmitted (Physical → Virtual)
// ---------------------------------------------------
instance RawLiDARPointCloud : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthImageData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseCamera
]

instance EgoSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ProcessedObjectTracks : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RawLiDARPointCloud
]

instance ACCDecisionOutput : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ACCDecisionModel
]

// ---------------------------------------------------
// Data (from Data Transmitted)
// ---------------------------------------------------
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 2‑D LiDAR point‑cloud scan"
    DTDFVocab:fromData RawLiDARPointCloud
    DTDFVocab:inputTo DataTranslationEnabler, DBSCANClusteringModel
]

instance DepthImage : DTDFVocab:Data [
    base:desc "Depth image from RealSense camera"
    DTDFVocab:fromData DepthImageData
    DTDFVocab:inputTo DataTranslationEnabler
]

instance EgoVehicleStateData : DTDFVocab:Data [
    base:desc "Combined ego vehicle speed and steering angle"
    DTDFVocab:fromData EgoSpeedData, SteeringAngleData
    DTDFVocab:inputTo Python38Runtime, DataTranslationEnabler, ACCDecisionModel
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Tracked objects (position, velocity) after clustering and Kalman filtering"
    DTDFVocab:fromData ProcessedObjectTracks
    DTDFVocab:inputTo ROS2Middleware, DataTranslationEnabler, Visualization3DModel, ReportGenerationEnabler
]

instance ACCDecisionData : DTDFVocab:Data [
    base:desc "ACC algorithm output (desired speed, following distance)"
    DTDFVocab:fromData ACCDecisionOutput
    DTDFVocab:inputTo RemoteManagementEnabler, Python38Runtime
]

// ---------------------------------------------------
// Models / Algorithms
// ---------------------------------------------------
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR points to generate object proposals"
    DTDFVocab:inputTo KalmanFilterTrackingModel, DataTranslationEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based multi‑target tracking producing position and velocity"
    DTDFVocab:inputTo Visualization3DModel, ReportGenerationEnabler, DataTranslationEnabler
]

instance ACCDecisionModel : DTDFVocab:Model [
    base:desc "ACC decision model detecting lead vehicle and computing speed per ISO 15622"
    DTDFVocab:inputTo RemoteManagementEnabler, DataTranslationEnabler
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model for real‑time UI rendering of vehicle and tracks"
    DTDFVocab:inputTo ROS2Middleware, DataTranslationEnabler
]

instance ReportGenerationModel : DTDFVocab:Model [
    base:desc "Time‑series CSV report generator storing data in external SQL database"
    DTDFVocab:inputTo ReportGenerationEnabler, DataTranslationEnabler
]

// ---------------------------------------------------
// Enablers (Tooling & Functional Entities)
// ---------------------------------------------------
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware handling inter‑process communication for all functional entities"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService,
                RemoteManagementService, ReportGenerationService
]

instance Python38Runtime : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime executing ACC algorithm and data‑translation scripts"
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService
]

instance CppRuntime : DTDFVocab:Enabler [
    base:desc "C++ node lifecycle managing actuation command handling"
    DTDFVocab:enables RemoteManagementService
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for clustering and tracking algorithm development"
    DTDFVocab:enables ComputationOffloadingService, ReportGenerationService
]

instance NVIDIAJetpackSDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK providing GPU acceleration on Jetson hardware"
    DTDFVocab:enables ComputationOffloadingService
]

instance WiFiNetwork : DTDFVocab:Enabler [
    base:desc "Wi‑Fi networking linking PT, DT, and UI devices"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Data Translation Functional Entity for serialization and unit conversion"
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService, ReportGenerationService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity enabling remote ACC parameter changes and emergency brake"
    DTDFVocab:enables RemoteManagementService
]

instance ReportGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Functional entity handling CSV generation and SQL storage"
    DTDFVocab:enables ReportGenerationService
]

// ---------------------------------------------------
// Services
// ---------------------------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI with 3‑D visualization, data logging and reporting"
    DTDFVocab:provides RealTimeVisualizationInsight, PostRunReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC computation from PT to DT"
    DTDFVocab:provides ACCDecisionInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enables/disables ACC, modifies set‑point speed, issues emergency brake"
    DTDFVocab:provides ACCParameterAdjustmentAction, EmergencyBrakeAction
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generates time‑series CSV reports stored in external SQL database"
    DTDFVocab:provides PostRunReportInsight
]

// ---------------------------------------------------
// Insights & Actions
// ---------------------------------------------------
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Operator receives real‑time 3‑D visualization of vehicle state and surrounding tracks"
]

instance PostRunReportInsight : DTDFVocab:Insight [
    base:desc "Operator can view post‑run CSV reports summarizing vehicle and track data"
]

instance ACCDecisionInsight : DTDFVocab:Insight [
    base:desc "ACC algorithm output indicating desired speed and following distance"
]

instance ACCParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Remote adjustment of ACC set‑point speed or enable/disable ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issuing an emergency brake command to the physical twin"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Transmission of desired speed set‑points, ACC enable/disable commands, emergency‑brake signals, and actuation commands (motor voltage, steering adjustments) from the Digital Twin Entity to the Physical Twin via the Actuation Functional Entity and a Wi‑Fi link."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in real‑time with an end‑to‑end network latency bounded to ≤100 ms (requirement R7) and all DTS components maintain clock synchronization within 100 ms (requirement R8), ensuring that data collection, control computation and actuation occur within a single perception cycle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An entity‑based architecture derived from ISO 23247 comprising a Physical Twin Entity (sensor/actuator layer), a Digital Twin Entity (data collection, processing, ACC control, reporting), a User Entity (UI and control panel), and a Cross‑System Data Translation Entity, interconnected via ROS 2 intra‑entity and Wi‑Fi inter‑entity links."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Safety‑critical ACC functionality follows ISO 15622 specifications; latency ≤100 ms and clock sync ≤100 ms are enforced to maintain real‑time fidelity; tracking accuracy relies on DBSCAN clustering and Kalman filtering, and physical‑to‑virtual data is timestamped for consistency."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Standardized communication interfaces realized with ROS 2 topics/services within the vehicle and Wi‑Fi (IEEE 802.11) for off‑board communication; the Data Translation FE handles message serialization and unit conversion across entities."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the on‑board NVIDIA Jetson Orin Nano; Digital Twin Entity and Data Translation Entity are hosted on an external compute platform (e.g., cloud or workstation) reachable via Wi‑Fi; User Entity UI runs on a separate PC."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adopts ISO 23247 (Digital Twin Manufacturing Framework) for architectural guidance, ISO 15622 for ACC functional requirements, ISO/IEC 30173:2023 for digital‑twin terminology, and 3GPP TS 22.185 for latency benchmarks; OPC UA is mentioned as an optional communication standard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations include adherence to ISO 15622 ACC specifications, enforced network latency ≤100 ms, and clock synchronization ≤100 ms to ensure deterministic control; explicit cybersecurity mechanisms are not described in the document."
]