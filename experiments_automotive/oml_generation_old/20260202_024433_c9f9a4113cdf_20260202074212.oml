// ------------------------------
// Physical Sensing Components
// ------------------------------
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST10LX LiDAR acquiring 3D point clouds"
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance DepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel D435i depth camera providing RGB‑D imagery"
    DTDFVocab:producedData DepthImageTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑state sensors collecting speed and steering angle"
    DTDFVocab:producedData VehicleTelemetryTransmitted
]

instance ProximitySensor : DTDFVocab:SensingComponent [
    base:desc "Proximity object‑detection sensors embedded on the vehicle"
    DTDFVocab:producedData ObjectTrackTransmitted
]

// ------------------------------
// Data Transmitted
// ------------------------------
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DepthCameraSensor
]

instance VehicleTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance ObjectTrackTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProximitySensor
]

// ------------------------------
// Data
// ------------------------------
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Serialized LiDAR point cloud data, unit‑converted by the Data Translation FE"
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataAnalysisEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image data from Intel D435i, serialized and unit‑converted"
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo DataAnalysisEnabler
]

instance VehicleTelemetryData : DTDFVocab:Data [
    base:desc "Speed and steering telemetry, serialized and unit‑converted by the Data Translation FE"
    DTDFVocab:fromData VehicleTelemetryTransmitted
    DTDFVocab:inputTo ComputationOffloadingEnabler,
                    ReportGenerationEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Object tracking data derived from LiDAR and depth imagery"
    DTDFVocab:fromData ObjectTrackTransmitted
    DTDFVocab:inputTo DataAnalysisEnabler
]

// ------------------------------
// Models / Data
// ------------------------------
instance ACCControlModel : DTDFVocab:Model [
    base:desc "ISO 15622 ACC control model computing distance‑based desired speed"
    DTDFVocab:inputTo ComputationOffloadingEnabler
]

instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point‑cloud data"
    DTDFVocab:inputTo DataAnalysisEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter tracking of detected objects"
    DTDFVocab:inputTo DataAnalysisEnabler
]

instance ReportGenerationModel : DTDFVocab:Model [
    base:desc "Generates time‑series CSV reports of vehicle telemetry"
    DTDFVocab:inputTo ReportGenerationEnabler
]

// ------------------------------
// Enablers
// ------------------------------
instance DataCollectionEnabler : DTDFVocab:Enabler [
    base:desc "Data Collection Facing Entity gathering speed, steering, and object tracks from the vehicle"
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for remote ACC logic execution on edge/cloud"
    DTDFVocab:enables ComputationOffloadingService
]

instance DeviceControlEnabler : DTDFVocab:Enabler [
    base:desc "Device Control Entity for actuating speed controller and steering servo"
    DTDFVocab:enables RemoteManagementService
]

instance DataAnalysisEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for clustering, tracking, and visualization analyses on the Digital Twin"
    DTDFVocab:enables VisualizationService
]

instance ReportGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for CSV report generation from telemetry data"
    DTDFVocab:enables ReportGenerationService
]

// ------------------------------
// Services
// ------------------------------
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI displaying vehicle state, object tracks, projected path, and report generation"
    DTDFVocab:provides VehicleStateInsight, ObjectHeatMapInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Remote execution of ACC logic on edge/cloud, returning desired speed"
    DTDFVocab:provides ACCSpeedInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI for remote enable/disable of ACC, desired speed adjustment, and emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustDesiredSpeedAction, EmergencyBrakeAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D rendering of vehicle and environment, including object heat‑maps"
    DTDFVocab:provides Rendering3DInsight, ObjectHeatMapInsight
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generates time‑series CSV reports of vehicle telemetry"
    DTDFVocab:provides ReportInsight
]

// ------------------------------
// Insights
// ------------------------------
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time vehicle speed and steering angle trends"
]

instance ObjectHeatMapInsight : DTDFVocab:Insight [
    base:desc "Heat‑map of detected objects around the vehicle"
]

instance ACCSpeedInsight : DTDFVocab:Insight [
    base:desc "Computed desired speed from ACC control model"
]

instance ReportInsight : DTDFVocab:Insight [
    base:desc "CSV report of vehicle telemetry time‑series"
]

instance Rendering3DInsight : DTDFVocab:Insight [
    base:desc "3D rendering of vehicle, surroundings, and tracked objects"
]

// ------------------------------
// Actions
// ------------------------------
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disables Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Adjusts desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Triggers emergency braking via Control Panel UI"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT issues control commands through the Data Collection and Device Control Entity: desired speed setpoints transmitted to the Victor speed controller, steering commands to the servo, enable/disable and emergency brake flags, all routed via ROS 2 topics over Wi‑Fi to the PT’s hardware interfaces."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All sensing and actuation updates occur in real‑time at the sensor perception cycle (LiDAR typically 10–15 Hz, camera 30 Hz) with end‑to‑end network latency capped at 100 ms as required by the DTS, ensuring that the DT’s control updates remain within the 100 ms window between vehicle and DT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates ROS 2 packages (e.g., Data Collection, Acc, User Interface) mapped to ISO 23247 Functional Entities, connected via intra-entity ROS 2 topics and inter‑entity Wi‑Fi communication. The Cross‑System Entity (Data Translation FE) normalizes data formats across entities, while the Physical Twin Entity bridges vehicle hardware to the Digital Twin Entity, and the User Entity exposes the 3D visualization and control panel to operators."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT operates in the ‘operated’ stage of the PT lifecycle: it is instantiated during runtime after the vehicle has been manufactured and deployed. It does not cover the design or manufactured representation stage, as the DT reflects the operational behavior of the physical twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured through real‑time linkage to high‑frequency sensors, rigorous clock synchronization (≤100 ms), and adherence to ISO 15622 for ACC behavior. Validation relies on simulation‑based round‑trips (operator reports and telemetry) and manual monitoring of safety‑critical metrics. Uncertainty analysis is implicit in the use of Kalman‑filter tracking and sensor noise models, though explicit V&V procedures are not detailed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication utilizes Wi‑Fi (likely 5 GHz) transmitting ROS 2 topics over DDS; intra‑entity communication relies on the ROS 2 middleware stack on the vehicle’s Jetson Orin Nano and on edge/cloud hosts, leveraging UDP multicast for low‑latency data exchange."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT runtime is distributed across the vehicle’s Jetson Orin Nano (handling point‑cloud clustering, tracking, and actuation) and an external edge/cloud server (handling ACC computation and UI rendering). The hosting platform uses the NVIDIA Jetpack SDK on the embedded system and standard cloud compute instances for the DT services."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT architecture follows the ISO 23247 Digital Twin Manufacturing Framework reference architecture, applies the ISO 15622 standard for ACC control, and leverages the ROS 2 middleware (DDS) and NVIDIA Jetpack SDK, all of which are standard industry artifacts."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety requirements include an end‑to‑end latency cap of 100 ms and alignment with ISO 15622, ensuring that remotely issued ACC commands do not violate safety constraints. No explicit cybersecurity measures are described, but the system’s ISO compliance and use of standardized protocols (DDS) provide a baseline for secure communication."
]