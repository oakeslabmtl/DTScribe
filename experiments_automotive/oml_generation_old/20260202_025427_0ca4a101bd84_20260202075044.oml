// Sensing Components
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing continuous 3D point‑clouds for vehicle perception."
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance IntelRealSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering depth image frames for visual perception."
    DTDFVocab:producedData DepthImageFrameTransmitted
]

instance WheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel‑speed sensor feeding ego speed values to the Data Collection FE."
    DTDFVocab:producedData EgoSpeedTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor providing steering angle messages to the Data Collection FE."
    DTDFVocab:producedData SteeringAngleTransmitted
]

instance SpeedControllerInterface : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑state interface from the electronic speed controller supplying status reports."
    DTDFVocab:producedData VehicleStateTransmitted
]

// Data Transmitted
instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthImageFrameTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCamera
]

instance EgoSpeedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedSensor
]

instance SteeringAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SpeedControllerInterface
]

// Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data used for clustering and tracking."
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo DataTranslationFE, AccControlFE, ReportGenerationFE
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames used for object detection and tracking."
    DTDFVocab:fromData DepthImageFrameTransmitted
    DTDFVocab:inputTo DataTranslationFE, AccControlFE, ReportGenerationFE
]

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Vehicle ego speed measurements."
    DTDFVocab:fromData EgoSpeedTransmitted
    DTDFVocab:inputTo DataTranslationFE, AccControlFE, ReportGenerationFE
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Vehicle steering angle measurements."
    DTDFVocab:fromData SteeringAngleTransmitted
    DTDFVocab:inputTo DataTranslationFE, AccControlFE, ReportGenerationFE
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state information from the speed controller."
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo DataTranslationFE, AccControlFE, ReportGenerationFE
]

// Enablers
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Serializes, performs unit conversions, and publishes ROS2 messages; enables monitoring, visualization, and reporting services."
    DTDFVocab:enables DataMonitoringService, VisualizationService, ReportingService
]

instance AccControlFE : DTDFVocab:Enabler [
    base:desc "ACC controller executed on the cloud; handles offloading and remote management."
    DTDFVocab:enables ComputationOffloadingService, RemoteManagementService
]

instance ReportGenerationFE : DTDFVocab:Enabler [
    base:desc "Generates human‑readable reports and SQL exports for maintenance and performance analysis."
    DTDFVocab:enables ReportingService
]

instance ActuationFE : DTDFVocab:Enabler [
    base:desc "Transmits control commands over Wi‑Fi to the Jetson GPIO for throttle, steering, and braking."
    DTDFVocab:enables RemoteManagementService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time viewer of vehicle speed, steering angle, and surrounding object tracks."
    DTDFVocab:provides SpeedInsight, SteeringAngleInsight, ObjectTrackInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Acc computation offloaded to the cloud, returning desired speed."
    DTDFVocab:provides DesiredSpeedCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote UI commands to enable/disable ACC, adjust desired speed, and trigger emergency braking."
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, TriggerEmergencyBrakeAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D rendering of vehicle, projected path, and tracked objects."
    DTDFVocab:provides VehicleVisualizationInsight, PathVisualizationInsight
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Generates human‑readable reports and exports time‑series SQL data."
    DTDFVocab:provides MaintenanceReportInsight, PerformanceDashboardInsight
]

// Insights
instance SpeedInsight : DTDFVocab:Insight [
    base:desc "Insight into real‑time vehicle speed for monitoring and tuning."
]

instance SteeringAngleInsight : DTDFVocab:Insight [
    base:desc "Insight into real‑time steering angle for monitoring and steering control."
]

instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Insight into tracked surrounding objects for safety assessment."
]

instance VehicleVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing a 3D visual representation of vehicle dynamics."
]

instance PathVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight of projected vehicle path for driver information."
]

instance MaintenanceReportInsight : DTDFVocab:Insight [
    base:desc "Insight providing predictive maintenance reports of brake systems."
]

instance PerformanceDashboardInsight : DTDFVocab:Insight [
    base:desc "Insight providing performance dashboards of speed, lead distance, and desired speed over time."
]

// Actions
instance DesiredSpeedCommandAction : DTDFVocab:Action [
    base:desc "Command to set desired speed returned by the ACC algorithm."
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Command to enable or disable the adaptive cruise control."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Command to adjust the desired speed manually."
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Command to trigger emergency braking."
    DTDFVocab:IsAutomatic false
]

instance ThrottleCommandAction : DTDFVocab:Action [
    base:desc "Throttle command sent to the vehicle’s electronic speed controller."
    DTDFVocab:IsAutomatic true
]

instance SteeringServoCommandAction : DTDFVocab:Action [
    base:desc "Steering servo command for lane keeping."
    DTDFVocab:IsAutomatic true
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Emergency braking command to actuate the vehicle’s braking system."
    DTDFVocab:IsAutomatic true
]

// Acting Components
instance ThrottleActuator : DTDFVocab:ActingComponent [
    base:desc "Throttle actuator receiving throttle commands from the Digital Twin via Wi‑Fi."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator receiving steering commands from the Digital Twin via Wi‑Fi."
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency brake actuator receiving emergency brake commands from the Digital Twin via Wi‑Fi."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Outputs from the Digital Twin, such as desired speed command, steering angle command, and ACC enable/disable signals, are published on the ROS 2 network and delivered to the PT via the Data Translation FE over Wi‑Fi. The actuator FEs on the PT convert these high‑level commands into motor voltage commands, steering servo PWM signals, or brake regulator signals, which directly control the vehicle’s hardware."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near‑real‑time operations with a maximum end‑to‑end latency of 100 ms between the PT and the Digital Twin. Data streams are sampled at the sensor frequencies (LiDAR at ~10 Hz, depth camera at ~6 Hz, vehicle‑state at 50‑100 Hz) and synchronized by the Data Translation FE with a clock accuracy of ≤ 100 ms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellation is an entity‑based architecture following ISO 23247: Physical Twin Entity hosts sensors and actuation, Digital Twin Entity hosts data collection, ACC computation, reporting; User Entity hosts 3D visualization and control panel; Cross‑System Entity implements Data Translation. ROS 2 message passing over Wi‑Fi connects these entities, forming a decentralized, real‑time orchestrated system."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the operation stage of the vehicle’s lifecycle; it monitors a manufactured 1/10‑scale PT (manufacturing stage) and provides active runtime services during operation. The system is not used during design or design validation, thus focusing on manufactured and operational stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through Kalman‑filter state‑estimation and DBSCAN clustering on raw LiDAR, which are validated against ground‑truth from manual inspection. ACC control complies with ISO 15622 safety levels, guaranteeing deterministic behavior. Data translation applies unit conversion and timestamp alignment to preserve temporal integrity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication uses ROS 2 DDS over Wi‑Fi (UDP/TCP). The PT‑DT link is a 5 GHz Wi‑Fi network; the vehicle’s Jetson publishes LiDAR and vehicle‑state topics and subscribes to actuation topics. The cloud ACC server communicates via secure MQTT or gRPC over TLS. Data Translation FE serializes messages into binary DDS payloads."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical hosting occurs on an NVIDIA Jetson Orin Nano installed in the vehicle, with additional ROS 2 nodes deployed on a cloud server (e.g., AWS EC2 GPU instance) for ACC computation. The User UI runs on an operator workstation (Windows/Linux) connected over the same Wi‑Fi LAN, or accessible via secure web interface. All nodes can be containerized with Docker or run natively on the target OS."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (RA) for entity–FE mapping, uses ISO 15622 (ACC control), ISO 30173 (concepts & terminology) for terminology, and IEC 62541 (OPC UA) where applicable. ROS 2 (DDS) adheres to MISRA‑C++ and ISO 14379. Firmware on Jetson uses NVIDIA JetPack 5.0 which complies with ISO 13849 for medical devices and ISO 26262 for automotive safety, providing baseline safety assurance."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The system is safety‑critical; operations are bound by a 100 ms latency threshold derived from 3GPP 22.185 V2V standards. The Digital Twin enforces command validation and timestamp checks to prevent stale commands and incorporates ISO 15622 safety rules for ACC. However, explicit cybersecurity measures (auth, encryption) are not detailed in the document."
]