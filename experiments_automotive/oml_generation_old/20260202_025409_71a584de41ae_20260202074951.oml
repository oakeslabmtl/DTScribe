// C3: Physical sensing components
instance HokuyoLidarSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST110LX LiDAR for point‑cloud acquisition"
    DTDFVocab:producedData LiDARPointCloudDataTransmission
]
instance DeepSenseD435iCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera for visual sensing"
    DTDFVocab:producedData DepthImageDataTransmission
]
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed measurement from onboard odometry"
    DTDFVocab:producedData VehicleSpeedDataTransmission
]
instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle measurement from steering controller"
    DTDFVocab:producedData SteeringAngleDataTransmission
]

// C4: Physical-to-virtual interaction
instance LiDARPointCloudDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLidarSensor
]
instance DepthImageDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DeepSenseD435iCamera
]
instance VehicleSpeedDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]
instance SteeringAngleDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C10: Models/Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud before clustering"
    DTDFVocab:fromData LiDARPointCloudDataTransmission
    DTDFVocab:inputTo ClusteringEnabler
]
instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image from D435i camera"
    DTDFVocab:fromData DepthImageDataTransmission
    DTDFVocab:inputTo TrackingEnabler
]
instance VehicleSpeedRawData : DTDFVocab:Data [
    base:desc "Vehicle speed value sampled from odometry"
    DTDFVocab:fromData VehicleSpeedDataTransmission
    DTDFVocab:inputTo AccComputationEnabler
]
instance SteeringAngleRawData : DTDFVocab:Data [
    base:desc "Steering angle value sampled from steering controller"
    DTDFVocab:fromData SteeringAngleDataTransmission
    DTDFVocab:inputTo AccComputationEnabler
]

instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering model processes LiDAR point clouds to detect objects"
    DTDFVocab:inputTo AccComputationEnabler
]
instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter for object track estimation"
    DTDFVocab:inputTo AccComputationEnabler
]
instance ACCControllerModel : DTDFVocab:Model [
    base:desc "ISO 15622 compliant ACC controller for speed computation"
    DTDFVocab:inputTo AccComputationEnabler
]

// C11: Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Serializes, type‑aligns, and converts units for all data streams"
]
instance ClusteringEnabler : DTDFVocab:Enabler [
    base:desc "Enables DBSCAN clustering on LiDAR point clouds"
    DTDFVocab:enables ClusteringService
]
instance TrackingEnabler : DTDFVocab:Enabler [
    base:desc "Enables Kalman filter tracking on visual and LiDAR data"
    DTDFVocab:enables TrackingService
]
instance AccComputationEnabler : DTDFVocab:Enabler [
    base:desc "Enables ACC computation using speed, steering, and object tracks"
    DTDFVocab:enables ComputationOffloadingService
]

// C6: Services
instance ClusteringService : DTDFVocab:Service [
    base:desc "Provides clustered object insights from LiDAR data"
    DTDFVocab:provides ObjectTrackInsight
]
instance TrackingService : DTDFVocab:Service [
    base:desc "Provides estimated object tracks via Kalman filtering"
    DTDFVocab:provides ObjectTrackInsight
]
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computes desired speed profiles remotely using ISO 15622 controller"
    DTDFVocab:provides SpeedProfileInsight
]
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Continuous real‑time display of vehicle speed, steering, and tracks"
    DTDFVocab:provides SpeedProfileInsight
]
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, and issue emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "3‑D virtual cockpit visualizes vehicle state and surroundings"
    DTDFVocab:provides VirtualCockpitView
]
instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generates CSV/JSON time‑series reports of vehicle state and tracks"
    DTDFVocab:provides TimeSeriesReportInsight
]

// Definition of VirtualCockpitView insight
instance VirtualCockpitView : DTDFVocab:Insight [
    base:desc "3D virtual cockpit displaying vehicle state and surroundings"
]

// C17: Insights/Actions
instance SpeedProfileInsight : DTDFVocab:Insight [
    base:desc "Computed desired speed profile informing operator decisions"
]
instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Clustered and tracked object locations from LiDAR and camera data"
]
instance TimeSeriesReportInsight : DTDFVocab:Insight [
    base:desc "Human‑readable CSV/JSON reports of vehicle state and object tracks"
]
instance EgoOrientationInsight : DTDFVocab:Insight [
    base:desc "Vehicle’s current orientation derived from steering data"
]
instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator command to set a new desired speed for the ACC system"
    DTDFVocab:IsAutomatic false
]
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]
instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]
instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator command to initiate emergency braking"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT via the Actuation FE. Desired speed values computed by the ACC controller are published on a ROS2 topic and translated by the Data Translation FE into motor voltage commands, which are then sent to the Vedder speed controller. Remote management commands (enable/disable ACC, change desired speed, emergency braking) are also transmitted over Wi‑Fi to the vehicle’s control interface."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates at a real‑time frequency matching the vehicle’s perception cycle (≈10 Hz). End‑to‑end communication latency is required to be ≤100 ms, as specified by 3GPP TSP 22.185 for V2V. Clock synchronization among all DT components is maintained to within 100 ms tolerance using ROS2 time utilities."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation is organized around the ISO 23247 reference architecture, with each Functional Entity (FE) mapped to a ROS2 package. The Physical Twin Entity hosts data pre‑processing and actuation FE; the Digital Twin Entity aggregates data collection, reporting, ACC control, and presentation FEs; the User Entity hosts a 3‑D visualization FE and a UI control panel FE; Cross‑System Entity implements Data Translation FE for inter‑entity communication. ROS2 topics serve as the internal message bus, while Wi‑Fi provides the external connectivity."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle covers the Operated phase of the physical vehicle. Design and requirement gathering (R1–R8) are performed at the top of the development cycle; architecture and implementation are performed subsequently; no manufacturing or as‑built representation is discussed. The DT is considered a virtual representation of an operating, manufactured vehicle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT’s fidelity is ensured by using validated clustering (DBSCAN) and tracking (Kalman filter) algorithms, an ISO 15622 ACC controller, and unit consistency via the Data Translation FE. Verification is performed by comparing DT outputs (vehicle speed, steering, track predictions) against ground truth from the PT; validation includes latency tests to confirm the 100 ms bound. Uncertainty in sensor data is mitigated via filtering, but explicit probabilistic error modeling is not described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication occurs over a standard Wi‑Fi network using the ROS2 communication stack. ROS2 nodes publish/subscribe on topics with DDS as the underlying transport, typically using UDP/TCP. The Data Translation FE handles serialization and unit conversion. Overall end‑to‑end latency is bounded by the 3GPP TSP 22.185 specification for V2V (≤100 ms)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity is deployed on a remote edge server (cloud or edge) accessible via Wi‑Fi from the vehicle. The Physical Twin Entity resides on the vehicle’s Jetson Orin Nano. The User Entity runs on a user workstation or a browser‑based interface hosted on a local server. All components are packaged as ROS2 nodes and containerized where appropriate."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system follows ISO 23247 (digital twin manufacturing framework) for architecture and entity mapping, ISO 15622 for ACC control logic, and ISO 30173 for terminology. It also employs ROS2 as the middleware standard and NVIDIA JetPack 5.0 for software stacks."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed for a safety‑critical automotive system; requirements specify a maximum latency of 100 ms and 100 ms clock synchronization for safe operation. No explicit cybersecurity protocols, authentication mechanisms, or fail‑safe architectures are described in the document."
]