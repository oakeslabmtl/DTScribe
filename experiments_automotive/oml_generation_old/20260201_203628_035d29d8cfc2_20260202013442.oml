// =========================
// 1. Sensing Components
// =========================
instance HokuyoUST10LXLidarSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing raw point clouds for environment perception."
    DTDFVocab:producedData LiDARPointCloudStream
]

instance IntelRealSenseD435iDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D frames."
    DTDFVocab:producedData DepthCameraFrameStream
]

instance EgoVehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring ego vehicle speed."
    DTDFVocab:producedData VehicleSpeedStream
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring steering angle."
    DTDFVocab:producedData SteeringAngleStream
]

// =========================
// 2. Data Transmitted
// =========================
instance LiDARPointCloudStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidarSensor
]

instance DepthCameraFrameStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseD435iDepthCameraSensor
]

instance VehicleSpeedStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoVehicleSpeedSensor
]

instance SteeringAngleStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance ObjectTracksStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidarSensor, IntelRealSenseD435iDepthCameraSensor, EgoVehicleSpeedSensor, SteeringAngleSensor
]

// =========================
// 3. Data Assets
// =========================
instance RawLiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud data as received from the sensor."
    DTDFVocab:fromData LiDARPointCloudStream
    DTDFVocab:inputTo DataCollectingFunctionalEntity
]

instance DepthCameraFrameData : DTDFVocab:Data [
    base:desc "Depth camera RGB‑D frames collected in real time."
    DTDFVocab:fromData DepthCameraFrameStream
    DTDFVocab:inputTo DataCollectingFunctionalEntity
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Ego vehicle speed measurements."
    DTDFVocab:fromData VehicleSpeedStream
    DTDFVocab:inputTo DataCollectingFunctionalEntity
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle measurements."
    DTDFVocab:fromData SteeringAngleStream
    DTDFVocab:inputTo DataCollectingFunctionalEntity
]

instance ProcessedObjectTracksData : DTDFVocab:Data [
    base:desc "Object tracks derived from LiDAR, camera and vehicle state after DBSCAN clustering and Kalman filtering."
    DTDFVocab:fromData ObjectTracksStream
    DTDFVocab:inputTo ObjectTrackingFunctionalEntity, ACCAlgorithmFunctionalEntity
]

instance VehicleStateTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of vehicle state (speed, steering) stored for reporting."
    DTDFVocab:fromData VehicleSpeedStream, SteeringAngleStream
    DTDFVocab:inputTo VisualizationFunctionalEntity, RemoteManagementFunctionalEntity
]

// =========================
// 4. Models
// =========================
instance DBSCANKalmanTrackerModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering module combined with a Kalman‑filter tracker for point‑cloud based object tracking."
    DTDFVocab:inputTo ObjectTrackingFunctionalEntity
]

instance ACCModelISO15622 : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model compliant with ISO 15622 for lead‑vehicle detection and speed set‑point generation."
    DTDFVocab:inputTo ACCAlgorithmFunctionalEntity
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model used to render vehicle state, projected path and object tracks in the UI."
    DTDFVocab:inputTo VisualizationFunctionalEntity
]

// =========================
// 5. Enablers (Functional Entities)
// =========================
instance DataCollectingFunctionalEntity : DTDFVocab:Enabler [
    base:desc "ROS 2 node responsible for gathering raw sensor streams."
    DTDFVocab:enables ComputationOffloadingService, DataMonitoringService
]

instance DataTranslationFunctionalEntity : DTDFVocab:Enabler [
    base:desc "ROS 2 node that performs unit conversion and message alignment."
    DTDFVocab:enables ComputationOffloadingService
]

instance ObjectTrackingFunctionalEntity : DTDFVocab:Enabler [
    base:desc "Functional entity that runs DBSCAN‑Kalman tracking on processed point clouds."
    DTDFVocab:enables ComputationOffloadingService
]

instance ACCAlgorithmFunctionalEntity : DTDFVocab:Enabler [
    base:desc "ACC ROS 2 node executing the ISO‑15622 algorithm to generate speed set‑points."
    DTDFVocab:enables RemoteManagementService, ComputationOffloadingService
]

instance RemoteManagementFunctionalEntity : DTDFVocab:Enabler [
    base:desc "ROS 2 node exposing commands for ACC enable/disable, set speed and emergency braking."
    DTDFVocab:enables RemoteManagementService
]

instance VisualizationFunctionalEntity : DTDFVocab:Enabler [
    base:desc "ROS 2 node providing 3‑D visualizations and report generation for the UI."
    DTDFVocab:enables DataMonitoringService
]

// =========================
// 6. Services
// =========================
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time UI visualizations of vehicle state, projected path and object tracks, and generates reports."
    DTDFVocab:provides SituationalAwarenessInsight, FaultAnalysisInsight, ParameterTuningInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes computationally intensive ACC algorithm off‑board, delivering lead‑vehicle detection and speed set‑points."
    DTDFVocab:provides AdjustACCSetpointAction, EnableACCAction, DisableACCAction, SetDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to remotely command ACC enable/disable, set desired speed, or trigger emergency braking."
    DTDFVocab:provides EmergencyBrakingAction, AdjustACCSetpointAction
]

// =========================
// 7. Insights
// =========================
instance SituationalAwarenessInsight : DTDFVocab:Insight [
    base:desc "Operators gain situational awareness through real‑time UI visualizations and reports."
]

instance FaultAnalysisInsight : DTDFVocab:Insight [
    base:desc "Developers use collected data for fault analysis."
]

instance ParameterTuningInsight : DTDFVocab:Insight [
    base:desc "Developers use collected data for parameter tuning of models."
]

// =========================
// 8. Actions
// =========================
instance AdjustACCSetpointAction : DTDFVocab:Action [
    base:desc "Adjust ACC speed set‑point via remote command."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Trigger emergency braking from UI."
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set desired speed for ACC."
    DTDFVocab:IsAutomatic false
]

// =========================
// 9. Acting Components
// =========================
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage command interface via the electronic speed controller."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo driven by the actuation functional entity."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT, including desired speed values for the motor controller, enable/disable ACC commands, emergency‑brake signals, and steering adjustments. These commands are issued by the Controlling FE (ACC) and the User Interface FE and executed by the Actuation FE on the vehicle."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is required to maintain end‑to‑end network latency ≤ 100 ms (R7) and clock synchronization accuracy of 100 ms across all DTS components (R8), ensuring real‑time operation of ACC offloading and remote control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of the Physical Twin Entity (on‑board Jetson/NVIDIA hardware), the Digital Twin Entity (hosted on external compute and containing Data Collecting, Controlling, Reporting, and Presentation FEs), the User Entity (UI with 3‑D visualization and control panel), and a Cross‑System Data Translation FE that mediates data exchange across entities via ROS 2 and Wi‑Fi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT operates primarily in the operational stage of the vehicle lifecycle, providing real‑time monitoring, control, and off‑board computation during vehicle use; it is also used during development for troubleshooting and validation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by meeting a ≤ 100 ms latency budget and clock sync of 100 ms, using high‑fidelity sensor data (LiDAR, depth camera) and validated tracking (DBSCAN + Kalman). Safety‑critical compliance follows ISO 15622 for ACC functionality, and real‑time constraints are strictly enforced to avoid control divergences."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication uses ROS 2 over a Wi‑Fi network (IEEE 802.11), with DDS handling publish/subscribe messaging. The Data Translation FE serializes and normalizes messages, and optional OPC UA could be employed for standardized data exchange (mentioned as a possible implementation)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin Entity and its services are hosted on external compute hardware (e.g., a workstation or cloud instance) separate from the vehicle’s on‑board Jetson NX/Orin Nano. The User Entity runs on a user workstation, while the Physical Twin Entity resides on the vehicle."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture conforms to ISO 23247 (Digital Twin Manufacturing Framework) reference architecture, utilizes ISO 15622 for ACC functionality, references ISO/IEC 30173 for digital‑twin terminology, and mentions optional use of OPC UA (IEC 62541) for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety considerations are highlighted by the requirement for ≤ 100 ms latency and synchronized clocks to ensure deterministic control. The DT implements remote emergency braking and ACC enable/disable commands, adhering to ISO 15622 safety requirements. No explicit cybersecurity mechanisms are described in the document."
]