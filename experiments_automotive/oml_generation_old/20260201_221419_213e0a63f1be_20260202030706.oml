// C3: Physical sensing components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing 2‑D point clouds for environment perception"
    DTDFVocab:producedData LiDARPointCloudTransmission
]

instance IntelRealSenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D images"
    DTDFVocab:producedData DepthImageTransmission
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board longitudinal speed sensor measuring vehicle speed"
    DTDFVocab:producedData VehicleSpeedTransmission
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor reporting vehicle heading"
    DTDFVocab:producedData SteeringAngleTransmission
]

// C4: Physical-to-virtual interaction (Data Transmission)
instance LiDARPointCloudTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]

instance DepthImageTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseDepthCamera
]

instance VehicleSpeedTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance SteeringAngleTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// C10: Data definitions
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Timestamped 2‑D LiDAR point‑cloud tracks"
    DTDFVocab:fromData LiDARPointCloudTransmission
    DTDFVocab:inputTo ROS2MiddlewareEnabler, TrackingProcessingEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames with associated timestamps"
    DTDFVocab:fromData DepthImageTransmission
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Longitudinal speed measurements (m/s) with timestamps"
    DTDFVocab:fromData VehicleSpeedTransmission
    DTDFVocab:inputTo ROS2MiddlewareEnabler, ACCComputationEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle values (rad) with timestamps"
    DTDFVocab:fromData SteeringAngleTransmission
    DTDFVocab:inputTo ROS2MiddlewareEnabler, ACCComputationEnabler
]

// C10: Model definitions
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm used for separating object point‑clouds"
    DTDFVocab:inputTo TrackingProcessingEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman filter for continuous object tracking across frames"
    DTDFVocab:inputTo TrackingProcessingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control control model conforming to ISO 15622 performance class I"
    DTDFVocab:inputTo ACCComputationEnabler
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model rendering vehicle state and predicted paths"
    DTDFVocab:inputTo UIVisualizationEnabler
]

// C11: Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS 2 middleware (Python 3.8 / C++) for topic‑based communication over Wi‑Fi"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance TrackingProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing node (MATLAB/Simulink) executing DBSCAN and Kalman filter for object tracking"
    DTDFVocab:enables ComputationOffloadingService
]

instance ACCComputationEnabler : DTDFVocab:Enabler [
    base:desc "C++ node running the ACC algorithm on the Digital Twin compute node"
    DTDFVocab:enables ComputationOffloadingService
]

instance UIVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Qt/ OpenGL based UI presenting real‑time vehicle state, tracks and projected paths"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database storing timestamped object tracks, vehicle speed, steering angle and reports"
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualizes real‑time vehicle state, object tracks, and projected path"
    DTDFVocab:provides RealTimeStateInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm (lead‑vehicle detection & speed computation) runs on the Digital Twin instead of on‑board ECU"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustSpeedSetpointAction, EmergencyBrakingAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, adjust speed set‑points, and trigger emergency braking via UI"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustSpeedSetpointAction, EmergencyBrakingAction
]

// C17: Insights/Actions
instance RealTimeStateInsight : DTDFVocab:Insight [
    base:desc "Operators gain situational awareness from live visualization of vehicle state and predicted trajectories"
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control on the physical twin"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control on the physical twin"
    DTDFVocab:IsAutomatic false
]

instance AdjustSpeedSetpointAction : DTDFVocab:Action [
    base:desc "Adjust the target speed set‑point for the ACC controller"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Trigger emergency braking on the physical twin"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT via ROS 2 over the same Wi‑Fi link. Commands include desired speed values (converted to motor voltage by the Actuation FE), ACC enable/disable signals, speed‑setpoint updates, and emergency‑brake commands issued from the User Interface FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is engineered to maintain end‑to‑end communication latency ≤ 100 ms (per 3GPP TS 22.185) and clock synchronization accuracy of 100 ms across all DT components, enabling real‑time ACC control loops synchronized with the PT perception cycle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation orchestrates the Physical Twin Entity, Digital Twin Entity, User Entity, and Cross‑System Entity. Intra‑entity communication uses ROS 2 topics; inter‑entity data exchange occurs over Wi‑Fi with the Data Translation FE handling serialization and unit conversion."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during the design and testing phase as a cyber‑physical experimentation platform and throughout operation for monitoring, control, and remote management of the PT, reflecting both development‑time and run‑time life‑cycle stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by using high‑resolution LiDAR data and validated DBSCAN/Kalman tracking; ACC behavior follows ISO 15622 specifications. Latency ≤ 100 ms and clock sync ≤ 100 ms guarantee temporal fidelity, while safety‑critical constraints are respected by limiting ACC to performance class I on the scale vehicle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual and virtual‑to‑physical data exchange uses a Wi‑Fi network with ROS 2 communication. The Data Translation FE serializes messages and performs unit conversion; optional OPC UA (IEC 62541) could be used for data translation but is not required in this implementation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the Jetson Orin Nano mounted in the vehicle. The Digital Twin Entity executes on an external compute platform (e.g., cloud server or desktop PC). The User Entity resides on an operator workstation displaying the UI and control panel."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) reference architecture, uses ISO 15622 for ACC functionality, references ISO/IEC 30173:2023 for twin concepts, and mentions optional OPC UA (IEC 62541) for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by adhering to ISO 15622 ACC specifications, enforcing a maximum 100 ms latency, and requiring clock synchronization within 100 ms. Remote commands include an emergency‑brake function to mitigate hazards. No explicit cybersecurity mechanisms are described in the document."
]