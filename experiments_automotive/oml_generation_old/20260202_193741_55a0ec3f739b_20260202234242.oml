// C2: Acting Components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller for motor management with torque limits and closed-loop control feedback via Kalman filter. Interfaces with Digital Twin Entity through ROS2 middleware for remote actuation."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Directional actuation component with servo response times for autonomous vehicle steering. Integrated with Digital Twin Entity via ROS2 for closed-loop control."
]

// C3: Physical Sensing Components
instance HokuyoUST10LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "High-resolution 360-degree omnidirectional LiDAR sensor providing 1D/2D point cloud data with sub-millimeter accuracy. Samples transmitted via ROS2 middleware to Data Collection Functional Entities."
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "RGB-D depth camera offering 1080p resolution at 30Hz with ±3mm depth precision. Forward-facing sensor integrated with ROS2 for real-time data processing and object detection."
    DTDFVocab:producedData DepthCameraRGBDData, ObjectDetectionEvents
]

// C4: Physical-to-Virtual Interaction
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR
    base:desc "Raw 1D/2D point cloud data stream from Hokuyo UST-10LX LiDAR with 360-degree coverage, transmitted via ROS2 topics for real-time processing."
]

instance DepthCameraRGBDData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
    base:desc "RGB-D data stream from Intel Deepsense D435i camera at 1080p resolution and 30Hz frame rate, transmitted via ROS2 for spatial analysis."
]

instance VehicleStateTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDAR, IntelDeepsenseD435iDepthCamera
    base:desc "Continuous stream of vehicle state parameters including velocity, acceleration, and sensor inputs transmitted via UDP/Wi-Fi network for real-time monitoring."
]

instance ObjectDetectionEvents : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
    base:desc "Event-based data stream of object detection events (e.g., obstacle clustering) triggered by depth camera processing, transmitted via ROS2 for visualization updates."
]

// C10: Models/Data
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Kalman filter-based state estimation model for dynamic system tracking and DBSCAN clustering algorithm for raw LiDAR point cloud segmentation into structured object tracks."
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance VehicleStateEstimationModel : DTDFVocab:Model [
    base:desc "Dynamic system model for autonomous vehicle state estimation integrating sensor data (LiDAR, depth camera) with Kalman filter for real-time trajectory prediction."
    DTDFVocab:inputTo ControlOptimizationEnabler
]

instance ProcessedObjectTracksData : DTDFVocab:Data [
    DTDFVocab:fromData LiDARPointCloudData, DepthCameraRGBDData
    base:desc "Structured object tracks derived from raw sensor data through Point Cloud Clustering & Tracking Functional Entity, used for visualization and control decision-making."
    DTDFVocab:inputTo VisualizationEnabler, ControlDecisionEnabler
]

instance HistoricalTelemetryData : DTDFVocab:Data [
    DTDFVocab:fromData VehicleStateTelemetry
    base:desc "Structured historical telemetry data stored in SQL database for trend analysis, predictive maintenance, and anomaly detection."
    DTDFVocab:inputTo PredictiveMaintenanceEnabler
]

// C11: Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "Real-time middleware for inter-process communication between Physical Twin Entity sensors and Digital Twin Entity components, enabling modular processing of point cloud data and vehicle state telemetry."
    DTDFVocab:enables DataCollectionService, VisualizationService, ControlService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "High-fidelity simulation engine for dynamic system modeling, co-simulation with ROS2 for hybrid physical-digital testing, and trajectory optimization for autonomous vehicles."
