]

instance NVIDIAJetsonOrinNanoEnabler : DTDFVocab:Enabler [
    base:desc "Embedded AI accelerator for onboard perception processing (LiDAR data, depth camera streams) and real-time control execution (e.g., ACC logic) with 100ms latency."
