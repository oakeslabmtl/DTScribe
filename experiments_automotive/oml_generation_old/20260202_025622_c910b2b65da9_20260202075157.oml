// Sensing Components
instance HokuyoLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST110LX LiDAR for 3D point cloud detection"
    DTDFVocab:producedData LiDARPointCloudData
]
instance IntelDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera for RGB-D imaging"
    DTDFVocab:producedData DepthCameraImageData
]
instance WheelSpeedEncoder : DTDFVocab:SensingComponent [
    base:desc "Wheel speed encoder providing ego vehicle speed"
    DTDFVocab:producedData EgoSpeedData
]
instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor for servo position"
    DTDFVocab:producedData SteeringAngleData
]
instance IMUSensor : DTDFVocab:SensingComponent [
    base:desc "Inertial Measurement Unit for vehicle orientation"
    DTDFVocab:producedData IMUData
]

// Data Transmitted
instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDAR
]
instance DepthCameraImageData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCamera
]
instance EgoSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedEncoder
]
instance SteeringAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]
instance IMUData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IMUSensor
]

// Data
instance LiDARPointCloud : DTDFVocab:Data [
    base:desc "3D point cloud from Hokuyo UST110LX LiDAR sensor"
    DTDFVocab:inputTo DBSCANEnabler, KalmanFilterEnabler, DataTranslationFE
    DTDFVocab:fromData LiDARPointCloudData
]
instance DepthCameraImage : DTDFVocab:Data [
    base:desc "RGB-D image from Intel Deepsense D435i camera"
    DTDFVocab:inputTo KalmanFilterEnabler, DataTranslationFE
    DTDFVocab:fromData DepthCameraImageData
]
instance EgoSpeed : DTDFVocab:Data [
    base:desc "Ego vehicle speed measured by wheel speed encoder"
    DTDFVocab:inputTo ACCModelEnabler, DataTranslationFE, DataCollectionFE
    DTDFVocab:fromData EgoSpeedData
]
instance SteeringAngle : DTDFVocab:Data [
    base:desc "Steering servo angle measured by steering angle sensor"
    DTDFVocab:inputTo ACCModelEnabler, DataTranslationFE, DataCollectionFE
    DTDFVocab:fromData SteeringAngleData
]
instance IMUOrientation : DTDFVocab:Data [
    base:desc "Vehicle orientation from IMU sensor"
    DTDFVocab:inputTo DataTranslationFE, DataCollectionFE
    DTDFVocab:fromData IMUData
]

// Enablers
instance DBSCANEnabler : DTDFVocab:Enabler [
    base:desc "DBSCAN clustering module for point cloud preprocessing"
    DTDFVocab:enables DataMonitoringService
]
instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter based object-tracking estimator processing LiDAR and depth camera data"
    DTDFVocab:enables DataMonitoringService
]
instance ACCModelEnabler : DTDFVocab:Enabler [
    base:desc "ACC industrial control model defined by ISO 15622, generates control signals"
    DTDFVocab:enables ComputationOffloadingService
]
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Data Translation FE serializes, aligns, and unit-converts sensor streams"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService, VisualizationService, ReportingService
]
instance DataCollectionFE : DTDFVocab:Enabler [
    base:desc "Data Collection FE aggregates data for 3D visualization and report generation"
    DTDFVocab:enables VisualizationService, ReportingService
]
instance SQLLoggerFE : DTDFVocab:Enabler [
    base:desc "SQL-based data logger storing vehicle state and tracks"
    DTDFVocab:enables ReportingService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of speed, steering angle, object tracks, projected path and logging"
    DTDFVocab:provides RealTimeSpeedInsight, SteeringAngleInsight, ObjectTrackInsight, PathProjectionInsight, ReportInsight
]
instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC algorithm executed remotely to compute control signals"
    DTDFVocab:provides SendControlSignalAction
]
instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote UI for enabling/disabling ACC, setting desired speed, and emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, TriggerEmergencyBrakingAction
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "3D rendering of vehicle trajectory and surrounding object tracks"
    DTDFVocab:provides PathProjectionInsight
]
instance ReportingService : DTDFVocab:Service [
    base:desc "Time-series reporting stored in local SQL database"
    DTDFVocab:provides ReportInsight
]

// Insights
instance RealTimeSpeedInsight : DTDFVocab:Insight [
    base:desc "Displays real-time vehicle speed"
]
instance SteeringAngleInsight : DTDFVocab:Insight [
    base:desc "Displays real-time steering angle"
]
instance ObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Shows detected object tracks processed by Kalman filter"
]
instance PathProjectionInsight : DTDFVocab:Insight [
    base:desc "Visualizes projected path of vehicle in 3D space"
]
instance ReportInsight : DTDFVocab:Insight [
    base:desc "Provides summary of time-series reports stored in SQL database"
]

// Actions
instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enables ACC functionality via remote operator UI"
    DTDFVocab:IsAutomatic false
]
instance DisableACCAction : DTDFVocab:Action [
    base:desc "Disables ACC functionality via remote operator UI"
    DTDFVocab:IsAutomatic false
]
instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets desired speed for ACC via remote operator UI"
    DTDFVocab:IsAutomatic false
]
instance TriggerEmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Triggers emergency braking command via remote operator UI"
    DTDFVocab:IsAutomatic false
]
instance SendControlSignalAction : DTDFVocab:Action [
    base:desc "Sends control signals to motor and steering actuators"
    DTDFVocab:IsAutomatic false
]

// Acting Components
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage command interface to Vedder electric speed controller"
]
instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo command interface to vehicle steering servo"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity issues control commands such as ‘desired speed’, ‘enable/disable ACC’, ‘emergency brake’, and steering commands. These are sent over ROS2 topics to the Vehicle State Actuation FE, which translates them into motor voltage and steering servo commands. The commands are transmitted over the Wi‑Fi network (UDP) and executed by the vehicle’s ESC and steering actuator."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All real‑time data exchanges and control loops run at sub‑second rates: LiDAR point‑clouds processed at roughly 20 Hz, ego vehicle state updated at ≥10 Hz, ACC control synchronized with a 100 ms end‑to‑end latency budget and 100 ms clock synchronization accuracy to meet safety constraints."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is an entity‑based architecture derived from ISO 23247. The Physical Twin Entity hosts sensor data collection FE, the Digital Twin Entity hosts data collection, reporting, and ACC control FE, the User Entity hosts 3‑D visualization, control panel, and reporting FE, and a Cross‑System Entity hosts data‑translation. The entire constellation communicates over a ROS2 DDS network on Wi‑Fi, orchestrated by a central host that runs the UI modules."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin operates in the ‘operated’ phase, capturing real‑time state of the vehicle and applying ACC control. It also supports a ‘development/testing’ support role by providing remote monitoring and telemetry during test runs, but is not used for design or manufacturing modeling."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT uses a high‑fidelity ROS2 simulation framework, with DBSCAN clustering and Kalman tracking providing state estimation; ACC logic follows ISO 15622, ensuring compliance with safety standards. Validation is performed by comparing real‑time sensor data against sensor‑board ground truth; the SQL logger records data for post‑hoc verification. Clock synchronization within 100 ms ensures data consistency across distributed components."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The PT–DT link is a wireless RF connection: the vehicle’s on‑board ROS2 nodes publish topics over the vehicle’s Wi‑Fi network (IEEE‑802.11ac) using ROS2 DDS over UDP. Cross‑entity communication also uses the same Wi‑Fi link; the DT host (remote cloud) receives the data through the same ROS2 layer. No explicit VPN or encryption is mentioned; traffic remains local to vehicle network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT runs partly on the vehicle’s embedded NVIDIA Jetson Orin Nano (for data translation and lightweight processing) and partly on a remote cloud host (for ACC computation, reporting, and UI). The user interface runs on a workstation PC that connects via Wi‑Fi. All services are containerized as ROS2 packages, deployable on Ubuntu 20.04 running Jetpack 5.0, and on standard Linux servers for the cloud host."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture conforms to ISO 23247 (digital twin manufacturing framework), ISO 15622 (ACC control standard), and utilizes ROS2 DDS middleware, which follows DDS‑IETF specifications. Additional reference to ISO 30173:2023 for terminology is acknowledged in background."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT follows safety‑critical handling by adhering to the end‑to‑end latency constraint of 100 ms and clock synchronization within 100 ms, enabling accurate state ordering. Control commands are encoded in ROS2 DDS messages, and the ACC logic conforms to ISO 15622, improving safety. No specific cybersecurity mechanisms (encryption, authentication) are described, but the system is designed to avoid windows for human‑in‑the‑loop safety violations by ensuring low latency and synchronized timing."
]