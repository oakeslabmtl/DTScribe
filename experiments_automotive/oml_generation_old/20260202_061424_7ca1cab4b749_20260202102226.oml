// C3: Physical sensing components
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR that scans the environment for object detection."
    DTDFVocab:producedData LiDARDataTransmitted
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i Depth Camera that captures vehicle state and depth information."
    DTDFVocab:producedData DepthCameraDataTransmitted
]

instance SpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Speed sensor providing real‑time vehicle speed measurements."
    DTDFVocab:producedData SpeedDataTransmitted
]

instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor providing real‑time vehicle position data."
    DTDFVocab:producedData PositionDataTransmitted
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SpeedSensor
]

instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

// C10: Models/Data
instance LiDARData : DTDFVocab:Data [
    base:desc "Processed point cloud data from Hokuyo UST-10LX LiDAR."
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo DataCollectionDeviceControlFE
]

instance DepthCameraData : DTDFVocab:Data [
    base:desc "Depth images and point cloud data from Intel D435i camera."
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo DataCollectionDeviceControlFE
]

instance SpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed data from Speed Sensor."
    DTDFVocab:fromData SpeedDataTransmitted
    DTDFVocab:inputTo DataCollectionDeviceControlFE
]

instance PositionData : DTDFVocab:Data [
    base:desc "Vehicle position data from Position Sensor."
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo DataCollectionDeviceControlFE
]

instance VehicleChassisCADModel : DTDFVocab:Model [
    base:desc "Geometric CAD mesh model of the vehicle chassis."
    DTDFVocab:inputTo DataCollectionDeviceControlFE
]

instance KinematicDynamicsModel : DTDFVocab:Model [
    base:desc "Kinematic equations governing vehicle actuator dynamics."
    DTDFVocab:inputTo DataCollectionDeviceControlFE
]

instance ACCAdaptiveCruiseControlModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model that generates acceleration setpoints."
    DTDFVocab:inputTo DataCollectionDeviceControlFE
]

instance PerformanceMetricsModel : DTDFVocab:Model [
    base:desc "Performance metrics model including acceleration curves and energy consumption."
    DTDFVocab:inputTo DataCollectionDeviceControlFE
]

// C11: Enablers
instance DataCollectionDeviceControlFE : DTDFVocab:Enabler [
    base:desc "Data Collection & Device Control Entity handling sensor streams and device‑control interfaces."
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring service that displays real‑time vehicle state, projected driving path, and detected object tracks."
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTrackingInsight, AccelerationProfileInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation Offloading service that offloads ACC decision‑making to cloud servers."
    DTDFVocab:provides ACCDecisionAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service enabling operators to enable/disable ACC, set desired speed, and issue emergency braking commands."
    DTDFVocab:provides EnableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Provides real‑time visualizations of vehicle speed, position, and motion data."
]

instance ObjectTrackingInsight : DTDFVocab:Insight [
    base:desc "Displays tracked objects detected by LiDAR and depth camera sensors."
]

instance AccelerationProfileInsight : DTDFVocab:Insight [
    base:desc "Shows acceleration curves generated by the ACC model."
]

// C17: Actions
instance ACCDecisionAction : DTDFVocab:Action [
    base:desc "Issue desired acceleration setpoint to vehicle actuators."
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Enable or disable the Adaptive Cruise Control system."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set desired speed through remote operator interface."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Trigger emergency braking command."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originating from the User Interface FE (e.g., acceleration, brake, steering requests) are routed through the Digital Twin’s Actuation FE components (Motor Actuation FE and Steering Servo Actuation FE) using the ROS2 network. Prior to transmission, the Data Translation component re‑serialises the commands, ensuring consistent message format and units. The actuation commands are then sent to the physical actuators over the Wi‑Fi network with UDP transport. Feedback of updated vehicle state information returned by the Vehicle State FE provides confirmation of command execution, allowing the Digital Twin to reconcile command status with the real‑world response."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Time synchronization between the Physical Twin Entity and Digital Twin Entity is defined to achieve a 100 ms accuracy, meeting the hardware limitations while supporting safety‑critical vehicular applications. Each ROS2 package communicates timestamps using the ROS2 clock mechanism, and the system architecture ensures that control‑loop latency between sensor data acquisition, processing, and actuation stays within the 100 ms bound. No finer granular synchronisation or higher frequency coordination is specified."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The design follows the ISO 23247 reference architecture, mapping each Software Component (SW) to a Functional Entity (FE) and deploying each FE as an individual ROS2 package containing ROS2 nodes. The system is partitioned into three entities: the User Entity hosting the User Interface FE (split into 3D visualization and control panel), the Digital Twin Entity handling data management and control mechanisms, and the Physical Twin Entity encapsulating device communication, data preprocessing, actuation, and automotive functionality such as point‑cloud clustering and tracking. Resource management is handled through ROS2 middleware, which facilitates communication across distributed nodes, while a central entity aggregates data transformation and high‑level control, thereby coordinating the distributed twins."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin Service is built on a hybrid network architecture. Software components within the same physical host communicate via ROS 2 over an internal bus, while inter‑entity communication (between the vehicle and the virtual twin) takes place over a Wi-Fi network using UDP. The system must honour a maximum network latency of 100 ms, as specified by Requirement R7. Bandwidth and reliability requirements beyond this latency constraint are not explicitly quantified. No explicit encryption or authentication protocols are specified for the network traffic in the provided documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system aligns with the ISO 23247 – Digital twin framework for manufacturing. The reference architecture (Part 2 of the standard) specifies an entity‑based architecture comprising: Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity, and User Entity, each composed of Functional Entities (FEs). The architecture supports digital representation of physical manufacturing elements (Part 3) and information exchange procedures (Part 4). Compliance is demonstrated by referencing the standard parts and by implementing data collection and control via OPC Unified Architecture, an interoperability protocol adopted by the standard."
]