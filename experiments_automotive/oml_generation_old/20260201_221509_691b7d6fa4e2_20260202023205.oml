// C3: Physical sensing components
instance HokuyoUST110LXLiDAR : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-110LX LiDAR providing 2-D range measurements for object detection and vehicle speed estimation"
    DTDFVocab:producedData LiDARDataTransmitted
]

instance IntelDeepsenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera delivering 3-D point clouds for clustering and tracking"
    DTDFVocab:producedData DepthCameraDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LiDARDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST110LXLiDAR
]

instance DepthCameraDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435iDepthCamera
]

// C5: Data
instance LiDARRawData : DTDFVocab:Data [
    base:desc "Raw 2-D range measurements from the LiDAR"
    DTDFVocab:fromData LiDARDataTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance PointCloudRawData : DTDFVocab:Data [
    base:desc "Raw 3-D point cloud from the depth camera"
    DTDFVocab:fromData DepthCameraDataTransmitted
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

instance ClusteringOutputData : DTDFVocab:Data [
    base:desc "Clustered objects obtained via DBSCAN algorithm"
    DTDFVocab:fromData PointCloudRawData
    DTDFVocab:inputTo DataTranslationEnabler
]

instance TrackingOutputData : DTDFVocab:Data [
    base:desc "Object tracks maintained by Kalman filter"
    DTDFVocab:fromData ClusteringOutputData
    DTDFVocab:inputTo DataTranslationEnabler
]

// C10: Models/Data
instance PointCloudClusteringAndTrackingModel : DTDFVocab:Model [
    base:desc "Behavioral tracking model applying DBSCAN clustering on point‑cloud data followed by a Kalman filter to maintain object tracks"
    DTDFVocab:inputTo PointCloudProcessingEnabler
]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "Robot Operating System 2 middleware for communication and data exchange"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance NVIDIAJetpackGPU : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK providing GPU‑accelerated compute for clustering and ACC algorithms"
    DTDFVocab:enables ComputationOffloadingService
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for modelling and simulation of complex control algorithms"
    DTDFVocab:enables ComputationOffloadingService
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "Relational SQL database for persisting raw and generated data"
    DTDFVocab:enables DataMonitoringService
]

instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247 Data Translation functional entity serialising messages, aligning data models and performing unit conversions"
    DTDFVocab:enables DataMonitoringService
]

instance PointCloudProcessingEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 node implementing DBSCAN clustering and Kalman filter using NVIDIA Jetpack GPU acceleration"
    DTDFVocab:enables ComputationOffloadingService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI visualising vehicle state, projected path and detected object tracks; allows viewing, saving and generating reports of logged data"
    DTDFVocab:provides VisualizeVehicleStateInsight, GenerateDataReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs Adaptive Cruise Control algorithm in the digital twin (cloud) and sends the desired speed set‑point back to the vehicle for actuation"
    DTDFVocab:provides SendDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI enables operators to enable/disable ACC, set desired speed manually, and issue an emergency‑brake command"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetManualSpeedAction, EmergencyBrakeAction
]

// C17: Insights
instance VisualizeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight to visualise vehicle state, projected driving path and detected tracks in the UI"
]

instance GenerateDataReportInsight : DTDFVocab:Insight [
    base:desc "Insight to generate reports of logged data for analysis"
]

// C17: Actions
instance SendDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to send computed desired speed set‑point to the vehicle for actuation"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable Adaptive Cruise Control functionality"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Action to disable Adaptive Cruise Control functionality"
    DTDFVocab:IsAutomatic false
]

instance SetManualSpeedAction : DTDFVocab:Action [
    base:desc "Action to manually set the desired speed of the vehicle"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to trigger immediate emergency braking of the vehicle"
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance DriveMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Drive motor controlled via Data Collection and Device Control entity, provides full speed range"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo controlling wheel angle within defined angular limits"
]

instance ESCVedderActuator : DTDFVocab:ActingComponent [
    base:desc "Vedder Electronic Speed Controller managing motor current limits and enforcing safety stop on emergency brake"
]

// C1: System entities
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical twin hosting sensors, actuators and compute resources"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital twin providing data management, control algorithms and services"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User entity offering UI for monitoring and remote management"
]

// Environment containing the entities
instance TwinSystemEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity, DigitalTwinEntity, UserEntity
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are sent from the Digital Twin back to the vehicle over the same Wi‑Fi UDP channel. Commands include enabling/disabling ACC, setting a desired speed, and an emergency‑brake command; these are issued by the remote‑management UI and by the off‑loaded ACC computation (which calculates a desired speed based on lead‑vehicle distance). The commands are serialized and unit‑converted by the Data Translation FE before transmission. The UI displays confirmation of command execution, but the documents do not describe specific validation, authentication, acknowledgement, or conflict‑resolution mechanisms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Clock synchronization between the physical vehicle and its digital twin must achieve an accuracy of 100 ms, as required for safety‑critical vehicular applications and limited by the hardware; this shared notion of time enables computation offloading across devices."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration follows the ISO 23247 reference architecture instantiated with ROS 2: each Functional Entity is packaged as an individual ROS 2 package containing one or more ROS 2 nodes; communication between entities occurs via ROS 2 topics/services, enabling coordination across the separate hardware platforms. The mapping of software components to entities provides resource‑level segregation and ownership."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The ISO 23247 framework structures the Digital Twin lifecycle into four sequential parts: (1) Overview and General Principles – defines the conceptual stage and high‑level goals; (2) Reference Architecture – establishes the entity‑based architectural stage where the Observable Manufacturing Element (OME), Data Collection and Device Control Entity, Digital Twin Entity and User Entity are defined; (3) Digital Representation of Physical Manufacturing Elements – implements the Digital Twin Entity using functional entities that model the OME; (4) Information Exchange – integrates the DT with external systems and supports the transition to operational use. Governance of the lifecycle is expressed through adherence to the ISO 23247 standard, which prescribes the entities, functional entities and their responsibilities, but does not detail transition mechanisms."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑component communication within the digital twin system is built on ROS 2. Communication between the physical twin and the digital twin occurs over a Wi‑Fi network using UDP transport. The system is required to provide low end‑to‑end latency for safety‑critical ACC functionality, but the documents do not give quantitative bandwidth or latency targets, nor do they describe redundancy, reliability mechanisms, or specific security protocols for the network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT services are executed on external compute resources that can be “better‑suited equipment, e.g., in the cloud”, enabling off‑loading of the ACC algorithm. No details are given about the precise hosting platform (cloud provider, edge or on‑premise), required computational or storage capacities, scalability mechanisms, supported deployment models, or availability/reliability guarantees."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system complies with ISO 23247 (four‑part Digital Twin framework) and adopts its entity‑based reference architecture. Additional standards cited in the broader document include ISO 15622 for Adaptive Cruise Control (ACC) implementation and 3GPP Technical Specification 22.185 for network latency requirements. Interoperability is supported through the optional use of OPC UA, aligning the DT with common industrial communication standards."
]