]

instance DataPreProcessingModel : DTDFVocab:Model [
    base:desc "Functional Entity model for data cleaning, normalization, and feature extraction in the Digital Twin Entity. Implemented as ROS2 package."
    DTDFVocab:inputTo ROS2DataProcessingEnabler
]

instance ActuationControlModel : DTDFVocab:Model [
    base:desc "Model handling actuation commands from Digital Twin to Physical Twin, including speed and braking control logic. Integrated with ROS2 for real-time execution."
    DTDFVocab:inputTo ROS2DeviceCommunicationEnabler
]

instance HokuyoLiDARPointCloud : DTDFVocab:Data [
