    base:desc "Action enabling saving and generating reports of monitored data for post-analysis."
    DTDFVocab:IsAutomatic false
]

instance ACCComputationOffloadingAction : DTDFVocab:Action [
    base:desc "Action offloading ACC computations from vehicle ECUs to digital twin, reducing onboard computational load while maintaining real-time capabilities."
    DTDFVocab:IsAutomatic true
]

instance SpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Action adjusting desired speed based on lead vehicle proximity and ACC system calculations."
    DTDFVocab:IsAutomatic true
]

instance RemoteACCControlAction : DTDFVocab:Action [
    base:desc "Action enabling remote management of ACC parameters including enable/disable and speed adjustments."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Action triggering emergency braking commands sent to the physical twin for critical safety scenarios."
    DTDFVocab:IsAutomatic false
]

// C1: Entities
instance PhysicalTwinEntity : DTDFVocab:Entity [
    base:desc "Hardware-specific entity consolidating sensors, actuators, and compute resources for the autonomous vehicle. Hosts point cloud clustering, tracking, and actuation functionalities."
    base:contains HokuyoUST10LXLiDAR, IntelDeepsenseD435iDepthCamera, VehicleStateSensor, SteeringServoSensor, ObjectTrackingSensor, ACCSensorInput, VedderElectronicSpeedController
    base:isContainedIn AutonomousVehicleEnvironment
]

instance DigitalTwinEntity : DTDFVocab:Entity [
    base:desc "Computational entity managing data pre-processing, control mechanisms, and device communication. Implements ROS2 packages for functional entities including data processing and actuation control."
    base:contains DataPreProcessingModel, ActuationControlModel, ROS2DataProcessingEnabler, ROS2DeviceCommunicationEnabler, PythonProcessingEnabler, SQLDataStorageEnabler
    base:isContainedIn AutonomousVehicleEnvironment
]

instance UserEntity : DTDFVocab:Entity [
    base:desc "User-facing entity hosting 3D visualization and control panel components. Enables remote monitoring, parameter adjustments, and system control via ROS2-based interfaces."
    base:contains ROS2DataVisualizationEnabler
    base:isContainedIn AutonomousVehicleEnvironment
]

// C12: Entity Relationships
instance DataFlowPhysicalToDigital : DTDFVocab:Relationship [
    base:desc "Data transmission protocol between Physical Twin and Digital Twin entities using ROS2 over Wi-Fi (UDP)."
    DTDFVocab:from PhysicalTwinEntity
    DTDFVocab:to DigitalTwinEntity
    DTDFVocab:dataTransmitted HokuyoLiDARPointCloudData, DeepsenseDepthCameraData, VehicleStateData, SteeringServoData, ObjectTrackData, ACCInputData, ProjectedDrivingPathData
]

instance UserInteractionFlow : DTDFVocab:Relationship [
    base:desc "ROS2-based communication interface enabling user interaction with the Digital Twin Entity through the User Entity's visualization and control components."
    DTDFVocab:from UserEntity
    DTDFVocab:to DigitalTwinEntity
    DTDFVocab:dataTransmitted ProjectedPathData
]

// C16: Environment
instance AutonomousVehicleEnvironment : DTDFVocab:Environment [
    base:desc "Operational environment for the 1/10-scale autonomous vehicle with ACC functionality, including physical sensors, actuators, and digital twin infrastructure."
    base:contains PhysicalTwinEntity, DigitalTwinEntity, UserEntity
]

// C13: Component Relationships
instance SensorToModelRelationship : DTDFVocab:Relationship [
    base:desc "Data flow from sensing components to computational models within the Physical Twin Entity for processing and analysis."
    DTDFVocab:from HokuyoUST10LXLiDAR
    DTDFVocab:to PointCloudClusteringTrackingModel
]

instance ModelToEnablerRelationship : DTDFVocab:Relationship [
