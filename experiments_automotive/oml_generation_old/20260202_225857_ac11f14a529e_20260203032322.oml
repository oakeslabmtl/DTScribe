]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time state monitoring service providing UI-based visualization of vehicle state data, path projections, and object tracks. Supports data persistence and reporting."
    DTDFVocab:provides RealTimeVehicleStateInsight, PathVisualizationInsight, DataPersistenceAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Distributed computing service offloading ACC system computations from on-board ECUs to digital twin infrastructure, ensuring real-time decision-making with 100ms clock synchronization."
    DTDFVocab:provides ACCComputationOffloadingAction, SpeedAdjustmentAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Teleoperation service enabling remote enable/disable of ACC functionality, desired speed adjustments, and emergency braking commands with 100ms latency."
    DTDFVocab:provides RemoteACCControlAction, EmergencyBrakingAction
]

// C17: Insights/Actions
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight providing real-time vehicle state data (speed, acceleration, braking status) for performance tracking and debugging."
]

instance PathVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization of projected driving path and detected object tracks for spatial awareness and decision support."
]

