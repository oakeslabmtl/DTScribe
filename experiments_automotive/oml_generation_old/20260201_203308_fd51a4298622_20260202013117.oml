// C3: Physical sensing components
instance EgoSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Ego‑vehicle speed measurement from the Physical Twin, provided in real‑time via ROS2."
    DTDFVocab:producedData VehicleTelemetryTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle measurement from the Physical Twin, provided in real‑time via ROS2."
    DTDFVocab:producedData VehicleTelemetryTransmitted
]

instance HokuyoLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "2‑D LiDAR point‑clouds from a Hokuyo UST‑10LX mounted on the vehicle, streamed as ROS2 messages."
    DTDFVocab:producedData LiDARPointCloudTransmitted
]

instance RealSenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Depth images from an Intel RealSense D435i depth camera, streamed as ROS2 messages."
    DTDFVocab:producedData DepthImageTransmitted
]

// C4: Physical‑to‑virtual interaction – Data transmitted
instance VehicleTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoSpeedSensor, SteeringAngleSensor
]

instance LiDARPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARSensor
]

instance DepthImageTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RealSenseDepthCamera
]

// C9: Data instances
instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Time‑series of ego vehicle speed after unit conversion."
    DTDFVocab:fromData VehicleTelemetryTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Time‑series of steering angle after unit conversion."
    DTDFVocab:fromData VehicleTelemetryTransmitted
    DTDFVocab:inputTo DataTranslationFE
]

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 2‑D LiDAR point‑clouds ready for clustering."
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ComputationProcessingEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth images from the RealSense sensor."
    DTDFVocab:fromData DepthImageTransmitted
    DTDFVocab:inputTo ComputationProcessingEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Object tracks generated by DBSCAN clustering and Kalman‑filter tracking."
    DTDFVocab:fromData LiDARPointCloudTransmitted
    DTDFVocab:inputTo ComputationProcessingEnabler
]

// C10: Models/Data (algorithms)
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering algorithm used to segment raw LiDAR point‑clouds into object candidates."
    DTDFVocab:inputTo ComputationProcessingEnabler
]

instance KalmanFilterTrackerModel : DTDFVocab:Model [
    base:desc "Kalman‑filter tracker that fuses successive detections into continuous object tracks."
    DTDFVocab:inputTo ComputationProcessingEnabler
]

instance ACCControllerModel : DTDFVocab:Model [
    base:desc "ISO‑15622‑based Adaptive Cruise Control controller that computes a safe following speed."
    DTDFVocab:inputTo ComputationProcessingEnabler
]

// C11: Enablers (ISO 23247 functional entities)
instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "Data Translation Functional Entity that serialises ROS2 streams, performs unit conversion and aligns message types."
    DTDFVocab:enables DataMonitoringService
]

instance ComputationProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that hosts perception and ACC computation (DBSCAN, Kalman filter, ACC controller) on external compute."
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementFE : DTDFVocab:Enabler [
    base:desc "Remote Management Functional Entity that processes operator commands (enable/disable ACC, adjust parameters, emergency brake)."
    DTDFVocab:enables RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI visualisation of speed, steering angle, object tracks and projected path, plus report generation."
    DTDFVocab:provides RealTimeVisualizationInsight, ReportGenerationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Execution of the ACC algorithm on the Digital Twin’s off‑loaded compute resources."
    DTDFVocab:provides ACCParameterAdjustmentAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator‑driven remote management of the ACC system, including enable/disable and emergency braking."
    DTDFVocab:provides ACCEnableDisableAction, EmergencyBrakingAction
]

// C17: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualisation of vehicle telemetry, object tracks and projected trajectory in the operator UI."
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Automatic generation of post‑run reports for analysis and refinement of ACC strategies."
]

instance ACCParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Operator can adjust desired speed and following‑distance parameters of the ACC controller."
    DTDFVocab:IsAutomatic false
]

instance ACCEnableDisableAction : DTDFVocab:Action [
    base:desc "Operator can enable or disable the Adaptive Cruise Control system."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Operator can trigger emergency braking through the UI."
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller that receives voltage commands from the DT to drive vehicle speed."
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo that receives position commands from the DT for steering‑angle control."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT, including desired speed for the motor, steering commands, and remote‑management commands (enable/disable ACC, set desired speed, emergency brake); these are transmitted over the same Wi‑Fi/ROS 2 channel and executed by the Actuation FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All services operate in real time with a maximum end‑to‑end latency of 100 ms between vehicle and DT (requirement R7) and clocks on all components are synchronised to within 100 ms (requirement R8)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture follows the ISO 23247 reference model: a Physical Twin Entity exposing sensors and actuators, a Digital Twin Entity hosting data collection, processing, ACC, and visualization functions, a User Entity providing UI elements, and a Cross‑System Entity for data translation; entities are distributed across vehicle‑onboard hardware, a cloud/server platform, and an operator workstation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during design and development (troubleshooting, simulation), testing (validation of ACC), and operational phases (runtime monitoring, remote management)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses a Wi‑Fi network carrying ROS 2 DDS messages; the Data Translation FE handles serialization, type alignment and unit conversion; optional OPC UA is mentioned as a possible transport but not used."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Physical Twin Entity runs on the Jetson Orin Nano aboard the vehicle; the Digital Twin Entity runs on external compute (e.g., a cloud or server) hosting ROS 2 nodes for data collection, ACC, and reporting; the User Entity UI runs on a workstation accessed by operators; each functional entity is packaged as a ROS 2 node."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system conforms to ISO 23247 (reference architecture and functional entities), ISO 15622 for ACC behavior, and uses ROS 2 (DDS) as a standardized middleware; OPC UA is referenced as a possible standard for data translation."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed for a safety‑critical ADAS; latency ≤100 ms and clock sync ≤100 ms are required to ensure timely actuation; the remote‑management interface includes an emergency‑brake command; however, specific cybersecurity mechanisms are not described."
]