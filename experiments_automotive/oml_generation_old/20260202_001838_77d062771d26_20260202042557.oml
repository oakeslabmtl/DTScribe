prefix DTDFVocab = "http://example.org/DTDFVocab"
prefix base = "http://example.org/base"
instance VehicleStateVisualization : DTDFVocab:Insight [ // Return code: 1 | Stderr:
    base:desc "Real-time visualization of vehicle speed, acceleration, and yaw rate"
]

instance ProjectedDrivingPath : DTDFVocab:Insight [
    base:desc "Projected driving path based on current trajectory and detected objects"
]

instance ObjectTracks : DTDFVocab:Insight [
    base:desc "Detected object tracks from LiDAR point cloud clustering"
]

instance LeadVehicleDetection : DTDFVocab:Insight [
    base:desc "Identification and tracking of lead vehicle for ACC operations"
]

instance SpeedCalculation : DTDFVocab:Insight [
    base:desc "Calculation of optimal speed based on distance to lead vehicle"
]

instance ActuationCommand : DTDFVocab:Action [
    base:desc "Command to adjust vehicle speed via motor control",
    DTDFVocab:IsAutomatic true
]

instance EnableACC : DTDFVocab:Action [
    base:desc "Enable Adaptive Cruise Control system",
    DTDFVocab:IsAutomatic false
]

instance DisableACC : DTDFVocab:Action [
    base:desc "Disable Adaptive Cruise Control system",
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeed : DTDFVocab:Action [
    base:desc "Set target speed for ACC operation",
    DTDFVocab:IsAutomatic false
]

instance EmergencyBraking : DTDFVocab:Action [
    base:desc "Initiate emergency braking command",
    DTDFVocab:IsAutomatic false
]

