// Sensing Components
instance HokuyoUST10LXSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR mounted on the 1/10-scale autonomous vehicle."
    DTDFVocab:producedData LiDARFrameTransmission
]

instance D435iDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i depth camera capturing RGB‑D images."
    DTDFVocab:producedData DepthImageTransmission
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle speed sensor measuring chassis velocity."
    DTDFVocab:producedData EgoSpeedTransmission
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor measuring wheel angle."
    DTDFVocab:producedData EgoSteeringTransmission
]

// Data Transmitted
instance LiDARFrameTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXSensor
]

instance DepthImageTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom D435iDepthCameraSensor
]

instance EgoSpeedTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]

instance EgoSteeringTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Data
instance LiDARFrameData : DTDFVocab:Data [
    base:desc "Raw LiDAR point cloud frames streamed from Hokuyo UST-10LX."
    DTDFVocab:inputTo DataTranslationEnabler
    DTDFVocab:inputTo TrackingEnabler
    DTDFVocab:fromData LiDARFrameTransmission
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Raw RGB‑D images from Intel Deepsense D435i."
    DTDFVocab:inputTo DataTranslationEnabler
    DTDFVocab:fromData DepthImageTransmission
]

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed data from speed sensor."
    DTDFVocab:inputTo DataTranslationEnabler
    DTDFVocab:fromData EgoSpeedTransmission
]

instance EgoSteeringData : DTDFVocab:Data [
    base:desc "Steering angle data from steering sensor."
    DTDFVocab:inputTo DataTranslationEnabler
    DTDFVocab:fromData EgoSteeringTransmission
]

instance ACCControlCommandData : DTDFVocab:Data [
    base:desc "Desired speed commands for ACC derived by the controller."
    DTDFVocab:inputTo ActuationEnabler
]

// Models
instance ACCControllerModel : DTDFVocab:Model [
    base:desc "ISO 15622-derived adaptive cruise control controller implemented in the DT."
    DTDFVocab:inputTo ACCControlEnabler
]

instance TrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN‑plus‑Kalman filter clustering/tracking model for LiDAR data."
    DTDFVocab:inputTo TrackingEnabler
]

// Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "Enables data translation and unit conversion from on-board sensors to DT."
    DTDFVocab:enables RealTimeMonitoringService
    DTDFVocab:enables ComputationOffloadingService
]

instance TrackingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler to execute DBSCAN‑Kalman tracking on LiDAR point clouds."
    DTDFVocab:enables TrackingService
]

instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler to forward ACC controller commands from DT to vehicle actuators."
    DTDFVocab:enables ComputationOffloadingService
]

instance ActuationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler forwarding control commands to on-board actuators."
    DTDFVocab:enables ActuationService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler to handle remote ACC enable/disable and speed adjustments."
    DTDFVocab:enables RemoteACCControlService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler to render 3‑D vehicle and environment models."
    DTDFVocab:enables VisualizationService
]

instance ReportingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler to aggregate historical data into reports."
    DTDFVocab:enables AutomatedReportingService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring vehicle speed, steering, and environment via real‑time telemetry."
    DTDFVocab:provides VehicleStateInsight, ObjectTrackingInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Service offloading ACC control loop computation to the digital twin."
    DTDFVocab:provides ACCPerformanceInsight
]

instance TrackingService : DTDFVocab:Service [
    base:desc "Service performing object tracking using DBSCAN and Kalman filter."
    DTDFVocab:provides ObjectTrackingInsight
]

instance RemoteACCControlService : DTDFVocab:Service [
    base:desc "Service providing remote control of ACC enable state and desired speed."
    DTDFVocab:provides RemoteACCEnableAction, SetDesiredSpeedAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service rendering vehicle, environment and tracked objects in 3‑D."
    DTDFVocab:provides VisualInsight
]

instance AutomatedReportingService : DTDFVocab:Service [
    base:desc "Service generating automated reports of ACC performance and vehicle telemetry."
    DTDFVocab:provides ReportInsight
]

instance ActuationService : DTDFVocab:Service [
    base:desc "Service executing steering servo, motor velocity, and emergency braking commands."
    DTDFVocab:provides RemoteACCEnableAction, SetDesiredSpeedAction, EmergencyBrakeExecutionAction
]

// Insights
instance VehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time dashboard insight of vehicle speed and steering state."
]

instance ObjectTrackingInsight : DTDFVocab:Insight [
    base:desc "Insight into detected object positions and trajectories."
]

instance ACCPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight on ACC loop performance and latency."
]

instance VisualInsight : DTDFVocab:Insight [
    base:desc "Real‑time visual representation of vehicle and detected objects."
]

instance ReportInsight : DTDFVocab:Insight [
    base:desc "Historical analysis of ACC performance and maintenance insights."
]

// Actions
instance RemoteACCEnableAction : DTDFVocab:Action [
    base:desc "Toggles ACC enable or disable state remotely."
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Sets desired speed for ACC via remote interface."
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeExecutionAction : DTDFVocab:Action [
    base:desc "Executes emergency braking when object proximity triggers."
    DTDFVocab:IsAutomatic true
]

// Acting Components
instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo receiving desired steering commands from DT."
]

instance MotorVelocityActuator : DTDFVocab:ActingComponent [
    base:desc "Motor velocity controller (Vedder ESC) executing desired speed commands."
]

instance EmergencyBrakingActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency braking actuator controlled by DT signals."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity’s Actuation FE outputs desired speed commands and emergency braking signals; these are transmitted back over Wi‑Fi/ROS 2 to the on‑board Jetson, converted to driver voltage commands for the Vedder ESC and steering servo; User Interface FE issues ACC enable/disable, set‑point changes, and emergency braking commands."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with end‑to‑end latency limited to 100 ms from PT to DT Entity; clock synchronization accuracy required within 100 ms; ACC control executed in near real‑time (vehicle‑side or offloaded)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "ISO 23247‑derived reference architecture with customized Physical Twin Entity, Digital Twin Entity, User Entity, and Cross‑System Entity; each mapped to a set of ROS 2 packages; orchestrated by a central virtual network (ROS 2 over Wi‑Fi) and a dedicated Data Translation layer, enabling distributed operation and modularity."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is instantiated during the operational stage of the vehicle, following manufacturing and preceding end‑of‑life. It supports real‑time monitoring, remote management, and data‑driven diagnostics during vehicle use."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "ACC controller validated against ISO 15622 performance class I; end‑to‑end latency limited to 100 ms and clock sync within 100 ms; data fidelity ensured through DBSCAN clustering and Kalman filtering; safety requirements considered via low‑latency communication and offloading for computing‑intensive tasks; uncertainty not explicitly quantified."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual data transmitted over Wi‑Fi using ROS 2 (DDS/UDP) with a Data Translation layer; virtual‑to‑physical control commands transmitted similarly; LiDAR frames and control signals carried over ROS 2 topics with serialization and unit conversion."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital Twin Entity deployed on cloud infrastructure with GPU compute; Physical Twin Entity’s FEs run on on‑board Jetson Orin Nano (and Jetson NX antenna); ROS 2 network spans both devices; user interface runs on a desktop client."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 (Reference Architecture), ISO 15622 (Adaptive Cruise Control spec), ROS 2 middleware standard, OPC UA optional, NVIDIA JetPack SDK."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical design incorporates 100 ms latency bound and 100 ms clock synchronization, adherence to ISO 15622 ACC safety class, and remote operation enabled by cloud offloading; specific cybersecurity controls are not detailed in the document."
]