instance HokuyoUST10LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR for point cloud data collection"
    DTDFVocab:producedData LidarPointCloudsDataTransmitted
]

instance IntelDeepsenseD435i : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i Depth Camera for depth perception"
    DTDFVocab:producedData DepthPerceptionDataTransmitted
]

instance VedderESC : DTDFVocab:SensingComponent [
    base:desc "Vedder Electronic Speed Controller for vehicle speed data collection"
    DTDFVocab:producedData VehicleSpeedDataTransmitted
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering angle sensor for vehicle steering control"
    DTDFVocab:producedData SteeringAngleDataTransmitted
]

instance LidarPointCloudsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LX
]

instance DepthPerceptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepsenseD435i
]

instance VehicleSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VedderESC
]

instance SteeringAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

instance LidarPointCloudsData : DTDFVocab:Data [
    base:desc "Raw point cloud data from Hokuyo UST-10LX LiDAR"
    DTDFVocab:fromData LidarPointCloudsDataTransmitted
    DTDFVocab:inputTo ROS2Middleware, Python38
]

instance DepthPerceptionData : DTDFVocab:Data [
    base:desc "Depth perception data from Intel Deepsense D435i"
    DTDFVocab:fromData DepthPerceptionDataTransmitted
    DTDFVocab:inputTo ROS2Middleware, Python38
]

instance VehicleSpeedData : DTDFVocab:Data [
    base:desc "Vehicle speed data from Vedder Electronic Speed Controller"
    DTDFVocab:fromData VehicleSpeedDataTransmitted
    DTDFVocab:inputTo ROS2Middleware, Python38
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Steering angle data from vehicle steering sensor"
    DTDFVocab:fromData SteeringAngleDataTransmitted
    DTDFVocab:inputTo ROS2Middleware, Python38
]

instance DBSCANModel : DTDFVocab:Model [
    base:desc "DBSCAN algorithm for point cloud clustering"
    DTDFVocab:inputTo ROS2Middleware, Python38
]

instance KalmanFilterModel : DTDFVocab:Model [
    base:desc "Kalman filter for object tracking"
    DTDFVocab:inputTo ROS2Middleware, Python38
]

instance ACCControlLogicModel : DTDFVocab:Model [
    base:desc "ACC control logic for lead vehicle detection and speed computation"
    DTDFVocab:inputTo ROS2Middleware, Python38
]

instance SQLDatabase : DTDFVocab:Data [
    base:desc "SQL database for storing vehicle data"
    DTDFVocab:fromData LidarPointCloudsDataTransmitted, DepthPerceptionDataTransmitted, VehicleSpeedDataTransmitted, SteeringAngleDataTransmitted
    DTDFVocab:inputTo ROS2Middleware
]

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 middleware for component integration"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance NVIDIAJetpack50SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for Jetson programming"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance Python38 : DTDFVocab:Enabler [
    base:desc "Python 3.8 implementation language"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance Cpp : DTDFVocab:Enabler [
    base:desc "C++ implementation language"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink for complex system modeling"
    DTDFVocab:enables ComputationOffloadingService
]

instance WiFi : DTDFVocab:Enabler [
    base:desc "Wi-Fi for inter-entity communication"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data monitoring service for real-time visualization and report generation"
    DTDFVocab:provides RealTimeVisualization, SystemPerformanceReport
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation offloading service for ACC system execution on DT"
    DTDFVocab:provides ACCControlAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote management service for enable/disable ACC, set desired speed, emergency braking via UI"
    DTDFVocab:provides EnableDisableACC, SetDesiredSpeed, EmergencyBraking
]

instance RealTimeVisualization : DTDFVocab:Insight [
    base:desc "Real-time visualization of vehicle state, object tracks, and projected path for driver trust"
]

instance SystemPerformanceReport : DTDFVocab:Insight [
    base:desc "Report generation for system performance analysis enabling human decision-making without direct PT control"
]

instance ACCControlAction : DTDFVocab:Action [
    base:desc "ACC control logic for lead vehicle detection and speed computation"
    DTDFVocab:IsAutomatic true
]

instance EnableDisableACC : DTDFVocab:Action [
    base:desc "Enable or disable ACC system via UI"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeed : DTDFVocab:Action [
    base:desc "Set desired speed for ACC system via UI"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBraking : DTDFVocab:Action [
    base:desc "Emergency braking command via UI"
    DTDFVocab:IsAutomatic false
]

instance AutonomousVehicleSystem : DTDFVocab:Environment [
    base:desc "1/10th-scale autonomous vehicle system"
    base:contains JetsonNX, OrinNano, HokuyoUST10LX, IntelDeepsenseD435i, VedderESC, SteeringAngleSensor, MotorActuator, SteeringServoActuator
]

instance JetsonNX : DTDFVocab:Component [
    base:desc "NVIDIA Jetson NX microcomputer for processing"
]

instance OrinNano : DTDFVocab:Component [
    base:desc "NVIDIA Orin Nano microcomputer for processing"
]

instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Motor actuator controlled via voltage commands for speed adjustments"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator controlled via voltage commands for steering adjustments"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "ACC control signals for desired speed, emergency braking commands, and steering adjustments sent to motor and steering servo actuators, generated by the Controlling FE and Actuation FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time operation with end-to-end latency ≤100 ms and clock synchronization accuracy of 100 ms as specified in requirements R7 and R8."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Structured into Physical Twin Entity (vehicle hardware), Digital Twin Entity (ACC, data processing), User Entity (UI), and Cross-System Entity (Data Translation FE), adhering to ISO 23247 reference architecture with modifications."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design phase (cyber-physical experimentation for ADAS development) and operation phase (real-time ACC monitoring and control during vehicle operation)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "ROS2 for intra-entity communication within hardware, Wi-Fi for inter-entity communication between vehicle and remote servers; Data Translation FE handles serialization, message type alignment, and unit conversions with ≤100 ms latency per 3GPP 22.185."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity deployed on vehicle hardware (Jetson Orin Nano); Digital Twin Entity and User Entity hosted on cloud or remote servers for computation offloading."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 reference architecture for digital twin framework, with ROS2 middleware and 3GPP 22.185 for V2V communication standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety-critical nature respected with latency compliance to 3GPP 22.185; no explicit security protocols (e.g., encryption, authentication) detailed in the document."
]