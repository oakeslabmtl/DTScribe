// C3: Physical sensing components
instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor providing raw point‑cloud data of the environment"
    DTDFVocab:producedData LiDARPointCloudDataTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle‑state sensors providing speed, steering angle and position"
    DTDFVocab:producedData VehicleStateDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LiDARPointCloudDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
]

instance VehicleStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// C10: Models/Data (Processed/Translated data)
instance TranslatedLiDARData : DTDFVocab:Data [
    base:desc "LiDAR point cloud after serialization, type alignment and unit conversion"
    DTDFVocab:fromData LiDARPointCloudDataTransmitted
    DTDFVocab:inputTo DataPreProcessingFE
]

instance TranslatedVehicleStateData : DTDFVocab:Data [
    base:desc "Vehicle state data after serialization, type alignment and unit conversion"
    DTDFVocab:fromData VehicleStateDataTransmitted
    DTDFVocab:inputTo DataCollectionFE
]

// C11: Enablers (Functional Entities)
instance DataPreProcessingFE : DTDFVocab:Enabler [
    base:desc "Data Pre‑Processing Functional Entity that clusters LiDAR point clouds and tracks objects (DBSCAN + Kalman filter)"
    DTDFVocab:enables DataMonitoringService
]

instance DataCollectionFE : DTDFVocab:Enabler [
    base:desc "Data Collection Functional Entity that aggregates vehicle state and object tracks"
    DTDFVocab:enables DataMonitoringService
]

instance PresentationFE : DTDFVocab:Enabler [
    base:desc "Presentation Functional Entity that visualizes pre‑processed data in a 3D UI"
    DTDFVocab:enables DataMonitoringService
]

instance ComputationOffloadingFE : DTDFVocab:Enabler [
    base:desc "Computation Offloading Functional Entity that runs the ACC behavioral model in the cloud"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementFE : DTDFVocab:Enabler [
    base:desc "Remote Management Functional Entity (Control Panel) allowing operators to enable/disable ACC, set speed, and issue emergency brake"
    DTDFVocab:enables RemoteManagementService
]

// C10: Models
instance ACCBehaviorModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control behavioral model determining lead vehicle and computing desired speed based on inter‑vehicle distance"
    DTDFVocab:inputTo ComputationOffloadingFE
]

instance ObjectTrackModel : DTDFVocab:Model [
    base:desc "Object‑track model derived from LiDAR point clouds, providing ID, size, position, and velocity for each detected object"
    DTDFVocab:inputTo PresentationFE
]

instance PointCloudClusteringTrackingModel : DTDFVocab:Model [
    base:desc "Point Cloud Clustering & Tracking algorithm (DBSCAN + Kalman filter) converting raw LiDAR clouds to clustered object tracks"
    DTDFVocab:inputTo ObjectTrackModel
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Data Monitoring service displaying real‑time vehicle state, projected path, and detected object tracks; enables viewing, saving and reporting"
    DTDFVocab:provides RealTimeVehicleStateInsight
    DTDFVocab:provides RealTimeObjectTrackInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Computation Offloading service executing the ACC algorithm on the digital twin (cloud) and sending the desired speed command back to the vehicle"
    DTDFVocab:provides SpeedCommandAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote Management service allowing operators to enable/disable ACC, set desired speed, and issue emergency brake via UI"
    DTDFVocab:provides EnableACCAction
    DTDFVocab:provides DisableACCAction
    DTDFVocab:provides SetDesiredSpeedAction
    DTDFVocab:provides EmergencyBrakeAction
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Insight of real‑time vehicle state (speed, steering angle, position) shown on the UI"
]

instance RealTimeObjectTrackInsight : DTDFVocab:Insight [
    base:desc "Insight of real‑time object tracks (ID, size, position, velocity) visualized in 3D"
]

// C17: Actions
instance SpeedCommandAction : DTDFVocab:Action [
    base:desc "Action transmitting the computed desired speed from the ACC model to the vehicle actuator"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to remotely enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Action to remotely disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to set a new desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to issue an emergency braking command"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance MotorActuationFE : DTDFVocab:ActingComponent [
    base:desc "Motor Actuation Functional Entity that commands the vehicle’s drive motor for speed control"
]

instance SteeringServoActuationFE : DTDFVocab:ActingComponent [
    base:desc "Steering Servo Actuation Functional Entity that commands the steering servo for direction control"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin generates control commands (ACC desired speed, enable/disable ACC, emergency‑brake request, and modified speed set‑points) through the Controlling FE (ACC) and sends them over the same Wi‑Fi UDP channel. Commands are formatted by the Data Translation FE (serialization, message type alignment, unit conversion) and received by the Actuation FE on the physical twin, which converts the desired speed into motor voltage commands and activates the steering and brake actuators. Remote‑management commands issued from the UI Control Panel are also routed through the Data Translation FE before execution on the vehicle. Execution confirmation is provided by the vehicle state feedback loop back to the DT."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Clock synchronization between the vehicle and the digital twin must achieve 100 ms accuracy, as required by hardware limitations and safety‑critical vehicular standards. Real‑time services (Data Monitoring, Computation Offloading, Remote Management) rely on low end‑to‑end latency communication, though the exact latency bound is not quantified. Temporal granularity includes continuous vehicle state updates, real‑time LiDAR point‑cloud processing, and rapid actuation feedback via ROS2 nodes."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system adopts the ISO‑23247 entity‑based reference architecture, extended by a Physical Twin Entity. Each Functional Entity is implemented as a distinct ROS2 package containing one or more ROS2 nodes. Intra‑entity communication uses ROS2 publish/subscribe; inter‑entity communication employs Wi‑Fi with UDP transport. Core services (Data Monitoring, Computation Offloading, Remote Management) are composed of Data Translation FE and other FEs, with resource management achieved by mapping FEs to specific compute hardware across the three entities."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is governed by safety‑critical latency requirements; the system mandates a maximum clock‑synchronisation error of 100 ms to ensure timely ACC computation and actuation. The Data Translation FE ensures unit consistency and message alignment, contributing to data validity. Real‑time visualisation of vehicle state, projected path, and object tracks, together with generated reports, serve as verification artefacts. No explicit uncertainty quantification or formal validation procedures are described in the provided documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS uses a hybrid network architecture: intra‑entity software components communicate via a ROS2 middleware layer, while inter‑entity communication (Physical Twin ↔ Digital Twin ↔ User Entity) occurs over a Wi‑Fi network using UDP at the transport layer. The system requires clock synchronisation with ≤ 100 ms accuracy. Low end‑to‑end latency is a design goal to support safety‑critical ACC functions, though exact latency numbers are not specified. Reliability is supported by ROS2’s QoS settings and the use of UDP; security mechanisms are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "dt_hosting_deployment"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external components is realized through ROS2 middleware for internal component interaction and UDP over Wi‑Fi for vehicle‑to‑twin data exchange. The Data Translation FE handles serialization, message type alignment, and unit conversion. While OPC UA is cited as an example protocol for implementing Data Translation, it is not used in this deployment. No direct interfaces to enterprise systems are described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system is built on the ISO 23247‑2 reference architecture for digital twins, adopting its entity‑based structure (Data Collection and Device Control Entity, Digital Twin Entity, User Entity). It leverages OPC Unified Architecture (OPC UA, IEC 62541) for data translation, and ROS 2 as the middleware for implementing functional entities. The authors argue that ISO 23247 alone is insufficient for safety‑critical automotive applications and recommend integrating ISO 26262 safety processes and AUTOSAR for automotive software architecture. Interoperability with other standards is intended through domain‑agnostic design and use of widely adopted protocols."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The case study notes that the ISO 23247 reference architecture (RA) is inadequate for safety‑critical automotive digital twins and therefore safety must be treated as a first‑class concern. It recommends incorporating the functional‑safety standard ISO 26262 into the DT, using its hazard analysis, risk‑assessment, safety‑case, and SIL allocation procedures for critical functions such as Adaptive Cruise Control (implemented per ISO 15622). Consequently, safety‑critical components should be designed with ISO 26262‑compliant fail‑safe mechanisms, redundancy, and verification activities. Although security issues are highlighted as important, the documents do not provide specific cybersecurity protocols, authentication, or access‑control measures."
]