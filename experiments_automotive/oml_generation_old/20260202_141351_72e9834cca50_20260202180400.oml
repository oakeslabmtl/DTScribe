]

instance DataTranslationFE : DTDFVocab:Enabler [
    base:desc "ISO 23247 compliant data translation functional entity serializing and converting data streams across heterogeneous sources (LiDAR, sensors, vehicle state)"
    DTDFVocab:enables ProcessedLiDARPointCloud, MotorActuationCommands
]

instance PresentationFE : DTDFVocab:Enabler [
    base:desc "Presentation functional entity integrating processed data into 3D visualization for autonomous vehicle digital cockpit"
    DTDFVocab:enables ObjectTrackingData
]

instance UserInterfaceFE : DTDFVocab:Enabler [
    base:desc "User interface functional entity enabling monitoring, saving, and report generation for ACC system operational metrics"
    DTDFVocab:enables OperationalMetricsReport
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time data monitoring service collecting and analyzing sensor data (LiDAR point clouds, camera feeds) to ensure alignment between physical and digital states"
    DTDFVocab:provides RealTimeDataValidationInsight
]

