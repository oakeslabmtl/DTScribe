    DTDFVocab:producedData RawSteeringData
]

instance VehicleStateMetricsSensor : DTDFVocab:SensingComponent [
    base:desc "Vehicle state metrics sensor collecting real-time performance data (e.g., speed, position, acceleration) for ACC validation"
