instance ROS2Network : DTDFVocab:Enabler [
    base:desc "Robot Operating System 2 network enabling intra-entity data exchange between software components for real-time autonomous vehicle control"
    DTDFVocab:enables RawLiDARPointCloudData, RawMotorStateData, ProcessedLiDARPointCloud
]

instance WiFiUDPTransport : DTDFVocab:Enabler [
    base:desc "Wi-Fi UDP transport layer facilitating real-time data transfer between physical and digital entities in autonomous vehicle system"
