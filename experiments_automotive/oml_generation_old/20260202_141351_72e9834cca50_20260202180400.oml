    DTDFVocab:producedFrom MotorStateSensor
]

instance RawSteeringData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringInputSensor
]

instance RawVehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateMetricsSensor
]

instance ProcessedLiDARClusteringData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLiDARSensor
]

instance ActuationFeedbackData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VedderElectronicSpeedController
]

instance PreprocessedVehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateMetricsSensor
]

// C5: Processed Data Components
instance ProcessedLiDARPointCloud : DTDFVocab:Data [
    base:desc "Processed LiDAR point cloud data after clustering and tracking operations for object detection in autonomous vehicle environment"
    DTDFVocab:fromData ProcessedLiDARClusteringData
    DTDFVocab:inputTo DataPreProcessingFE
]

instance MotorActuationCommands : DTDFVocab:Data [
    base:desc "Processed motor actuation commands converted from desired speed inputs for real-time control execution"
    DTDFVocab:fromData ActuationFeedbackData
    DTDFVocab:inputTo ActuationFE
]

instance FilteredVehicleTrajectory : DTDFVocab:Data [
    base:desc "Pre-processed vehicle trajectory data with noise reduction and unit conversion for ACC validation"
    DTDFVocab:fromData PreprocessedVehicleStateData
    DTDFVocab:inputTo DataPreProcessingFE
]

instance ObjectTrackingData : DTDFVocab:Data [
    base:desc "Processed object tracking data from LiDAR point cloud clustering for autonomous vehicle perception"
    DTDFVocab:fromData ProcessedLiDARPointCloud
    DTDFVocab:inputTo PresentationFE
]

// C10: Models/Data (Functional Entities)
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "LiDAR point cloud clustering model executed within ROS2 network for object detection in autonomous vehicle environment"
    DTDFVocab:inputTo DataPreProcessingFE
]

instance DataPreProcessingFE : DTDFVocab:Enabler [
    base:desc "Centralized data preprocessing functional entity handling noise reduction, alignment, and unit conversions for heterogeneous sensor data"
    DTDFVocab:enables ProcessedLiDARPointCloud, FilteredVehicleTrajectory
]

instance ActuationFE : DTDFVocab:Enabler [
    base:desc "Functional entity responsible for real-time actuation feedback processing and motor command conversion for autonomous vehicle control"
