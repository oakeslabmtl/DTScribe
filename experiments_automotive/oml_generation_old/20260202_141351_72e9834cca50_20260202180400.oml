    base:desc "Real-time insight verifying data quality and synchronization between physical and digital states of autonomous vehicle components"
]

instance PerceptionModelExecutionInsight : DTDFVocab:Insight [
    base:desc "Insight from point cloud clustering and tracking execution validating perception model performance in autonomous vehicle environment"
]

