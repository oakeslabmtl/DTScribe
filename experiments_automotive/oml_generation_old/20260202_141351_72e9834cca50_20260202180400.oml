    base:desc "Vedder Electronic Speed Controller for autonomous vehicle's motor actuation, converting desired speed commands into motor voltage signals for real-time control"
]

// C3: Physical Sensing Components
instance HokuyoUST10LXLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR sensor providing 2D plane representation of point clouds for spatial mapping in autonomous vehicle testing environment"
