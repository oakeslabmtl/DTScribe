// C3: Physical sensing components
instance HokuyoUST10LXLidar : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX 2-D LiDAR providing distance measurements used by point‑cloud clustering & tracking"
    DTDFVocab:producedData LiDARPointCloudTransmission
]

instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel DeepSense D435i depth camera supplying RGB‑D data for perception tasks"
    DTDFVocab:producedData DepthCameraRGBDTransmission
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance LiDARPointCloudTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoUST10LXLidar
]

instance DepthCameraRGBDTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

// C10: Data produced from sensors
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw 2‑D LiDAR point‑cloud stream at native sampling rate"
    DTDFVocab:fromData LiDARPointCloudTransmission
    DTDFVocab:inputTo DataTranslationEnabler
]

instance DepthCameraRGBDData : DTDFVocab:Data [
    base:desc "RGB‑D frames streamed from the depth camera at native rate"
    DTDFVocab:fromData DepthCameraRGBDTransmission
    DTDFVocab:inputTo DataTranslationEnabler
]

// C11: Enablers
instance DataTranslationEnabler : DTDFVocab:Enabler [
    base:desc "ISO 23247 Data Translation FE serializes, aligns message types and performs unit conversions for incoming sensor data"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance PointCloudClusteringEnabler : DTDFVocab:Enabler [
    base:desc "Executes DBSCAN clustering on LiDAR point clouds and Kalman‑filter tracking to produce object tracks"
    DTDFVocab:enables DataMonitoringService, ACCOffloadingEnabler
]

instance ACCOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Runs Adaptive Cruise Control algorithm on cloud resources and returns desired speed to the vehicle"
    DTDFVocab:enables ComputationOffloadingService
]

instance DataStorageEnabler : DTDFVocab:Enabler [
    base:desc "Data Storage FE aggregates object tracks and ego‑vehicle state into a relational SQL database"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

// C10: Models
instance PointCloudClusteringAndTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering of LiDAR point clouds with Kalman‑filter based object tracking"
    DTDFVocab:inputTo PointCloudClusteringEnabler, DataStorageEnabler
]

instance ACCAlgorithmModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm executed on cloud; computes desired speed from lead‑vehicle detection and distance"
    DTDFVocab:inputTo ACCOffloadingEnabler, DataStorageEnabler
]

// C10: Model‑derived data
instance ObjectTracksData : DTDFVocab:Data [
    base:desc "Processed object tracks and projected driving path generated by clustering & tracking model"
    DTDFVocab:fromData LiDARPointCloudTransmission
    DTDFVocab:inputTo DataStorageEnabler
]

instance DesiredSpeedData : DTDFVocab:Data [
    base:desc "Desired vehicle speed computed by ACC algorithm, streamed back for actuation"
    DTDFVocab:fromData LiDARPointCloudTransmission
    DTDFVocab:inputTo DataStorageEnabler
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time UI visualises vehicle state, projected trajectory, and detected object tracks; allows data saving and report generation"
    DTDFVocab:provides RealTimeVehicleStateInsight, ObjectTracksInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC computation to cloud resources and streams desired speed back to the vehicle for actuation"
    DTDFVocab:provides DesiredSpeedInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "UI enables operators to enable/disable ACC, set target speed, and issue emergency‑brake commands over a low‑latency link"
    DTDFVocab:provides ToggleACCAction, SetTargetSpeedAction, EmergencyBrakeAction, IssueRemoteCommandAction
]

// C17: Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Provides operators with real‑time visualization of vehicle state variables and trajectory"
]

instance ObjectTracksInsight : DTDFVocab:Insight [
    base:desc "Displays detected object tracks derived from LiDAR clustering and tracking"
]

instance DesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Shows the desired speed computed by the ACC algorithm"
]

// C17: Actions
instance ToggleACCAction : DTDFVocab:Action [
    base:desc "Operator toggles Adaptive Cruise Control on or off via the UI"
    DTDFVocab:IsAutomatic false
]

instance SetTargetSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets a target speed for the vehicle through the UI"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers an emergency‑brake command to stop the vehicle immediately"
    DTDFVocab:IsAutomatic false
]

instance IssueRemoteCommandAction : DTDFVocab:Action [
    base:desc "Operator issues remote control commands (throttle, steering) via the UI"
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance VedderElectronicSpeedController : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller receives desired speed commands from the Digital Twin and drives the propulsion motor"
]

instance SteeringServo : DTDFVocab:ActingComponent [
    base:desc "Steering servo adjusts wheel angle based on commands from the Digital Twin"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DTS runs the ACC service, computes the lead‑vehicle identification and desired speed, and sends the desired speed command back to the vehicle where an Actuation Front‑End (Motor, Steering, Servo) executes the actuation. The Remote Management UI can also transmit enable/disable ACC commands, set‑point speed adjustments and emergency‑braking commands to the physical twin. These control messages are conveyed over the same Wi‑Fi UDP channel used for sensor data, but the documents do not detail the command payload format, validation, authentication, or acknowledgement protocols."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires that all devices share a common notion of time to enable computation offloading; clock synchronization must achieve 100 ms accuracy (limited by hardware), while many safety‑critical vehicular standards mandate tighter synchronization, indicating that the digital twin operates on a sub‑second time granularity with a synchronization interval of at most 100 ms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin follows the ISO 23247 reference architecture, organizing software components into Functional Entities (FEs) that are implemented as individual ROS 2 packages containing one or more ROS 2 nodes. The Physical Twin Entity hosts resource‑specific functionality (e.g., point‑cloud clustering), the Digital Twin Entity provides data management and control, and the User Entity contains the User Interface FE split into visualization and control panel. This entity‑based design orchestrates the system through ROS 2 communication and ROS‑based component integration."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DTS intra‑component communication relies on a ROS 2 network, providing publish/subscribe messaging among software modules. Inter‑entity (physical‑digital) communication uses a Wi‑Fi network with UDP as the transport protocol. The system is required to support low end‑to‑end latency communication to satisfy safety‑critical ACC operation, though specific latency, bandwidth, reliability, redundancy or security protocol details are not provided in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin’s compute workload (e.g., the ACC algorithm, data collection, reporting and visualization services) is off‑loaded from the resource‑constrained vehicle to external compute resources described as “cloud” or other off‑vehicle platforms. These platforms host ROS 2 nodes for the various Front‑Ends (Data Monitoring, Computation Offloading, Remote Management) and provide storage for collected vehicle state and sensor data. Deployment can thus be distributed, with the physical twin on‑board the vehicle and the digital twin services on remote servers or edge devices capable of running the required ROS 2 components. While the documents mention the need for scalability and low latency, they do not specify concrete hardware models, storage capacities, scalability mechanisms, redundancy strategies, or availability guarantees."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The ISO 23247 framework allows Functional Entities to be implemented with standards such as OPC Unified Architecture (OPC UA), suggesting that external data exchange and interoperability with other enterprise systems can be achieved via OPC UA. No additional external integration patterns or protocols are detailed in the provided documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adopts the ISO 23247 digital‑twin framework for manufacturing, specifically part 2 (Reference Architecture), to structure the twin into Observable Manufacturing Elements, Data Collection and Device Control Entity, Digital Twin Entity, and User Entity, each composed of Functional Entities. The implementation follows the ISO‑defined entity‑based approach and aligns software components with the corresponding functional entities. Communication and interoperability may employ OPC Unified Architecture (OPC UA) as suggested in the standard, although the actual deployment uses ROS 2 packages for intra‑twin communication."
]