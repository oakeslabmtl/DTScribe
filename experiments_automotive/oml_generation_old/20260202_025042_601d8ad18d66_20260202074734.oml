// Physical sensing components
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board speed sensor capturing vehicle speed data"
    DTDFVocab:producedData VehicleSpeedDataRaw
]

instance VehicleSteeringSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board steering angle sensor capturing steering data"
    DTDFVocab:producedData SteeringAngleDataRaw
]

instance LiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX LiDAR producing raw point cloud data"
    DTDFVocab:producedData LiDARRawPointCloud
]

instance DepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel Iris D435i depth camera producing raw depth image frames"
    DTDFVocab:producedData DepthRawImage
]

// Data transmitted (raw data)
instance LiDARRawPointCloud : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LiDARSensor
    base:desc "Raw LiDAR point cloud data transmitted over ROS2/DDS"
]

instance DepthRawImage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DepthCameraSensor
    base:desc "Raw depth image frame transmitted over ROS2/DDS"
]

instance VehicleSpeedDataRaw : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
    base:desc "Raw vehicle speed measurement transmitted over ROS2/DDS"
]

instance SteeringAngleDataRaw : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSteeringSensor
    base:desc "Raw steering angle measurement transmitted over ROS2/DDS"
]

// Processed data
instance LiDARProcessedTracks : DTDFVocab:Data [
    base:desc "Object tracks extracted from LiDAR point clouds using DBSCAN clustering"
    DTDFVocab:inputTo TrackingProcessingEnabler
    DTDFVocab:fromData LiDARRawPointCloud
]

instance DepthProcessedTracks : DTDFVocab:Data [
    base:desc "Object tracks extracted from depth images using DBSCAN clustering"
    DTDFVocab:inputTo TrackingProcessingEnabler
    DTDFVocab:fromData DepthRawImage
]

instance VehicleStateData : DTDFVocab:Data [
    base:desc "Combined vehicle speed and steering angle data serialized for digital twin"
    DTDFVocab:inputTo VehicleStateProcessingEnabler, ComputeOffloadingEnabler
    DTDFVocab:fromData VehicleSpeedDataRaw, SteeringAngleDataRaw
]

// Models
instance TrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering + Kalman filter tracking model processing LiDAR and depth data"
    DTDFVocab:inputTo TrackingProcessingEnabler
]

instance VehicleStateModel : DTDFVocab:Model [
    base:desc "Unit conversion and serialization model for speed and steering data"
    DTDFVocab:inputTo VehicleStateProcessingEnabler
]

instance ACCControlModel : DTDFVocab:Model [
    base:desc "ACC logic following ISO 15622 controlling desired speed"
    DTDFVocab:inputTo ComputeOffloadingEnabler
]

instance ThreeDVisualizationModel : DTDFVocab:Model [
    base:desc "Model for 3D rendering of vehicle and surrounding environment"
    DTDFVocab:inputTo VisualizationEnabler
]

instance SQLDatabaseStorageModel : DTDFVocab:Model [
    base:desc "SQL database model for storing vehicle state and track time-series logs"
    DTDFVocab:inputTo ReportGenerationEnabler
]

instance PresentationReportingModel : DTDFVocab:Model [
    base:desc "Presentation and reporting model generating human-readable reports for UI"
    DTDFVocab:inputTo ReportGenerationEnabler
]

// Enablers
instance VehicleStateProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that processes vehicle state data for monitoring and ACC"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

instance TrackingProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that processes LiDAR and depth data for tracking"
    DTDFVocab:enables DataMonitoringService
]

instance ComputeOffloadingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that runs ACC logic on Digital Twin"
    DTDFVocab:enables ComputationOffloadingService
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Enabler facilitating remote ACC management"
    DTDFVocab:enables RemoteManagementService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler providing 3D visualization capabilities"
    DTDFVocab:enables VisualizationService
]

instance ReportGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for storing logs and generating reports"
    DTDFVocab:enables ReportGenerationService
]

// Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time dashboard displaying ego speed, steering, object tracks, and projected path"
    DTDFVocab:provides VehicleSpeedInsight, SteeringAngleInsight, TrackInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "ACC logic executed on Digital Twin, returning desired speed command to vehicle"
    DTDFVocab:provides AdjustDesiredSpeedAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operator interface to enable/disable ACC, adjust desired speed, trigger emergency braking"
    DTDFVocab:provides EnableACCAction, DisableACCAction, EmergencyBrakeAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D rendering of vehicle and surroundings"
    DTDFVocab:provides ThreeDVisualizationInsight
]

instance ReportGenerationService : DTDFVocab:Service [
    base:desc "Generate human‑readable time‑series logs of vehicle state and tracks stored in SQL database"
    DTDFVocab:provides ReportGenerationInsight
]

// Insights
instance VehicleSpeedInsight : DTDFVocab:Insight [
    base:desc "Insight showing instantaneous vehicle speed"
]

instance SteeringAngleInsight : DTDFVocab:Insight [
    base:desc "Insight showing instantaneous steering angle"
]

instance TrackInsight : DTDFVocab:Insight [
    base:desc "Insight showing detected object tracks in real‑time"
]

instance ThreeDVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing 3D visualization of vehicle and environment"
]

instance ReportGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that detailed reports have been generated"
]

// Actions
instance AdjustDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Action to set desired speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Action to enable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Action to disable Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Action to trigger emergency braking"
    DTDFVocab:IsAutomatic false
]

// Components & Environment
instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Entity on vehicle ECU performing data pre‑processing (clustering, filtering)"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Cloud‑hosted Digital Twin performing ACC logic and analytics"
]

instance UserNode : DTDFVocab:Component [
    base:desc "Operator node with UI to monitor and control ACC"
]

instance CrossSystemNode : DTDFVocab:Component [
    base:desc "Cross‑system node facilitating inter‑vehicle communication and data sharing"
]

instance VehicleEnvironment : DTDFVocab:Environment [
    base:contains PhysicalTwinEntity, DigitalTwinEntity, UserNode, CrossSystemNode
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Desired speed and steering commands generated by the ACC Controlling FE are converted to motor voltage and servo signals and sent via the Data Translation FE to the vehicle’s actuators; user‑initiated remote commands (enable/disable ACC, set desired speed, emergency brake) are transmitted from the User Entity to the vehicle over the same ROS2/DDS network."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with a required end‑to‑end latency ≤100 ms from sensor data acquisition to actuation; clock synchronization accuracy of 100 ms across all distributed components; data collection and monitoring occur at sub‑100 ms intervals."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "ISO 23247 reference architecture instantiated as four entities; Physical Twin Entity hosts raw sensing/actuation, Digital Twin Entity hosts processing and modeling, User Entity hosts UI components, and Cross‑System Entity manages data translation; orchestrated via ROS2 topics over Wi‑Fi and internal ROS2 communication."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design/definition (capturing R1–R8 requirements), Development (architectural mapping to ISO 23247 and implementation in ROS2), Validation and deployment (cloud offload, latency testing), and Runtime Operation (live monitoring, remote management and data logging). The twin represents the vehicle as a manufactured, operated system with real‑time data exchange."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Safety‑critical latency constraint (≤100 ms) and clock synchronization (≤100 ms) ensure temporal fidelity; data integrity maintained by Data Translation FE; model validity supported by SL and report generation; however, formal verification steps are not detailed in the document."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑entity communication over IEEE 802.11 Wi‑Fi using ROS 2 DDS; intra‑entity internal communication using ROS 2 topics; data serialization handled by Data Translation FE; optional use of OPC UA for data translation (not explicitly implemented)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "On‑board execution on NVIDIA Jetson Orin Nano and vehicle ECU; compute offloading performed on a cloud host (unspecified platform) to handle ACC logic; persistent data storage in an external SQL database, possibly hosted on the same cloud infrastructure."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "ISO 23247 (Reference Architecture), ISO 15622 (ACC control), ROS 2 open standard, optional OPC UA for data translation; adherence to automotive standards via ISO 15622."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical end‑to‑end latency ≤100 ms and 100 ms clock synchronization applied; ACC control conforms to ISO 15622; no explicit cybersecurity mechanisms (e.g., encryption, authentication) are detailed in the document."
]