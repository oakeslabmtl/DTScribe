    base:desc "Offline troubleshooting using historical data and real-time monitoring"
    DTDFVocab:IsAutomatic false
]

// C13: Environment
instance AutonomousVehicleEnvironment : DTDFVocab:Environment [
    base:contains LiDARSensorCluster, RadarSensorArray, VehicleSpeedSensor,
               PositionTrackingSensor, MotorActuationSensor,
               SteeringFeedbackSensor, AdaptiveSpeedController,
               EmergencyBrakeActuator, SteeringCommandGenerator,
               ProjectedDrivingPathModel, ObjectTrackingModel,
               ACCControlLogicModel, SafetyValidationModel,
               DataFusionEngine, CloudComputeCluster,
               ROS2CommunicationLayer, WiFiUDPTransport,
               TimeSeriesDatabase, DataPreProcessingEngine,
               DataTranslationEngine, DataReportingEngine,
               RealTimeMonitoringService, DynamicPathVisualizationService,
               RemoteManagementService
]

// C12: Data
instance RawLiDARData : DTDFVocab:Data [
    base:desc "Raw 2D LiDAR point cloud data from sensor acquisition events"
