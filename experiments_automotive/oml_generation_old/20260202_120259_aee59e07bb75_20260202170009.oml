// C2: Acting Components
instance AdaptiveSpeedController : DTDFVocab:Actuator [
    base:desc "Cloud-based PID controller implementing speed adjustment logic for ACC based on lead vehicle distance and safety margins"
]

instance EmergencyBrakeActuator : DTDFVocab:Actuator [
    base:desc "Low-latency emergency braking system triggered via remote operator commands or real-time safety algorithms"
]

instance SteeringCommandGenerator : DTDFVocab:Actuator [
    base:desc "Generates steering commands for ACC system based on projected driving paths and object tracks"
]

// C3: Physical Sensing Components
instance LiDARSensorCluster : DTDFVocab:SensingComponent [
    base:desc "2D LiDAR sensor suite providing raw point clouds for object detection and environment perception"
    DTDFVocab:producedData LiDARPointCloudStream
]

instance RadarSensorArray : DTDFVocab:SensingComponent [
    base:desc "Radar system detecting lead vehicles and obstacles with fusion capabilities for proximity tracking"
    DTDFVocab:producedData RadarObjectDetectionStream
]

instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On-board speed sensor measuring instantaneous vehicle velocity for ACC state monitoring"
    DTDFVocab:producedData VehicleStateMetricsStream
]

instance PositionTrackingSensor : DTDFVocab:SensingComponent [
    base:desc "GPS/IMU system tracking vehicle position and orientation for path projection"
    DTDFVocab:producedData VehicleStateMetricsStream
]

instance MotorActuationSensor : DTDFVocab:SensingComponent [
    base:desc "Feedback sensor monitoring motor actuation signals for control loop validation"
    DTDFVocab:producedData ActuationCommandStream
]

instance SteeringFeedbackSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor providing real-time steering angle feedback for ACC system validation"
    DTDFVocab:producedData SteeringCommandGenerator
]

// C4: Data Transmission Components
instance LiDARPointCloudStream : DTDFVocab:DataTransmitted [
    base:desc "Raw 2D LiDAR point cloud data processed via Point Cloud Clustering & Tracking software"
    DTDFVocab:producedFrom LiDARSensorCluster
]

instance RadarObjectDetectionStream : DTDFVocab:DataTransmitted [
    base:desc "Processed radar data generating structured object tracks and proximity information"
    DTDFVocab:producedFrom RadarSensorArray
]

instance VehicleStateMetricsStream : DTDFVocab:DataTransmitted [
    base:desc "Aggregated vehicle state metrics including speed, position, and orientation"
    DTDFVocab:producedFrom VehicleSpeedSensor, PositionTrackingSensor
]

instance ActuationCommandStream : DTDFVocab:DataTransmitted [
    base:desc "Control commands sent to vehicle actuators (speed, steering) for ACC execution"
    DTDFVocab:producedFrom AdaptiveSpeedController, SteeringCommandGenerator
]

instance SensorFusionOutputStream : DTDFVocab:DataTransmitted [
    base:desc "Fused sensor data generating projected driving paths and object tracks"
    DTDFVocab:producedFrom LiDARPointCloudStream, RadarObjectDetectionStream
]

// C10: Models
instance ProjectedDrivingPathModel : DTDFVocab:Model [
    base:desc "Dynamic path projection model generating ACC speed adjustments based on lead vehicle distance"
    DTDFVocab:inputTo DataFusionEngine
]

instance ObjectTrackingModel : DTDFVocab:Model [
    base:desc "Kalman/particle filter model tracking detected objects (lead vehicles, obstacles) in vehicle's proximity"
    DTDFVocab:inputTo DataFusionEngine
]

instance ACCControlLogicModel : DTDFVocab:Model [
    base:desc "PID controller implementation for adaptive cruise control speed regulation"
    DTDFVocab:inputTo CloudComputeCluster
]

instance SafetyValidationModel : DTDFVocab:Model [
    base:desc "Safety-critical validation model ensuring low-latency emergency braking fallback mechanisms"
    DTDFVocab:inputTo CloudComputeCluster
]

// C11: Enablers
instance DataFusionEngine : DTDFVocab:Enabler [
    base:desc "Real-time data fusion algorithms (Kalman/particle filters) integrating LiDAR/radar inputs"
    DTDFVocab:enables ProjectedDrivingPathModel, ObjectTrackingModel
]

instance CloudComputeCluster : DTDFVocab:Enabler [
    base:desc "Distributed cloud infrastructure handling ACC computations offloaded from on-board ECUs"
    DTDFVocab:enables ACCControlLogicModel, SafetyValidationModel
]

instance ROS2CommunicationLayer : DTDFVocab:Enabler [
    base:desc "ROS2 middleware enabling intra-entity real-time synchronization between components"
    DTDFVocab:enables LiDARPointCloudStream, RadarObjectDetectionStream,
                   VehicleStateMetricsStream, ActuationCommandStream,
                   SensorFusionOutputStream
]

instance WiFiUDPTransport : DTDFVocab:Enabler [
    base:desc "Low-latency Wi-Fi UDP communication protocol for vehicle-to-cloud data transfer"
    DTDFVocab:enables LiDARPointCloudStream, RadarObjectDetectionStream,
                   VehicleStateMetricsStream, ActuationCommandStream,
                   SensorFusionOutputStream
]

instance DataPreProcessingEngine : DTDFVocab:Enabler [
    base:desc "Data preprocessing modules filtering noise, aligning message types, and performing unit conversions"
    DTDFVocab:inputTo LiDARPointCloudStream, RadarObjectDetectionStream,
                   VehicleStateMetricsStream, SensorFusionOutputStream
]

instance DataTranslationEngine : DTDFVocab:Enabler [
    base:desc "Data translation component serializing and aligning message types for inter-entity compatibility"
    DTDFVocab:inputTo ROS2CommunicationLayer
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time-series database storing real-time vehicle state data and historical reports"
    DTDFVocab:inputTo DataReportingEngine
]

instance DataReportingEngine : DTDFVocab:Enabler [
    base:desc "Report generation engine capturing aggregated metrics for post-mission analysis"
    DTDFVocab:inputTo TimeSeriesDatabase
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of vehicle state data (speed, position, sensor readings) via user interface"
    DTDFVocab:provides RealTimeVisualizationInsight, HistoricalDataAnalysisAction
]

instance DataReportingService : DTDFVocab:Service [
    base:desc "Support for saving and generating reports of historical data for post-mission analysis"
    DTDFVocab:provides HistoricalDataAnalysisAction
]

instance DynamicPathVisualizationService : DTDFVocab:Service [
    base:desc "Dynamic display of projected driving paths and detected object tracks within vehicle's proximity"
    DTDFVocab:provides PathProjectionInsight, ObjectTrackingInsight
]

instance LatencySensitiveStreamService : DTDFVocab:Service [
    base:desc "Latency-sensitive data streams for critical ACC operations (emergency braking commands)"
    DTDFVocab:provides EmergencyBrakeAction
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloads ACC-specific computations from on-board ECUs to cloud-based infrastructure"
    DTDFVocab:provides AsynchronousControlAction, NearSynchronousControlAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Remote enable/disable of ACC functions with low end-to-end latency"
    DTDFVocab:provides OperatorControlAction, DeveloperDebugAction
]

// C17: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "User interface displaying real-time vehicle state data (speed, position, sensor readings)"
]

instance HistoricalDataAnalysisAction : DTDFVocab:Action [
    base:desc "Generates and stores historical data reports for post-mission analysis"
    DTDFVocab:IsAutomatic false
]

instance PathProjectionInsight : DTDFVocab:Insight [
    base:desc "Visual representation of projected driving paths based on lead vehicle distance"
]

instance ObjectTrackingInsight : DTDFVocab:Insight [
    base:desc "Dynamic display of detected object tracks (lead vehicles, obstacles) in vehicle's proximity"
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Emergency braking command triggered via safety algorithms or operator input"
    DTDFVocab:IsAutomatic true
]

instance AsynchronousControlAction : DTDFVocab:Action [
    base:desc "Asynchronous communication between physical and digital twins for control actuation"
    DTDFVocab:IsAutomatic true
]

instance NearSynchronousControlAction : DTDFVocab:Action [
    base:desc "Near-synchronous communication ensuring real-time control feedback"
    DTDFVocab:IsAutomatic true
]

instance OperatorControlAction : DTDFVocab:Action [
    base:desc "Remote operator commands enabling/disabling ACC functions with low latency"
    DTDFVocab:IsAutomatic false
]

