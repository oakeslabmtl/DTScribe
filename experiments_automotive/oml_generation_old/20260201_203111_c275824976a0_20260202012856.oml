// C3: Physical sensing components
instance LidarSensor : DTDFVocab:SensingComponent [
    base:desc "LiDAR sensor providing 3‑D point‑cloud data of the environment"
    DTDFVocab:producedData LidarPointCloudTransmitted
]

instance MotorStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing the current motor state of the vehicle"
    DTDFVocab:producedData MotorStateTransmitted
]

instance SteeringServoSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting the steering servo position"
    DTDFVocab:producedData SteeringServoPosTransmitted
]

instance VehicleStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor aggregating overall vehicle state such as speed, pose, and battery level"
    DTDFVocab:producedData VehicleStateTransmitted
]

// C4: Physical‑to‑virtual interaction (Data Transmitted)
instance LidarPointCloudTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LidarSensor
]

instance MotorStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorStateSensor
]

instance SteeringServoPosTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringServoSensor
]

instance VehicleStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance ObjectTrackTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LidarSensor
]

instance SpeedCommandTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

instance PathProjectionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleStateSensor
]

// C10: Data instances
instance RawLidarData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud samples before clustering"
    DTDFVocab:fromData LidarPointCloudTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance RawMotorStateData : DTDFVocab:Data [
    base:desc "Raw motor state values"
    DTDFVocab:fromData MotorStateTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance RawSteeringPosData : DTDFVocab:Data [
    base:desc "Raw steering servo position values"
    DTDFVocab:fromData SteeringServoPosTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance RawVehicleStateData : DTDFVocab:Data [
    base:desc "Raw aggregated vehicle state information"
    DTDFVocab:fromData VehicleStateTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance ObjectTrackData : DTDFVocab:Data [
    base:desc "Tracked object detections derived from LiDAR clustering"
    DTDFVocab:fromData ObjectTrackTransmitted
    DTDFVocab:inputTo UIEnabler
]

instance SpeedCommandData : DTDFVocab:Data [
    base:desc "Speed command generated by ACC computation"
    DTDFVocab:fromData SpeedCommandTransmitted
    DTDFVocab:inputTo ROS2MiddlewareEnabler
]

instance ProjectedPathData : DTDFVocab:Data [
    base:desc "Projected vehicle path for operator visualization"
    DTDFVocab:fromData PathProjectionTransmitted
    DTDFVocab:inputTo UIEnabler
]

// C10: Models
instance PointCloudClusteringModel : DTDFVocab:Model [
    base:desc "Clusters and tracks 2‑D LiDAR point samples into detected object tracks"
    DTDFVocab:inputTo CloudComputeEnabler
]

instance ACCComputationModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control algorithm that detects lead vehicle and computes desired speed"
    DTDFVocab:inputTo CloudComputeEnabler
]

instance PathProjectionModel : DTDFVocab:Model [
    base:desc "Projects future vehicle path based on current state and environment"
    DTDFVocab:inputTo UIEnabler
]

// C11: Enablers
instance ROS2MiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "ROS2 publish/subscribe middleware over Wi‑Fi UDP linking Physical Twin, Digital Twin, and User entities"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

instance CloudComputeEnabler : DTDFVocab:Enabler [
    base:desc "Cloud computing infrastructure that hosts offloaded ACC logic"
    DTDFVocab:enables ComputationOffloadingService
]

instance UIEnabler : DTDFVocab:Enabler [
    base:desc "User interface application providing 3‑D visualization and control commands"
    DTDFVocab:enables DataMonitoringService, RemoteManagementService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Streams real‑time vehicle state, projected path, and nearby object tracks to a graphical UI"
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Executes ACC algorithm in the cloud and returns speed command to the vehicle"
    DTDFVocab:provides ExecuteACCAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Allows operators to enable/disable ACC, set desired speed, and issue emergency‑brake commands remotely"
    DTDFVocab:provides EnableACCAction, DisableACCAction, SetDesiredSpeedAction, EmergencyBrakeAction
]

// C17: Insights / Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides operators with live 3‑D visualization of vehicle state, object tracks, and projected path"
]

instance ExecuteACCAction : DTDFVocab:Action [
    base:desc "Run Adaptive Cruise Control algorithm on cloud resources"
    DTDFVocab:IsAutomatic true
]

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Activate ACC functionality via remote command"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Deactivate ACC functionality via remote command"
    DTDFVocab:IsAutomatic false
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Set target speed for the vehicle"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Issue emergency brake command to the vehicle"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components (Physical Twin actuation)
instance SpeedCommandActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator that receives speed commands from the Digital Twin and controls the vehicle motor"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator that executes emergency brake commands issued by the Remote Management service"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin Entity generates control commands for the physical twin through its Controlling FE (ACC). Commands include enable/disable ACC, set‑desired‑speed, emergency‑brake, and the computed desired speed that the vehicle must actuate. These commands are passed to the Data Translation FE for serialisation, message‑type alignment and unit conversion, then transmitted over the Wi‑Fi UDP link to the Physical Twin Entity. The Actuation FE on the physical side receives the commands and drives the motor and steering servo actuators. Vehicle‑state feedback is continuously streamed back via the same data‑translation pipeline, providing confirmation of command execution. The documents do not detail explicit validation or authentication mechanisms, but the system is described as safety‑critical and must meet low‑latency requirements."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system requires a shared notion of time among devices to support computation offloading. Clock synchronization must achieve at least 100 ms accuracy, which is the imposed limit due to hardware constraints and conforms to safety‑critical vehicular standards. No finer granularity or latency figures are provided."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated according to the ISO 23247 reference architecture. Software components are identified, mapped to Functional Entities, and each Functional Entity is implemented as an individual ROS 2 package containing one or more ROS 2 nodes. Entities are deployed on distinct compute resources (e.g., separate hardware for Physical Twin, Digital Twin, and User entities), providing a distributed, entity‑based orchestration. Coordination relies on the entity relationships defined in ISO 23247 and on ROS 2 communication mechanisms."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The architecture mandates a shared notion of time across devices, requiring clock‑synchronisation accuracy of 100 ms for safety‑critical vehicular applications, which constitutes a fidelity requirement for data exchange and control. No additional model validation, verification, uncertainty quantification, or error‑correction procedures are described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin System uses a mixed network architecture. Inside each hardware platform, all functional entities are implemented as ROS 2 packages; each package contains one or more ROS 2 nodes that communicate over ROS 2 topics for intra‑entity data exchange. Across entities (Physical Twin, Digital Twin, User Entity) communication is performed over a Wi‑Fi network using UDP at the transport layer. Clock synchronisation across devices is required; standards for safety‑critical vehicular applications demand sub‑100 ms accuracy, and the system targets a 100 ms synchronisation tolerance. The DT must provide low end‑to‑end latency for ACC operation, though exact latency budgets are not quantified. No explicit bandwidth, redundancy, or security protocols are mentioned in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The documents reference ISO 23247 Part 4 (Information exchange) and note that Functional Entities may be realized using standards such as OPC Unified Architecture, but no concrete data‑exchange protocol, interoperability layer, or integration with external enterprise systems is described. Hence, specific horizontal integration details are not provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin system is built on the ISO 23247 standard for manufacturing digital twins. It follows Part 2 of the standard, which defines an entity‑based reference architecture (Data Collection and Device Control Entity, Digital Twin Entity, User Entity, and Observable Manufacturing Element). The design explicitly maps software components to Functional Entities as prescribed by the ISO 23247 RA. OPC Unified Architecture is cited as an example protocol that can be used to implement data exchange between functional entities, reflecting compliance with the standard’s recommended communication mechanisms. The implementation acknowledges deviations (e.g., introduction of a Physical Twin Entity) but remains anchored to the ISO 23247 framework, indicating intentional alignment with that industry standard."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The case study reports that the ISO 23247 reference architecture (RA) does not address safety‑critical requirements for automotive digital twins. It recommends elevating safety to a first‑class concern by integrating the functional‑safety standard ISO 26262 (ISO 26262‑1:2018) into the DT design. Safety analysis, risk assessment and fail‑safe mechanisms defined in ISO 26262 should be applied to the DT components (e.g., Data Pre‑Processing FE, Actuation FE) deployed on the physical twin. The authors note that existing automotive standards such as AUTOSAR provide hardware‑agnostic component definitions that can be reused within the DT to support safety‑critical deployments."
]