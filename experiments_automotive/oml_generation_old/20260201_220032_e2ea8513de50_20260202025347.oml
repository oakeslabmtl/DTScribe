// Acting Components
instance ElectronicSpeedControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Electronic speed controller (Vedder) issuing motor voltage commands to drive the vehicle"
]

instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Steering servo actuator controlling the front wheel steering angle"
]

instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Emergency brake actuator allowing the DT to trigger a rapid stop"
]

// Physical Sensing Components
instance HokuyoLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑10LX 2‑D LiDAR providing 270° point‑cloud scans"
    DTDFVocab:producedData LiDARPointCloudTransmission
]

instance IntelRealSenseDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering RGB‑D images and IMU data"
    DTDFVocab:producedData DepthImageTransmission
]

instance WheelEncoderSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel‑encoder based sensor measuring vehicle forward speed"
    DTDFVocab:producedData SpeedDataTransmission
]

instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Steering‑angle sensor reporting current servo position"
    DTDFVocab:producedData SteeringAngleTransmission
]

// Data Transmitted
instance LiDARPointCloudTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARSensor
]

instance DepthImageTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelRealSenseDepthCamera
]

instance SpeedDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelEncoderSpeedSensor
]

instance SteeringAngleTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// Data
instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Raw LiDAR point‑cloud data used for object clustering"
    DTDFVocab:fromData LiDARPointCloudTransmission
    DTDFVocab:inputTo DBSCANClusteringEnabler
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames used for visualization and perception"
    DTDFVocab:fromData DepthImageTransmission
    DTDFVocab:inputTo VisualizationEnabler
]

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Measured forward speed of the ego vehicle"
    DTDFVocab:fromData SpeedDataTransmission
    DTDFVocab:inputTo ACCControlEnabler
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Current steering angle of the vehicle"
    DTDFVocab:fromData SteeringAngleTransmission
    DTDFVocab:inputTo ACCControlEnabler
]

// Models
instance DBSCANClusteringModel : DTDFVocab:Model [
    base:desc "DBSCAN point‑cloud clustering algorithm implemented with the DBSCAN library"
    DTDFVocab:inputTo DBSCANClusteringEnabler
]

instance KalmanFilterTrackingModel : DTDFVocab:Model [
    base:desc "Kalman‑filter based multi‑target tracker"
    DTDFVocab:inputTo KalmanFilterTrackingEnabler
]

instance ACCControllerModel : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control controller following ISO 15622 performance‑class I logic"
    DTDFVocab:inputTo ACCControlEnabler
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model rendering vehicle state, object tracks and projected path"
    DTDFVocab:inputTo VisualizationEnabler
]

// Enablers
instance DBSCANClusteringEnabler : DTDFVocab:Enabler [
    base:desc "Runs DBSCAN clustering on incoming LiDAR point clouds using ROS 2 and the DBSCAN library"
    DTDFVocab:enables ComputationOffloadingService
]

instance KalmanFilterTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Executes Kalman‑filter tracking on clustered objects"
    DTDFVocab:enables ComputationOffloadingService
]

instance ACCControlEnabler : DTDFVocab:Enabler [
    base:desc "Computes ACC speed command based on tracked lead vehicle and desired speed"
    DTDFVocab:enables ComputationOffloadingService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Provides real‑time 3‑D visualisation using the Visualization3DModel"
    DTDFVocab:enables DataMonitoringUI
]

instance RemoteManagementEnabler : DTDFVocab:Enabler [
    base:desc "Exposes ROS 2 services over Wi‑Fi (optional OPC‑UA) for operator interaction"
    DTDFVocab:enables RemoteManagementUI
]

instance ReportingEnabler : DTDFVocab:Enabler [
    base:desc "Generates time‑series performance reports and stores them in an SQL database using Python"
    DTDFVocab:enables ReportingService
]

// Services
instance DataMonitoringUI : DTDFVocab:Service [
    base:desc "User interface visualising real‑time vehicle state, object tracks and projected path"
    DTDFVocab:provides RealTimeVehicleStateInsight, ProjectedPathInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Off‑loads ACC perception and control computations to edge/cloud resources"
    DTDFVocab:provides LeadVehicleDetectionInsight, SpeedCommandGenerationAction
]

instance RemoteManagementUI : DTDFVocab:Service [
    base:desc "Remote operator console to adjust ACC parameters and issue emergency brake"
    DTDFVocab:provides SetDesiredSpeedAction, EnableDisableACCAction, TriggerEmergencyBrakeAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Generates and archives performance reports in an SQL database"
    DTDFVocab:provides PerformanceReportInsight
]

// Insights
instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time visual insight into vehicle state and projected path"
]

instance ProjectedPathInsight : DTDFVocab:Insight [
    base:desc "Projected future trajectory based on current ACC command"
]

instance LeadVehicleDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection and classification of the lead vehicle from clustered and tracked objects"
]

instance PerformanceReportInsight : DTDFVocab:Insight [
    base:desc "Generated performance reports summarising ACC behaviour over a mission"
]

// Actions
instance SpeedCommandGenerationAction : DTDFVocab:Action [
    base:desc "Autonomously decides the appropriate speed command for ACC based on lead‑vehicle detection"
    DTDFVocab:IsAutomatic true
]

instance SetDesiredSpeedAction : DTDFVocab:Action [
    base:desc "Operator sets the desired cruising speed for ACC"
    DTDFVocab:IsAutomatic false
]

instance EnableDisableACCAction : DTDFVocab:Action [
    base:desc "Operator enables or disables the ACC function"
    DTDFVocab:IsAutomatic false
]

instance TriggerEmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator issues an emergency brake command to stop the vehicle immediately"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT over the same Wi‑Fi/ROS 2 channel: desired speed values for the ACC, enable/disable ACC commands, emergency‑brake command, and any steering adjustments, which are converted by the Actuation functional entity into motor voltage or servo signals."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates with a hard end‑to‑end latency bound of 100 ms between vehicle and DT, and all distributed clocks are synchronised to within 100 ms accuracy."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Sensor data from the PT are ingested by the Physical Twin Entity (data pre‑processing and actuation FEs), passed via the Data Translation FE to the Digital Twin Entity (data collection, ACC, reporting, visualization, storage), while the User Entity provides a 3D visualization and control‑panel UI; all entities communicate over ROS 2 on‑board and Wi‑Fi between vehicle and remote host."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is used during the operational stage of the vehicle, supporting both development/testing (simulation and debugging) and runtime operation (monitoring, remote control, and data logging)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity sensor data (LiDAR point clouds) are processed with DBSCAN and Kalman filtering to ensure accurate object tracking; the ACC algorithm conforms to ISO 15622 performance class I; latency is bounded to ≤100 ms and clocks synchronised within 100 ms to preserve temporal coherence; storage of raw data enables post‑hoc validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication between PT and DT uses a standard Wi‑Fi network (IP‑based) with ROS 2 as the middleware; a Data Translation functional entity handles serialization, message type alignment and unit conversion; the underlying transport is typical TCP/UDP over IP (not explicitly named)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the vehicle‑mounted NVIDIA Jetson Orin Nano; Digital Twin Entity and User Entity execute on a remote compute platform (cloud or edge server) capable of off‑loading ACC computation; ROS 2 packages are used for deployment on each node."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system follows ISO 23247 (Digital Twin Manufacturing Framework) for architecture, ISO 15622 for ACC functionality, and ISO/IEC 30173:2023 for digital‑twin terminology; ROS 2 and OPC UA are referenced as middleware/transport standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT is designed for a safety‑critical ADAS application with strict latency (≤100 ms) and clock‑sync (≤100 ms) requirements; remote commands (enable/disable ACC, emergency brake) are handled via controlled interfaces, but specific cybersecurity measures are not described in the document."
]