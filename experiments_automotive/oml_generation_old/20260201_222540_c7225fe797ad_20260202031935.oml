// =============================================================
// Physical Sensing Components
// =============================================================

// C3: Physical sensing component – Hokuyo LiDAR
instance HokuyoLiDARUST110LX : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST‑110LX 2‑D LiDAR providing real‑time point clouds via ROS2 topics"
    DTDFVocab:producedData LiDARPointCloudTrans
]

// C3: Physical sensing component – Intel DeepSense Depth Camera
instance IntelDeepSenseD435iDepthCamera : DTDFVocab:SensingComponent [
    base:desc "Intel RealSense D435i depth camera delivering depth images and IMU data over ROS2"
    DTDFVocab:producedData DepthImageTrans
]

// C3: Physical sensing component – Ego Vehicle Speed Sensor
instance EgoVehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board sensor measuring vehicle forward speed, published on ROS2"
    DTDFVocab:producedData VehicleSpeedTrans
]

// C3: Physical sensing component – Steering Angle Sensor
instance SteeringAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor reporting steering angle of the 1/10‑scale vehicle via ROS2"
    DTDFVocab:producedData SteeringAngleTrans
]

// =============================================================
// Physical Acting Components
// =============================================================

// C2: Acting component – Motor Voltage Actuator (speed control)
instance MotorVoltageActuator : DTDFVocab:ActingComponent [
    base:desc "Motor voltage actuator driving vehicle speed, controlled by the Physical Twin Actuation FE"
]

// C2: Acting component – Steering Servo Actuator
instance SteeringServoActuator : DTDFVocab:ActingComponent [
    base:desc "Servo actuator adjusting steering angle, commanded by the Physical Twin Actuation FE"
]

// C2: Acting component – Emergency Brake Actuator
instance EmergencyBrakeActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator used to trigger rapid motor shutdown for emergency braking"
]

// =============================================================
// Data Transmitted (Physical‑to‑Virtual)
// =============================================================

instance LiDARPointCloudTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARUST110LX
]

instance DepthImageTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDeepSenseD435iDepthCamera
]

instance VehicleSpeedTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EgoVehicleSpeedSensor
]

instance SteeringAngleTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SteeringAngleSensor
]

// =============================================================
// Data (Virtual)
// =============================================================

instance LiDARPointCloudData : DTDFVocab:Data [
    base:desc "Timestamped 3‑D point cloud generated from LiDAR scans"
    DTDFVocab:fromData LiDARPointCloudTrans
    DTDFVocab:inputTo ROS2Middleware
]

instance DepthImageData : DTDFVocab:Data [
    base:desc "Depth image frames with associated IMU poses"
    DTDFVocab:fromData DepthImageTrans
    DTDFVocab:inputTo ROS2Middleware
]

instance EgoSpeedData : DTDFVocab:Data [
    base:desc "Real‑time vehicle forward speed readings"
    DTDFVocab:fromData VehicleSpeedTrans
    DTDFVocab:inputTo ROS2Middleware
]

instance SteeringAngleData : DTDFVocab:Data [
    base:desc "Real‑time steering angle measurements"
    DTDFVocab:fromData SteeringAngleTrans
    DTDFVocab:inputTo ROS2Middleware
]

// =============================================================
// Models / Algorithms
// =============================================================

instance DBSCANKalmanTrackingModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering combined with a Kalman filter for multi‑object tracking"
    DTDFVocab:inputTo MATLABSimulinkClusteringTool
]

instance ACCControlModelISO15622 : DTDFVocab:Model [
    base:desc "Adaptive Cruise Control model following ISO 15622 for lead‑vehicle detection and speed computation"
    DTDFVocab:inputTo Python38Runtime
]

instance Visualization3DModel : DTDFVocab:Model [
    base:desc "3‑D visualization model rendering vehicle state, object tracks and projected path in the UI"
    DTDFVocab:inputTo UIFramework
]

// =============================================================
// Enablers (Tooling & Infrastructure)
// =============================================================

instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 DDS middleware enabling intra‑entity communication over Wi‑Fi (IEEE 802.11)"
    DTDFVocab:enables DataMonitoringService
]

instance Python38Runtime : DTDFVocab:Enabler [
    base:desc "Python 3.8 runtime executing the ACC algorithm on the Digital Twin compute node"
    DTDFVocab:enables ComputationOffloadingService
]

instance MATLABSimulinkClusteringTool : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment providing DBSCAN and Kalman filter libraries"
    DTDFVocab:enables ComputationOffloadingService
]

instance UIFramework : DTDFVocab:Enabler [
    base:desc "User‑interface framework (e.g., Qt) delivering visual insights and operator actions"
    DTDFVocab:enables RemoteManagementService
]

instance WiFi80211Link : DTDFVocab:Enabler [
    base:desc "IEEE 802.11 Wi‑Fi link for inter‑entity data exchange between PT and DT"
]

instance NVIDIAJetPack5SDK : DTDFVocab:Enabler [
    base:desc "NVIDIA JetPack 5.0 SDK supporting GPU‑accelerated processing on Jetson platforms"
]

instance SQLDatabase : DTDFVocab:Enabler [
    base:desc "SQL database persisting object tracks, ego speed, steering angle and timestamped sensor readings"
]

// =============================================================
// Services
// =============================================================

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "UI visualises real‑time speed, steering angle, object tracks, projected path and generates time‑series reports"
    DTDFVocab:provides RealTimeVehicleStateInsight, PostRunReportInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Runs ACC algorithm in the Digital Twin and returns the desired speed to the Physical Twin"
    DTDFVocab:provides DesiredSpeedInsight
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Operators can enable/disable ACC, modify desired speed, and trigger emergency braking via the UI"
    DTDFVocab:provides EnableACCAction, DisableACCAction, AdjustTargetSpeedAction, EmergencyBrakeAction
]

// =============================================================
// Insights
// =============================================================

instance RealTimeVehicleStateInsight : DTDFVocab:Insight [
    base:desc "Live visual insight into vehicle speed, steering angle and surrounding objects"
]

instance PostRunReportInsight : DTDFVocab:Insight [
    base:desc "Generated time‑series report for post‑run analysis of vehicle behavior"
]

instance DesiredSpeedInsight : DTDFVocab:Insight [
    base:desc "Desired speed computed by the ACC model for the vehicle to follow"
]

// =============================================================
// Actions
// =============================================================

instance EnableACCAction : DTDFVocab:Action [
    base:desc "Operator command to activate Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance DisableACCAction : DTDFVocab:Action [
    base:desc "Operator command to deactivate Adaptive Cruise Control"
    DTDFVocab:IsAutomatic false
]

instance AdjustTargetSpeedAction : DTDFVocab:Action [
    base:desc "Operator modifies the target speed setpoint for ACC"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakeAction : DTDFVocab:Action [
    base:desc "Operator triggers emergency braking via the motor actuator"
    DTDFVocab:IsAutomatic false
]

// =============================================================
// Entity Components (Multiplicity)
// =============================================================

instance PhysicalTwinEntity : DTDFVocab:Component [
    base:desc "Physical Twin hosted on the on‑vehicle Jetson; contains sensors and actuators"
]

instance DigitalTwinEntity : DTDFVocab:Component [
    base:desc "Digital Twin hosted on off‑vehicle compute; runs models and services"
]

instance UserEntity : DTDFVocab:Component [
    base:desc "User Entity providing UI interaction for monitoring and remote management"
]

instance CrossSystemEntity : DTDFVocab:Component [
    base:desc "Cross‑System Entity responsible for data translation and unit conversion between PT and DT"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends computed desired speed commands, enable/disable ACC flags, emergency braking signals, and optional steering adjustments back to the PT over a Wi‑Fi link; the Actuation FE translates these commands into motor voltage and servo signals for execution on the vehicle."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system is designed for sub‑second operation: network latency is bounded to ≤100 ms (per 3GPP TS‑22.185) and clocks on all DTS components are synchronised to an accuracy of 100 ms, enabling real‑time data collection and control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A layered architecture following ISO 23247: Physical Twin Entity (sensors and actuators), Digital Twin Entity (data collection, ACC, reporting, visualization), User Entity (3D visualization and control panel UI), and Cross‑System Entity (data translation); each functional entity is implemented as an independent ROS2 package and deployed on distinct hardware platforms."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during development (developers use data collection and monitoring to troubleshoot) and during operation (operators monitor and remotely manage ACC), thus covering both the design/testing and runtime stages of the vehicle lifecycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High‑fidelity sensor data (LiDAR point clouds) are processed in real time; synchronization to 100 ms ensures temporal coherence; ACC behaviour conforms to ISO 15622 performance class I; latency and clock‑sync constraints are enforced to maintain safety‑critical operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication over a Wi‑Fi network linking the vehicle’s Jetson board to the off‑board DT host; ROS2 topics carry sensor streams and control commands; the Data Translation FE handles serialization, message‑type alignment, and unit conversion."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Physical Twin Entity runs on the on‑board NVIDIA Jetson Orin Nano; Digital Twin Entity and User Entity run on an external compute platform (e.g., a PC or cloud instance); each functional entity is packaged as a separate ROS2 node set for independent deployment."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows ISO 23247 (Digital Twin Manufacturing Framework) reference architecture, leverages ISO 15622 for ACC functionality, and aligns with ISO/IEC 30173 conceptual definitions of digital twins."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is addressed by enforcing a maximum 100 ms end‑to‑end latency and clock synchronization to 100 ms, complying with ISO 15622 ACC performance class; however, explicit security mechanisms (authentication, encryption) are not described in the document."
]