// C2: Acting Components
instance SteeringActuator : DTDFVocab:ActingComponent [
    base:desc "Lower-level chassis steering actuator controlled via Vedder Electronic Speed Controller for autonomous steering adjustments"
]

instance SpeedControlActuator : DTDFVocab:ActingComponent [
    base:desc "Lower-level chassis speed control actuator managed by Vedder Electronic Speed Controller for adaptive cruise control speed modulation"
]

instance AutonomyControlActuator : DTDFVocab:ActingComponent [
    base:desc "Upper-level chassis autonomy actuator hosting NVIDIA Jetson Orin Nano for high-level ACC control logic execution"
]

// C3: Physical Sensing Components
instance JetsonNXSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded NVIDIA Jetson NX processor for real-time data processing and autonomy algorithms"
    DTDFVocab:producedData JetsonNXProcessedData
]

instance JetsonOrinNanoSensor : DTDFVocab:SensingComponent [
    base:desc "NVIDIA Jetson Orin Nano processor for compute offloading of ACC control logic"
    DTDFVocab:producedData JetsonOrinNanoProcessedData
]

instance HokuyoLiDARSensor : DTDFVocab:SensingComponent [
    base:desc "Hokuyo UST-10LX LiDAR providing 3D object detection with 10m range and 0.5° angular resolution"
    DTDFVocab:producedData LiDARPointCloudData
]

instance IntelDepthCameraSensor : DTDFVocab:SensingComponent [
    base:desc "Intel Deepsense D435i Depth Camera for environmental perception with 50° field of view and 20Hz update rate"
    DTDFVocab:producedData DepthCameraData
]

// C4: Physical-to-Virtual Interaction
instance JetsonNXProcessedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JetsonNXSensor
]

instance JetsonOrinNanoProcessedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JetsonOrinNanoSensor
]

instance LiDARPointCloudData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARSensor
]

instance DepthCameraData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IntelDepthCameraSensor
]

instance EgoVehicleStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JetsonNXSensor, JetsonOrinNanoSensor
    base:desc "Real-time ego vehicle state data (speed, steering angle) generated via DBSCAN clustering + Kalman filter tracking"
]

instance ObjectTrackData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HokuyoLiDARSensor, IntelDepthCameraSensor
    base:desc "Object tracks (position/velocity) generated via DBSCAN clustering + Kalman filter tracking from LiDAR and depth camera data"
]

// C10: Models/Data
instance Vehicle3DModel : DTDFVocab:Model [
    base:desc "3D CAD representation of the 1/10th-scale autonomous vehicle for visualization purposes"
    DTDFVocab:inputTo Custom3DVisualizationEnabler
]

instance ObjectDetectionModel : DTDFVocab:Model [
    base:desc "DBSCAN clustering + Kalman filter tracking model for object detection and tracking from LiDAR data"
    DTDFVocab:inputTo JetsonNXSensor, JetsonOrinNanoSensor
]

instance ACCAlgorithmModel : DTDFVocab:Model [
    base:desc "ISO 15622 compliant Adaptive Cruise Control algorithm implemented in MATLAB/Simulink for ACC performance class I"
    DTDFVocab:inputTo JetsonOrinNanoSensor
]

instance HistoricalDataStorage : DTDFVocab:Data [
    base:desc "SQL database storing historical object tracks and ego vehicle state data for performance analytics"
    DTDFVocab:fromData ObjectTrackData, EgoVehicleStateData
    DTDFVocab:inputTo SQLDatabaseEnabler
]

instance RealTimeDataStorage : DTDFVocab:Data [
    base:desc "Real-time data storage of current ego vehicle state and object tracks for immediate visualization"
    DTDFVocab:fromData ObjectTrackData, EgoVehicleStateData
    DTDFVocab:inputTo RealTimeDatabaseEnabler
]

// C11: Enablers
instance ROS2Middleware : DTDFVocab:Enabler [
    base:desc "ROS2 (Robot Operating System 2) middleware for inter-component communication between physical and digital twin entities"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService, RemoteManagementService
]

instance NVIDIAJetpack5 : DTDFVocab:Enabler [
    base:desc "NVIDIA Jetpack 5.0 SDK for hardware integration and device management on Jetson platforms"
    DTDFVocab:enables JetsonNXSensor, JetsonOrinNanoSensor
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for complex system modeling and algorithm implementation"
    DTDFVocab:enables ACCAlgorithmModel
]

instance Custom3DVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Custom 3D visualization framework for real-time rendering of ego vehicle state and object tracks"
    DTDFVocab:enables DataMonitoringService
]

instance SQLDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "SQL database management system for storing historical data and analytics"
    DTDFVocab:enables HistoricalDataStorage
]

instance RealTimeDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Real-time database system for immediate data storage and processing"
    DTDFVocab:enables RealTimeDataStorage
]

instance ISO23247DataTranslation : DTDFVocab:Enabler [
    base:desc "ISO 23247 compliant data translation layer for standardized message serialization between physical and digital twin"
    DTDFVocab:enables DataMonitoringService, ComputationOffloadingService
]

// C6: Services
instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of ego vehicle state (speed, steering angle), object tracks, and projected driving path via 3D Visualization FE"
    DTDFVocab:provides RealTimeVisualizationInsight, PathProjectionInsight
]

instance ComputationOffloadingService : DTDFVocab:Service [
    base:desc "Offloading ACC control logic from vehicle's resource-constrained ECUs to cloud-based compute (NVIDIA Jetson Orin Nano) for performance optimization"
    DTDFVocab:provides PerformanceOptimizationAction
]

instance RemoteManagementService : DTDFVocab:Service [
    base:desc "Enabling operators to enable/disable ACC, set desired speeds, and trigger emergency braking via Control Panel FE"
    DTDFVocab:provides ACCControlAction, EmergencyBrakingAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Generating reports via Reporting FE for post-operation analysis of performance analytics and troubleshooting insights"
    DTDFVocab:provides PerformanceAnalyticsInsight, TroubleshootingInsight, SafetyValidationInsight
]

// C17: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time 3D visualization of ego vehicle state (speed, steering angle) and object tracks for immediate situational awareness"
]

instance PathProjectionInsight : DTDFVocab:Insight [
    base:desc "Projected driving path visualization based on current sensor data and ACC control logic"
]

instance PerformanceAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Historical data analysis showing fuel economy improvements and operational optimization metrics"
]

instance TroubleshootingInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring for sensor drift detection and system health diagnostics"
]

instance SafetyValidationInsight : DTDFVocab:Insight [
    base:desc "Remote emergency braking commands ensuring human-in-the-loop safety validation"
]

instance ParameterUpdateAction : DTDFVocab:Action [
    base:desc "Dynamic adjustment of ACC settings (desired speed) via Control Panel FE"
    DTDFVocab:IsAutomatic false
]

instance ACCControlAction : DTDFVocab:Action [
    base:desc "Enable/disable ACC functionality through Control Panel interface"
    DTDFVocab:IsAutomatic false
]

instance EmergencyBrakingAction : DTDFVocab:Action [
    base:desc "Trigger emergency braking command from Control Panel for safety validation"
    DTDFVocab:IsAutomatic false
]

instance PerformanceOptimizationAction : DTDFVocab:Action [
    base:desc "Execute compute offloading of ACC algorithms to optimize performance on resource-constrained ECUs"
    DTDFVocab:IsAutomatic true
]

instance HistoricalAnalysisReport : DTDFVocab:Action [
    base:desc "Generate comprehensive reports from historical data for post-operation analysis"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT’s Digital Twin Entity’s ACC Controlling FE computes desired speeds based on lead vehicle distance (per ISO 15622) and sends actuation commands via the Physical Twin Entity’s Actuation FE to the motor and steering servos. These commands are transmitted over Wi-Fi to the vehicle’s onboard hardware, where they are converted into motor voltage commands via the Actuation FE. Emergency braking commands are also remotely triggered through the User Entity’s Control Panel FE."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates at a **real-time scale** with a synchronization frequency of **100ms end-to-end latency** (per 3GPP TS 22.185) between the vehicle and DT Entity. Clock synchronization is maintained within **±100ms accuracy** across distributed devices to ensure event ordering and data integrity, though hardware limitations restrict stricter synchronization (e.g., <1ms) required by some vehicular standards."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated via a **three-entity architecture** (ISO 23247-based): **Physical Twin Entity** (hosts sensors/actuators), **Digital Twin Entity** (processes data/controls ACC), and **User Entity** (provides visualization/management interfaces). The **Data Translation FE** acts as a cross-system intermediary, ensuring inter-entity communication via Wi-Fi (UDP/ROS2 topics). The system is **monolithic** in structure, with no sub-twin hierarchies, though the User Interface FE is decomposed into visualization and control panels."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans **three lifecycle stages**: **1) Design Phase** – Used for cyber-physical experimentation (e.g., ACC simulation, 3D CAD integration); **2) Manufacturing Phase** – Enables predictive maintenance (e.g., brake system monitoring via CREO Simulate integration); **3) Operational Phase** – Supports real-time optimization (e.g., fuel economy improvements via DT data analytics). The DT covers the **operated** phase of the physical twin’s lifecycle, focusing on runtime performance validation and remote management."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured via: **1) Real-time Data Validation** – Sensor data (LiDAR, cameras) is pre-processed (DBSCAN + Kalman filter) to eliminate noise before transmission; **2) Latency Constraints** – End-to-end latency <100ms guarantees timely control commands; **3) Verification/Validation** – ACC logic adheres to ISO 15622 standards; **4) Uncertainty Handling** – Object tracks are probabilistic (Kalman filter) to account for sensor noise. Validation occurs during development (e.g., ROS2 testing) and operational phases (e.g., emergency braking testing)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT employs a **hybrid network architecture**: **1) Onboard Communication** – ROS2 topics over ROS2 middleware for intra-entity (Physical Twin/Digital Twin) communication; **2) Inter-Entity Communication** – Wi-Fi (UDP) for cross-entity (Digital Twin/User) data exchange; **3) Protocols** – ISO 23247-compliant Data Translation FE for standardized message serialization (e.g., OPC UA for data translation); **4) Synchronization** – NTP-based clock synchronization (±100ms accuracy) for distributed devices. Security is implicit via ROS2’s built-in trust models."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed on **three hardware layers**: **1) Onboard Hardware** – NVIDIA Jetson Orin Nano (Digital Twin Entity) and Jetson NX (Physical Twin Entity) for real-time processing; **2) Cloud Hosting** – External SQL databases for data storage; **3) User Interface** – Hosted on a remote server for visualization/management. Deployment follows ISO 23247’s entity separation principles, with each FE deployed as a ROS2 package."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT integrates horizontally with **external systems** via: **1) Standardized Protocols** – OPC UA (for data translation) and ROS2 (for inter-DT communication); **2) Data Exchange** – Object tracks and ego vehicle state are shared with other DTs or IoT systems via Wi-Fi; **3) Lifecycle Integration** – Enables digital threads for product lifecycle management (e.g., linking design, manufacturing, and operational data). Horizontal integration is not explicitly detailed but implied via ISO 23247’s cross-system entity design."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership is **shared**: **1) Physical Twin Owner** – Controls sensor data collection (e.g., LiDAR inputs); **2) DT Service Provider** – Manages data storage, visualization, and remote management. Privacy is addressed via: **1) Encrypted Wi-Fi Communication** (implicit in ROS2/Wi-Fi); **2) Access Controls** – User Entity restricts commands to authorized operators; **3) Anonymization** – Object tracks are processed to remove PII before storage. No explicit policies are outlined, but ISO 23247’s modular design supports privacy-by-design principles."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT adheres to the following standards: **1) ISO 23247** – Reference architecture (entity-based design, Data Translation FE); **2) ISO 15622** – ACC control logic (performance class I); **3) ROS2** – Middleware for inter-component communication; **4) 3GPP TS 22.185** – Latency requirements (V2V communication); **5) NVIDIA Jetpack 5.0 SDK** – Hardware abstraction for Jetson devices. The system is not fully compliant with ISO 23247’s Data Storage FE or stricter clock synchronization (<100ms) due to hardware constraints."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety are addressed via: **1) Safety-Critical Design** – ACC logic adheres to ISO 15622, with emergency braking commands prioritized; **2) Latency Constraints** – <100ms end-to-end latency ensures timely control responses; **3) Remote Management** – Human-in-the-loop (Fully Autonomous Digital Twin with HITL) mitigates autonomous risks; **4) Data Integrity** – Clock synchronization (±100ms) and Data Translation FE prevent message corruption; **5) Access Controls** – User Entity restricts unauthorized commands. The system is **not explicitly certified** for autonomous driving (e.g., Level 4+), but safety is ensured via real-time validation and operator oversight."
]