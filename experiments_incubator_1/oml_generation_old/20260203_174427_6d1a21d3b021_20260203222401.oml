// C2: Acting Components
instance HeatbedHeater : DTDFVocab:ActingComponent [
    base:desc "Heatbed heater element driven by a MOSFET switch on the Raspberry Pi."
]

instance FanMotor : DTDFVocab:ActingComponent [
    base:desc "Fan motor controlling air circulation in the incubator, driven by a MOSFET switch."
]

// C3: Physical sensing components
instance InternalTempSensorInside1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer inside the incubator measuring internal temperature."
    DTDFVocab:producedData InternalTempDataTransmitted
]

instance InternalTempSensorInside2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer inside the incubator measuring internal temperature."
    DTDFVocab:producedData InternalTempDataTransmitted
]

instance ExternalTempSensorRoom : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer outside the incubator measuring room temperature."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Data transmitted
instance InternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorInside1, InternalTempSensorInside2
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensorRoom
]

// C10: Data
instance InternalTemperatureData : DTDFVocab:Data [
    base:desc "Internal temperature time series recorded by incubator sensors."
    DTDFVocab:fromData InternalTempDataTransmitted
    DTDFVocab:inputTo RaspberryPiHub, PythonScipyOptimize
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Room temperature time series recorded by external sensor."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo RaspberryPiHub, PythonScipyOptimize
]

// C11: Enablers
instance RaspberryPiHub : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B controller managing sensors, actuators, and running Python scripts."
    DTDFVocab:enables DataAcquisitionService, TemperatureDynamicsService, ControlStrategyService, MonitoringService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker for local message passing between Raspberry Pi and virtual twin."
    DTDFVocab:enables DataTransmissionService
]

instance OneWireBus : DTDFVocab:Enabler [
    base:desc "1-Wire bus interfacing DS18S20 sensors with Raspberry Pi."
    DTDFVocab:enables DataAcquisitionService
]

instance WiFiCommunication : DTDFVocab:Enabler [
    base:desc "Wi-Fi communication module enabling JSON message upload to cloud."
    DTDFVocab:enables DataTransmissionService
]

instance PythonScipyOptimize : DTDFVocab:Enabler [
    base:desc "Python environment with scipy.optimize for nonlinear least squares calibration."
    DTDFVocab:enables ParameterOptimisationService, TemperatureDynamicsService
]

// C10: Models
instance ModelA : DTDFVocab:Model [
    base:desc "Parametric model A describing temperature evolution with parameters C_air and G_box."
    DTDFVocab:inputTo PythonScipyOptimize, RaspberryPiHub
]

instance ModelB : DTDFVocab:Model [
    base:desc "Parametric model B describing temperature evolution with parameters C_air, C_heater, G_box, G_heater."
    DTDFVocab:inputTo PythonScipyOptimize, RaspberryPiHub
]

// C6: Services
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Acquisition of sensor data via 1-Wire bus."
    DTDFVocab:provides SensorDataAcquisitionInsight
]

instance TemperatureDynamicsService : DTDFVocab:Service [
    base:desc "Simulation of temperature dynamics using ModelA and ModelB."
    DTDFVocab:provides TemperaturePredictionInsight, PowerConsumptionInsight
]

instance ParameterOptimisationService : DTDFVocab:Service [
    base:desc "Parameter optimization via least‑squares residual minimization."
    DTDFVocab:provides CalibrationResultsInsight, ResidualDetectionInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitoring of temperature and power consumption data."
    DTDFVocab:provides TemperatureMonitoringInsight, PowerConsumptionMonitoringInsight
]

instance ControlStrategyService : DTDFVocab:Service [
    base:desc "Automatic control strategy update based on model predictions and residuals."
    DTDFVocab:provides ControlStrategyUpdateAction
]

instance DataTransmissionService : DTDFVocab:Service [
    base:desc "Transmission of sensor data to remote servers via JSON over Wi‑Fi."
    DTDFVocab:provides DataTransmissionAction
]

// C17: Insights and Actions
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory from simulated models for future control planning."
]

instance PowerConsumptionInsight : DTDFVocab:Insight [
    base:desc "Estimated power consumption of heatbed and fan based on model outputs."
]

instance CalibrationResultsInsight : DTDFVocab:Insight [
    base:desc "Updated model parameters (C_air, G_box, C_heater, G_heater) after calibration."
]

instance ResidualDetectionInsight : DTDFVocab:Insight [
    base:desc "Residual analysis revealing mismatch between model predictions and real measurements."
]

instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring of internal and room temperatures."
]

instance PowerConsumptionMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring of power consumption for heatbed and fan."
]

instance ControlStrategyUpdateAction : DTDFVocab:Action [
    base:desc "Automatic update of control signals to heatbed and fan based on predictions and residuals."
    DTDFVocab:IsAutomatic true
]

instance DataTransmissionAction : DTDFVocab:Action [
    base:desc "Transmission of sensor data to remote servers via JSON over Wi‑Fi."
    DTDFVocab:IsAutomatic true
]

instance SensorDataAcquisitionInsight : DTDFVocab:Insight [
    base:desc "Acquisition of sensor data from DS18S20 sensors via 1‑Wire bus."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin publishes control commands via RabbitMQ to the Raspberry Pi; the controller receives these commands to activate/deactivate the heatbed and fan, and to read sensor data back to the twin"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated set of components: low‑level driver (hardware abstraction), controller (bang‑bang logic with H/U/C/C parameters), simulation engine (Model A/B), RabbitMQ server (message broker), and PLC firmware hosted on Raspberry Pi"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation through comparison of simulation with experimental temperature trajectories; non‑linear least squares to minimise residual error; assumptions on uniform temperature, insulated walls, constant specific heat, negligible heatbed losses; model fidelity assessed by residual error minimisation and parameter convergence"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical twin communicates with the digital twin via a local RabbitMQ AMQP message broker running on the Raspberry Pi. Sensor data and finite‑state machine messages are transmitted over the Pi’s GPIO and 1‑Wire bus, while command messages travel over the AMQP exchange. Both components reside on the same Pi, with the RabbitMQ broker handling all message passing between low‑level driver, controller, and the digital twin simulation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted locally on the Raspberry Pi 4 Model B; RabbitMQ server runs on same device; low‑level driver and controller firmware run on Pi; simulation and calibration scripts executed on the Pi or a remote computer linked via network"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver implements a safe protocol to ensure the PT remains in a safe state. While the system uses open‑source software and standard protocols (RabbitMQ, AMQP, 1‑Wire), explicit cybersecurity measures are not described. The design focuses on safe operation of the physical hardware to avoid accidents, especially in the absence of human presence."
]