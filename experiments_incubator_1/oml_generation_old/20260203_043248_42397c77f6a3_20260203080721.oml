// C3: Physical sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer placed inside the insulated incubator; accuracy ±0.5 °C."
    DTDFVocab:producedData InternalTempDataTransmitted1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer placed inside the insulated incubator; accuracy ±0.5 °C."
    DTDFVocab:producedData InternalTempDataTransmitted2
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted outside the incubator; accuracy ±0.5 °C."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Physical‑to‑virtual interaction (data transmitted)
instance InternalTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// C10: Data (sensor readings)
instance InternalTempData1 : DTDFVocab:Data [
    base:desc "Scalar temperature reading (°C) from internal sensor 1, sampled at the sensor’s native rate."
    DTDFVocab:fromData InternalTempDataTransmitted1
    DTDFVocab:inputTo RabbitMQCommunicationEnabler
]

instance InternalTempData2 : DTDFVocab:Data [
    base:desc "Scalar temperature reading (°C) from internal sensor 2, sampled at the sensor’s native rate."
    DTDFVocab:fromData InternalTempDataTransmitted2
    DTDFVocab:inputTo RabbitMQCommunicationEnabler
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Scalar temperature reading (°C) from external sensor, sampled at the sensor’s native rate."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo RabbitMQCommunicationEnabler
]

// C10: Models (analytical thermal models)
instance TwoParamThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model of the incubator containing two free parameters."
    DTDFVocab:inputTo ModelCalibrationEnabler
]

instance FourParamThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model of the incubator containing four free parameters to capture heat‑bed inertia."
    DTDFVocab:inputTo ModelCalibrationEnabler
]

// C11: Enablers
instance RabbitMQCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ server on the Raspberry Pi used for forwarding sensor data and supporting DT services."
    DTDFVocab:enables MonitoringService, PredictionService, OptimisationService, SafetyCheckService, VisualizationService
]

instance ModelCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that adjusts free parameters of thermal models using incoming sensor data."
    DTDFVocab:enables CalibrationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuously monitors the three temperature streams to detect deviations from desired set‑points."
    DTDFVocab:provides TemperatureDeviationInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Updates thermal model parameters by applying calibration algorithms to the latest sensor data."
    DTDFVocab:provides CalibrationInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Runs predictive simulations reproducing and forecasting the incubator’s thermal behavior under current conditions."
    DTDFVocab:provides ModelPredictionInsight
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Suggests optimal control set‑points for the heat‑bed and fan to keep temperature within safe bounds."
    DTDFVocab:provides OptimisationInsight, AdjustSetpointAction
]

instance SafetyCheckService : DTDFVocab:Service [
    base:desc "Evaluates sensor streams for safety violations and raises alerts for operators or supervisory controllers."
    DTDFVocab:provides SafetyViolationInsight, AlertOperatorAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides visualization of temperature trends over time."
    DTDFVocab:provides TemperatureTrendInsight
]

// C17: Insights
instance TemperatureDeviationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature deviations indicating sub‑optimal or unsafe incubator conditions."
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Result of model calibration indicating updated parameter values and confidence."
]

instance ModelPredictionInsight : DTDFVocab:Insight [
    base:desc "Forecast of future internal temperature based on calibrated thermal models."
]

instance OptimisationInsight : DTDFVocab:Insight [
    base:desc "Recommendation of optimal heating and fan set‑points to maintain target temperature."
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Identification of a safety breach (e.g., temperature out‑of‑range) requiring intervention."
]

instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Aggregated view of temperature evolution useful for operator decision‑making."
]

// C17: Actions
instance AdjustSetpointAction : DTDFVocab:Action [
    base:desc "Command sent from the DT to the Raspberry Pi to adjust heat‑bed or fan set‑points."
    DTDFVocab:IsAutomatic true
]

instance AlertOperatorAction : DTDFVocab:Action [
    base:desc "Notification (e.g., email, UI alarm) sent to a human operator when a safety violation is detected."
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is orchestrated as a layered framework that integrates three core artefacts: (1) **Data** obtained continuously from the Physical Twin (PT) via its sensors; (2) **Models** that represent the cyber‑physical behavior of the PT and its environment; and (3) **Algorithms** that consume the data and models to generate knowledge (e.g., fault detectors, state estimators, optimisers). Calibration algorithms are employed to periodically update the parameters of the CPS and environment models using the latest sensor data, thereby keeping the virtual representation aligned with the PT. The calibrated models feed monitoring components that assess safety and optimality criteria in real time. When a monitor signals a violation, a decision layer—implemented by either human operators or autonomous algorithms—triggers corrective actions on the PT. This orchestration follows the schematic depicted in Figure 1 of Document 1, emphasizing tight coupling between sensing, model updating, monitoring, and control loops."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the two thermal models against experimental temperature data. Validation experiments showed that the four‑parameter model more accurately reproduces the thermal inertia of the heat‑bed, thereby offering higher fidelity and being selected for further digital‑twin development. Uncertainty is reduced through calibration algorithms that estimate the best‑fit parameters, and model performance is monitored by the DT’s supervisory algorithms that detect deviations between predicted and measured temperatures."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The communication infrastructure consists of a single Raspberry Pi that hosts both the controller and a RabbitMQ server. Sensor data travel from the 1‑Wire bus to the low‑level driver, and all inter‑component messages (sensor updates and control commands) are exchanged via the RabbitMQ server. No additional network topology, bandwidth, latency, redundancy, or security protocols are specified in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin’s runtime environment is hosted directly on the edge device—the Raspberry Pi that also controls the incubator. The RabbitMQ server and the calibration/monitoring algorithms execute on this platform, implying modest compute and storage needs fitting the Pi’s resources. Scalability is limited to the single‑node deployment; no cloud or multi‑node scaling mechanisms are described. Availability relies on the Raspberry Pi remaining powered; no explicit high‑availability or fault‑tolerance strategies are provided."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT architecture described in Document 1 integrates safety monitoring by employing calibration algorithms that update models of the cyber‑physical system and its environment, and then feeds the resulting data to monitors that continuously evaluate whether the system is operating safely and optimally. Violations detected by these monitors can trigger human operators or automated algorithms to initiate corrective actions on the physical twin. While the documents do not detail specific cybersecurity protocols, access‑control, or authentication mechanisms, the safety‑oriented components include the use of runtime monitors and fault‑detectors as part of the algorithmic layer that support risk mitigation and fail‑safe responses."
]