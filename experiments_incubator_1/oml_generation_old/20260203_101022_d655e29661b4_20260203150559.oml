// C3: Physical sensing components
instance OperationalSensor : DTDFVocab:SensingComponent [
    base:desc "Collects operational data from the Physical Twin over time"
    DTDFVocab:producedData OperationalDataTransmitted
]

// C4: Physical-to-virtual interaction
instance OperationalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalSensor
]

instance RawSensorData : DTDFVocab:Data [
    base:desc "Raw time‑series sensor data transmitted from the Physical Twin"
    DTDFVocab:fromData OperationalDataTransmitted
    DTDFVocab:inputTo CalibrationModule, MonitoringModule, FaultDetectionModule, StateEstimationModule
]

// C10: Models/Data
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "Geometric model encoded as CAD geometry representing physical dimensions and styling of the PT"
    DTDFVocab:inputTo SimulationEngine
]

instance DynamicBehaviorModel : DTDFVocab:Model [
    base:desc "Dynamic model expressed by differential equations capturing system dynamics of the PT"
    DTDFVocab:inputTo CalibrationModule, SimulationEngine
]

instance AnalyticalKnowledgeModel : DTDFVocab:Model [
    base:desc "Analytical knowledge‑based model capturing cyber‑physical interactions and environmental influences"
    DTDFVocab:inputTo MonitoringModule
]

// C11: Enablers
instance CalibrationModule : DTDFVocab:Enabler [
    base:desc "Calibration algorithm module that refines dynamic model parameters using real‑time sensor data"
    DTDFVocab:enables ModelCalibrationAndOptimizationService
]

instance MonitoringModule : DTDFVocab:Enabler [
    base:desc "Monitoring module that validates model predictions against real‑time observations and performs safety and performance checks"
    DTDFVocab:enables ContinuousMonitoringService
]

instance FaultDetectionModule : DTDFVocab:Enabler [
    base:desc "Fault detection and supervisory control module that alerts operators to safety or performance constraint violations"
    DTDFVocab:enables FaultDetectionAndSupervisoryControlService
]

instance StateEstimationModule : DTDFVocab:Enabler [
    base:desc "State estimation and prognostics module that infers hidden system states and anticipates future failures"
    DTDFVocab:enables StateEstimationAndPrognosticsService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine for forward and inverse modeling of the twin"
    DTDFVocab:enables SimulationAndPredictionService
]

// C6: Services
instance ModelCalibrationAndOptimizationService : DTDFVocab:Service [
    base:desc "Service that calibrates and optimizes dynamic models based on incoming data"
    DTDFVocab:provides CalibrationResultInsight
]

instance ContinuousMonitoringService : DTDFVocab:Service [
    base:desc "Service providing continuous monitoring via data‑collection layer for safety and performance"
    DTDFVocab:provides SafetyMonitoringInsight
]

instance FaultDetectionAndSupervisoryControlService : DTDFVocab:Service [
    base:desc "Service performing fault detection and supervisory control algorithms, alerting operators"
    DTDFVocab:provides FaultDetectionInsight, ExecuteControlAction
]

instance StateEstimationAndPrognosticsService : DTDFVocab:Service [
    base:desc "Service delivering state estimation and prognostics using updated data"
    DTDFVocab:provides StateEstimationInsight, PrognosticAction
]

instance SimulationAndPredictionService : DTDFVocab:Service [
    base:desc "Service that simulates and predicts the Physical Twin behavior under current conditions"
    DTDFVocab:provides SimulationPredictionInsight
]

// C17: Insights
instance CalibrationResultInsight : DTDFVocab:Insight [
    base:desc "Insights regarding calibration results of dynamic models"
]

instance SafetyMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight indicating safety and performance compliance"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight identifying faults in the system"
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Insight providing estimated hidden system states"
]

instance SimulationPredictionInsight : DTDFVocab:Insight [
    base:desc "Prediction of future PT behavior based on simulation"
]

// C17: Actions
instance ExecuteControlAction : DTDFVocab:Action [
    base:desc "Automated control action to adjust the Physical Twin"
    DTDFVocab:IsAutomatic true
]

instance PrognosticAction : DTDFVocab:Action [
    base:desc "Action to preemptively mitigate anticipated failures"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "When the monitoring subsystem flags a violation, the digital twin’s control layer may issue adjustment commands (e.g., actuator or configuration changes) to the physical twin. Execution of these commands is confirmed via feedback from the PT, allowing the twin to resolve conflicts and validate outcomes."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A Digital Twin system orchestrates data acquisition, model representation, and algorithmic reasoning in a tightly coupled, closed‑loop architecture. Time‑stamped sensor data from the physical twin are streamed continuously and feed calibration algorithms that update analytical models of both the cyber and physical domains of the system and its environment. These updated models are then queried by simulation, fault‑detection, supervisory controller, and optimization algorithms. A monitoring layer consumes the outputs of these algorithms to enforce safety and performance constraints, and when violations are detected, human operators or automated agents may decide to intervene or modify the physical twin. This flow integrates modeling, simulation, monitoring, and optimization to provide predictive and prescriptive capabilities."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle consists of a design and modeling phase where abstract models (geometric, dynamical, material) are created to capture selected physical aspects of the target PT; a deployment phase where these models are integrated into a DT framework that ingests continuous sensor data streams from the PT; and an operational phase where calibration algorithms continuously update the models to maintain alignment, while monitors evaluate safety and performance metrics and trigger interventions; lifecycle governance is exercised through iterative calibration, monitoring, and human or automated decision‑making upon detection of violations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is preserved through ongoing calibration against sensor data, whereby calibration algorithms iteratively adjust model parameters to match observed behavior within acceptable bounds. The Digital Twin employs monitoring mechanisms that evaluate the system’s performance against safety and optimality specifications; any detected violations trigger alerts or autonomous corrective actions. While explicit V&V procedures are not detailed, the architecture implies continuous verification via statistical consistency checks between model predictions and sensor observations, and validation through operational testing where the DT’s predictions are compared against real‐world outcomes. The system thereby implements an implicit quality assurance loop that flags inconsistencies and prompts human or automated intervention to reconcile discrepancies."
]