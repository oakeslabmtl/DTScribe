// C3: Physical sensing components
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor A placed inside the incubator chamber, provides scalar temperature measurements."
    DTDFVocab:producedData InternalTempDataTransmittedA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor B placed inside the incubator chamber, provides scalar temperature measurements."
    DTDFVocab:producedData InternalTempDataTransmittedB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor mounted on the exterior of the incubator, provides ambient temperature measurements."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Physical‑to‑virtual interaction (data transmitted)
instance InternalTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// C4: Data objects generated from transmitted messages
instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from internal sensor A (timestamp, sensor id, float value)."
    DTDFVocab:fromData InternalTempDataTransmittedA
    DTDFVocab:inputTo CalibrationAlgorithmEnabler
]

instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from internal sensor B (timestamp, sensor id, float value)."
    DTDFVocab:fromData InternalTempDataTransmittedB
    DTDFVocab:inputTo CalibrationAlgorithmEnabler
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from external sensor (timestamp, sensor id, float value)."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithmEnabler
]

// C10: Simulation models
instance IncubatorThermalModel_TwoParams : DTDFVocab:Model [
    base:desc "Thermal dynamics model of the incubator heat‑bed with two free parameters, used for temperature prediction."
    DTDFVocab:inputTo PredictionEngineEnabler
]

instance IncubatorThermalModel_FourParams : DTDFVocab:Model [
    base:desc "Extended thermal‑airflow model including fan effects with four free parameters, used for temperature prediction."
    DTDFVocab:inputTo PredictionEngineEnabler
]

// C11: Enablers (algorithms and infrastructure)
instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ broker mediating AMQP messages from the Raspberry Pi to the digital twin."
    DTDFVocab:enables TemperatureMonitoringService, TemperaturePredictionService, TemperatureOptimizationService, SafetyMonitoringService, TemperatureVisualizationService
]

instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithms that estimate model parameters from incoming temperature data streams."
    DTDFVocab:enables TemperatureOptimizationService, SafetyMonitoringService
]

instance PredictionEngineEnabler : DTDFVocab:Enabler [
    base:desc "Prediction engine that consumes calibrated models to generate future temperature trajectories."
    DTDFVocab:enables TemperaturePredictionService, TemperatureVisualizationService
]

instance OptimizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Optimization algorithm that computes heat‑bed and fan set‑points based on calibrated models and predictions."
    DTDFVocab:enables TemperatureOptimizationService
]

instance SafetyMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Safety monitor that checks temperature limits and issues shutdown commands when violations occur."
    DTDFVocab:enables SafetyMonitoringService
]

instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Visualization engine that renders simulation results for engineers."
    DTDFVocab:enables TemperatureVisualizationService
]

// C6: Services offered by the digital twin
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of inside and outside temperatures using sensor streams."
    DTDFVocab:provides TemperatureConditionInsight
]

instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Prediction of future temperature trajectories using calibrated simulation models."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance TemperatureOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of heat‑bed and fan set‑points through real‑time calibration and predictive control."
    DTDFVocab:provides OptimizeHeatbedFanAction
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Safety and performance monitoring that detects temperature limit violations."
    DTDFVocab:provides SafetyViolationInsight
]

instance TemperatureVisualizationService : DTDFVocab:Service [
    base:desc "Visualization of simulation results for engineers to assess system behaviour."
    DTDFVocab:provides VisualizationInsight
]

// C17: Insights and actions
instance TemperatureConditionInsight : DTDFVocab:Insight [
    base:desc "Current temperature condition inside and outside the incubator derived from live sensor data."
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Forecasted temperature trajectory over the next planning horizon."
]

instance OptimizeHeatbedFanAction : DTDFVocab:Action [
    base:desc "Command to adjust heat‑bed power level and fan speed to achieve target temperature."
    DTDFVocab:IsAutomatic true
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature exceeding safety thresholds, triggering protective shutdown."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of model predictions versus measured temperatures."
]

// C2: Acting components (actuators)
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that can be switched on/off or set to discrete power levels to raise internal temperature."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan that circulates warm air to improve temperature homogeneity inside the incubator."
]

// C1: Environment containing the physical components
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InternalTempSensorA, InternalTempSensorB, ExternalTempSensor, HeatbedActuator, FanActuator, RabbitMQBrokerEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands flow from the digital twin to the physical twin through the same RabbitMQ broker. The DT publishes AMQP messages that encode actuator commands (e.g., “HEATBED_ON”, “HEATBED_OFF”, “FAN_ON”, “FAN_OFF”) together with optional parameters such as heating duration (H) and waiting duration (C). The low‑level driver receives these messages, validates them against the built‑in safety protocol, and forwards the appropriate GPIO signals to the heatbed and fan. After execution the driver acknowledges the command with a response message, allowing the DT to confirm actuation. Conflict resolution is handled by the controller logic that prioritises the latest command."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The incubator Digital Twin follows a CPS‑based orchestration where the physical twin (insulated styrofoam box, heat‑bed, fan, and temperature sensors) is managed by a Raspberry Pi controller. Sensor data are streamed from the PT to a time‑series database; a dashboard consumes this data for real‑time visualization. Calibration algorithms run on the stored data to update the parameters of Model B (the four‑parameter thermal model). The calibrated model feeds a Kalman filter that estimates the unmeasured heat‑bed temperature and performs anomaly detection. Upon detection, a self‑adaptation loop schedules an experiment, re‑configures the controller, gathers new data, re‑calibrates Model B, updates the Kalman filter, runs what‑if co‑simulations to optimise controller settings, and finally re‑configures the controller. This integration of data acquisition, storage, model calibration, state estimation, anomaly detection, simulation and controller re‑configuration constitutes the overall orchestration of the Digital Twin system."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through calibration algorithms that adjust the parameters of the incubator thermal models (a two‑parameter and a four‑parameter model) using the collected temperature data, thereby reducing prediction error of thermal inertia. Validation is performed by comparing model outputs against measured temperature trajectories; deviations trigger violation detection in the monitoring subsystem. Uncertainty arises from sensor noise and simplifications in the thermal models; the DT quantifies it implicitly by tracking residual errors during calibration. Quality assurance is achieved by the monitor that checks for safe and optimal operation and by human or higher‑level algorithmic intervention when violations are detected."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection is built around a RabbitMQ message broker using the AMQP 0‑9‑1 protocol over TCP/IP. All components (low‑level driver, controller, DT services) act as AMQP clients in a star topology with the broker at the centre. RabbitMQ provides message durability, acknowledgements and automatic reconnection, satisfying reliability requirements. No explicit bandwidth or latency figures are given; the system assumes standard Ethernet/Wi‑Fi links sufficient for low‑frequency sensor streams (seconds‑scale). Security is limited to the broker’s native authentication (username/password); no additional encryption is mentioned."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The deployment can be on‑premise or in the cloud; the RabbitMQ server may run on a local machine, a dedicated edge server, or a cloud VM. Compute for the digital‑twin models runs on the same host as the DT services or on separate hardware, though exact CPU or storage needs are not specified. Scalability is achieved by adding RabbitMQ nodes or scaling consumer instances. Availability is addressed by RabbitMQ’s mature clustering and fail‑over capabilities, although the case study does not describe explicit redundancy configurations."
]