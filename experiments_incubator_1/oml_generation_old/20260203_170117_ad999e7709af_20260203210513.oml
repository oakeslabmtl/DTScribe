// Sensing components
instance InsideDS18S20Sensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire digital temperature sensor inside the insulated box, adjacent to the heatbed."
    DTDFVocab:producedData InsideTempDataTransmitted1
]

instance InsideDS18S20Sensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire digital temperature sensor inside the insulated box, adjacent to the heatbed."
    DTDFVocab:producedData InsideTempDataTransmitted2
]

instance ExternalDS18S20Sensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire digital temperature sensor positioned externally next to the box."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// Data transmitted by the sensors
instance InsideTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideDS18S20Sensor1
]

instance InsideTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideDS18S20Sensor2
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalDS18S20Sensor
]

// Raw temperature data used by DT components
instance InsideTempData1 : DTDFVocab:Data [
    base:desc "Temperature reading from InsideDS18S20Sensor1, accuracy ±0.5°C, range 10–85°C."
    DTDFVocab:fromData InsideTempDataTransmitted1
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler, DataIngestionEnabler
]

instance InsideTempData2 : DTDFVocab:Data [
    base:desc "Temperature reading from InsideDS18S20Sensor2, accuracy ±0.5°C, range 10–85°C."
    DTDFVocab:fromData InsideTempDataTransmitted2
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler, DataIngestionEnabler
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Temperature reading from ExternalDS18S20Sensor, accuracy ±0.5°C, range 10–85°C."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler, DataIngestionEnabler
]

// Enablers
instance DataIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Ingests temperature data from Raspberry Pi via RabbitMQ for real‑time processing."
    DTDFVocab:enables RealTimeMonitoringService, SafetyOversightService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Performs non‑linear least‑squares calibration of thermal model parameters using sensor data."
    DTDFVocab:enables ParameterCalibrationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Runs forward simulation of thermal dynamics using calibrated models to predict future temperatures."
    DTDFVocab:enables PredictiveModelService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides continuous monitoring of temperature against safety thresholds."
    DTDFVocab:provides TemperatureDeviationInsight
]

instance SafetyOversightService : DTDFVocab:Service [
    base:desc "Detects unsafe conditions and signals corrective action to actuators."
    DTDFVocab:provides HeaterOnAction, FanSpeedAdjustmentAction
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates model parameters using sensor data."
    DTDFVocab:provides StartCalibrationAction
]

instance PredictiveModelService : DTDFVocab:Service [
    base:desc "Produces predictive temperature forecasts based on calibrated models."
    DTDFVocab:provides PredictiveInsight
]

// Insights
instance TemperatureDeviationInsight : DTDFVocab:Insight [
    base:desc "Detects deviation between sensor measurement and model prediction beyond tolerance."
]

instance ModelFitInsight : DTDFVocab:Insight [
    base:desc "Assesses goodness‑of‑fit of the calibration step."
]

instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Forecasts future temperature based on calibrated model."
]

// Actions
instance HeaterOnAction : DTDFVocab:Action [
    base:desc "Turns on the heatbed to increase temperature."
    DTDFVocab:IsAutomatic true
]

instance FanSpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjusts fan speed to improve heat distribution."
    DTDFVocab:IsAutomatic true
]

instance StartCalibrationAction : DTDFVocab:Action [
    base:desc "Initiates calibration of thermal model parameters."
    DTDFVocab:IsAutomatic false
]

// Thermal models
instance TwoParameterThermalModel : DTDFVocab:Model [
    base:desc "Thermal model with two free parameters representing heat transfer coefficients."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler
]

instance FourParameterThermalModel : DTDFVocab:Model [
    base:desc "Thermal model with four free parameters accounting for additional heat transfer effects."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler
]

// Physical components
instance HeaterComponent : DTDFVocab:Component [
    base:desc "Heatbed heating element controlled by Raspberry Pi."
]

instance FanComponent : DTDFVocab:Component [
    base:desc "Fan for convective heat mixing within the styrofoam enclosure."
]

instance PiControllerComponent : DTDFVocab:Component [
    base:desc "Embedded Raspberry Pi running control software, receives sensor data and issues actuation commands."
]

instance StyrofoamBoxComponent : DTDFVocab:Component [
    base:desc "Insulated styrofoam enclosure forming the incubator."
]

instance InsideDS18S20Sensor1Component : DTDFVocab:Component [
    base:desc "DS18S20 sensor inside the box, adjacent to heatbed."
]

instance InsideDS18S20Sensor2Component : DTDFVocab:Component [
    base:desc "DS18S20 sensor inside the box, adjacent to heatbed."
]

instance ExternalDS18S20SensorComponent : DTDFVocab:Component [
    base:desc "DS18S20 sensor external to the box."
]

// Environment encompassing all components
instance PhysicalIncubator : DTDFVocab:Environment [
    base:contains HeaterComponent, FanComponent, PiControllerComponent, StyrofoamBoxComponent, InsideDS18S20Sensor1Component, InsideDS18S20Sensor2Component, ExternalDS18S20SensorComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands for the heater and fan are sent from the digital twin via RabbitMQ to the low‑level driver on the Raspberry Pi. The driver checks the RabbitMQ server for such commands and forwards the appropriate actuator signals to the heater and fan. The bang‑bang controller on the Pi generates command messages based on the temperature thresholds (LL, UL, H, C). No explicit message format, validation, authentication, or conflict‑resolution details are provided in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is orchestrated by a Raspberry Pi controller that runs the low‑level driver and a bespoke communication server (RabbitMQ). It consumes sensor data (temperature readings) in real‑time, updates the simulation model (Model B with four free parameters) by a non‑linear least‑squares calibration routine, and runs a Kalman filter to estimate the unmeasured heat‑bed temperature. Co‑simulation modules retrieve historical or live data from the PT and execute what‑if scenarios, while a dashboard displays real‑time state. This logical layering couples cyber and physical models under a single, centrally managed framework."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle for the incubator begins with *Data Acquisition*—continuous readings from two inside temperature sensors and an outside sensor, streamed via the Raspberry Pi to a cloud or local storage. Next is *Model Development*, where two thermal simulation models (one with two free parameters and one with four) are implemented in an open‑source repository (see https://github.com/INTO-CPS-Association/example-incubator). *Model Calibration* follows, utilizing a calibration algorithm that fuses real‑time sensor data with the parameterized models to obtain the most accurate physical–cyber representation. The *Simulation* phase runs the calibrated models to predict future temperature trajectories and evaluate control actions. *Monitoring* then compares simulated predictions with live sensor data, feeding safety and optimality checks back into the system. Finally, *Decision Support* allows human operators or automated supervisors to modify the physical twin (e.g., adjust heater duty cycle) based on detected violations or optimization outputs, thereby completing the loop. Transition management is handled via continuous integration of new sensor data into the model repository, while governance is enforced by version control on GitHub and regular model validation against experimental results."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by comparing the two analytical models against experimental temperature profiles. The four‑parameter model demonstrates superior prediction of the heatbed’s thermal inertia, making it the preferred model for subsequent DT development. Calibration involves fitting free parameters to measured sensor data, thus grounding the model in physical reality. Validation methods include experimental evaluation of temperature control performance and monitoring of safety/marginal violations. Uncertainty sources, such as unmodeled heat losses and sensor noise, are implicitly addressed through continual monitoring and calibration updates. Error detection is performed by the DT monitors, which flag deviations from acceptable temperature ranges or predicted behavior, prompting corrective action by the controller or human operators. Quality assurance is supported by publicly available open‑source hardware and software specifications, facilitating reproducibility and independent verification.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin communication relies on a RabbitMQ message broker deployed locally on the Raspberry Pi. All interactions between the DT components, controller, and low‑level driver occur over RabbitMQ queues, providing synchronization and message passing. The documents describe RabbitMQ as a mature, lightweight, on‑premises or cloud‑compatible broker, but do not specify network topology, bandwidth, latency, redundancy, or security protocols beyond the use of RabbitMQ."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital‑twin software—including RabbitMQ, the controller, and the low‑level driver—is run on a Raspberry Pi (edge/on‑premises). No separate cloud, container, or other deployment infrastructure is described, and the documents give no explicit computational or storage requirements beyond the presence of the Raspberry Pi."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Within the incubator, temperature sensors (DS18S20) are bus‑connected via a 1‑Wire interface, and all sensor and control messages are transmitted through a RabbitMQ broker. No additional external enterprise protocols such as OPC‑UA or MQTT are referenced in the documents."
]