// =============================================================
// Physical Sensing Components
// =============================================================
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor located inside the incubator box (sensor 1)."
    DTDFVocab:producedData InternalTempDataTx1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor located inside the incubator box (sensor 2)."
    DTDFVocab:producedData InternalTempDataTx2
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient temperature sensor placed outside the incubator."
    DTDFVocab:producedData ExternalTempDataTx
]

// =============================================================
// Data Transmitted (Physical‑to‑Virtual)
// =============================================================
instance InternalTempDataTx1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempDataTx2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance ExternalTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// =============================================================
// Data (consumed by DT components)
// =============================================================
instance InternalTempData1 : DTDFVocab:Data [
    base:desc "Numeric temperature reading (°C) from internal sensor 1."
    DTDFVocab:fromData InternalTempDataTx1
    DTDFVocab:inputTo KalmanFilterEngine, MonitoringEngine, ControllerEngine
]

instance InternalTempData2 : DTDFVocab:Data [
    base:desc "Numeric temperature reading (°C) from internal sensor 2."
    DTDFVocab:fromData InternalTempDataTx2
    DTDFVocab:inputTo KalmanFilterEngine, MonitoringEngine, ControllerEngine
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Numeric ambient temperature reading (°C) from external sensor."
    DTDFVocab:fromData ExternalTempDataTx
    DTDFVocab:inputTo KalmanFilterEngine, MonitoringEngine, ControllerEngine
]

// =============================================================
// Acting Components (Physical actuators)
// =============================================================
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that provides heating to reach target temperature."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Small fan that circulates air inside the insulated styrofoam box."
]

// =============================================================
// Models / Data (Analytical simulation models)
// =============================================================
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model A using simplifying assumptions (2 free parameters)."
    DTDFVocab:inputTo CalibrationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Analytical thermal model B with four free parameters (relaxes heat‑bed storage assumption)."
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine, WhatIfCoSimulationEngine
]

// =============================================================
// Enablers (Algorithms, middleware, infrastructure)
// =============================================================
instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "On‑demand calibration algorithm that estimates best‑fit parameters for thermal models."
    DTDFVocab:enables OnDemandCalibrationService
]

instance KalmanFilterEngine : DTDFVocab:Enabler [
    base:desc "Kalman filter that fuses Model B predictions with sensor measurements to estimate heat‑bed temperature and detect anomalies."
    DTDFVocab:enables AnomalyDetectionService, HeatBedStateEstimationService
]

instance WhatIfCoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation infrastructure that runs what‑if scenarios using calibrated Model B and historic PT data."
    DTDFVocab:enables PredictiveSimulationService
]

instance MonitoringEngine : DTDFVocab:Enabler [
    base:desc "Runtime monitor comparing live sensor data against model‑based predictions for safety and performance."
    DTDFVocab:enables ContinuousMonitoringService
]

instance ControllerEngine : DTDFVocab:Enabler [
    base:desc "Bang‑bang controller (with lower/upper temperature limits, heating duration H and waiting duration C) executed on the Raspberry Pi."
    DTDFVocab:enables ControlActionService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "AMQP message broker that routes sensor data and control commands between driver, controller and DT components."
    DTDFVocab:enables RealTimeVisualizationService, ControlActionService
]

instance DashboardVisualizationEngine : DTDFVocab:Enabler [
    base:desc "Dashboard that streams time‑series data from the time‑series database for real‑time visualisation."
    DTDFVocab:enables RealTimeVisualizationService
]

// =============================================================
// Services (DT functionalities)
// =============================================================
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Streams temperature, controller state and actuator commands to a real‑time dashboard."
    DTDFVocab:provides IncubatorStatusInsight
]

instance OnDemandCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates thermal models on demand, updating model parameters with best‑fit estimates."
    DTDFVocab:provides ModelParameterEstimatesInsight, UpdateModelParametersAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Detects temperature anomalies using Kalman filter residuals."
    DTDFVocab:provides UnsafeTemperatureAlertInsight
]

instance HeatBedStateEstimationService : DTDFVocab:Service [
    base:desc "Estimates non‑measured heat‑bed temperature via Kalman filter."
    DTDFVocab:provides HeatBedStateEstimateInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Runs what‑if co‑simulations to optimise controller parameters."
    DTDFVocab:provides RecommendedControllerParametersInsight, OptimiseControllerParametersAction
]

instance ContinuousMonitoringService : DTDFVocab:Service [
    base:desc "Continuously monitors live data for safety or performance violations."
    DTDFVocab:provides PerformanceViolationInsight
]

instance ControlActionService : DTDFVocab:Service [
    base:desc "Issues ON/OFF commands for heat‑bed and fan based on controller decisions."
    DTDFVocab:provides ActuateHeatBedAndFanAction
]

// =============================================================
// Insights / Actions (Decision support outputs)
// =============================================================
instance IncubatorStatusInsight : DTDFVocab:Insight [
    base:desc "Current status of temperature, controller state and actuator commands displayed on dashboard."
]

instance ModelParameterEstimatesInsight : DTDFVocab:Insight [
    base:desc "Best‑fit parameter values obtained after model calibration."
]

instance UpdateModelParametersAction : DTDFVocab:Action [
    base:desc "Updates the internal representation of Model B with newly calibrated parameters."
    DTDFVocab:IsAutomatic true
]

instance UnsafeTemperatureAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating temperature excursion beyond safe limits."
]

instance HeatBedStateEstimateInsight : DTDFVocab:Insight [
    base:desc "Estimated temperature of the heat‑bed (non‑measured state) provided by the Kalman filter."
]

instance RecommendedControllerParametersInsight : DTDFVocab:Insight [
    base:desc "Suggested Bang‑bang controller parameters (LL, UL, H, C) derived from what‑if simulations."
]

instance OptimiseControllerParametersAction : DTDFVocab:Action [
    base:desc "Re‑configures the controller with optimised parameters."
    DTDFVocab:IsAutomatic true
]

instance PerformanceViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of safety or performance violations prompting self‑adaptation."
]

instance ActuateHeatBedAndFanAction : DTDFVocab:Action [
    base:desc "Sends ON/OFF commands to HeatBedActuator and FanActuator via RabbitMQ."
    DTDFVocab:IsAutomatic true
]

// =============================================================
// Physical Components & Environment
// =============================================================
instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi hosting the low‑level driver, controller and enabler software."
]

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, FanActuator, RaspberryPiController, InternalTempSensor1, InternalTempSensor2, ExternalTempSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital‑Twin components publish control commands to the same RabbitMQ broker; the controller on the Raspberry Pi subscribes to these messages. Commands comprise fan activation/deactivation, heat‑bed heating signals, and parameter settings such as lower/upper temperature limits (LL, UL), heating duration (H) and waiting duration (C). The command messages follow the AMQP format used by RabbitMQ. Upon receipt, the controller executes a bang‑bang‑style control law and the low‑level driver enforces a safe‑protocol before applying actuator commands. The controller then publishes state feedback (e.g., current actuator status) back to RabbitMQ, providing execution confirmation to the DT."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sensor data from the physical twin (two internal temperature sensors and one external sensor) are streamed continuously to the low‑level driver, which publishes the readings to the RabbitMQ message broker. The controller also publishes its state changes to RabbitMQ. DT components such as real‑time visualisation, on‑demand calibration, Kalman‑filter based anomaly detection and co‑simulation subscribe to these topics and operate in (near) real‑time, enabling the dashboard to reflect the current incubator status. Calibration and anomaly detection are triggered on‑demand rather than at a fixed periodic interval. The documents do not state explicit sampling periods, latency requirements or temporal granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The incubator DT is orchestrated around a RabbitMQ message broker that mediates communication between physical and cyber components. Low‑level driver abstracts sensor and actuator I/O and publishes measurements to RabbitMQ; the controller (a bang‑bang logic) consumes these measurements, issues fan and heat‑bed commands, and publishes its control states. Separate DT services—real‑time visualisation (using a time‑series database and dashboard), on‑demand model calibration, Kalman‑filter based anomaly detection, and co‑simulation for what‑if analysis—are implemented as independent processes subscribing to the same message bus, achieving loose coupling and coordinated operation. Calibration updates model parameters used by monitors and the Kalman filter, while the self‑adaptation loop (detect‑plan‑execute) closes the coordination across components."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is governed by four explicit assumptions: (1) uniform temperature distribution inside the box (ensured by the fan), (2) negligible heat accumulation in the box walls, (3) constant specific heat capacity of air, and (4) all electrical power converted to heat in the air (relaxed in Model B). Validation experiments demonstrated that Model B better predicts the heat‑bed’s thermal inertia, confirming higher fidelity for that aspect. Calibration algorithms continuously adjust model parameters using measured sensor data to reduce prediction error. Uncertainty sources include the simplifying assumptions, variations in ambient temperature, and unmodeled heat losses. Anomaly detection is performed by a Kalman filter that compares measured temperatures with Model B predictions, flagging deviations as potential faults. Quality assurance is achieved through on‑demand calibration, continuous monitoring, and re‑validation of models when anomalies are detected."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the physical twin and the digital twin is realized through a RabbitMQ message broker, which operates over TCP/IP. All components (low‑level driver, controller, and DT services) connect in a star topology to the broker, enabling publish/subscribe messaging. RabbitMQ supplies reliable message delivery and supports lightweight, on‑premise deployment; however, explicit bandwidth, latency, redundancy, or security protocol specifications (e.g., TLS) are not detailed in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external software is realised through the open‑source RabbitMQ broker (AMQP) for publish/subscribe messaging and a time‑series database (unspecified) for persisting sensor streams and supporting the dashboard. The low‑level driver provides a hardware‑abstraction layer that enables the DT to interoperate with other enterprise systems or additional Digital Twins via standard messaging protocols. No further external system dependencies, interoperability standards, or integration patterns are detailed in the documents."
]