// -----------------------
// Physical Sensing Components
// -----------------------
instance BoxTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer inside incubator box (−55 °C to +125 °C, 0.5 °C accuracy)"
    DTDFVocab:producedData BoxTempSensor1Stream
]

instance BoxTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer inside incubator box (second sensor, same specs as BoxTempSensor1)"
    DTDFVocab:producedData BoxTempSensor2Stream
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer measuring ambient room temperature (−55 °C to +125 °C, 0.5 °C accuracy)"
    DTDFVocab:producedData AmbientTempSensorStream
]

// -----------------------
// Data Transmitted (Physical‑to‑Virtual)
// -----------------------
instance BoxTempSensor1Stream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxTempSensor1
]

instance BoxTempSensor2Stream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxTempSensor2
]

instance AmbientTempSensorStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// -----------------------
// Data (Digital Twin)
// -----------------------
instance BoxTempSensor1Data : DTDFVocab:Data [
    base:desc "Temperature reading from BoxTempSensor1"
    DTDFVocab:fromData BoxTempSensor1Stream
    DTDFVocab:inputTo RabbitMQBroker
]

instance BoxTempSensor2Data : DTDFVocab:Data [
    base:desc "Temperature reading from BoxTempSensor2"
    DTDFVocab:fromData BoxTempSensor2Stream
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Ambient room temperature reading from AmbientTempSensor"
    DTDFVocab:fromData AmbientTempSensorStream
    DTDFVocab:inputTo RabbitMQBroker
]

// -----------------------
// Acting Components
// -----------------------
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heatbed (214 mm × 214 mm × 3 mm) providing ≥100 W heating, switched by MOSFET driver on PCB"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V fan circulating air at ≈0.02 m s⁻¹, driven via MOSFET/optocoupler stage"
]

// -----------------------
// Physical Components & Environment
// -----------------------
instance IncubatorBox : DTDFVocab:Component [
    base:desc "Styrofoam insulated box (~0.03 m³ air volume) housing the incubator"
]

instance Heatbed : DTDFVocab:Component [
    base:desc "Resistive heating element integrated in the box floor"
]

instance Fan : DTDFVocab:Component [
    base:desc "Small fan providing airflow inside the incubator"
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running DT software and GPIO control"
]

instance ControlPCB : DTDFVocab:Component [
    base:desc "Custom PCB with MOSFET power switches and optocouplers for heatbed and fan"
]

instance DCPowerSupply : DTDFVocab:Component [
    base:desc "DC power supply providing required voltages for all components"
]

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains IncubatorBox, Heatbed, Fan, RaspberryPiController, ControlPCB, DCPowerSupply,
                 BoxTempSensor1, BoxTempSensor2, AmbientTempSensor,
                 HeatbedActuator, FanActuator
]

// -----------------------
// Enablers (Tooling & Platforms)
// -----------------------
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on the Raspberry Pi, receives temperature messages from sensors"
    DTDFVocab:enables RealTimeMonitoringService
    DTDFVocab:enables ParameterCalibrationService
    DTDFVocab:enables TemperatureSimulationServiceA
    DTDFVocab:enables TemperatureSimulationServiceB
    DTDFVocab:enables HeatingCycleOptimizationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Python simulation engine executing thermal models"
    DTDFVocab:enables TemperatureSimulationServiceA
    DTDFVocab:enables TemperatureSimulationServiceB
]

instance SciPyCalibrator : DTDFVocab:Enabler [
    base:desc "SciPy non‑linear least‑squares optimizer used for model parameter calibration"
    DTDFVocab:enables ParameterCalibrationService
]

instance PythonController : DTDFVocab:Enabler [
    base:desc "Raspberry Pi controller using GPIO library to drive MOSFET switches and execute DT services"
    DTDFVocab:enables RealTimeMonitoringService
    DTDFVocab:enables HeatingCycleOptimizationService
    DTDFVocab:enables AdjustSetpointAction
    DTDFVocab:enables SwitchHeatbedAction
    DTDFVocab:enables SwitchFanAction
]

// -----------------------
// Models (Physics‑Based)
// -----------------------
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Air temperature dynamics model with single thermal capacitance C_air and conductance G_box"
    DTDFVocab:inputTo SimulationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Extended model adding heatbed capacitance C_heater and conductance G_heater"
    DTDFVocab:inputTo SimulationEngine
]

// -----------------------
// Services
// -----------------------
instance TemperatureSimulationServiceA : DTDFVocab:Service [
    base:desc "Simulation of incubator temperature using ThermalModelA"
    DTDFVocab:provides TemperatureSimulationInsightA
]

instance TemperatureSimulationServiceB : DTDFVocab:Service [
    base:desc "Simulation using ThermalModelB (including heatbed dynamics)"
    DTDFVocab:provides TemperatureSimulationInsightB
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibration of model parameters (C_air, G_box, etc.) via gradient‑descent least‑squares optimizer"
    DTDFVocab:provides CalibrationUpdateInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature limits and violation detection"
    DTDFVocab:provides TemperatureViolationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection using safe‑state protocols"
    DTDFVocab:provides FaultDetectionInsight
]

instance HeatingCycleOptimizationService : DTDFVocab:Service [
    base:desc "Bang‑bang heating‑cycle optimisation with configurable lower/upper limits and durations"
    DTDFVocab:provides HeatingCycleOptimizationInsight
]

// -----------------------
// Insights
// -----------------------
instance TemperatureSimulationInsightA : DTDFVocab:Insight [
    base:desc "Predicted air temperature from Model A"
]

instance TemperatureSimulationInsightB : DTDFVocab:Insight [
    base:desc "Predicted air temperature from Model B including heatbed effect"
]

instance CalibrationUpdateInsight : DTDFVocab:Insight [
    base:desc "Updated thermal model parameters (C_air, G_box, etc.) after calibration"
]

instance TemperatureViolationInsight : DTDFVocab:Insight [
    base:desc "Detected temperature violation beyond configured limits"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detected fault condition requiring transition to safe state"
]

instance HeatingCycleOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimised heating and waiting durations for bang‑bang controller"
]

// -----------------------
// Actions
// -----------------------
instance AdjustSetpointAction : DTDFVocab:Action [
    base:desc "Operator adjusts temperature set‑point or control duration"
    DTDFVocab:IsAutomatic false
]

instance SwitchHeatbedAction : DTDFVocab:Action [
    base:desc "Activate or deactivate heatbed via MOSFET driver"
    DTDFVocab:IsAutomatic true
]

instance SwitchFanAction : DTDFVocab:Action [
    base:desc "Turn fan on/off via MOSFET/optocoupler stage"
    DTDFVocab:IsAutomatic true
]

instance OptimizeHeatingAction : DTDFVocab:Action [
    base:desc "Execute optimized heating cycle based on bang‑bang controller"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT components subscribe to the same RabbitMQ broker and send command messages (e.g., turn heatbed on/off, set fan speed) that are received by the controller on the Raspberry Pi, which then actuates the hardware through the PCB."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture comprises the Raspberry Pi controller, a low‑level driver, a RabbitMQ communication server, and external DT modules that listen to the broker to receive sensor data, run simulations, perform calibration, and publish control commands back to the broker, forming a closed feedback loop."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing simulated temperature trajectories with measurements from uniform‑temperature experiments (max deviation ≤ 7 °C). Assumptions such as uniform air temperature (validated by fan operation) and negligible heat loss through walls are documented; calibration residuals are minimised using non‑linear least‑squares to ensure model validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication between PT and DT is realised through a RabbitMQ broker running locally on the Raspberry Pi. The low‑level driver publishes sensor readings to the broker; the controller and other DT components subscribe to these topics. Conversely, control commands are published to the broker and consumed by the controller, which then actuates hardware via GPIO. All exchanges occur over the Pi’s internal network stack; the specific messaging protocol is that provided by RabbitMQ (e.g., AMQP) as implemented in the software, though only RabbitMQ is explicitly mentioned in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT components (RabbitMQ server, low‑level driver, controller code, and calibration scripts) are all deployed on the Raspberry Pi 4 Model B; source code and hardware designs are hosted publicly on GitHub."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver implements a safe‑state protocol that forces the heatbed and fan into predefined safe conditions if abnormal sensor readings or communication failures are detected. Electrical isolation is achieved with optocouplers separating the Raspberry Pi GPIO from the MOSFET power stages, reducing risk of hardware damage. The controller enforces lower (LL) and upper (UL) temperature thresholds to prevent overheating. Fan voltage specifications (12 V/24 V) and heatbed power requirements (≥100 W) are respected to ensure safe electrical operation."
]