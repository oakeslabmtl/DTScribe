// C3: Physical Sensing Components
instance ForceSensorNetwork : DTDFVocab:SensingComponent [
    base:desc "Deployed time-series sensors capturing real-time operational forces (e.g., accelerometers, force sensors) on the Physical Twin to monitor dynamic interactions like chassis dynamics and movement trajectories."
    DTDFVocab:producedData ForceSensorDataTransmitted
]

instance EnvironmentalMonitor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensors measuring external conditions (e.g., temperature, pressure) impacting the Physical Twin's operational performance."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

instance PositionTrackingSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors tracking spatial positioning and displacement of Physical Twin components (e.g., wheels, chassis) with high-frequency sampling."
    DTDFVocab:producedData PositionDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance ForceSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ForceSensorNetwork
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalMonitor
]

instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionTrackingSensor
]

// C10: Models/Data
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "Geometric representation of Physical Twin components (e.g., car chassis, wheels) created using CAD systems for structural analysis."
    DTDFVocab:inputTo CADModellingEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Differential equation-based model capturing temporal behaviors like force dynamics and movement trajectories using MATLAB/Simulink."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance MultiphysicsSimulationModel : DTDFVocab:Model [
    base:desc "Multiphysics simulation model (e.g., fluid-structure interactions) implemented using ANSYS/Fluent for automotive system analysis."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance KnowledgeGraphModel : DTDFVocab:Model [
    base:desc "Structured representation of Physical Twin's cyber and physical aspects (e.g., sensor-actuator relationships) enabling semantic querying and model integration."
    DTDFVocab:inputTo OntologyEnabler
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "High-frequency time-series data collected from Physical Twin sensors (e.g., accelerometers, force sensors) for real-time calibration."
    DTDFVocab:fromData ForceSensorDataTransmitted, EnvironmentalDataTransmitted, PositionDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, FaultDetectionEnabler, StateEstimationEnabler
]

instance StructuredMetadata : DTDFVocab:Data [
    base:desc "Relational database storing model parameters, calibration histories, and system metadata for Physical Twin operations."
    DTDFVocab:fromData MetadataDataTransmitted
]

// C11: Enablers
instance CADModellingEnabler : DTDFVocab:Enabler [
    base:desc "CAD systems (e.g., SolidWorks, CATIA) for geometric and structural modeling of Physical Twin components."
    DTDFVocab:enables CADModelingService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Dynamic simulation engines (MATLAB/Simulink, ANSYS/Fluent) for control system design and multiphysics simulations."
    DTDFVocab:enables DynamicSimulationService, MultiphysicsSimulationService
]

instance OntologyEnabler : DTDFVocab:Enabler [
    base:desc "Knowledge graphs/ontologies storing structured representations of Physical Twin's cyber-physical relationships for semantic reasoning."
    DTDFVocab:enables SemanticQueryService
]

instance TimeSeriesDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Time-series databases (InfluxDB, TimescaleDB) for high-frequency sensor data storage and retrieval."
    DTDFVocab:enables DataStorageService
]

instance RelationalDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Relational databases (PostgreSQL) storing structured metadata and calibration histories."
    DTDFVocab:enables MetadataManagementService
]

instance EdgeComputingEnabler : DTDFVocab:Enabler [
    base:desc "Edge computing infrastructure processing low-latency sensor data at the sensor level to reduce bandwidth usage."
    DTDFVocab:enables RealTimeCalibrationService
]

instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Parameter estimation techniques (Kalman filters, Bayesian updates) refining Digital Twin models using real-time Physical Twin data."
    DTDFVocab:enables ModelCalibrationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Machine learning-based anomaly detection or rule-based systems identifying deviations from expected Physical Twin behavior."
    DTDFVocab:enables AnomalyDetectionService
]

instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "Filtering algorithms (Extended Kalman Filters) fusing sensor data with model predictions for accurate state reconstruction."
    DTDFVocab:enables StateEstimationService
]

instance OptimizationSolverEnabler : DTDFVocab:Enabler [
    base:desc "Constrained optimization techniques (gradient descent, genetic algorithms) deriving control parameters or design improvements."
    DTDFVocab:enables OptimizationService
]

instance CloudHPCEnabler : DTDFVocab:Enabler [
    base:desc "Cloud/High-Performance Computing infrastructure hosting resource-intensive simulations for predictive analysis."
    DTDFVocab:enables LargeScaleSimulationService
]

instance ContainerizationEnabler : DTDFVocab:Enabler [
    base:desc "Containerization tools (Docker, Kubernetes) enabling scalable deployment of Digital Twin components across heterogeneous environments."
    DTDFVocab:enables ScalableDeploymentService
]

instance APIMiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "APIs and middleware (RESTful APIs, MQTT) facilitating interoperability between Physical Twin sensors, Digital Twin models, and user interfaces."
    DTDFVocab:enables InteroperabilityService
]

instance DigitalTwinPlatformEnabler : DTDFVocab:Enabler [
    base:desc "Digital Twin platforms (Siemens MindSphere, PTC ThingWorx) orchestrating data flow, model updates, and service delivery."
    DTDFVocab:enables PlatformOrchestrationService
]

instance RealTimeProtocolEnabler : DTDFVocab:Enabler [
    base:desc "Low-latency communication standards (OPC UA, DDS) enabling synchronized Physical Twin-Digital Twin interactions."
    DTDFVocab:enables SynchronizationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "3D modeling software (Unity, Unreal Engine) and data analytics dashboards (Tableau, Grafana) for immersive and customizable visualizations."
    DTDFVocab:enables VisualizationService
]

instance AIMLIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "AI/ML integration embedding predictive models (e.g., neural networks for fault forecasting) within the Digital Twin's algorithmic pipeline."
    DTDFVocab:enables PredictiveAnalysisService
]

// C6: Services
instance CADModelingService : DTDFVocab:Service [
    base:desc "Geometric and structural modeling service providing static representations of Physical Twin components using CAD systems."
    DTDFVocab:provides CADModelInsight
]

instance DynamicSimulationService : DTDFVocab:Service [
    base:desc "Dynamic simulation service capturing temporal behaviors (e.g., force dynamics, movement trajectories) using differential equation models."
    DTDFVocab:provides DynamicBehaviorInsight
]

instance MultiphysicsSimulationService : DTDFVocab:Service [
    base:desc "Multiphysics simulation service analyzing fluid-structure interactions and other coupled physical phenomena."
    DTDFVocab:provides MultiphysicsAnalysisInsight
]

instance SemanticQueryService : DTDFVocab:Service [
