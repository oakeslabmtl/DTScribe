// Acting Component
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "The heating element (heat‑bed) supplies heat to raise the incubator internal temperature; it is driven by an embedded controller receiving set‑points from the cyber component."
]

// Sensing Components
instance InteriorTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor located inside the incubator box (first interior sensor)."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance InteriorTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor located inside the incubator box (second interior sensor)."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance ExteriorTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor monitoring the exterior temperature of the incubator."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// Physical‑to‑Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTempSensor1, InteriorTempSensor2, ExteriorTempSensor
]

// Data (raw sensor readings)
instance TemperatureSensorData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature readings streamed from the three sensors for calibration and monitoring."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo CalibrationEngine, FaultDetector, SupervisoryController, StateEstimator
]

// Models
instance SimpleThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model of the incubator with two free parameters (e.g., heat transfer coefficient and thermal inertia)."
    DTDFVocab:inputTo SimulationEngine, OptimisationEngine
]

instance RichThermalModel : DTDFVocab:Model [
    base:desc "Richer analytical model with four free parameters capturing detailed heat‑bed dynamics."
    DTDFVocab:inputTo SimulationEngine, OptimisationEngine
]

// Enablers
instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Algorithm that calibrates model parameters by fitting sensor data to the analytical models."
    DTDFVocab:enables ModelCalibrationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine that uses calibrated thermal models to predict internal temperature and thermal inertia."
    DTDFVocab:enables SimulationPredictionService
]

instance OptimisationEngine : DTDFVocab:Enabler [
    base:desc "Optimisation algorithm that computes optimal control set‑points to maintain target temperature while minimizing energy."
    DTDFVocab:enables ControlOptimisationService
]

instance FaultDetector : DTDFVocab:Enabler [
    base:desc "Fault detection algorithm that analyses temperature streams to identify sensor or actuator anomalies."
    DTDFVocab:enables FaultDetectionService
]

instance SupervisoryController : DTDFVocab:Enabler [
    base:desc "Supervisory controller that evaluates safety constraints and issues control adjustments."
    DTDFVocab:enables SafetyOptimalityCheckService
]

instance StateEstimator : DTDFVocab:Enabler [
    base:desc "State estimator that fuses sensor data and model predictions to estimate the current thermal state."
    DTDFVocab:enables StateEstimationService
]

// Services
instance SimulationPredictionService : DTDFVocab:Service [
    base:desc "Provides simulation‑based prediction of the incubator’s thermal behaviour using calibrated models."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Delivers real‑time monitoring of temperature sensor streams."
    DTDFVocab:provides MonitoringAlertInsight
]

instance SafetyOptimalityCheckService : DTDFVocab:Service [
    base:desc "Performs safety and optimality checks, detecting violations and suggesting corrective actions."
    DTDFVocab:provides SafetyViolationInsight, OptimalSetPointAction
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Executes calibration of the thermal models with live sensor data."
    DTDFVocab:provides CalibrationCompleteInsight
]

instance ControlOptimisationService : DTDFVocab:Service [
    base:desc "Optimises control set‑points to achieve target temperature efficiently."
    DTDFVocab:provides OptimisedSetPointInsight, ControlAdjustmentAction
]

instance VisualisationService : DTDFVocab:Service [
    base:desc "Advanced visualisation of temperature evolution for operators and engineers."
    DTDFVocab:provides VisualizationAlertInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects sensor or actuator faults from temperature data."
    DTDFVocab:provides FaultDetectionInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Provides estimated thermal state based on sensor data and model outputs."
    DTDFVocab:provides StateEstimationInsight
]

// Insights
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory generated by the simulation engine."
]

instance MonitoringAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when temperature deviates from expected ranges during real‑time monitoring."
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of safety constraint breach (e.g., overheating) by supervisory controller."
]

instance CalibrationCompleteInsight : DTDFVocab:Insight [
    base:desc "Indicates successful calibration of model parameters with current sensor data."
]

instance OptimisedSetPointInsight : DTDFVocab:Insight [
    base:desc "Optimised control set‑point computed by the optimisation engine."
]

instance VisualizationAlertInsight : DTDFVocab:Insight [
    base:desc "Visualization alert highlighting temperature trends or anomalies for operator."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identified fault condition in temperature sensor or heat‑bed actuator."
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated internal temperature state derived from sensor data and model predictions."
]

// Actions
instance OptimalSetPointAction : DTDFVocab:Action [
    base:desc "Suggested optimal heating set‑point to maintain target temperature."
    DTDFVocab:IsAutomatic false
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of heat‑bed actuator to new set‑point."
    DTDFVocab:IsAutomatic true
]

// Physical Components (for context)
instance IncubatorBox : DTDFVocab:Component [
    base:desc "Styrofoam insulated container forming the incubator’s physical enclosure."
]

instance Heatbed : DTDFVocab:Component [
    base:desc "Heating element (heat‑bed) that provides thermal energy to raise internal temperature."
]

instance CoolingFan : DTDFVocab:Component [
    base:desc "Fan that distributes heat evenly inside the incubator."
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi running the control software and communicating set‑points to the heat‑bed."
]

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains IncubatorBox, Heatbed, CoolingFan, RaspberryPiController,
               InteriorTempSensor1, InteriorTempSensor2, ExteriorTempSensor,
               HeatbedActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Raspberry Pi serves as the controller for the physical twin, issuing control actions to the heat‑bed and the fan based on the digital twin’s algorithms; the documents state that the plant is controlled by a Raspberry Pi but give no details on command types, message formats, validation/authentication, feedback loops, conflict resolution, or execution confirmation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The lifecycle described consists of (i) model development, where abstract representations (e.g., CAD or dynamic differential‑equation models) of the physical system are created; (ii) deployment/integration, where these models are incorporated into the Digital Twin together with sensor data streams; (iii) runtime operation, in which continuous data collection from the physical twin triggers calibration algorithms that update model parameters, monitors that check safety and optimality, and possibly human or higher‑level algorithmic interventions; and (iv) maintenance, where updated models and algorithms replace outdated ones. Transitions between phases are managed by the calibration‑monitoring loop illustrated in Figure 1, providing implicit governance through continuous model updates and safety monitoring."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the two temperature prediction models against the measured sensor data; the four‑parameter model was found to better capture the thermal inertia of the heatbed, indicating higher validity. Calibration algorithms update model parameters to minimise prediction error, providing a quantitative validation step. Monitors continuously check the calibrated model predictions for safety and optimality violations, and any detected deviation triggers corrective actions, constituting an ongoing verification and quality‑assurance process."
]