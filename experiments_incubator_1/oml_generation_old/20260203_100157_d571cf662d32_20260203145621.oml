// Sensing component
instance PhysicalTwinSensor : DTDFVocab:SensingComponent [
    base:desc "Collects continuous sensor streams from the physical twin."
    DTDFVocab:producedData PhysicalTwinDataStream
]

// Data transmitted
instance PhysicalTwinDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalTwinSensor
]

// Data
instance ObservationTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series observations collected from the twin."
    DTDFVocab:fromData PhysicalTwinDataStream
    DTDFVocab:inputTo SimulationEngine
    DTDFVocab:inputTo CalibrationAlgorithm
]

// Models
instance CADModel : DTDFVocab:Model [
    base:desc "CAD model storing dimensional and shape information of the system."
    DTDFVocab:inputTo SimulationEngine
]

instance DynamicODEModel : DTDFVocab:Model [
    base:desc "Dynamic model expressed by differential equations capturing forces and motion."
    DTDFVocab:inputTo SimulationEngine
]

instance AnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model part of the CPS knowledge base."
    DTDFVocab:inputTo SimulationEngine
]

// Enablers
instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Engine that runs simulations reproducing current operating conditions."
    DTDFVocab:enables SimulationService
    DTDFVocab:enables OptimizationService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Algorithm adjusting model parameters based on sensor data."
    DTDFVocab:enables CalibrationService
]

// Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs real‑time simulation of current operating conditions."
    DTDFVocab:provides FaultDetectionAlert
    DTDFVocab:provides StateEstimationInsight
    DTDFVocab:provides AdjustOperationalParameters
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that performs optimisation calculations for resource usage."
    DTDFVocab:provides OptimizationReport
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that calculates calibration parameters for model fidelity."
    DTDFVocab:provides CalibrationResultInsight
]

// Insights
instance FaultDetectionAlert : DTDFVocab:Insight [
    base:desc "Alert generated when simulation detects safety violations."
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimation of unmeasured variables based on sensor data and models."
]

instance OptimizationReport : DTDFVocab:Insight [
    base:desc "Report summarising resource usage optimisation calculations."
]

instance CalibrationResultInsight : DTDFVocab:Insight [
    base:desc "Result of calibration algorithm indicating updated model parameters."
]

// Actions
instance AdjustOperationalParameters : DTDFVocab:Action [
    base:desc "Automatic adjustment of operational parameters by supervisory controller."
    DTDFVocab:IsAutomatic true
]

instance HumanIntervention : DTDFVocab:Action [
    base:desc "Action requiring human operator intervention upon detecting violations."
    DTDFVocab:IsAutomatic false
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Development phase: create abstract representations such as static CAD geometry models of the vehicle structure and dynamic models expressed by differential equations for behavior prediction. Representation types shift from static‑geometry CAD to ODE‑based dynamic simulation models as the system progresses toward deployment. Transition management is achieved by embedding the models into a digital twin framework, where calibration algorithms continuously update model parameters with real‑time telemetry collected from the physical twin. Lifecycle governance is exercised through continuous monitoring modules that apply fault detectors, supervisory controllers, state estimators, and optimizers to assess safety and performance; when violations are detected, automatic or human‑initiated interventions adjust the physical twin and propagate updated model parameters back into the twin."
]