// ====================
// Physical Sensing Components
// ====================

instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor placed inside the incubator box to monitor internal temperature."
    DTDFVocab:producedData InternalTempDataTransmittedA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor placed inside the incubator box to monitor internal temperature (second sensor for redundancy)."
    DTDFVocab:producedData InternalTempDataTransmittedB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor mounted outside the incubator box to provide ambient reference temperature."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// ====================
// Data Transmitted from Sensors
// ====================

instance InternalTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// ====================
// Data Instances (collected temperature readings)
// ====================

instance InternalTemperatureDataA : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from internal sensor A (±0.5 °C accuracy)."
    DTDFVocab:fromData InternalTempDataTransmittedA
    DTDFVocab:inputTo CalibrationEngine, SimulationEngine
]

instance InternalTemperatureDataB : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from internal sensor B (±0.5 °C accuracy)."
    DTDFVocab:fromData InternalTempDataTransmittedB
    DTDFVocab:inputTo CalibrationEngine, SimulationEngine
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Timestamped ambient temperature reading from the external sensor (±0.5 °C accuracy)."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo CalibrationEngine, SimulationEngine
]

// ====================
// Physical Acting Components
// ====================

instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed element that generates heat inside the incubator box, driven by bang‑bang control logic."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Small fan that circulates air within the incubator, ensuring uniform temperature distribution."
]

// ====================
// Analytical Models
// ====================

instance SimpleIncubatorModel : DTDFVocab:Model [
    base:desc "Simplified temperature model with two free parameters that predicts incubator interior temperature."
    DTDFVocab:inputTo CalibrationEngine, SimulationEngine
]

instance DetailedIncubatorModel : DTDFVocab:Model [
    base:desc "Detailed temperature model with four free parameters capturing the thermal inertia of the heat‑bed."
    DTDFVocab:inputTo CalibrationEngine, SimulationEngine
]

// ====================
// Enablers (Algorithms / Engines)
// ====================

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that updates model parameters using the latest temperature data."
    DTDFVocab:enables CalibrationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine that predicts future temperature dynamics based on calibrated models."
    DTDFVocab:enables SimulationService
]

instance MonitoringEngine : DTDFVocab:Enabler [
    base:desc "Monitoring algorithm that evaluates safety limits and detects operational violations."
    DTDFVocab:enables MonitoringService
]

instance ControlEngine : DTDFVocab:Enabler [
    base:desc "Control adjustment logic that generates bang‑bang commands for heat‑bed and fan based on model insights."
    DTDFVocab:enables ControlAdjustmentService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Visualization module that renders temperature trends and model predictions."
    DTDFVocab:enables VisualizationService
]

instance ReconfigurabilityEngine : DTDFVocab:Enabler [
    base:desc "Reconfigurability algorithm that adapts system parameters to changing environmental conditions or workloads."
    DTDFVocab:enables ReconfigurabilityService
]

// ====================
// Services
// ====================

instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Continuous acquisition of temperature sensor data from the physical twin."
    DTDFVocab:provides TemperatureAcquisitionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration of analytical incubator models using incoming temperature data."
    DTDFVocab:provides ModelParameterInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation/prediction of temperature dynamics for future state forecasting."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitoring of operational safety and optimality, raising alerts on threshold violations."
    DTDFVocab:provides SafetyAlertInsight
]

instance ControlAdjustmentService : DTDFVocab:Service [
    base:desc "Adjustment of Raspberry Pi control commands based on model‑driven insights."
    DTDFVocab:provides TemperatureControlAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Advanced visualisation of temperature trends and model predictions."
    DTDFVocab:provides TemperatureTrendInsight
]

instance ReconfigurabilityService : DTDFVocab:Service [
    base:desc "Reconfigurability support to adapt to environmental changes or workload variations."
    DTDFVocab:provides ReconfigurationAction
]

// ====================
// Insights
// ====================

instance TemperatureAcquisitionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful acquisition and timestamping of temperature measurements."
]

instance ModelParameterInsight : DTDFVocab:Insight [
    base:desc "Insight describing updated model parameters that reflect current operating conditions."
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Insight providing predicted temperature trajectory over the upcoming time horizon."
]

instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Insight that an operating safety limit (lower or upper temperature bound) has been breached."
]

instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Insight visualising historical and projected temperature trends for operator awareness."
]

// ====================
// Actions
// ====================

instance TemperatureControlAction : DTDFVocab:Action [
    base:desc "Command to turn heat‑bed on/off or adjust fan speed based on control law."
    DTDFVocab:IsAutomatic true
]

instance ReconfigurationAction : DTDFVocab:Action [
    base:desc "Operation to modify system configuration (e.g., sampling period, control thresholds) in response to environmental changes."
    DTDFVocab:IsAutomatic false
]

// ====================
// Environment & Physical Components (optional context)
// ====================

instance IncubatorContainer : DTDFVocab:Component [
    base:desc "Styrofoam‑insulated container housing the heat‑bed, fan, and internal temperature sensors."
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi that runs sensor drivers, control logic, and communicates via RabbitMQ."
]

instance RabbitMQServer : DTDFVocab:Component [
    base:desc "Message broker that transports sensor data and control commands between physical twin and digital twin."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "When the digital twin’s monitors detect safety or performance violations, it can trigger human operators or automated algorithms to issue corrective actions to the physical twin; the documents do not specify concrete command formats, validation, or acknowledgement mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is realized as a set of co‑located software components on the Raspberry Pi that hosts the physical incubator. A RabbitMQ server acts as the communication middleware (Communication Server) mediating messages between a low‑level driver that directly controls the heatbed and fan hardware and a high‑level controller that implements the temperature regulation logic. The DT component subscribes to the same RabbitMQ topics, receives sensor readings (two internal and one external temperature values), observes actuator commands, and updates its thermal models using calibration algorithms. It can also generate simulated actions that are sent back through the same message bus. This architecture follows a centralized, component‑based constellation where all twin services (data acquisition, model updating, simulation, and decision support) are integrated via the message broker on a single physical node."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed by comparing the predicted temperature trajectories against measured data from the incubator. Experimental results indicated that the four‑parameter model provides higher fidelity in capturing the heatbed’s thermal inertia than the simpler two‑parameter model. Validation is performed through empirical experiments, and calibration algorithms update the model parameters to minimise prediction error. Uncertainty arises from parameter estimation and sensor noise; the DT uses continuous monitoring to detect deviations and apply corrective updates, ensuring ongoing model validity."
]