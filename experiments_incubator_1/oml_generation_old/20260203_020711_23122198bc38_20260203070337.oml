// --------------------------------------------------
// Acting Components
// --------------------------------------------------
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed heating element that provides power to raise the incubator temperature."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan driven by the Raspberry Pi to circulate air inside the insulated styrofoam box."
]

// --------------------------------------------------
// Sensing Components
// --------------------------------------------------
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor positioned inside the incubator box (sensor A)."
    DTDFVocab:producedData InternalTempDataTxA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor positioned inside the incubator box (sensor B)."
    DTDFVocab:producedData InternalTempDataTxB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor positioned outside the incubator box to monitor ambient temperature."
    DTDFVocab:producedData ExternalTempDataTx
]

// --------------------------------------------------
// Physical‑to‑Virtual Interaction (Data Transmission)
// --------------------------------------------------
instance InternalTempDataTxA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempDataTxB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// --------------------------------------------------
// Data (temperature measurements)
// --------------------------------------------------
instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurement from internal sensor A."
    DTDFVocab:fromData InternalTempDataTxA
    DTDFVocab:inputTo CalibrationEngine, MonitoringEngine
]

instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurement from internal sensor B."
    DTDFVocab:fromData InternalTempDataTxB
    DTDFVocab:inputTo CalibrationEngine, MonitoringEngine
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurement from the external ambient sensor."
    DTDFVocab:fromData ExternalTempDataTx
    DTDFVocab:inputTo CalibrationEngine, MonitoringEngine
]

// --------------------------------------------------
// Models (thermal dynamics)
// --------------------------------------------------
instance TwoParameterThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model of the incubator with two free parameters (heat transfer coefficient, thermal mass)."
    DTDFVocab:inputTo PredictionEngine
]

instance FourParameterThermalModel : DTDFVocab:Model [
    base:desc "Enhanced analytical thermal model with four free parameters (adds fan airflow factor and heat‑bed capacity) that better captures thermal inertia."
    DTDFVocab:inputTo PredictionEngine
]

// --------------------------------------------------
// Enablers (algorithms / execution engines)
// --------------------------------------------------
instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that continuously updates model parameters from incoming temperature data."
    DTDFVocab:enables CalibrationService
]

instance MonitoringEngine : DTDFVocab:Enabler [
    base:desc "Real‑time monitoring engine that evaluates sensor streams and checks safety limits."
    DTDFVocab:enables RealTimeMonitoringService, SafetyCheckService
]

instance PredictionEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs the calibrated thermal models to predict future box temperature."
    DTDFVocab:enables PredictiveSimulationService
]

instance DecisionSupportEngine : DTDFVocab:Enabler [
    base:desc "Decision‑support logic that proposes control actions (heat‑bed power, fan speed) based on predictions and safety checks."
    DTDFVocab:enables DecisionSupportService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Visualization component that renders current and predicted temperature trajectories for operators."
    DTDFVocab:enables VisualizationService
]

// --------------------------------------------------
// Services (functionalities offered by the DT)
// --------------------------------------------------
instance CalibrationService : DTDFVocab:Service [
    base:desc "Continuously calibrates thermal models using latest temperature measurements."
    DTDFVocab:provides ModelParameterUpdateInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of temperature sensor streams."
    DTDFVocab:provides TemperatureMonitoringInsight
]

instance SafetyCheckService : DTDFVocab:Service [
    base:desc "Detects violations of temperature safety limits and raises alerts."
    DTDFVocab:provides TemperatureViolationInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Generates predictive temperature trajectories using the calibrated thermal models."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Recommends control actions (adjust heat‑bed power, fan speed) to achieve target temperature safely."
    DTDFVocab:provides AdjustHeatbedPowerAction, AdjustFanSpeedAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Displays current and predicted temperature trajectories to the operator."
    DTDFVocab:provides TemperatureTrajectoryInsight
]

// --------------------------------------------------
// Insights (information derived from services)
// --------------------------------------------------
instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Current temperature status of internal and external sensors."
]

instance TemperatureViolationInsight : DTDFVocab:Insight [
    base:desc "Indicates that temperature has exceeded predefined safety thresholds."
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Forecasted temperature evolution over the next prediction horizon."
]

instance TemperatureTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of observed and predicted temperature trajectories."
]

instance ModelParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Shows updated values of the thermal model free parameters after calibration."
]

// --------------------------------------------------
// Actions (control commands)
// --------------------------------------------------
instance AdjustHeatbedPowerAction : DTDFVocab:Action [
    base:desc "Adjust the heat‑bed power level to increase or decrease the box temperature."
    DTDFVocab:IsAutomatic false
]

instance AdjustFanSpeedAction : DTDFVocab:Action [
    base:desc "Set the fan speed to modify air circulation inside the incubator."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The controller executed on a Raspberry Pi decides on heating and fan actuation based on the reference temperature. It sends control commands (heat‑bed ON/OFF and fan ON/OFF) as RabbitMQ messages to the low‑level driver. The driver validates the command using an incorporated safe protocol and then issues the corresponding signals to the physical actuators. Execution feedback is implicitly obtained through subsequent sensor readings that are sent back to the broker."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT ingests sensor data and low‑level driver/controller messages from the physical incubator continuously, streams them into a time‑series database and updates visualisations and algorithmic components (calibration, Kalman filter, co‑simulation) essentially in real‑time; the documents do not specify a fixed synchronization interval, frequency, or explicit latency requirements, only that the process operates as soon as messages are received."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT follows a cyber‑physical feedback architecture: data collection (temperature sensors, controller messages) feeds a time‑series store; calibration algorithms update Model B parameters; monitors check safety; a Kalman filter estimates the unmeasured heat‑bed temperature; co‑simulation modules perform what‑if analyses; the resulting model outputs are used to reconfigure the controller, closing the loop. This orchestrated pattern matches the common DT structure of Data, Models, Algorithms, and monitoring/actuation layers described in the documents."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the two temperature prediction models against experimental measurements; the four‑parameter model demonstrated higher fidelity by more accurately representing the heatbed’s thermal inertia. Validation is performed through experiments that record temperature trajectories and assess prediction errors. Uncertainty arises from sensor measurement noise and simplifications in the thermal model; calibration algorithms are employed to estimate the best‑fit parameters, thereby reducing model‑data mismatch. The DT framework includes monitors that detect violations of expected behavior, providing an error‑detection mechanism, and the overall quality assurance relies on the calibration‑validation cycle described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin relies on RabbitMQ as the technical communication backbone. RabbitMQ is an open‑source message broker used for synchronization and messaging between the low‑level driver, the controller, and any DT components. All components act as clients of the central RabbitMQ broker, which can be deployed on‑premise or in the cloud, providing a reliable and lightweight network infrastructure for the DT."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital‑twin logic (e.g., model calibration, monitoring algorithms) is implemented as software components that subscribe to RabbitMQ topics. According to the documents, RabbitMQ can be hosted on‑premise or in the cloud, enabling the DT components to be deployed either on edge devices such as the Raspberry Pi or on external server platforms. No specific computational, storage, or scalability requirements are detailed in the provided material."
]