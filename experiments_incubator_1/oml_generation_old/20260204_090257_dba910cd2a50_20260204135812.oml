    base:desc "Automated or human-validated adjustments to physical twin's operation based on detected faults or performance deviations."
    DTDFVocab:IsAutomatic false
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Supervisory control adjustments to physical twin's operation parameters based on digital twin-generated insights."
    DTDFVocab:IsAutomatic true
]

