// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded thermocouple measuring real-time thermal conditions with ±0.1% precision at 100Hz sampling frequency for dynamic systems."
    DTDFVocab:producedData TimeSeriesTemperatureData
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Strain gauge-based pressure transducer with 12-bit resolution measuring structural loads at 1kHz sampling frequency."
    DTDFVocab:producedData TimeSeriesPressureData
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Piezoelectric accelerometer array capturing multi-axis vibration data with 24-bit resolution at 10kHz for structural health monitoring."
    DTDFVocab:producedData TimeSeriesVibrationData
]

instance ForceSensor : DTDFVocab:SensingComponent [
    base:desc "Load cell measuring dynamic forces with ±0.05% accuracy at 500Hz sampling frequency for real-time control applications."
    DTDFVocab:producedData TimeSeriesForceData
]

instance DisplacementSensor : DTDFVocab:SensingComponent [
    base:desc "Laser displacement sensor with ±0.01mm resolution measuring structural deformations at 1kHz sampling frequency."
    DTDFVocab:producedData TimeSeriesDisplacementData
]

instance FaultAlarmSensor : DTDFVocab:SensingComponent [
    base:desc "Event-based sensor triggering on threshold crossings or fault conditions with millisecond-level latency for immediate anomaly detection."
    DTDFVocab:producedData EventBasedFaultData
]

instance EnvironmentalWeatherStation : DTDFVocab:SensingComponent [
    base:desc "External sensor suite measuring wind speed, humidity, and solar radiation with 1Hz sampling frequency for environmental impact analysis."
    DTDFVocab:producedData EnvironmentalData
]

instance SensorCalibrationLogger : DTDFVocab:SensingComponent [
    base:desc "Embedded system logging sensor calibration parameters and environmental conditions affecting measurement accuracy."
    DTDFVocab:producedData CalibrationMetadata
]

// C4: Physical-to-Virtual Data Transmission
instance TimeSeriesTemperatureData : DTDFVocab:DataTransmitted [
    base:desc "Continuous thermal data stream transmitted via OPC UA protocol at 10-100Hz for real-time thermal analysis."
    DTDFVocab:producedFrom TemperatureSensor
]

instance TimeSeriesPressureData : DTDFVocab:DataTransmitted [
    base:desc "High-frequency pressure measurements transmitted via MQTT protocol at 1kHz for structural dynamics analysis."
    DTDFVocab:producedFrom PressureSensor
]

instance TimeSeriesVibrationData : DTDFVocab:DataTransmitted [
    base:desc "Multi-axis vibration data transmitted via PROFINET protocol at 10kHz for fatigue analysis and fault detection."
    DTDFVocab:producedFrom VibrationSensor
]

instance TimeSeriesForceData : DTDFVocab:DataTransmitted [
    base:desc "Dynamic force measurements transmitted via custom API at 500Hz for control system validation."
    DTDFVocab:producedFrom ForceSensor
]

instance TimeSeriesDisplacementData : DTDFVocab:DataTransmitted [
    base:desc "High-precision displacement data transmitted via Ethernet at 1kHz for structural integrity monitoring."
    DTDFVocab:producedFrom DisplacementSensor
]

instance EventBasedFaultData : DTDFVocab:DataTransmitted [
    base:desc "Event-triggered fault alerts transmitted via MQTT with millisecond latency for immediate response systems."
    DTDFVocab:producedFrom FaultAlarmSensor
]

instance EnvironmentalData : DTDFVocab:DataTransmitted [
    base:desc "Environmental parameters transmitted via CoAP protocol at 1Hz for external condition analysis."
    DTDFVocab:producedFrom EnvironmentalWeatherStation
]

instance CalibrationMetadata : DTDFVocab:DataTransmitted [
    base:desc "Structured metadata including sensor calibration logs and environmental conditions transmitted via REST API."
    DTDFVocab:producedFrom SensorCalibrationLogger
]

// C10: Models/Data
instance GeometricModel : DTDFVocab:Model [
    base:desc "CAD-based geometric representation of physical components with static and quasi-static spatial configurations."
    DTDFVocab:inputTo GeometricModelingEnabler
]

instance BehavioralDynamicsModel : DTDFVocab:Model [
    base:desc "Physics-based simulation model using differential equations to represent dynamic system behavior under operational conditions."
    DTDFVocab:inputTo SimulationEngine
]

instance AnalyticalControlModel : DTDFVocab:Model [
    base:desc "Control-theoretic model using finite element analysis for predictive analysis, fault detection, and optimization."
    DTDFVocab:inputTo OptimizationSolver
]

instance HistoricalOperationalData : DTDFVocab:Data [
    base:desc "Archived datasets including maintenance logs and operational records used for baseline comparisons and trend analysis."
    DTDFVocab:fromData ArchivedOperationalDataTransmitted
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Continuous real-time streams from embedded sensors monitoring current operational state and environmental conditions."
    DTDFVocab:fromData TimeSeriesTemperatureData, TimeSeriesPressureData, TimeSeriesVibrationData, TimeSeriesForceData, TimeSeriesDisplacementData, EnvironmentalData
    DTDFVocab:inputTo StateEstimationEnabler, FaultDetectionEnabler, DataPreprocessingEnabler
]

instance CalibratedModelParameters : DTDFVocab:Data [
    base:desc "Dynamic model parameters updated via calibration algorithms to align simulated behavior with observed physical twin performance."
    DTDFVocab:fromData CalibrationMetadata
    DTDFVocab:inputTo ModelCalibrationEnabler
]

// C11: Enablers
instance OpcUaProtocolEnabler : DTDFVocab:Enabler [
    base:desc "Standardized industrial protocol enabling bidirectional data exchange between physical twin and digital twin at 10-100Hz."
    DTDFVocab:enables RealTimeStateEstimationService
]

instance MqttProtocolEnabler : DTDFVocab:Enabler [
    base:desc "Lightweight IoT protocol for event-driven data transmission from edge devices with millisecond-level latency."
    DTDFVocab:enables EventTriggeredAlertService
]

instance DataPreprocessingEnabler : DTDFVocab:Enabler [
    base:desc "ETL pipeline performing normalization, resampling, and feature extraction on raw sensor data for downstream processing."
    DTDFVocab:enables AnomalyDetectionService
]

instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter-based algorithm reconstructing dynamic system states from noisy sensor data with sub-millimeter accuracy."
    DTDFVocab:enables RealTimeStateEstimationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Machine learning model using isolation forests to classify anomalies in sensor data with 95% detection accuracy."
    DTDFVocab:enables FaultDetectionService
]

instance DataReconciliationEnabler : DTDFVocab:Enabler [
    base:desc "Parameter estimation framework using least squares and Bayesian inference to calibrate models with observed physical twin behavior."
    DTDFVocab:enables ModelCalibrationService
]

instance ModelCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Bayesian inference engine updating digital twin models in real-time using sensor data to reduce model drift."
    DTDFVocab:enables ParameterCalibrationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink-based platform running dynamic simulations to reproduce and predict physical twin behavior under various conditions."
    DTDFVocab:enables BehavioralSimulationService
]

instance OptimizationSolver : DTDFVocab:Enabler [
    base:desc "Gurobi-based mathematical programming solver optimizing operational strategies while adhering to safety and regulatory constraints."
    DTDFVocab:enables OperationalOptimizationService
]

instance GeometricModelingEnabler : DTDFVocab:Enabler [
    base:desc "CAD integration framework enabling hierarchical coupling between low-fidelity and high-fidelity geometric representations."
    DTDFVocab:enables VisualizationService
]

instance DataIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Ontology-driven data mapping framework ensuring consistency across heterogeneous data sources including CAD models and IoT sensors."
    DTDFVocab:enables SemanticIntegrationService
]

// C6: Services
instance RealTimeStateEstimationService : DTDFVocab:Service [
    base:desc "State estimator reconstructing physical twin's dynamic state (position, velocity, temperature) from noisy sensor data with sub-millisecond latency."
    DTDFVocab:provides RealTimeStateInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection algorithm identifying anomalies or deviations in physical twin behavior by comparing real-time data against modeled expectations."
    DTDFVocab:provides FaultDiagnosisInsight
]

instance PerformanceMonitoringService : DTDFVocab:Service [
    base:desc "Continuous evaluation of physical twin's operational metrics (efficiency, safety margins) via monitoring algorithms flagging threshold violations."
    DTDFVocab:provides PerformanceMetricsInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibration algorithm updating digital twin's models with best-estimate parameters derived from sensor data to reduce model drift."
    DTDFVocab:provides CalibratedModelInsight
]

instance OperationalOptimizationService : DTDFVocab:Service [
    base:desc "Optimizer determining control inputs or operational strategies maximizing performance while adhering to safety and regulatory constraints."
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Time-series forecasting model projecting future system degradation or failure risks to enable proactive maintenance scheduling."
    DTDFVocab:provides MaintenanceRecommendationInsight
]

instance BehavioralSimulationService : DTDFVocab:Service [
    base:desc "Dynamic simulation reproducing and predicting physical twin's behavior under current or hypothetical operating conditions for what-if analysis."
    DTDFVocab:provides SimulationResultsInsight
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Supervisory controller adjusting physical twin's operation based on digital twin-generated insights either autonomously or via human validation."
    DTDFVocab:provides ControlAdjustmentAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive dashboard providing real-time visualizations of physical twin's state, model predictions, and optimization outcomes for engineers."
    DTDFVocab:provides VisualizationInsight
]

instance AlertingService : DTDFVocab:Service [
    base:desc "Automated alerting system triggering notifications when digital twin detects critical events (safety hazards, efficiency drops)."
    DTDFVocab:provides AlertNotificationAction
]

instance SemanticIntegrationService : DTDFVocab:Service [
    base:desc "Ontology-driven framework ensuring consistency across heterogeneous data sources including CAD models, IoT sensors, and SCADA systems."
    DTDFVocab:provides IntegratedDataInsight
]

instance EventTriggeredAlertService : DTDFVocab:Service [
    base:desc "Event-based alert service triggering notifications when critical fault conditions are detected in real-time."
    DTDFVocab:provides AlertNotificationAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Machine learning-based anomaly detection service identifying deviations in sensor data patterns."
    DTDFVocab:provides FaultDiagnosisInsight
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Data integration service ensuring semantic consistency across heterogeneous data sources."
    DTDFVocab:provides IntegratedDataInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Model calibration service updating digital twin models with observed physical twin behavior."
    DTDFVocab:provides CalibratedModelInsight
]

// C17: Insights/Actions
instance RealTimeStateInsight : DTDFVocab:Insight [
    base:desc "Reconstructed dynamic state (position, velocity, temperature) of the physical twin with sub-millisecond accuracy for real-time monitoring."
]

instance FaultDiagnosisInsight : DTDFVocab:Insight [
    base:desc "Identified root causes of anomalies or deviations in physical twin behavior with 95% confidence interval."
]

instance PerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Continuous evaluation metrics of physical twin's operational efficiency and safety margins with real-time threshold comparisons."
]

instance CalibratedModelInsight : DTDFVocab:Insight [
    base:desc "Updated model parameters reflecting current physical twin behavior with reduced uncertainty through Bayesian calibration."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimal control inputs or operational strategies maximizing performance while adhering to safety and regulatory constraints."
]

instance MaintenanceRecommendationInsight : DTDFVocab:Insight [
    base:desc "Predicted failure risks and recommended maintenance actions based on time-series forecasting models."
]

instance SimulationResultsInsight : DTDFVocab:Insight [
    base:desc "Predicted behavior of physical twin under current or hypothetical operating conditions with confidence intervals."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D/2D visualizations of physical twin's state, model predictions, and optimization outcomes for decision support."
]

instance IntegratedDataInsight : DTDFVocab:Insight [
    base:desc "Consolidated data representation ensuring semantic consistency across CAD models, IoT sensors, and SCADA systems."
]

