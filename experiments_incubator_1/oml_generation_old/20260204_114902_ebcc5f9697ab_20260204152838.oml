// C2: Acting Components
instance HeatingElement : DTDFVocab:ActingComponent [
    base:desc "Controlled heat source integrated into the heatbed platform within the thermal incubator enclosure, responsible for maintaining precise temperature conditions through thermal regulation."
]

instance CirculationFan : DTDFVocab:ActingComponent [
    base:desc "Fan component within the thermal incubator enclosure responsible for uniform air circulation to ensure consistent temperature distribution across the enclosed volume."
]

// C3: Physical sensing components
instance IncubatorTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 High-Precision 1-Wire Digital Thermometer deployed within the thermal incubator enclosure to measure real-time thermal conditions with high accuracy."
    DTDFVocab:producedData TemperatureMeasurementDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureMeasurementDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorTemperatureSensor
]

// C10: Models/Data
instance ThermalIncubatorDynamicModel : DTDFVocab:Model [
    base:desc "Physics-based dynamic model described by differential equations representing the thermal behavior of the incubator enclosure, including heat transfer dynamics and temperature distribution."
    DTDFVocab:inputTo CalibrationAlgorithmEnabler
]

instance RawTemperatureData : DTDFVocab:Data [
    base:desc "Raw numerical temperature readings collected periodically from the DS18S20 sensor in raw format, transmitted via 1-Wire bus to the Raspberry Pi for processing."
    DTDFVocab:fromData TemperatureMeasurementDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithmEnabler
]

instance CalibratedModelParameters : DTDFVocab:Data [
    base:desc "Updated model parameters derived from calibration algorithms that reconcile sensor measurements with model predictions to improve parameter accuracy."
    DTDFVocab:fromData CalibrationOutputData
]

instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Predictive simulation results generated by solving differential equations using SciPy, representing expected thermal behavior under current or hypothetical conditions."
    DTDFVocab:fromData DynamicModelSimulationEnabler
]

// C11: Enablers
instance RaspberryPiEdgeNode : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B acting as the edge computing node for data acquisition, sensor interfacing, and algorithm execution. Hosts calibration logic, monitoring, and simulation models."
    DTDFVocab:enables TemperatureDataAcquisitionService, CalibrationService, MonitoringService, SimulationService, StateEstimationService
]

instance RabbitMQMessageBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ server running on the Raspberry Pi facilitating asynchronous communication between sensor systems and Digital Twin components. Enables data streaming from sensors to algorithms."
    DTDFVocab:enables DataStreamingService
]

instance PythonCalibrationLibrary : DTDFVocab:Enabler [
    base:desc "Python-based calibration algorithms leveraging SciPy for numerical computations to update dynamic models using real-time sensor data, minimizing prediction errors."
    DTDFVocab:enables CalibrationService
]

instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "State estimation algorithms that reconcile sensor measurements with model predictions to improve parameter accuracy and detect deviations from nominal behavior."
    DTDFVocab:enables MonitoringService, ControlService
]

instance DynamicModelSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python/SciPy-based simulation engine executing differential equations to reproduce and predict thermal incubator behavior under current or hypothetical conditions."
    DTDFVocab:enables SimulationService
]

instance DS18S20Driver : DTDFVocab:Enabler [
    base:desc "Low-level driver periodically reading temperature measurements from DS18S20 sensors via 1-Wire bus and transmitting data to the RabbitMQ server."
    DTDFVocab:enables TemperatureDataAcquisitionService
]

// C6: Services
instance TemperatureDataAcquisitionService : DTDFVocab:Service [
    base:desc "Real-time data acquisition service collecting periodic temperature measurements from the DS18S20 sensor and transmitting them via RabbitMQ for Digital Twin processing."
    DTDFVocab:provides TemperatureDataInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Dynamic model calibration service updating the Digital Twin's thermal equations using real-time sensor data to minimize prediction errors and improve model accuracy."
    DTDFVocab:provides ModelAccuracyInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time and historical monitoring service detecting safety violations, performance deviations, or anomalies by comparing simulated vs. observed thermal behavior."
    DTDFVocab:provides SafetyViolationAlert, PerformanceDeviationAlert
    DTDFVocab:provides AdjustControlParametersAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Dynamic and predictive modeling service running simulations to reproduce and predict thermal incubator behavior under current or hypothetical operating conditions."
    DTDFVocab:provides PredictiveBehaviorInsight
    DTDFVocab:provides WhatIfAnalysisInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "State estimation service reconciling sensor measurements with model predictions to improve parameter accuracy and detect deviations from nominal behavior."
    DTDFVocab:provides ParameterAccuracyInsight
]

instance DataStreamingService : DTDFVocab:Service [
    base:desc "Asynchronous data streaming service facilitating communication between sensor systems and Digital Twin components via RabbitMQ message broker."
    DTDFVocab:provides DataIntegrityInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Supervisory control service using state estimators to adjust thermal incubator behavior in real-time based on Digital Twin insights."
    DTDFVocab:provides ControlAdjustmentAction
]

// C17: Insights/Actions
instance TemperatureDataInsight : DTDFVocab:Insight [
    base:desc "Real-time temperature measurements collected periodically from the DS18S20 sensor, transmitted via RabbitMQ for Digital Twin processing."
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantitative measure of the Digital Twin's model accuracy derived from calibration algorithms reconciling sensor data with model predictions."
]

instance SafetyViolationAlert : DTDFVocab:Insight [
    base:desc "Alert generated when the Digital Twin detects deviations from safe operating parameters in the thermal incubator's thermal behavior."
]

instance PerformanceDeviationAlert : DTDFVocab:Insight [
    base:desc "Notification triggered when the Digital Twin identifies performance deviations from expected thermal behavior or operational efficiency."
]

instance PredictiveBehaviorInsight : DTDFVocab:Insight [
    base:desc "Predictive simulation results showing expected thermal behavior under current or hypothetical operating conditions, generated by solving differential equations."
]

instance WhatIfAnalysisInsight : DTDFVocab:Insight [
    base:desc "Results from what-if analysis testing the impact of design changes or operational scenarios on the thermal incubator's behavior."
]

instance ParameterAccuracyInsight : DTDFVocab:Insight [
    base:desc "Confidence measures of the Digital Twin's model parameters derived from state estimation algorithms reconciling sensor data with predictions."
]

instance DataIntegrityInsight : DTDFVocab:Insight [
    base:desc "Assurance of data integrity in the asynchronous data streaming process between sensors and Digital Twin components."
]

instance AdjustControlParametersAction : DTDFVocab:Action [
    base:desc "Automated adjustment of control parameters (e.g., heating element power, fan speed) to maintain optimal thermal conditions based on Digital Twin insights."
    DTDFVocab:IsAutomatic true
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Supervisory control adjustments to the Physical Twin's behavior based on Digital Twin state estimation and monitoring results."
    DTDFVocab:IsAutomatic true
]

// C18: Environments/Components
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Enclosed, insulated system designed to maintain precise temperature conditions for experimental or industrial processes."
    base:contains IncubatorEnclosureComponent, HeatingElement, CirculationFan, RaspberryPiEdgeNode, IncubatorTemperatureSensor
]

instance IncubatorEnclosureComponent : DTDFVocab:Component [
    base:desc "Styrofoam box providing thermal isolation to minimize external environmental interference within the thermal incubator system."
]

// C19: Data flows
instance CalibrationOutputData : DTDFVocab:Data [
    base:desc "Output data from calibration algorithms containing updated model parameters and error metrics used to refine the Digital Twin's thermal model."
    DTDFVocab:fromData RawTemperatureData
    DTDFVocab:inputTo ThermalIncubatorDynamicModel
]

instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithms that update the Digital Twin's dynamic models using real-time sensor data to minimize prediction errors."
    DTDFVocab:enables CalibrationService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "
The **virtual-to-physical interaction** in this Digital Twin system is facilitated through a **low-level driver** that interfaces with the **Physical Twin (PT)** and issues control commands to a **RabbitMQ server** (hosted on the Raspberry Pi). The driver incorporates a **safe protocol** to ensure reliable command execution, though specific validation or authentication mechanisms are not detailed. Commands are issued to adjust the **states of the PT**, with the system employing a **bang-bang controller** (a discrete-time control strategy) for state regulation. No explicit feedback mechanisms (e.g., acknowledgment protocols, error responses) or command confirmation mechanisms are described in the provided documents. The interaction relies on RabbitMQ’s message-passing architecture to transmit control signals from the DT’s algorithms to the PT.

Supported by: *'low-level driver is used to interact with the PT and to issue the states of the PT to the RabbitMQ server', 'safe protocol is incorporated into the low-level driver', 'controller used in the case study is a comparable to a bang-bang controller'*.
"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system operates with **periodic data acquisition** from the Physical Twin (PT) via sensors, where measurements are collected over time to inform model updates and monitoring. The document specifies that data is gathered through continuous or scheduled sensor readings (e.g., temperature data) but does not quantify synchronization frequencies (e.g., Hz, ms, or seconds) or define explicit latency requirements. The temporal granularity is implied to be **asynchronous or event-driven** for calibration and monitoring, where algorithms update models based on incoming data streams without real-time constraints explicitly stated. No specific time-scale constraints (e.g., real-time, near-real-time) or synchronization protocols (e.g., clock synchronization mechanisms) are mentioned in the provided context."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows an orchestrated architecture that integrates three core components: **Data** (real-time sensor streams from the PT), **Models** (knowledge representations of the PT's cyber and physical aspects, including environmental interactions), and **Algorithms** (e.g., fault detectors, state estimators, and optimizers). The system employs a modular design where calibration algorithms dynamically update models to reflect the PT's evolving state, feeding refined data into monitoring services that assess safety and optimality. Human-in-the-loop or automated decision-making mechanisms intervene when violations are detected, triggering adjustments to the PT. The overall coordination relies on iterative feedback loops between data acquisition, model refinement, and algorithmic processing, ensuring the DT remains a live, adaptive representation of the PT."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "
The lifecycle of a Digital Twin (DT) spans multiple phases, beginning with **development**, where abstract representations (e.g., CAD models for geometry, dynamic models for physics, and cyber-physical system (CPS) models for behavior) are constructed to analyze specific aspects of the Physical Twin (PT). These models are iteratively refined through **simulation-based validation**, where differential equations and other mathematical frameworks (e.g., [3, Section 5]) are employed to predict system behavior under varying conditions.

During the **integration phase**, models are not discarded post-deployment but are **embedded into the DT framework**, which unifies **data collection** (via sensors monitoring the PT over time), **knowledge models** (encompassing physics, cyber, and environmental aspects), and **algorithms** (e.g., fault detectors, state estimators, and optimizers). The DT employs **calibration algorithms** to iteratively update models with real-time data, ensuring the DT’s parameters align with the PT’s current state. This phase also includes **monitoring** for safety and optimality, where violations trigger **adaptive decision-making** (human or algorithmic) to modify the PT’s operation.

Lifecycle governance involves **continuous feedback loops** between the DT and PT, ensuring alignment through **parameter estimation** and **performance validation**. Transition management between phases (e.g., from design to operational DT) relies on **model persistence**, where legacy models are repurposed for real-time analytics, and **version control** (implicitly assumed for iterative model updates). Governance frameworks emphasize **closed-loop optimization**, where the DT’s predictive capabilities inform iterative improvements to both the PT and its digital counterpart.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin’s technical connection relies on a Raspberry Pi 4 Model B as the primary computing node, equipped with built-in Wi-Fi and Bluetooth for wireless communication. The system uses a RabbitMQ server for message routing, enabling point-to-point or publish-subscribe communication between components. No advanced networking protocols (e.g., OPC UA, MQTT, Modbus TCP), network topology specifics, or latency/bandwidth requirements are mentioned. Security protocols are not detailed beyond the ‘safe protocol’ in the low-level driver. Redundancy or reliability mechanisms are not referenced in the provided documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin system is deployed on a Raspberry Pi 4 Model B, which hosts the controller, driver, and RabbitMQ server. No cloud, edge, or on-premise hosting distinctions are made; computational and storage requirements are unspecified. Scalability mechanisms, deployment models (e.g., containerization), or availability/reliability assurances (e.g., failover, replication) are not addressed in the documents."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "
The Digital Twin (DT) incorporates **safety monitoring mechanisms** to ensure the Physical Twin (PT) operates within predefined operational boundaries. Specifically, the system employs **calibration algorithms** to update models of the Cyber-Physical System (CPS) and its environment, ensuring parameter estimates align with real-time sensor data. **Monitoring components** within the DT verify system performance by cross-referencing simulated behavior against operational constraints, detecting deviations that may compromise safety. For instance, the DT includes **state estimators** and **fault detectors** to identify anomalies, triggering corrective actions (e.g., human intervention or automated adjustments) when violations of safety thresholds (e.g., temperature limits LL and UL) are detected. While the document does not explicitly detail **cybersecurity protocols** (e.g., encryption, authentication, or access control), it implies operational safety is prioritized through **fail-safe mechanisms** tied to real-time calibration and monitoring. No formal risk assessment frameworks (e.g., ISO 31000, IEC 61508) or threat mitigation strategies (e.g., intrusion detection systems) are described."
]