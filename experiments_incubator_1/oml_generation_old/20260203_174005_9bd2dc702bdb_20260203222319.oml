// C3: Physical sensing components
instance HotZoneTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer positioned in the hot zone inside the styrofoam enclosure, communicating over 1‑Wire bus."
    DTDFVocab:producedData HotZoneTempPacket
]

instance ColdZoneTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer positioned in the cold zone inside the styrofoam enclosure, communicating over 1‑Wire bus."
    DTDFVocab:producedData ColdZoneTempPacket
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer positioned outside the incubator to monitor ambient temperature, communicating over 1‑Wire bus."
    DTDFVocab:producedData AmbientTempPacket
]

// C4: Physical-to-virtual interaction
instance HotZoneTempPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HotZoneTemperatureSensor
]

instance ColdZoneTempPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ColdZoneTemperatureSensor
]

instance AmbientTempPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

// C4: Actuator status packets
instance HeaterStatusPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatBedHeater
]

instance FanStatusPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FanMotor
]

// C10: Data
instance HotZoneTemperatureData : DTDFVocab:Data [
    base:desc "Temperature value retrieved from HotZoneTemperatureSensor."
    DTDFVocab:fromData HotZoneTempPacket
    DTDFVocab:inputTo PythonSciPyCalibrationEnvironment,
               RabbitMQBroker
]

instance ColdZoneTemperatureData : DTDFVocab:Data [
    base:desc "Temperature value retrieved from ColdZoneTemperatureSensor."
    DTDFVocab:fromData ColdZoneTempPacket
    DTDFVocab:inputTo PythonSciPyCalibrationEnvironment,
               RabbitMQBroker
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Temperature value retrieved from AmbientTemperatureSensor."
    DTDFVocab:fromData AmbientTempPacket
    DTDFVocab:inputTo PythonSciPyCalibrationEnvironment,
               RabbitMQBroker
]

instance HeaterStatusData : DTDFVocab:Data [
    base:desc "Current status (on/off) of HeatBedHeater delivered via DataTransmitted."
    DTDFVocab:fromData HeaterStatusPacket
    DTDFVocab:inputTo RabbitMQBroker
]

instance FanStatusData : DTDFVocab:Data [
    base:desc "Current status (on/off) of FanMotor delivered via DataTransmitted."
    DTDFVocab:fromData FanStatusPacket
    DTDFVocab:inputTo RabbitMQBroker
]

// C2: Acting Components
instance HeatBedHeater : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed heater controlled via MOSFETs and optocouplers, commanded by Raspberry Pi."
]

instance FanMotor : DTDFVocab:ActingComponent [
    base:desc "12V/24V fan driven through MOSFETs and optocouplers, controlled by Raspberry Pi."
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on Raspberry Pi, managing AMQP communication of sensor data and actuator status."
    DTDFVocab:enables RealTimeMonitoringService,
                   FaultDetectionService,
                   VisualizationService
]

instance PythonSciPyCalibrationEnvironment : DTDFVocab:Enabler [
    base:desc "Python environment with NumPy/SciPy enabling model calibration via nonlinear least squares and simulation execution."
    DTDFVocab:enables ModelCalibrationService,
                   TemperatureSimulationService
]

instance RaspberryPiGPIOController : DTDFVocab:Enabler [
    base:desc "GPIO controller on Raspberry Pi managing digital I/O to MOSFETs and optocouplers for actuators."
    DTDFVocab:enables ActuationCommandService
]

// C10: Models
instance ModelA_ThermalModel : DTDFVocab:Model [
    base:desc "Model A assumes complete conversion of electrical power to heat in the air."
    DTDFVocab:inputTo PythonSciPyCalibrationEnvironment
]

instance ModelB_ThermalModel : DTDFVocab:Model [
    base:desc "Model B additionally accounts for heat capacity of the heater."
    DTDFVocab:inputTo PythonSciPyCalibrationEnvironment
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Monitors real‑time temperature streams from sensors via RabbitMQ, providing live temperature updates."
    DTDFVocab:provides MonitoringInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults by inferring sensor anomalies in real‑time data."
    DTDFVocab:provides FaultDetectionInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualizes sensor data streams and simulation results to operators through UI."
    DTDFVocab:provides MonitoringInsight,
               TemperatureUniformityInsight
]

instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Simulates temperature dynamics using ModelA and ModelB, generating predicted temperature curves."
    DTDFVocab:provides OptimalModelSelectionInsight,
               TemperatureUniformityInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates model parameters using nonlinear least squares in SciPy."
    DTDFVocab:provides ParameterEstimatesInsight
]

instance ActuationCommandService : DTDFVocab:Service [
    base:desc "Issues control signals (heat and fan on/off) to actuators based on DT decisions."
    DTDFVocab:provides AdjustFanVoltageAction,
               UpdateSensorPlacementAction
]

// C17: Insights
instance OptimalModelSelectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating ModelB selected due to lower prediction error."
]

instance ParameterEstimatesInsight : DTDFVocab:Insight [
    base:desc "Parameter estimates for G_box and G_heater from calibration."
]

instance TemperatureUniformityInsight : DTDFVocab:Insight [
    base:desc "Insight identifying limits of temperature uniformity within incubator."
]

instance FanVoltageRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation to adjust fan voltage for improved temperature uniformity."
]

instance SensorPlacementRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation for optimal sensor placement based on experimental insights."
]

instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Live monitoring insight of temperature streams."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of anomalies in sensor data indicative of faults."
]

// C17: Actions
instance AdjustFanVoltageAction : DTDFVocab:Action [
    base:desc "Adjusts fan voltage to improve temperature uniformity."
    DTDFVocab:IsAutomatic true
]

instance UpdateSensorPlacementAction : DTDFVocab:Action [
    base:desc "Repositions sensors based on DT recommendations."
    DTDFVocab:IsAutomatic false
]

// C1: Environment and Component
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HotZoneTemperatureSensor,
               ColdZoneTemperatureSensor,
               AmbientTemperatureSensor,
               HeatBedHeater,
               FanMotor
]

instance IncubatorComponent : DTDFVocab:Component [
    base:desc "Thermal incubator comprising insulated styrofoam box, heat‑bed heater, fan, Raspberry Pi controller, and DS18S20 sensors."
    base:isContainedIn IncubatorEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT consumes commands from RabbitMQ (e.g., set heat duration, waiting duration, fan state) which are forwarded by the controller to the Raspberry Pi’s GPIO, thus affecting the heat‑bed and fan. The DT also publishes control states back to the PT for monitoring."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation consists of the Raspberry Pi controller, the low‑level driver, the RabbitMQ server, the heat‑bed heater, the fan, the DS18S20 sensors, and the custom PCB. The orchestration flow follows controller → RabbitMQ → PT hardware actions, and PT sensor data → RabbitMQ → DT services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin is in the Validation/Experimental phase: models are designed and calibrated against experimental data, control logic is tested, and uniform‑temperature experiments validate assumptions. Full operational deployment and continuous production‑time twin are planned as future work, not yet implemented."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed through comparison of simulated temperature trajectories against measured data; validity is ensured by calibration of free parameters, assumption verification (e.g., uniform temperature, negligible wall heat accumulation), and residual error minimization during least‑squares fitting."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication uses RabbitMQ (AMQP) over TCP on the local network; sensor data travels over the 1‑Wire bus to the Raspberry Pi. The controller publishes and subscribes to relevant queues/exchanges to exchange messages with the PCBs and actuators."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT runtime, RabbitMQ broker, and calibration scripts are hosted directly on the Raspberry Pi 4, enabling low‑latency integration with the physical twin on the same embedded system."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is incorporated into the low‑level driver to maintain safe states; optocouplers provide electrical isolation between the Pi and high‑current actuators. No authentication, encryption, or redundant control logic for safety or security is mentioned in the documents."
]