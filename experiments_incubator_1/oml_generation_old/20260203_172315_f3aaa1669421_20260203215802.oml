// C3: Physical sensing components
instance InsideTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer deployed inside insulated box, monitoring internal temperature."
    DTDFVocab:producedData InternalTemperatureData
]
instance InsideTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 1‑Wire digital thermometer inside insulated box."
    DTDFVocab:producedData InternalTemperatureData
]
instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer mounted outside the incubator to measure ambient temperature."
    DTDFVocab:producedData AmbientTemperatureData
]

// C4: Data transmitted by sensors
instance InternalTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor1, InsideTemperatureSensor2
]
instance AmbientTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

// C10: Data used by models and services
instance InternalTemperatureDataSet : DTDFVocab:Data [
    base:desc "Internal temperature readings published from sensors to RabbitMQ and used by models."
    DTDFVocab:inputTo ScipyCalibrator, RealtimePredictionEnabler
    DTDFVocab:fromData InternalTemperatureData
]
instance AmbientTemperatureDataSet : DTDFVocab:Data [
    base:desc "Ambient temperature readings published from sensor to RabbitMQ."
    DTDFVocab:inputTo RealtimePredictionEnabler
    DTDFVocab:fromData AmbientTemperatureData
]

// C10: Models
instance ModelA : DTDFVocab:Model [
    base:desc "Energy balance model with single free parameter C_air for air heat capacity."
    DTDFVocab:inputTo ScipyCalibrator, RealtimePredictionEnabler
]
instance ModelB : DTDFVocab:Model [
    base:desc "Energy balance model with free parameters C_heater, C_air, G_heater, G_box."
    DTDFVocab:inputTo ScipyCalibrator, RealtimePredictionEnabler
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker facilitating inter‑process communication between PT and virtual domain."
    DTDFVocab:enables DataAcquisitionService, BangBangControllerService, TemperaturePredictionService, ComplianceMonitoringService
]
instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Low‑level driver reading DS18S20 sensors and publishing data to RabbitMQ."
    DTDFVocab:enables DataAcquisitionService
]
instance ScipyCalibrator : DTDFVocab:Enabler [
    base:desc "Python‑Scipy nonlinear least‑squares optimizer for calibrating ModelA and ModelB."
    DTDFVocab:enables CalibrationService
]
instance RealtimePredictionEnabler : DTDFVocab:Enabler [
    base:desc "Component that subscribes to temperature data on RabbitMQ, feeds models for real‑time prediction."
    DTDFVocab:enables TemperaturePredictionService
]
instance ActuatorControllerEnabler : DTDFVocab:Enabler [
    base:desc "GPIO‑based driver that sends enable/disable commands to MOSFET‑controlled heatbed and fan via optocouplers."
    DTDFVocab:enables BangBangControllerService, ComplianceMonitoringService
]

// C6: Services
instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Provides temperature forecasts using ModelA and ModelB."
    DTDFVocab:provides PredictionInsight, ResidualErrorInsight
]
instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibrates models using nonlinear least‑squares optimization."
    DTDFVocab:provides ParameterEstimationInsight
]
instance ComplianceMonitoringService : DTDFVocab:Service [
    base:desc "Monitors temperature compliance against safe limits (LL/UL) and triggers control actions."
    DTDFVocab:provides ComplianceStatusInsight, AdjustControlLimits
]
instance BangBangControllerService : DTDFVocab:Service [
    base:desc "Bang‑bang controller state machine managing heater and fan operations."
    DTDFVocab:provides ControllerStateInsight, ActuatorCommand
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Generates visualization such as state chart and residual plots."
    DTDFVocab:provides VisualizationInsight
]
instance ModelValidationService : DTDFVocab:Service [
    base:desc "Validates calibrated models against experimental data."
    DTDFVocab:provides ModelValidationInsight
]
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Collects sensor data via LowLevelDriver and publishes to RabbitMQ."
    DTDFVocab:provides DataAcquisitionInsight
]

// C17: Insights
instance PredictionInsight : DTDFVocab:Insight [
    base:desc "Real‑time temperature predictions generated by ModelA and ModelB."
]
instance ResidualErrorInsight : DTDFVocab:Insight [
    base:desc "Plots of residual errors between predicted and measured temperatures."
]
instance ParameterEstimationInsight : DTDFVocab:Insight [
    base:desc "Calibrated parameter values (C_air, C_heater, G_box, G_heater)."
]
instance ComplianceStatusInsight : DTDFVocab:Insight [
    base:desc "Current compliance status versus safe temperature limits."
]
instance ControllerStateInsight : DTDFVocab:Insight [
    base:desc "Current state of the bang‑bang controller (heater on, fan off, etc.)."
]
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "State chart visualization of the control loop."
]
instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Assessment of model validity against recorded data."
]
instance DataAcquisitionInsight : DTDFVocab:Insight [
    base:desc "Insights about data acquisition, such as sensor connectivity status."
]

// C17: Actions
instance AdjustControlLimits : DTDFVocab:Action [
    base:desc "Operator action to modify safe temperature limits."
    DTDFVocab:IsAutomatic false
]
instance ActuatorCommand : DTDFVocab:Action [
    base:desc "Command to enable or disable heatbed or fan through MOSFETs."
    DTDFVocab:IsAutomatic true
]

// C3: Components and Environment
instance Heatbed : DTDFVocab:Component [
    base:desc "100 mm × 214 mm × 3 mm heatbed heating element."
]
instance Fan : DTDFVocab:Component [
    base:desc "0.02 m³ s⁻¹ airflow fan for circulation."
]
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains Heatbed, Fan, InsideTemperatureSensor1, InsideTemperatureSensor2, AmbientTemperatureSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin publishes control commands (e.g., heatbed on/off, fan on/off, heating/waiting durations) to the RabbitMQ broker. The Raspberry Pi controller consumes these messages and applies the received commands to the actuators via GPIO, thereby influencing the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation consists of the physical hardware (heatbed, fan, sensors, Raspberry Pi), the low‑level driver, the controller software, and the RabbitMQ message broker. The controller and driver run on the same Pi, exchanging messages through RabbitMQ, while the DT (model and calibration code) may run separately on a host machine accessing the broker. This architecture is decentralized per component but orchestrated via the broker."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity relies on four key assumptions (uniform internal temperature, negligible wall heat accumulation, constant specific heat of air, negligible fan heat). Validation is performed by comparing model output against experimental temperature traces and minimizing the residual error in the least‑squares objective; no stochastic uncertainty quantification is reported."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data flow uses the 1‑Wire bus for sensors and GPIO pins for actuators; inter‑module communication occurs over RabbitMQ using the AMQP protocol on the local network; the Raspberry Pi provides built‑in Wi‑Fi for remote access but the broker runs locally."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT runtime components—controller, low‑level driver, RabbitMQ broker, and simulation/calibration scripts—are deployed on a single Raspberry Pi 4 Model B located inside the incubator enclosure. The Pi powers the PT hardware and hosts the core DT logic. No external cloud deployment is described in the documents."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver implements a safe protocol to guard against erroneous commands, and MOSFETs with optocouplers provide electrical isolation between the Pi and high‑current heatbed. No explicit cybersecurity measures are described, but the use of RabbitMQ on a local network limits exposure to external actors."
]