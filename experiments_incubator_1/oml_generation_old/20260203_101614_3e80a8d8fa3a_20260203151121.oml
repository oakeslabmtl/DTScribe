// C3: Physical sensing components
instance InsideTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑wire thermometer monitoring temperature at location 1 inside the insulated incubator."
    DTDFVocab:producedData InsideTempDataTransmitted1
]

instance InsideTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 thermometer monitoring temperature at location 2 inside the insulated incubator."
    DTDFVocab:producedData InsideTempDataTransmitted2
]

instance OutsideTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 thermometer measuring ambient temperature outside the insulated incubator."
    DTDFVocab:producedData OutsideTempDataTransmitted
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance InsideTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor1
]

instance InsideTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor2
]

instance OutsideTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideTemperatureSensor
]

// New Data Transmitted from actuators (fan power logs and heatbed voltage/current)
instance FanPowerLogTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FanActuator
]

instance HeatbedVoltageCurrentLogTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatbedActuator
]

// C10: Models/Data
instance ModelA : DTDFVocab:Model [
    base:desc "Dynamic thermal model A with single‑parameter G_box and C_air describing heat transfer between the box and the air."
    DTDFVocab:inputTo ScipyLeastSquaresOptimizer, PythonSimulationScript
]

instance ModelB : DTDFVocab:Model [
    base:desc "Dynamic thermal model B with four‑parameter G_box, G_heater, C_air, and C_heater capturing combined heat‑bed and ambient interactions."
    DTDFVocab:inputTo ScipyLeastSquaresOptimizer, PythonSimulationScript
]

instance InsideTempData1 : DTDFVocab:Data [
    base:desc "Time‑stamped indoor temperature readings from InsideTemperatureSensor1."
    DTDFVocab:fromData InsideTempDataTransmitted1
    DTDFVocab:inputTo ScipyLeastSquaresOptimizer, PythonCalibrationScript
]

instance InsideTempData2 : DTDFVocab:Data [
    base:desc "Time‑stamped indoor temperature readings from InsideTemperatureSensor2."
    DTDFVocab:fromData InsideTempDataTransmitted2
    DTDFVocab:inputTo ScipyLeastSquaresOptimizer, PythonCalibrationScript
]

instance OutsideTempData : DTDFVocab:Data [
    base:desc "Time‑stamped ambient temperature readings from OutsideTemperatureSensor."
    DTDFVocab:fromData OutsideTempDataTransmitted
    DTDFVocab:inputTo ScipyLeastSquaresOptimizer, PythonCalibrationScript
]

instance FanPowerLogData : DTDFVocab:Data [
    base:desc "Logged fan power consumption (current/voltage) recorded by the Raspberry Pi during operation."
    DTDFVocab:fromData FanPowerLogTransmitted
    DTDFVocab:inputTo ScipyLeastSquaresOptimizer, PythonCalibrationScript
]

instance HeatbedVoltageCurrentLogData : DTDFVocab:Data [
    base:desc "Logged heat‑bed current and voltage readings recorded by the Raspberry Pi during operation."
    DTDFVocab:fromData HeatbedVoltageCurrentLogTransmitted
    DTDFVocab:inputTo ScipyLeastSquaresOptimizer, PythonCalibrationScript
]

// C11: Enablers
instance RaspberryPiController : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B acting as the controller, handling sensor polling, actuator command generation, and local processing."
    DTDFVocab:enables FanControlService, HeatbedControlService, MonitoringService, DecisionSupportService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker on the local network, transporting sensor data messages from the Raspberry Pi to the Digital Twin services."
    DTDFVocab:enables DataTransportService
]

instance DataTransportService : DTDFVocab:Service [
    base:desc "Service handling message transport between the Raspberry Pi and downstream Digital Twin services."
]

instance ScipyLeastSquaresOptimizer : DTDFVocab:Enabler [
    base:desc "Scipy least‑squares optimizer performing online parameter estimation from empirical temperature and actuator data."
    DTDFVocab:enables ParameterEstimationService
]

instance PythonSimulationScript : DTDFVocab:Enabler [
    base:desc "Python script executing ModelA and ModelB simulations for predictive temperature dynamics."
    DTDFVocab:enables SimulationService
]

instance PythonCalibrationScript : DTDFVocab:Enabler [
    base:desc "Python script orchestrating data ingestion, model selection, and calibration workflow."
    DTDFVocab:enables DecisionSupportService
]

// C6: Services
instance ParameterEstimationService : DTDFVocab:Service [
    base:desc "Service applying Scipy least‑squares to estimate G_box, G_heater, C_air, C_heater from temperature and actuator logs."
    DTDFVocab:provides InsightCalibratedParameters
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service running dynamic thermal simulations (ModelA and ModelB) to predict temperature evolution."
    DTDFVocab:provides InsightModelSelection
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service continuously monitoring sensor data streams and emitting alerts when thresholds are exceeded."
    DTDFVocab:provides ActionFanSpeedControl, ActionHeatbedPowerControl
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Service aggregating insights and providing setpoint recommendations based on calibrated parameters."
    DTDFVocab:provides ActionSetpointRecommendation
]

instance FanControlService : DTDFVocab:Service [
    base:desc "Service commanding fan MOSFET stages to adjust air circulation speed via Raspberry Pi GPIO pins."
]

instance HeatbedControlService : DTDFVocab:Service [
    base:desc "Service commanding heat‑bed MOSFET stage to regulate heat output to maintain target temperature."
]

// C17: Insight/Action
instance InsightCalibratedParameters : DTDFVocab:Insight [
    base:desc "Calibrated estimates of thermal model parameters: G_box, G_heater, C_air, and C_heater."
]

instance InsightModelSelection : DTDFVocab:Insight [
    base:desc "Selection evidence indicating ModelB provides a more accurate fit to the empirical data."
]

instance ActionSetpointRecommendation : DTDFVocab:Action [
    base:desc "Recommended steady‑state setpoints for fan speed and heat‑bed power to achieve target temperature."
    DTDFVocab:IsAutomatic true
]

instance ActionFanSpeedControl : DTDFVocab:Action [
    base:desc "Automated adjustment of fan motor speed based on real‑time temperature error."
    DTDFVocab:IsAutomatic true
]

instance ActionHeatbedPowerControl : DTDFVocab:Action [
    base:desc "Automated adjustment of heat‑bed power to regulate inside temperature."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components (Physical Actuation)
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Electric heating element driving air temperature inside the incubator, controlled via a MOSFET stage isolated from the Raspberry Pi."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V DC fan for air circulation inside the incubator, controlled via a MOSFET stage isolated from the Raspberry Pi."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin publishes control commands (heatbed ON/OFF, fan ON/OFF, target temperature) to RabbitMQ queues that the Raspberry Pi controller subscribes to; the controller translates these into GPIO signals driving MOSFETs and the fan actuator."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near‑real‑time exchange: sensor samples and control commands are published to RabbitMQ every few seconds (fan state persistence and heatbed actuation cycles) with the Digital Twin’s simulation step sized to match the physical sampling period."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Component layout: Low‑level driver (sensor/actuator abstraction), Controller (bang‑bang control with LL, UL, H, C parameters), RabbitMQ communication server, Custom PCB linking PI to electronics, and the Digital Twin backend that subscribes to/produces messages, runs simulations and calibration."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design/Modeling → Fabrication/Implementation (open‑source hardware and software released on GitHub) → Operation/Monitoring during runtime, with the Digital Twin continuously calibrating and validating the physical system across these phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model assumptions (uniform temperature, negligible wall heat accumulation, constant specific heat, negligible fan heating) are explicitly listed; validation performed with uniform temperature experiments (Fig. 10, 11, 12) and residual error minimization via least‑squares; uncertainties due to assumptions acknowledged; no formal model verification tools reported."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "RabbitMQ (AMQP) running locally on the Raspberry Pi over IP (likely Wi‑Fi/Bluetooth) connects DT backend to the controller; communication uses per‑message queues for sensor data and control commands."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Both the control logic and the Digital Twin run on the same Raspberry Pi, i.e., an edge deployment with local storage and computation; the source code is open‑source and can be deployed on other edge devices or in the cloud."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safe protocol incorporated in the low‑level driver to keep the device in a safe state; control commands are strictly validated before GPIO output; the system uses the Raspberry Pi’s built‑in Wi‑Fi/Bluetooth with default security but no advanced cyber‑security measures are reported."
]