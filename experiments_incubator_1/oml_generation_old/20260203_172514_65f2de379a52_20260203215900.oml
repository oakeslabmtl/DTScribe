// C3: Physical sensing components
instance InternalBoxTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside the insulated box to monitor process temperature."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance ExternalAmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located outside the insulated box to measure ambient temperature."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance InternalBoxTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 temperature sensor inside the insulated box for redundancy."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance PowerSupplyMonitor : DTDFVocab:SensingComponent [
    base:desc "Monitor component that reads power supply voltage and current on the Raspberry Pi."
    DTDFVocab:producedData PowerSupplyDataTransmitted
]
instance ActuatorStateMonitor : DTDFVocab:SensingComponent [
    base:desc "Monitor component that reads actuators' (heatbed, fan) ON/OFF states via optocouplers."
    DTDFVocab:producedData ActuatorStateDataTransmitted
]

// C4: Data transmitted
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalBoxTempSensor, ExternalAmbientTempSensor, InternalBoxTempSensor2
]
instance PowerSupplyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerSupplyMonitor
]
instance ActuatorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ActuatorStateMonitor
]

// C10: Models/Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Streaming temperature data aggregated from DS18S20 sensors, including value and timestamp."
    DTDFVocab:inputTo PythonProcessingUnit, RabbitMQBrokerUnit
    DTDFVocab:fromData TemperatureDataTransmitted
]
instance PowerSupplyData : DTDFVocab:Data [
    base:desc "Current voltage and current readings from the power supply."
    DTDFVocab:inputTo PythonProcessingUnit, RabbitMQBrokerUnit
    DTDFVocab:fromData PowerSupplyDataTransmitted
]
instance ActuatorStateData : DTDFVocab:Data [
    base:desc "ON/OFF state of heatbed and fan actuators."
    DTDFVocab:inputTo PythonProcessingUnit, RabbitMQBrokerUnit
    DTDFVocab:fromData ActuatorStateDataTransmitted
]
instance ModelA : DTDFVocab:Model [
    base:desc "First-order single-parameter energy balance model for the incubator."
    DTDFVocab:inputTo PythonProcessingUnit
]
instance ModelB : DTDFVocab:Model [
    base:desc "First-order four-parameter heatbed–air system model."
    DTDFVocab:inputTo PythonProcessingUnit
]

// C11: Enablers
instance PythonProcessingUnit : DTDFVocab:Enabler [
    base:desc "Python runtime environment (scipy) that performs simulation, optimisation, and control."
    DTDFVocab:enables TemperatureForecastService, ParameterOptimisationService, FeedbackControlService
]
instance RabbitMQBrokerUnit : DTDFVocab:Enabler [
    base:desc "RabbitMQ broker producer for streaming temperature data via AMQP."
    DTDFVocab:enables DataStreamingService
]

// C6: Services
instance TemperatureForecastService : DTDFVocab:Service [
    base:desc "Real-time simulation of thermal dynamics using calibrated ModelA and ModelB."
    DTDFVocab:provides TemperatureForecastInsight
]
instance ParameterOptimisationService : DTDFVocab:Service [
    base:desc "Non-linear least-squares optimisation of model parameters based on measured data."
    DTDFVocab:provides ParameterOptimisationInsight
]
instance FeedbackControlService : DTDFVocab:Service [
    base:desc "Bang-bang style feedback control to maintain set-point temperature."
    DTDFVocab:provides FeedbackControlAction
]
instance DataStreamingService : DTDFVocab:Service [
    base:desc "Real-time monitoring of temperature, streaming data to the digital twin."
    DTDFVocab:provides TemperatureMonitoringInsight
]

// C17: Insights/Actions
instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory based on current model state."
]
instance ParameterOptimisationInsight : DTDFVocab:Insight [
    base:desc "Calibrated model parameters after least-squares optimisation."
]
instance FeedbackControlAction : DTDFVocab:Action [
    base:desc "Adjust heatbed or fan activation to maintain desired temperature."
    DTDFVocab:IsAutomatic true
]
instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Live temperature readings displayed on the digital twin dashboard."
]

// C1: Components and Environment
instance DS18S20InternalSensor1 : DTDFVocab:Component [
    base:desc "High-precision DS18S20 temperature sensor for internal process monitoring."
]
instance DS18S20InternalSensor2 : DTDFVocab:Component [
    base:desc "High-precision DS18S20 temperature sensor for internal process monitoring."
]
instance DS18S20ExternalSensor : DTDFVocab:Component [
    base:desc "High-precision DS18S20 temperature sensor for ambient temperature monitoring."
]
instance Heatbed : DTDFVocab:Component [
    base:desc "Heatbed powered by 12–24 V supply, driven through MOSFET switch and optocoupler."
]
instance Fan : DTDFVocab:Component [
    base:desc "Circulation fan driven through MOSFET switch, isolated by optocoupler, PWM controlled by Raspberry Pi."
]
instance RaspberryPi4 : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B acting as controller and communication hub."
]
instance PowerSupply12to24V : DTDFVocab:Component [
    base:desc "12–24 V power supply providing voltage to heatbed."
]
instance MosfetSwitchHeatbed : DTDFVocab:Component [
    base:desc "MOSFET switch isolated by optocoupler that drives the heatbed."
]
instance MosfetSwitchFan : DTDFVocab:Component [
    base:desc "MOSFET switch isolated by optocoupler that drives the fan."
]
instance OptocouplerHeatbed : DTDFVocab:Component [
    base:desc "Optocoupler providing electrical isolation for heatbed control."
]
instance OptocouplerFan : DTDFVocab:Component [
    base:desc "Optocoupler providing electrical isolation for fan control."
]
instance RabbitMQBroker : DTDFVocab:Component [
    base:desc "RabbitMQ message broker publishing sensor data using AMQP."
]
instance PythonEnvironment : DTDFVocab:Component [
    base:desc "Python runtime (Scipy) used for model simulation and optimisation."
]
instance GitHubRepository : DTDFVocab:Component [
    base:desc "Open-source repository containing hardware schematics and software code."
]
instance InsulatedThermalIncubator : DTDFVocab:Environment [
    base:contains RaspberryPi4, PowerSupply12to24V, Heatbed, Fan, DS18S20InternalSensor1, DS18S20InternalSensor2, DS18S20ExternalSensor, MosfetSwitchHeatbed, MosfetSwitchFan, OptocouplerHeatbed, OptocouplerFan, RabbitMQBroker, PythonEnvironment, GitHubRepository, PowerSupplyMonitor, ActuatorStateMonitor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin issues control commands (heatbed on/off, fan on/off) back to the Raspberry Pi via RabbitMQ; the controller processes these messages and drives the MOSFETs accordingly, thus affecting the PT’s operating state."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates synchronously with the physical plant, sampling sensor data and applying control decisions on a sub‑second to one‑second cadence; the simulation models are updated continuously with real‑time data, enabling predictive forecasts within the 2‑second response window of the fan’s airflow cycle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized orchestration: low‑level driver reads sensors and publishes via RabbitMQ; controller consumes commands and publishes actuator states; simulation models run as separate Python services listening to sensor streams; decision logic executes on the Pi or an external host."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design/Specification – hardware selection (styrofoam, heatbed, fan, sensors), Implementation – PCB design and Raspberry Pi driver/controller deployment, Modelling – development of two thermal models (A and B), Calibration – parameter estimation using experimental data, Validation – experimental testing of uniform temperature and model accuracy, Deployment – open‑source repository and continuous operation during incubation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity bounded by assumptions: uniform temperature distribution, negligible wall heat, constant specific heat, full energy transfer to air; validation performed by measuring maximum temperature discrepancy (≤7 °C) and calibrating four parameters; sensor accuracy ±0.5 °C over ±10–85 °C range; uncertainty in fan airflow and heatbed heat loss ignored."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical ↔ virtual communication is through the DS18S20 sensors on a 1‑Wire bus connected to the Pi GPIO, and MQTT messages published/subscribed via the local RabbitMQ broker over TCP/IP using the Pi’s Wi‑Fi interface. The Raspberry Pi’s Ethernet port is unused but available. Optocouplers isolate the Pi from the high‑current fan and heatbed drivers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All twin components (controller, low‑level driver, RabbitMQ broker, simulation services) are hosted locally on the Raspberry Pi, with optional external deployment of simulation notebooks or analysis dashboards on a workstation or cloud instance."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Optocoupler isolation protects the Pi from high‑current actuation circuits; low‑level driver employs a safe protocol to ensure the PT stays within electrical safety limits; controller respects heating duration and waiting duration limits to prevent overheating; no remote execution capability described, limiting safety risk."
]