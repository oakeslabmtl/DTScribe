// C3: Physical sensing components
instance InsideIncubatorTempSensorLeft : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor positioned inside the incubator (left side)."
    DTDFVocab:producedData InsideIncubatorTempDataTransmitted
]

instance InsideIncubatorTempSensorRight : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor positioned inside the incubator (right side)."
    DTDFVocab:producedData InsideIncubatorTempDataTransmitted
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor measuring ambient (outside) temperature."
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// Additional sensing components for power and fan state
instance HeatbedPowerMeasurement : DTDFVocab:SensingComponent [
    base:desc "Electrical measurement of heatbed power consumption via shunt resistor."
    DTDFVocab:producedData HeatbedPowerDataTransmitted
]

instance FanActuatorStateMeasurement : DTDFVocab:SensingComponent [
    base:desc "Electrical pulse‑width modulation status readout of the fan actuator."
    DTDFVocab:producedData FanActuatorStateDataTransmitted
]

// C4: Data transmitted
instance InsideIncubatorTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideIncubatorTempSensorLeft, InsideIncubatorTempSensorRight
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

instance HeatbedPowerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatbedPowerMeasurement
]

instance FanActuatorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FanActuatorStateMeasurement
]

// C10: Data
instance InsideIncubatorTemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature readings from the two inside incubator sensors."
    DTDFVocab:inputTo RabbitMQBroker
    DTDFVocab:fromData InsideIncubatorTempDataTransmitted
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Real‑time ambient temperature reading."
    DTDFVocab:inputTo RabbitMQBroker
    DTDFVocab:fromData AmbientTempDataTransmitted
]

instance HeatbedPowerData : DTDFVocab:Data [
    base:desc "Instantaneous power measurement of the heatbed."
    DTDFVocab:inputTo RabbitMQBroker
    DTDFVocab:fromData HeatbedPowerDataTransmitted
]

instance FanActuatorStateData : DTDFVocab:Data [
    base:desc "Current state of the fan actuator (ON/OFF or PWM level)."
    DTDFVocab:inputTo RabbitMQBroker
    DTDFVocab:fromData FanActuatorStateDataTransmitted
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP server for publishing sensor data and receiving remote actuation commands."
    DTDFVocab:enables RealTimeTemperatureMonitoringService, RemoteActuationService
]

instance PythonSciPyCalibrationTool : DTDFVocab:Enabler [
    base:desc "Python runtime environment with SciPy and NumPy for least‑squares calibration and predictive simulation."
    DTDFVocab:enables CalibrationService, PredictiveSimulationService, DecisionSupportService
]

instance RaspberryPiRuntime : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B executing control scripts and PWM outputs."
    DTDFVocab:enables BangBangControlService
]

instance MOSFETOptocouplerPCB : DTDFVocab:Enabler [
    base:desc "MOSFET and optocoupler board providing isolated switching for the heatbed and fan."
    DTDFVocab:enables BangBangControlService
]

// C6: Services
instance RealTimeTemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time temperature monitoring service continuously streams sensor data."
    DTDFVocab:provides RealTimeTemperatureInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation of incubator thermal dynamics using Models A and B."
    DTDFVocab:provides PredictedTemperatureInsight, SteadyStateTemperaturePredictionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Least‑squares optimisation‑based calibration of Model A and B parameters."
    DTDFVocab:provides CalibratedThermalInertiaInsight
]

instance BangBangControlService : DTDFVocab:Service [
    base:desc "Closed‑loop bang‑bang control of heatbed and fan based on predicted temperatures."
    DTDFVocab:provides BangBangControlAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides interactive visualization of temperature trajectories and model predictions."
    DTDFVocab:provides VisualizeDataAction
]

instance RemoteActuationService : DTDFVocab:Service [
    base:desc "Remote actuation service that sends control commands to the heatbed and fan via the Raspberry Pi."
    DTDFVocab:provides RemoteActuationAction
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Decision‑making service that generates recommendations based on model calibration and predictions."
    DTDFVocab:provides SuggestParameterUpdateAction, SuggestScheduleChangeAction
]

// C17: Insights
instance CalibratedThermalInertiaInsight : DTDFVocab:Insight [
    base:desc "Calibrated thermal inertia parameters derived from Model A and B."
]

instance SteadyStateTemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted steady‑state temperature of the incubator based on current parameters."
]

instance ControlScheduleInsight : DTDFVocab:Insight [
    base:desc "Recommended control schedule for heatbed and fan to maintain target temperatures."
]

instance RealTimeTemperatureInsight : DTDFVocab:Insight [
    base:desc "Live temperature readings from the incubator sensors."
]

instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Model‑predicted temperature trajectory for the incubator."
]

// C17: Actions
instance SuggestParameterUpdateAction : DTDFVocab:Action [
    base:desc "Suggests updates to the model parameters based on recent data."
    DTDFVocab:IsAutomatic false
]

instance SuggestScheduleChangeAction : DTDFVocab:Action [
    base:desc "Suggests a change in the fan/heatbed control schedule."
    DTDFVocab:IsAutomatic false
]

instance BangBangControlAction : DTDFVocab:Action [
    base:desc "Bang‑bang control pulse applied to the heatbed or fan."
    DTDFVocab:IsAutomatic true
]

instance VisualizeDataAction : DTDFVocab:Action [
    base:desc "Triggers visualization of temperature and prediction data in the dashboard."
    DTDFVocab:IsAutomatic false
]

instance RemoteActuationAction : DTDFVocab:Action [
    base:desc "Sends a remote actuation command to the physical twin."
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance ModelA : DTDFVocab:Model [
    base:desc "Thermodynamic model A with 2 free parameters representing heat capacity and insulation."
    DTDFVocab:inputTo PythonSciPyCalibrationTool
]

instance ModelB : DTDFVocab:Model [
    base:desc "Thermodynamic model B with 4 free parameters capturing additional effects such as fan dynamics."
    DTDFVocab:inputTo PythonSciPyCalibrationTool
]

// C15/ C7: Environment and Component
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InsideIncubatorTemperatureData, AmbientTemperatureData, HeatbedPowerData, FanActuatorStateData
]

instance IncubatorPhysicalSystem : DTDFVocab:Component [
    base:desc "Styrofoam insulated box incubator with heatbed, fan, and Raspberry Pi controller."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT issues control commands (heatbed on/off, fan on/off) via RabbitMQ messages that the Raspberry Pi controller processes and forwards to the MOSFET‑controlled actuators. These commands constitute the virtual‑to‑physical flow."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation with periodic sensor polling (few seconds) and command updates through RabbitMQ. Calibration and long‑term data analysis are performed offline on recorded data samples."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is orchestrated by the RabbitMQ message broker linking the physical components (sensors/actuators) to the DT services (control, modeling, monitoring). The theatrical flow runs from PT → low‑level driver → RabbitMQ → DT algorithms → RabbitMQ → controller → PT."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the PT during manufacturing (setup of hardware and initial software) and operation (runtime monitoring and control). It does not explicitly cover design/ideal stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is limited by assumptions (uniform temperature, negligible wall heat absorption, constant air specific heat). Validation is performed by comparing simulation outputs with experimental temperature traces and by calibrating free parameters to minimize residual error."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical–digital linkage uses RabbitMQ AMQP over a local network (Wi‑Fi/Ethernet). The Raspberry Pi publishes sensor data and receives actuator commands through AMQP topics."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted on the Raspberry Pi embedded in the incubator, leveraging its local Wi‑Fi/Ethernet connectivity. The codebase is open‑source and can be deployed on other Linux machines as well."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is incorporated in the low‑level driver to keep the device in a safe state; however, detailed cybersecurity or safety standards are not specified in the document."
]