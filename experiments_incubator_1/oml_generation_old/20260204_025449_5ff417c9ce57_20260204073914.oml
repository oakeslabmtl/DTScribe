// C1: Environment // Return code: 1 | Stderr:
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Insulated incubator comprising a 0.03 m³ styrofoam box, a heatbed, a fan, and a Raspberry Pi 4 Model B controller."
    base:contains RaspberryPi4, PCB, Heatbed, Fan, InternalTempSensor1, InternalTempSensor2, ExternalTempSensor
]

// C2: Acting Components
instance Heatbed : DTDFVocab:ActingComponent [
    base:desc "Resistive heatbed, 4 A capacity, driven by a MOSFET transistor via the Raspberry Pi 4."
    DTDFVocab:producedData ActuatorStatePacket
]
instance Fan : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V fan, driven by a MOSFET transistor via the Raspberry Pi 4."
    DTDFVocab:producedData ActuatorStatePacket
]
instance RaspberryPi4 : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B, hosting Python driver, RabbitMQ broker, and SciPy optimiser."
]
instance PCB : DTDFVocab:Component [
    base:desc "Printed circuit board with MOSFETs, optocouplers, and 12 V/24 V regulator."
]

// C3: Physical sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer, housed inside the styrofoam box."
    DTDFVocab:producedData TemperaturePacket
]
instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer, housed inside the styrofoam box."
    DTDFVocab:producedData TemperaturePacket
]
instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer, mounted outside the incubator for ambient temperature."
    DTDFVocab:producedData TemperaturePacket
]

// C4: Physical‑to‑virtual interaction
instance TemperaturePacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1, InternalTempSensor2, ExternalTempSensor
]
instance ActuatorStatePacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Heatbed, Fan
]

// C5: Data generated from packets
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time stream of temperature readings from the DS18S20 sensors, timestamped and sent via RabbitMQ."
    DTDFVocab:fromData TemperaturePacket
    DTDFVocab:inputTo DriverBrokerEnabler, SimulationEnabler, CalibrationEnabler, OptimizationEnabler
]
instance ActuatorStateData : DTDFVocab:Data [
    base:desc "Log of actuator states (heatbed and fan) published to RabbitMQ."
    DTDFVocab:fromData ActuatorStatePacket
    DTDFVocab:inputTo DriverBrokerEnabler
]
instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Outputs of the chosen thermal model (Model B) simulating temperature trajectories."
    DTDFVocab:fromData TemperaturePacket
    DTDFVocab:inputTo CalibrationEnabler, OptimizationEnabler
]

// C10: Models/Data
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Energy balance equation with parameters C_air and G_box."
    DTDFVocab:inputTo SimulationEnabler
]
instance ThermalModelB : DTDFVocab:Model [
    base:desc "Heatbed–air coupling model with parameters C_air, C_heater, G_box, G_heater."
    DTDFVocab:inputTo SimulationEnabler
]

// C11: Enablers
instance DriverBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Python driver polling DS18S20 sensors and publishing data via the local RabbitMQ broker."
    DTDFVocab:enables MonitoringService
]
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Software stack (NumPy integration) running the thermal models and producing simulation outputs."
    DTDFVocab:enables SimulationService
]
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "SciPy least‑squares optimiser calibrating model parameters against real temperature data."
    DTDFVocab:enables CalibrationService
]
instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Parameter optimisation service refining fan voltage and heating cycle durations to improve energy efficiency."
    DTDFVocab:enables OptimizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature and actuator states via RabbitMQ."
    DTDFVocab:provides TemperatureAlert, PredictiveTemperatureGraph
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of the incubator dynamics using Model B with real‑time temperature inputs."
    DTDFVocab:provides SimulationOutput
]
instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration of model parameters through non‑linear least‑squares optimisation using SciPy."
    DTDFVocab:provides ParameterUpdateInsight
]
instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimisation of fan voltage and heating cycle durations to maximise energy efficiency."
    DTDFVocab:provides FanVoltageAdjustmentSuggestion, HeatingCycleSuggestion
]

// C17: Insights/Actions
instance TemperatureAlert : DTDFVocab:Insight [
    base:desc "Real‑time alert when temperature limits are exceeded."
]
instance PredictiveTemperatureGraph : DTDFVocab:Insight [
    base:desc "Simulated temperature trajectory plotted for future prediction."
]
instance SimulationOutput : DTDFVocab:Insight [
    base:desc "Run‑time output of the chosen thermal model for current state."
]
instance ParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Calibrated parameter updates for future control adjustments."
]
instance FanVoltageAdjustmentSuggestion : DTDFVocab:Action [
    base:desc "Suggestion to adjust fan voltage to improve energy efficiency."
    DTDFVocab:IsAutomatic false
]
instance HeatingCycleSuggestion : DTDFVocab:Action [
    base:desc "Suggestion to modify heating cycle durations for optimal temperature maintenance."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT consumes control messages from its workflow engine and transmits them over the RabbitMQ broker back to the controller. These messages dictate the on/off state of the heatbed and fan, effectively commanding the physical actuators. The controller listens to the command queue and actuates the MOSFETs accordingly, completing the closed‑loop DT‑PT interaction."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The interaction system performs polling of sensor data and command handling in an event‑driven manner; no explicit sampling interval or actuation latency is specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of the physical incubator, the low‑level driver, the controller, the RabbitMQ broker, and the DT engine running the simulation models. The driver and controller are tightly coupled to the Pi; the broker mediates between the PT and the remote DT services. All components are orchestrated via message queues and shared data structures."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle spans design (conceptual model and hardware selection), manufacturing (assembly of PCB, sensors, heatbed, and fan), and operation (deployment, periodic simulation, calibration, validation, and monitoring during experiments)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is constrained by assumptions: uniform temperature distribution (validated by uniform‑temperature experiments), negligible wall heat accumulation, constant specific heat of air, and ignoring fan heat. Validation via experimental temperature recordings against model predictions yielded residual errors; calibration improved fidelity. Uncertainty bounds arise from sensor accuracy (±0.5 °C) and parameter identifiability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The communication stack uses AMQP over TCP/IP within the Raspberry Pi’s LAN. Sensors connect via 1‑Wire bus to GPIO pins; actuators are driven through MOSFETs controlled through GPIO lines. The RabbitMQ server runs locally on the Pi; controllers and DT services publish/subscribe to AMQP queues."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components (controller, driver, RabbitMQ broker, simulation models) are hosted on the same Raspberry Pi 4, providing a tightly coupled local deployment without external cloud services."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safety protocol with defined lower and upper temperature limits (LL, UL), heating duration (H), and waiting duration (C) to avoid overheating. Electrical isolation is provided by optocouplers between the Pi and MOSFET controls. No further cybersecurity measures are detailed in the document."
]