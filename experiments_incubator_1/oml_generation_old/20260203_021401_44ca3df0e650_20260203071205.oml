// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Surface heater (heatbed) driven through a MOSFET switch on the PCB, commanded by the Raspberry Pi."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Air circulator (fan) driven through a MOSFET switch on the PCB, commanded by the Raspberry Pi."
]

// C3: Physical sensing components
instance InteriorAirTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring interior air temperature (sensor 1), accuracy ±0.5 °C, range –55 °C to +125 °C."
    DTDFVocab:producedData InteriorAirTempMessage1
]

instance InteriorAirTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring interior air temperature (sensor 2), accuracy ±0.5 °C, range –55 °C to +125 °C."
    DTDFVocab:producedData InteriorAirTempMessage2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring ambient environment temperature, accuracy ±0.5 °C, range –55 °C to +125 °C."
    DTDFVocab:producedData AmbientTempMessage
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance InteriorAirTempMessage1 : DTDFVocab:DataTransmitted [
    base:desc "RabbitMQ message containing a time‑stamped temperature reading from InteriorAirTempSensor1."
    DTDFVocab:producedFrom InteriorAirTempSensor1
]

instance InteriorAirTempMessage2 : DTDFVocab:DataTransmitted [
    base:desc "RabbitMQ message containing a time‑stamped temperature reading from InteriorAirTempSensor2."
    DTDFVocab:producedFrom InteriorAirTempSensor2
]

instance AmbientTempMessage : DTDFVocab:DataTransmitted [
    base:desc "RabbitMQ message containing a time‑stamped temperature reading from AmbientTempSensor."
    DTDFVocab:producedFrom AmbientTempSensor
]

// C10: Data (consumed by Enablers)
instance InteriorAirTemperatureData1 : DTDFVocab:Data [
    base:desc "Time‑stamped interior air temperature value (°C) received from InteriorAirTempMessage1."
    DTDFVocab:fromData InteriorAirTempMessage1
    DTDFVocab:inputTo PythonDriverEnabler, CalibrationEnabler
]

instance InteriorAirTemperatureData2 : DTDFVocab:Data [
    base:desc "Time‑stamped interior air temperature value (°C) received from InteriorAirTempMessage2."
    DTDFVocab:fromData InteriorAirTempMessage2
    DTDFVocab:inputTo PythonDriverEnabler, CalibrationEnabler
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped ambient temperature value (°C) received from AmbientTempMessage."
    DTDFVocab:fromData AmbientTempMessage
    DTDFVocab:inputTo PythonDriverEnabler, CalibrationEnabler
]

// C11: Enablers
instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker used for publishing sensor messages and delivering them to the Digital Twin."
    DTDFVocab:enables SimulationService, MonitoringService
]

instance PythonDriverEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level Python driver accessing GPIO pins to read sensors and drive actuators."
    DTDFVocab:enables MonitoringService, CalibrationService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "SciPy non‑linear least‑squares optimizer employed to calibrate thermal model parameters."
    DTDFVocab:enables CalibrationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine executing thermal models to predict incubator temperature."
    DTDFVocab:enables SimulationService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Runs thermal models (Model A and Model B) to simulate incubator temperature dynamics."
    DTDFVocab:provides InsightSimulationResult
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibrates model parameters (C_air, G_box, C_heater, G_heater) using recorded temperature trajectories."
    DTDFVocab:provides InsightCalibrationComplete
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitors real‑time temperature against defined limits and decides heating or cooling actions."
    DTDFVocab:provides InsightTemperatureWithinLimits, ActionActivateHeatbed, ActionActivateFan
]

instance SafetyCheckService : DTDFVocab:Service [
    base:desc "Performs safety checks and can trigger fan actuation when unsafe temperature conditions are detected."
    DTDFVocab:provides InsightSafetyRiskDetected, ActionActivateFan
]

// C17: Insights
instance InsightSimulationResult : DTDFVocab:Insight [
    base:desc "Result of thermal simulation indicating the predicted temperature trajectory for the incubator."
]

instance InsightCalibrationComplete : DTDFVocab:Insight [
    base:desc "Calibration completed, delivering updated model parameters (C_air, G_box, C_heater, G_heater)."
]

instance InsightTemperatureWithinLimits : DTDFVocab:Insight [
    base:desc "Current temperature is within the specified operational limits."
]

instance InsightSafetyRiskDetected : DTDFVocab:Insight [
    base:desc "Potential safety risk detected because temperature exceeds the safe threshold."
]

// C17: Actions
instance ActionActivateHeatbed : DTDFVocab:Action [
    base:desc "Command to turn on the heatbed for heating the incubator."
    DTDFVocab:IsAutomatic true
]

instance ActionActivateFan : DTDFVocab:Action [
    base:desc "Command to turn on the fan for cooling or safety mitigation."
    DTDFVocab:IsAutomatic true
]

// C10: Models/Data
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Physics‑based thermal model A with air capacity C_air and heat‑loss conductance G_box."
    DTDFVocab:inputTo SimulationEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Physics‑based thermal model B extending Model A with heater thermal mass C_heater and conductance G_heater."
    DTDFVocab:inputTo SimulationEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes command messages (heat‑bed ON/OFF, fan ON/OFF, waiting durations) to the same RabbitMQ broker; the controller on the Raspberry Pi consumes these messages and actuates the heatbed and fan via the MOSFET/optocoupler circuit."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation comprises the physical incubator, the Raspberry Pi controller, a low‑level driver, a RabbitMQ server on the Pi, and DT components (calibration, simulation, monitoring) that subscribe/publish to the broker, forming a loosely‑coupled message‑based architecture (Fig. 7)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed by comparing simulated temperature trajectories with measurements from uniform‑temperature experiments; Model B, which includes heater thermal inertia, showed higher predictive accuracy, and calibration stops when the residual error of the cost function becomes sufficiently small."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses the RabbitMQ AMQP protocol over the Raspberry Pi’s built‑in Wi‑Fi/Bluetooth network; actuator commands and sensor updates are exchanged as discrete messages via the broker."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT software components (RabbitMQ broker, low‑level driver, controller logic, calibration scripts) are deployed on the Raspberry Pi 4 Model B, which also supplies power to the PCB and peripherals; the source code and configuration are hosted in a public GitHub repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol that ensures the PT is kept in a safe state before executing commands, and the DT includes monitors that detect violations of temperature limits to prevent unsafe operation."
]