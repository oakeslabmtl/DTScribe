// C3: Physical sensing components
instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the Physical Twin to continuously collect temperature data for real‑time state estimation."
    DTDFVocab:producedData AmbientTemperatureDataTransmitted
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Pressure sensor embedded in the Physical Twin to capture pressure variations relevant to structural dynamics."
    DTDFVocab:producedData PressureDataTransmitted
]

// C4: Physical-to-virtual interaction
instance AmbientTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

// C10: Models/Data
instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series temperature measurements streamed from the AmbientTemperatureSensor."
    DTDFVocab:fromData AmbientTemperatureDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, ControlEnabler
]

instance PressureData : DTDFVocab:Data [
    base:desc "Time‑series pressure measurements streamed from the PressureSensor."
    DTDFVocab:fromData PressureDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

// DTDFVocab:Model instances
instance GeometricModel : DTDFVocab:Model [
    base:desc "Geometric representation with shape definitions and dimensional parameters of the Physical Twin."
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

instance BehaviouralDynamicsModel : DTDFVocab:Model [
    base:desc "Differential equations describing the dynamics of the system, calibrated by sensor data."
    DTDFVocab:inputTo CalibrationEnabler
]

instance AnalyticalPhysicsModel : DTDFVocab:Model [
    base:desc "Analytical model representing physics and cyber‑system aspects for simulation and optimisation."
    DTDFVocab:inputTo MonitoringEnabler, OptimizationEnabler
]

// C11: Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm enabler that adjusts differential equation parameters to align the BehaviouralDynamicsModel with observed sensor data."
    DTDFVocab:enables CalibrationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring enabler responsible for feeding state‑estimation and fault‑detection modules with synchronized sensor data."
    DTDFVocab:enables MonitoringService
]

instance ControlEnabler : DTDFVocab:Enabler [
    base:desc "Control enabler that delivers corrective actuation commands based on predictive model outputs."
    DTDFVocab:enables ControlService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimization enabler that formulates objective‑oriented problem definitions using calibrated models."
    DTDFVocab:enables OptimizationService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that executes calibration routines and updates model parameters based on real‑time sensor streams."
    DTDFVocab:provides CalibrationInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that fuses multi‑modal sensor data and performs state‑estimation to detect deviations from nominal behaviour."
    DTDFVocab:provides FaultDetectionInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Service that computes corrective actuation commands to maintain safe operating envelopes."
    DTDFVocab:provides ControlAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that solves optimisation problems to enhance energy‑efficiency or performance using calibrated models."
    DTDFVocab:provides OptimizationInsight
]

// C17: Insights/Actions
instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Confidence‑measured insight indicating that model parameters have converged within acceptable tolerance."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight flagging deviations that may indicate emergent failures based on model‑data residuals."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight presenting optimal configuration or scheduling solution derived from calibrated models."
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Automatic actuation command to be relayed to the Physical Twin for corrective action."
    DTDFVocab:IsAutomatic true
]

instance OptimizationAction : DTDFVocab:Action [
    base:desc "Recommended configuration or scheduling adjustment to be validated by human operators."
    DTDFVocab:IsAutomatic false
]

// Environment
instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains AmbientTemperatureSensor, PressureSensor, GeometricModel, BehaviouralDynamicsModel, AnalyticalPhysicsModel, CalibrationEnabler, MonitoringEnabler, ControlEnabler, OptimizationEnabler, CalibrationService, MonitoringService, ControlService, OptimizationService, CalibrationInsight, FaultDetectionInsight, OptimizationInsight, ControlAction, OptimizationAction
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Calibration algorithms are employed to refine model parameters, suggesting a validation loop that adjusts the model to match observed data. Monitors evaluate whether the Physical Twin is operating safely and optimally, detecting violations that trigger human or algorithmic corrective actions. While explicit formal verification or uncertainty quantification methods are not detailed, the described calibration and monitoring activities represent practical fidelity assurance mechanisms within the system."
]