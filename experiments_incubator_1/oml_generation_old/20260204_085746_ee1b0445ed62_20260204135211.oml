// C3: Physical Sensing Components
instance ForceSensorArray : DTDFVocab:SensingComponent [
    base:desc "Array of force sensors deployed across the Physical Twin to capture dynamic interaction forces between components under operating conditions, with millisecond-level latency for real-time monitoring."
    DTDFVocab:producedData ForceSensorDataTransmitted
]

instance EnvironmentalMonitor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor system measuring external factors like aerodynamic forces, thermal gradients, and operational conditions that influence system behavior, with 1-10Hz sampling frequency."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

instance PositionTrackingSystem : DTDFVocab:SensingComponent [
    base:desc "High-precision position tracking system using inertial measurement units and global positioning for capturing spatial dynamics of the Physical Twin components with sub-millimeter accuracy."
    DTDFVocab:producedData PositionDataTransmitted
]

instance VibrationAnalysisUnit : DTDFVocab:SensingComponent [
    base:desc "Vibration analysis unit employing accelerometers and FFT-based signal processing to detect structural health and dynamic response characteristics at 100Hz sampling rate."
    DTDFVocab:producedData VibrationDataTransmitted
]

instance TemperatureMonitoringNetwork : DTDFVocab:SensingComponent [
    base:desc "Distributed temperature monitoring network with RTD sensors and thermocouples deployed across critical components to measure thermal dynamics with 1Hz resolution."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance ForceSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ForceSensorArray
    DTDFVocab:transmissionProtocol OPCUA
    DTDFVocab:transmissionFrequency 100
    DTDFVocab:dataType TimeSeries
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalMonitor
    DTDFVocab:transmissionProtocol MQTT
    DTDFVocab:transmissionFrequency 5
    DTDFVocab:dataType StructuredMetadata
]

instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionTrackingSystem
    DTDFVocab:transmissionProtocol EthernetIP
    DTDFVocab:transmissionFrequency 1000
    DTDFVocab:dataType SpatialCoordinates
]

instance VibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationAnalysisUnit
    DTDFVocab:transmissionProtocol PROFINET
    DTDFVocab:transmissionFrequency 100
    DTDFVocab:dataType FrequencyDomain
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureMonitoringNetwork
    DTDFVocab:transmissionProtocol OPCUA
    DTDFVocab:transmissionFrequency 1
    DTDFVocab:dataType ThermalProfiles
]

// C10: Models/Data
instance GeometricModel : DTDFVocab:Model [
    base:desc "CAD-based geometric representation of Physical Twin components including chassis, wheels, and structural elements with millimeter-level precision for spatial analysis."
    DTDFVocab:inputTo CADIntegrationEnabler
]

instance DynamicBehaviorModel : DTDFVocab:Model [
    base:desc "Physics-based dynamic model implemented via differential equations to simulate forces, movement, and system interactions under operating conditions with 0.1ms time step resolution."
    DTDFVocab:inputTo SimulationEngineEnabler
    DTDFVocab:inputTo CalibrationAlgorithmEnabler
]

instance AnalyticalPerformanceModel : DTDFVocab:Model [
    base:desc "Mathematical formulation of physical laws for predictive analysis and optimization, incorporating environmental interaction parameters with 1% accuracy tolerance."
    DTDFVocab:inputTo OptimizationEnabler
    DTDFVocab:inputTo PredictiveAnalysisService
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Aggregated time-series dataset combining sensor-collected operational parameters including forces, environmental conditions, and component states with 10ms timestamp resolution."
    DTDFVocab:fromData ForceSensorDataTransmitted, EnvironmentalDataTransmitted, PositionDataTransmitted, VibrationDataTransmitted, TemperatureDataTransmitted
    DTDFVocab:inputTo StateEstimationEnabler
    DTDFVocab:inputTo MonitoringServiceEnabler
]

instance CalibrationParameters : DTDFVocab:Data [
    base:desc "Optimized model parameters derived from best-estimate techniques including material properties, control gains, and environmental coefficients with Bayesian confidence intervals."
    DTDFVocab:fromData RealTimeOperationalData
    DTDFVocab:inputTo CalibrationAlgorithmEnabler
    DTDFVocab:inputTo OptimizationEnabler
]

instance KnowledgeRepository : DTDFVocab:Data [
    base:desc "Structured knowledge base storing validated models of Cyber-Physical Systems and environmental interactions with version-controlled metadata and calibration histories."
    DTDFVocab:inputTo FederatedLearningEnabler
    DTDFVocab:inputTo VisualizationEnabler
]

// C11: Enablers
instance CADIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "SolidWorks-based CAD integration platform enabling 3D geometric visualization and spatial analysis with millimeter-level precision."
    DTDFVocab:enables StructuralAnalysisService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "ANSYS Fluent computational environment for solving dynamic system equations with adaptive time-stepping and parallel processing capabilities."
    DTDFVocab:enables BehavioralReproductionService
    DTDFVocab:enables ScenarioTestingService
]

instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Bayesian inference framework implementing least-squares optimization for refining model parameters with 0.5% accuracy improvement per calibration cycle."
    DTDFVocab:enables ParameterCalibrationService
    DTDFVocab:enables ModelValidationService
]

instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "Unscented Kalman Filter implementation for reconstructing Physical Twin state from noisy sensor inputs with 95% confidence interval reporting."
    DTDFVocab:enables StateEstimationService
    DTDFVocab:enables AnomalyDetectionService
]

instance MonitoringServiceEnabler : DTDFVocab:Enabler [
    base:desc "Real-time data processing pipeline combining ETL pipelines and anomaly detection algorithms with sub-second latency."
    DTDFVocab:enables MonitoringService
    DTDFVocab:enables FaultDetectionService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Multi-objective optimization solver using evolutionary strategies for parameter tuning with 10% performance improvement targets."
    DTDFVocab:enables PerformanceTuningService
    DTDFVocab:enables ControlParameterService
]

instance FederatedLearningEnabler : DTDFVocab:Enabler [
    base:desc "Decentralized learning framework maintaining data privacy while improving model accuracy across distributed Digital Twin instances."
    DTDFVocab:enables ModelRefinementService
    DTDFVocab:enables KnowledgeIntegrationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unity-based 3D visualization platform integrating WebGL overlays for real-time data visualization with sub-100ms rendering latency."
    DTDFVocab:enables VisualizationService
    DTDFVocab:enables InteractiveDashboardService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous real-time data acquisition and validation service comparing Physical Twin behavior against Digital Twin predictions with 99.9% uptime SLA."
    DTDFVocab:provides RealTimeStateInsight
    DTDFVocab:provides DataQualityAlertAction
]

instance BehavioralReproductionService : DTDFVocab:Service [
    base:desc "Dynamic simulation service reproducing Physical Twin behavior under current operating conditions with 0.01% error margin."
    DTDFVocab:provides CurrentStateInsight
    DTDFVocab:provides SimulationValidationAction
]

instance PredictiveAnalysisService : DTDFVocab:Service [
    base:desc "Time-series forecasting service predicting future states 1-10 minutes ahead using physics-informed neural networks with 85% confidence intervals."
    DTDFVocab:provides FutureStateInsight
    DTDFVocab:provides RiskAssessmentAction
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "State reconstruction service using Kalman filtering to estimate Physical Twin state from incomplete or noisy sensor data with 98% accuracy."
    DTDFVocab:provides StateEstimationInsight
    DTDFVocab:provides StateCorrectionAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Fault detection service identifying deviations from expected behavior using statistical process control and autoencoder anomaly detection."
    DTDFVocab:provides AnomalyDetectionInsight
    DTDFVocab:provides FaultAlertAction
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Model parameter optimization service refining Digital Twin models using least-squares fitting and Bayesian inference techniques."
    DTDFVocab:provides CalibrationMetricsInsight
    DTDFVocab:provides ModelUpdateAction
]

instance PerformanceTuningService : DTDFVocab:Service [
    base:desc "Operational parameter optimization service adjusting control signals and resource allocation for maximum efficiency with 5% throughput improvement targets."
    DTDFVocab:provides OptimizationMetricsInsight
    DTDFVocab:provides ControlAdjustmentAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D dashboard service providing real-time visualizations of Physical Twin state, model predictions, and anomaly alerts with sub-second update rates."
    DTDFVocab:provides VisualizationInsight
    DTDFVocab:provides UserInteractionAction
]

// C17: Insights/Actions
instance RealTimeStateInsight : DTDFVocab:Insight [
    base:desc "Continuous real-time representation of Physical Twin's current operational state derived from sensor data and model predictions with millisecond-level timestamp."
]

instance CurrentStateInsight : DTDFVocab:Insight [
    base:desc "Dynamic simulation output showing Physical Twin's behavior under current operating conditions with 0.01% error margin."
]

instance FutureStateInsight : DTDFVocab:Insight [
    base:desc "Predicted future states of the Physical Twin 1-10 minutes ahead with 85% confidence intervals based on current trends and environmental conditions."
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Reconstructed state of the Physical Twin from noisy sensor data using Kalman filtering with 98% accuracy confidence metrics."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Identified deviations from expected behavior patterns with statistical significance scores and root cause probability estimates."
]

instance CalibrationMetricsInsight : DTDFVocab:Insight [
    base:desc "Model accuracy metrics including parameter confidence intervals, calibration error statistics, and best-estimate technique performance indicators."
]

instance OptimizationMetricsInsight : DTDFVocab:Insight [
    base:desc "Performance improvement metrics showing efficiency gains, safety margins, and resource utilization optimization results."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "3D spatial and temporal visualizations combining CAD models, real-time sensor data, and predictive analytics for intuitive decision support."
]

instance DataQualityAlertAction : DTDFVocab:Action [
    base:desc "Automated alert generation for data transmission errors, sensor failures, or quality degradation with immediate notification to monitoring systems."
    DTDFVocab:IsAutomatic true
]

instance FaultAlertAction : DTDFVocab:Action [
    base:desc "Immediate fault detection response triggering safety protocols and maintenance alerts with automatic isolation of affected components."
    DTDFVocab:IsAutomatic true
]

instance StateCorrectionAction : DTDFVocab:Action [
    base:desc "Automated state correction applying Kalman filter updates to Digital Twin models based on new sensor observations with confidence-weighted adjustments."
    DTDFVocab:IsAutomatic true
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Real-time control parameter adjustments executed via supervisory controllers to maintain system performance within operational constraints."
    DTDFVocab:IsAutomatic true
]

instance UserInteractionAction : DTDFVocab:Action [
    base:desc "Human-in-the-loop decision support enabling manual overrides, parameter tuning, and scenario testing through interactive visualization interfaces."
    DTDFVocab:IsAutomatic false
]

instance SimulationValidationAction : DTDFVocab:Action [
    base:desc "Automated validation of simulation results against real-world data to ensure Digital Twin accuracy."
    DTDFVocab:IsAutomatic true
]

instance RiskAssessmentAction : DTDFVocab:Action [
    base:desc "Automated risk assessment identifying potential failure modes and their likelihood based on current system state."
    DTDFVocab:IsAutomatic true
]

instance ModelUpdateAction : DTDFVocab:Action [
    base:desc "Automated model update applying corrections to Digital Twin parameters based on validation results."
    DTDFVocab:IsAutomatic true
]

// C1: Physical Twin Components
instance PhysicalTwinSystem : DTDFVocab:Environment [
    base:desc "Complex Cyber-Physical System integrating physical components, cyber systems, and environmental interactions operating in real-time with safety-critical performance requirements."
    base:contains ChassisComponent, WheelAssembly, SensorNetwork, ActuatorSystem, EnvironmentalInterface
]

instance ChassisComponent : DTDFVocab:Component [
    base:desc "Primary structural element of the Physical Twin with geometric CAD representation and dynamic behavior modeled via finite element analysis for force distribution analysis."
    base:isContainedIn PhysicalTwinSystem
]

instance WheelAssembly : DTDFVocab:Component [
    base:desc "Rotational mechanical subsystem with dynamic behavior modeled via multibody dynamics simulations incorporating friction, inertia, and environmental interaction forces."
    base:isContainedIn PhysicalTwinSystem
]

instance SensorNetwork : DTDFVocab:Component [
    base:desc "Distributed sensor infrastructure capturing operational parameters including forces, motion, and environmental conditions with millisecond-level latency."
    base:isContainedIn PhysicalTwinSystem
]

instance ActuatorSystem : DTDFVocab:Component [
    base:desc "Control actuation subsystem implementing real-time adjustments to Physical Twin behavior based on Digital Twin optimization recommendations."
    base:isContainedIn PhysicalTwinSystem
]

instance EnvironmentalInterface : DTDFVocab:Component [
    base:desc "External interaction surface modeling aerodynamic forces, thermal gradients, and operational conditions affecting system performance."
    base:isContainedIn PhysicalTwinSystem
]

// Added missing service instances
instance StructuralAnalysisService : DTDFVocab:Service [
    base:desc "Structural analysis service performing finite element analysis to evaluate component integrity under dynamic loading conditions."
]

instance ScenarioTestingService : DTDFVocab:Service [
    base:desc "Scenario testing service simulating hypothetical operational conditions to evaluate system robustness and failure modes."
]

instance ModelValidationService : DTDFVocab:Service [
    base:desc "Model validation service comparing Digital Twin predictions against real-world Physical Twin behavior to assess accuracy and reliability."
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection service identifying and classifying system failures using statistical process control and machine learning-based anomaly detection."
]

instance ModelRefinementService : DTDFVocab:Service [
    base:desc "Model refinement service continuously improving Digital Twin accuracy through adaptive learning and parameter optimization techniques."
]

instance KnowledgeIntegrationService : DTDFVocab:Service [
    base:desc "Knowledge integration service combining insights from multiple Digital Twin instances to create comprehensive system understanding."
]

instance ControlParameterService : DTDFVocab:Service [
    base:desc "Control parameter service optimizing system control parameters for maximum efficiency and safety under varying operational conditions."
]

