// ====================== Sensors ======================
instance DS18S20BoxSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer (range –55 °C to +125 °C, accuracy 0.5 °C within –10 °C to +85 °C) located inside the incubator box, unique 64‑bit ID 0x1"
    DTDFVocab:producedData TemperatureMessageBox1
]

instance DS18S20BoxSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer (range –55 °C to +125 °C, accuracy 0.5 °C within –10 °C to +85 °C) located inside the incubator box, unique 64‑bit ID 0x2"
    DTDFVocab:producedData TemperatureMessageBox2
]

instance DS18S20AmbientSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer (range –55 °C to +125 °C, accuracy 0.5 °C within –10 °C to +85 °C) measuring ambient temperature outside the box, unique 64‑bit ID 0x3"
    DTDFVocab:producedData TemperatureMessageAmbient
]

// ====================== Data Transmitted ======================
instance TemperatureMessageBox1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20BoxSensor1
]

instance TemperatureMessageBox2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20BoxSensor2
]

instance TemperatureMessageAmbient : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20AmbientSensor
]

// ====================== Data ======================
instance TemperatureDataBox1 : DTDFVocab:Data [
    base:desc "Raw temperature reading (°C) from DS18S20BoxSensor1 published via RabbitMQ"
    DTDFVocab:fromData TemperatureMessageBox1
    DTDFVocab:inputTo RabbitMQBrokerEnabler, SciPyCalibrationEnabler, BangBangControllerEnabler
]

instance TemperatureDataBox2 : DTDFVocab:Data [
    base:desc "Raw temperature reading (°C) from DS18S20BoxSensor2 published via RabbitMQ"
    DTDFVocab:fromData TemperatureMessageBox2
    DTDFVocab:inputTo RabbitMQBrokerEnabler, SciPyCalibrationEnabler, BangBangControllerEnabler
]

instance TemperatureDataAmbient : DTDFVocab:Data [
    base:desc "Raw temperature reading (°C) from DS18S20AmbientSensor published via RabbitMQ"
    DTDFVocab:fromData TemperatureMessageAmbient
    DTDFVocab:inputTo RabbitMQBrokerEnabler, SciPyCalibrationEnabler, BangBangControllerEnabler
]

instance CalibratedParametersData : DTDFVocab:Data [
    base:desc "Set of calibrated model parameters (G_box, C_air, C_heater, G_heater) produced by SciPyCalibrationEnabler"
    DTDFVocab:inputTo PredictionEngineEnabler
]

instance PredictedBoxTemperatureData : DTDFVocab:Data [
    base:desc "Predicted temperature trajectory of the incubator box generated by PredictionEngineEnabler"
    DTDFVocab:inputTo BangBangControllerEnabler
]

// ====================== Acting Components ======================
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed providing up to 100 W (≤4 A) surface heating for the incubator, switched via MOSFET on the custom PCB"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan delivering airflow ≥0.02 m³·s⁻¹ for air circulation inside the incubator, driven through MOSFET switching"
]

// ====================== Models ======================
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single thermal‑mass model with heat‑transfer parameter G_box representing the incubator box"
    DTDFVocab:inputTo PredictionEngineEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Two‑mass model with air and heatbed masses (C_air, C_heater) and conductances G_box, G_heater"
    DTDFVocab:inputTo PredictionEngineEnabler
]

// ====================== Enablers ======================
instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source RabbitMQ broker running on the Raspberry Pi, receives temperature messages from the low‑level driver and forwards them to DT services"
    DTDFVocab:enables RealTimeTemperatureMonitoringService
]

instance SciPyCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Python SciPy non‑linear least‑squares optimizer that calibrates thermal‑model parameters from temperature data"
    DTDFVocab:enables ParameterCalibrationService
]

instance PredictionEngineEnabler : DTDFVocab:Enabler [
    base:desc "Prediction engine that uses calibrated parameters together with Model A and Model B to simulate future box temperature"
    DTDFVocab:enables PredictiveTemperatureSimulationService
]

instance BangBangControllerEnabler : DTDFVocab:Enabler [
    base:desc "Bang‑bang controller with dwell times that issues heating or waiting commands based on lower/upper temperature limits"
    DTDFVocab:enables BangBangControlService
]

// ====================== Services ======================
instance RealTimeTemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Streams real‑time temperature data from the three sensors for operator monitoring"
    DTDFVocab:provides TemperatureLimitViolationInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Automatically calibrates Model A and Model B parameters using the SciPy optimizer on experimental temperature traces"
    DTDFVocab:provides CalibratedParametersInsight, ExecuteCalibrationAction
]

instance PredictiveTemperatureSimulationService : DTDFVocab:Service [
    base:desc "Runs predictive simulation of incubator box temperature employing calibrated Model A and Model B"
    DTDFVocab:provides PredictedBoxTemperatureInsight
]

instance BangBangControlService : DTDFVocab:Service [
    base:desc "Model‑based bang‑bang control that activates the heatbed for duration H when temperature  LL and activates a waiting period C when temperature  UL"
    DTDFVocab:provides ActivateHeatingAction, ActivateFanWaitingAction
]

// ====================== Insights ======================
instance TemperatureLimitViolationInsight : DTDFVocab:Insight [
    base:desc "Detects when measured temperature falls below the lower limit LL or exceeds the upper limit UL, flagging a safety violation for operator intervention"
]

instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Provides calibrated thermal‑model parameters (G_box, C_air, C_heater, G_heater) resulting from the SciPy optimization routine"
]

instance PredictedBoxTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicts future box temperature using the calibrated Model A or Model B"
]

// ====================== Actions ======================
instance ActivateHeatingAction : DTDFVocab:Action [
    base:desc "Turns on the heatbed via MOSFET switch for the configured dwell time H"
    DTDFVocab:IsAutomatic true
]

instance ActivateFanWaitingAction : DTDFVocab:Action [
    base:desc "Keeps the fan running (or idle) for waiting period C after temperature exceeds UL"
    DTDFVocab:IsAutomatic true
]

instance ExecuteCalibrationAction : DTDFVocab:Action [
    base:desc "Runs the SciPy calibration routine on collected temperature traces to update model parameters"
    DTDFVocab:IsAutomatic true
]

// ====================== Additional Physical Components ======================
instance RaspberryPiComponent : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B hosting the low‑level driver and the RabbitMQ broker"
]

instance PCBComponent : DTDFVocab:Component [
    base:desc "Custom PCB containing MOSFET switches and optocouplers for power isolation of heatbed and fan"
]

// ====================== Environment ======================
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains DS18S20BoxSensor1, DS18S20BoxSensor2, DS18S20AmbientSensor,
                HeatbedActuator, FanActuator,
                RaspberryPiComponent, PCBComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands to the RabbitMQ server; the Raspberry Pi controller subscribes to these messages, interprets them, and drives the MOSFETs to turn the heatbed and fan on or off, thereby affecting the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture comprises the physical components (container, heatbed, fan, sensors, PCB, Raspberry Pi), a low‑level driver that reads sensors and publishes data, a RabbitMQ message broker mediating all PT↔DT messages, a controller module that subscribes to commands and implements the bang‑bang strategy, calibrated thermal models (Model A/B) used for simulation and prediction, and monitoring modules that evaluate safety constraints."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validity was examined through two experiments: (1) uniform temperature verification by comparing sensors at different locations with varied fan voltages (12 V vs 18 V) showing max temperature deviation of 7 °C and 6 °C respectively; (2) calibration using least‑squares fitting to minimise residual error between model output and measured data. Assumptions such as uniform air temperature, negligible wall heat storage, constant air specific heat, and ignored fan heat were explicitly stated and tested."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange between PT and DT is performed via a RabbitMQ message broker running on the Raspberry Pi, using standard AMQP messaging (implicit in RabbitMQ). The Raspberry Pi provides Wi‑Fi and Bluetooth connectivity for network access."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT components (RabbitMQ server, low‑level driver, controller, and calibration scripts) are hosted on the Raspberry Pi 4 Model B, which runs the full software stack. Source code and hardware schematics are publicly available in the GitHub repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the PT in a safe state during communication failures. The DT includes monitors that check temperature limits and can trigger safety alerts. Actuation signals are isolated via MOSFETs and optocouplers to prevent electrical hazards. No explicit cybersecurity standards are mentioned."
]