// C3: Physical sensing components
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor located inside the incubator box."
    DTDFVocab:producedData InternalTempDataTransmittedA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Second internal temperature sensor located inside the incubator box."
    DTDFVocab:producedData InternalTempDataTransmittedB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor located outside the incubator container."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Physical-to-virtual interaction
instance InternalTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// C10: Data
instance InternalTemperatureDataA : DTDFVocab:Data [
    base:desc "Time‑series temperature data streamed from InternalTempSensorA."
    DTDFVocab:fromData InternalTempDataTransmittedA
    DTDFVocab:inputTo CalibrationEngine, RuntimeMonitorEngine
]

instance InternalTemperatureDataB : DTDFVocab:Data [
    base:desc "Time‑series temperature data streamed from InternalTempSensorB."
    DTDFVocab:fromData InternalTempDataTransmittedB
    DTDFVocab:inputTo CalibrationEngine, RuntimeMonitorEngine
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series temperature data streamed from ExternalTempSensor."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo CalibrationEngine, RuntimeMonitorEngine
]

// C10: Models/Data
instance SimpleThermalModel : DTDFVocab:Model [
    base:desc "Simplified analytical thermal model of the incubator with two free parameters."
    DTDFVocab:inputTo CalibrationEngine, RuntimeMonitorEngine
]

instance DetailedThermalModel : DTDFVocab:Model [
    base:desc "Detailed analytical thermal model of the incubator capturing the thermal inertia of the heat‑bed with four free parameters."
    DTDFVocab:inputTo CalibrationEngine, RuntimeMonitorEngine
]

// C11: Enablers
instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Calibration engine that runs estimation algorithms to update model parameters using the latest temperature data."
    DTDFVocab:enables CalibrationService
]

instance RuntimeMonitorEngine : DTDFVocab:Enabler [
    base:desc "Runtime monitoring engine that evaluates calibrated model outputs against safety and performance thresholds."
    DTDFVocab:enables SafetyMonitoringService, ContinuousMonitoringService
]

instance PredictiveSimulationEngine : DTDFVocab:Enabler [
    base:desc "Predictive simulation engine that reproduces and forecasts incubator thermal behaviour under current operating conditions."
    DTDFVocab:enables PredictiveSimulationService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Visualization engine that generates temperature trajectories and model predictions for engineers and operators."
    DTDFVocab:enables VisualizationService
]

instance ReconfigurationEngine : DTDFVocab:Enabler [
    base:desc "Reconfiguration engine that adapts the control strategy when the environment or payload changes."
    DTDFVocab:enables ReconfigurationService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that calibrates the thermal models using sensor data."
    DTDFVocab:provides TemperatureModelUpdateInsight
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Service that checks calibrated model outputs against safety temperature limits and raises alerts on violations."
    DTDFVocab:provides TemperatureSafetyAlertInsight, HeatingPowerAdjustmentAction
]

instance ContinuousMonitoringService : DTDFVocab:Service [
    base:desc "Service that continuously monitors temperature sensor streams and actuator states."
    DTDFVocab:provides TemperaturePerformanceInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Service that runs predictive simulations of the incubator's thermal behaviour."
    DTDFVocab:provides PredictedTemperatureInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that visualizes temperature trajectories and model predictions."
    DTDFVocab:provides VisualizationInsight
]

instance ReconfigurationService : DTDFVocab:Service [
    base:desc "Service that reconfigures control parameters to accommodate new conditions."
    DTDFVocab:provides ReconfigurationInsight
]

// C17: Insights
instance TemperatureSafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when temperature exceeds safety limits, indicating a safety violation."
]

instance TemperaturePerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight about ongoing temperature performance relative to the target set‑point."
]

instance TemperatureModelUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight that model parameters have been updated after calibration."
]

instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Forecasted temperature trajectory produced by the predictive simulation engine."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of temperature data and model predictions for operators."
]

instance ReconfigurationInsight : DTDFVocab:Insight [
    base:desc "Information that the control strategy has been reconfigured to match new environmental or payload conditions."
]

// C17: Actions
instance HeatingPowerAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of heat‑bed power to bring temperature back within safe limits."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin can influence the Physical Twin when a monitor detects a safety or performance violation; it may issue control actions (e.g., adjust heat‑bed power or fan speed) through the Raspberry Pi to the actuators. The documents do not specify command formats, validation, or acknowledgement mechanisms."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by experimentally comparing the two temperature prediction models against measured incubator temperatures; the four‑parameter model showed higher fidelity in reproducing the heat‑bed’s thermal inertia. Validation is performed through these experiments, and calibration algorithms continuously update model parameters to minimize prediction error. Sources of uncertainty include the free model parameters and sensor measurement noise, which are quantified and corrected via calibration. Ongoing quality assurance is maintained by the monitoring loop described in Document 1."
]