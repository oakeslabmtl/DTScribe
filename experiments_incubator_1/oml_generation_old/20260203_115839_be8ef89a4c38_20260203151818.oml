// C3: Physical sensing component
instance TemperatureSensorRaspberryPi : DTDFVocab:SensingComponent [
    base:desc "Low‑level driver on a Raspberry Pi reading raw temperature sensor values"
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Physical‑to‑virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorRaspberryPi
    base:desc "Raw temperature sensor values uploaded to the local communication server via RabbitMQ"
]

// C10: Models/Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Continuous, time‑stamped temperature measurements collected from the physical twin"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo RabbitMQBrokerEnabler,
               CalibrationAlgorithmEnabler,
               MonitoringAlgorithmEnabler,
               SupervisoryAlgorithmEnabler,
               OptimisationAlgorithmEnabler
]

// C11: Enablers
instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ broker used to transmit sensor payloads over Wi‑Fi/local area network"
    DTDFVocab:enables DataIngestionService
]

instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that updates model parameters based on the latest sensor data"
    DTDFVocab:enables CalibrationService
]

instance MonitoringAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring algorithm that continuously assesses safety and performance constraints"
    DTDFVocab:enables MonitoringService
]

instance SupervisoryAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Supervisory controller algorithm that decides on system adjustments"
    DTDFVocab:enables DecisionMakingService
]

instance OptimisationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Optimization algorithm that produces optimal operational strategies"
    DTDFVocab:enables OptimisationService
]

// C6: Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Consumes sensor payloads from the RabbitMQ queue and stores them for DT use"
    DTDFVocab:provides DataIngestionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Updates cyber‑physical and environmental models with calibrated parameters"
    DTDFVocab:provides UpdatedModelInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Checks for safety and optimality violations; triggers decision‑making processes"
    DTDFVocab:provides ViolationDetectedInsight
]

instance DecisionMakingService : DTDFVocab:Service [
    base:desc "Triggers automated controllers or human operators based on insights"
    DTDFVocab:provides ControlAction
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Generates optimal operational decisions for the system"
    DTDFVocab:provides OptimisationAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Provides simulation and predictive capabilities to reproduce the physical twin’s behavior"
    DTDFVocab:provides PredictiveInsight
]

// C17: Insights and Actions
instance DataIngestionInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data has been received via RabbitMQ"
]

instance UpdatedModelInsight : DTDFVocab:Insight [
    base:desc "Model parameters have been updated based on calibration algorithm"
]

instance ViolationDetectedInsight : DTDFVocab:Insight [
    base:desc "Safety or performance constraints have been violated"
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Automated controller action resulting from supervisory decision"
    DTDFVocab:IsAutomatic true
]

instance OptimisationAction : DTDFVocab:Action [
    base:desc "Optimal operational strategy determined by optimisation algorithm"
    DTDFVocab:IsAutomatic true
]

instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Predicted future behavior of the physical twin under current operating conditions"
]

// C18: Environment
instance RaspberryPiEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensorRaspberryPi
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the digital twin domain. Commands that enable the fan or heatbed are issued via RabbitMQ to the controller process running on the Raspberry Pi, which then transmits the actual actuator signals to the hardware through its GPIO interfaces. The system does not define explicit command format schemas or authentication mechanisms; commands are accepted by the controller when they match the predetermined messaging convention. Feedback on command execution is implicit—humans, or an external supervisor may decide to intervene when a safety violation is detected, prompting a change to the physical twin."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system adopts a modular, loosely‑coupled architecture centered on message‑oriented middleware (RabbitMQ). The core consists of a controller that encodes physical‑plant operations, a low‑level driver that interfaces directly with the incubator hardware, and a communication server that publishes and subscribes to state messages. Messages propagate bidirectionally: sensor readings and actuator commands flow from the Physical Twin to the Digital Twin via the driver, while simulation data, calibration updates, and control decisions flow back to the controller through the DT. This architecture aligns with publish/subscribe patterns, enabling scalable orchestration and resource management while ensuring real‑time feedback cycles."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical network relies on a RabbitMQ broker running locally on the Raspberry Pi, communicating over a Wi‑Fi or Bluetooth interface. The network topology is a simple client‑server model where the digital twin components act as publishers/subscribers to the broker. Bandwidth and latency tolerances are not quantitatively specified in the documents, but the use of Wi‑Fi and the local broker indicates an operation under standard LAN constraints (~Mbps bandwidth, <10 ms latency). No redundancy or explicit security protocols beyond the default RabbitMQ configuration are documented."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment occurs on an edge Raspberry Pi device that hosts the RabbitMQ broker, the sensor driver, and the control application. The hosting platform is on‑premise edge hardware with modest CPU and memory resources suitable for lightweight message‑passing workloads. No explicit scalability, multi‑site deployment, or high‑availability strategies are described in the documents."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin employs continuous safety monitoring that ingests time‑stamped sensor data from the Physical Twin. Calibration engines update model parameters in real time, and supervisory controllers enforce operational constraints derived from safety-critical analysis. When sensor readings exceed predefined safety bounds, the monitor triggers a fail‑safe protocol that can, for example, gracefully shutdown affected actuators or switch to redundant pathways. This protocol is embedded in the low‑level driver (as noted in the referenced section 2.2.2), ensuring the CPS remains in a safe state even under fault conditions. While explicit cybersecurity hardening details are not enumerated in the document, the integration of safety monitors and calibrated constraints demonstrates a safety‑critical design approach that mitigates runtime risks."
]