// ====================
// C3: Physical sensing components
// ====================

instance IncubatorBoxTempSensorInside1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor located inside the incubator box"
    DTDFVocab:producedData TemperatureReadingBoxInside1
]

instance IncubatorBoxTempSensorInside2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor located inside the incubator box (second unit)"
    DTDFVocab:producedData TemperatureReadingBoxInside2
]

instance AmbientRoomTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor measuring ambient room temperature"
    DTDFVocab:producedData TemperatureReadingAmbient
]

// ====================
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// ====================

instance TemperatureReadingBoxInside1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorBoxTempSensorInside1
]

instance TemperatureReadingBoxInside2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorBoxTempSensorInside2
]

instance TemperatureReadingAmbient : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientRoomTempSensor
]

// ====================
// C10: Data
// ====================

instance TemperatureDataBoxInside1 : DTDFVocab:Data [
    base:desc "Time‑series temperature data from the first inside‑box DS18S20 sensor"
    DTDFVocab:fromData TemperatureReadingBoxInside1
    DTDFVocab:inputTo RabbitMQBroker
]

instance TemperatureDataBoxInside2 : DTDFVocab:Data [
    base:desc "Time‑series temperature data from the second inside‑box DS18S20 sensor"
    DTDFVocab:fromData TemperatureReadingBoxInside2
    DTDFVocab:inputTo RabbitMQBroker
]

instance TemperatureDataAmbient : DTDFVocab:Data [
    base:desc "Time‑series temperature data from the ambient room DS18S20 sensor"
    DTDFVocab:fromData TemperatureReadingAmbient
    DTDFVocab:inputTo RabbitMQBroker
]

// ====================
// C11: Enablers
// ====================

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on the Raspberry Pi, transports sensor readings to the Digital Twin"
    DTDFVocab:enables RealTimeMonitoringService
]

instance PythonControlLogic : DTDFVocab:Enabler [
    base:desc "Python control software on the Raspberry Pi executing simulations and calibrations"
    DTDFVocab:enables SimulationServiceModelA, SimulationServiceModelB, ParameterOptimizationService
]

instance SciPyOptimizer : DTDFVocab:Enabler [
    base:desc "SciPy optimisation library used for non‑linear least‑squares calibration of model parameters"
    DTDFVocab:enables ParameterOptimizationService
]

// ====================
// C6: Services
// ====================

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature against configured upper and lower limits"
    DTDFVocab:provides TemperatureOutOfBoundsInsight
]

instance SimulationServiceModelA : DTDFVocab:Service [
    base:desc "Simulation of incubator temperature using calibrated Model A"
    DTDFVocab:provides OptimalHeatingAction
]

instance SimulationServiceModelB : DTDFVocab:Service [
    base:desc "Simulation of incubator temperature using calibrated Model B"
    DTDFVocab:provides OptimalHeatingAction
]

instance ParameterOptimizationService : DTDFVocab:Service [
    base:desc "Parameter optimisation via non‑linear least‑squares using SciPy"
    DTDFVocab:provides CalibratedParametersInsight
]

// ====================
// C17: Insights / Actions
// ====================

instance TemperatureOutOfBoundsInsight : DTDFVocab:Insight [
    base:desc "Alert when temperature exceeds defined upper or lower limits"
]

instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Calibrated thermal model parameters (C_air, G_box, C_heater, G_heater) produced by the Digital Twin"
]

instance OptimalHeatingAction : DTDFVocab:Action [
    base:desc "Determines optimal heating (H) and waiting (C) durations for the bang‑bang controller"
    DTDFVocab:IsAutomatic true
]

// ====================
// C2: Acting components
// ====================

instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed heating element (~4 A) driven by MOSFET switches on the custom PCB"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal circulation fan (~2 s air exchange) driven by MOSFET switches on the custom PCB"
]

// ====================
// Additional Actions for actuators
// ====================

instance ActivateHeatBed : DTDFVocab:Action [
    base:desc "Command to turn the heat‑bed on or off"
    DTDFVocab:IsAutomatic true
]

instance ActivateFan : DTDFVocab:Action [
    base:desc "Command to set the fan speed (on/off)"
    DTDFVocab:IsAutomatic true
]

// ====================
// C12: Models
// ====================

instance ThermalModelA : DTDFVocab:Model [
    base:desc "Physics‑based thermal Model A with air heat capacity C_air and box heat‑transfer coefficient G_box"
    DTDFVocab:inputTo PythonControlLogic
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Physics‑based thermal Model B adding heater capacity C_heater and heater heat‑transfer coefficient G_heater"
    DTDFVocab:inputTo PythonControlLogic
]

// ====================
// C9: Environment and physical components
// ====================

instance IncubatorBoxComponent : DTDFVocab:Component [
    base:desc "Polystyrene insulated box (~0.03 m³) housing the heat‑bed and fan"
]

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains IncubatorBoxComponent, HeatBedActuator, FanActuator,
                 IncubatorBoxTempSensorInside1, IncubatorBoxTempSensorInside2, AmbientRoomTempSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (heat‑bed ON/OFF, fan ON/OFF, heating duration, waiting duration) are generated by the digital twin logic and sent as RabbitMQ messages to the controller, which forwards them via the low‑level driver to the MOSFET drivers on the PCB."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture consists of the physical incubator (PT), a low‑level driver on the Pi interfacing sensors and actuators, a RabbitMQ communication server linking the PT to the digital twin, and DT components (model simulator, calibrator, monitor) that subscribe to the broker. The DT can run on the same Pi or on external machines connected to the broker."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing simulated temperature trajectories with measured data from uniform‑temperature experiments. Assumptions (uniform air temperature, negligible wall heat accumulation, constant air specific heat, neglect of fan heat) are explicitly listed, and Model B relaxes the assumption that the heat‑bed does not store heat. Calibration residuals are minimised to ensure validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual and virtual‑to‑physical communication is realized through a RabbitMQ message broker running on the Raspberry Pi. Messages are exchanged over the local network using the Pi's built‑in Wi‑Fi, following RabbitMQ's standard messaging protocol. The low‑level driver publishes sensor readings, and the controller subscribes to command messages, both via RabbitMQ."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ server and controller software are deployed directly on the Raspberry Pi 4. DT computational components (simulation, calibration, monitoring) can be hosted on the same Pi or on external computers that connect to the Pi’s RabbitMQ broker."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safety protocol that forces the PT into a safe state (e.g., turning off heater/fan) if abnormal conditions are detected, providing basic safety guarantees for remote actuation."
]