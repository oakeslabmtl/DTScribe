// Sensing component
instance DS18S20TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer placed inside the thermal incubator to measure the internal temperature."
    DTDFVocab:producedData TempDataTransmitted
]

// Data transmitted by the sensor
instance TempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20TemperatureSensor
]

// Real‑time temperature data
instance RealTimeTemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature data collected from DS18S20TemperatureSensor inside the incubator."
    DTDFVocab:fromData TempDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, DataAcquisitionEnabler
]

// Thermal dynamics model of the incubator
instance ThermalDynamicModel : DTDFVocab:Model [
    base:desc "Thermal dynamics model representing heat transfer in the insulated incubator box, heating element behavior, and fan cooling effect."
    DTDFVocab:inputTo CalibrationEnabler
]

// Enablers
instance DataAcquisitionEnabler : DTDFVocab:Enabler [
    base:desc "Collects real‑time sensor data streams and exposes them to downstream services."
    DTDFVocab:enables ContinuousMonitoringService, OptimizationService, SupervisoryControlService
]
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Updates the ThermalDynamicModel parameters using real‑time sensor data."
    DTDFVocab:enables PredictiveSimulationService
]

// Insights
instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring of the incubator temperature to ensure it stays within specified limits."
]
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive simulation output estimating future temperature trend inside the incubator."
]
instance PerformanceOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization guidance to adjust control actions for improved temperature maintenance efficiency."
]
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Fault detection algorithm output identifying anomalous temperature behavior or hardware failure."
]

// Actions
instance AdjustHeatingElementAction : DTDFVocab:Action [
    base:desc "Modify heating element power output to compensate for temperature deviations."
    DTDFVocab:IsAutomatic true
]
instance ShutdownHeatingElementAction : DTDFVocab:Action [
    base:desc "Immediately shut down the heating element in response to critical fault."
    DTDFVocab:IsAutomatic true
]

// Services
instance ContinuousMonitoringService : DTDFVocab:Service [
    base:desc "Continuous real‑time monitoring of sensor streams to assess safety and performance."
    DTDFVocab:provides TemperatureMonitoringInsight
]
instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation service reproducing incubator behavior using calibrated thermal model."
    DTDFVocab:provides TemperaturePredictionInsight
]
instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service adjusting model parameters and control actions to improve performance."
    DTDFVocab:provides PerformanceOptimizationInsight
]
instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Supervisory control that detects anomalies and triggers corrective actions in conjunction with human operators."
    DTDFVocab:provides FaultDetectionInsight, AdjustHeatingElementAction, ShutdownHeatingElementAction
]

// Components
instance HeatBed : DTDFVocab:Component [
    base:desc "Heating element (heatbed) inside the insulated incubator box."
]
instance CirculatingFan : DTDFVocab:Component [
    base:desc "Fan circulating air to enhance thermal uniformity within the incubator."
]
instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B controller running control algorithms defined in the digital twin."
]
instance MOSFETPCB : DTDFVocab:Component [
    base:desc "Printed circuit board with MOSFETs and optocouplers driving the heating element."
]
instance PowerSupply : DTDFVocab:Component [
    base:desc "Power supply unit providing voltage to the Raspberry Pi controller, MOSFET PCB, and heating element."
]

// Environment
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBed, CirculatingFan, DS18S20TemperatureSensor, RaspberryPiController, MOSFETPCB, PowerSupply
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central architecture that orchestrates data acquisition from the physical twin via sensors, applies calibration algorithms to update the models of the cyber‑physical system and its environment, and forwards the calibrated data to monitors that assess safety and optimal performance. This pattern layers data collection, model calibration, simulation, and monitoring, enabling continuous value generation by integrating modelling, simulation, monitoring, and optimisation technologies."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is upheld through calibration algorithms that incorporate real‑time sensor data to refine parameter estimates of the CPS and environmental models, ensuring the digital twin reflects observed physical behaviour. Operational monitors continuously evaluate safety and performance metrics; detected violations trigger alerts and may lead to corrective actions in the physical twin. Although specific validation, error‑correction, and quality assurance processes are not detailed in the document, the described calibration and monitoring loops provide a foundational framework for assessing and preserving model fidelity and data integrity."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin framework incorporates safety‑monitoring components that continuously compare real‑time sensor data with model‑based predictions to determine whether the physical system is operating safely and optimally. When the monitors detect a safety or performance violation, they trigger alert mechanisms that allow either human operators or autonomous decision‑making algorithms to intervene and adjust the physical twin. Fault‑detection algorithms, among other diagnostic tools, are included as part of the safety validation process. "
]