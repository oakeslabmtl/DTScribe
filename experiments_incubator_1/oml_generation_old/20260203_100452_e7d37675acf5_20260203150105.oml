// Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor attached to the physical twin, collecting in‑situ ambient temperature data during operation."
    DTDFVocab:producedData TemperatureDataTrans
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Pressure sensor attached to the physical twin, measuring system pressure in real time."
    DTDFVocab:producedData PressureDataTrans
]

// Data Transmitted by Sensors
instance TemperatureDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

// Time‑Series Data Streams
instance TemperatureTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series stream of temperature measurements gathered directly from the PT‑attached temperature sensor."
    DTDFVocab:inputTo CalibrationEngine, MonitoringEngine
    DTDFVocab:fromData TemperatureDataTrans
]

instance PressureTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series stream of pressure measurements captured by the PT‑attached pressure sensor."
    DTDFVocab:inputTo CalibrationEngine, MonitoringEngine
    DTDFVocab:fromData PressureDataTrans
]

// Physical Models
instance GeometricModel : DTDFVocab:Model [
    base:desc "Geometric representation of the PT’s structure used for visualization and structural analysis."
    DTDFVocab:inputTo CalibrationEngine
]

instance BehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model describing the PT’s dynamic response to operational inputs."
    DTDFVocab:inputTo CalibrationEngine, MonitoringEngine
]

instance AnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model capturing physical laws governing the PT, including heat transfer and fluid dynamics."
    DTDFVocab:inputTo CalibrationEngine, MonitoringEngine
]

// Enablers
instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Calibration engine continuously adjusts model parameters using sensor data to maintain model relevance."
    DTDFVocab:enables CalibrationService
]

instance MonitoringEngine : DTDFVocab:Enabler [
    base:desc "Monitoring engine analyzes updated models and data streams to detect performance deviations."
    DTDFVocab:enables MonitoringService
]

// Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that applies parameter adjustments to models based on calibration insights."
    DTDFVocab:provides ModelParameterAdjustmentInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors PT performance, identifies deviations, and triggers safety actions."
    DTDFVocab:provides PerformanceDeviationInsight, SafetyThresholdViolationInsight, AutomatedShutdownAction, ManualInterventionAction
]

// Insights
instance ModelParameterAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Insight indicating necessary changes to model parameters derived from calibration."
]

instance PerformanceDeviationInsight : DTDFVocab:Insight [
    base:desc "Insight highlighting observed deviations between model predictions and live sensor data."
]

instance SafetyThresholdViolationInsight : DTDFVocab:Insight [
    base:desc "Insight signaling that safety thresholds have been breached, requiring intervention."
]

// Actions
instance AutomatedShutdownAction : DTDFVocab:Action [
    base:desc "Automatic action to shut down the PT when safety thresholds are violated."
    DTDFVocab:IsAutomatic true
]

instance ManualInterventionAction : DTDFVocab:Action [
    base:desc "Action indicating that a human operator must intervene after a fault is detected."
    DTDFVocab:IsAutomatic false
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by ongoing calibration against real‑time sensor data; validation relies on the DT’s monitoring components that compare model predictions with actual PT measurements, flagging deviations that exceed safety or performance thresholds. Although the document does not specify quantitative verification metrics or formal uncertainty quantification, it implies that error detection occurs through violation detection in monitors, with corrective actions taken either automatically by algorithms or by human operators. Quality assurance is therefore achieved through this continuous observation–correction cycle, ensuring that models remain accurate and trustworthy over the PT’s lifecycle."
]