namespace base = "http://www.w3.org/2000/01/rdf-schema#"
namespace DTDFVocab = "http://example.com/DTDFVocab"
instance WheelsComponent : DTDFVocab:Component [
    base:desc "Automobile wheel component for movement and load bearing"
]
instance ChassisComponent : DTDFVocab:Component [
    base:desc "Automobile chassis structure providing structural integrity"
]
instance BodyStructureComponent : DTDFVocab:Component [
    base:desc "Automobile body structure for aerodynamics and passenger protection"
]
instance HeatbedActuator : DTDFVocab:Component [
    base:desc "Thermal regulation component for adjusting heatbed temperature within specified operational ranges"
]
instance FanActuator : DTDFVocab:Component [
    base:desc "Airflow distribution component for thermal management"
]
instance ControllerInterface : DTDFVocab:Component [
    base:desc "Interface component receiving instructions from Digital Twin to adjust actuator parameters"
]
instance AutomobileSystem : DTDFVocab:Environment [
    base:desc "Automobile system with wheels, chassis, and body structure for mechanical dynamics and vehicle movement",
    base:contains WheelsComponent, ChassisComponent, BodyStructureComponent, HeatbedActuator, FanActuator, ControllerInterface
]
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 High-Precision 1-Wire Digital Thermometer monitoring internal temperature within the enclosure (accuracy ±0.5°C)",
    DTDFVocab:producedData InternalTempData1Transmitted
]
instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 High-Precision 1-Wire Digital Thermometer monitoring internal temperature within the enclosure (accuracy ±0.5°C)",
    DTDFVocab:producedData InternalTempData2Transmitted
]
instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor for ambient conditions",
    DTDFVocab:producedData ExternalTempDataTransmitted
]
instance InternalTempData1Transmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]
instance InternalTempData2Transmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]
instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]
instance SafetyMonitorInsight : DTDFVocab:Insight [
    base:desc "Real-time safety status based on sensor data and model analysis"
]
instance PerformanceMonitorInsight : DTDFVocab:Insight [
    base:desc "System performance metrics for operational optimality"
]
instance FaultDetectedInsight : DTDFVocab:Insight [
    base:desc "Detection of system faults indicating potential failures"
]
instance StateEstimateInsight : DTDFVocab:Insight [
    base:desc "Estimated current state of the physical twin system"
]
instance PredictiveSimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulated behavior of physical twin under current operating conditions"
]
instance OptimizedParametersAction : DTDFVocab:Action [
    base:desc "Automated adjustment of system parameters for optimal performance",
    DTDFVocab:IsAutomatic true
]
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of system safety and optimality using sensor data and models",
    DTDFVocab:provides SafetyMonitorInsight, PerformanceMonitorInsight
]
instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detection of system faults through analysis of sensor data and model deviations",
    DTDFVocab:provides FaultDetectedInsight
]
instance StateEstimationService : DTDFVocab:Service [
    base:desc "Estimation of current system state using sensor data and dynamic models",
    DTDFVocab:provides StateEstimateInsight
]
instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization of system parameters for peak performance and efficiency",
    DTDFVocab:provides OptimizedParametersAction
]
instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Simulation of physical twin behavior under various operating conditions",
    DTDFVocab:provides PredictiveSimulationResultInsight
]
instance RabbitMQ : DTDFVocab:Enabler [
    base:desc "Message broker facilitating real-time data exchange between physical sensors and Digital Twin components",
    DTDFVocab:enables MonitoringService, FaultDetectionService, StateEstimationService
]
instance RaspberryPi : DTDFVocab:Enabler [
    base:desc "Hardware platform for sensor data acquisition and actuator command execution",
    DTDFVocab:enables MonitoringService, OptimizationService
]
instance ScipyEnabler : DTDFVocab:Enabler [
    base:desc "Python Scipy library for parameter optimization and calibration algorithms",
    DTDFVocab:enables OptimizationService, StateEstimationService
]
instance InternalTempData1 : DTDFVocab:Data [
    base:desc "Real-time temperature data from first internal DS18S20 sensor",
    DTDFVocab:fromData InternalTempData1Transmitted,
    DTDFVocab:inputTo ScipyEnabler
]
instance InternalTempData2 : DTDFVocab:Data [
    base:desc "Real-time temperature data from second internal DS18S20 sensor",
    DTDFVocab:fromData InternalTempData2Transmitted,
    DTDFVocab:inputTo ScipyEnabler
]
instance ExternalTempData : DTDFVocab:Data [
    base:desc "Real-time ambient temperature data from external sensor",
    DTDFVocab:fromData ExternalTempDataTransmitted,
    DTDFVocab:inputTo ScipyEnabler
]
instance StructuralModel : DTDFVocab:Model [
    base:desc "Geometric CAD model representing structural properties of automobile chassis and body structure",
    DTDFVocab:inputTo ScipyEnabler
]
instance DynamicModel : DTDFVocab:Model [
    base:desc "Analytical model defined by differential equations for force and movement analysis",
    DTDFVocab:inputTo ScipyEnabler
]
instance CalibrationAlgorithm : DTDFVocab:Model [
    base:desc "Algorithm for updating model parameters using sensor data and calibration techniques",
    DTDFVocab:inputTo ScipyEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Raspberry Pi controller subscribes to RabbitMQ for fan and heatbed control commands, executing actions such as issuing a heating signal to activate the heatbed upon receipt."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "RabbitMQ server was deployed for synchronization and communication between physical and digital components; the low-level driver periodically reads temperature data from the physical twin. Specific synchronization intervals and latency requirements are not specified."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The software setup includes a controller, a low-level driver, and a communication server (RabbitMQ), with Figure 7 illustrating the communication flow between these components and the physical incubator system for real-time monitoring and control."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Calibration algorithms update cyber-physical system models with parameter estimates derived from sensor data to minimize residual error, while monitoring systems validate safety and optimality against predefined criteria, triggering human or algorithmic interventions upon violation detection."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "RabbitMQ handles synchronization and communication, with sensors connected via 1-Wire bus and Raspberry Pi utilizing built-in Wi-Fi and Bluetooth for network connectivity."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The system is deployed on a Raspberry Pi 4 Model B edge device, hosting both the RabbitMQ server and controller software."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Real-time monitoring mechanisms within the Digital Twin assess the Physical Twin's safety compliance and operational optimality; upon detection of safety violations, corrective actions are initiated by human operators or autonomous algorithms to modify the Physical Twin's state."
]