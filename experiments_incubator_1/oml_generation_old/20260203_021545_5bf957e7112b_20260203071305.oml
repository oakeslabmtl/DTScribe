// ------------------------------------------------------------
// Environment and Physical Components
// ------------------------------------------------------------
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains PolystyreneContainer, ResistiveHeatbed, InternalFan,
                 RaspberryPiController, CustomPCBCircuit, DCPowerSupply
]

instance PolystyreneContainer : DTDFVocab:Component [
    base:desc "Polystyrene (styrofoam) insulated container with volume ~0.03 m³."
]

instance ResistiveHeatbed : DTDFVocab:Component [
    base:desc "Resistive heatbed delivering ≥100 W of heating power, on/off controllable."
]

instance InternalFan : DTDFVocab:Component [
    base:desc "Internal fan providing ~0.02 m³·s⁻¹ airflow, powered at 12 V/24 V, on/off controllable."
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running low‑level driver, controller code and RabbitMQ broker."
]

instance CustomPCBCircuit : DTDFVocab:Component [
    base:desc "Custom PCB with MOSFET drivers and optocouplers for heatbed and fan actuation."
]

instance DCPowerSupply : DTDFVocab:Component [
    base:desc "DC power supply providing the required voltage and current for heatbed and fan."
]

// ------------------------------------------------------------
// Acting Components (Actuators)
// ------------------------------------------------------------
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed actuator (on/off switch) delivering ≥100 W, driven via MOSFET on the PCB."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan actuator (on/off) with ~0.02 m³·s⁻¹ airflow, driven via MOSFET on the PCB at 12 V or 24 V."
]

// ------------------------------------------------------------
// Sensing Components
// ------------------------------------------------------------
instance InsideTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer mounted inside the incubator to measure air temperature (range –55 °C to +125 °C, accuracy ±0.5 °C from 10 °C to 85 °C)."
    DTDFVocab:producedData InsideTempDataTransmitted1
]

instance InsideTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 1‑Wire digital thermometer mounted inside the incubator to measure air temperature (same specifications as InsideTempSensor1)."
    DTDFVocab:producedData InsideTempDataTransmitted2
]

instance OutsideTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer mounted outside the incubator to measure ambient room temperature (range –55 °C to +125 °C, accuracy ±0.5 °C from 10 °C to 85 °C)."
    DTDFVocab:producedData OutsideTempDataTransmitted
]

instance PowerSupplyMonitor : DTDFVocab:SensingComponent [
    base:desc "Monitoring component that measures DC power‑supply voltage and current used by the heatbed and fan."
    DTDFVocab:producedData PowerMeasurementDataTransmitted
]

// ------------------------------------------------------------
// Data Transmitted Instances
// ------------------------------------------------------------
instance InsideTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensor1
]

instance InsideTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensor2
]

instance OutsideTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideTempSensor
]

instance PowerMeasurementDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerSupplyMonitor
]

// ------------------------------------------------------------
// Data Instances
// ------------------------------------------------------------
instance InsideTemperatureData1 : DTDFVocab:Data [
    base:desc "Air temperature stream from InsideTempSensor1."
    DTDFVocab:fromData InsideTempDataTransmitted1
    DTDFVocab:inputTo LowLevelDriverEnabler, SimulationEnabler
]

instance InsideTemperatureData2 : DTDFVocab:Data [
    base:desc "Air temperature stream from InsideTempSensor2."
    DTDFVocab:fromData InsideTempDataTransmitted2
    DTDFVocab:inputTo LowLevelDriverEnabler, SimulationEnabler
]

instance OutsideTemperatureData : DTDFVocab:Data [
    base:desc "Ambient room temperature stream from OutsideTempSensor."
    DTDFVocab:fromData OutsideTempDataTransmitted
    DTDFVocab:inputTo LowLevelDriverEnabler, SimulationEnabler
]

instance PowerMeasurementData : DTDFVocab:Data [
    base:desc "Voltage and current measurements of the DC power supply."
    DTDFVocab:fromData PowerMeasurementDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler
]

// ------------------------------------------------------------
// Enablers (Tools & Infrastructure)
// ------------------------------------------------------------
instance LowLevelDriverEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level driver on the Raspberry Pi that reads DS18S20 sensors and publishes AMQP messages via RabbitMQ."
    DTDFVocab:enables RealTimeMonitoringService
]

instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker running on the Raspberry Pi for exchange of sensor data and actuator state messages."
    DTDFVocab:enables RealTimeMonitoringService, CalibrationService, SimulationService, PredictiveForecastingService, SafetyViolationDetectionService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Python SciPy non‑linear least‑squares optimizer used for automatic calibration of thermal model parameters."
    DTDFVocab:enables CalibrationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine executing physics‑based thermal models (Model A and Model B) for incubator air temperature."
    DTDFVocab:enables SimulationService, PredictiveForecastingService, SafetyViolationDetectionService
]

instance SafetyEnabler : DTDFVocab:Enabler [
    base:desc "Safety engine evaluating temperature against predefined limits and generating violation alerts."
    DTDFVocab:enables SafetyViolationDetectionService
]

// ------------------------------------------------------------
// Models
// ------------------------------------------------------------
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Physics‑based thermal model A with parameters C_air and G_box describing heat transfer between heatbed, air and environment."
    DTDFVocab:inputTo SimulationEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Physics‑based thermal model B extending Model A with additional heat capacity C_heater and conductance G_heater."
    DTDFVocab:inputTo SimulationEnabler
]

// ------------------------------------------------------------
// Services
// ------------------------------------------------------------
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time temperature monitoring from sensor streams."
    DTDFVocab:provides CurrentTemperatureInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Automatically calibrates thermal model parameters using non‑linear least‑squares optimisation."
    DTDFVocab:provides CalibratedParametersInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Executes Model A and Model B to simulate box air temperature."
    DTDFVocab:provides TemperatureTrajectoryInsight
]

instance PredictiveForecastingService : DTDFVocab:Service [
    base:desc "Predicts future temperature trajectories for set‑point control."
    DTDFVocab:provides ForecastedTemperatureInsight
]

instance SafetyViolationDetectionService : DTDFVocab:Service [
    base:desc "Detects safety violations when temperature exceeds predefined thresholds."
    DTDFVocab:provides ViolationAlertInsight, AdjustHeatingAction
]

// ------------------------------------------------------------
// Insights
// ------------------------------------------------------------
instance CurrentTemperatureInsight : DTDFVocab:Insight [
    base:desc "Current air temperature inside the incubator as measured by the sensors."
]

instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Calibrated values for model parameters C_air, G_box (and C_heater, G_heater for Model B)."
]

instance TemperatureTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Simulated and measured temperature trajectories of the incubator air."
]

instance ForecastedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted future temperature trajectory over the forecasting horizon."
]

instance ViolationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating that the incubator temperature has violated safety limits."
]

// ------------------------------------------------------------
// Actions
// ------------------------------------------------------------
instance AdjustHeatingAction : DTDFVocab:Action [
    base:desc "Operator can adjust heating duration or set‑point based on violation alerts."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT components send control commands (heatbed ON/OFF, fan ON/OFF, heating duration, waiting duration) as AMQP messages to the RabbitMQ server; the controller on the Pi subscribes, interprets the commands and drives the MOSFET/optocoupler circuits to actuate the heatbed and fan."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A CPS‑based DT architecture where the physical incubator hardware is interfaced through a low‑level driver to a RabbitMQ server; the controller, DT model/calibration modules and monitoring services subscribe/publish to the broker, forming a loosely‑coupled constellation of cyber components that interact with the PT via the broker."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is examined by testing the uniform‑temperature assumption (fan on, temperature variance ≤7 °C) and by comparing Model A versus Model B; Model B is deemed more accurate because it accounts for heatbed thermal inertia. Calibration residuals are minimised using gradient‑descent optimisation, providing validated parameter values."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses the AMQP protocol over RabbitMQ running on the Raspberry Pi; messages are exchanged via the local network (Wi‑Fi or Ethernet) using standard TCP/IP."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ broker and the low‑level driver reside on the Raspberry Pi 4, which also hosts the controller; DT analytics (simulation, calibration) can run on the same device or on external machines that connect to the broker."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe‑protocol that forces the hardware into a defined safe state if communication fails; the controller performs safety monitoring of temperature limits (LL, UL) and can halt actuation on violation. No explicit cybersecurity standards are described."
]