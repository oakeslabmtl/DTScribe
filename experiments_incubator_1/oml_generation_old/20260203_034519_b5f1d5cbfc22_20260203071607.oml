// C3: Physical sensing components
instance InternalBedTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer mounted on the heat‑bed surface; range –55 °C to +125 °C, accuracy ±0.5 °C; polls at ~1 Hz on shared 1‑Wire bus."
    DTDFVocab:producedData InternalBedTempDataTransmitted
]

instance InternalAirTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer positioned in the incubator airspace; range –55 °C to +125 °C, accuracy ±0.5 °C; polls at ~1 Hz on shared 1‑Wire bus."
    DTDFVocab:producedData InternalAirTempDataTransmitted
]

instance ExternalAmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer placed outside the incubator to monitor ambient conditions; range –55 °C to +125 °C, accuracy ±0.5 °C; polls at ~1 Hz on shared 1‑Wire bus."
    DTDFVocab:producedData ExternalAmbientTempDataTransmitted
]

// C4: Physical‑to‑virtual interaction
instance InternalBedTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalBedTemperatureSensor
]

instance InternalAirTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalAirTemperatureSensor
]

instance ExternalAmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalAmbientTemperatureSensor
]

// C10: Data
instance InternalBedTemperatureData : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from heat‑bed sensor stored for calibration, validation and runtime monitoring."
    DTDFVocab:fromData InternalBedTempDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, OptimisationEnabler
]

instance InternalAirTemperatureData : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from internal air sensor stored for calibration, validation and runtime monitoring."
    DTDFVocab:fromData InternalAirTempDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, OptimisationEnabler
]

instance ExternalAmbientTemperatureData : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from external ambient sensor stored for environmental context."
    DTDFVocab:fromData ExternalAmbientTempDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, OptimisationEnabler
]

// C10: Models
instance ReducedTemperatureDynamicsModel : DTDFVocab:Model [
    base:desc "Reduced internal temperature dynamics model with two free parameters representing the incubator thermal response."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler
]

instance ExtendedTemperatureDynamicsModel : DTDFVocab:Model [
    base:desc "Extended internal temperature dynamics model with four free parameters capturing heat‑bed thermal inertia."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler
]

// C11: Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm using SciPy optimisation to estimate model parameters from collected temperature data."
    DTDFVocab:enables ParameterCalibrationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python‑based simulation engine that integrates calibrated temperature dynamics models to predict future temperature trajectories."
    DTDFVocab:enables TemperatureSimulationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Continuous monitoring algorithm that evaluates incoming temperature data against safety thresholds and performance targets."
    DTDFVocab:enables ContinuousMonitoringService
]

instance OptimisationEnabler : DTDFVocab:Enabler [
    base:desc "Optimisation and fault‑detection routine that analyses temperature trends to propose corrective actions or flag anomalies."
    DTDFVocab:enables OptimisationAndFaultDetectionService
]

instance SupervisoryControlEnabler : DTDFVocab:Enabler [
    base:desc "Supervisory control component that translates high‑level decisions into heat‑bed actuation commands via RabbitMQ to the Raspberry Pi."
    DTDFVocab:enables SupervisoryControlService
]

// C6: Services
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Acquires raw temperature streams from the incubator’s three DS18S20 sensors."
    DTDFVocab:provides TemperatureDataInsight
]

instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Runs model‑based simulations to reproduce and forecast incubator temperature dynamics under current conditions."
    DTDFVocab:provides PredictedTemperatureInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Executes calibration algorithms to update model parameters using the latest sensor data."
    DTDFVocab:provides CalibratedParameterInsight
]

instance ContinuousMonitoringService : DTDFVocab:Service [
    base:desc "Continuously checks safety limits and optimal performance of the incubator temperature."
    DTDFVocab:provides TemperatureSafetyInsight
]

instance OptimisationAndFaultDetectionService : DTDFVocab:Service [
    base:desc "Analyzes temperature data to detect faults and propose optimisation actions."
    DTDFVocab:provides PerformanceOptimizationInsight, FaultDetectionAction
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Provides closed‑loop supervisory control, issuing heat‑bed activation commands to maintain target temperature."
    DTDFVocab:provides ControlHeatBedAction
]

// C17: Insights
instance TemperatureDataInsight : DTDFVocab:Insight [
    base:desc "Insight that raw temperature data have been successfully captured and stored."
]

instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Insight presenting predicted temperature trajectories from the simulation model."
]

instance CalibratedParameterInsight : DTDFVocab:Insight [
    base:desc "Insight reporting the latest calibrated values of the temperature dynamics model parameters."
]

instance TemperatureSafetyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that current temperature readings are within defined safety thresholds."
]

instance PerformanceOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting adjustments to improve temperature regulation efficiency."
]

// C17: Actions
instance ControlHeatBedAction : DTDFVocab:Action [
    base:desc "Action to command the heat‑bed to increase thermal output to reach the target temperature."
    DTDFVocab:IsAutomatic true
]

instance FaultDetectionAction : DTDFVocab:Action [
    base:desc "Action to raise an alarm when a temperature anomaly or sensor fault is detected."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Component (heat‑bed)
instance IncubatorHeatBed : DTDFVocab:ActingComponent [
    base:desc "Thermal heating element that supplies energy to raise internal temperature; controlled by the supervisory control enabler."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The incubator plant is controlled by a Raspberry Pi that drives the heat‑bed and the fan. The Digital Twin generates control commands (e.g., activate/deactivate the fan, adjust heat‑bed power) based on model predictions and monitoring outcomes, and these commands are sent to the Raspberry Pi to affect the physical actuators. The documents do not provide specifics on command message formats, validation, authentication, feedback loops, conflict resolution, or execution confirmation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin adopts a layered orchestration where sensor data collected from the physical twin is fed to calibration algorithms that update the cyber‑physical system and environment models; the refreshed models are then used by monitoring components to evaluate safety and optimality, and upon detection of violations a decision layer (human operators or other algorithms) may initiate changes to the physical twin. This integration of data, models, and algorithms forms a closed‑loop architecture as described in the common structure illustrated in Fig. 1 of Document 1."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed by comparing the two temperature prediction models against experimental temperature traces; the four‑parameter model showed lower prediction error for thermal inertia, indicating higher fidelity. Calibration algorithms continuously update model parameters using incoming sensor data, serving as a validation loop. The DT employs monitors that evaluate the calibrated model output against safety and performance thresholds, providing error detection. No explicit uncertainty quantification or formal V&V procedures are detailed."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT incorporates safety monitoring by continuously comparing sensor‑derived temperature data from the incubator with model‑based predictions; a monitor component flags violations of predefined safe operating bounds. When a violation is detected, the framework can trigger human operators or automated corrective actions to return the Physical Twin to a safe state. Calibration algorithms are employed to keep model parameters aligned with the actual plant, thereby supporting reliable fault detection. The physical plant itself includes redundant temperature sensors (two internal, one external) and a fan/heat‑bed actuation loop controlled by a Raspberry Pi, providing basic fail‑safe capability through hardware monitoring. No explicit cybersecurity protocols or access‑control mechanisms are described in the documents."
]