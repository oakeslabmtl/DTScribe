// =====================
// Physical Sensing Components
// =====================

instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor placed inside the incubator (first of two internal sensors)."
    DTDFVocab:producedData TemperatureReadingMessage
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor placed inside the incubator (second of two internal sensors)."
    DTDFVocab:producedData TemperatureReadingMessage
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor placed outside the incubator."
    DTDFVocab:producedData TemperatureReadingMessage
]

// =====================
// Data Transmitted (message)
// =====================

instance TemperatureReadingMessage : DTDFVocab:DataTransmitted [
    base:desc "AMQP message published to RabbitMQ containing a numeric temperature reading tagged with sensor identifier."
    DTDFVocab:producedFrom InternalTempSensorA, InternalTempSensorB, ExternalTempSensor
]

// =====================
// Physical Data (timestamped temperature readings)
// =====================

instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Timestamped temperature reading obtained from InternalTempSensorA."
    DTDFVocab:fromData TemperatureReadingMessage
    DTDFVocab:inputTo CalibrationEnabler, FaultDetectionEnabler, MonitoringEnabler, SimulationEngineEnabler
]

instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Timestamped temperature reading obtained from InternalTempSensorB."
    DTDFVocab:fromData TemperatureReadingMessage
    DTDFVocab:inputTo CalibrationEnabler, FaultDetectionEnabler, MonitoringEnabler, SimulationEngineEnabler
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Timestamped temperature reading obtained from ExternalTempSensor."
    DTDFVocab:fromData TemperatureReadingMessage
    DTDFVocab:inputTo CalibrationEnabler, FaultDetectionEnabler, MonitoringEnabler, SimulationEngineEnabler
]

// =====================
// Acting Components (actuators)
// =====================

instance ResistiveHeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed driven by the Raspberry Pi GPIO to generate heat for reaching the target temperature inside the incubator."
]

instance AirCirculationFanActuator : DTDFVocab:ActingComponent [
    base:desc "Small fan driven by the Raspberry Pi GPIO to circulate air inside the insulated styrofoam box."
]

// =====================
// Models (analytical/behavioral)
// =====================

instance ThermalDynamicsModelTwoParams : DTDFVocab:Model [
    base:desc "Analytical thermal dynamics model of the incubator with two free parameters representing overall heat transfer."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance ThermalDynamicsModelFourParams : DTDFVocab:Model [
    base:desc "Analytical thermal dynamics model of the incubator with four free parameters, capturing the heat‑bed's thermal inertia."
    DTDFVocab:inputTo SimulationEngineEnabler
]

// =====================
// Enablers (algorithms / infrastructure)
// =====================

instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker that receives temperature messages from the low‑level driver and forwards them to DT components."
    DTDFVocab:enables TemperatureMonitoringService, ModelCalibrationService, SafetyCheckingService, HeatingOptimisationService, TemperaturePredictionService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that estimates free parameters of the thermal models using incoming temperature data."
    DTDFVocab:enables ModelCalibrationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Fault detection algorithm that checks temperature readings for violations of safety thresholds."
    DTDFVocab:enables SafetyCheckingService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring algorithm that continuously evaluates internal and external temperature trends."
    DTDFVocab:enables TemperatureMonitoringService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs the analytical thermal models to predict future internal temperature."
    DTDFVocab:enables TemperaturePredictionService
]

instance OptimisationEnabler : DTDFVocab:Enabler [
    base:desc "Optimisation algorithm that computes optimal heating‑bed power and fan speed to keep temperature at the set‑point."
    DTDFVocab:enables HeatingOptimisationService
]

// =====================
// Services
// =====================

instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Simulation‑based prediction of the incubator's internal temperature using calibrated thermal models."
    DTDFVocab:provides PredictedTemperatureInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Online calibration (parameter estimation) of the two thermal models using recent sensor data."
    DTDFVocab:provides CalibratedParametersInsight
]

instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of internal and external temperature streams for trend analysis."
    DTDFVocab:provides TemperatureTrendInsight
]

instance SafetyCheckingService : DTDFVocab:Service [
    base:desc "Safety checking that detects temperature violations and raises alerts."
    DTDFVocab:provides TemperatureViolationInsight
]

instance HeatingOptimisationService : DTDFVocab:Service [
    base:desc "Optimisation of heating‑bed power and fan speed to maintain the target temperature with minimal energy."
    DTDFVocab:provides OptimisationRecommendationAction
]

// =====================
// Insights and Actions
// =====================

instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted internal temperature trajectory over the next control horizon."
]

instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Estimated values of the free parameters for each thermal model after calibration."
]

instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Detected trends (rising/falling) in internal and external temperature readings."
]

instance TemperatureViolationInsight : DTDFVocab:Insight [
    base:desc "Identification of temperature readings that exceed predefined safety thresholds."
]

instance OptimisationRecommendationAction : DTDFVocab:Action [
    base:desc "Recommended adjustment of heat‑bed power and fan speed to achieve the set‑point."
    DTDFVocab:IsAutomatic true
]

// =====================
// Environment (Physical Twin)
// =====================

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Thermal incubator consisting of insulated styrofoam box, heat‑bed, fan, three temperature sensors and a Raspberry Pi controller."
    base:contains InternalTempSensorA, InternalTempSensorB, ExternalTempSensor, ResistiveHeatBedActuator, AirCirculationFanActuator, RaspberryPiController
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Embedded Raspberry Pi that runs the low‑level driver, hosts the RabbitMQ client and executes DT algorithms."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the digital twin are sent as AMQP messages through the RabbitMQ server to the controller running on the Raspberry Pi. The controller interprets commands (e.g., turn fan on/off, activate heat‑bed for a specified heating duration, wait for a waiting duration) and forwards actuator states to the low‑level driver, which then issues the actual signals to the physical devices. The low‑level driver includes a safety protocol that validates incoming commands before execution and acknowledges successful actuation back to the controller via RabbitMQ, providing feedback for closed‑loop operation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The incubator DT processes data in (near) real‑time: sensor readings and controller/driver messages are continuously streamed to a time‑series database, visualised on a dashboard, and used immediately by on‑demand calibration, Kalman‑filter anomaly detection and co‑simulation modules; the loop operates at the sampling rate of the temperature sensors (implicit) to keep the digital and physical twins synchronised."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized orchestration is employed: the physical twin feeds raw data to a central DT that hosts a time‑series store, a calibration engine, a Kalman‑filter based state estimator, and a co‑simulation component. These services interact internally to support real‑time visualisation, on‑demand model calibration, anomaly detection, what‑if simulations and the self‑adaptation loop."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The documents outline a three‑phase lifecycle: (1) Development – creation of abstract models of the system (e.g., CAD geometry, dynamic differential‑equation model); (2) Deployment – integration of these models with sensor data into the Digital Twin, where calibration algorithms update model parameters with the best estimates; (3) Operation – continuous acquisition of sensor data, execution of monitoring algorithms that assess safety and optimality, and possible human or automated interventions that may trigger updates to the physical twin or to the twin’s models."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing simulated temperature trajectories against measured data. Experiments showed that the four‑parameter model more accurately reproduces the thermal inertia of the heat‑bed than the simpler two‑parameter model, indicating higher validity for control tasks. Calibration algorithms continuously adjust model parameters to reduce prediction error, thereby addressing uncertainties arising from sensor noise and unmodelled environmental effects. No formal verification or quantitative uncertainty bounds are described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin and physical twin communicate over a central RabbitMQ message broker using the AMQP protocol. All components (controller, low‑level driver, DT analytics modules) connect as clients to this broker, forming a star‑topology network. RabbitMQ can be deployed on‑premise or in the cloud, offering lightweight, mature messaging with support for tens of thousands of concurrent users. Reliability is provided by RabbitMQ’s built‑in message durability and acknowledgment mechanisms; however, specific redundancy or bandwidth/latency specifications are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ server that underpins the digital‑twin communication can be hosted either on‑premise or in a cloud environment. The controller and low‑level driver run on a Raspberry Pi, providing the computational platform for real‑time control. DT analytics and model calibration components may run on any machine that can connect to the RabbitMQ broker, scaling with RabbitMQ’s ability to handle many clients. Storage requirements are not specified, but the architecture supports scalability via RabbitMQ’s clustering capabilities. Availability is ensured by RabbitMQ’s mature implementation, though explicit redundancy or SLA details are not provided."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin incorporates safety monitoring algorithms that continuously evaluate sensor data against predefined safety criteria; monitors assess whether the system is performing safely and optimally, and upon detection of a violation they can alert humans or trigger corrective actions on the physical twin. The documents do not detail any cybersecurity protocols, access control mechanisms, authentication systems, threat mitigation strategies, fail‑safe mechanisms, or risk assessment approaches."
]