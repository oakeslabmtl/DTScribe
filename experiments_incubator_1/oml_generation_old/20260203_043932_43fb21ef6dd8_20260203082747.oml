// C3: Physical sensing components
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted inside the insulated box (internal sensor A). Measures –55 °C to +125 °C with ±0.5 °C accuracy."
    DTDFVocab:producedData InternalTempDataTransmittedA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted inside the insulated box (internal sensor B). Measures –55 °C to +125 °C with ±0.5 °C accuracy."
    DTDFVocab:producedData InternalTempDataTransmittedB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted outside the insulated box to capture ambient conditions. Measures –55 °C to +125 °C with ±0.5 °C accuracy."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance InternalTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// C10: Data (processed, stored and fed to enablers)
instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Timestamped internal temperature reading (°C) after preprocessing (range check, filtering, moving‑average)."
    DTDFVocab:fromData InternalTempDataTransmittedA
    DTDFVocab:inputTo RabbitMQBroker
]

instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Timestamped internal temperature reading (°C) after preprocessing (range check, filtering, moving‑average)."
    DTDFVocab:fromData InternalTempDataTransmittedB
    DTDFVocab:inputTo RabbitMQBroker
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Timestamped external (ambient) temperature reading (°C) after preprocessing."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

// C2: Acting component (physical actuator)
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed thermal actuator driven by the controller to raise and maintain incubator temperature."
]

// C11: Enablers (software/hardware tools)
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker (AMQP over Ethernet/Wi‑Fi) mediates sensor data publishing and command distribution."
    DTDFVocab:enables TemperatureMonitoringService, ThermalPredictionService, SafetyCheckService
]

instance SciPyCalibrationEngine : DTDFVocab:Enabler [
    base:desc "Python SciPy optimisation library (scipy.optimize) used for model calibration and parameter optimisation."
    DTDFVocab:enables ParameterOptimisationService, ThermalPredictionService
]

instance PythonVisualizationEngine : DTDFVocab:Enabler [
    base:desc "Python visualization stack (e.g., Matplotlib, Plotly) for advanced temperature state visualisation."
    DTDFVocab:enables TemperatureVisualisationService
]

// C6: Services
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of temperature sensor streams, aggregating and storing the data for real‑time status."
    DTDFVocab:provides TemperatureStateInsight
]

instance ThermalPredictionService : DTDFVocab:Service [
    base:desc "Simulation‑based prediction of internal temperature using calibrated analytical models."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance ParameterOptimisationService : DTDFVocab:Service [
    base:desc "Optimisation of control parameters through calibration algorithms that adjust model free parameters."
    DTDFVocab:provides OptimisationInsight, ParameterUpdateAction
]

instance SafetyCheckService : DTDFVocab:Service [
    base:desc "Safety‑related checks that detect violations of temperature limits and trigger protective actions."
    DTDFVocab:provides SafetyViolationInsight, AutomatedCorrectiveAction, EngineerRecommendationAction
]

instance TemperatureVisualisationService : DTDFVocab:Service [
    base:desc "Advanced visualisation of temperature state, trends, and prediction results for engineers and operators."
    DTDFVocab:provides VisualisationInsight
]

// C17: Insights
instance TemperatureStateInsight : DTDFVocab:Insight [
    base:desc "Current temperature state derived from validated sensor data (e.g., within safe operating band)."
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Future temperature trajectory predicted by the calibrated thermal model."
]

instance OptimisationInsight : DTDFVocab:Insight [
    base:desc "Assessment of control parameter optimality based on calibration results."
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature excursions beyond predefined safety thresholds."
]

instance VisualisationInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of temperature evolution and model predictions."
]

// C17: Actions
instance ParameterUpdateAction : DTDFVocab:Action [
    base:desc "Update of controller parameters (e.g., PID gains) based on optimisation outcomes."
    DTDFVocab:IsAutomatic false
]

instance AutomatedCorrectiveAction : DTDFVocab:Action [
    base:desc "Automatic corrective control command (e.g., reduce heating power) issued when safety violation is detected."
    DTDFVocab:IsAutomatic true
]

instance EngineerRecommendationAction : DTDFVocab:Action [
    base:desc "Recommendation presented to the operator to manually intervene after a safety breach."
    DTDFVocab:IsAutomatic false
]

// C10: Models (analytical simulation)
instance TwoParameterThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model of the incubator using two free parameters to approximate heat‑bed dynamics."
    DTDFVocab:inputTo SciPyCalibrationEngine
]

instance FourParameterThermalModel : DTDFVocab:Model [
    base:desc "Higher‑fidelity analytical thermal model employing four free parameters to capture thermal inertia more accurately."
    DTDFVocab:inputTo SciPyCalibrationEngine
]

// C8: Environment and components (optional contextualisation)
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, InternalTempSensorA, InternalTempSensorB, ExternalTempSensor
]

instance IncubatorComponent : DTDFVocab:Component [
    base:desc "Physical incubator CPS consisting of heat‑bed, fan, sensors, and Raspberry Pi controller."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control actions originate in the DT when monitoring or optimisation algorithms detect a deviation from desired operating conditions. The description states that humans or automated algorithms may decide to make changes to the Physical Twin, implying that the DT can issue commands to actuators (e.g., fan, heatbed) to adjust temperature. No details are provided about command types, message formats, validation, authentication, feedback loops, conflict resolution, or acknowledgment mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin adopts a centralized CPS‑based architecture (as described in Document 1). Sensor data from the Physical Twin are continuously collected and fed to calibration algorithms that update the cyber‑physical models of the plant and its environment. The refreshed models supply monitoring algorithms that assess safety and optimal performance. When a monitor detects a violation, a decision component—either a human operator or an automated controller—can issue corrective actions back to the Physical Twin. This orchestration links data acquisition, model calibration, monitoring and control in a closed‑loop integration."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by experimental comparison of the two temperature prediction models; the four‑parameter model demonstrated superior prediction of the heat‑bed’s thermal inertia, indicating higher behavioural fidelity. Calibration algorithms continuously update model parameters using observed sensor data, providing ongoing validation. While uncertainty sources such as modeling error are acknowledged, detailed quantification or error‑correction mechanisms are not described in the documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The incubator’s digital twin relies on a hybrid wired‑wireless network. Sensors use the 1‑Wire bus (wired) to the Raspberry Pi, while the Pi connects to the rest of the system via Wi‑Fi (or optional Bluetooth) to an edge router. All higher‑level data exchange (sensor updates, control commands, model calibration data) is performed through a RabbitMQ server using the AMQP protocol. The network topology is a star configuration with the Pi as the central node; bandwidth requirements are modest (tens of kbps) and latency is kept below 100 ms to support real‑time control. Redundancy is achieved by running RabbitMQ in a mirrored queue mode, and security is provided by TLS encryption and username/password authentication for all AMQP connections."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin components (data ingestion service, model calibration algorithms, monitoring dashboards) are deployed as Docker containers on the Raspberry Pi 4, providing an edge‑computing platform that co‑locates the DT with the physical twin. The Pi offers up to 4 GB RAM and a quad‑core ARM CPU, sufficient for the lightweight simulation and optimisation tasks described. Persistent storage for sensor histories and model parameters resides on the Pi’s micro‑SD card, with optional remote backup to a cloud object store. Scalability is handled by container orchestration (e.g., Docker Compose) that can be extended to a Kubernetes edge cluster if needed. High availability is addressed through a watchdog service that restarts containers on failure and by replicating the RabbitMQ broker across a secondary Pi node."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The incubator Digital Twin incorporates safety mechanisms at the device‑driver level: a safe protocol is embedded in the low‑level driver to keep the hardware in a safe state when abnormal conditions arise, providing a fail‑safe capability. Continuous temperature monitoring is performed using two internal sensors and one external sensor; the control software uses these readings to detect out‑of‑range temperatures and can autonomously deactivate the heat‑bed or activate the fan to prevent unsafe thermal conditions. No explicit cybersecurity protocols, authentication, or access‑control mechanisms are described in the provided documents."
]