// C3: Physical sensing components
instance InteriorTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside the incubator (interior sensor 1) providing high‑precision temperature measurements over a 1‑Wire bus"
    DTDFVocab:producedData IncubatorTelemetry
]

instance InteriorTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside the incubator (interior sensor 2) providing high‑precision temperature measurements over a 1‑Wire bus"
    DTDFVocab:producedData IncubatorTelemetry
]

instance ExteriorTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor measuring ambient temperature outside the incubator"
    DTDFVocab:producedData IncubatorTelemetry
]

// C2: Acting components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed acting as the heating element, driven via MOSFET switches on a custom PCB"
    DTDFVocab:producedData IncubatorTelemetry
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Circulation fan driven via MOSFET switches on a custom PCB"
    DTDFVocab:producedData IncubatorTelemetry
]

// C4: Physical-to-virtual interaction
instance IncubatorTelemetry : DTDFVocab:DataTransmitted [
    base:desc "Telemetry message containing temperature measurements from three DS18S20 sensors and current states of heatbed and fan, published periodically by the low‑level driver to RabbitMQ"
    DTDFVocab:producedFrom InteriorTempSensor1, InteriorTempSensor2, ExteriorTempSensor, HeatbedActuator, FanActuator
]

// C10: Data
instance IncubatorTelemetryData : DTDFVocab:Data [
    base:desc "Aggregated temperature and actuator‑state data extracted from IncubatorTelemetry"
    DTDFVocab:fromData IncubatorTelemetry
    DTDFVocab:inputTo RabbitMQMessagingEnabler
]

instance CalibrationTemperatureData : DTDFVocab:Data [
    base:desc "Temperature trajectory data collected during calibration experiments, used for parameter estimation"
    DTDFVocab:fromData IncubatorTelemetry
    DTDFVocab:inputTo SciPyCalibrationEnabler
]

// C11: Enablers (tooling and enablers)
instance RabbitMQMessagingEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on Raspberry Pi 4, enabling publish/subscribe of telemetry between physical twin and digital twin"
    DTDFVocab:enables RealTimeMonitoringService, ViolationDetectionService, TemperaturePredictionService, ModelCalibrationService
]

instance SciPyCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Python SciPy library providing non‑linear least‑squares optimisation for calibrating model parameters"
    DTDFVocab:enables ModelCalibrationService
]

instance PredictionEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime executing calibrated physics‑based temperature models for prediction"
    DTDFVocab:enables TemperaturePredictionService
]

instance ActuationControlEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level driver on Raspberry Pi that drives MOSFET switches to control heatbed and fan"
    DTDFVocab:enables HeatingAction, CoolingAction
]

// C10: Models/Data
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Physics‑based Model A derived from energy‑balance equations, using a single thermal capacitance parameter"
    DTDFVocab:inputTo PredictionEngineEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Physics‑based Model B derived from energy‑balance equations, using four parameters (C_air, G_box, G_heater, C_heater)"
    DTDFVocab:inputTo PredictionEngineEnabler
]

// C6: Services
instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Provides temperature prediction using calibrated Model A and Model B"
    DTDFVocab:provides PredictedTemperatureInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates model parameters using non‑linear least‑squares optimisation on experimental temperature data"
    DTDFVocab:provides CalibrationParametersInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Monitors temperature in real time against defined safety limits"
    DTDFVocab:provides SafetyViolationInsight
]

instance ViolationDetectionService : DTDFVocab:Service [
    base:desc "Detects breaches of lower/upper temperature limits and triggers appropriate actions"
    DTDFVocab:provides HeatingAction, CoolingAction
]

// C17: Insights
instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted future evolution of incubator air temperature based on calibrated models"
]

instance CalibrationParametersInsight : DTDFVocab:Insight [
    base:desc "Estimated model parameters (C_air, G_box, G_heater, C_heater) obtained from calibration"
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature violations relative to lower and upper safety thresholds"
]

// C17: Actions
instance HeatingAction : DTDFVocab:Action [
    base:desc "Increase heatbed power to raise incubator temperature"
    DTDFVocab:IsAutomatic false
]

instance CoolingAction : DTDFVocab:Action [
    base:desc "Increase fan speed or reduce heatbed power to lower incubator temperature"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (turn‑on/off heatbed, turn‑on/off fan) to the RabbitMQ server; the Raspberry Pi controller receives these messages and actuates the MOSFET driver circuit accordingly."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture consists of the Physical Twin (hardware), a low‑level driver translating sensor reads and actuator commands, a RabbitMQ communication server on the Raspberry Pi, DT modules that subscribe to RabbitMQ for data ingestion and model execution, and a calibration/monitoring service that updates model parameters and generates control set‑points."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity relies on four assumptions (uniform temperature, negligible wall heat storage, constant air specific heat, all electrical power converted to heat) and is validated by uniformity experiments and calibration against measured temperature trajectories; residual errors are minimised using a gradient‑descent based least‑squares optimizer."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual and virtual‑to‑physical communication is implemented via RabbitMQ, a lightweight message broker using standard TCP/IP networking; messages carry sensor readings, actuator commands, and status flags."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT services (RabbitMQ server, low‑level driver, calibration scripts) are hosted on the same Raspberry Pi 4 that controls the incubator; all source code and hardware designs are hosted in a public GitHub repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the hardware in a safe state; monitoring monitors temperature limits to prevent unsafe overheating, though no explicit cybersecurity measures are described."
]