// Sensing components
instance IncubatorTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital temperature sensor located inside the incubator (first sensor)."
    DTDFVocab:producedData IncubatorTempAMQPMessage
]

instance IncubatorTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital temperature sensor located inside the incubator (second sensor)."
    DTDFVocab:producedData IncubatorTempAMQPMessage
]

instance RoomTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital temperature sensor measuring ambient room temperature."
    DTDFVocab:producedData RoomTempAMQPMessage
]

// Data transmitted via RabbitMQ
instance IncubatorTempAMQPMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorTempSensor1, IncubatorTempSensor2
]

instance RoomTempAMQPMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTempSensor
]

// Virtual temperature data
instance IncubatorTempData : DTDFVocab:Data [
    base:desc "Temperature readings from the two DS18S20 sensors inside the incubator published via AMQP."
    DTDFVocab:fromData IncubatorTempAMQPMessage
    DTDFVocab:inputTo PythonSimulationEnabler, PTMonitoringService
]

instance RoomTempData : DTDFVocab:Data [
    base:desc "Room temperature readings from DS18S20 sensor published via AMQP."
    DTDFVocab:fromData RoomTempAMQPMessage
    DTDFVocab:inputTo PythonSimulationEnabler, PTMonitoringService
]

// Actuating components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heating element driven by Raspberry Pi GPIO through MOSFETs and optocouplers."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "High‑speed fan driven by Raspberry Pi GPIO through MOSFETs and optocouplers."
]

// Enablers
instance LowLevelDriverEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level driver that reads DS18S20 sensors and publishes data to RabbitMQ AMQP broker."
    DTDFVocab:enables SensorDataReceptionService
]

instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker running on Raspberry Pi for message passing between sensors and DT services."
    DTDFVocab:enables SensorDataReceptionService
]

instance GPIOControlEnabler : DTDFVocab:Enabler [
    base:desc "GPIO control layer on Raspberry Pi using MOSFETs and optocouplers to drive heatbed and fan actuators."
    DTDFVocab:enables HeatbedControlService, FanControlService
]

instance PythonSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python environment with SciPy and custom simulation code for model‑based simulation and calibration."
    DTDFVocab:enables TemperatureSimulationService, CalibrationService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration enabler that performs non‑linear least squares fitting of ModelA and ModelB parameters."
    DTDFVocab:enables CalibrationService
]

instance ControlLogicEnabler : DTDFVocab:Enabler [
    base:desc "Control logic enabler coordinating bang‑bang controller decisions for fan and heatbed."
    DTDFVocab:enables BangBangControlService
]

// Services
instance SensorDataReceptionService : DTDFVocab:Service [
    base:desc "Receives sensor data messages from RabbitMQ broker for further processing."
]

instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Model‑based simulation of temperature dynamics using Model A and Model B with least‑squares parameter calibration."
    DTDFVocab:provides TemperaturePredictionInsight, ParameterUpdateAction
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration of free parameters (C_air, G_box, G_heater, C_heater) using non‑linear least‑squares (SciPy)."
    DTDFVocab:provides ParameterUpdateAction
]

instance PTMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of PT state and fault/delay‑aware bang‑bang control logic."
    DTDFVocab:provides SafetyMonitoringFlagAction, FanDutyCycleRecommendationAction
]

instance BangBangControlService : DTDFVocab:Service [
    base:desc "Bang‑bang controller for fan and heatbed actuators driven by Raspberry Pi GPIO."
    DTDFVocab:provides SetHeatbedPowerAction, SetFanDutyCycleAction
]

instance HeatbedControlService : DTDFVocab:Service [
    base:desc "Control service for heatbed power level."
    DTDFVocab:provides SetHeatbedPowerAction
]

instance FanControlService : DTDFVocab:Service [
    base:desc "Control service for fan duty cycle."
    DTDFVocab:provides SetFanDutyCycleAction
]

// DT models
instance ModelATemperatureDynamics : DTDFVocab:Model [
    base:desc "Dynamic temperature model accounting for thermal mass C_air, heat transfer G_box, heating element G_heater, and heater thermal capacitance C_heater (Model A)."
    DTDFVocab:inputTo PythonSimulationEnabler
]

instance ModelBTemperatureDynamics : DTDFVocab:Model [
    base:desc "Dynamic temperature model refining Model A with additional thermal inertia parameters (Model B)."
    DTDFVocab:inputTo PythonSimulationEnabler
]

// Simulation trajectory data
instance ModelATemperatureTrajectory : DTDFVocab:Data [
    base:desc "Simulated temperature trajectory produced by Model A."
    DTDFVocab:inputTo PythonSimulationEnabler
]

instance ModelBTemperatureTrajectory : DTDFVocab:Data [
    base:desc "Simulated temperature trajectory produced by Model B."
    DTDFVocab:inputTo PythonSimulationEnabler
]

// Insights and actions
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time temperature predictions from simulation models."
]

instance ParameterUpdateAction : DTDFVocab:Action [
    base:desc "Action to update model parameters based on calibration results."
    DTDFVocab:IsAutomatic true
]

instance SafetyMonitoringFlagAction : DTDFVocab:Action [
    base:desc "Action flagging safety incidents when temperature exceeds prescribed thresholds."
    DTDFVocab:IsAutomatic true
]

instance FanDutyCycleRecommendationAction : DTDFVocab:Action [
    base:desc "Recommended fan duty cycle to maintain temperature within safe limits."
    DTDFVocab:IsAutomatic true
]

instance SetHeatbedPowerAction : DTDFVocab:Action [
    base:desc "Action to set heatbed power level via GPIO."
    DTDFVocab:IsAutomatic false
]

instance SetFanDutyCycleAction : DTDFVocab:Action [
    base:desc "Action to set fan duty cycle via GPIO."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (e.g., heatbed on/off, fan on/off) to RabbitMQ; the Raspberry Pi controller consumes them and toggles the actuators via GPIO."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized DT stack on the Raspberry Pi consisting of the Communication Server (RabbitMQ), Low‑level Driver, Control Logic, and DT models; message exchange via AMQP orchestrates interaction between DT and PT."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (formulating dynamic models and assumptions), Calibration (parameter estimation under operation), and Operation (continuous monitoring and possible re‑calibration)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Models rely on assumptions of uniform temperature, negligible wall heat capacity, constant air specific heat, and neglect of fan heat; validity confirmed by uniform temperature experiments; calibration minimises residual error using SciPy optimisation; uncertainty not explicitly quantified."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Connection between PT and DT is through the local RabbitMQ broker hosted on the Raspberry Pi; the Pi publishes sensor telemetry and consumes actuator command queues; underlying protocol is the standard RabbitMQ messaging (AMQP) over the Pi’s local network; message exchange occurs asynchronously over queues."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "DT logic (communication server, driver, controller) hosted on the Raspberry Pi 4 Model B, with all components running locally on the same device."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safe protocol embedded in low‑level driver to prevent unsafe states; isolation via MOSFETs and optocouplers; RabbitMQ provides reliable messaging; no explicit security or safety certifications mentioned."
]