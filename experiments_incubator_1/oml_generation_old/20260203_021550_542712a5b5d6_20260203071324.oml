// C3: Physical sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer placed inside the incubator, ±0.5 °C accuracy"
    DTDFVocab:producedData InternalTempDataTransmitted1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer placed inside the incubator, ±0.5 °C accuracy"
    DTDFVocab:producedData InternalTempDataTransmitted2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer placed outside the incubator to measure ambient temperature, ±0.5 °C accuracy"
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// C4: Physical-to-virtual interaction – Data transmitted via RabbitMQ
instance InternalTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// C10: Data (interpreted temperature measurements)
instance InternalTempData1 : DTDFVocab:Data [
    base:desc "Temperature measurement from internal sensor 1 (°C) published via RabbitMQ"
    DTDFVocab:fromData InternalTempDataTransmitted1
    DTDFVocab:inputTo RabbitMQMessageBroker, SciPyCalibrationEngine
]

instance InternalTempData2 : DTDFVocab:Data [
    base:desc "Temperature measurement from internal sensor 2 (°C) published via RabbitMQ"
    DTDFVocab:fromData InternalTempDataTransmitted2
    DTDFVocab:inputTo RabbitMQMessageBroker, SciPyCalibrationEngine
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Ambient temperature measurement (°C) published via RabbitMQ"
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo RabbitMQMessageBroker, SciPyCalibrationEngine
]

// C11: Enablers (tools/software)
instance RabbitMQMessageBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP message broker running on the Raspberry Pi, receives sensor measurements and forwards them to DT services"
    DTDFVocab:enables RealTimeMonitoringService, AlertGenerationService, ModelBasedPredictionService
]

instance SciPyCalibrationEngine : DTDFVocab:Enabler [
    base:desc "Python SciPy library used for non‑linear least‑squares calibration of thermal models (Model A and Model B)"
    DTDFVocab:enables ParameterCalibrationService
]

instance LowLevelDriverSoftware : DTDFVocab:Enabler [
    base:desc "Low‑level driver reads DS18S20 sensors via Raspberry Pi GPIO 1‑Wire bus and publishes readings to RabbitMQ"
    DTDFVocab:enables RealTimeMonitoringService, ParameterCalibrationService, ModelBasedPredictionService
]

// C6: Services
instance ModelBasedPredictionService : DTDFVocab:Service [
    base:desc "Provides model‑based temperature prediction using calibrated Model A or Model B"
    DTDFVocab:provides TemperaturePredictionInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates model parameters against experimental temperature data using SciPy optimisation"
    DTDFVocab:provides CalibratedParametersInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Monitors temperature in real time and checks against defined safety limits"
    DTDFVocab:provides TemperatureLimitAlertInsight
]

instance AlertGenerationService : DTDFVocab:Service [
    base:desc "Generates alerts when safety or performance bounds are violated"
    DTDFVocab:provides SafetyAlertInsight, AdjustHeatingAction
]

// C17: Insights / Actions
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory for the incubator derived from the calibrated thermal model"
]

instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Calibrated model parameters (C_air, G_box, C_heater, G_heater) stored for future predictions"
]

instance TemperatureLimitAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when measured temperature exceeds defined limits"
]

instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Alert for safety or performance bound violations (e.g., overheating)"
]

instance AdjustHeatingAction : DTDFVocab:Action [
    base:desc "Automatically adjust heatbed power or fan speed based on model predictions and alerts"
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single‑node thermal model (Model A) with parameters C_air (air heat capacity) and G_box (thermal conductance of the box)"
    DTDFVocab:inputTo SciPyCalibrationEngine, ModelBasedPredictionService
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Extended thermal model (Model B) adding heater thermal mass C_heater and conductance G_heater to Model A"
    DTDFVocab:inputTo SciPyCalibrationEngine, ModelBasedPredictionService
]

// C2: Acting components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑generating surface (heatbed) switched via MOSFET driver on the custom PCB"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal circulation fan (12 V/24 V) switched via MOSFET driver on the custom PCB"
]

// C17: Environment and physical components
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InternalTempSensor1, InternalTempSensor2, AmbientTempSensor,
                HeatbedActuator, FanActuator, CustomPCB, RaspberryPi4Controller
]

instance CustomPCB : DTDFVocab:Component [
    base:desc "Custom PCB hosting MOSFET drivers and optocouplers for heatbed and fan control"
]

instance RaspberryPi4Controller : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B acting as controller and host for RabbitMQ, low‑level driver, and SciPy calibration engine"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin sends command messages (e.g., turn on/off heatbed, set fan speed) through RabbitMQ to the controller, which interprets them and drives the MOSFETs to actuate the heatbed and fan."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a CPS‑based DT architecture: the Physical Twin connects to a low‑level driver, which forwards sensor data to a RabbitMQ communication server; the controller consumes commands from the same server and actuates the PT; DT components (e.g., calibration service, monitor) subscribe to the RabbitMQ topics to receive data and send control commands, forming a tightly coupled, centrally orchestrated constellation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validity is assessed through experiments testing the uniformity assumption (fan‑induced mixing) and by comparing model predictions with measured temperature trajectories; calibration minimizes residual error using a non‑linear least‑squares objective, and the best‑fit parameters are evaluated for physical plausibility."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses the RabbitMQ message broker over AMQP running on the Raspberry Pi; sensor data are acquired via the 1‑Wire GPIO interface; control commands are sent over the same network to the controller; Wi‑Fi/Bluetooth on the Raspberry Pi provides optional external connectivity."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT software components (RabbitMQ server, low‑level driver, controller, calibration scripts) are deployed on the Raspberry Pi 4 Model B, which also hosts the PT hardware; the implementation is open‑source and available in the referenced GitHub repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol that enforces a safe state for the hardware; the controller monitors temperature limits and can halt actuation to prevent unsafe overheating, providing basic safety guarantees."
]