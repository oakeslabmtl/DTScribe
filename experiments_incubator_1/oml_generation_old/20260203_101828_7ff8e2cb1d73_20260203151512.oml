// C3: Physical sensing components
instance InternalIncubatorTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside the incubator, measuring internal ambient temperature"
    DTDFVocab:producedData InternalIncubatorTempDataTransmitted1
]

instance InternalIncubatorTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside the incubator, measuring internal ambient temperature"
    DTDFVocab:producedData InternalIncubatorTempDataTransmitted2
]

instance ExternalAmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located outside the incubator, measuring external ambient temperature"
    DTDFVocab:producedData ExternalAmbientTempDataTransmitted
]

// C4: Data transmitted
instance InternalIncubatorTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalIncubatorTemperatureSensor1
]

instance InternalIncubatorTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalIncubatorTemperatureSensor2
]

instance ExternalAmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalAmbientTemperatureSensor
]

// C10: Data
instance TemperatureData1 : DTDFVocab:Data [
    base:desc "Time‑stamped readings from InternalIncubatorTemperatureSensor1"
    DTDFVocab:inputTo RabbitMQServerEnabler
    DTDFVocab:fromData InternalIncubatorTempDataTransmitted1
]

instance TemperatureData2 : DTDFVocab:Data [
    base:desc "Time‑stamped readings from InternalIncubatorTemperatureSensor2"
    DTDFVocab:inputTo RabbitMQServerEnabler
    DTDFVocab:fromData InternalIncubatorTempDataTransmitted2
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped readings from ExternalAmbientTemperatureSensor"
    DTDFVocab:inputTo RabbitMQServerEnabler
    DTDFVocab:fromData ExternalAmbientTempDataTransmitted
]

// C11: Enablers
instance RabbitMQServerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ server running on the Raspberry Pi, receives temperature data over AMQP protocol via Wi‑Fi"
    DTDFVocab:enables RealTimeMonitoringService, SimulationService, CalibrationPipelineService, DataLoggingService, VisualizationDashboardService
]

instance SciPyLeastSquaresEnabler : DTDFVocab:Enabler [
    base:desc "Provides SciPy non‑linear least‑squares optimization for calibrating ModelA and ModelB"
    DTDFVocab:enables CalibrationPipelineService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of temperature, diagnostics, and safety alerts"
    DTDFVocab:provides RealTimeDiagnosticsInsight, SafetyAlertInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs simulation of thermal dynamics using calibrated models (ModelA and ModelB)"
    DTDFVocab:provides SimulationInsight
]

instance CalibrationPipelineService : DTDFVocab:Service [
    base:desc "Calibrates dynamic thermal models using non‑linear least‑squares optimization (SciPy)"
    DTDFVocab:provides CalibrationInsight
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs temperature, power consumption, fan/heatbed status, and calibration residuals"
    DTDFVocab:provides LogInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Provides online visualization dashboard (open‑source) for displaying real‑time data streams"
    DTDFVocab:provides DashboardInsight
]

// C17: Insights/Actions
instance RealTimeDiagnosticsInsight : DTDFVocab:Insight [
    base:desc "Computes deviation between predicted and measured temperatures in real time"
]

instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Triggers safety alerts when temperature setpoints are violated"
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Displays calibration residuals after model fitting"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Shows simulated temperature profiles from ModelA and ModelB"
]

instance LogInsight : DTDFVocab:Insight [
    base:desc "Provides historical logs of temperature and actuator status"
]

instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Renders real‑time data streams on an open‑source dashboard"
]

instance ParameterAdjustmentSuggestionAction : DTDFVocab:Action [
    base:desc "Suggests adjustments to heating duration (H) and waiting duration (C) based on calibrated models"
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heating element driven via MOSFETs and optocouplers, controlled by Raspberry Pi"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12/24 V fan for air circulation, powered and commanded via MOSFET driver"
]

instance PiControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi controller toggles heatbed and fan actuators, runs low‑level driver and RabbitMQ"
]

// Components
instance HeatbedHeatingElement : DTDFVocab:Component [
    base:desc "Heating element located inside the incubator"
]

instance Fan : DTDFVocab:Component [
    base:desc "12/24 V fan providing air circulation in the incubator"
]

instance RaspberryPi4BController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B controller running low‑level driver and RabbitMQ server"
]

// Environment
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedHeatingElement, Fan, RaspberryPi4BController, HeatbedActuator, FanActuator, PiControllerActuator
]

// Models
instance ModelAThermal : DTDFVocab:Model [
    base:desc "Single‑zone air temperature dynamics model with parameters C_air and G_box"
    DTDFVocab:inputTo SciPyLeastSquaresEnabler
]

instance ModelBThermal : DTDFVocab:Model [
    base:desc "Two‑zone dynamics model including heatbed temperature with parameters C_heater and G_heater"
    DTDFVocab:inputTo SciPyLeastSquaresEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes command messages via RabbitMQ (e.g., turn heatbed ON/OFF, turn fan ON/OFF) which are received by the low‑level driver on the Raspberry Pi and converted into GPIO outputs to actuate the heatbed/fan through MOSFETs and optocouplers."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A CPS‑based Digital Twin where the physical twin (incubator, Raspberry Pi, sensors, actuators) communicates with the DT via a RabbitMQ broker hosted on the Pi. The DT consists of a Python simulation layer (Model A/B), a controller layer implementing Bang‑Bang logic, and a communication layer that publishes control commands and diagnostics back to the Pi."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Four modeling assumptions (uniform temperature distribution, negligible wall heat accumulation, constant specific heat capacity of air, and heatbed heat‑loss neglect) were validated experimentally; calibration minimized residual errors; model validity assessed against temperature experiments; uncertainties derived from least‑squares fit; models capture thermal inertia but not detailed wall heat transfer."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "PT communicates over Wi‑Fi through RabbitMQ using AMQP; device and controller publish/subscribe to specific queues; DT components on host connect to the same RabbitMQ broker for data ingestion and command dissemination."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "RabbitMQ server is hosted on the Raspberry Pi; Digital Twin simulation and control logic run in Python on the same Pi or a local PC, with all software open‑source and available via GitHub."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Low‑level driver implements a safe protocol to prevent unsafe states; optocouplers and MOSFETs provide electrical isolation; communication via RabbitMQ over Wi‑Fi (TLS not specified), but system design includes isolation to avoid overheating or unsafe actuator commands."
]