// ===========================
// Acting Components (C2)
// ===========================
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heating element driven via MOSFETs, on/off control"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V circulation fan switched on/off through Raspberry Pi GPIO"
]

// ===========================
// Sensing Components (C3)
// ===========================
instance AirTempSensorInBox1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted inside the incubator to measure air temperature"
    DTDFVocab:producedData TemperatureDataTransmittedInBox1
]

instance AirTempSensorInBox2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted inside the incubator to measure air temperature (second point)"
    DTDFVocab:producedData TemperatureDataTransmittedInBox2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer placed external to the incubator to measure room temperature"
    DTDFVocab:producedData TemperatureDataTransmittedAmbient
]

// ===========================
// Data Transmitted (C4)
// ===========================
instance TemperatureDataTransmittedInBox1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirTempSensorInBox1
]

instance TemperatureDataTransmittedInBox2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirTempSensorInBox2
]

instance TemperatureDataTransmittedAmbient : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// ===========================
// Data (C5)
// ===========================
instance TemperatureMeasurementInBox1 : DTDFVocab:Data [
    base:desc "Raw temperature measurement (°C) read from AirTempSensorInBox1"
    DTDFVocab:fromData TemperatureDataTransmittedInBox1
    DTDFVocab:inputTo RabbitMQBroker
]

instance TemperatureMeasurementInBox2 : DTDFVocab:Data [
    base:desc "Raw temperature measurement (°C) read from AirTempSensorInBox2"
    DTDFVocab:fromData TemperatureDataTransmittedInBox2
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTemperatureMeasurement : DTDFVocab:Data [
    base:desc "Raw temperature measurement (°C) read from AmbientTempSensor"
    DTDFVocab:fromData TemperatureDataTransmittedAmbient
    DTDFVocab:inputTo RabbitMQBroker
]

// ===========================
// Enablers (C11)
// ===========================
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker (AMQP over TCP/IP) used for publishing sensor measurements and actuator status"
    DTDFVocab:enables RealTimeMonitoringService
]

instance PythonControlLogic : DTDFVocab:Enabler [
    base:desc "Python code running on the Raspberry Pi that consumes data from RabbitMQ, runs simulation, and executes decisions"
    DTDFVocab:enables TemperatureSimulationService
    DTDFVocab:enables SafetyCheckService
    DTDFVocab:enables OptimalityCheckService
]

instance SciPyCalibrationEngine : DTDFVocab:Enabler [
    base:desc "SciPy optimisation package employed for nonlinear least‑squares calibration of thermal model parameters"
    DTDFVocab:enables ParameterCalibrationService
]

// ===========================
// Services (C6)
// ===========================
instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Model‑based temperature simulation using analytical thermal models"
    DTDFVocab:provides TemperaturePredictionInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibration of model parameters (C_air, G_box, C_heater, G_heater) via nonlinear least‑squares optimisation"
    DTDFVocab:provides CalibrationResultInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of temperature measurements received from the incubator"
    DTDFVocab:provides TemperatureAlertInsight
]

instance SafetyCheckService : DTDFVocab:Service [
    base:desc "Generation of alerts and automatic safety actions when temperature exceeds defined limits"
    DTDFVocab:provides SafetyShutdownAction
]

instance OptimalityCheckService : DTDFVocab:Service [
    base:desc "Assessment of operational optimality based on calibrated model predictions"
    DTDFVocab:provides OptimalOperationInsight
]

// ===========================
// Insights (C17)
// ===========================
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory of the incubator generated by the simulation service"
]

instance CalibrationResultInsight : DTDFVocab:Insight [
    base:desc "Updated model parameters (C_air, G_box, C_heater, G_heater) after calibration"
]

instance TemperatureAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when measured temperature exceeds predefined safety thresholds"
]

instance OptimalOperationInsight : DTDFVocab:Insight [
    base:desc "Recommendation for optimal heating set‑points derived from calibrated model output"
]

// ===========================
// Actions (C17)
// ===========================
instance SafetyShutdownAction : DTDFVocab:Action [
    base:desc "Automatic shutdown of the heat‑bed to protect the incubator from overheating"
    DTDFVocab:IsAutomatic true
]

// ===========================
// Models (C10)
// ===========================
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model with single capacitance C_air and conductance G_box"
    DTDFVocab:inputTo PythonControlLogic
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Analytical thermal model adding heat‑bed dynamics with C_heater, G_heater and G_box"
    DTDFVocab:inputTo PythonControlLogic
    DTDFVocab:inputTo SciPyCalibrationEngine
]

// ===========================
// Calibrated Parameters Data (C5)
// ===========================
instance CalibrationResultDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ParameterCalibrationService
]

instance CalibratedParametersData : DTDFVocab:Data [
    base:desc "Calibrated thermal model parameters C_air, G_box, C_heater, G_heater"
    DTDFVocab:fromData CalibrationResultDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

// ===========================
// Actuator Status Data (C5)
// ===========================
instance HeatBedStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatBedActuator
]

instance FanStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FanActuator
]

instance HeatBedStatusData : DTDFVocab:Data [
    base:desc "Current ON/OFF status of the heat‑bed actuator"
    DTDFVocab:fromData HeatBedStatusDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

instance FanStatusData : DTDFVocab:Data [
    base:desc "Current ON/OFF status of the circulation fan actuator"
    DTDFVocab:fromData FanStatusDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital‑twin components subscribe to the RabbitMQ broker and publish command messages (e.g., turn heat‑bed on/off, set fan state) which are received by the controller on the Raspberry Pi and enacted through the PCB drivers."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture comprises the physical incubator components, a Raspberry Pi‑hosted controller, a low‑level driver, a RabbitMQ broker that mediates messages, and DT modules (simulation, calibration, monitoring) that subscribe to the broker. This arrangement follows the schematic shown in Fig. 1 and Fig. 7 of the paper."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing simulated temperature curves against experimentally measured data; calibration minimises the residual error between model output and sensor data. Uniformity of temperature inside the box is experimentally verified with three sensors, showing a maximum deviation of 6–7 °C. Model B demonstrated higher accuracy for predicting the heat‑bed thermal inertia."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "DT components communicate via the RabbitMQ message broker using the AMQP protocol over a TCP/IP network; the broker runs on the same Raspberry Pi that hosts the controller and low‑level driver."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The communication server (RabbitMQ) and the controller software are deployed directly on the Raspberry Pi 4 Model B that is part of the physical incubator; DT services can run on the same device or on external machines that connect to the broker."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the device in a safe state, and the DT includes monitors that check whether the system operates within predefined temperature bounds, enabling safety interventions when violations are detected."
]