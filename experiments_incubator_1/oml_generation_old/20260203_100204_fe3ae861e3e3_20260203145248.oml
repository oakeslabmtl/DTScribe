instance VehicleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors on the Physical Twin collect data over time."
    DTDFVocab:producedData VehicleSensorDataStream
]

instance VehicleSensorDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSensor
]

instance VehicleSensorTimeSeriesData : DTDFVocab:Data [
    base:desc "Time-series observations harvested continuously from the Physical Twin via onboard sensors."
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, SimulationEnabler, FaultDetectionEnabler, StateEstimationEnabler, OptimizationEnabler
    DTDFVocab:fromData VehicleSensorDataStream
]

instance VehicleGeometricModel : DTDFVocab:Model [
    base:desc "CAD model of a vehicle describing wheel sizes, chassis shape, and styling."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler
]

instance VehicleBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model constructed from differential equations to capture system dynamics."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler, OptimizationEnabler
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm continually refines model parameters based on time‑series sensor data."
    DTDFVocab:enables CalibrationService
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that updates model parameters based on real‑time sensor data."
    DTDFVocab:provides CalibrationInsight
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Indicates updated model parameters reflecting the latest physical reality."
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring enabler analyzes model outputs and sensor data to verify safety and operational optimality."
    DTDFVocab:enables MonitoringService
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that verifies safety and operational optimality, and can trigger corrective actions."
    DTDFVocab:provides SafetyCheckInsight, CorrectiveAction, HumanDecisionAction
]

instance SafetyCheckInsight : DTDFVocab:Insight [
    base:desc "Insight that verifies safety and operational optimality based on model outputs and sensor data."
]

instance CorrectiveAction : DTDFVocab:Action [
    base:desc "Automatic correction of device or system states to restore safety or performance."
    DTDFVocab:IsAutomatic true
]

instance HumanDecisionAction : DTDFVocab:Action [
    base:desc "Human‑initiated decision to address identified issues."
    DTDFVocab:IsAutomatic false
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation enabler generates forecasts of the PT's future behavior under current operating conditions."
    DTDFVocab:enables PredictiveSimulationService
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Service that generates forecasts of the PT's future behavior."
    DTDFVocab:provides FutureBehaviorInsight
]

instance FutureBehaviorInsight : DTDFVocab:Insight [
    base:desc "Forecast of the PT's future behavior under current operating conditions."
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Fault detection enabler identifies anomalies or deviations from expected behavior."
    DTDFVocab:enables FaultDetectionService
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service that identifies anomalies or deviations and initiates recovery strategies."
    DTDFVocab:provides FaultDetectionInsight, ComponentFailurePredictionInsight
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of anomalies or deviations from expected behavior."
]

instance ComponentFailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Prediction of component failures based on anomaly detection."
]

instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "State estimation enabler fuses data to compute internal states."
    DTDFVocab:enables StateEstimationService
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Service that computes internal states from noisy sensor inputs."
    DTDFVocab:provides StateEstimationInsight
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated internal states of the Physical Twin computed from noisy sensor inputs."
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimization enabler iteratively adjusts system parameters or operating points."
    DTDFVocab:enables OptimizationService
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that proposes best action sets or operating points to improve performance metrics."
    DTDFVocab:provides OptimizationInsight, OptimalOperatingPointInsight
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Proposed best action sets or operating points to improve performance metrics such as energy efficiency or throughput."
]

instance OptimalOperatingPointInsight : DTDFVocab:Insight [
    base:desc "Optimal operating point determined by optimization algorithms."
]

instance SupervisoryControlEnabler : DTDFVocab:Enabler [
    base:desc "Supervisory controller enabler enforces safety limits or initiates recovery strategies."
    DTDFVocab:enables SupervisoryControlService
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Service that enforces safety limits or initiates recovery strategies."
    DTDFVocab:provides ControlAction
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Control command issued by supervisory controller to enforce safety limits."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Development: models (e.g., CAD for static geometry and dynamic differential‑equation models) are built to understand specific aspects of the system. Deployment: these models are retained and integrated into a Digital Twin framework. Representation: static CAD structures, dynamic simulation models, and parameterised models are utilised. Transition: calibration algorithms adjust model parameters based on sensor data collected from the Physical Twin, aligning the digital representation with reality. Lifecycle governance: safety monitors evaluate model outputs against operational thresholds; violations trigger human or algorithmic intervention, forming an implicit governance loop."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin employs calibration algorithms to adjust model parameters based on collected data, suggesting a continuous model‑validation loop. However, explicit fidelity requirements, validation and verification procedures, uncertainty sources, error detection and correction mechanisms, or quality assurance processes for models and data are not detailed in the document."
]