// C17: Insights
instance ModelBasedPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory generated by Model A or Model B"
]

instance ModelParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Updated thermal model parameters (C_air, C_heater, G_box, G_heater) after calibration"
]

instance CurrentTemperatureInsight : DTDFVocab:Insight [
    base:desc "Current measured temperatures from the three DS18S20 sensors"
]

instance TemperatureLimitViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature exceeding defined lower or upper limits"
]

// C17: Actions
instance HeatBedToggleAction : DTDFVocab:Action [
    base:desc "Turns the heat‑bed ON or OFF according to bang‑bang control logic",
    DTDFVocab:IsAutomatic true
]

instance FanToggleAction : DTDFVocab:Action [
    base:desc "Turns the fan ON or OFF according to bang‑bang control logic",
    DTDFVocab:IsAutomatic true
]

// C6: Services
instance ModelBasedPredictionService : DTDFVocab:Service [
    base:desc "Provides model‑based temperature prediction using Model A (2 free parameters) and Model B (4 free parameters)",
    DTDFVocab:provides ModelBasedPredictionInsight
]

instance OnlineCalibrationService : DTDFVocab:Service [
    base:desc "Performs online calibration of model parameters via non‑linear least‑squares optimisation (SciPy)",
    DTDFVocab:provides ModelParameterUpdateInsight
]

instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of internal and ambient temperatures",
    DTDFVocab:provides CurrentTemperatureInsight
]

instance SafetyCheckingService : DTDFVocab:Service [
    base:desc "Checks measured temperatures against lower/upper limits (LL/UL) and raises violations",
    DTDFVocab:provides TemperatureLimitViolationInsight
]

instance ActuationDecisionService : DTDFVocab:Service [
    base:desc "Bang‑bang controller decides heating duration H and waiting duration C and issues actuation commands",
    DTDFVocab:provides HeatBedToggleAction,
    DTDFVocab:provides FanToggleAction
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "AMQP message broker (RabbitMQ) that ingests data streams and forwards them to DT services",
    DTDFVocab:enables ModelBasedPredictionService,
    DTDFVocab:enables OnlineCalibrationService,
    DTDFVocab:enables TemperatureMonitoringService,
    DTDFVocab:enables SafetyCheckingService,
    DTDFVocab:enables ActuationDecisionService
]

// C3: Physical sensing components
instance BoxInternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor inside the incubator (range –55 °C to +125 °C, 0.5 °C accuracy 10‑85 °C)",
    DTDFVocab:producedData BoxInternalTempDataTransmittedA
]

instance BoxInternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor inside the incubator (second node, same specs as sensor A)",
    DTDFVocab:producedData BoxInternalTempDataTransmittedB
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor measuring ambient temperature outside the incubator",
    DTDFVocab:producedData AmbientTempDataTransmitted
]

instance ActuatorStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Low‑level driver on the Raspberry Pi reporting heat‑bed and fan states to RabbitMQ",
    DTDFVocab:producedData ActuatorStatusDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance BoxInternalTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxInternalTempSensorA
]

instance BoxInternalTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxInternalTempSensorB
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

instance ActuatorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ActuatorStatusSensor
]

// C10: Data
instance BoxInternalTempDataA : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from internal sensor A",
    DTDFVocab:fromData BoxInternalTempDataTransmittedA,
    DTDFVocab:inputTo RabbitMQBroker
]

instance BoxInternalTempDataB : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from internal sensor B",
    DTDFVocab:fromData BoxInternalTempDataTransmittedB,
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Timestamped ambient temperature reading",
    DTDFVocab:fromData AmbientTempDataTransmitted,
    DTDFVocab:inputTo RabbitMQBroker
]

instance ActuatorStateData : DTDFVocab:Data [
    base:desc "Current ON/OFF states of heat‑bed and fan as reported by the driver",
    DTDFVocab:fromData ActuatorStatusDataTransmitted,
    DTDFVocab:inputTo RabbitMQBroker
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin publishes control commands (heat‑bed ON/OFF, fan ON/OFF or voltage level) to RabbitMQ. The controller on the Raspberry Pi subscribes to these messages, interprets them, and drives the MOSFET/optocoupler circuit on the PCB to actuate the physical devices."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sensor acquisition and message publishing occur at a sub‑second to second rate (fan circulates the box air in ≈2 s; controller statechart defines heating duration H and waiting duration C on the order of seconds). Model prediction and calibration are performed offline or on‑demand, while monitoring runs continuously during operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation consists of the physical incubator hardware, a low‑level driver, a controller, and a RabbitMQ server running on the same Raspberry Pi. DT components (e.g., model executor, calibration routine) subscribe to the broker, process PT data, and publish control commands, forming a closed feedback loop as illustrated in Figure 7."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is employed during the operation stage of the incubator to monitor temperature, calibrate models, and generate control actions; the design and manufacturing stages are represented only by the hardware description and open‑source repository."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity relies on four assumptions (uniform temperature, negligible wall heat, constant air specific heat, negligible heater/fan heat loss). Validity is examined through uniformity experiments (max temperature discrepancy 6–7 °C) and calibration experiments minimizing residual error via least‑squares. Model B includes heater inertia, improving prediction of thermal inertia."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses the AMQP protocol via RabbitMQ on the Raspberry Pi, with Wi‑Fi/Bluetooth providing network connectivity. Sensor data travels over the 1‑Wire bus; actuator commands are sent over GPIO to MOSFET drivers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT software components (RabbitMQ broker, low‑level driver, controller, calibration scripts) are hosted on the Raspberry Pi 4 Model B, which also powers the PT. No external cloud or server is described."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safety protocol that ensures the incubator remains in a safe state (e.g., preventing overheating) and isolates control signals via optocouplers. No further security standards are specified."
]