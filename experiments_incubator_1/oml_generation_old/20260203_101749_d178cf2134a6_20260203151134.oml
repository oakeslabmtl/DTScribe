// C1: Primary Twin Instances // Return code: 1 | Stderr:
instance IncubatorPhysicalTwin : DTDFVocab:Component [
    base:desc "Real-world incubator system built on a Raspberry Pi 4, insulated Styrofoam box, heatbed, fan, and temperature sensing."
]

instance IncubatorVirtualTwin : DTDFVocab:Component [
    base:desc "Digital twin comprising two thermal state‑space models (ModelAThermal and ModelBThermal) and data streams."
]

// C2: Acting Components
instance HeatbedHeater : DTDFVocab:ActingComponent [
    base:desc "MOSFET‑controlled heater powered by the Raspberry Pi controller."
]

instance FanMotor : DTDFVocab:ActingComponent [
    base:desc "PWM‑driven fan regulated via an optocoupler, controlled by the Raspberry Pi."
]

// C3: Physical sensing components
instance InsideTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor positioned at the front of the incubator."
    DTDFVocab:producedData TempDataFromSensor1
]

instance InsideTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor positioned at the rear of the incubator."
    DTDFVocab:producedData TempDataFromSensor2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor placed outside the incubator to record ambient room temperature."
    DTDFVocab:producedData TempDataFromAmbient
]

// C4: Physical-to-virtual interaction
instance TempDataFromSensor1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensor1
]

instance TempDataFromSensor2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensor2
]

instance TempDataFromAmbient : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// C10: Models/Data
instance InsideTemperatureData1 : DTDFVocab:Data [
    base:desc "Time‑stamped internal temperature data stream from InsideTempSensor1."
    DTDFVocab:fromData TempDataFromSensor1
    DTDFVocab:inputTo RabbitMQBroker
]

instance InsideTemperatureData2 : DTDFVocab:Data [
    base:desc "Time‑stamped internal temperature data stream from InsideTempSensor2."
    DTDFVocab:fromData TempDataFromSensor2
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped ambient room temperature data stream from AmbientTempSensor."
    DTDFVocab:fromData TempDataFromAmbient
    DTDFVocab:inputTo RabbitMQBroker
]

instance ModelAThermal : DTDFVocab:Model [
    base:desc "Thermal state‑space model A with parameters (C_air, G_box, G_heater, C_heater) used for prediction."
    DTDFVocab:inputTo RabbitMQBroker
]

instance ModelBThermal : DTDFVocab:Model [
    base:desc "Thermal state‑space model B with alternative parameterization, compared against Model A."
    DTDFVocab:inputTo RabbitMQBroker
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker handling data flow between physical sensors and virtual models."
    DTDFVocab:enables RealTimeMonitoringService, ThermalModelPredictionService, CalibrationService, FaultDetectionService, SupervisoryBangBangControlService, OptimizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring and visualization of temperature data streams."
    DTDFVocab:provides TemperatureMonitoringInsight
]

instance ThermalModelPredictionService : DTDFVocab:Service [
    base:desc "Model‑based temperature prediction using ModelAThermal and ModelBThermal."
    DTDFVocab:provides PredictionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration and parameter estimation of thermal models using experimental temperature series."
    DTDFVocab:provides CalibrationResultInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detection of anomalies such as sensor failures or actuator malfunctions."
    DTDFVocab:provides FaultAlert
]

instance SupervisoryBangBangControlService : DTDFVocab:Service [
    base:desc "Bang‑bang supervisory control of heater and fan based on temperature telemetry."
    DTDFVocab:provides BangBangControlAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Future optimization of heating and fan strategies for energy efficiency."
    DTDFVocab:provides OptimizationAction
]

// C17: Insights/Actions
instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Visualization of current incubator temperature and trend analysis."
]

instance PredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted future temperature curves from thermal models."
]

instance CalibrationResultInsight : DTDFVocab:Insight [
    base:desc "Insight revealing which thermal model better captures heatbed inertia."
]

instance ModelComparisonInsight : DTDFVocab:Insight [
    base:desc "Comparison between ModelAThermal and ModelBThermal prediction accuracy."
]

instance FaultAlert : DTDFVocab:Insight [
    base:desc "Alert when sensor data deviates from expected ranges or actuator status is abnormal."
]

instance BangBangControlAction : DTDFVocab:Action [
    base:desc "Automatic on/off control of heater and fan to maintain desired temperature setpoints."
    DTDFVocab:IsAutomatic true
]

instance OptimizationAction : DTDFVocab:Action [
    base:desc "Proposed adjustments to heating and fan operations for reduced energy consumption."
    DTDFVocab:IsAutomatic false
]

// C7: Components
instance Heatbed : DTDFVocab:Component [
    base:desc "Metal heatbed providing uniform heating surface for the incubated items."
]

instance Fan : DTDFVocab:Component [
    base:desc "Ventilation fan ensuring air circulation within the incubator."
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 acting as the central controller for sensors and actuators."
]

// C18: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains Heatbed, Fan, RaspberryPiController, InsideTempSensor1, InsideTempSensor2, AmbientTempSensor, HeatbedHeater, FanMotor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT generates model‑based predictions and control commands (e.g., heating duration, fan ON/OFF) that are sent via RabbitMQ to the controller, which drives the MOSFET switches to act on the heatbed and fan."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "DT operates in near real‑time with the PT, exchanging sensor data and control commands every few seconds via RabbitMQ; offline calibration and parameter optimization are performed on a separate batch timescale."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "PT consisting of hardware (heatbed, fan, sensors, Raspberry Pi) with firmware for low‑level driver and controller; DT comprising the same communication interface, calibrated thermal models, monitoring, and visualization components running on the same or remote host, all orchestrated via RabbitMQ."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (ideal specification), manufacturing (assembling Raspberry Pi, PCB, sensors, enclosure), and operation/maintenance (running the incubator under the DT’s supervision)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model calibration via nonlinear least‑squares, comparison of simulated trajectories with measured data, experimental validation of assumptions such as uniform temperature and heat loss; accuracy limited by sensor precision and model assumptions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Connection between DT and PT is achieved through RabbitMQ over Wi‑Fi/ethernet using TCP; sensors communicate over 1‑wire bus, actuators via MOSFETs; messages typically contain JSON payloads."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components run locally on the Raspberry Pi hardware; the design and code are open source and can be deployed on a single host or a remote server if desired."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver implements a safe protocol to keep the device in a safe state; RabbitMQ ensures message reliability; no explicit mention of encryption, access control, or enforcement of safety during remote execution, thus safety responsibilities rely on controller logic."
]