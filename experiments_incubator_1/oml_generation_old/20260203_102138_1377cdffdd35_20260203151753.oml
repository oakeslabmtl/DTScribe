// --------- Physical Sensing Components ----------
instance InsideBoxTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire temperature sensor inside the insulated box for air temperature monitoring (sensor 1)."
    DTDFVocab:producedData InsideBoxTemperatureData1
]

instance InsideBoxTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire temperature sensor inside the insulated box for air temperature monitoring (sensor 2)."
    DTDFVocab:producedData InsideBoxTemperatureData2
]

instance OutsideRoomTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire temperature sensor outside the box for room temperature monitoring."
    DTDFVocab:producedData OutsideRoomTemperatureData
]

// --------- Data Transmitted from Sensors ----------
instance InsideBoxTemperatureData1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideBoxTemperatureSensor1
]

instance InsideBoxTemperatureData2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideBoxTemperatureSensor2
]

instance OutsideRoomTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideRoomTemperatureSensor
]

// --------- Physical Acting Components ----------
instance HeatbedHeatingElement : DTDFVocab:ActingComponent [
    base:desc "Heatbed heating element controlled via MOSFETs and optocouplers driven by the Raspberry Pi 4."
    DTDFVocab:producedData HeatbedStateData
]

instance FanMotor : DTDFVocab:ActingComponent [
    base:desc "Fan motor for airflow control within the insulated box, driven by MOSFETs and optocouplers."
    DTDFVocab:producedData FanStateData
]

// --------- Data Transmitted from Actuators ----------
instance HeatbedStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatbedHeatingElement
]

instance FanStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FanMotor
]

// --------- Measurement Data Instances ----------
instance InsideBoxTemperatureMeasurement1 : DTDFVocab:Data [
    base:desc "Raw temperature measurement from InsideBoxTemperatureSensor1."
    DTDFVocab:fromData InsideBoxTemperatureData1
    DTDFVocab:inputTo DataAcquisitionDriver
]

instance InsideBoxTemperatureMeasurement2 : DTDFVocab:Data [
    base:desc "Raw temperature measurement from InsideBoxTemperatureSensor2."
    DTDFVocab:fromData InsideBoxTemperatureData2
    DTDFVocab:inputTo DataAcquisitionDriver
]

instance OutsideRoomTemperatureMeasurement : DTDFVocab:Data [
    base:desc "Raw temperature measurement from OutsideRoomTemperatureSensor."
    DTDFVocab:fromData OutsideRoomTemperatureData
    DTDFVocab:inputTo DataAcquisitionDriver
]

instance HeatbedStateMeasurement : DTDFVocab:Data [
    base:desc "Measured state of the heatbed heating element (ON/OFF)."
    DTDFVocab:fromData HeatbedStateData
    DTDFVocab:inputTo RabbitMQBrokerEnabler
]

instance FanStateMeasurement : DTDFVocab:Data [
    base:desc "Measured state of the fan motor (ON/OFF)."
    DTDFVocab:fromData FanStateData
    DTDFVocab:inputTo RabbitMQBrokerEnabler
]

// --------- Enablers ----------
instance DataAcquisitionDriver : DTDFVocab:Enabler [
    base:desc "Low-level driver on the Raspberry Pi 4 that polls DS18S20 sensors and forwards data to RabbitMQ."
    DTDFVocab:enables TemperatureAcquisitionService
]

instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker over TCP/IP that exchanges sensor data and actuator states."
    DTDFVocab:enables ContinuousMonitoringService, OnlineParameterCalibrationService, BangBangControlService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that executes calibrated thermal models for simulation."
    DTDFVocab:enables SimulationServiceModelA, SimulationServiceModelB
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that performs nonlinear least-squares calibration of thermal model parameters."
    DTDFVocab:enables OnlineParameterCalibrationService
]

// --------- Models ----------
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Temperature dynamics model with parameters C_air and G_box."
    DTDFVocab:inputTo SimulationEnabler, CalibrationEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Temperature dynamics model with parameters C_air, C_heater, G_heater, G_box."
    DTDFVocab:inputTo SimulationEnabler, CalibrationEnabler
]

// --------- Services ----------
instance TemperatureAcquisitionService : DTDFVocab:Service [
    base:desc "Collects raw temperature measurements from DS18S20 sensors via DataAcquisitionDriver."
    DTDFVocab:provides DataCollectionInsight
]

instance ContinuousMonitoringService : DTDFVocab:Service [
    base:desc "Continuously monitors DT operation using RabbitMQ data streams."
    DTDFVocab:provides RealTimeTemperatureTrendInsight, PerformanceVisibilityInsight
]

instance OnlineParameterCalibrationService : DTDFVocab:Service [
    base:desc "Performs online calibration of model parameters using nonlinear least-squares."
    DTDFVocab:provides ParameterEstimationInsight, ThermalInertiaPredictionInsight
]

instance BangBangControlService : DTDFVocab:Service [
    base:desc "Implements a bang-bang controller that enforces temperature limits."
    DTDFVocab:provides BangBangControllerAction
]

instance SimulationServiceModelA : DTDFVocab:Service [
    base:desc "Simulates temperature dynamics using calibrated ThermalModelA."
    DTDFVocab:provides SimulationPredictionInsightA
]

instance SimulationServiceModelB : DTDFVocab:Service [
    base:desc "Simulates temperature dynamics using calibrated ThermalModelB."
    DTDFVocab:provides SimulationPredictionInsightB
]

// --------- Insights ----------
instance DataCollectionInsight : DTDFVocab:Insight [
    base:desc "Provides visibility into raw sensor data collection status and quality."
]

instance RealTimeTemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Real-time temperature trends across the insulated box and the room."
]

instance ParameterEstimationInsight : DTDFVocab:Insight [
    base:desc "Latest parameter estimates for system thermal models derived via least-squares."
]

instance ThermalInertiaPredictionInsight : DTDFVocab:Insight [
    base:desc "Predictions of thermal inertia based on current model parameters."
]

instance PerformanceVisibilityInsight : DTDFVocab:Insight [
    base:desc "Visibility into overall system performance for operators."
]

instance SimulationPredictionInsightA : DTDFVocab:Insight [
    base:desc "Simulation prediction of temperature dynamics using ModelA."
]

instance SimulationPredictionInsightB : DTDFVocab:Insight [
    base:desc "Simulation prediction of temperature dynamics using ModelB."
]

// --------- Actions ----------
instance BangBangControllerAction : DTDFVocab:Action [
    base:desc "Bang-bang control action to enforce temperature limits on the heatbed and fan."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands (heatbed on/off, fan on/off) to the Raspberry Pi controller via RabbitMQ messages, which the low‑level driver forwards to the heatbed and fan circuits."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data acquisition and control updates occur at a sampling interval of a few seconds (set by the low‑level driver polling), while the simulation and calibration calculations run in real‑time with the same granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Hardware: heatbed, fan, sensors, Raspberry Pi controller. Software: low‑level driver, communication server (RabbitMQ), bang‑bang controller, simulation models, calibration engine. All orchestrated on the Pi with messages exchanged via AMQP."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design and model building → Calibration and validation experiments → Deployment of the twin on the Pi → Operational monitoring and online parameter updates; the DT represents the as‑operated state of the PT."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Assumptions of uniform internal temperature, negligible heat flux into walls, constant specific heat of air, and that electrical power goes to heatbody; validation performed by comparing simulated temperature traces to experimental measurements and minimizing residual error."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "RabbitMQ running on the Raspberry Pi, communicating via AMQP over TCP/IP to the low‑level driver; sensors connected over 1‑Wire bus; MOSFETs and optocouplers provide electrical isolation between Pi and high‑current circuits."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital twin components (communication server, controller, simulation, calibration) are deployed locally on the Raspberry Pi 4 that physically hosts the PT; the system operates on the local network or via Wi‑Fi."
]