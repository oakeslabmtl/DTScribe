// Acting Components
instance HeatbedPadHeater : DTDFVocab:ActingComponent [
    base:desc "MOSFET controlled heatbed pad on the incubator's base"
]

instance AirCirculationFan : DTDFVocab:ActingComponent [
    base:desc "12/24 V fan that circulates air within the insulated Styrofoam box"
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running the low‑level driver for sensor polling and RabbitMQ publishing"
]

instance PowerSupplyComponent : DTDFVocab:Component [
    base:desc "Power supply that feeds the RS Pi, MOSFET driver, and heater"
]

instance CustomPCB : DTDFVocab:Component [
    base:desc "Custom PCB with MOSFETs and optocouplers that interface the Raspberry Pi GPIO to the heater and fan"
]

// Physical sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor inside the Styrofoam box (sensor 1), serial code: 00:1B:44:11:3A:B7"
    DTDFVocab:producedData InternalTempTelemetry1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor inside the Styrofoam box (sensor 2), serial code: 00:1C:44:22:4B:C8"
    DTDFVocab:producedData InternalTempTelemetry2
]

instance ExternalAmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor outside the Styrofoam box, serial code: 00:1D:44:33:5C:D9"
    DTDFVocab:producedData AmbientTempTelemetry
]

// Data transmitted via RabbitMQ broker
instance InternalTempTelemetry1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempTelemetry2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance AmbientTempTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalAmbientTempSensor
]

// Raw data received by the twin
instance InternalTemperatureData1 : DTDFVocab:Data [
    base:desc "Raw temperature reading from internal sensor 1"
    DTDFVocab:inputTo RealTimeSimulationEnabler, CalibrationEnabler, MonitoringEnabler
    DTDFVocab:fromData InternalTempTelemetry1
]

instance InternalTemperatureData2 : DTDFVocab:Data [
    base:desc "Raw temperature reading from internal sensor 2"
    DTDFVocab:inputTo RealTimeSimulationEnabler, CalibrationEnabler, MonitoringEnabler
    DTDFVocab:fromData InternalTempTelemetry2
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Raw ambient temperature reading from external sensor"
    DTDFVocab:inputTo RealTimeSimulationEnabler, CalibrationEnabler, MonitoringEnabler
    DTDFVocab:fromData AmbientTempTelemetry
]

// Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Temperature prediction model A parameterized by the ambient air specific heat capacity C_air"
    DTDFVocab:inputTo RealTimeSimulationEnabler, OptimizationEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Temperature prediction model B parameterized by C_air, G_box, G_heater, and C_heater"
    DTDFVocab:inputTo RealTimeSimulationEnabler, OptimizationEnabler
]

// Enablers
instance RealTimeSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python + Scipy computational engine that runs real‑time temperature simulations using Model A and Model B"
    DTDFVocab:enables RealTimeSimulationService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Non‑linear least‑squares optimizer that calibrates Model A and Model B parameters against experimental data"
    DTDFVocab:enables CalibrationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Runtime monitor that evaluates temperature compliance against user‑defined constraints"
    DTDFVocab:enables MonitoringService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimization engine that determines optimal heating and fan duty cycles based on calibrated models"
    DTDFVocab:enables OptimizationService
]

instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ broker that provides AMQP based interfaces for data ingestion and actuation commands"
    DTDFVocab:enables RealTimeSimulationService, CalibrationService, MonitoringService, OptimizationService
]

// Services
instance RealTimeSimulationService : DTDFVocab:Service [
    base:desc "Real‑time temperature forecasting service using the calibrated parametric models"
    DTDFVocab:provides RealTimeTemperaturePredictionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that calibrates the thermal models via non‑linear least‑squares optimization"
    DTDFVocab:provides CalibratedModelParametersInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that continuously checks temperature compliance and issues alerts"
    DTDFVocab:provides TemperatureComplianceAlertInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that generates optimal heating schedules and duty cycles for the heater and fan"
    DTDFVocab:provides OptimizationRecommendationInsight
    DTDFVocab:provides StartHeatbedPadAction
    DTDFVocab:provides StopHeatbedPadAction
    DTDFVocab:provides StartAirCirculationFanAction
    DTDFVocab:provides StopAirCirculationFanAction
]

// Insights
instance CalibratedModelParametersInsight : DTDFVocab:Insight [
    base:desc "Output of the calibration service containing calibrated parameters for Model A and Model B"
]

instance RealTimeTemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Real‑time temperature predictions generated by the twin’s simulation engine"
]

instance TemperatureComplianceAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when the incubator’s temperature deviates from user‑defined constraints"
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommended optimal heating and fan duty cycles to meet target temperature profiles"
]

// Actions (commands sent via RabbitMQ)
instance StartHeatbedPadAction : DTDFVocab:Action [
    base:desc "Command to turn ON the heatbed pad"
    DTDFVocab:IsAutomatic true
]

instance StopHeatbedPadAction : DTDFVocab:Action [
    base:desc "Command to turn OFF the heatbed pad"
    DTDFVocab:IsAutomatic true
]

instance StartAirCirculationFanAction : DTDFVocab:Action [
    base:desc "Command to turn ON the air circulation fan"
    DTDFVocab:IsAutomatic true
]

instance StopAirCirculationFanAction : DTDFVocab:Action [
    base:desc "Command to turn OFF the air circulation fan"
    DTDFVocab:IsAutomatic true
]

// Environment (physical twin)
instance IncubatorPhysicalEnvironment : DTDFVocab:Environment [
    base:contains HeatbedPadHeater, AirCirculationFan,
                InternalTempSensor1, InternalTempSensor2, ExternalAmbientTempSensor,
                RaspberryPiController, PowerSupplyComponent, CustomPCB
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin publishes control commands (e.g., heatbed on/off, fan on/off, heating and waiting durations) via RabbitMQ messages to the controller module on the Pi; the controller forwards these commands to the GPIO outputs that drive the MOSFETs, thereby actuating the physical twin."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of a local RabbitMQ AMQP broker, a low‑level driver module on the Pi, a Bang‑Bang controller module, and a simulation‑/optimization module; all components communicate over AMQP, with the Pi providing Wi‑Fi/Bluetooth network connectivity."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through assumptions of uniform temperature, negligible heat conduction to the box walls, constant air heat capacity, and ignoring fan heat; sensor accuracy is 0.5 °C between –10 °C and +85 °C; calibration reduces parameter uncertainty, and validation compares simulated trajectories to experimental data with a maximum discrepancy of less than 7 °C."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data flows from PT to DT via a 1‑Wire DS18S20 sensor bus attached to the Pi’s GPIO; commands flow from DT to PT through AMQP messages sent over RabbitMQ on the local network. The low‑level driver isolates GPIO outputs with optocouplers and drives MOSFETs to actuate the heater and fan."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All Digital Twin components run on the Raspberry Pi 4 Model B: the RabbitMQ broker, Python-based simulation, calibration, and control modules. The Pi provides Wi‑Fi and Bluetooth for network access, and can host a containerised deployment for the entire twin stack."
]