// D1: Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor monitoring the Physical Twin's operating temperature"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Pressure sensor monitoring the Physical Twin's operating pressure"
    DTDFVocab:producedData PressureDataTransmitted
]

// D4: Data Transmitted
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

// D10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements streamed from the Physical Twin"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DataAcquisitionLayer, CalibrationAlgorithm
]

instance PressureData : DTDFVocab:Data [
    base:desc "Time‑stamped pressure measurements streamed from the Physical Twin"
    DTDFVocab:fromData PressureDataTransmitted
    DTDFVocab:inputTo DataAcquisitionLayer, CalibrationAlgorithm
]

// D10: Models
instance CyberPhysicalModel : DTDFVocab:Model [
    base:desc "Dynamic differential equation model encapsulating cyber‑physical behavior of the Physical Twin"
    DTDFVocab:inputTo CalibrationAlgorithm
]

// C11: Enablers
instance DataAcquisitionLayer : DTDFVocab:Enabler [
    base:desc "Sensor data acquisition layer that collects time‑stamped measurements"
    DTDFVocab:enables MonitoringService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Calibration routine that iteratively adjusts model parameters to align simulated outputs with sensor data"
    DTDFVocab:enables PredictionService
]

instance MonitoringModule : DTDFVocab:Enabler [
    base:desc "Monitoring module that evaluates safety and operational constraints"
    DTDFVocab:enables MonitoringService
]

instance Optimizer : DTDFVocab:Enabler [
    base:desc "Data‑driven optimizer that suggests parameter adjustments maximizing system performance"
    DTDFVocab:enables OptimizationService
]

instance SupervisoryController : DTDFVocab:Enabler [
    base:desc "Supervisory controller that recommends or enacts interventions on the physical system"
    DTDFVocab:enables ControlService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuously assesses safety and optimal performance of the Physical Twin by ingesting live sensor data and running model‑based checks"
    DTDFVocab:provides FaultDetectionInsight, FaultCorrectionAction
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Executes physics‑based simulations to reproduce and predict future behavior of the twin under current operating conditions"
    DTDFVocab:provides PredictionInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Applies data‑driven techniques to suggest parameter adjustments maximizing system performance"
    DTDFVocab:provides OptimizationInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Recommends or enacts interventions on the Physical Twin based on model calibrations, supervisory controllers, and state estimators"
    DTDFVocab:provides ControlAction
]

// C17: Insights
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identifies faults in the Physical Twin based on sensor data and model predictions"
]

instance PredictionInsight : DTDFVocab:Insight [
    base:desc "Forecasts future operating conditions and potential deviations from expected behavior"
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommends parameter adjustments to maximize system performance while maintaining safety"
]

// C17: Actions
instance FaultCorrectionAction : DTDFVocab:Action [
    base:desc "Applies automated corrective intervention when a fault is detected"
    DTDFVocab:IsAutomatic true
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Manually or automatically enacts control signals on the Physical Twin to maintain desired operation"
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is implemented as an integrated framework that combines three core components: (1) Data – real‑time sensor streams recorded from the Physical Twin; (2) Models – analytical or simulation models that capture the cyber and physical aspects of the system and its environment; (3) Algorithms – processes that calibrate the models using the sensor data, run optimisers and fault detectors, and generate control or supervisory actions. The framework orchestrates these components in a pipeline where calibration algorithms first update model parameters, the updated models produce predictions that are compared against live data via monitors, and any violations trigger corrective actions. This design follows a modular, layered architecture with explicit data flow and feedback loops, and is often deployed within a cloud or edge‑computing environment to manage resources and coordinate simulation workloads."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Development, validation and simulation of abstract models (CAD geometry, differential equation dynamics) followed by deployment of a Digital Twin that ingests continuous sensor data. Real‑time calibration algorithms update model parameters, and monitors compare predicted and observed behavior to ensure safety and optimality. Violations trigger human or algorithmic interventions. Governance is exercised via these monitoring loops and model update cycles."
]