]

instance ControlOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler implementing supervisory controllers (e.g., PID tuning, MPC) and optimization algorithms (e.g., gradient descent, genetic algorithms) to refine control policies and model parameters for optimal temperature regulation."
    DTDFVocab:enables ControlOptimizationService
]

instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler combining sensor data and model predictions to estimate the internal state of the incubator system, providing a coherent representation of temperature gradients and system dynamics."
