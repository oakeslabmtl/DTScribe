// C11: Enablers
instance PhysicsBasedModelingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler leveraging differential equation solvers (e.g., SciPy, MATLAB/Simulink) to simulate thermal dynamics and system behavior under varying conditions. Supports time-domain simulations for incubator temperature prediction."
    DTDFVocab:enables DynamicSimulationService, ModelCalibrationService
]

instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Enabler implementing parameter estimation techniques (e.g., least-squares, Bayesian inference) to continuously update model parameters using real-time sensor data and historical operational data. Minimizes prediction errors through iterative calibration."
    DTDFVocab:enables ModelCalibrationService, SafetyPerformanceValidationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler processing sensor data and model outputs to detect deviations from safe/optimal operating conditions. Implements algorithmic fault detectors to identify potential issues in the incubator system."
