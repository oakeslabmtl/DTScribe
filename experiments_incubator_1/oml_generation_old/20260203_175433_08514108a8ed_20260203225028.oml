]

instance CommunicationMiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "Enabler facilitating seamless communication between sensors, controllers, and simulation modules using middleware like MQTT or ROS. Supports low-latency data transmission for real-time control."
