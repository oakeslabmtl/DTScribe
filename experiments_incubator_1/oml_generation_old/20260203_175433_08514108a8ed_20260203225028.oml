]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler providing real-time dashboards (e.g., Grafana, Matplotlib) and 3D/2D schematics (e.g., CAD models) for visualizing system states, temperature profiles, control signals, and alerts."
