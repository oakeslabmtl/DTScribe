]

instance PredictiveAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Enabler generating predictive insights (e.g., temperature trends, failure probabilities) using historical data and calibrated models. Supports proactive maintenance and adaptive control strategies."
    DTDFVocab:enables PredictiveAnalyticsService
]

instance DataPreprocessingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler implementing noise reduction, normalization, and feature extraction using libraries like Pandas and NumPy. Prepares sensor data for integration into models and algorithms."
