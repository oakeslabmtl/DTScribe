// ------------------------------------------------------------
// Acting Components
// ------------------------------------------------------------

instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that provides thermal energy to the incubator chamber, driven by the Raspberry Pi controller via set‑point commands."
]

// ------------------------------------------------------------
// Physical Sensing Components
// ------------------------------------------------------------

instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer placed inside the incubator box (accuracy ±0.5 °C)."
    DTDFVocab:producedData TemperatureDataTransmittedA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer placed inside the incubator box (accuracy ±0.5 °C)."
    DTDFVocab:producedData TemperatureDataTransmittedB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "Digital temperature sensor measuring the ambient temperature outside the incubator box."
    DTDFVocab:producedData TemperatureDataTransmittedExternal
]

// ------------------------------------------------------------
// Data Transmitted (Physical → Virtual)
// ------------------------------------------------------------

instance TemperatureDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance TemperatureDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance TemperatureDataTransmittedExternal : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// ------------------------------------------------------------
// Data (Virtual)
// ------------------------------------------------------------

instance TemperatureDataA : DTDFVocab:Data [
    base:desc "Timestamped temperature measurement from InternalTempSensorA."
    DTDFVocab:fromData TemperatureDataTransmittedA
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, SimulationEnabler, OptimisationEnabler
]

instance TemperatureDataB : DTDFVocab:Data [
    base:desc "Timestamped temperature measurement from InternalTempSensorB."
    DTDFVocab:fromData TemperatureDataTransmittedB
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, SimulationEnabler, OptimisationEnabler
]

instance TemperatureDataExternal : DTDFVocab:Data [
    base:desc "Timestamped ambient temperature measurement from ExternalTempSensor."
    DTDFVocab:fromData TemperatureDataTransmittedExternal
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, SimulationEnabler, OptimisationEnabler
]

// ------------------------------------------------------------
// Models (Analytical Temperature‑Prediction)
// ------------------------------------------------------------

instance TwoParameterThermalModel : DTDFVocab:Model [
    base:desc "Analytical temperature‑prediction model with two free parameters."
    DTDFVocab:inputTo SimulationEnabler, OptimisationEnabler
]

instance FourParameterThermalInertiaModel : DTDFVocab:Model [
    base:desc "Analytical temperature‑prediction model with four free parameters capturing the heat‑bed’s thermal inertia."
    DTDFVocab:inputTo SimulationEnabler, OptimisationEnabler
]

// ------------------------------------------------------------
// Enablers (Core Software Algorithms)
// ------------------------------------------------------------

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that updates model parameters using incoming temperature measurements."
    DTDFVocab:enables TemperatureSimulationService, OptimisationRecommendationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring algorithm that evaluates real‑time temperature streams for safety and performance."
    DTDFVocab:enables RealTimeTemperatureMonitoringService, TemperatureVisualizationService
]

instance SafetyEnabler : DTDFVocab:Enabler [
    base:desc "Fault‑detection and safety‑monitoring algorithm that detects violations of temperature limits."
    DTDFVocab:enables SafetyViolationDetectionService
]

instance OptimisationEnabler : DTDFVocab:Enabler [
    base:desc "Optimisation algorithm that generates control set‑point recommendations based on calibrated models."
    DTDFVocab:enables OptimisationRecommendationService, WhatIfAnalysisService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that uses calibrated thermal models to forecast future temperature trajectories."
    DTDFVocab:enables TemperatureSimulationService, WhatIfAnalysisService
]

instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker that transports sensor data streams from the Raspberry Pi to the Digital Twin via publish/subscribe."
    DTDFVocab:enables RealTimeTemperatureMonitoringService, TemperatureSimulationService, OptimisationRecommendationService
]

// ------------------------------------------------------------
// Services (DT Functionalities)
// ------------------------------------------------------------

instance RealTimeTemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of the three temperature sensors."
    DTDFVocab:provides TemperatureTrendInsight
]

instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Runs simulation models that reproduce and predict the incubator’s temperature dynamics."
    DTDFVocab:provides TemperatureForecastInsight
]

instance SafetyViolationDetectionService : DTDFVocab:Service [
    base:desc "Detects violations of predefined temperature limits for safety assurance."
    DTDFVocab:provides TemperatureSafetyViolationInsight
]

instance OptimisationRecommendationService : DTDFVocab:Service [
    base:desc "Generates optimisation recommendations for the Raspberry Pi controller."
    DTDFVocab:provides OptimisationRecommendationAction
]

instance TemperatureVisualizationService : DTDFVocab:Service [
    base:desc "Visualises temperature trends and model‑based what‑if analysis results."
    DTDFVocab:provides TemperatureTrendVisualizationInsight
]

instance WhatIfAnalysisService : DTDFVocab:Service [
    base:desc "Performs model‑based what‑if analysis to evaluate alternative control strategies."
    DTDFVocab:provides WhatIfScenarioInsight
]

// ------------------------------------------------------------
// Insights / Actions
// ------------------------------------------------------------

instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Insight into current temperature trends derived from live sensor data."
]

instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of future temperature trajectories produced by the simulation models."
]

instance TemperatureSafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Alert indicating a breach of configured temperature safety limits."
]

instance TemperatureTrendVisualizationInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of temperature evolution over time."
]

instance OptimisationRecommendationAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of heat‑bed set‑point to optimise temperature stability."
    DTDFVocab:IsAutomatic true
]

instance WhatIfScenarioInsight : DTDFVocab:Insight [
    base:desc "Evaluation result of a hypothetical control scenario produced by what‑if analysis."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are sent from the Digital Twin (or from external algorithms/human operators) through the same RabbitMQ broker to a controller program running on the Raspberry Pi. The controller listens for messages that command the fan and the heat‑bed actuators; the message format is not specified in the documents. Upon receipt, the controller validates the command, actuates the corresponding hardware, and the resulting physical state is observable again via the temperature sensors, providing implicit feedback to the DT. Conflict resolution and explicit command‑execution acknowledgements are not described."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing predicted temperature trajectories against the observed temperature data from the physical incubator. Experiments demonstrated that the four‑parameter model reproduces the thermal inertia of the heat‑bed more accurately than the two‑parameter model, indicating higher fidelity and suitability for further DT development. Model validation is performed through calibration runs where the model parameters are adjusted to minimise the error between simulated and measured temperatures. Uncertainty arises from sensor noise and unmodelled environmental effects; the calibration algorithm provides the best‑estimate parameters, quantifying this uncertainty. Continuous monitoring within the DT checks for deviations beyond tolerated thresholds, triggering alerts for possible model drift."
]