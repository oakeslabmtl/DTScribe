// ===============================
// C3: Physical sensing components
// ===============================

instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor placed inside the insulated styrofoam incubator box (first internal sensor)."
    DTDFVocab:producedData TemperatureReadingsMessage
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor placed inside the insulated styrofoam incubator box (second internal sensor)."
    DTDFVocab:producedData TemperatureReadingsMessage
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor placed outside the incubator box to monitor ambient temperature."
    DTDFVocab:producedData TemperatureReadingsMessage
]

// ======================================
// C4: Physical‑to‑virtual interaction
// ======================================

instance TemperatureReadingsMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA, InternalTempSensorB, ExternalTempSensor
    base:desc "AMQP message (RabbitMQ) carrying time‑stamped temperature readings from the three sensors."
]

// =============================
// C10: Data and Models
// =============================

instance TemperatureDataset : DTDFVocab:Data [
    base:desc "Time‑stamped temperature dataset obtained from TemperatureReadingsMessage, used for calibration, monitoring and simulation."
    DTDFVocab:fromData TemperatureReadingsMessage
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance ThermalModelTwoParam : DTDFVocab:Model [
    base:desc "Thermal dynamics simulation model of the incubator containing two free parameters."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance ThermalModelFourParam : DTDFVocab:Model [
    base:desc "Thermal dynamics simulation model of the incubator containing four free parameters for higher fidelity."
    DTDFVocab:inputTo SimulationEngineEnabler
]

// =============================
// C11: Enablers
// =============================

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ server using AMQP protocol that transports sensor messages from the Physical Twin to the Digital Twin."
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Software engine (hosted on the Raspberry Pi) that runs simulation, calibration, monitoring, optimisation and visualisation algorithms."
    DTDFVocab:enables TemperaturePredictionService,
                       ModelCalibrationService,
                       SafetyPerformanceMonitoringService,
                       HeatingControlOptimizationService,
                       AdvancedVisualizationService
]

// =============================
// C6: Services
// =============================

instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Simulation‑based prediction of the incubator’s internal temperature dynamics."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Calibration of the thermal models using collected temperature sensor data."
    DTDFVocab:provides CalibrationInsight
]

instance SafetyPerformanceMonitoringService : DTDFVocab:Service [
    base:desc "Continuous safety and performance monitoring of the incubator using calibrated models."
    DTDFVocab:provides SafetyOptimalityInsight, AlertGenerationAction
]

instance HeatingControlOptimizationService : DTDFVocab:Service [
    base:desc "Optimisation of heating‑control settings to maintain target temperature efficiently."
    DTDFVocab:provides ControlAdjustmentAction
]

instance AdvancedVisualizationService : DTDFVocab:Service [
    base:desc "Advanced visualisations supporting re‑configuration, maintenance reduction and decision‑making."
    DTDFVocab:provides VisualizationInsight
]

// =============================
// C17: Insights / Actions
// =============================

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulated temperature predictions to inform future control strategies."
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the quality of model parameter estimation after calibration."
]

instance SafetyOptimalityInsight : DTDFVocab:Insight [
    base:desc "Insight evaluating whether the incubator is operating safely and optimally based on model‑data comparison."
]

instance AlertGenerationAction : DTDFVocab:Action [
    base:desc "Action that generates an alert when safety or optimality violations are detected."
    DTDFVocab:IsAutomatic true
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Action that modifies heating control commands to bring the system back to safe/optimal operation."
    DTDFVocab:IsAutomatic true
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight provided by advanced visualisations to aid human operators in maintenance and decision‑making."
]

// =============================
// C2: Acting components
// =============================

instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that provides heating power to the interior of the styrofoam incubator box."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan that circulates heated air inside the incubator to ensure uniform temperature."
]

// =============================
// Additional components
// =============================

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi that hosts the control software, simulation engine and communicates with sensors, actuators and RabbitMQ."
]

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, FanActuator, InternalTempSensorA, InternalTempSensorB, ExternalTempSensor, RaspberryPiController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin sends control commands (e.g., heat‑bed ON/OFF, fan ON/OFF) to the Physical Twin via the RabbitMQ broker. The controller on the Raspberry Pi publishes command messages—containing command type and parameters such as heating duration (H) and waiting duration (C)—to RabbitMQ; the low‑level driver receives the messages, validates them through its safe protocol, actuates the hardware, and can acknowledge execution as part of its regular data upload."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin operates in real‑time: it continuously listens to controller and low‑level driver messages, streams the data into a time‑series database and updates a dashboard for visualization. Calibration and anomaly detection (Kalman filter) are performed on‑demand using the latest sensor readings. No explicit synchronization frequencies or latency requirements are stated in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT follows a CPS‑based architecture: sensor data and controller messages from the Physical Twin are ingested into a time‑series database, which feeds a real‑time dashboard. Two simulation models (one with two free parameters, one with four) are calibrated on‑demand; the calibrated Model B is used by a Kalman filter for heat‑bed state estimation and anomaly detection. What‑if simulations are carried out via co‑simulation that consumes historical or live PT data. These services are orchestrated in a self‑adaptation loop that can re‑configure the controller based on detected changes."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the two thermal models: the four‑parameter model shows higher fidelity in reproducing the heat‑bed’s thermal inertia, as demonstrated by experimental validation described in the case study. Model validation is performed through calibration against the recorded sensor data and by evaluating prediction errors in the experimental results. Uncertainty sources include sensor noise and model simplifications, though quantitative uncertainty quantification is not detailed. The calibration step serves as an error‑correction mechanism, and the overall quality assurance relies on experimentally verifying that the model predictions match measured temperatures."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between physical components and the Digital Twin relies on a RabbitMQ message broker. The broker uses the AMQP protocol over a local network connecting the Raspberry Pi controller, the low‑level driver and any DT services. The network topology is essentially a star with RabbitMQ as the central hub. RabbitMQ provides reliable message delivery, persistence and supports clustering for redundancy, though specific bandwidth or latency requirements are not specified in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin is deployed on‑premise: the controller runs on an edge device (Raspberry Pi) and the RabbitMQ server can be hosted locally or in the cloud, as RabbitMQ is described as lightweight and easy to deploy on premises or in the cloud. Computational load is modest (temperature acquisition and simple bang‑bang control) and storage needs are limited to recent sensor logs. Scalability is achieved by adding consumers or clustering RabbitMQ; availability and reliability are supported by RabbitMQ’s mature fault‑tolerance mechanisms."
]