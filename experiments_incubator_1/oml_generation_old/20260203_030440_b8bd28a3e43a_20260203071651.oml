// C3: Physical sensing components
instance IncubatorInsideTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor inside the incubator chamber providing numeric temperature measurements."
    DTDFVocab:producedData InsideTempDataTransmitted1
]

instance IncubatorInsideTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second temperature sensor inside the incubator chamber providing numeric temperature measurements."
    DTDFVocab:producedData InsideTempDataTransmitted2
]

instance IncubatorOutsideTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor located outside the incubator providing ambient temperature measurements."
    DTDFVocab:producedData OutsideTempDataTransmitted
]

// C4: Physical-to-virtual interaction
instance InsideTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInsideTempSensor1
]

instance InsideTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInsideTempSensor2
]

instance OutsideTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorOutsideTempSensor
]

// C10: Data
instance InsideTempData1 : DTDFVocab:Data [
    base:desc "Numeric temperature measurement from inside sensor 1 collected over time."
    DTDFVocab:fromData InsideTempDataTransmitted1
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringAlgorithm, SimulationEngine
]

instance InsideTempData2 : DTDFVocab:Data [
    base:desc "Numeric temperature measurement from inside sensor 2 collected over time."
    DTDFVocab:fromData InsideTempDataTransmitted2
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringAlgorithm, SimulationEngine
]

instance OutsideTempData : DTDFVocab:Data [
    base:desc "Numeric temperature measurement from the external sensor collected over time."
    DTDFVocab:fromData OutsideTempDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringAlgorithm, SimulationEngine
]

// C10: Models
instance SimpleThermalModel : DTDFVocab:Model [
    base:desc "Simple incubator temperature model with two free parameters."
    DTDFVocab:inputTo CalibrationAlgorithm, SimulationEngine
]

instance DetailedThermalModel : DTDFVocab:Model [
    base:desc "Detailed incubator temperature model with four free parameters capturing thermal inertia of the heat‑bed."
    DTDFVocab:inputTo CalibrationAlgorithm, SimulationEngine
]

// C11: Enablers
instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that continuously adjusts model parameters using the latest sensor data."
    DTDFVocab:enables CalibrationService
]

instance MonitoringAlgorithm : DTDFVocab:Enabler [
    base:desc "Monitoring algorithm that compares simulated and measured states to detect safety or performance violations."
    DTDFVocab:enables MonitoringService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs thermal behaviour predictions of the incubator."
    DTDFVocab:enables PredictionService
]

instance OptimizationEngine : DTDFVocab:Enabler [
    base:desc "Optimization engine that suggests or enacts control actions to maintain target temperature."
    DTDFVocab:enables OptimizationService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Continuously runs calibration algorithms ingesting sensor data to update cyber‑physical models."
    DTDFVocab:provides DecisionSupportInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Checks safety and optimality of temperature control by monitoring simulated vs. measured states."
    DTDFVocab:provides SystemHealthInsight, PredictiveWarningInsight, AlertAction
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Provides simulation‑based prediction of the incubator's thermal behaviour."
    DTDFVocab:provides PredictiveWarningInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Suggests or enacts control actions to keep the incubator at the target temperature."
    DTDFVocab:provides ControlRecommendationAction, ControlEnactmentAction
]

// C17: Insights
instance SystemHealthInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into system health based on comparison of simulated and measured temperature."
]

instance PredictiveWarningInsight : DTDFVocab:Insight [
    base:desc "Predictive warnings of temperature deviations before they occur."
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Decision support for corrective actions derived from continuous calibration."
]

// C17: Actions
instance AlertAction : DTDFVocab:Action [
    base:desc "Generates an alert when a safety or performance violation is detected."
    DTDFVocab:IsAutomatic false
]

instance ControlRecommendationAction : DTDFVocab:Action [
    base:desc "Recommends a modification to the physical twin's control actions."
    DTDFVocab:IsAutomatic false
]

instance ControlEnactmentAction : DTDFVocab:Action [
    base:desc "Enacts a control action to adjust the heating element and maintain target temperature."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT can issue control actions back to the PT to regulate the incubator temperature. Commands are directed to the heatbed (heating element) and the fan (air distribution). The documents mention that the DT may make changes to the physical twin, but they do not describe the command format, validation or authentication mechanisms, feedback loops, conflict‑resolution strategies, or confirmation of command execution."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin follows a modular pipeline architecture: sensor data from the Physical Twin is ingested, calibration algorithms update the cyber‑physical system and environment models with the best‑estimate parameters, the refreshed models feed monitoring components that assess safety and optimality, and upon detection of violations a decision component (human operator or automated algorithm) triggers corrective actions on the Physical Twin. This reflects coordinated orchestration of data acquisition, model calibration, monitoring, and actuation as described in Document 1."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing two temperature prediction models: the four‑parameter model, which captures the heat‑bed’s thermal inertia, demonstrated higher predictive accuracy in experimental trials and was therefore selected for further DT development. Validation is performed through empirical experiments that measure the incubator temperature and compare it to model outputs. Calibration algorithms are used to update model parameters based on observed data, providing a mechanism for error correction. The documents do not detail uncertainty quantification, error detection methods, or broader quality‑assurance processes."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT architecture includes a cyber‑physical link that enables data acquisition from sensors and command transmission to actuators, but the documents do not provide details on the underlying network infrastructure such as specific communication protocols, network topology, bandwidth, latency, reliability, redundancy, or security protocols."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The documents describe the DT as a framework that integrates models, algorithms, and data, yet they give no information about the hosting environment (cloud, edge, or on‑premise), computational or storage resources, scalability approaches, deployment models, or availability and reliability guarantees."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin framework described integrates monitoring algorithms that continuously evaluate sensor data collected from the Physical Twin to detect safety violations. When a breach of predefined safety constraints is identified, the DT triggers alerts and a decision loop that may involve human operators or autonomous controllers to enact corrective actions on the Physical Twin. This safety‑centric monitoring is explicitly mentioned as a core part of the DT architecture, aiming to keep the system operating within safe limits and to enable predictive safety checks."
]