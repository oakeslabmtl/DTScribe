// C3: Physical Sensing Components // Return code: 1 | Stderr:
instance IncubatorInternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor #1 located in the styrofoam enclosure to monitor incubator air temperature."
    DTDFVocab:producedData InternalTempData1Transmitted
]

instance IncubatorInternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor #2 located in the styrofoam enclosure to monitor incubator air temperature."
    DTDFVocab:producedData InternalTempData2Transmitted
]

instance IncubatorExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "In‑box external temperature sensor measuring ambient temperature around the incubator."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Physical-to-Virtual Interaction – Data Transmitted
instance InternalTempData1Transmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInternalTempSensor1
]

instance InternalTempData2Transmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInternalTempSensor2
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorExternalTempSensor
]

// C10: Models/Data – Data Sets
instance InternalTempDataSet1 : DTDFVocab:Data [
    base:desc "Collected temperature readings from IncubatorInternalTempSensor1, ingested via RabbitMQ."
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine, SimulationEngine
    DTDFVocab:fromData InternalTempData1Transmitted
]

instance InternalTempDataSet2 : DTDFVocab:Data [
    base:desc "Collected temperature readings from IncubatorInternalTempSensor2, ingested via RabbitMQ."
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine, SimulationEngine
    DTDFVocab:fromData InternalTempData2Transmitted
]

instance ExternalTempDataSet : DTDFVocab:Data [
    base:desc "Collected ambient temperature readings from IncubatorExternalTempSensor, ingested via RabbitMQ."
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine, SimulationEngine
    DTDFVocab:fromData ExternalTempDataTransmitted
]

// C10: Models – Thermal Models
instance ModelA : DTDFVocab:Model [
    base:desc "Thermal model A that assumes uniform temperature, negligible wall heat, constant specific heat, and direct conversion of electrical power into air heat. Includes two free parameters."
    DTDFVocab:inputTo SimulationEngine
]

instance ModelB : DTDFVocab:Model [
    base:desc "Thermal model B that relaxes the fourth assumption, accounting for the thermal inertia of the heat‑bed. Contains four free parameters."
    DTDFVocab:inputTo SimulationEngine, CalibrationEngine
]

// C11: Enablers – Infrastructure & Processing
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "Local RabbitMQ server using AMQP to publish sensor readings and consume control commands."
    DTDFVocab:enables DataAcquisitionService, ControlCommandService
]

instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Interface written in C running on Raspberry Pi 4 that reads sensors, sinks commands, and enforces safety constraints."
    DTDFVocab:enables ControlCommandService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation engine that runs ModelA and ModelB in real time to predict interior temperature."
    DTDFVocab:enables SimulationService
]

instance KalmanFilterEngine : DTDFVocab:Enabler [
    base:desc "Kalman‑filter engine that fuses ModelB predictions with measured temperatures to estimate unmeasured heat‑bed temperature."
    DTDFVocab:enables KalmanFilterService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Least‑squares calibration algorithm that updates ModelB parameters based on incoming temperature data."
    DTDFVocab:enables CalibrationService
]

instance AnomalyDetectionEngine : DTDFVocab:Enabler [
    base:desc "Anomaly detection module that flags deviations using residuals from the Kalman filter."
    DTDFVocab:enables AnomalyDetectionService
]

instance WhatIfSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation engine that runs what‑if scenarios, injecting live or historic PT data into the models."
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationEngine : DTDFVocab:Enabler [
    base:desc "Self‑adaptation routine that schedules experiments, recalibrates ModelB, reconfigures the Kalman filter and controller, and re‑optimises control parameters."
    DTDFVocab:enables SelfAdaptationService
]

instance DashboardEngine : DTDFVocab:Enabler [
    base:desc "Dashboard that consumes controller and driver messages to provide real‑time visualization."
    DTDFVocab:enables VisualizationService
]

// C6: Services – Functional Units
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Service that ingests raw temperature data from RabbitMQ for logging, monitoring and calibration."
    DTDFVocab:provides TemperatureDataReceivedInsight
]

instance ControlCommandService : DTDFVocab:Service [
    base:desc "Service that receives bang‑bang control commands for the heat‑bed and fan, and forwards them via RabbitMQ."
    DTDFVocab:provides HeatBedControlSentInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs real‑time simulations of ModelA and ModelB."
    DTDFVocab:provides SimulationInsight
]

instance KalmanFilterService : DTDFVocab:Service [
    base:desc "Service that runs the Kalman filter for state estimation."
    DTDFVocab:provides KalmanEstimatedHeatBedTempInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that calibrates ModelB using least‑squares optimisation."
    DTDFVocab:provides ModelCalibrationUpdatedInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Service that detects anomalies via residuals from the Kalman filter."
    DTDFVocab:provides AnomalyDetectedInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Service that runs what‑if co‑simulations with historical or live PT data."
    DTDFVocab:provides WhatIfScenarioInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Service that monitors filter residuals, schedules experiments, recalibrates, and re‑optimises control parameters."
    DTDFVocab:provides SelfAdaptationTriggeredInsight
    DTDFVocab:provides ReconfigureKalmanFilterAction
    DTDFVocab:provides ReoptimizeControllerParametersAction
    DTDFVocab:provides ScheduleExperimentAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that renders real‑time dashboards from controller and driver messages."
    DTDFVocab:provides RealTimeVisualizationInsight
]

// C17: Insights
instance TemperatureDataReceivedInsight : DTDFVocab:Insight [
    base:desc "Data ingestion of temperature readings has completed and data is now available for downstream services."
]

instance HeatBedControlSentInsight : DTDFVocab:Insight [
    base:desc "Bang‑bang control command to enable or disable the heat‑bed has been sent through the RabbitMQ broker."
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Realtime visualisation of the incubator state is being displayed on the dashboard."
]

instance ModelCalibrationUpdatedInsight : DTDFVocab:Insight [
    base:desc "Least‑squares calibration algorithm has updated ModelB parameters based on recent data."
]

instance KalmanEstimatedHeatBedTempInsight : DTDFVocab:Insight [
    base:desc "Kalman filter has produced an estimate of the unmeasured heat‑bed temperature."
]

instance AnomalyDetectedInsight : DTDFVocab:Insight [
    base:desc "An anomaly has been detected based on residuals from the Kalman filter."
]

instance WhatIfScenarioInsight : DTDFVocab:Insight [
    base:desc "What‑if scenario simulation has completed and results are available."
]

instance SelfAdaptationTriggeredInsight : DTDFVocab:Insight [
    base:desc "Self‑adaptation routine has been triggered due to detected model drift."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight providing simulation outputs for interior temperature predictions."
]

// C17: Actions
instance ReconfigureKalmanFilterAction : DTDFVocab:Action [
    base:desc "Action to reconfigure the Kalman filter parameters in response to changing plant dynamics."
    DTDFVocab:IsAutomatic true
]

instance ReoptimizeControllerParametersAction : DTDFVocab:Action [
    base:desc "Action to re‑optimise bang‑bang controller parameters (LL, UL, H, C)."
    DTDFVocab:IsAutomatic true
]

instance ScheduleExperimentAction : DTDFVocab:Action [
    base:desc "Action to schedule a new experiment for model validation."
    DTDFVocab:IsAutomatic true
]

// C10: Physical-acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heating pad whose power is supplied by Raspberry Pi and can be switched on or off via low‑level driver."
    DTDFVocab:producedData HeatBedCommandTransmitted
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Electric motor that distributes heated air within the styrofoam enclosure controlled via low‑level driver."
    DTDFVocab:producedData FanCommandTransmitted
]

// Physical-to-virtual interaction for actuators
instance HeatBedCommandTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatBedActuator
]

instance FanCommandTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FanActuator
]

// Data set for commands (if needed)
instance HeatBedCommandDataSet : DTDFVocab:Data [
    base:desc "Command data set for heat‑bed activation states transmitted to the controller."
    DTDFVocab:inputTo ControlCommandService
    DTDFVocab:fromData HeatBedCommandTransmitted
]

instance FanCommandDataSet : DTDFVocab:Data [
    base:desc "Command data set for fan activation states transmitted to the controller."
    DTDFVocab:inputTo ControlCommandService
    DTDFVocab:fromData FanCommandTransmitted
]

// Environment container
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains IncubatorInternalTempSensor1,
    IncubatorInternalTempSensor2,
    IncubatorExternalTempSensor,
    HeatBedActuator,
    FanActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT controller calculates the control action (turn fan/heatbed on or off) based on the latest temperature telemetry. It publishes the command to the local RabbitMQ queue. The low‑level driver receives the command, validates it against a safety protocol that prevents unsafe operations (e.g., disabling the heatbed if the temperature exceeds the upper limit), and transmits the actuator instruction to the physical twin. The driver confirms execution by publishing the actuator state back to RabbitMQ, allowing the DT to maintain an up‑to‑date view of the physical system."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Digital Twin architecture consists of a controller running on a Raspberry Pi, a low-level driver that abstracts sensor/actuator communication, and a RabbitMQ communication server that exchanges AMQP messages between the controller and the driver. The Twin updates its embedded dynamic models (Model A and Model B) through a calibration algorithm that uses sensor data, and it runs monitoring functions that check safety and performance. All components are integrated within the same process frame and communicate over the RabbitMQ broker, allowing the model, simulation, and monitoring services to operate synchronously with the physical twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The documents do not provide a formal description of Digital Twin lifecycle stages, management of representation types, transition processes, or governance approaches."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is governed by four assumptions: 1) the temperature inside the box is spatially uniform due to the fan; 2) thermal accumulation in the box walls is negligible; 3) the specific heat capacity of air is constant despite pressure or humidity changes; 4) nearly all electrical power supplied to the heat‑bed is converted to heating the air (the heat generated by the fan is neglected). Model A applies all four assumptions and contains two free parameters; Model B omits assumption 4 and has four free parameters, enabling better prediction of the heat‑bed’s thermal inertia. Validation is performed by calibrating the model parameters using a least‑squares fit against the measured temperature data from the sensors. Calibration updates the parameter estimates to produce the best‑fit model at each iteration. The models are then compared against measured data to assess residual errors. Although explicit error‑correction mechanisms are not described, the calibration algorithm ensures that model predictions remain aligned with physical measurements, thereby maintaining both fidelity and validity appropriate for the Digital Twin application."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All intra‑system communication is mediated by a local RabbitMQ message broker instantiated on the Raspberry Pi that serves the incubator. The broker exchanges messages between the low‑level driver, the DT controller, and any external monitoring services. RabbitMQ provides the messaging middleware that enables asynchronous, decoupled interaction among these components. No additional network topology or specialized protocols beyond this broker are defined in the case study."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire DT stack runs on‑premise on a Raspberry Pi 4 Model B, which hosts the Raspberry Pi OS (Debian‑based), RabbitMQ, the low‑level driver, and the controller. The deployment is based on open‑source containers/packages available through the repository https://github.com/INTO-CPS-Association/example-incubator. The setup requires only a modest compute node; no cloud or external hosting is discussed. Scalability is limited to the Pi’s resources; for larger scale deployments, the architecture would need to be extended."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT integrates externally with the RabbitMQ message broker using the AMQP protocol to exchange sensor readings, control commands, and telemetry. No additional external enterprise systems, standards, or other Digital Twins are referenced in the documents. The open‑source code repository hosts all software but is not an external integration point for runtime data exchange."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Incubator DT uses RabbitMQ as the communication broker to transmit sensor readings and command messages between the Raspberry‑Pi controller, the low‑level driver, and external data services.  The low‑level driver incorporates a built‑in safety protocol that periodically polls the PT temperature sensors, validates incoming control commands, and ensures actuator states (heatbed and fan) are only enabled within defined safe bounds.  The controller implements a bang‑bang logic with configurable lower (LL) and upper (UL) temperature limits, heating duration (H), and waiting duration (C) to prevent temperature overshoot and to allow thermal stabilization.  These mechanisms provide run‑time fail‑safe behaviour and mitigate risks of unsafe temperature excursions.  The documents do not describe additional cybersecurity mechanisms such as encryption, authentication, or access control, nor do they specify compliance with data protection regulations or privacy‑preserving data handling policies."
]