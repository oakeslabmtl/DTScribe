// C2: Acting Components //
instance Heatbed : DTDFVocab:ActingComponent [
    base:desc "Primary heating source for the air inside the thermal incubator box, controlled via MOSFET interface by the RaspberryPiController to regulate internal temperature through thermal conduction."
]

instance Fan : DTDFVocab:ActingComponent [
    base:desc "Air circulation component that distributes heat uniformly within the incubator box by circulating air, controlled via MOSFET interface by the RaspberryPiController to ensure temperature homogeneity."
]

instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "Embedded controller executing bang-bang control logic to regulate Heatbed and Fan operations based on real-time temperature feedback from DS18S20 sensors, interfaced through MOSFETs and optocouplers for safe high-current actuation."
]

instance MOSFETInterface : DTDFVocab:ActingComponent [
    base:desc "Electronic interface between RaspberryPiController and high-current actuators (Heatbed) providing galvanic isolation and current amplification through optocouplers for safe operation."
]

// C3: Physical Sensing Components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision digital thermometer measuring real-time internal temperature at primary measurement point within the incubator box."
    DTDFVocab:producedData InternalTemperatureData
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision digital thermometer measuring real-time internal temperature at secondary measurement point within the incubator box for spatial temperature validation."
    DTDFVocab:producedData InternalTemperatureData
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision digital thermometer measuring external/ambient room temperature for environmental modeling and external condition monitoring."
    DTDFVocab:producedData ExternalTemperatureData
]

// C4: Physical-to-Virtual Interaction
instance InternalTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1, InternalTemperatureSensor2
]

instance ExternalTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

instance ControlCommandData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RaspberryPiController
]

// C10: Models/Data
instance SimplifiedThermalModel : DTDFVocab:Model [
    base:desc "Model A: Simplified dynamic thermal model with 2 free parameters (C_air, G_box) focusing on air-heatbed interaction dynamics for rapid control calculations."
    DTDFVocab:inputTo RabbitMQServer, PythonScipyCalibrator
]

instance DetailedThermalModel : DTDFVocab:Model [
    base:desc "Model B: Detailed dynamic thermal model with 4 free parameters (C_heater, C_air, G_heater, G_box) accounting for heatbed thermal inertia and comprehensive system dynamics."
    DTDFVocab:inputTo RabbitMQServer, PythonScipyCalibrator
]

instance RealTimeTemperatureData : DTDFVocab:Data [
    base:desc "Aggregated real-time temperature readings from all DS18S20 sensors (internal and external) used for control validation and environmental modeling."
    DTDFVocab:fromData InternalTemperatureData, ExternalTemperatureData
    DTDFVocab:inputTo SimplifiedThermalModel, DetailedThermalModel, RabbitMQServer
]

instance EnvironmentalConditionData : DTDFVocab:Data [
    base:desc "External environmental data including room temperature and ambient conditions used for predictive analysis and model calibration."
    DTDFVocab:fromData ExternalTemperatureData
    DTDFVocab:inputTo DetailedThermalModel, PythonScipyCalibrator
]

instance ControlActionData : DTDFVocab:Data [
    base:desc "Actuation commands including heatbed/fan states and system response data transmitted from RaspberryPiController to the Digital Twin for closed-loop validation."
    DTDFVocab:fromData ControlCommandData
    DTDFVocab:inputTo SimplifiedThermalModel, DetailedThermalModel, PythonScipyCalibrator
]

instance CalibrationData : DTDFVocab:Data [
    base:desc "Experimental data used for non-linear least squares calibration of model parameters (C_air, G_box, C_heater, G_heater) to minimize prediction errors."
    DTDFVocab:fromData RealTimeTemperatureData, ControlActionData
    DTDFVocab:inputTo PythonScipyCalibrator
]

// C11: Enablers
instance RabbitMQServer : DTDFVocab:Enabler [
    base:desc "Message broker facilitating real-time communication between physical sensors (DS18S20), controller (RaspberryPiController), and Digital Twin components via MQTT protocol."
    DTDFVocab:enables TemperatureDataStreamingService, ModelCalibrationService
]

instance PythonScipyCalibrator : DTDFVocab:Enabler [
    base:desc "Non-linear least squares solver implementation using Python's Scipy library for automated calibration of thermal model parameters against real-time sensor data."
    DTDFVocab:enables ModelCalibrationService
]

instance BangBangController : DTDFVocab:Enabler [
    base:desc "Software implementation of bang-bang control algorithm executed on RaspberryPiController to regulate Heatbed and Fan operations based on temperature setpoints."
    DTDFVocab:enables TemperatureRegulationService
]

// C6: Services
instance TemperatureDataStreamingService : DTDFVocab:Service [
    base:desc "Real-time streaming service transmitting sensor data (temperature readings) from physical components to the Digital Twin via RabbitMQ for continuous monitoring and analysis."
    DTDFVocab:provides TemperatureMonitoringInsight, EnvironmentalAnalysisInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Service calibrating thermal models (Model A and Model B) using least-squares optimization against real-time sensor data to improve prediction accuracy."
    DTDFVocab:provides ModelAccuracyInsight
]

instance TemperatureRegulationService : DTDFVocab:Service [
    base:desc "Closed-loop control service regulating internal temperature through coordinated actuation of Heatbed and Fan based on model predictions and real-time feedback."
    DTDFVocab:provides TemperatureStabilityInsight, EnergyEfficiencyAction
]

instance PredictiveAnalysisService : DTDFVocab:Service [
    base:desc "Service simulating system behavior under varying conditions (e.g., environmental changes) to anticipate temperature dynamics and optimize control strategies."
    DTDFVocab:provides ScenarioAnalysisInsight
]

// C17: Insights/Actions
instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Continuous real-time monitoring of internal and external temperature readings for immediate system health assessment and anomaly detection."
]

instance EnvironmentalAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analysis of external environmental conditions (room temperature) to assess their impact on incubator performance and model fidelity."
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantitative assessment of model prediction accuracy through comparison of simulated vs. observed temperature dynamics using calibration metrics."
]

instance TemperatureStabilityInsight : DTDFVocab:Insight [
    base:desc "Evaluation of system's ability to maintain target temperature despite external disturbances or internal load changes."
]

instance EnergyEfficiencyAction : DTDFVocab:Action [
    base:desc "Dynamic adjustment of Fan speed and Heatbed operation to optimize energy consumption while maintaining temperature stability."
    DTDFVocab:IsAutomatic true
]

instance ScenarioAnalysisInsight : DTDFVocab:Insight [
    base:desc "Predictive insights into system behavior under hypothetical scenarios (e.g., power outages, extreme ambient temperatures) to inform preventive measures."
]

// C1: Physical Environment
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Insulated styrofoam container serving as the primary physical environment for maintaining controlled thermal conditions."
    base:contains Heatbed, Fan, InternalTemperatureSensor1, InternalTemperatureSensor2, RaspberryPiController, MOSFETInterface
]

instance ExternalEnvironment : DTDFVocab:Environment [
    base:desc "Ambient environment containing the ThermalIncubatorEnvironment, providing external temperature conditions monitored by ExternalTemperatureSensor."
    base:contains ExternalTemperatureSensor
]

instance ThermalIncubatorSystem : DTDFVocab:SystemUnderStudy [
    base:desc "Thermal incubator system designed to maintain specific temperature inside an insulated box."
    DTDFVocab:hasEnvironment ThermalIncubatorEnvironment, ExternalEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The interactions from the virtual world to the physical world include:
  - **Control Commands**: The DT (via the controller) sends commands to the Raspberry Pi to:
    - Activate/deactivate the **heatbed** (via MOSFETs).
    - Adjust the **fan** speed (via voltage control).
  - **State Updates**: The DT communicates control states (e.g., heating duration, waiting duration) back to the physical system via the **RabbitMQ server** for synchronization."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twinning time scale involves:
  - **Real-time Monitoring**: Continuous data acquisition and processing at high frequencies (e.g., temperature readings every few seconds).
  - **Control Loop Latency**: The DT-to-PT interaction occurs in real-time or near-real-time, with control commands executed within milliseconds to seconds.
  - **Simulation and Calibration**: Offline or periodic calibration of models (e.g., parameter tuning) may occur at lower frequencies (e.g., hourly or daily) to adapt to environmental changes or system drift."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is structured as follows:
  - **Communication Layer**: RabbitMQ server facilitates message passing between the controller, low-level driver, and DT components.
  - **Control Layer**: Raspberry Pi implements the control logic (bang-bang controller) and interfaces with actuators/sensors.
  - **Model Layer**: Dynamic models (A/B) reside in the DT to simulate and predict behavior.
  - **Monitoring Layer**: Real-time data from sensors is processed to detect faults, optimize performance, and visualize trends.
  - **Orchestration**: The DT acts as a centralized framework integrating models, data, and algorithms to enhance the Physical Twin's operation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin covers the **as-operated phase** of the Physical Twin's lifecycle:
  - **Representation Phase**: The DT represents the Physical Twin in its operational state, not during design or manufacturing.
  - **Development Focus**: The case study emphasizes **runtime modeling and calibration** to improve the DT's accuracy and utility during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are addressed through:
  - **Model Assumptions**: Simplifications (e.g., uniform temperature, constant heat capacity) are validated experimentally (e.g., temperature uniformity tests).
  - **Calibration**: Non-linear least squares optimization minimizes residual error between model predictions and experimental data.
  - **Verification**: Experimental results (e.g., fig. 10, fig. 12) compare sensor data with model outputs to assess accuracy.
  - **Uncertainty**: Model parameters (e.g., `G_box`, `G_heater`) are treated as uncertain and calibrated to reduce prediction errors.
  - **Trade-offs**: Model A (simpler) vs. Model B (detailed) balances computational efficiency and accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection between PT and DT includes:
  - **Network Protocol**: RabbitMQ (message broker) enables asynchronous communication between components.
  - **Data Flow**:
    - **PT → DT**: Temperature data streams via RabbitMQ from sensors to the DT.
    - **DT → PT**: Control commands (e.g., heatbed/fan activation) are sent via RabbitMQ to the Raspberry Pi.
  - **Architecture**: Decoupled design with optocouplers and MOSFETs ensuring safe electrical isolation between the Raspberry Pi and high-power actuators."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted and deployed on:
  - **Hardware**: Raspberry Pi 4 (embedded system) running the RabbitMQ server and control logic.
  - **Software Environment**: Lightweight, open-source tools (RabbitMQ, Python) deployed on-premises (no cloud dependency mentioned).
  - **Scalability**: The centralized architecture is scalable for additional sensors or actuators if needed."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not explicitly mentioned in the document. No integration with external systems (e.g., other DTs, enterprise systems) is described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Not explicitly referenced. No standards (e.g., OPC UA, IEC 62424) are mentioned for DT development or communication."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety are partially addressed:
  - **Safety Protocols**: The low-level driver includes safeguards to prevent unsafe states (e.g., overheating).
  - **Remote Operation**: The DT can remotely control the PT (e.g., via Raspberry Pi), but no discussion of human safety risks (e.g., accidents) or cybersecurity threats (e.g., hacking) is provided.
  - **Isolation**: Optocouplers and MOSFETs ensure electrical isolation for safety.
  - **Limited Cybersecurity**: No mention of authentication, encryption, or secure communication protocols for the RabbitMQ server."
]