// C3: Physical sensing components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital temperature sensor inside the incubator box (range –55 °C to +125 °C, 0.5 °C accuracy)"
    DTDFVocab:producedData InternalTemperatureDataTransmitted1
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital temperature sensor inside the incubator box (range –55 °C to +125 °C, 0.5 °C accuracy)"
    DTDFVocab:producedData InternalTemperatureDataTransmitted2
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital temperature sensor measuring ambient room temperature (range –55 °C to +125 °C, 0.5 °C accuracy)"
    DTDFVocab:producedData AmbientTemperatureDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance InternalTemperatureDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1
]

instance InternalTemperatureDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor2
]

instance AmbientTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

// C10: Data
instance InternalTemperatureTimeSeries1 : DTDFVocab:Data [
    base:desc "Temperature time‑series from internal sensor 1 used for model calibration and validation"
    DTDFVocab:fromData InternalTemperatureDataTransmitted1
    DTDFVocab:inputTo RabbitMQBroker
]

instance InternalTemperatureTimeSeries2 : DTDFVocab:Data [
    base:desc "Temperature time‑series from internal sensor 2 used for model calibration and validation"
    DTDFVocab:fromData InternalTemperatureDataTransmitted2
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTemperatureTimeSeries : DTDFVocab:Data [
    base:desc "Ambient room temperature time‑series used for safety monitoring"
    DTDFVocab:fromData AmbientTemperatureDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on the Raspberry Pi for uploading sensor samples and PT state events"
    DTDFVocab:enables RealTimeMonitoringService
    DTDFVocab:enables CalibrationService
    DTDFVocab:enables SimulationService
]

instance PythonCalibrationEngine : DTDFVocab:Enabler [
    base:desc "Python calibration engine using SciPy non‑linear least‑squares solver"
    DTDFVocab:enables CalibrationService
]

instance PythonSimulationEngine : DTDFVocab:Enabler [
    base:desc "Python simulation engine executing Model A and Model B thermal dynamics"
    DTDFVocab:enables SimulationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature against safety limits"
    DTDFVocab:provides SafetyViolationInsight
    DTDFVocab:provides SuggestCorrectiveAction
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Parameter calibration of thermal models using SciPy non‑linear least‑squares"
    DTDFVocab:provides CalibrationInsight
    DTDFVocab:provides RefineHeatingDurationAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Model‑based simulation of incubator thermal dynamics (Model A and Model B)"
    DTDFVocab:provides SimulationInsight
]

// C17: Insights
instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Updated thermal parameters C_air, G_box, C_heater, G_heater after calibration"
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature exceeding predefined safety limits"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory generated by the selected thermal model"
]

// C17: Actions
instance RefineHeatingDurationAction : DTDFVocab:Action [
    base:desc "Adjust heating duration (H) and waiting duration (C) in the controller based on calibrated parameters"
    DTDFVocab:IsAutomatic true
]

instance SuggestCorrectiveAction : DTDFVocab:Action [
    base:desc "Suggest corrective actions to human operators when a safety violation is detected"
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance ModelA : DTDFVocab:Model [
    base:desc "Single‑energy‑balance thermal model with air capacitance C_air and box conductance G_box"
    DTDFVocab:inputTo PythonSimulationEngine
]

instance ModelB : DTDFVocab:Model [
    base:desc "Extended thermal model adding heater capacitance C_heater and conductance G_heater to Model A"
    DTDFVocab:inputTo PythonSimulationEngine
]

// C2: Acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Planar heat‑bed switched by MOSFET driver (~4 A) to provide heating power inside the incubator"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V fan controlled via the custom PCB to circulate air inside the incubator"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (heat‑bed ON/OFF, fan ON/OFF) to RabbitMQ; the low‑level driver subscribes to these topics and forwards the commands to the GPIO‑controlled MOSFETs, thereby closing the loop to the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture comprises the PT hardware (box, heat‑bed, fan, sensors, PCB), the Raspberry Pi running the controller, low‑level driver, and RabbitMQ server; DT components (model evaluator, calibration routine, monitor) subscribe to broker messages, process data, and publish control actions, forming an integrated CPS‑based digital twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed by comparing simulated temperature trajectories with measured data; uniformity of temperature is verified experimentally using three sensors and varied fan voltages (12 V vs 18 V). Calibration error is minimized using a least‑squares objective; assumptions (uniform temperature, negligible wall heat storage, constant air specific heat) are explicitly stated and tested."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT is realized via the RabbitMQ broker using standard AMQP over TCP/IP on the Raspberry Pi network interface; messages carry sensor readings and control commands."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ server, low‑level driver, controller, and DT services are all hosted on the same Raspberry Pi 4 device, providing an on‑edge deployment of the digital twin."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the PT in a safe state; the controller includes safety limits (LL, UL) and monitors for violations, generating alerts before unsafe temperature excursions occur."
]