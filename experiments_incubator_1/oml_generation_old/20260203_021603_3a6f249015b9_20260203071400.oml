// -----------------------------------------------------
// Physical Sensing Components
// -----------------------------------------------------
instance AirTempInsideSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer measuring air temperature inside the incubator (sensor 1, range –55 °C to +125 °C, 0.5 °C accuracy)."
    DTDFVocab:producedData RabbitMQTemperatureMessage
]

instance AirTempInsideSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer measuring air temperature inside the incubator (sensor 2, same specifications as sensor 1)."
    DTDFVocab:producedData RabbitMQTemperatureMessage
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer measuring the ambient room temperature (range –55 °C to +125 °C, 0.5 °C accuracy)."
    DTDFVocab:producedData RabbitMQTemperatureMessage
]

// -----------------------------------------------------
// Physical Acting Components
// -----------------------------------------------------
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heating element (heat‑bed) switched via a MOSFET driver on the custom PCB; controlled by the Raspberry Pi."
]

instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal circulation fan switched via a MOSFET driver on the custom PCB; controlled by the Raspberry Pi."
]

// -----------------------------------------------------
// Physical‑to‑Virtual Interaction (Data Transmission)
// -----------------------------------------------------
instance RabbitMQTemperatureMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirTempInsideSensor1, AirTempInsideSensor2, AmbientTempSensor
]

// -----------------------------------------------------
// Data Objects
// -----------------------------------------------------
instance TemperatureSensorData : DTDFVocab:Data [
    base:desc "Real‑time temperature measurements streamed from the three DS18S20 sensors."
    DTDFVocab:fromData RabbitMQTemperatureMessage
    DTDFVocab:inputTo EnablerLowLevelDriver, EnablerScipyCalibration, EnablerPythonSimulation
]

instance HistoricalTemperatureData : DTDFVocab:Data [
    base:desc "Stored historical temperature trajectories used for model calibration."
    DTDFVocab:fromData RabbitMQTemperatureMessage
    DTDFVocab:inputTo EnablerScipyCalibration
]

instance CalibratedParametersData : DTDFVocab:Data [
    base:desc "Optimised model parameters obtained after non‑linear least‑squares calibration."
    DTDFVocab:fromData RabbitMQTemperatureMessage
    DTDFVocab:inputTo EnablerPythonSimulation
]

instance PredictedTemperatureDataA : DTDFVocab:Data [
    base:desc "Temperature predictions generated by Model A (single‑parameter air‑heat model)."
    DTDFVocab:fromData RabbitMQTemperatureMessage
    DTDFVocab:inputTo EnablerPythonSimulation
]

instance PredictedTemperatureDataB : DTDFVocab:Data [
    base:desc "Temperature predictions generated by Model B (four‑parameter heat‑bed thermal‑mass model)."
    DTDFVocab:fromData RabbitMQTemperatureMessage
    DTDFVocab:inputTo EnablerPythonSimulation
]

// -----------------------------------------------------
// Models
// -----------------------------------------------------
instance ModelA : DTDFVocab:Model [
    base:desc "Model A – single‑parameter air‑heat model for incubator temperature dynamics."
    DTDFVocab:inputTo EnablerPythonSimulation
]

instance ModelB : DTDFVocab:Model [
    base:desc "Model B – four‑parameter model including heat‑bed thermal mass for more accurate temperature dynamics."
    DTDFVocab:inputTo EnablerPythonSimulation
]

// -----------------------------------------------------
// Enablers (Tooling & Middleware)
// -----------------------------------------------------
instance EnablerRabbitMQ : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker running on the Raspberry Pi; publishes sensor messages and the DT subscribes for real‑time data."
    DTDFVocab:enables RealTimeTemperatureMonitoringService, SafetyViolationDetectionService
]

instance EnablerLowLevelDriver : DTDFVocab:Enabler [
    base:desc "Low‑level driver library providing abstraction for DS18S20 sensors and MOSFET‑controlled actuators."
    DTDFVocab:enables RealTimeTemperatureMonitoringService, HeatingFanControlOptimizationService
]

instance EnablerScipyCalibration : DTDFVocab:Enabler [
    base:desc "Python SciPy non‑linear least‑squares optimisation used to calibrate Model A and Model B against experimental data."
    DTDFVocab:enables ParameterCalibrationService
]

instance EnablerPythonSimulation : DTDFVocab:Enabler [
    base:desc "Python runtime executing temperature prediction simulations using calibrated Model A and Model B."
    DTDFVocab:enables TemperaturePredictionServiceModelA, TemperaturePredictionServiceModelB, HeatingFanControlOptimizationService
]

// -----------------------------------------------------
// Services
// -----------------------------------------------------
instance TemperaturePredictionServiceModelA : DTDFVocab:Service [
    base:desc "Provides temperature prediction simulations using Model A."
    DTDFVocab:provides PredictedTemperatureInsightA
]

instance TemperaturePredictionServiceModelB : DTDFVocab:Service [
    base:desc "Provides temperature prediction simulations using Model B."
    DTDFVocab:provides PredictedTemperatureInsightB
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates Model A and Model B parameters using SciPy non‑linear least‑squares optimisation."
    DTDFVocab:provides CalibratedParametersInsight
]

instance RealTimeTemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Monitors real‑time temperature limits and publishes status updates."
    DTDFVocab:provides TemperatureLimitStatusInsight
]

instance SafetyViolationDetectionService : DTDFVocab:Service [
    base:desc "Detects safety violations when temperature exceeds predefined thresholds."
    DTDFVocab:provides TemperatureSafetyViolationInsight
]

instance HeatingFanControlOptimizationService : DTDFVocab:Service [
    base:desc "Optimises heating‑bed and fan control logic based on model predictions."
    DTDFVocab:provides FanSpeedAdjustmentAction, HeatBedToggleAction
]

// -----------------------------------------------------
// Insights & Actions
// -----------------------------------------------------
instance PredictedTemperatureInsightA : DTDFVocab:Insight [
    base:desc "Insight delivering predicted temperature trajectory from Model A."
]

instance PredictedTemperatureInsightB : DTDFVocab:Insight [
    base:desc "Insight delivering predicted temperature trajectory from Model B."
]

instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Insight exposing the calibrated parameters for Model A and Model B."
]

instance TemperatureLimitStatusInsight : DTDFVocab:Insight [
    base:desc "Insight indicating whether current temperatures are within safe operating limits."
]

instance TemperatureSafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Insight flagging a safety violation when temperature exceeds critical thresholds."
]

instance FanSpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of the internal fan speed based on predicted temperature trends."
    DTDFVocab:IsAutomatic true
]

instance HeatBedToggleAction : DTDFVocab:Action [
    base:desc "Automatic on/off control of the heat‑bed to maintain target temperature."
    DTDFVocab:IsAutomatic true
]

// -----------------------------------------------------
// Environment (Physical Twin)
// -----------------------------------------------------
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains AirTempInsideSensor1, AirTempInsideSensor2, AmbientTempSensor,
                HeatBedActuator, InternalFanActuator,
                RabbitMQTemperatureMessage, EnablerRabbitMQ, EnablerLowLevelDriver
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (heat‑bed ON/OFF, fan ON/OFF, setpoint adjustments) to the RabbitMQ server; the Raspberry Pi controller subscribes, interprets the commands and drives the MOSFETs to actuate the heat‑bed and fan accordingly."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture comprises the Physical Twin (incubator hardware), a Raspberry Pi controller, a low‑level driver, a RabbitMQ communication server, and DT modules (models, calibrators, monitors) that subscribe to and publish on the message bus, forming a closed feedback loop between PT and virtual components."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is based on four assumptions (uniform temperature, negligible wall heat storage, constant air specific heat, negligible fan heat). Validation is performed through uniform‑temperature experiments (sensor comparison) and calibration experiments where model parameters are adjusted to minimise residual error between simulated and measured temperature trajectories."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses RabbitMQ on the Raspberry Pi, employing the AMQP protocol over the local network; messages contain sensor readings and control commands."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT components and the RabbitMQ broker are hosted directly on the Raspberry Pi 4 Model B, providing on‑device deployment without external cloud services."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the hardware in a safe state; the DT includes monitors that check temperature limits and can trigger safety actions when violations are detected."
]