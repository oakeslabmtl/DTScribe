// C3: Physical sensing component // Return code: 1 | Stderr:
instance GeneralPhysicalTwinSensor : DTDFVocab:SensingComponent [
    base:desc "A generic sensor that collects real‑time data streams (temperature, pressure, vibration) from the Physical Twin for digital twin integration."
    DTDFVocab:producedData PTDataTransmission
]

// C4: Data transmitted by the sensor
instance PTDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GeneralPhysicalTwinSensor
]

// C10: Data instance
instance PTData : DTDFVocab:Data [
    base:desc "Real‑time sensor data stream collected over time from the Physical Twin."
    DTDFVocab:fromData PTDataTransmission
    DTDFVocab:inputTo DataAcquisitionLayer, MonitoringModule, SimulationEngine, CalibrationAlgorithm
]

// C10: Model instance
instance PhysTwinModel : DTDFVocab:Model [
    base:desc "Differential equation‑based dynamic model capturing the cyber and physical aspects of the Physical Twin, including geometry, behavior, and analysis."
    DTDFVocab:inputTo CalibrationAlgorithm, SimulationEngine
]

// C11: Enablers
instance DataAcquisitionLayer : DTDFVocab:Enabler [
    base:desc "Data acquisition layer that ingests sensor streams and forwards raw data to downstream enablers."
    DTDFVocab:enables MonitoringService
]

instance ModellingLayer : DTDFVocab:Enabler [
    base:desc "Modelling layer that translates cyber‑physical knowledge into structural, geometric, and behavioral models."
    DTDFVocab:enables OptimizationControlService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine that executes dynamic models to reproduce and predict system behavior."
    DTDFVocab:enables PredictiveSimulationService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Adaptive calibration algorithm that updates model parameters based on live sensor data."
    DTDFVocab:enables ModelCalibrationService
]

instance MonitoringModule : DTDFVocab:Enabler [
    base:desc "Monitoring module that evaluates sensor data against safety and performance thresholds and triggers remediation."
    DTDFVocab:enables SafetyMonitoringService, FaultDetectionService, StateEstimationService, PredictiveMaintenanceService
]

// C6: Services
instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring service providing real‑time safety and performance alerts."
    DTDFVocab:provides SafetyViolationInsight, RecordSafetyViolationAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection service that identifies anomalies in sensor data and operational states."
    DTDFVocab:provides FaultDetectionInsight, ForwardFaultDetectionAction
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "State estimation service that infers hidden system states from noise‑corrupted sensor observations."
    DTDFVocab:provides StateEstimationInsight
]

instance OptimizationControlService : DTDFVocab:Service [
    base:desc "Optimization service that computes optimal control or operational strategies for the Physical Twin."
    DTDFVocab:provides OptimalControlRecommendationInsight, EnactControlAction
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation service that runs dynamic models to forecast future system behavior under various scenarios."
    DTDFVocab:provides PredictiveSimulationInsight, RunPredictiveSimulationAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance service that recommends maintenance actions based on diagnostic analysis."
    DTDFVocab:provides MaintenanceRecommendationInsight, ScheduleMaintenanceAction
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Model calibration service that applies updated parameters to the dynamic model."
    DTDFVocab:provides ParameterUpdateInsight, ApplyCalibrationAction
]

// C17: Insights
instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that safety or performance thresholds have been violated in real time."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the detection of anomalous behavior or fault conditions."
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Insight providing estimates of hidden system states derived from sensor data."
]

instance OptimalControlRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal control actions for maintaining or improving performance."
]

instance PredictiveSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing predictive simulation results for future system states."
]

instance MaintenanceRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending maintenance or remediation actions based on diagnostics."
]

instance ParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight indicating updated model parameters after calibration."
]

instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight indicating general monitoring status of sensor data streams."
]

// C17: Actions
instance RecordSafetyViolationAction : DTDFVocab:Action [
    base:desc "Action to log and record safety violation events for audit and analytics."
    DTDFVocab:IsAutomatic true
]

instance ForwardFaultDetectionAction : DTDFVocab:Action [
    base:desc "Action to forward fault detection findings to human operators or automated control."
    DTDFVocab:IsAutomatic false
]

instance EnactControlAction : DTDFVocab:Action [
    base:desc "Automated control action that enacts optimal operational strategies."
    DTDFVocab:IsAutomatic true
]

instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Action to schedule maintenance tasks based on predictive maintenance insights."
    DTDFVocab:IsAutomatic false
]

instance RunPredictiveSimulationAction : DTDFVocab:Action [
    base:desc "Action to execute predictive simulation runs on demand or at scheduled intervals."
    DTDFVocab:IsAutomatic false
]

instance ApplyCalibrationAction : DTDFVocab:Action [
    base:desc "Action to apply calibrated parameters to the dynamic model."
    DTDFVocab:IsAutomatic true
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service orchestrating monitoring of sensor data streams and triggering downstream enablers."
    DTDFVocab:provides MonitoringInsight
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin integrates modelling, simulation, monitoring, and optimisation within a single framework. Deployment‑time models are continuously updated via calibration algorithms that refine the physics and cyber models of the cyber‑physical system (CPS) and its environment using real‑time sensor data collected from the physical twin. The calibrated models and synthesized data are then provided to safety and optimality monitors which evaluate operational compliance. When a violation is detected, either human operators or autonomous decision‑making algorithms may intervene to modify the physical twin. This orchestration pattern couples data ingestion, model calibration, monitoring, and control within a unified architecture, emphasizing data‑driven updates and closed‑loop decision support."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin life cycle is structured in four main stages: (1) Development and Modeling – engineers construct abstract representations of the physical system, including CAD models for geometry and differential equation‑based dynamic models for physical interactions; (2) Deployment and Integration – the developed models are integrated into the DT framework, making the DT operational alongside the Physical Twin; (3) Data Acquisition and Calibration – sensor data from the PT are continuously collected and used by calibration algorithms to update model parameters and synchronize the cyber‑physical system; (4) Monitoring and Optimization – the calibrated DT runs monitoring algorithms to assess safety and performance, detects violations, and triggers interaction with human operators or supervisory controllers to adjust the Physical Twin. Lifecycle governance involves continuous model refinement and scenario‑based verification but no explicit governance model is detailed in the document."
]