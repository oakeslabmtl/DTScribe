// C2: Acting Components
instance HeatBedResistiveHeater : DTDFVocab:ActingComponent [
    base:desc "High‑temperature resistive heater (HW-HEATER-101) integrated into the heatbed, delivering ~60 W in bang‑bang mode when the temperature falls below 60 °C; it exposes an MQTT topic for status and override control."
]

instance HeatBedBrushlessFan : DTDFVocab:ActingComponent [
    base:desc "Brushless DC fan (HW-FAN-101) operating in bang‑bang on/off mode with a 0–1200 rpm range, synchronized with the heater to maintain airflow during heating cycles; it exposes an MQTT topic for status and override control."
]

// C3: Physical sensing components
instance HeatBedCenterTempSensor : DTDFVocab:SensingComponent [
    base:desc "TMP36 precision silicon thermistor positioned at the center of the heatbed surface; ±0.5 °C accuracy over 0–80 °C range, 0.1 °C resolution; sampled at 1 Hz and transmitted via 115.2 kbit/s serial bus to the local data acquisition unit."
    DTDFVocab:producedData HeatBedCenterTempDataTrans
]

instance HeatBedPeripheralTempSensor : DTDFVocab:SensingComponent [
    base:desc "TMP36 thermistor mounted on the peripheral point of the heatbed to monitor convection effects; ±0.5 °C accuracy over 0–80 °C range, 0.1 °C resolution; sampled at 1 Hz and transmitted via 115.2 kbit/s serial bus to the local data acquisition unit."
    DTDFVocab:producedData HeatBedPeripheralTempDataTrans
]

instance AmbientChamberOutsideTempSensor : DTDFVocab:SensingComponent [
    base:desc "TMP36 thermistor mounted on the ambient chamber wall; ±0.5 °C accuracy over 0–80 °C range, 0.1 °C resolution; sampled at 1 Hz and transmitted via 115.2 kbit/s serial bus to the local data acquisition unit."
    DTDFVocab:producedData AmbientChamberOutsideTempDataTrans
]

// C4: Physical‑to‑virtual interaction
instance HeatBedCenterTempDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatBedCenterTempSensor
]

instance HeatBedPeripheralTempDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatBedPeripheralTempSensor
]

instance AmbientChamberOutsideTempDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientChamberOutsideTempSensor
]

// C10: Models/Data
instance HeatBedCenterTempSeries : DTDFVocab:Data [
    base:desc "Time‑series of center surface temperature values streamed from HeatBedCenterTempDataTrans; subject to timestamp alignment, out‑of‑range filtering, and moving‑average smoothing."
    DTDFVocab:fromData HeatBedCenterTempDataTrans
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, FaultDetectionEnabler
]

instance HeatBedPeripheralTempSeries : DTDFVocab:Data [
    base:desc "Time‑series of peripheral surface temperature values streamed from HeatBedPeripheralTempDataTrans; subject to timestamp alignment, out‑of‑range filtering, and moving‑average smoothing."
    DTDFVocab:fromData HeatBedPeripheralTempDataTrans
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, FaultDetectionEnabler
]

instance AmbientChamberOutsideTempSeries : DTDFVocab:Data [
    base:desc "Time‑series of external ambient chamber temperature values streamed from AmbientChamberOutsideTempDataTrans; subject to timestamp alignment, out‑of‑range filtering, and moving‑average smoothing."
    DTDFVocab:fromData AmbientChamberOutsideTempDataTrans
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, FaultDetectionEnabler
]

instance ChassisCADModel : DTDFVocab:Model [
    base:desc "Geometric CAD representation of the vehicle chassis and wheels used for structural analysis within the Digital Twin."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance VehicleDynamicsBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model expressed by differential equations capturing vehicle physics; updated continuously by calibration algorithms ingesting sensor data."
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, SimulationEngineEnabler
]

instance ThermalAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model for predictive simulation of chamber temperature dynamics; consumes the calibrated thermal sensor series and forecasts future temperature states."
    DTDFVocab:inputTo SimulationEngineEnabler, CalibrationAlgorithmEnabler
]

// C11: Enablers
instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm component that ingests sensor time‑series to update parameters of behavioral and analytical models."
    DTDFVocab:enables MonitoringService, PredictiveSimulationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs predictive simulations of vehicle and thermal dynamics using the CAD, behavioral, and analytical models."
    DTDFVocab:enables PredictiveSimulationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Fault detection module employing algorithms such as fault detectors, supervisory controllers, and state estimators to analyze sensor data streams."
    DTDFVocab:enables MonitoringService
]

instance OptimizationControlEnabler : DTDFVocab:Enabler [
    base:desc "Optimization module that evaluates model predictions and sensor data to adjust operation and issue optimization recommendations."
    DTDFVocab:enables OptimizationService, ControlService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring service that compares model predictions with real‑time sensor data and detects deviations indicating unsafe or sub‑optimal behavior."
    DTDFVocab:provides FaultDetectionInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that applies calibration algorithms to update model parameters and recommends adjustments to meet design constraints."
    DTDFVocab:provides OptimizationRecommendationInsight, AdjustForOptimizationAction
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation service that reproduces and forecasts the physical twin’s behavior under current operating conditions."
    DTDFVocab:provides SimulationForecastInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Control service that communicates detected violations to human operators or automatically triggers controllers to modify the physical twin’s actions."
    DTDFVocab:provides IssueCorrectionAction
]

// C17: Insights/Actions
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Diagnostic insight indicating a fault in the heating cycle, such as overheating beyond the 60 °C safety threshold or relay malfunction."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation insight suggesting adjustments to heater or fan operation to improve energy efficiency while maintaining desired temperature set‑points."
]

instance SimulationForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasted temperature trajectory for the next 10 minutes derived from the predictive simulation of the thermal model."
]

instance AdjustForOptimizationAction : DTDFVocab:Action [
    base:desc "Automated action to adjust heater or fan duty cycle in response to optimization recommendations from the OptimizationService."
    DTDFVocab:IsAutomatic true
]

instance IssueCorrectionAction : DTDFVocab:Action [
    base:desc "Action to trigger corrective measure, such as shutting down the heater or fan, when a fault is detected by the MonitoringService."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT component running on the physical twin’s edge device (e.g., Raspberry Pi) subscribes to a RabbitMQ queue to receive control commands. Commands are formatted as JSON objects containing an action field and associated parameters. Incoming messages are authenticated (e.g., via a shared token) and validated against a predefined JSON schema before being applied. After executing a command, the DT publishes an acknowledgement or status message back to the queue or a dedicated status topic, enabling synchronous feedback to the original controller."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is structured around a centralized orchestration that receives real‑time sensor data from the Physical Twin, feeds this data into calibration algorithms that continually update both cyber‑and physics‑based models, and then circulates the refined model output to monitoring components. These monitors evaluate safety and performance against predefined thresholds, triggering either algorithmic adjustments or human interventions when violations occur. The system thus implements a closed‑loop simulation‑monitor‑actuation workflow sustained by continuous data ingestion, model calibration, and feedback control."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle proceeds through a sequence of phases that begin with the creation of component‑level models—CAD representations for static geometry, dynamic models defined by differential equations for behavioural analysis, and other cyber‑physical abstractions. In the integration phase the DT framework is assembled by linking the physical twin to this model collection, attaching a real‑time data layer that streams sensor measurements, and connecting a set of algorithms (e.g., calibration, fault detection, supervisory control, optimisation). Transition management is effected by continuous calibration: the calibration algorithms ingest live data to estimate the most current parameter set for each model; these updated models are then fed back into the monitoring loop. The DT lifecycle governance involves coordinated data management, model versioning (implicitly captured by calibration snapshots), and decision‑making cycles that monitor for safety and performance violations and trigger human or automated corrective actions. The final operational phase comprises real‑time simulation, prediction, and optimisation that informs the physical twin in real‑time."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is constrained by the assumption of spatial temperature uniformity across the heat‑bed surface (Assumption 1).  Validation is performed through a multi‑stage process: (1) an initial calibration step compares measured temperature trajectories against the nominal plant model predictions and adjusts the time‑constant τ; (2) a residual‑error minimization routine uses a sliding‑window least‑squares fit to quantify model bias over successive 30‑minute cycles; (3) a periodic cross‑check between the sensor and a high‑precision reference thermometer ensures at least ±0.5 °C agreement.  Error detection is facilitated by monitoring the residual trend: a monotonic drift beyond 0.3 °C triggers an automatic re‑calibration routine.  All validation data, residual plots, and re‑calibration logs are archived in the digital twin metadata repository, providing traceability and enabling continuous quality assurance."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT network backbone is built around a RabbitMQ message broker deployed locally on the edge device. Communication between DT components occurs over TCP/IP on the local LAN, using standard MQTT or AMQP protocols. The expected bandwidth is modest (tens of kilobits per second) with latency below 100 ms to support near‑real‑time monitoring. Reliability is ensured through RabbitMQ’s persistence and duplicate‑message detection. Security is handled by TLS‑encrypted connections for the broker, along with token‑based authentication for each client."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted on an edge deployment realized on a Raspberry Pi single‑board computer. The device runs a lightweight Linux OS, hosts the RabbitMQ broker, and runs the DT application. Compute resources include a 1‑GHz ARM CPU, 512 MB RAM, and 16 GB SD storage, sufficient for data ingestion, preprocessing, and lightweight simulation and calibration. The deployment is scalable by adding additional Pi nodes or migrating workloads to a cloud tier if needed, but the current reference implementation is purely on‑premise edge with high availability achieved by local redundancy of the broker queues."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin implements a safety protocol embedded within its low‑level driver layer to maintain the device in a safe operating state. This prototype‑level safety measure ensures that, upon detection of unsafe conditions, the driver initiates appropriate fail‑safe procedures to prevent harm or damage."
]