// C3: Physical sensing components
instance IncubatorHotSpotTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer placed at the hot spot inside the incubator (range –55 °C to +125 °C, accuracy ±0.5 °C within –10 °C to +85 °C)."
    DTDFVocab:producedData HotSpotTempDataTransmitted
]

instance IncubatorColdSpotTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer placed at the cold spot inside the incubator (range –55 °C to +125 °C, accuracy ±0.5 °C within –10 °C to +85 °C)."
    DTDFVocab:producedData ColdSpotTempDataTransmitted
]

instance AmbientRoomTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer measuring ambient room temperature (range –55 °C to +125 °C, accuracy ±0.5 °C within –10 °C to +85 °C)."
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// C4: Physical‑to‑virtual interaction (sensor readings published via RabbitMQ)
instance HotSpotTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorHotSpotTempSensor
    base:desc "Periodic temperature reading from the hot‑spot sensor, published to RabbitMQ by the low‑level driver."
]

instance ColdSpotTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorColdSpotTempSensor
    base:desc "Periodic temperature reading from the cold‑spot sensor, published to RabbitMQ by the low‑level driver."
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientRoomTempSensor
    base:desc "Periodic temperature reading from the ambient room sensor, published to RabbitMQ by the low‑level driver."
]

// C5: Data (processed from transmitted messages)
instance HotSpotTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature value of the incubator hot spot derived from RabbitMQ messages."
    DTDFVocab:fromData HotSpotTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

instance ColdSpotTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature value of the incubator cold spot derived from RabbitMQ messages."
    DTDFVocab:fromData ColdSpotTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped ambient room temperature derived from RabbitMQ messages."
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

// Calibration dataset aggregating all three sensor streams
instance CalibrationDatasetData : DTDFVocab:Data [
    base:desc "Experimental calibration dataset consisting of synchronized temperature readings from hot‑spot, cold‑spot, and ambient sensors."
    DTDFVocab:fromData HotSpotTempDataTransmitted, ColdSpotTempDataTransmitted, AmbientTempDataTransmitted
    DTDFVocab:inputTo SciPyCalibrationEngine
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single‑parameter thermal model (Model A) of the incubator used for fast temperature prediction."
    DTDFVocab:inputTo PythonController
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Four‑parameter thermal model (Model B) including heater thermal inertia, used for more accurate prediction."
    DTDFVocab:inputTo PythonController
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker running on the Raspberry Pi, transports sensor data to the Digital Twin."
    DTDFVocab:enables RuntimeMonitoringService, FaultDetectionService
]

instance SciPyCalibrationEngine : DTDFVocab:Enabler [
    base:desc "Python SciPy non‑linear least‑squares optimizer used to calibrate model parameters (C_air, G_box, C_heater, G_heater)."
    DTDFVocab:enables ParameterCalibrationService
]

instance PythonController : DTDFVocab:Enabler [
    base:desc "Python control software on the Raspberry Pi that implements prediction, bang‑bang heating control and interacts with the PCB."
    DTDFVocab:enables ModelBasedPredictionService, HeatingCycleOptimizationService
]

// C6: Services
instance ModelBasedPredictionService : DTDFVocab:Service [
    base:desc "Provides model‑based temperature predictions using Model A or Model B."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates thermal model parameters from experimental data via SciPy least‑squares optimisation."
    DTDFVocab:provides CalibrationUpdateInsight
]

instance RuntimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuously monitors temperature against configured lower/upper limits during operation."
    DTDFVocab:provides TemperatureLimitAlertInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects safety‑critical temperature violations and raises fault conditions."
    DTDFVocab:provides FaultDetectionInsight
]

instance HeatingCycleOptimizationService : DTDFVocab:Service [
    base:desc "Optimises heating cycles using a bang‑bang controller with configurable limits and durations."
    DTDFVocab:provides HeatingCycleAdjustmentAction
]

// C17: Insights/Actions
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Prediction of future temperature trajectory based on the selected thermal model."
]

instance CalibrationUpdateInsight : DTDFVocab:Insight [
    base:desc "Indicates that model parameters have been updated after calibration."
]

instance TemperatureLimitAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when measured temperature exceeds configured safety limits."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Inspection of fault condition caused by temperature out‑of‑bounds."
]

instance HeatingCycleAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatically adjusts heating and waiting durations of the bang‑bang controller to maintain target temperature."
    DTDFVocab:IsAutomatic true
]

instance CorrectiveHeatingAdjustmentAction : DTDFVocab:Action [
    base:desc "Triggers a corrective increase of heat‑bed power when a temperature limit alert is raised."
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed (214 × 214 × 3 mm) switched by MOSFETs on the custom PCB, provides the primary heating source."
]

instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal fan (≈0.02 m³·s⁻¹) driven through MOSFETs, circulates air to homogenise temperature."
]

// C8: Environment and Physical Components
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains IncubatorContainer, HeatbedComponent, InternalFanComponent, RaspberryPi4Controller, CustomPCBoard, PowerSupply12V24V, HeatbedActuator, InternalFanActuator
]

instance IncubatorContainer : DTDFVocab:Component [
    base:desc "Styrofoam insulated container (~0.03 m³ volume) forming the physical twin."
]

instance HeatbedComponent : DTDFVocab:Component [
    base:desc "Surface heater (heatbed) 214 × 214 × 3 mm mounted inside the incubator."
]

instance InternalFanComponent : DTDFVocab:Component [
    base:desc "Low‑power fan that turns over the air volume in ~2 s."
]

instance RaspberryPi4Controller : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running Linux, hosts the low‑level driver, RabbitMQ broker and Python control software."
]

instance CustomPCBoard : DTDFVocab:Component [
    base:desc "Custom PCB with MOSFETs and optocouplers for safe power switching of heatbed and fan."
]

instance PowerSupply12V24V : DTDFVocab:Component [
    base:desc "12 V / 24 V power supply providing required voltages for actuators and controller."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT (or any client) publishes command messages to the same RabbitMQ broker; the controller subscribed to these topics receives commands and drives the heatbed and fan via the PCB, thus forming the DT→PT control path."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture comprises the PT hardware, a Raspberry Pi controller, a low‑level driver that abstracts sensor/actuator I/O, a RabbitMQ communication server that mediates messages, and DT components that subscribe to the broker to receive sensor data, run the predictive models, perform calibration, and publish control commands. All components can be deployed on the same Pi (centralised) or distributed across networked nodes."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity relies on four assumptions: uniform temperature (validated by fan‑induced mixing experiments showing ≤7 °C spread), negligible wall heat storage, constant air specific heat capacity, and (for Model A) full conversion of electrical power to heat. Model B relaxes the last assumption by modelling heater thermal inertia. Calibration reduces residual error, and experimental uniformity tests assess the validity of the uniform‑temperature assumption."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical components are wired to the Raspberry Pi GPIO pins; the low‑level driver accesses sensors and actuators through MOSFET drivers and optocouplers on the PCB. Software communication between driver, controller, and DT services uses the RabbitMQ message broker running locally on the Pi, employing its native messaging protocol over the Pi’s network stack (TCP/IP)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ broker, low‑level driver, and controller all execute on the Raspberry Pi 4 Model B, providing an on‑device, edge‑hosted DT deployment."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver implements a safe protocol that forces the hardware into a known safe state on communication loss. The DT includes monitoring for safety violations (temperature limits) and can trigger shutdown commands. Use of optocouplers isolates the Raspberry Pi control signals from high‑current actuator circuits."
]