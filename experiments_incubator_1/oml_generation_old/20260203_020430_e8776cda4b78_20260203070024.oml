// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed providing binary on/off heating to the incubator interior."
]

instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal fan that distributes warm air generated by the heat‑bed."
]

// C3: Physical sensing components
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor located inside the insulated styrofoam box monitoring interior temperature."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Second internal temperature sensor inside the insulated styrofoam box monitoring interior temperature."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor measuring ambient temperature outside the incubator."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmission)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA, InternalTempSensorB, ExternalTempSensor
]

instance ActuatorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatBedActuator, InternalFanActuator
]

// C10: Data objects
instance TemperatureData : DTDFVocab:Data [
    base:desc "Raw temperature readings (°C) from the three sensors as published via RabbitMQ."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker, TimeSeriesDatabase, ThermalModelA, ThermalModelB, KalmanFilterEngine
]

instance ActuatorStateData : DTDFVocab:Data [
    base:desc "Binary on/off states of the heat‑bed and fan as published via RabbitMQ."
    DTDFVocab:fromData ActuatorStateDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker, TimeSeriesDatabase
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker using AMQP protocol to decouple low‑level driver, controller and DT components."
    DTDFVocab:enables RealTimeVisualizationService,
                   OnDemandCalibrationService,
                   AnomalyDetectionService,
                   WhatIfSimulationService,
                   SelfAdaptationLoopService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time‑series database storing incoming sensor and actuator data for dashboard visualisation."
    DTDFVocab:enables RealTimeVisualizationService
]

instance KalmanFilterEngine : DTDFVocab:Enabler [
    base:desc "Kalman filter implementation (based on Model B) for heat‑bed state estimation."
    DTDFVocab:enables AnomalyDetectionService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Automatic calibration routine that adjusts free parameters of thermal models on demand."
    DTDFVocab:enables OnDemandCalibrationService
]

instance CoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation platform that replays historic or live PT data for what‑if analyses."
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationLoopEngine : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop orchestrating anomaly detection, experiment scheduling, model recalibration and controller re‑configuration."
    DTDFVocab:enables SelfAdaptationLoopService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Streams sensor and actuator data to a time‑series database and renders an interactive dashboard of temperature, fan and heat‑bed states."
    DTDFVocab:provides TemperatureVisualizationInsight
]

instance OnDemandCalibrationService : DTDFVocab:Service [
    base:desc "Runs calibration routines to automatically update parameters of ThermalModelA and ThermalModelB."
    DTDFVocab:provides ControlParameterAdjustmentInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Detects anomalies and estimates heat‑bed state by fusing measurements with Model B via Kalman filter."
    DTDFVocab:provides AnomalyDetectionInsight,
                   HeatBedStateEstimationInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Performs what‑if simulations using co‑simulation of historic or live PT data to evaluate alternative controller settings."
    DTDFVocab:provides WhatIfSimulationInsight,
                   ControlParameterAdjustmentInsight
]

instance SelfAdaptationLoopService : DTDFVocab:Service [
    base:desc "Executes the self‑adaptation loop: anomaly detection, experiment scheduling, model recalibration, controller re‑configuration and deployment."
    DTDFVocab:provides AdjustControlParametersAction,
                   ReconfigureControllerAction
]

// C17: Insights
instance TemperatureVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualisation of temperature trends inside the incubator."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of abnormal temperature deviations using Kalman filter."
]

instance HeatBedStateEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated state of the heat‑bed derived from Model B and sensor data."
]

instance WhatIfSimulationInsight : DTDFVocab:Insight [
    base:desc "Outcome of scenario analyses for alternative controller parameter settings."
]

instance ControlParameterAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Optimised control limits, heating duration and waiting period suggested by the self‑adaptation loop."
]

// C17: Actions
instance AdjustControlParametersAction : DTDFVocab:Action [
    base:desc "Automatically updates lower/upper temperature limits, heating duration and waiting period in the controller."
    DTDFVocab:IsAutomatic true
]

instance ReconfigureControllerAction : DTDFVocab:Action [
    base:desc "Re‑programs the Raspberry‑Pi controller with new bang‑bang parameters."
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model with two free parameters assuming all supplied electrical power converts to heat (Q = cmΔT)."
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine, CoSimulationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Analytical thermal model with four free parameters capturing heat‑bed thermal inertia."
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine, CoSimulationEngine
]

// C2: Controller component
instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry‑Pi running a bang‑bang controller with configurable lower/upper temperature limits, heating duration and waiting period."
]

// C16: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator,
                  InternalFanActuator,
                  InternalTempSensorA,
                  InternalTempSensorB,
                  ExternalTempSensor,
                  RaspberryPiController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin (or any DT component) sends control commands to the Raspberry Pi controller via RabbitMQ messages. Commands include turning the heatbed on/off, setting heating duration (H), waiting duration (C), and adjusting temperature limits (LL, UL). The controller receives these messages, validates them locally, and actuates the heatbed and fan accordingly; execution confirmation is implied by the controller publishing its state back to RabbitMQ."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The incubator Digital Twin follows a centrally orchestrated, message‑driven architecture. The physical twin (heat‑bed, fan, temperature sensors) is accessed via a low‑level driver that periodically reads sensor values and publishes them to a RabbitMQ message broker. The controller, implemented on a Raspberry Pi as a bang‑bang style regulator, both consumes these sensor topics and publishes actuator commands through the same broker. All DT services—real‑time visualisation, on‑demand calibration, Kalman‑filter based heat‑bed state estimation, what‑if co‑simulation, and the self‑adaptation loop—are realized as independent components that subscribe to the relevant RabbitMQ topics, apply the stored models (Model A or Model B) and algorithms, and publish results back to the broker or to a time‑series database for dashboarding. Coordination and data flow among components are therefore achieved solely via RabbitMQ, providing loose coupling and allowing new DT modules to be added or replaced without modifying the physical twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle described in the documents follows several phases. First, during design and development, physics‑based and data‑driven models (Model A and Model B) are created and calibrated using calibration algorithms (Document 1, Document 4). After the physical twin (PT) is built, the DT is integrated with the PT by connecting sensors to a data acquisition pipeline (Document 1). In the deployment phase, continuous streams of sensor data are collected via the low‑level driver and published to the RabbitMQ communication server (Document 5). Runtime monitoring uses calibrated models and algorithms to check safety and optimality (Document 1). Finally, the DT enters a self‑adaptation loop that iteratively: detects anomalies, schedules experiments, re‑configures the controller, gathers new data, re‑calibrates Model B, updates the Kalman filter, runs what‑if simulations, and re‑configures the controller (Document 4)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is governed by four simplifying assumptions (uniform temperature, negligible wall heat storage, constant air specific heat, and full conversion of electrical power to heat). Model B improves fidelity by relaxing the fourth assumption, resulting in better prediction of heat‑bed inertia as demonstrated in the calibration results (Fig. 13). Validation is performed via experimental runs that compare predicted temperatures against the sensor measurements; calibration algorithms adjust model parameters to minimise error. Uncertainty arises from the assumptions, sensor noise, and incomplete heat‑bed power modelling. Anomaly detection and state estimation are realized with a Kalman filter that flags deviations, providing an error‑detection mechanism. On‑demand calibration and continuous monitoring constitute the quality‑assurance process."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the Physical Twin and the Digital Twin components is realised through a RabbitMQ message broker deployed on premises. RabbitMQ uses the AMQP protocol over TCP/IP, forming a client‑server topology where the Raspberry Pi (controller) and the low‑level driver act as clients. No explicit bandwidth, latency, redundancy, or security specifications (e.g., TLS) are provided in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external software is performed through the open‑source RabbitMQ message broker, which uses the AMQP protocol for publish/subscribe communication. Sensor measurements, controller states, and DT‑generated messages are exchanged via RabbitMQ topics; DT components may forward processed data to a time‑series database that feeds the real‑time dashboard. The documented stack does not reference additional enterprise systems, but the reliance on RabbitMQ enables interoperability with any external system capable of AMQP messaging."
]