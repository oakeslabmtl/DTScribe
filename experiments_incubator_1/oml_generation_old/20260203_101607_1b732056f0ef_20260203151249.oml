// C3: Physical sensing components
instance InsideTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire digital temperature sensor located inside the incubator for temperature feedback"
    DTDFVocab:producedData Inside1TempDataTransmitted
]

instance InsideTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire digital temperature sensor located inside the incubator for temperature feedback"
    DTDFVocab:producedData Inside2TempDataTransmitted
]

instance OutsideTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire digital temperature sensor located outside the incubator for ambient temperature monitoring"
    DTDFVocab:producedData OutsideTempDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance Inside1TempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor1
]

instance Inside2TempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor2
]

instance OutsideTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideTemperatureSensor
]

// D1: Data produced by driver after reading sensor values
instance InsideTempData1 : DTDFVocab:Data [
    base:desc "Inside temperature reading from sensor 1"
    DTDFVocab:fromData Inside1TempDataTransmitted
    DTDFVocab:inputTo CustomPythonDriver
]

instance InsideTempData2 : DTDFVocab:Data [
    base:desc "Inside temperature reading from sensor 2"
    DTDFVocab:fromData Inside2TempDataTransmitted
    DTDFVocab:inputTo CustomPythonDriver
]

instance OutsideTempData : DTDFVocab:Data [
    base:desc "Ambient temperature reading from outside sensor"
    DTDFVocab:fromData OutsideTempDataTransmitted
    DTDFVocab:inputTo CustomPythonDriver
]

// C2: Acting components 
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heating pad controlled via Raspberry Pi GPIO through MOSFET and optocoupler"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Electric fan controlled via Raspberry Pi GPIO through MOSFET and optocoupler"
]

// C11: Enablers
instance CustomPythonDriver : DTDFVocab:Enabler [
    base:desc "Low‑level driver on Raspberry Pi that reads sensors via 1‑Wire, publishes to RabbitMQ over TCP, and provides data to subsequent services"
    DTDFVocab:enables TemperatureDataCollectionService
]

instance RabbitMqBroker : DTDFVocab:Enabler [
    base:desc "Local RabbitMQ broker running on Raspberry Pi 4B over TCP, handling message publication and subscription of temperature data"
    DTDFVocab:enables PredictiveThermalSimulationService, BangBangControllerService
]

instance SciPyLeastSquaresOptimizer : DTDFVocab:Enabler [
    base:desc "Python SciPy least‑squares optimizer used for numerical calibration of Model A and Model B parameters"
    DTDFVocab:enables ParameterCalibrationService
]

// C6: Services
instance TemperatureDataCollectionService : DTDFVocab:Service [
    base:desc "Collects temperature data from DS18S20 sensors via Python async I/O and publishes values to RabbitMQ"
    DTDFVocab:provides TemperatureCollectionInsight
]

instance PredictiveThermalSimulationService : DTDFVocab:Service [
    base:desc "Runs dynamic thermal models (Model A and Model B) to forecast inside‑box temperature for controller adjustments"
    DTDFVocab:provides TemperaturePredictionInsight
]

instance BangBangControllerService : DTDFVocab:Service [
    base:desc "Bang‑bang temperature controller that issues heating and fan control actions based on predicted and measured temperatures"
    DTDFVocab:provides HeaterControlAction, FanControlAction
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Performs data‑driven parameter calibration using SciPy least‑squares to refine model parameters"
    DTDFVocab:provides CalibrationInsight
]

// C10: Models/Data
instance ModelA : DTDFVocab:Model [
    base:desc "Dynamic thermal model A with parameters C_air, G_box, G_heater, C_heater"
    DTDFVocab:inputTo CustomPythonDriver
]

instance ModelB : DTDFVocab:Model [
    base:desc "Dynamic thermal model B with parameters C_air, G_box, G_heater, C_heater"
    DTDFVocab:inputTo CustomPythonDriver
]

// C17: Insights and Actions
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Temperature predictions generated by thermal models forecasting future inside‑box temperature for controller adjustments"
]

instance TemperatureCollectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that temperature data has been successfully collected and stored"
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight providing calibrated model parameters after numerical calibration"
]

instance HeaterControlAction : DTDFVocab:Action [
    base:desc "Command to toggle heatbed heating via Raspberry Pi GPIO through MOSFET control"
    DTDFVocab:IsAutomatic true
]

instance FanControlAction : DTDFVocab:Action [
    base:desc "Command to start or stop electric fan via Raspberry Pi GPIO through MOSFET control"
    DTDFVocab:IsAutomatic true
]

// C17: Environment
instance ThermoIncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator, FanActuator, InsideTemperatureSensor1, InsideTemperatureSensor2, OutsideTemperatureSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin publishes control commands (heatbed on/off, fan on/off, target temperature) to the RabbitMQ server; the Raspberry Pi controller subscribes to these messages, translates them into GPIO/MOSFET signals, and actuates the heatbed and fan accordingly."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation: sensor polling occurs approximately every 1 s, control logic executes upon new samples, and RabbitMQ messages are exchanged with millisecond latency; heating and waiting durations (H and C) are defined in seconds."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "On the Raspberry Pi the communication server (RabbitMQ), low‑level driver, controller, and simulation models form a tightly coupled orchestration; messages flow between PT hardware and DT services via the broker queues."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin covers the as‑designed phase (initial thermal model), manufactured phase (integration of actual hardware on the Raspberry Pi), and operated phase (runtime monitoring and calibration of the models)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Uniform temperature, negligible wall heat accumulation, constant air heat capacity, and heatbed energy accumulation assumptions were experimentally tested; Model B fit measured data better, reducing prediction error to < 1 °C; model validation performed by comparing simulated temperature trajectories with measured traces."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "1‑Wire bus connects DS18S20 sensors to Raspberry Pi GPIO; Raspberry Pi hosts RabbitMQ, communicating over TCP on the local network using AMQP protocol; actuator signals are driven via MOSFETs from Pi GPIO."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin is hosted on the Raspberry Pi 4, running the controller, low‑level driver, RabbitMQ broker, and simulation model code; no external cloud hosting is used."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Employs 1‑Wire sensor protocol, AMQP over TCP for RabbitMQ; development follows open‑source repository practices; industry‑specific standards are not cited."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is implemented in the low‑level driver to maintain device safety; specific encryption or access‑control mechanisms are not detailed, but safety against human exposure is implicit through the use of insulated components and GPIO control."
]