// Sensors
instance BoxInnerTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "First DS18S20 temperature sensor located inside the insulated styrofoam box, collecting high‑precision ambient temperature data over the 1‑Wire bus."
    DTDFVocab:producedData BoxInnerTempDataTx1
]

instance BoxInnerTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 temperature sensor located inside the insulated styrofoam box, providing independent ambient temperature measurements."
    DTDFVocab:producedData BoxInnerTempDataTx2
]

instance RoomTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor positioned outside the insulated box to capture ambient room temperature."
    DTDFVocab:producedData RoomTempDataTx
]

// Data transmitted
instance BoxInnerTempDataTx1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxInnerTempSensor1
]

instance BoxInnerTempDataTx2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxInnerTempSensor2
]

instance RoomTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTempSensor
]

// Command log transmitted
instance CommandLogDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PiControllerActuator
]

// Data
instance BoxInnerTempData1 : DTDFVocab:Data [
    base:desc "Temperature time series collected from the first DS18S20 sensor inside the insulated box."
    DTDFVocab:fromData BoxInnerTempDataTx1
    DTDFVocab:inputTo RabbitMQBroker, PythonCalibrationEnabler
]

instance BoxInnerTempData2 : DTDFVocab:Data [
    base:desc "Temperature time series collected from the second DS18S20 sensor inside the insulated box."
    DTDFVocab:fromData BoxInnerTempDataTx2
    DTDFVocab:inputTo RabbitMQBroker, PythonCalibrationEnabler
]

instance RoomTempData : DTDFVocab:Data [
    base:desc "Ambient room temperature time series recorded by the DS18S20 sensor outside the insulating box."
    DTDFVocab:fromData RoomTempDataTx
    DTDFVocab:inputTo RabbitMQBroker, PythonCalibrationEnabler
]

instance CommandLogData : DTDFVocab:Data [
    base:desc "Control command log from the Raspberry Pi controller, detailing actuator states for batching and debugging."
    DTDFVocab:fromData CommandLogDataTx
    DTDFVocab:inputTo RabbitMQBroker, PythonCalibrationEnabler
]

// Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker (AMQP) running on the Raspberry Pi, handling real‑time ingestion of sensor data and command logs."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveSimulationService, BangBangControllerService
]

instance PythonCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Python ecosystem (numpy, scipy) enabling model calibration and offline data analysis."
    DTDFVocab:enables CalibrationService
]

// Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Continuous‑time thermal model assuming full energy transfer to air, parameterized by C_air, G_box, G_heater."
    DTDFVocab:inputTo RabbitMQBroker
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Continuous‑time thermal model accounting for heatbed heat capacity (C_heater), in addition to heat transfer coefficients G_box and G_heater."
    DTDFVocab:inputTo RabbitMQBroker
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring service providing live temperature feeds and heat‑map visualizations."
    DTDFVocab:provides TemperatureMonitoringInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation service utilizing ThermalModelA and ThermalModelB to forecast temperature evolution."
    DTDFVocab:provides PredictedTemperatureEvolutionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Parameter calibration service performing nonlinear least‑squares optimization using SciPy."
    DTDFVocab:provides ParameterMismatchInsight
]

instance BangBangControllerService : DTDFVocab:Service [
    base:desc "Closed‑loop temperature regulation via bang‑bang controller with user‑defined temperature limits."
    DTDFVocab:provides AdjustHeatingScheduleAction, AdjustFanScheduleAction
]

// Insights
instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Live insights into temperature readings, including anomalies and threshold breaches."
]

instance PredictedTemperatureEvolutionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature evolution computed by the DT, highlighting future thermal trends."
]

instance ParameterMismatchInsight : DTDFVocab:Insight [
    base:desc "Assessment of parameter mismatches identified through model calibration."
]

// Actions
instance AdjustHeatingScheduleAction : DTDFVocab:Action [
    base:desc "Recommended adjustment to heating schedule based on predictive simulation and calibration results."
    DTDFVocab:IsAutomatic false
]

instance AdjustFanScheduleAction : DTDFVocab:Action [
    base:desc "Recommended adjustment to fan schedule to optimize thermal uniformity and energy consumption."
    DTDFVocab:IsAutomatic false
]

// Components
instance HeatbedActuator : DTDFVocab:Component [
    base:desc "Heatbed (heater) actuated via MOSFETs controlled by the Raspberry Pi to raise internal temperature."
]

instance FanActuator : DTDFVocab:Component [
    base:desc "Air circulation fan actuated via optocouplers on the custom PCB to promote temperature uniformity."
]

instance PiControllerActuator : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B acting as the core controller, driving MOSFETs and optocouplers for actuation."
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator, FanActuator, PiControllerActuator,
           BoxInnerTempSensor1, BoxInnerTempSensor2, RoomTempSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (turning the heatbed and fan ON/OFF, and setting actuators) to the RabbitMQ broker, which the Raspberry Pi controller consumes and forwards to the MOSFETs and fan driver, thereby actuating the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation comprises the PT (incubator), low‑level driver, communication server (RabbitMQ), controller, and the virtual model components that subscribe to sensor messages and publish actuator commands; the figure 7 depiction shows the directed data flow between these elements."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design of the incubator hardware and controller, manufacturing of the physical components, commissioning of the PT, and operational monitoring and simulation during the operated phase; the DT covers all phases through modelling, calibration, and live integration."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Assumptions of uniform temperature, negligible wall heat accumulation, constant air heat capacity, and negligible fan heat; experimental validation with three‑sensor temperature distribution (maximum discrepancy 7 °C); model parameters estimated via least‑squares with minimal residual error, providing quantitative fidelity checks."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT occurs over a local RabbitMQ AMQP broker hosted on the Raspberry Pi. Sensors connect via 1‑Wire bus to Pi GPIO; actuators connect via MOSFETs and optocoupler‑isolated GPIO lines. Optional network interfaces (Wi‑Fi or Bluetooth) are available on the Pi but not required for internal messaging."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire DT stack, including RabbitMQ, low‑level driver, controller, and modeling modules, is hosted locally on the Raspberry Pi 4, leveraging its built‑in Wi‑Fi and Bluetooth, enabling on‑device deployment without external servers."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is incorporated into the low‑level driver to maintain device safety; RabbitMQ provides a mature, lightweight message broker; no explicit security mechanisms are described beyond the standard RabbitMQ usage."
]