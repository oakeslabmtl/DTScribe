// C3: Physical sensing component
instance DS18S20TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "High‑precision temperature sensor using DS18S20 1‑Wire digital thermometers mounted inside the incubator enclosure."
    DTDFVocab:producedData TemperatureSensorData
]

instance TemperatureSensorData : DTDFVocab:DataTransmitted [
    base:desc "Raw temperature readings from DS18S20 sensors transmitted via MQTT."
]

// C4: Physical-to-virtual interaction
instance SensorToMQTTData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20TemperatureSensor
]

// C10: Data
instance InfluxTemperatureTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series temperature data stored in InfluxDB after being transmitted via MQTT."
    DTDFVocab:fromData SensorToMQTTData
    DTDFVocab:inputTo CalibrationEnabler
    DTDFVocab:inputTo SimulationEnabler
]

instance CalibratedModelParametersData : DTDFVocab:Data [
    base:desc "Calibrated parameters (thermal conductivity, heat transfer coefficient, fan airflow constant) derived from least‑squares calibration."
    DTDFVocab:inputTo MonitoringEnabler
]

instance SimulatedTemperatureData : DTDFVocab:Data [
    base:desc "Temperature predictions produced by the real‑time thermal simulation model."
    DTDFVocab:inputTo MonitoringEnabler
]

// C11: Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that uses calibration data to update the thermal model parameters."
    DTDFVocab:enables CalibrationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that runs the coupled ODE thermal simulation model using calibrated parameters."
    DTDFVocab:enables SimulationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that applies safety thresholds to simulated and measured temperatures to detect deviations."
    DTDFVocab:enables MonitoringService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that optimizes heatbed and fan duty cycle settings to maximize safety and performance."
    DTDFVocab:enables OptimizationService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that calibrates the thermal model parameters using least‑squares optimization."
    DTDFVocab:provides CalibratedParametersInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs the real‑time thermal simulation model to predict temperature profiles."
    DTDFVocab:provides PredictedTemperatureInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that continuously monitors temperature predictions and measurements against safety limits."
    DTDFVocab:provides SafetyComplianceInsight
    DTDFVocab:provides AlarmAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that optimizes heatbed and fan duty cycles to maintain desired temperature while minimizing energy."
    DTDFVocab:provides OptimalControlInsight
    DTDFVocab:provides ApplyDutyCycleAction
]

// C10: Models
instance ThermalSimulationModel : DTDFVocab:Model [
    base:desc "Coupled ODE thermal simulation model describing heat exchange between heatbed, fan airflow, and ambient air within the styrofoam enclosure."
    DTDFVocab:inputTo SimulationEnabler
]

instance ParameterCalibrationModel : DTDFVocab:Model [
    base:desc "Least‑squares optimization model adjusting thermal conductivity, heat transfer coefficient, and fan airflow constant to minimize residual between measured and simulated temperatures."
    DTDFVocab:inputTo CalibrationEnabler
]

// C17: Insights
instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predictive insight containing future temperature trajectory for the incubator."
]

instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Insight providing updated values of thermal conductivity, heat transfer coefficient, and fan airflow constant after calibration."
]

instance SafetyComplianceInsight : DTDFVocab:Insight [
    base:desc "Insight indicating whether current and predicted temperatures remain within user‑defined operating limits (e.g., 34–39 °C)."
]

instance OptimalControlInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting optimal duty cycle settings for heatbed and fan to sustain desired temperature while reducing energy consumption."
]

// C17: Actions
instance AlarmAction : DTDFVocab:Action [
    base:desc "Automatic action to trigger alarm and optionally shut down the incubator when temperature limits are breached."
    DTDFVocab:IsAutomatic true
]

instance ApplyDutyCycleAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust duty cycle of the heatbed and fan based on optimization results."
    DTDFVocab:IsAutomatic true
]

// C4: Physical sensing components
instance DS18S20SensorComponent : DTDFVocab:Component [
    base:desc "DS18S20 1‑Wire digital thermometer installed in the incubator."
]

// C4: Physical components
instance HeatBed : DTDFVocab:Component [
    base:desc "Heatbed providing heat input to the incubator chamber."
]

instance Fan : DTDFVocab:Component [
    base:desc "Fan delivering airflow and aiding heat removal within the insulated enclosure."
]

instance StyrofoamEnclosure : DTDFVocab:Component [
    base:desc "Insulated styrofoam enclosure forming the thermal boundary of the incubator."
]

instance RaspberryPi4Controller : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B acting as local controller for logic and MQTT communication."
]

instance InfluxDBServer : DTDFVocab:Component [
    base:desc "InfluxDB time‑series database server storing temperature data received via MQTT."
]

instance MQTTBroker : DTDFVocab:Component [
    base:desc "MQTT broker mediating sensor data transfer from the incubator controller to the database."
]

// C10: Environment
instance IncubatorLabEnvironment : DTDFVocab:Environment [
    base:desc "Laboratory environment containing the thermal incubator system and supporting infrastructure."
    base:contains HeatBed, Fan, StyrofoamEnclosure, RaspberryPi4Controller, InfluxDBServer, MQTTBroker, DS18S20SensorComponent
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is architected around three core layers: data acquisition, modelling, and control/optimization algorithms. Sensors on the physical twin emit raw telemetry that is streamed in real‑time (latency typically in the order of milliseconds) into the DT’s data layer, where it is stored in a time‑series database. Calibration algorithms continuously ingest this data to refine the parameters of both cyber (software) and physical (mechanical, environmental) models, ensuring that model predictions remain aligned with actual measurements. A monitoring service consumes the updated predictions and real‑time data to evaluate safety and performance metrics; any detected violations trigger either automated corrective actions or human operators via a decision‑support interface. The system employs a publish/subscribe messaging pattern (e.g., MQTT or RabbitMQ) to coordinate between components, enabling low‑latency communication between the calibration, monitoring, and optimization layers. Resource management is handled through container orchestration (e.g., Docker Compose or Kubernetes), allocating CPU, memory, and network bandwidth to each service based on demand and QoS requirements. This layered orchestration pattern allows tight coupling between physical behavior and digital reaction, while preserving scalability and modularity."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Calibration algorithms update the models of the CPS and environment with the best estimate of parameters, and the resulting data is used by monitors to verify whether the system is performing safely and optimally. Detailed validation and verification methods, uncertainty quantification, error‑correction mechanisms, and quality assurance processes are not specified in the document."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT framework incorporates runtime safety monitoring by continuously evaluating the system's operating parameters against predefined safety and performance thresholds. The monitored sensor outputs are fed into safety monitors which, upon detecting a violation, can trigger a safe‑mode response or halt system operation to prevent hazards. These safety checks are integral to the calibration workflow that updates models based on real‑time data, ensuring that any deviations from expected behavior are identified and addressed before they propagate to the physical twin. No explicit cybersecurity or access‑control mechanisms are described in the provided material."
]