// ------------------------------------------------------------
// C3: Physical sensing components
// ------------------------------------------------------------
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Thermometric sensor placed inside the insulated styrofoam box to monitor air temperature (internal sensor 1)."
    DTDFVocab:producedData InternalTempDataTransmitted1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Thermometric sensor placed inside the insulated styrofoam box to monitor air temperature (internal sensor 2)."
    DTDFVocab:producedData InternalTempDataTransmitted2
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "Thermometric sensor mounted outside the box to record ambient (room) temperature."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// ------------------------------------------------------------
// C4: Physical-to-virtual interaction (DataTransmitted)
// ------------------------------------------------------------
instance InternalTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// ------------------------------------------------------------
// C10: Data definitions (raw temperature readings)
// ------------------------------------------------------------
instance InternalTempData1 : DTDFVocab:Data [
    base:desc "Timestamped temperature reading (°C) from internal sensor 1."
    DTDFVocab:fromData InternalTempDataTransmitted1
    DTDFVocab:inputTo RabbitMQBroker
]

instance InternalTempData2 : DTDFVocab:Data [
    base:desc "Timestamped temperature reading (°C) from internal sensor 2."
    DTDFVocab:fromData InternalTempDataTransmitted2
    DTDFVocab:inputTo RabbitMQBroker
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Timestamped ambient temperature reading (°C) from external sensor."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

// ------------------------------------------------------------
// C2: Acting components
// ------------------------------------------------------------
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heatbed (thermal actuator) switched on/off for a programmable heating duration H."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal fan (air‑flow actuator) turned on to homogenise temperature inside the incubator."
]

// ------------------------------------------------------------
// C11: Enablers
// ------------------------------------------------------------
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker using AMQP protocol; receives temperature messages from the low‑level driver and forwards them to DT services."
    DTDFVocab:enables RealTimeVisualization,
                     ModelCalibration,
                     AnomalyDetection,
                     WhatIfSimulation,
                     SelfAdaptationLoop
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time‑series database storing all incoming temperature readings for visualisation, calibration and anomaly detection."
    DTDFVocab:enables RealTimeVisualization,
                     ModelCalibration,
                     AnomalyDetection,
                     WhatIfSimulation
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Automated calibration routine that estimates free parameters of Model B from sensor data."
    DTDFVocab:enables ModelCalibration
]

instance KalmanFilterEngine : DTDFVocab:Enabler [
    base:desc "Kalman‑filter based state estimator fusing sensor data with Model B predictions to estimate heat‑bed temperature."
    DTDFVocab:enables AnomalyDetection
]

instance VisualizationDashboard : DTDFVocab:Enabler [
    base:desc "Real‑time dashboard visualising temperature trends and controller status."
    DTDFVocab:enables RealTimeVisualization
]

instance CoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation platform executing what‑if scenarios using historical or live PT data."
    DTDFVocab:enables WhatIfSimulation
]

instance SelfAdaptationEngine : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop that triggers experiments, re‑calibrates models, and re‑configures controller parameters."
    DTDFVocab:enables SelfAdaptationLoop
]

// ------------------------------------------------------------
// C6: Services
// ------------------------------------------------------------
instance RealTimeVisualization : DTDFVocab:Service [
    base:desc "Provides real‑time visualisation of incubator temperature status by ingesting messages from RabbitMQ and querying the time‑series database."
    DTDFVocab:provides InsightTemperatureTrend,
                     ActionDisplayDashboard
]

instance ModelCalibration : DTDFVocab:Service [
    base:desc "On‑demand calibration of Model B using incoming temperature data."
    DTDFVocab:provides InsightCalibrationResult,
                     ActionReconfigureController
]

instance AnomalyDetection : DTDFVocab:Service [
    base:desc "Detects anomalies and estimates heat‑bed state via a Kalman filter that fuses sensor data with Model B."
    DTDFVocab:provides InsightAnomalyDetection,
                     ActionAdjustKalmanParameters
]

instance WhatIfSimulation : DTDFVocab:Service [
    base:desc "Executes what‑if simulations through co‑simulation to predict system behaviour under alternative controller settings."
    DTDFVocab:provides InsightWhatIfPrediction,
                     ActionOptimiseControllerParameters
]

instance SelfAdaptationLoop : DTDFVocab:Service [
    base:desc "Runs the self‑adaptation cycle: detects behavioural change, schedules experiments, re‑calibrates models, and updates controller configuration."
    DTDFVocab:provides InsightSelfAdaptationDecision,
                     ActionScheduleExperiment
]

// ------------------------------------------------------------
// C17: Insights
// ------------------------------------------------------------
instance InsightTemperatureTrend : DTDFVocab:Insight [
    base:desc "Real‑time temperature trends visualised on the dashboard."
]

instance InsightCalibrationResult : DTDFVocab:Insight [
    base:desc "Result of Model B calibration, including estimated parameters."
]

instance InsightAnomalyDetection : DTDFVocab:Insight [
    base:desc "Detection of temperature anomalies and estimated heat‑bed temperature."
]

instance InsightWhatIfPrediction : DTDFVocab:Insight [
    base:desc "Predicted system response for alternative heating duration H and waiting interval C."
]

instance InsightSelfAdaptationDecision : DTDFVocab:Insight [
    base:desc "Decision to trigger new experiments or re‑configure controller based on detected behavioural shifts."
]

// ------------------------------------------------------------
// C17: Actions
// ------------------------------------------------------------
instance ActionDisplayDashboard : DTDFVocab:Action [
    base:desc "Updates the visualisation dashboard with latest temperature data."
    DTDFVocab:IsAutomatic true
]

instance ActionReconfigureController : DTDFVocab:Action [
    base:desc "Re‑configures bang‑bang controller limits (LL, UL), heating duration H and waiting duration C using calibrated Model B."
    DTDFVocab:IsAutomatic true
]

instance ActionAdjustKalmanParameters : DTDFVocab:Action [
    base:desc "Adjusts Kalman filter noise covariance matrices based on recent anomaly detection results."
    DTDFVocab:IsAutomatic true
]

instance ActionOptimiseControllerParameters : DTDFVocab:Action [
    base:desc "Optimises controller parameters (H, C) from what‑if simulation outcomes."
    DTDFVocab:IsAutomatic true
]

instance ActionScheduleExperiment : DTDFVocab:Action [
    base:desc "Schedules a data‑gathering experiment to collect new sensor data for re‑calibration."
    DTDFVocab:IsAutomatic true
]

// ------------------------------------------------------------
// Environment and Components
// ------------------------------------------------------------
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InternalTempSensor1,
                 InternalTempSensor2,
                 ExternalTempSensor,
                 HeatbedActuator,
                 FanActuator,
                 RabbitMQBroker,
                 TimeSeriesDatabase,
                 CalibrationEngine,
                 KalmanFilterEngine,
                 VisualizationDashboard,
                 CoSimulationEngine,
                 SelfAdaptationEngine
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi executing the bang‑bang control logic and publishing/receiving messages via RabbitMQ."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands for the heat‑bed and the fan are generated by the controller (a bang‑bang controller with parameters LL, UL, H, C) and sent as RabbitMQ messages to the low‑level driver. The driver validates the commands against its safe protocol before forwarding them to the hardware actuators, then confirms execution back to the controller. The DT can also inject or modify commands by publishing to the same RabbitMQ queues, enabling a closed‑loop self‑adaptation flow."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The incubator Digital Twin is orchestrated around a central RabbitMQ message broker (AMQP) that synchronises communication between the physical twin’s low‑level driver, the Raspberry‑Pi controller, and the DT services. The low‑level driver reads temperature sensors and publishes measurements to RabbitMQ; the controller subscribes to these messages, issues fan and heat‑bed commands, and also publishes its state. DT components (real‑time visualisation, calibration service, Kalman‑filter based anomaly detection, what‑if co‑simulation, and the self‑adaptation loop) subscribe to the same topics, consume the data, update model parameters, run monitors, and publish results back through the broker. Calibration algorithms periodically update model parameters (Model A, Model B) which are then used by monitoring and control optimisation services. Thus the system follows a component‑based, message‑driven architecture with the broker acting as the coordination hub and resource manager for all DT services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The incubator Digital Twin lifecycle described in the documents proceeds through (1) initial hardware and software setup of the physical twin (styrofoam box, heat‑bed, fan, temperature sensors, Raspberry‑Pi controller); (2) development of two simulation models (Model A based on four assumptions, Model B relaxing assumption 4) and their implementation; (3) calibration of the models using calibration algorithms that estimate parameters from sensor data; (4) online monitoring where data from the low‑level driver are streamed via RabbitMQ to the DT; (5) anomaly detection and state estimation (Kalman filter) that feed back into the DT; (6) what‑if simulations and optimisation of controller parameters; and (7) a self‑adaptation loop that re‑configures the controller and re‑calibrates the model when the plant behaviour changes. Transition between stages is managed by the calibration process and the self‑adaptation loop, and the lifecycle is governed by continuous monitoring and re‑calibration."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the predictions of Model A (two free parameters) and Model B (four free parameters) against experimental temperature recordings; experiments demonstrated that Model B more accurately captures the thermal inertia of the heatbed. Fidelity uncertainties stem from the simplifying assumptions (uniform temperature distribution, negligible wall heat storage, constant air specific heat, and complete conversion of electrical power to heat) listed in the modelling section. On‑demand calibration algorithms periodically re‑estimate model parameters using the latest sensor data, reducing parametric error. Validation is performed through on‑line anomaly detection and heat‑bed state estimation using a Kalman filter that fuses Model B with measured temperatures, enabling detection of deviations caused by modelling inaccuracies or unforeseen disturbances. Calibration results are visualised (e.g., Figure 13) to assess model‑parameter convergence, and the self‑adaptation loop re‑calibrates models whenever significant anomalies are detected."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All cyber‑physical communication is mediated by a RabbitMQ message broker using the AMQP protocol. The controller runs on a Raspberry Pi and connects to RabbitMQ over the local network (wired or Wi‑Fi). The topology is a star/bus where each component (controller, low‑level driver, DT modules) is a client of the broker. RabbitMQ provides reliable message delivery, persistence, and can be deployed on‑premise or in the cloud, offering redundancy and fault tolerance. No explicit bandwidth, latency, or security protocol details are provided in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The controller software executes on an on‑board Raspberry Pi (edge device). The RabbitMQ broker and DT services (visualisation dashboard, calibration engine, Kalman filter, what‑if simulation) can be hosted either on‑premise or in a cloud environment, as RabbitMQ is described as easy to deploy in both contexts. Time‑series data are stored in a database for dashboarding. Specific computational, storage, scalability or availability specifications are not detailed in the supplied documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through RabbitMQ message exchanges and a time‑series database that stores sensor streams for dashboards. The DT listens to controller and driver messages (AMQP) and forwards processed data to the database for real‑time visualisation. Co‑simulation for what‑if scenarios can ingest historical or live PT data via the same message channel, allowing external simulation tools to be coupled. No additional enterprise‑level standards (e.g., OPC‑UA) are mentioned; the integration relies on open‑source components (RabbitMQ, time‑series DB, dashboards) and the publicly available GitHub repository for hardware/software artifacts."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The incubator Digital Twin incorporates safety measures through a 'safe protocol' embedded in the low‑level driver, which ensures the physical device remains in a safe state while interacting with the Physical Twin. Communication between the controller and the low‑level driver is mediated by a RabbitMQ message broker, providing synchronized, reliable message exchange for temperature readings, control commands, and state updates. The controller on the Raspberry Pi implements a bang‑bang control strategy with defined upper and lower temperature limits (UL, LL), heating duration (H) and waiting duration (C), and it periodically receives temperature measurements before issuing actuation commands. Although no explicit authentication, access‑control, or encryption mechanisms are described, the combination of the safe driver protocol and the controlled message flow via RabbitMQ constitutes the documented safety and security considerations for this DT system."
]