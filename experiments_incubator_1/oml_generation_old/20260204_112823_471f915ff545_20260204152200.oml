// C3: Physical Sensing Components
instance InternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer deployed inside the Physical Twin enclosure to measure localized thermal gradients with ±0.5°C accuracy and 0.0625°C resolution. Positioned near heatbed and ModelA/B surfaces for spatial temperature monitoring."
    DTDFVocab:producedData InternalTemperatureDataTransmitted
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer deployed outside the Physical Twin enclosure to measure ambient temperature influences with ±0.5°C accuracy and 0.0625°C resolution."
    DTDFVocab:producedData ExternalTemperatureDataTransmitted
]

instance HeatbedTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer embedded near the heated bed to monitor thermal source conditions with ±0.5°C accuracy and 0.0625°C resolution."
    DTDFVocab:producedData HeatbedTemperatureDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance InternalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor
]

instance ExternalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

instance HeatbedTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatbedTemperatureSensor
]

// C10: Models/Data
instance ThermalBehaviorModel : DTDFVocab:Model [
    base:desc "Dynamic model representing thermal mass dynamics and heat transfer within the Physical Twin system, described by differential equations for ModelA/B thermal behavior. Calibrated using non-linear least squares optimization against real-time sensor data."
    DTDFVocab:inputTo NonLinearLeastSquaresSolver
]

instance EnvironmentalThermalModel : DTDFVocab:Model [
    base:desc "Model representing environmental thermal influences on the Physical Twin system, accounting for ambient temperature variations and their impact on internal thermal dynamics."
    DTDFVocab:inputTo NonLinearLeastSquaresSolver
]

instance InternalTemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature measurements collected from internal DS18S20 sensors at configurable polling intervals, transmitted via 1-Wire protocol to RabbitMQ server for processing."
    DTDFVocab:fromData InternalTemperatureDataTransmitted
    DTDFVocab:inputTo NonLinearLeastSquaresSolver
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Ambient temperature measurements collected from external DS18S20 sensors at configurable polling intervals, transmitted via 1-Wire protocol to RabbitMQ server for environmental context analysis."
    DTDFVocab:fromData ExternalTemperatureDataTransmitted
    DTDFVocab:inputTo NonLinearLeastSquaresSolver
]

instance HeatbedTemperatureData : DTDFVocab:Data [
    base:desc "Thermal source measurements collected from heatbed-proximity DS18S20 sensors at configurable polling intervals, transmitted via 1-Wire protocol to RabbitMQ server for control calibration."
    DTDFVocab:fromData HeatbedTemperatureDataTransmitted
    DTDFVocab:inputTo NonLinearLeastSquaresSolver
]

// C11: Enablers
instance RabbitMQServer : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker hosted on RaspberryPi4 ModelB for real-time data streaming between DS18S20 sensors, controllers, and Digital Twin components. Provides message queuing and basic data integrity for distributed processing."
    DTDFVocab:enables RealTimeDataAcquisitionService,
                  StateEstimationService,
                  FaultDetectionService,
                  ParameterCalibrationService
]

instance NonLinearLeastSquaresSolver : DTDFVocab:Enabler [
    base:desc "Python SciPy-based non-linear least squares solver for model calibration, minimizing discrepancies between simulated and observed temperature trajectories to ensure accurate parameter estimation for CPS and environmental models."
    DTDFVocab:enables StateEstimationService,
                  ParameterCalibrationService
]

instance BangBangController : DTDFVocab:Enabler [
    base:desc "Discrete-time bang-bang control algorithm implemented on RaspberryPi4 for Physical Twin temperature regulation, using real-time sensor feedback to maintain setpoint conditions."
    DTDFVocab:enables ControlAdaptationService
]

instance DifferentialEquationFramework : DTDFVocab:Enabler [
    base:desc "Dynamic modeling framework for simulating thermal mass dynamics and heat transfer behavior under current operating conditions, enabling what-if analysis and fault detection scenarios."
    DTDFVocab:enables BehaviorReproductionService,
                  FaultDetectionService
]

// C6: Services
instance RealTimeDataAcquisitionService : DTDFVocab:Service [
    base:desc "Continuous collection of temperature readings from DS18S20 sensors via RaspberryPi4 using periodic polling mechanism, transmitted through RabbitMQ server for real-time processing."
    DTDFVocab:provides TemperatureDataInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Non-linear least squares-based state estimation that calibrates CPS and environmental models against sensor data to ensure accurate parameter estimation for predictive simulations."
    DTDFVocab:provides ModelAccuracyInsight,
                  StateEstimationAction
]

instance BehaviorReproductionService : DTDFVocab:Service [
    base:desc "Dynamic model simulation reproducing Physical Twin's response under current operating conditions using differential equations, enabling what-if analysis and scenario testing."
    DTDFVocab:provides SimulationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Algorithmic monitoring using supervisory controllers to identify deviations from optimal/safe performance based on real-time data comparisons against calibrated models."
    DTDFVocab:provides FaultDetectionInsight,
                  ViolationAlertAction
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Algorithm-driven parameter calibration that updates CPS and environmental models with best-fit parameters to improve predictive accuracy through iterative optimization."
    DTDFVocab:provides ModelImprovementInsight
]

instance ControlAdaptationService : DTDFVocab:Service [
    base:desc "Post-hoc analysis of control strategies via simulated scenarios, enabling engineers to evaluate alternative control approaches beyond the Physical Twin's bang-bang controller implementation."
    DTDFVocab:provides ControlStrategyInsight
]

// C17: Insights/Actions
instance TemperatureDataInsight : DTDFVocab:Insight [
    base:desc "Real-time temperature readings from internal and external DS18S20 sensors providing spatial thermal distribution data for immediate analysis."
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantitative assessment of model calibration accuracy through comparison of simulated vs. observed temperature trajectories, indicating parameter estimation reliability."
]

instance StateEstimationAction : DTDFVocab:Action [
    base:desc "Automated parameter adjustment in CPS and environmental models based on non-linear least squares optimization results to maintain predictive fidelity."
    DTDFVocab:IsAutomatic true
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Predictive simulations of Physical Twin behavior under current operating conditions, enabling what-if scenario analysis and performance evaluation."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of performance deviations from optimal/safe operating ranges through comparison of real-time data against calibrated model expectations."
]

instance ViolationAlertAction : DTDFVocab:Action [
    base:desc "Automated or manual intervention trigger when detected violations (e.g., temperature drift) exceed predefined safety thresholds, initiating corrective actions."
    DTDFVocab:IsAutomatic false
]

instance ModelImprovementInsight : DTDFVocab:Insight [
    base:desc "Analysis of model parameter optimization results showing improved predictive accuracy through iterative calibration processes."
]

instance ControlStrategyInsight : DTDFVocab:Insight [
    base:desc "Comparative analysis of control strategies including the Physical Twin's bang-bang controller and simulated alternatives for performance optimization."
]

// C2: Acting Components
instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "RaspberryPi4 ModelB embedded system responsible for sensor data acquisition, actuation control, and RabbitMQ server hosting for Physical-to-Virtual data transmission."
]

instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Thermal source component providing controlled heating within the Physical Twin enclosure, regulated by the bang-bang controller based on sensor feedback."
]

instance CirculationFan : DTDFVocab:ActingComponent [
    base:desc "Air circulation component ensuring uniform temperature distribution within the Physical Twin enclosure through forced convection."
]

// C5: Environment
instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:desc "Thermal incubator system serving as the Physical Twin, consisting of insulated enclosure, heated bed, circulation fan, and embedded sensing/acting components."
    base:contains StyrofoamEnclosure,
                  HeatbedActuator,
                  CirculationFan,
                  InternalTemperatureSensor,
                  ExternalTemperatureSensor,
                  HeatbedTemperatureSensor,
                  RaspberryPiController
]

instance StyrofoamEnclosure : DTDFVocab:Component [
    base:desc "Insulated styrofoam chamber providing thermal regulation environment for the Physical Twin system, minimizing external thermal influences."
    base:isContainedIn PhysicalTwinEnvironment
]

// C12: Data Storage (Implicit)
instance TimeSeriesDataStorage : DTDFVocab:Enabler [
    base:desc "Implicit time-series data storage mechanism for historical temperature trajectories required for model calibration, though no specific database system (e.g., InfluxDB) is explicitly implemented."
    DTDFVocab:enables ParameterCalibrationService,
                  StateEstimationService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin system communicates control commands to the Physical Twin (PT) through a **low-level driver** integrated with the Raspberry Pi 4 Model B. Commands are issued via the RabbitMQ server, specifically targeting the **fan and heatbed** of the system, utilizing a **bang-bang controller** for actuation. Message formats are not explicitly detailed, but the system employs a **safe protocol** to ensure command execution integrity. No explicit validation, authentication, or feedback mechanisms are described beyond the implicit reliance on the RabbitMQ server for command transmission. Conflict resolution or command execution confirmation mechanisms are not mentioned in the provided documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows an architecture pattern that integrates three core components: **Data** (collected from the PT via sensors), **Models** (abstract representations of the PT's cyber and physical aspects), and **Algorithms** (e.g., fault detectors, supervisory controllers, state estimators, and optimizers). These components are orchestrated to enable continuous monitoring, predictive analysis, and optimization of the PT. The system employs calibration algorithms to update models dynamically, ensuring alignment between the digital and physical representations. Resource management is implied through the use of these algorithms, which manipulate data and models to generate actionable insights. System-wide coordination is achieved via feedback loops where detected violations (e.g., safety or performance issues) trigger human or automated interventions to adjust the PT. The document highlights a closed-loop architecture where the DT's outputs inform real-time decisions for the PT."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
The Digital Twin system emphasizes **model fidelity** through **validation and verification (V&V) processes** rooted in **model assumptions** and **calibration methodologies**. Model fidelity is ensured by comparing simulated outputs (from behavioral models) with **real-time sensor data trajectories** using a **non-linear least squares optimization** technique to minimize a cost function. This process adjusts model parameters iteratively, reducing discrepancies between the Digital Twin and Physical Twin behaviors. **Uncertainty quantification** is implicitly addressed via the calibration process, where deviations from observed data are treated as errors to be minimized. **Error detection and correction** are handled through the calibration algorithms, which refine model parameters dynamically. However, the documents do not explicitly detail **periodic recalibration schedules**, **convection effects**, or **quality assurance processes** beyond the calibration framework. The system assumes that model assumptions (e.g., thermal dynamics, environmental interactions) are sufficiently captured by the chosen behavioral models and sensor data.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin system employs a **local network infrastructure** centered around a **Raspberry Pi 4 Model B**, which supports **wireless internet (Wi-Fi and Bluetooth)** for communication. The system uses a **RabbitMQ server** hosted on the Raspberry Pi for message brokering, facilitating communication between the Physical Twin and Digital Twin components. No explicit mention of network topology (e.g., edge/core/cloud layers), bandwidth requirements, latency specifications, or redundancy mechanisms (e.g., failover protocols) is provided. Security protocols are not detailed beyond the implicit use of RabbitMQ for message integrity, though the Raspberry Pi’s built-in Wi-Fi may incorporate basic encryption (e.g., WPA2/WPA3)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin system is deployed on a **Raspberry Pi 4 Model B**, which serves as both the hosting platform and computational unit. The RabbitMQ server is installed and runs **on the Raspberry Pi itself**, indicating an **on-premise, single-node deployment model**. No cloud or edge computing components are referenced. The system’s computational requirements are limited to the Raspberry Pi’s ARM-based processor and basic memory/storage capabilities, with no mention of scalability mechanisms, orchestration tools, or high-availability features. Availability/reliability assurance is not explicitly addressed beyond the system’s reliance on the Raspberry Pi’s hardware and RabbitMQ’s basic fault tolerance."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "
The Digital Twin (DT) system incorporates a **low-level driver protocol** designed to maintain the Physical Twin (PT) in a **safe operational state** by enforcing predefined constraints. While the document does not explicitly detail comprehensive cybersecurity protocols (e.g., encryption, firewalls, or authentication frameworks), it highlights that the DT framework integrates **monitoring algorithms** to detect deviations from safe performance. These monitors leverage real-time data from the PT to trigger **safety checks**, ensuring compliance with operational boundaries. The system’s **calibration algorithms** refine models dynamically, reducing the risk of misalignment between the DT and PT, thereby indirectly supporting safety-critical operations. However, no explicit mention of **access control mechanisms**, **threat mitigation strategies**, or **risk assessment methodologies** (e.g., penetration testing, vulnerability scanning) is provided in the context. The document emphasizes **safety** as a core outcome of DT integration but lacks granular technical specifications for security hardening or compliance frameworks (e.g., ISO 27001, NIST SP 800-53)."
]