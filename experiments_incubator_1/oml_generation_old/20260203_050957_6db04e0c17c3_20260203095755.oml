// ==================== C3: Physical sensing components ====================
// Inside incubator, high position sensor
instance IncubatorAirTempSensorHigh : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (‑55 °C to +125 °C, ±0.5 °C accuracy 10 °C‑85 °C) mounted at the top inside the insulated incubator"
    DTDFVocab:producedData IncubatorHighTempMessage
]
// Inside incubator, low position sensor
instance IncubatorAirTempSensorLow : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (‑55 °C to +125 °C, ±0.5 °C accuracy 10 °C‑85 °C) mounted at the bottom inside the insulated incubator"
    DTDFVocab:producedData IncubatorLowTempMessage
]
// External room temperature sensor
instance RoomTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (‑55 °C to +125 °C, ±0.5 °C accuracy 10 °C‑85 °C) located outside the incubator to measure ambient room temperature"
    DTDFVocab:producedData RoomTempMessage
]

// ==================== C4: Physical‑to‑virtual interaction ====================
// Message format produced by the three sensors
instance IncubatorHighTempMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorAirTempSensorHigh
]
instance IncubatorLowTempMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorAirTempSensorLow
]
instance RoomTempMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTempSensor
]

// ==================== C10: Data objects ====================
// Individual temperature readings extracted from messages
instance IncubatorHighTempReading : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from the high‑position incubator sensor, sampled at ≈1 Hz"
    DTDFVocab:fromData IncubatorHighTempMessage
    DTDFVocab:inputTo RabbitMQBroker, ModelExecutionEngine, SciPyLeastSquaresOptimizer
]
instance IncubatorLowTempReading : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from the low‑position incubator sensor, sampled at ≈1 Hz"
    DTDFVocab:fromData IncubatorLowTempMessage
    DTDFVocab:inputTo RabbitMQBroker, ModelExecutionEngine, SciPyLeastSquaresOptimizer
]
instance RoomTempReading : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from the external room sensor, sampled at ≈1 Hz"
    DTDFVocab:fromData RoomTempMessage
    DTDFVocab:inputTo RabbitMQBroker, ModelExecutionEngine, SciPyLeastSquaresOptimizer
]

// Aggregated calibration dataset (temperature + power)
instance CalibrationDataset : DTDFVocab:Data [
    base:desc "Combined dataset of temperature trajectories from all three DS18S20 sensors and corresponding power input (V·I·Δt) used for parameter identification"
    DTDFVocab:inputTo SciPyLeastSquaresOptimizer
]

// ==================== C2: Acting components ====================
// Heat‑bed actuator
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET‑controlled heating element (214 mm × 214 mm × 3 mm) switched on/off (and PWM‑modulated) via Raspberry Pi GPIO"
]
// Internal fan actuator
instance IncubatorFanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V circulation fan (≈0.02 m³ s⁻¹) driven by MOSFET stage and controllable (on/off, voltage adjustable) via Raspberry Pi GPIO"
]
// MOSFET/optocoupler isolation stage
instance MOSFETIsolationStage : DTDFVocab:ActingComponent [
    base:desc "Printed‑circuit‑board MOSFET and optocoupler stage that isolates the Pi from high‑current loads for safe actuation of the heat‑bed and fan"
]

// ==================== C11: Enablers ====================
// RabbitMQ message broker
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "AMQP broker running on the Raspberry Pi, receives temperature messages from the low‑level driver and forwards them to DT services"
    DTDFVocab:enables RealTimeTemperatureMonitoring, ModelParameterCalibration
]
// SciPy non‑linear least‑squares optimizer
instance SciPyLeastSquaresOptimizer : DTDFVocab:Enabler [
    base:desc "Python SciPy implementation of Levenberg‑Marquardt used to calibrate model parameters (C_air, G_box, …) against experimental data"
    DTDFVocab:enables ModelParameterCalibration
]
// Bang‑bang controller engine with hysteresis
instance BangBangControllerEngine : DTDFVocab:Enabler [
    base:desc "Python controller implementing bang‑bang logic with lower/upper temperature limits and configurable heating/waiting durations"
    DTDFVocab:enables FaultDetectionAndControl
]
// Data logger & visualization tool
instance DataLoggerTool : DTDFVocab:Enabler [
    base:desc "Python logging module plus optional Grafana/InfluxDB stack for persisting sensor streams and control actions"
    DTDFVocab:enables DataLoggingAndVisualization
]
// Model execution engine
instance ModelExecutionEngine : DTDFVocab:Enabler [
    base:desc "Runtime component that executes calibrated physics‑based thermal models (Model A, Model B) to predict future temperature trajectories"
    DTDFVocab:enables ThermalModelPrediction
]

// ==================== C6: Services ====================
// Real‑time temperature monitoring and safety checking
instance RealTimeTemperatureMonitoring : DTDFVocab:Service [
    base:desc "Continuously monitors incoming temperature streams, validates ranges and raises safety alerts"
    DTDFVocab:provides TemperatureSafetyAlert, LogEntryInsight
]
// Execution of calibrated physics‑based models
instance ThermalModelPrediction : DTDFVocab:Service [
    base:desc "Runs Model A or Model B using current parameters to forecast incubator air temperature"
    DTDFVocab:provides TemperaturePredictionInsight
]
// Parameter calibration service
instance ModelParameterCalibration : DTDFVocab:Service [
    base:desc "Optimises model parameters (C_air, G_box, C_heater, G_heater, …) via SciPy least‑squares against calibration dataset"
    DTDFVocab:provides ParameterUpdateInsight, LogEntryInsight
]
// Fault detection and supervisory control
instance FaultDetectionAndControl : DTDFVocab:Service [
    base:desc "Detects temperature limit violations and drives the bang‑bang controller to command heating or waiting actions"
    DTDFVocab:provides HeatBedOnAction, HeatBedOffAction, FanOnAction, FanOffAction, TemperatureSafetyAlert
]
// Data logging and visualisation
instance DataLoggingAndVisualization : DTDFVocab:Service [
    base:desc "Records sensor readings, controller decisions and model predictions; provides visual dashboards"
    DTDFVocab:provides LogEntryInsight
]

// ==================== C17: Insights / Actions ====================
// Insights
instance TemperatureSafetyAlert : DTDFVocab:Insight [
    base:desc "Alert raised when temperature exceeds predefined upper or lower safety limits"
]
instance ParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Notification that model parameters have been successfully updated after calibration"
]
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted future temperature trajectory generated by the selected thermal model"
]
instance LogEntryInsight : DTDFVocab:Insight [
    base:desc "Standard log entry summarising sensor data, decisions and actions for audit"
]

// Actions
instance HeatBedOnAction : DTDFVocab:Action [
    base:desc "Command to switch the heat‑bed MOSFET on (or increase PWM duty cycle) to raise temperature"
    DTDFVocab:IsAutomatic true
]
instance HeatBedOffAction : DTDFVocab:Action [
    base:desc "Command to switch the heat‑bed MOSFET off (or decrease PWM duty cycle) to stop heating"
    DTDFVocab:IsAutomatic true
]
instance FanOnAction : DTDFVocab:Action [
    base:desc "Command to power the internal circulation fan"
    DTDFVocab:IsAutomatic true
]
instance FanOffAction : DTDFVocab:Action [
    base:desc "Command to stop the internal circulation fan"
    DTDFVocab:IsAutomatic true
]

// ==================== C10: Models ====================
// Single‑energy‑balance air model (Model A)
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Physics‑based thermal model with one energy balance for air; parameters C_air (thermal capacitance) and G_box (conductance to environment)"
    DTDFVocab:inputTo ModelExecutionEngine, SciPyLeastSquaresOptimizer
]
// Dual‑energy‑balance model (Model B)
instance ThermalModelB : DTDFVocab:Model [
    base:desc "Physics‑based thermal model with separate energy balances for heat‑bed and air; parameters C_heater, C_air, G_heater, G_box"
    DTDFVocab:inputTo ModelExecutionEngine, SciPyLeastSquaresOptimizer
]

// ==================== C9: Environment & Components ====================
// Physical environment (incubator)
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, IncubatorFanActuator, MOSFETIsolationStage,
               IncubatorAirTempSensorHigh, IncubatorAirTempSensorLow, RoomTempSensor
]

// General component (Raspberry Pi host)
instance RaspberryPiHost : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B providing GPIO, Wi‑Fi/Bluetooth, running the low‑level driver, RabbitMQ broker and DT services"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands (heat‑bed ON/OFF, fan ON/OFF, optional fan voltage level) as AMQP messages to the RabbitMQ server. The controller process on the Raspberry Pi subscribes to these command queues, interprets the messages and drives the MOSFET/optocoupler outputs to actuate the heat‑bed and fan accordingly."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture is a centralized constellation where the Raspberry Pi hosts the PT hardware interface, the RabbitMQ broker, the low‑level driver and the controller. The DT components (model simulators, calibration engine, monitoring dashboards) run as separate processes or services that subscribe to the same RabbitMQ topics, forming a tightly coupled cyber‑physical loop. All communication follows a publish/subscribe pattern through the broker."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is based on four explicit assumptions (uniform air temperature, negligible wall heat storage, constant air specific heat, and either full power conversion to air heat or inclusion of heat‑bed storage). Validation experiments measured temperature uniformity across three sensor locations, showing a maximum 7 °C deviation (6 °C with higher fan voltage). Calibration residuals are minimised via least‑squares; the calibrated Model B, with four free parameters, showed superior prediction of thermal inertia, indicating higher fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The PT and DT exchange data over the local network using AMQP protocol handled by RabbitMQ on the Raspberry Pi. Messages are transported over TCP/IP (implicitly via the Pi's Wi‑Fi or Ethernet interface). The low‑level driver acts as the PT side publisher; the controller and DT services act as subscribers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT software components (RabbitMQ broker, low‑level driver, controller, model simulators, calibration scripts) are deployed on the same Raspberry Pi 4 Model B that also hosts the PT hardware. Source code, schematics and documentation are hosted publicly on GitHub (https://github.com/INTO-CPS-Association/example‑incubator)."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol that ensures the PT remains in a safe state if communication fails. MOSFET drivers are isolated from the Raspberry Pi by optocouplers to prevent electrical faults. The DT includes monitoring of temperature limits and can halt heating if safety thresholds are breached. Communication security (authentication/encryption) is not explicitly described in the document."
]