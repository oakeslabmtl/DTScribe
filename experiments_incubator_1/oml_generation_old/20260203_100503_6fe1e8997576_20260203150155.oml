// C3: Physical sensing components
instance WheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel speed sensor installed on each wheel measuring instantaneous rotational speed."
    DTDFVocab:producedData WheelSpeedDataTransmitted
]

instance EnginePressureSensor : DTDFVocab:SensingComponent [
    base:desc "Engine pressure sensor measuring cylinder pressure."
    DTDFVocab:producedData EnginePressureDataTransmitted
]

// C4: Physical-to-virtual interaction
instance WheelSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedSensor
]

instance EnginePressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnginePressureSensor
]

// C10: Models/Data
instance WheelSpeedMeasurementData : DTDFVocab:Data [
    base:desc "Time-stamped wheel speed measurements from the vehicle's physical twin."
    DTDFVocab:fromData WheelSpeedDataTransmitted
    DTDFVocab:inputTo SafetyMonitorEnabler, PredictionEnabler
]

instance EnginePressureMeasurementData : DTDFVocab:Data [
    base:desc "Time-stamped engine pressure measurements from the vehicle's physical twin."
    DTDFVocab:fromData EnginePressureDataTransmitted
    DTDFVocab:inputTo SafetyMonitorEnabler, PredictionEnabler
]

instance VehicleDynamicModel : DTDFVocab:Model [
    base:desc "Differential equation model encoding the vehicle's mechanical dynamics."
    DTDFVocab:inputTo PredictionEnabler
]

instance CalibrationModel : DTDFVocab:Model [
    base:desc "Calibration algorithm to update model parameters to match runtime sensor observations."
    DTDFVocab:inputTo OptimizationEnabler
]

// C11: Enablers
instance SafetyMonitorEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that receives sensor data and evaluates safety metrics against calibrated model parameters."
    DTDFVocab:enables MonitoringService
]

instance PredictionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that forwards data to prediction service for forward-time simulation."
    DTDFVocab:enables PredictionService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that supplies data to optimization service adjusting control inputs or suggesting maintenance actions."
    DTDFVocab:enables OptimizationService
]

instance ControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that provides data to control service to generate command recommendations."
    DTDFVocab:enables ControlService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that feeds data to visualization service for rendering CAD-based geometry and simulation outputs."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring service that evaluates safety and performance against calibrated model parameters."
    DTDFVocab:provides SafetyInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Prediction service that runs forward-time simulations reproducing and forecasting vehicle dynamics."
    DTDFVocab:provides ForecastInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that incorporates supervisory algorithms to adjust control inputs or suggest maintenance actions."
    DTDFVocab:provides OptimizationSolutionInsight, MaintenanceAction
]

instance ControlService : DTDFVocab:Service [
    base:desc "Control service that can provide command recommendations or automated actuator directives."
    DTDFVocab:provides CommandRecommendationAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualization service that renders updated CAD-based geometry and simulation outputs."
    DTDFVocab:provides VisualInsight
]

// C17: Insights/Actions
instance SafetyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating potential safety violations based on monitoring data."
]

instance ForecastInsight : DTDFVocab:Insight [
    base:desc "Insight predicting vehicle dynamic response under current operating conditions."
]

instance OptimizationSolutionInsight : DTDFVocab:Insight [
    base:desc "Insight providing optimal control inputs or maintenance suggestions derived from optimization service."
]

instance MaintenanceAction : DTDFVocab:Action [
    base:desc "Recommended maintenance action suggested by optimization service."
    DTDFVocab:IsAutomatic false
]

instance CommandRecommendationAction : DTDFVocab:Action [
    base:desc "Command recommendation for actuators provided by control service."
    DTDFVocab:IsAutomatic false
]

instance VisualInsight : DTDFVocab:Insight [
    base:desc "Visualization of updated CAD-based geometry and simulation outputs."
]

// C3: Physical components
instance PassengerAutomotiveVehicle : DTDFVocab:Component [
    base:desc "Passenger automotive vehicle comprising a rigid-body chassis, wheel assemblies, an internal combustion engine, a transmission system, and body modules."
]