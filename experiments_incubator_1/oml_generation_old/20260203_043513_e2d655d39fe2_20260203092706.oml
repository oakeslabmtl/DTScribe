// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed (surface planar heater) driven via MOSFETs on the custom PCB; can be commanded ON/OFF by the controller"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V fan for air circulation driven via MOSFETs on the custom PCB; can be commanded ON/OFF by the controller"
]

// C3: Physical sensing components
instance ChamberTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer inside the incubation chamber (–55 °C to +125 °C, 0.5 °C accuracy)"
    DTDFVocab:producedData ChamberTempDataTransmitted1
]

instance ChamberTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer inside the incubation chamber (–55 °C to +125 °C, 0.5 °C accuracy)"
    DTDFVocab:producedData ChamberTempDataTransmitted2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer measuring ambient (room) temperature (–55 °C to +125 °C, 0.5 °C accuracy)"
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance ChamberTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChamberTempSensor1
]

instance ChamberTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChamberTempSensor2
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// C5: Data
instance ChamberTemperatureData1 : DTDFVocab:Data [
    base:desc "Temperature reading from ChamberTempSensor1 used for monitoring, calibration and prediction"
    DTDFVocab:fromData ChamberTempDataTransmitted1
    DTDFVocab:inputTo RabbitMQBroker, CalibrationEngine, SimulationEngine
]

instance ChamberTemperatureData2 : DTDFVocab:Data [
    base:desc "Temperature reading from ChamberTempSensor2 used for monitoring, calibration and prediction"
    DTDFVocab:fromData ChamberTempDataTransmitted2
    DTDFVocab:inputTo RabbitMQBroker, CalibrationEngine, SimulationEngine
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Ambient temperature reading from AmbientTempSensor used for monitoring and as environmental boundary condition"
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker, CalibrationEngine, SimulationEngine
]

// C10: Models/Data
instance ModelA : DTDFVocab:Model [
    base:desc "Thermal Model A – single‑capacitance air model with heat loss to the environment"
    DTDFVocab:inputTo SimulationEngine
]

instance ModelB : DTDFVocab:Model [
    base:desc "Thermal Model B – dual‑capacitance model adding heat‑bed thermal inertia"
    DTDFVocab:inputTo SimulationEngine
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on the Raspberry Pi; receives periodic temperature messages from the low‑level driver"
    DTDFVocab:enables TemperatureMonitoringService, ModelCalibrationService, TemperaturePredictionService, TemperatureAlertService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Python calibration script using SciPy non‑linear least‑squares optimisation to calibrate Model A and Model B parameters"
    DTDFVocab:enables ModelCalibrationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine executing calibrated Model A and Model B to predict future temperature dynamics"
    DTDFVocab:enables TemperaturePredictionService
]

instance ActuationController : DTDFVocab:Enabler [
    base:desc "Python controller on the Raspberry Pi that drives MOSFETs to switch the heat‑bed and fan"
    DTDFVocab:enables HeatBedControlService
]

// C6: Services
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of chamber temperature using sensor data streamed via RabbitMQ"
    DTDFVocab:provides InsightTemperatureWithinLimits
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Calibration of thermal model parameters (C_air, G_box, C_heater, G_heater) from experimental temperature trajectories"
    DTDFVocab:provides InsightUpdatedModelParameters
]

instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Simulation of temperature evolution using calibrated Model A and Model B"
    DTDFVocab:provides InsightPredictedTemperature
]

instance TemperatureAlertService : DTDFVocab:Service [
    base:desc "Alerting when chamber temperature exceeds configured lower or upper limits"
    DTDFVocab:provides InsightTemperatureAlert, ActionSendAlert
]

instance HeatBedControlService : DTDFVocab:Service [
    base:desc "Automated control of the heat‑bed (activation, deactivation) and fan to keep temperature within limits"
    DTDFVocab:provides ActionActivateHeatBed, ActionDeactivateHeatBed
]

// C17: Insights
instance InsightUpdatedModelParameters : DTDFVocab:Insight [
    base:desc "Updated model parameters (C_air, G_box, C_heater, G_heater) after calibration"
]

instance InsightPredictedTemperature : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory over the upcoming time horizon"
]

instance InsightTemperatureWithinLimits : DTDFVocab:Insight [
    base:desc "Current chamber temperature is maintained within the configured lower and upper bounds"
]

instance InsightTemperatureAlert : DTDFVocab:Insight [
    base:desc "Temperature has exceeded the configured safety limits"
]

// C17: Actions
instance ActionActivateHeatBed : DTDFVocab:Action [
    base:desc "Command to turn ON the heat‑bed"
    DTDFVocab:IsAutomatic true
]

instance ActionDeactivateHeatBed : DTDFVocab:Action [
    base:desc "Command to turn OFF the heat‑bed"
    DTDFVocab:IsAutomatic true
]

instance ActionSendAlert : DTDFVocab:Action [
    base:desc "Send temperature‑limit breach alert to the operator"
    DTDFVocab:IsAutomatic false
]

// C13: Environment (optional, for completeness)
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, FanActuator, ChamberTempSensor1, ChamberTempSensor2, AmbientTempSensor, RabbitMQBroker, ActuationController, CalibrationEngine, SimulationEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (e.g., heat‑bed ON/OFF, fan ON/OFF, heating duration, waiting duration) are sent from the digital twin to the controller via RabbitMQ; the controller interprets these commands and actuates the heat‑bed and fan through the PCB MOSFET drivers."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A three‑layer architecture: (1) Physical layer – incubator hardware; (2) Communication layer – RabbitMQ server on the Pi mediating messages; (3) Software layer – low‑level driver abstracts sensor/actuator I/O, controller implements a bang‑bang‑like logic, and digital‑twin modules subscribe to sensor data and publish control commands, forming a closed feedback loop."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Assumptions underlying the models (uniform temperature, negligible wall heat storage, constant air specific heat, dominant heat‑bed power) are explicitly listed; uniformity is experimentally verified by comparing three sensor locations; model fidelity is assessed by calibrating parameters and minimizing residual error; validation experiments test temperature discrepancy under different fan voltages."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Message exchange over RabbitMQ (AMQP protocol) running on the Raspberry Pi, linking the low‑level driver, controller, and digital‑twin components; communication uses TCP/IP within the local network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "RabbitMQ broker and all DT software components (driver, controller, calibration and simulation modules) are hosted on the same Raspberry Pi 4 that also runs the physical controller."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the device in a safe state; the controller monitors temperature limits (LL, UL) and can stop actuation if limits are violated, providing basic safety safeguards."
]