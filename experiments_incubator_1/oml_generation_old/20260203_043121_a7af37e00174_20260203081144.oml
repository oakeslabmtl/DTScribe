// C3: Physical sensing components
instance InternalTempSensorTop : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor placed at the top inside the incubator (range –55 °C to +125 °C, ±0.5 °C accuracy, 0.5 °C resolution)."
    DTDFVocab:producedData InternalTempDataTransmittedTop
]

instance InternalTempSensorBottom : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor placed at the bottom inside the incubator (range –55 °C to +125 °C, ±0.5 °C accuracy, 0.5 °C resolution)."
    DTDFVocab:producedData InternalTempDataTransmittedBottom
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor mounted on the external surface of the incubator enclosure (range –55 °C to +125 °C, ±0.5 °C accuracy, 0.5 °C resolution)."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Physical-to-virtual interaction
instance InternalTempDataTransmittedTop : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorTop
]

instance InternalTempDataTransmittedBottom : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorBottom
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// C10: Data
instance InternalTempDataTop : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements from the top internal DS18S20 sensor."
    DTDFVocab:fromData InternalTempDataTransmittedTop
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, PredictionEnabler
]

instance InternalTempDataBottom : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements from the bottom internal DS18S20 sensor."
    DTDFVocab:fromData InternalTempDataTransmittedBottom
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, PredictionEnabler
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements from the external DS18S20 sensor."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, PredictionEnabler
]

// C11: Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithms that estimate the free parameters of the two‑parameter and four‑parameter thermal models using sensor data."
    DTDFVocab:enables CalibrationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring algorithms that evaluate safety and optimality constraints based on sensor data and model predictions."
    DTDFVocab:enables SafetyCheckService, OptimalityCheckService, AlertService
]

instance PredictionEnabler : DTDFVocab:Enabler [
    base:desc "Simulation module that runs the calibrated thermal models to predict internal temperature under current operating conditions."
    DTDFVocab:enables PredictionService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of the temperature sensor streams."
    DTDFVocab:provides TemperatureInsight
]

instance SafetyCheckService : DTDFVocab:Service [
    base:desc "Checks safety constraints and raises violations when temperature exceeds safe limits."
    DTDFVocab:provides SafetyViolationInsight, AlertAction
]

instance OptimalityCheckService : DTDFVocab:Service [
    base:desc "Evaluates optimality of the temperature relative to the set‑point and suggests corrective actions."
    DTDFVocab:provides OptimalityInsight, CorrectiveAction
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Delivers prediction of the incubator's thermal behaviour under current operating conditions."
    DTDFVocab:provides PredictiveInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Optimises model parameters via calibration routines using sensor data."
    DTDFVocab:provides CalibrationInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Advanced visualisation dashboards for engineers/operators to inspect sensor data, model outputs and prediction results."
    DTDFVocab:provides VisualizationInsight
]

instance ReconfigurationService : DTDFVocab:Service [
    base:desc "Allows the twin to adapt its models when the environment or operating conditions change."
    DTDFVocab:provides ReconfigurationInsight
]

instance AlertService : DTDFVocab:Service [
    base:desc "Generates alerts for detected safety or optimality violations."
    DTDFVocab:provides AlertAction
]

// C17: Insights
instance TemperatureInsight : DTDFVocab:Insight [
    base:desc "Current temperature reading and trend derived from sensor streams."
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature exceeding predefined safety limits."
]

instance OptimalityInsight : DTDFVocab:Insight [
    base:desc "Assessment of temperature deviation from the optimal set‑point."
]

instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Anticipated temperature evolution based on calibrated model simulation."
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Result of parameter estimation indicating updated model fidelity."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of sensor data, model predictions and system status."
]

instance ReconfigurationInsight : DTDFVocab:Insight [
    base:desc "Notification that model structure has been adapted to new operating conditions."
]

// C17: Actions
instance AlertAction : DTDFVocab:Action [
    base:desc "Raise an alert to the operator or higher‑level controller."
    DTDFVocab:IsAutomatic true
]

instance CorrectiveAction : DTDFVocab:Action [
    base:desc "Suggest a corrective adjustment to heater set‑point or fan speed."
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance TwoParameterThermalModel : DTDFVocab:Model [
    base:desc "Analytical two‑parameter thermal model predicting internal temperature of the incubator."
    DTDFVocab:inputTo PredictionEnabler
]

instance FourParameterThermalModel : DTDFVocab:Model [
    base:desc "Analytical four‑parameter thermal model capturing heat‑bed thermal inertia."
    DTDFVocab:inputTo PredictionEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Algorithms within the Digital Twin generate control actions when monitors detect violations; these actions may be executed by humans or automated components to modify the physical twin’s operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin follows a CPS‑centric orchestration pattern where sensor data from the Physical Twin are continuously streamed into the cyber side. Calibration algorithms consume this data to update the parameters of physics‑based models of the system and its environment. Updated model outputs are fed to monitoring components that assess safety and performance criteria. If a violation is detected, a decision layer—potentially involving human operators or automated supervisory controllers—triggers corrective actions that may be sent back to the Physical Twin. Thus the architecture integrates data acquisition, model calibration, monitoring, and decision/actuation loops within a unified framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity was assessed experimentally by comparing predicted temperature trajectories against measured values. The four‑parameter model demonstrated superior accuracy in reproducing the heatbed’s thermal inertia and was therefore selected for further DT development. Calibration algorithms are used to update model parameters based on incoming sensor data, providing a basic validation loop. Explicit uncertainty quantification, error detection mechanisms, or broader quality‑assurance processes are not described in the documents."
]