// ------------------------------------------------------------
// C2: Acting Components
// ------------------------------------------------------------
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heating element (heat‑bed) that provides thermal power to raise the temperature inside the insulated styrofoam box"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan that distributes heat uniformly inside the incubator box"
]

instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi running the control software and low‑level driver interfacing the sensors and actuators"
]

// ------------------------------------------------------------
// C3: Physical Sensing Components
// ------------------------------------------------------------
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "First interior temperature sensor measuring the temperature inside the incubator box"
    DTDFVocab:producedData InternalTempDataTransmitted1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second interior temperature sensor measuring the temperature inside the incubator box"
    DTDFVocab:producedData InternalTempDataTransmitted2
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "Exterior temperature sensor measuring the ambient room temperature"
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// ------------------------------------------------------------
// C4: Physical‑to‑Virtual Interaction (Data Transmitted)
// ------------------------------------------------------------
instance InternalTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// ------------------------------------------------------------
// C5: Data (Temperature streams)
// ------------------------------------------------------------
instance InternalTemperatureData1 : DTDFVocab:Data [
    base:desc "Temperature readings (°C) from InternalTempSensor1"
    DTDFVocab:fromData InternalTempDataTransmitted1
    DTDFVocab:inputTo TimeSeriesDatabaseEnabler, KalmanFilterEnabler
]

instance InternalTemperatureData2 : DTDFVocab:Data [
    base:desc "Temperature readings (°C) from InternalTempSensor2"
    DTDFVocab:fromData InternalTempDataTransmitted2
    DTDFVocab:inputTo TimeSeriesDatabaseEnabler, KalmanFilterEnabler
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Ambient temperature readings (°C) from ExternalTempSensor"
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo TimeSeriesDatabaseEnabler, KalmanFilterEnabler
]

// ------------------------------------------------------------
// C10: Models / Data (Simulation models)
// ------------------------------------------------------------
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model of the incubator (Model A) with two free parameters"
    DTDFVocab:inputTo CalibrationEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Analytical thermal model of the incubator (Model B) with four free parameters; captures thermal inertia of the heat‑bed"
    DTDFVocab:inputTo CalibrationEnabler, KalmanFilterEnabler
]

// ------------------------------------------------------------
// C11: Enablers
// ------------------------------------------------------------
instance TimeSeriesDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Time‑series database (e.g., InfluxDB) persisting sensor streams for dashboards and downstream algorithms"
    DTDFVocab:enables RealTimeVisualizationService
]

instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard component that reads data from the time‑series store and visualises incubator status in real time"
    DTDFVocab:enables RealTimeVisualizationService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Automated calibration algorithm (tracking‑simulator concept) that adjusts model parameters on‑line using sensor data"
    DTDFVocab:enables ModelCalibrationService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter implementation that fuses temperature streams with Model B for state estimation and anomaly detection"
    DTDFVocab:enables AnomalyDetectionService
]

instance CoSimulationFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Co‑simulation framework that replays historical or live PT data together with Model B to evaluate alternative controller settings"
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationEnabler : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop engine that orchestrates detection, experimentation, re‑calibration and controller re‑configuration"
    DTDFVocab:enables SelfAdaptationService
]

// ------------------------------------------------------------
// C6: Services
// ------------------------------------------------------------
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualisation of incubator status by listening to controller & driver messages, persisting them, and plotting on a dashboard"
    DTDFVocab:provides IncubatorStatusInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "On‑demand calibration of simulation models (Model A & Model B) using the automated calibration algorithm"
    DTDFVocab:provides CalibrateModelBAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection and heat‑bed state estimation via a Kalman filter that fuses sensor data with Model B"
    DTDFVocab:provides ThermalAnomalyInsight, EstimateHeatbedTempAction
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What‑if simulations executed as co‑simulations to evaluate alternative controller parameter sets"
    DTDFVocab:provides ScenarioEvaluationInsight, RunWhatIfSimulationAction
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Self‑adaptation loop that detects behavioural changes, schedules experiments, re‑calibrates Model B, updates the Kalman filter and re‑applies optimized controller settings"
    DTDFVocab:provides BehaviorChangeDetectionInsight, ReconfigureControllerAction
]

// ------------------------------------------------------------
// C17: Insights & Actions
// ------------------------------------------------------------
instance IncubatorStatusInsight : DTDFVocab:Insight [
    base:desc "Current temperature status of the incubator (internal & external) visualised on the dashboard"
]

instance CalibrateModelBAction : DTDFVocab:Action [
    base:desc "Execute the calibration algorithm to adjust the four free parameters of Model B"
    DTDFVocab:IsAutomatic true
]

instance ThermalAnomalyInsight : DTDFVocab:Insight [
    base:desc "Detection of deviations between measured temperature and Model B predictions indicating possible faults"
]

instance EstimateHeatbedTempAction : DTDFVocab:Action [
    base:desc "Estimate the unmeasured heat‑bed temperature using the Kalman filter"
    DTDFVocab:IsAutomatic true
]

instance ScenarioEvaluationInsight : DTDFVocab:Insight [
    base:desc "Evaluation results of what‑if simulation scenarios (e.g., controller parameter impact on temperature regulation)"
]

instance RunWhatIfSimulationAction : DTDFVocab:Action [
    base:desc "Run a co‑simulation with Model B and supplied PT data to explore alternative control strategies"
    DTDFVocab:IsAutomatic false
]

instance BehaviorChangeDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of a behavioural change in the plant (e.g., cold object introduced) based on Kalman filter residuals"
]

instance ReconfigureControllerAction : DTDFVocab:Action [
    base:desc "Automatically re‑configure the Raspberry Pi controller with newly optimised heating and fan parameters"
    DTDFVocab:IsAutomatic true
]

// ------------------------------------------------------------
// Environment & Component aggregation
// ------------------------------------------------------------
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator, FanActuator, RaspberryPiController,
                 InternalTempSensor1, InternalTempSensor2, ExternalTempSensor
]

instance IncubatorComponent : DTDFVocab:Component [
    base:desc "Physical twin of the thermal incubator comprising heating, fan, sensors and controller"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the DT (or by the controller logic) and sent as AMQP messages over RabbitMQ to the low‑level driver. The command set includes turn‑on/turn‑off directives for the heat‑bed and the fan, as well as parameters such as heating duration (H) and waiting duration (C). Upon receipt, the driver checks the command against its built‑in safety protocol before actuating the physical twin. The driver then acknowledges execution by publishing the resulting actuation state back to RabbitMQ, allowing the controller/DT to receive feedback."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates with real‑time monitoring: temperature sensor data are continuously streamed from the Raspberry Pi controller to a time‑series database, enabling a dashboard that visualises the incubator status in (near) real time. Calibration of the thermal simulation models is performed on demand by automatically running the calibration routine described in section 3.3. Anomaly detection and heat‑bed state estimation run concurrently using a Kalman filter on the live data stream. What‑if simulations can be executed with either historical or real‑time PT data, but no explicit synchronization frequency, latency bound, or temporal granularity is provided in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT follows a CPS‑based centralized architecture (Fig. 1). The physical twin comprises the insulated box, heat‑bed, fan and temperature sensors, controlled by a Raspberry Pi. The cyber side includes data acquisition (listening to controller and low‑level driver messages), a time‑series database, a dashboard for real‑time visualization, calibration algorithms that update two thermal models, a Kalman‑filter based anomaly detector and heat‑bed state estimator, and a co‑simulation engine for what‑if analyses. These components are orchestrated as outlined in the self‑adaptation loop: detect anomaly → schedule experiment → configure controller → gather data → calibrate model → re‑configure Kalman filter → run simulations → re‑configure controller."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the prediction accuracy of Model A and Model B against experimental measurements; Model B provides higher fidelity for the heat‑bed inertia. Validation is performed through calibration experiments described in the case study, where model parameters are tuned to minimise the error between simulated and measured temperature trajectories. Uncertainty sources include sensor noise and unmodelled environmental influences; the Kalman filter is employed to fuse model predictions with noisy measurements, thereby detecting anomalies and estimating hidden states. Quality assurance is achieved by continuous monitoring of model‑derived predictions and by re‑calibrating the models on demand."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The incubator DT relies on a central RabbitMQ server as the technical communication layer. RabbitMQ implements the AMQP protocol over TCP/IP, providing a publish/subscribe topology where the controller, low‑level driver and any DT analytics components act as clients. The architecture is a star‑shaped network with the broker as the hub. RabbitMQ offers message durability, acknowledgments and clustering for reliability, though specific bandwidth, latency or QoS numbers are not given in the documents. Security mechanisms (e.g., TLS, authentication) are not described."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ broker can be deployed either on‑premise (e.g., on the same Raspberry Pi or a local server) or in the cloud, as noted in the documents. No quantitative computational or storage requirements are provided; the DT components are assumed to run on the Raspberry Pi or on any host that can connect to the broker. Scalability is supported by RabbitMQ’s clustering capability, and availability is achieved through its mature, lightweight design, but exact deployment models and SLA details are not specified."
]