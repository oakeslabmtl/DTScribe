// C2: Acting Components
instance HeatbedHeaterActuator : DTDFVocab:ActingComponent [
    base:desc "Electrically powered heatbed actuated via MOSFET, controlled by Raspberry Pi GPIO, serves as the primary heating element."
]
instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal fan with 0.02 m³/s airflow, driven through MOSFET and optocoupler, provides air circulation to improve temperature uniformity."
]

// C3: Physical sensing components
instance InsideTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire high‑precision thermometer installed in the incubator box near the chicken side, ±0.5°C accuracy."
    DTDFVocab:producedData InsideTempDataTransmitted1
]
instance InsideTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire high‑precision thermometer installed in the incubator box near the egg side, ±0.5°C accuracy."
    DTDFVocab:producedData InsideTempDataTransmitted2
]
instance OutsideTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire thermometer measuring external room temperature, ±0.5°C accuracy."
    DTDFVocab:producedData OutsideTempDataTransmitted
]

// C4: Physical-to-virtual interaction
instance InsideTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor1
]
instance InsideTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor2
]
instance OutsideTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideTemperatureSensor
]

// C10: Models/Data
instance ThermalModelA : DTDFVocab:Model [
    base:desc "First‑order thermal model (Model A) representing heat transfer in the incubator box using constants G_box and G_heater."
    DTDFVocab:inputTo ModelExecutionEnabler
]
instance ThermalModelB : DTDFVocab:Model [
    base:desc "Second‑order dynamic model (Model B) capturing transient temperature dynamics inside the incubator."
    DTDFVocab:inputTo ModelExecutionEnabler
]
instance InsideTemperatureData1 : DTDFVocab:Data [
    base:desc "Time series of temperature readings from InsideTemperatureSensor1, streamed via RabbitMQ."
    DTDFVocab:inputTo SensorDataIngestionEnabler
    DTDFVocab:fromData InsideTempDataTransmitted1
]
instance InsideTemperatureData2 : DTDFVocab:Data [
    base:desc "Time series of temperature readings from InsideTemperatureSensor2, streamed via RabbitMQ."
    DTDFVocab:inputTo SensorDataIngestionEnabler
    DTDFVocab:fromData InsideTempDataTransmitted2
]
instance OutsideTemperatureData : DTDFVocab:Data [
    base:desc "Time series of ambient temperature readings from OutsideTemperatureSensor, streamed via RabbitMQ."
    DTDFVocab:inputTo SensorDataIngestionEnabler
    DTDFVocab:fromData OutsideTempDataTransmitted
]
instance SimulatedTemperatureData : DTDFVocab:Data [
    base:desc "Predicted temperature trajectory generated by the DT simulation using calibrated models."
    DTDFVocab:inputTo ModelExecutionEnabler
]

// C11: Enablers
instance SensorDataIngestionEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ ingestion service that collects raw sensor data and forwards it to the time‑series database."
    DTDFVocab:enables TemperatureMonitoringService
]
instance ModelExecutionEnabler : DTDFVocab:Enabler [
    base:desc "SciPy‑based nonlinear least‑squares optimizer that runs calibrated models and produces simulation outputs."
    DTDFVocab:enables TemperaturePredictionService
]

// C6: Services
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time safety and fault monitoring that evaluates temperature limits and uniformity across sensors."
    DTDFVocab:provides TemperatureSafetyInsight, OverheatDetectionInsight, TemperatureUniformityInsight, TriggerAlertAction
]
instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Real‑time temperature prediction service leveraging calibrated models to forecast future temperature trends."
    DTDFVocab:provides FutureTemperatureForecastInsight
]

// C17: Insights/Actions
instance TemperatureSafetyInsight : DTDFVocab:Insight [
    base:desc "Insight that identifies whether measured temperatures stay within predefined safety limits."
]
instance OverheatDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight that detects internal temperatures exceeding safe thresholds and proposes corrective actions."
]
instance TemperatureUniformityInsight : DTDFVocab:Insight [
    base:desc "Insight evaluating the variance between InsideTemperatureSensor1 and InsideTemperatureSensor2 to flag non‑uniform temperature distributions."
]
instance FutureTemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Insight providing a forecast of future temperature trajectories to inform heating duration and fan speed adjustments."
]
instance AdjustHeatingAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of heatbed on/off command via Raspberry Pi GPIO to maintain target temperature."
    DTDFVocab:IsAutomatic true
]
instance AdjustFanSpeedAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of fan speed through MOSFET and optocoupler output to improve temperature uniformity."
    DTDFVocab:IsAutomatic true
]
instance TriggerAlertAction : DTDFVocab:Action [
    base:desc "Non‑automatic action that sends an alert to operators when temperature variance exceeds the threshold."
    DTDFVocab:IsAutomatic false
]

// C7: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedHeaterActuator, InternalFanActuator, InsideTemperatureSensor1, InsideTemperatureSensor2, OutsideTemperatureSensor
]

// C8: Component
instance HeatbedComponent : DTDFVocab:Component [
    base:desc "Heatbed assembly providing electrical heating inside the incubator box."
]
instance FanComponent : DTDFVocab:Component [
    base:desc "Internal fan assembly for air circulation within the incubator."
]
instance DS18S20SensorComponent : DTDFVocab:Component [
    base:desc "DS18S20 high‑precision 1‑Wire temperature sensors."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT’s controller publishes ON/OFF commands for the heatbed and fan through RabbitMQ, which the low‑level driver forwards to the Raspberry Pi GPIO, thereby actuating the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An integrated stack where the PT (heater, fan, sensors, Raspberry Pi, PCB) communicates with the DT over RabbitMQ; the DT comprises a controller module, a simulation module (Model A/B), a calibration module, and a monitoring interface, all running on the same device or locally."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design of the physical incubator → development of dynamic models (Model A/B) → calibration of model parameters using experimental data → validation against measured temperature traces → deployment of the DT on the Raspberry Pi → future extensions to improve model fidelity and optimisation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity depends on validity of assumptions (uniform temperature, negligible wall heat accumulation, constant specific heat of air, negligible heater heat loss). Validation is performed by comparing simulated temperature profiles with measured data from the uniform‑temperature experiments; residual errors after calibration are minimized using SciPy's least‑squares optimiser."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data flows over the Raspberry Pi’s Wi‑Fi interface to a local RabbitMQ broker; temperature sensors communicate via the 1‑Wire bus; actuator commands are transmitted through GPIO‑controlled MOSFETs with optocoupler isolation; all messages are serialized using RabbitMQ's AMQP protocol."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT stack (controller, simulation, calibration) is hosted on the Raspberry Pi used for physical control, delivering low‑latency interaction; the RabbitMQ broker is also locally hosted, enabling near‑real‑time synchronization between PT and DT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Hardware follows the DS18S20 1‑Wire specification for temperature sensing; communication uses the AMQP/RabbitMQ standard; controller logic follows established bang‑bang control algorithm; PCB design adheres to typical MOSFET/optocoupler isolation standards. No industry‑wide digital twin standards are explicitly referenced."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Low‑level driver incorporates a safe protocol to ensure the PT stays in a safe state; optocouplers isolate control signals; the AMQP broker supports authentication and access control; safety considerations include preventing overheating by enforcing temperature limits within the controller statechart."
]