// C3: Physical sensing components
instance BoxAirTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor 1 measuring air temperature inside the incubator box"
    DTDFVocab:producedData BoxAirTempDataTransmitted1
]

instance BoxAirTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor 2 measuring air temperature inside the incubator box"
    DTDFVocab:producedData BoxAirTempDataTransmitted2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor measuring ambient temperature outside the incubator box"
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// C4: Physical-to-virtual interaction – Data transmitted via RabbitMQ
instance BoxAirTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxAirTempSensor1
]

instance BoxAirTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxAirTempSensor2
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// C10: Data objects (temperature readings)
instance BoxAirTemperatureData1 : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from internal sensor 1 with timestamp"
    DTDFVocab:fromData BoxAirTempDataTransmitted1
    DTDFVocab:inputTo RabbitMQBroker
]

instance BoxAirTemperatureData2 : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from internal sensor 2 with timestamp"
    DTDFVocab:fromData BoxAirTempDataTransmitted2
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Ambient temperature reading (°C) from external sensor with timestamp"
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

// C2: Acting components (actuators and controller)
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heating element (heat‑bed) used to raise temperature inside the incubator"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan inside the incubator providing air circulation for uniform heat distribution"
]

instance BangBangController : DTDFVocab:ActingComponent [
    base:desc "Bang‑bang temperature controller running on Raspberry Pi with parameters LL, UL, H, C"
]

// C11: Enablers (tools & infrastructure)
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker (TCP/IP) that routes sensor data and actuation commands"
    DTDFVocab:enables RealTimeVisualizationService,
                     ModelCalibrationService,
                     AnomalyDetectionService,
                     StateEstimationService,
                     PredictiveSimulationService,
                     ControllerOptimizationService,
                     SelfAdaptationService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Automated calibration algorithm that ingests temperature streams to update model parameters"
    DTDFVocab:enables ModelCalibrationService
]

instance KalmanFilter : DTDFVocab:Enabler [
    base:desc "Kalman filter performing state estimation and anomaly detection on the calibrated thermal model"
    DTDFVocab:enables AnomalyDetectionService,
                     StateEstimationService
]

instance CoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation infrastructure enabling what‑if scenarios with live or historical PT data"
    DTDFVocab:enables PredictiveSimulationService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time‑series database (e.g., InfluxDB) persisting sensor measurements for dashboards"
    DTDFVocab:enables RealTimeVisualizationService
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model A derived from Q = c·m·ΔT with two free parameters"
    DTDFVocab:inputTo CalibrationAlgorithm,
                     KalmanFilter
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Analytical thermal model B (higher fidelity) with four free parameters and heat‑bed inertia"
    DTDFVocab:inputTo CalibrationAlgorithm,
                     KalmanFilter
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of incubator status via dashboards"
    DTDFVocab:provides TemperatureAnomalyInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Performs on‑demand model calibration using streamed temperature data"
    DTDFVocab:provides RecalibrateModelAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Detects temperature anomalies using a Kalman filter"
    DTDFVocab:provides TemperatureAnomalyInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Estimates heat‑bed state and temperature using Kalman filtering"
    DTDFVocab:provides HeatBedStateEstimateInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Runs what‑if simulations via co‑simulation to explore controller parameter effects"
    DTDFVocab:provides PredictiveSimulationInsight
]

instance ControllerOptimizationService : DTDFVocab:Service [
    base:desc "Optimises bang‑bang controller parameters based on model predictions"
    DTDFVocab:provides ControllerParameterRecommendationInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Closed‑loop self‑adaptation loop that triggers experiments, recalibrates models and updates the PT"
    DTDFVocab:provides SafetyCheckInsight,
                     UpdatePhysicalTwinAction
]

// C17: Insights
instance TemperatureAnomalyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating abnormal temperature deviation detected in real time"
]

instance HeatBedStateEstimateInsight : DTDFVocab:Insight [
    base:desc "Insight providing estimated heat‑bed temperature and operational state"
]

instance PredictiveSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight summarising outcomes of what‑if simulations for alternative controller settings"
]

instance ControllerParameterRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending new bang‑bang controller parameters (LL, UL, H, C) to maintain target temperature"
]

instance SafetyCheckInsight : DTDFVocab:Insight [
    base:desc "Insight confirming safety constraints are satisfied before applying actuation commands"
]

// C17: Actions
instance RecalibrateModelAction : DTDFVocab:Action [
    base:desc "Automatic action to recalibrate the selected thermal model with latest sensor data"
    DTDFVocab:IsAutomatic true
]

instance ReconfigureControllerAction : DTDFVocab:Action [
    base:desc "Automatic action to reconfigure bang‑bang controller parameters after calibration"
    DTDFVocab:IsAutomatic true
]

instance UpdatePhysicalTwinAction : DTDFVocab:Action [
    base:desc "Automatic action that updates the physical twin (PT) with new control set‑points"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The controller (running on a Raspberry Pi) receives control commands from the RabbitMQ server that specify actions for the fan and the heat‑bed (e.g., turn on, turn off, heating duration, waiting duration). The controller forwards these commands to the low‑level driver, which executes the actuator states on the physical twin. A safe‑protocol is incorporated in the low‑level driver to keep the device in a safe state before applying commands. The controller also publishes its own control‑state messages back to RabbitMQ, providing feedback that can be consumed by the digital twin. Message formats and authentication details are not described in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is organised around a message‑oriented middleware pattern using a central RabbitMQ server. The physical twin’s low‑level driver reads temperature data periodically and publishes it to RabbitMQ; the controller subscribes to these messages, receives commands from RabbitMQ, and publishes its control states. DT components (e.g., calibration, monitoring, simulation modules) also subscribe to the same message streams, enabling decoupled interaction between cyber and physical elements and supporting the calibration, anomaly detection, what‑if simulation, and self‑adaptation loops described in the case study."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by developing two models with differing abstraction levels; experimental results (Fig. 13) show that Model B, which accounts for heat‑bed inertia, yields higher accuracy in predicting system magnitude and time scale, thus being the preferred model for the DT. Validation is performed through calibration experiments where sensor data are used to estimate model parameters, and through anomaly detection via a Kalman filter that compares measured temperatures with model‑predicted heat‑bed temperature, exposing discrepancies. Uncertainty sources stem from the modelling assumptions (uniform temperature distribution, negligible wall heat storage, constant specific heat capacity, and power‑to‑heat conversion). Calibration, on‑demand recalibration, and continuous monitoring constitute the quality‑assurance process, while the safe‑protocol in the low‑level driver mitigates risks from erroneous actuation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The communication backbone of the incubator digital twin is a RabbitMQ message broker. Components (sensors, low‑level driver, controller, DT services) connect to the broker using the AMQP protocol over TCP/IP. The network topology follows a publish/subscribe pattern: PT sensors → low‑level driver → RabbitMQ → controller and DT subscribers. RabbitMQ is described as a mature, lightweight, and easy‑to‑deploy server that can run on‑premise or in the cloud, providing reliability through its built‑in message queuing and delivery guarantees. Specific bandwidth, latency or redundancy mechanisms are not quantified in the source material."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through the RabbitMQ message broker. The low‑level driver, controller, and DT services communicate by publishing and subscribing to messages on RabbitMQ, allowing other applications or enterprise systems that can connect to the broker to exchange sensor data, control commands, and status information."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol that keeps the physical twin in a safe state; communication between the controller, low‑level driver and other components is performed through a RabbitMQ message broker, which synchronises messages but the documents do not detail authentication, encryption, or access‑control mechanisms. Safety functions are supported by a Kalman‑filter based anomaly detection and heat‑bed state estimation that run on the digital twin to monitor deviations from expected behaviour. No explicit cybersecurity protocols, threat‑mitigation strategies, or formal risk‑assessment procedures are described in the provided documents."
]