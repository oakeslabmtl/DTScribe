// Sensors
instance WheelDiameterSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures wheel diameters in real-time"
    DTDFVocab:producedData WheelDiameterDataStream
]

instance ChassisProfileSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that captures chassis profile data for CAD model updates"
    DTDFVocab:producedData ChassisProfileDataStream
]

instance ForceInteractionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures force and interaction forces between physical components"
    DTDFVocab:producedData ForceInteractionDataStream
]

instance MotionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that provides real-time motion data for dynamic model"
    DTDFVocab:producedData MotionDataStream
]

// Data transmitted
instance WheelDiameterDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelDiameterSensor
]

instance ChassisProfileDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChassisProfileSensor
]

instance ForceInteractionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ForceInteractionSensor
]

instance MotionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionSensor
]

// Data
instance WheelDiameterMeasurements : DTDFVocab:Data [
    base:desc "Real-time wheel diameter measurements collected from WheelDiameterSensor"
    DTDFVocab:fromData WheelDiameterDataStream
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

instance ChassisProfileMeasurements : DTDFVocab:Data [
    base:desc "Chassis profile measurements used to refine geometric model"
    DTDFVocab:fromData ChassisProfileDataStream
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

instance ForceInteractionMeasurements : DTDFVocab:Data [
    base:desc "Real-time force interaction measurements from ForceInteractionSensor"
    DTDFVocab:fromData ForceInteractionDataStream
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

instance MotionMeasurements : DTDFVocab:Data [
    base:desc "Real-time motion data collected from MotionSensor"
    DTDFVocab:fromData MotionDataStream
    DTDFVocab:inputTo CalibrationEnabler
]

// Models
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "CAD-style geometric model storing detailed artifacts such as wheel diameters, chassis profiles, and visual styling"
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

instance DynamicBehavioralModel : DTDFVocab:Model [
    base:desc "Dynamic behavioral model formulated with differential equations capturing physics of motion and force interactions"
    DTDFVocab:inputTo CalibrationEnabler
]

// Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that refines CPS and environment models using sensor data"
    DTDFVocab:enables RealTimeSimulationService, PredictiveAnalyticsService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring module that evaluates physical twin operational state against safety and optimality criteria derived from models"
    DTDFVocab:enables ContinuousMonitoringService, SupervisoryControlService
]

// Services
instance RealTimeSimulationService : DTDFVocab:Service [
    base:desc "Real-time simulation of the physical twin using updated models"
    DTDFVocab:provides SimulationResultInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics to forecast future behavior under current operating conditions"
    DTDFVocab:provides ForecastInsight
]

instance ContinuousMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring for safety and optimal performance"
    DTDFVocab:provides SafetyViolationInsight, OptimalPerformanceInsight, FaultDetectionAlertAction, HumanInterventionAction, AlgorithmicCorrectiveAction
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Supervisory controller that processes monitoring outputs and decides on corrective actions"
    DTDFVocab:provides SupervisoryControlInsight, SupervisoryCorrectiveAction
]

// Insights
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Results from real-time simulation of the physical twin"
]

instance ForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted future behavior of the system under current operating conditions"
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Indicates the physical twin is violating safety criteria derived from models"
]

instance OptimalPerformanceInsight : DTDFVocab:Insight [
    base:desc "Indicates the physical twin is operating optimally according to model predictions"
]

instance SupervisoryControlInsight : DTDFVocab:Insight [
    base:desc "Insight derived from supervisory control decisions"
]

// Actions
instance FaultDetectionAlertAction : DTDFVocab:Action [
    base:desc "Alert generated when a safety or optimality criterion violation is detected"
    DTDFVocab:IsAutomatic true
]

instance HumanInterventionAction : DTDFVocab:Action [
    base:desc "Human operator intervention triggered by supervisory controller"
    DTDFVocab:IsAutomatic false
]

instance AlgorithmicCorrectiveAction : DTDFVocab:Action [
    base:desc "Automated corrective action applied by an algorithm in response to fault detection"
    DTDFVocab:IsAutomatic true
]

instance SupervisoryCorrectiveAction : DTDFVocab:Action [
    base:desc "Corrective action decided by the supervisory controller"
    DTDFVocab:IsAutomatic true
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is achieved through continuous calibration: the Twin’s calibration algorithms automatically adjust the model parameters to align with real‑time sensor data, thereby reducing deviation between the simulated and actual system behaviour. The monitoring layer continually verifies that the system remains within specified safety and performance envelopes, effectively serving as an online validation and error detection mechanism. Whenever deviations exceed acceptable thresholds, the system flags abnormalities for corrective action, ensuring ongoing quality assurance of both models and data."
]