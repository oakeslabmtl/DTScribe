// 1. Physical sensing components
instance InteriorTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer inside the incubator, measuring interior air temperature (range -55 °C to +125 °C, accuracy ±0.5 °C)."
    DTDFVocab:producedData TempDataTransmitted
]

instance InteriorTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer inside the incubator, second interior air temperature sensor (range -55 °C to +125 °C, accuracy ±0.5 °C)."
    DTDFVocab:producedData TempDataTransmitted
]

instance ExteriorTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer placed outside the box, measuring ambient room temperature (range -55 °C to +125 °C, accuracy ±0.5 °C)."
    DTDFVocab:producedData TempDataTransmitted
]

// 2. Data transmitted from sensors
instance TempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTempSensor1, InteriorTempSensor2, ExteriorTempSensor
]

// 3. Data produced by the transmission
instance TemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements from the three DS18S20 sensors, streamed via RabbitMQ."
    DTDFVocab:fromData TempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

// 4. Enablers (tools/platforms)
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker used for publishing sensor readings, actuator states and for inter‑service communication."
    DTDFVocab:enables RealTimeMonitoringService,
                     AutomaticCalibrationService,
                     TemperatureSimulationServiceA,
                     TemperatureSimulationServiceB,
                     SafetyCheckingService
]

instance PythonSciPyOptimiser : DTDFVocab:Enabler [
    base:desc "Python SciPy library performing non‑linear least‑squares optimisation for model calibration."
    DTDFVocab:enables AutomaticCalibrationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Python runtime that executes calibrated thermal models to predict temperature dynamics."
    DTDFVocab:enables TemperatureSimulationServiceA,
                     TemperatureSimulationServiceB
]

instance ControllerDriver : DTDFVocab:Enabler [
    base:desc "Low‑level driver on the Raspberry Pi that reads sensors, publishes to RabbitMQ and drives actuators."
    DTDFVocab:enables RealTimeMonitoringService,
                     SafetyCheckingService
]

// 5. Services offered by the DT
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of temperature data in real time."
    DTDFVocab:provides TemperatureLimitViolationInsight
]

instance AutomaticCalibrationService : DTDFVocab:Service [
    base:desc "Automatic calibration of thermal model parameters using SciPy least‑squares optimisation."
    DTDFVocab:provides ModelParameterUpdateInsight
]

instance TemperatureSimulationServiceA : DTDFVocab:Service [
    base:desc "Simulation of temperature dynamics using calibrated Model A (two parameters C_air, G_box)."
    DTDFVocab:provides PredictedTemperatureInsightA
]

instance TemperatureSimulationServiceB : DTDFVocab:Service [
    base:desc "Simulation of temperature dynamics using calibrated Model B (four parameters C_air, G_box, C_heater, G_heater)."
    DTDFVocab:provides PredictedTemperatureInsightB
]

instance SafetyCheckingService : DTDFVocab:Service [
    base:desc "Safety and optimality checking that detects limit violations and can trigger alerts or suggested actions."
    DTDFVocab:provides TemperatureLimitViolationInsight,
                     AlertAction
]

// 6. Insights and actions
instance TemperatureLimitViolationInsight : DTDFVocab:Insight [
    base:desc "Detection that the measured temperature exceeds predefined safety limits."
]

instance ModelParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Updated values of thermal model parameters (C_air, G_box, C_heater, G_heater) after calibration."
]

instance PredictedTemperatureInsightA : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory generated by Model A for the upcoming time horizon."
]

instance PredictedTemperatureInsightB : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory generated by Model B for the upcoming time horizon."
]

instance AlertAction : DTDFVocab:Action [
    base:desc "Send an alert to the human operator and/or suggest corrective actuator commands."
    DTDFVocab:IsAutomatic false
]

// 7. Physical acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heating element (heat‑bed) driven by MOSFET switches, capable of up to 4 A current."
    DTDFVocab:producedData ActuatorStateTransmitted
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal circulation fan driven by MOSFET switches, providing ~0.03 m³·s⁻¹ airflow."
    DTDFVocab:producedData ActuatorStateTransmitted
]

// 8. Data transmitted from actuators
instance ActuatorStateTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatBedActuator, FanActuator
]

instance ActuatorStateData : DTDFVocab:Data [
    base:desc "Current state (ON/OFF, PWM level) of the heat‑bed and fan, published via RabbitMQ."
    DTDFVocab:fromData ActuatorStateTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

// 9. Thermal models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Physics‑based thermal model A describing heat flow in the incubator, parametrised by C_air and G_box."
    DTDFVocab:inputTo SimulationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Physics‑based thermal model B describing heat flow in the incubator, parametrised by C_air, G_box, C_heater and G_heater."
    DTDFVocab:inputTo SimulationEngine
]

// 10. Calibration data
instance CalibrationData : DTDFVocab:Data [
    base:desc "Experimental temperature recordings used for fitting model parameters, streamed via RabbitMQ."
    DTDFVocab:fromData TempDataTransmitted
    DTDFVocab:inputTo PythonSciPyOptimiser
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (heating duration, fan on/off, waiting duration) are sent from DT components to the RabbitMQ server; the controller subscribes to these command messages and drives the MOSFETs to actuate the heat‑bed and fan accordingly."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture consists of the PT (incubator hardware) connected to a Raspberry Pi that runs the controller, low‑level driver and a RabbitMQ server; DT components (model simulator, calibrator, monitor) subscribe to RabbitMQ topics to receive sensor data and publish control commands, forming a decoupled cyber‑physical loop."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is based on four explicit assumptions (uniform temperature, negligible wall heat, constant air specific heat, heat‑bed power fully converted to heat). Model B relaxes the heat‑bed assumption for higher fidelity. Calibration uses non‑linear least‑squares to minimise residual error, and experiments (uniformity tests with varied fan voltage) validate the assumptions and quantify temperature deviation (max 6–7 °C across sensors)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual and virtual‑to‑physical messages are exchanged via RabbitMQ, which operates over TCP/IP (the Raspberry Pi provides built‑in Wi‑Fi and Bluetooth for network access)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ broker and controller software are hosted locally on the Raspberry Pi 4; model calibration and simulation are performed on the same device or an external workstation accessing the broker through the network."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver implements a safe protocol to keep the incubator in a safe state; the controller includes upper and lower temperature limits and waiting durations to prevent overshoot, providing a safety layer for the PT."
]