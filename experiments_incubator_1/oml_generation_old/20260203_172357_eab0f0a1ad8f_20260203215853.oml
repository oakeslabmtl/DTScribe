// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling heatbed heating via MOSFET on custom PCB."
]
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling fan cooling via MOSFET on custom PCB."
]

// C3: Physical sensing components
instance InternalDS18S20Sensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside insulated box at position 1."
    DTDFVocab:producedData InternalDS18S20TemperatureDataMessage
]
instance InternalDS18S20Sensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside insulated box at position 2."
    DTDFVocab:producedData InternalDS18S20TemperatureDataMessage2
]
instance ExternalDS18S20Sensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located on the exterior for ambient temperature."
    DTDFVocab:producedData ExternalDS18S20TemperatureDataMessage
]

// C4: Physical-to-virtual interaction                                           
instance InternalDS18S20TemperatureDataMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalDS18S20Sensor1
]
instance InternalDS18S20TemperatureDataMessage2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalDS18S20Sensor2
]
instance ExternalDS18S20TemperatureDataMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalDS18S20Sensor
]

// C10: Models/Data
instance InternalDS18S20TemperatureData : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from internal sensor 1."
    DTDFVocab:fromData InternalDS18S20TemperatureDataMessage
    DTDFVocab:inputTo RabbitMQBroker, ScipyRuntime, PythonRuntime
]
instance InternalDS18S20TemperatureData2 : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from internal sensor 2."
    DTDFVocab:fromData InternalDS18S20TemperatureDataMessage2
    DTDFVocab:inputTo RabbitMQBroker, ScipyRuntime, PythonRuntime
]
instance ExternalDS18S20TemperatureData : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from external ambient sensor."
    DTDFVocab:fromData ExternalDS18S20TemperatureDataMessage
    DTDFVocab:inputTo RabbitMQBroker, ScipyRuntime, PythonRuntime
]

instance ModelA : DTDFVocab:Model [
    base:desc "Single‑compartment heat‑balance model with parameters C_air, G_box, and power input V·I·Δt."
    DTDFVocab:inputTo ScipyRuntime, PythonRuntime
]
instance ModelB : DTDFVocab:Model [
    base:desc "Two‑compartment heat‑balance model adding heatbed thermal mass with parameters C_heater, C_air, G_heater, G_box."
    DTDFVocab:inputTo ScipyRuntime, PythonRuntime
]
instance ModelPrediction : DTDFVocab:Data [
    base:desc "Predicted temperature trajectory generated by calibrated thermal models."
    DTDFVocab:inputTo RabbitMQBroker
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker hosted on Raspberry Pi, transfers sensor data to twin services."
    DTDFVocab:enables TemperatureMonitoringService, ThermalSimulationServiceA, ThermalSimulationServiceB, ParameterCalibrationService, BangBangControlService, SafetyMonitoringService, VisualizationService
]
instance ScipyRuntime : DTDFVocab:Enabler [
    base:desc "Python SciPy runtime performing non‑linear least‑squares calibration of model parameters."
    DTDFVocab:enables ParameterCalibrationService, ThermalSimulationServiceA, ThermalSimulationServiceB
]
instance PythonRuntime : DTDFVocab:Enabler [
    base:desc "Python execution environment carrying out bang‑bang control strategy."
    DTDFVocab:enables BangBangControlService, SafetyMonitoringService
]

// C6: Services
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time temperature monitoring of incubator using incoming sensor data."
    DTDFVocab:provides TemperatureThresholdAlertInsight
]
instance ThermalSimulationServiceA : DTDFVocab:Service [
    base:desc "Simulation of temperature dynamics using calibrated ModelA."
    DTDFVocab:provides ForecastedTemperatureCurveInsight
]
instance ThermalSimulationServiceB : DTDFVocab:Service [
    base:desc "Simulation of temperature dynamics using calibrated ModelB."
    DTDFVocab:provides ForecastedTemperatureCurveInsight
]
instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Non‑linear least‑squares calibration of model parameters via SciPy."
    DTDFVocab:provides ParameterEstimatesInsight
]
instance BangBangControlService : DTDFVocab:Service [
    base:desc "Bang‑bang control strategy executed on Raspberry Pi GPIO outputs."
    DTDFVocab:provides ApplyBangBangControlAction
]
instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Safety monitoring of operating temperature limits."
    DTDFVocab:provides SafetyMonitoringInsight
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualisation of sensor data and model predictions."
    DTDFVocab:provides VisualizationInsight
]

// C17: Insights/Actions
instance TemperatureThresholdAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when temperature exceeds set thresholds."
]
instance ForecastedTemperatureCurveInsight : DTDFVocab:Insight [
    base:desc "Forecasted temperature curves using calibrated thermal models."
]
instance ParameterEstimatesInsight : DTDFVocab:Insight [
    base:desc "Output of parameter estimates from calibration process."
]
instance SafetyMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight indicating safety status regarding temperature limits."
]
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of sensor data and simulation predictions."
]
instance ApplyBangBangControlAction : DTDFVocab:Action [
    base:desc "Bang‑bang control strategy applied to heatbed and fan."
    DTDFVocab:IsAutomatic true
]

// Environment and Components
instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B controller running low‑level driver."
]
instance CustomPCB : DTDFVocab:Component [
    base:desc "Custom PCB with MOSFETs and optocouplers controlling actuators."
]
instance RabbitMQServer : DTDFVocab:Component [
    base:desc "RabbitMQ AMQP broker server hosted on Raspberry Pi."
]
instance StyrofoamInsulatedBox : DTDFVocab:Component [
    base:desc "Insulated styrofoam box housing the incubator."
]
instance IncubatorHeatbed : DTDFVocab:Component [
    base:desc "Heatbed providing thermal energy to the incubator."
]
instance IncubatorFan : DTDFVocab:Component [
    base:desc "Fan providing airflow for cooling."
]

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains RaspberryPiController, CustomPCB, RabbitMQServer, StyrofoamInsulatedBox, IncubatorHeatbed, IncubatorFan
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin computes control commands (heatbed on/off, fan on/off) and publishes them to RabbitMQ; the controller’s low‑level driver receives these messages, translates them to GPIO commands and actuates the heatbed and fan through the MOSFETs on the PCB."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The controller specifies two time constants in seconds: H (heating duration) and C (waiting duration) that govern the bang‑bang cycle. The low‑level driver samples sensor data at a periodic interval; the exact frequency is not explicitly stated in the document, only that it is periodic (e.g., at least once per second). The digital twin operates synchronously with these event‑driven intervals."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Components orchestrated as follows: low‑level driver interfaces with PT (sensors/actuators), RabbitMQ communication server mediates data flow, controller implements bang‑bang logic, and the DT engine (simulation, calibration) processes incoming data and publishes control commands, closing the loop between PT and DT."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin is developed after the physical twin is manufactured and deployed, operating during the ‘operated’ lifecycle phase, with periodic updates such as parameter recalibration and potential future upgrades."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Assumptions: (1) uniform temperature achieved by fan; (2) negligible heat transfer to box walls; (3) constant specific heat capacity of air; (4) heatbed dominates heat generation. Validation experiments measured temperature uniformity (maximum discrepancy ≤7 °C); model calibration minimized residual error – explicit RMSE values are not reported."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Uses RabbitMQ (AMQP) as message broker over Wi‑Fi; sensor data collected via 1‑Wire bus; actuators controlled via GPIO on Raspberry Pi; all PT‑DT communication occurs over the local network through RabbitMQ queues."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The controller, communication server and low‑level driver run on the Raspberry Pi; the DT simulation and calibration modules can run locally on the Pi or on a separate host; the whole system is open‑source and can be deployed on an embedded Linux environment or in the cloud."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to maintain device safety; MOSFETs and optocouplers provide electrical isolation; controller ensures safe heating and fan operation; RabbitMQ handles message delivery but no explicit security measures are described."
]