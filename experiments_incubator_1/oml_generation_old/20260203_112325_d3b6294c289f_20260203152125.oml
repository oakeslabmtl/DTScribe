// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Thermistor or DS18B20 temperature sensor measuring incubator interior temperature."
    DTDFVocab:producedData TemperatureDataStream
]

// C4: Physical-to-virtual interaction
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C10: Models/Data
instance TemperatureSensorData : DTDFVocab:Data [
    base:desc "Continuous time-series data of temperature readings from the incubator interior sensor."
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, FaultDetectionEnabler, SupervisoryControllerEnabler, StateEstimatorEnabler
]

instance CADIncubatorModel : DTDFVocab:Model [
    base:desc "CAD representation of the thermal incubator geometry, including styrofoam enclosure."
    DTDFVocab:inputTo CalibrationEnabler
]

instance ThermalDynamicsModel : DTDFVocab:Model [
    base:desc "Differential equation model describing the temperature dynamics of the incubator."
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, FaultDetectionEnabler, SupervisoryControllerEnabler, StateEstimatorEnabler
]

// C1: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed actuator controlling heating power based on supervisory commands."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan actuator controlling fan speed for cooling or turbulence."
]

// C1: Physical components
instance HeatBedElement : DTDFVocab:Component [
    base:desc "Electric heat‑bed element that provides heating to maintain temperature inside the incubator."
]

instance Fan : DTDFVocab:Component [
    base:desc "Fan for cooling or turbulence to regulate heat distribution."
]

instance RaspberryPi4 : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B acting as PLC‑style controller for the incubator system."
]

// C17: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedElement, Fan, TemperatureSensor, RaspberryPi4
]

// C11: Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Python‑based calibration enabler using SciPy's optimize to adjust model parameters from sensor data."
    DTDFVocab:enables CalibrationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler supervising monitoring service to evaluate safety and optimality criteria."
    DTDFVocab:enables MonitoringService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Fault detection enabler processing sensor data to identify anomalies."
    DTDFVocab:enables FaultDetectionService
]

instance SupervisoryControllerEnabler : DTDFVocab:Enabler [
    base:desc "Supervisory control enabler generating corrective actions for actuators."
    DTDFVocab:enables SupervisoryControlService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimization enabler evaluating parameter tuning for optimal performance."
    DTDFVocab:enables OptimizationService
]

instance StateEstimatorEnabler : DTDFVocab:Enabler [
    base:desc "State estimator enabler updating internal state representation from sensor data."
    DTDFVocab:enables StateEstimationService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service performing model parameter estimation using sensor data streams."
    DTDFVocab:provides ModelCalibrationInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service evaluating safety and optimality of the incubator system."
    DTDFVocab:provides MonitoringInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service detecting fault conditions and anomalies in sensor readings."
    DTDFVocab:provides FaultDetectionInsight
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Service proposing corrective control actions for the actuators."
    DTDFVocab:provides SupervisoryControlAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing control parameters for performance."
    DTDFVocab:provides OptimizationInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Service estimating the state of the incubator based on sensor data."
    DTDFVocab:provides StateEstimationInsight
]

// C17: Insights and Actions
instance ModelCalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight that the thermal dynamics model parameters have been updated to match observed data."
]

instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the system meets safety and optimality criteria."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight identifying anomalies or faults in the incubator temperature data."
]

instance SupervisoryControlAction : DTDFVocab:Action [
    base:desc "Automatic corrective action proposal for heat‑bed or fan to maintain set temperature."
    DTDFVocab:IsAutomatic true
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight on optimized control parameters for improved performance."
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Insight providing updated internal state estimation of the incubator temperature dynamics."
]

// Actions for actuators
instance ControlHeatBedAction : DTDFVocab:Action [
    base:desc "Command to adjust heat‑bed element power to achieve desired temperature."
    DTDFVocab:IsAutomatic true
]

instance FanControlAction : DTDFVocab:Action [
    base:desc "Command to change fan speed for cooling or turbulence effects."
    DTDFVocab:IsAutomatic true
]

instance TemperatureSetpointAdjustmentAction : DTDFVocab:Action [
    base:desc "Human or autonomous adjustment of temperature setpoint target."
    DTDFVocab:IsAutomatic false
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Within a Digital Twin system, the lifecycle progresses through a conceptual modeling phase where abstract representations are created to capture specific aspects of the physical twin, followed by a design phase that builds detailed physical models (e.g., CAD or dynamic models). These models are persisted and continuously integrated into the Digital Twin rather than discarded after deployment. During operation, calibration algorithms update the physics and cyber models with the latest sensor data, producing updated model parameters. The monitoring component then examines this data to verify safe and optimal performance. If a violation is detected, a transition occurs to a corrective phase where humans or automated decision‑making agents modify the physical twin. Governance of the lifecycle typically relies on model‑based validation, periodic reassessment of calibration accuracy, and versioned management of model artifacts, ensuring consistency between the Data, Model, and Algorithm layers across all stages."
]