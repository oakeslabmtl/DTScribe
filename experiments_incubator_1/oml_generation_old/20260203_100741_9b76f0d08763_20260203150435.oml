// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring ambient temperature in real‑time"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Pressure sensor monitoring system pressure continuously"
    DTDFVocab:producedData PressureDataTransmitted
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Vibration sensor capturing dynamic structural vibrations"
    DTDFVocab:producedData VibrationDataTransmitted
]

// C4: Data transmission
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

instance VibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Raw temperature readings collected from TemperatureSensor"
    DTDFVocab:inputTo CalibrationEnabler
    DTDFVocab:fromData TemperatureDataTransmitted
]

instance PressureData : DTDFVocab:Data [
    base:desc "Raw pressure readings collected from PressureSensor"
    DTDFVocab:inputTo CalibrationEnabler
    DTDFVocab:fromData PressureDataTransmitted
]

instance VibrationData : DTDFVocab:Data [
    base:desc "Raw vibration RSSI readings collected from VibrationSensor"
    DTDFVocab:inputTo CalibrationEnabler
    DTDFVocab:fromData VibrationDataTransmitted
]

// C10: Models
instance GeometricModel : DTDFVocab:Model [
    base:desc "Geometric description of the physical structure"
    DTDFVocab:inputTo CalibrationEnabler
]

instance DynamicModel : DTDFVocab:Model [
    base:desc "Behavioral dynamics represented by differential equations"
    DTDFVocab:inputTo CalibrationEnabler
]

instance PerformanceModel : DTDFVocab:Model [
    base:desc "Analytical abstraction of system performance metrics"
    DTDFVocab:inputTo CalibrationEnabler
]

// C11: Enabler
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration routines that integrate sensor data to update model parameters and pose"
    DTDFVocab:enables DigitalTwinService
]

// C6: Service
instance DigitalTwinService : DTDFVocab:Service [
    base:desc "Digital twin service that processes data, calibrates models, and generates insights and actions"
    DTDFVocab:provides FaultDiagnosisInsight, PerformanceOptimisationDirectiveInsight, StateEstimationUpdateInsight, SafetyComplianceInsight, OptimalityComplianceInsight, CorrectiveAction, AdjustControlAction
]

// C17: Insights
instance FaultDiagnosisInsight : DTDFVocab:Insight [
    base:desc "Real‑time fault diagnostics derived from sensor data and model knowledge"
]

instance PerformanceOptimisationDirectiveInsight : DTDFVocab:Insight [
    base:desc "Performance optimisation directives generated by analysing model outputs"
]

instance StateEstimationUpdateInsight : DTDFVocab:Insight [
    base:desc "Updated state estimates calculated from fused sensor data and dynamic model"
]

instance SafetyComplianceInsight : DTDFVocab:Insight [
    base:desc "Assessment of safety compliance based on monitored constraints"
]

instance OptimalityComplianceInsight : DTDFVocab:Insight [
    base:desc "Assessment of operational optimality by evaluating performance metrics"
]

// C17: Actions
instance CorrectiveAction : DTDFVocab:Action [
    base:desc "Automatic corrective action triggered when safety or optimality violations are detected"
    DTDFVocab:IsAutomatic true
]

instance AdjustControlAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of control inputs based on performance optimisation directives"
    DTDFVocab:IsAutomatic true
]