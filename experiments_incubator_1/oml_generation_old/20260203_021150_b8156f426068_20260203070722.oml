// Acting components
instance ResistiveHeatBed : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that provides thermal energy to the insulated incubator enclosure, driven by a controller that can set heating power level via PWM or duty‑cycle commands."
]

instance IncubatorFan : DTDFVocab:ActingComponent [
    base:desc "Fan that circulates air inside the incubator chamber to improve temperature uniformity."
]

// Physical sensing components
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor embedded in the incubator chamber, provides continuous scalar temperature measurements."
    DTDFVocab:producedData TemperatureDataTransmittedInternalA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Second internal temperature sensor embedded in the incubator chamber, provides continuous scalar temperature measurements."
    DTDFVocab:producedData TemperatureDataTransmittedInternalB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor attached to the incubator, provides continuous scalar temperature measurements."
    DTDFVocab:producedData TemperatureDataTransmittedExternal
]

// Physical‑to‑virtual interaction (DataTransmitted)
instance TemperatureDataTransmittedInternalA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance TemperatureDataTransmittedInternalB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance TemperatureDataTransmittedExternal : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// Data artefacts
instance InternalTemperatureDataA : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements from InternalTempSensorA."
    DTDFVocab:fromData TemperatureDataTransmittedInternalA
    DTDFVocab:inputTo CalibrationEnabler
]

instance InternalTemperatureDataB : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements from InternalTempSensorB."
    DTDFVocab:fromData TemperatureDataTransmittedInternalB
    DTDFVocab:inputTo CalibrationEnabler
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements from ExternalTempSensor."
    DTDFVocab:fromData TemperatureDataTransmittedExternal
    DTDFVocab:inputTo CalibrationEnabler
]

// Models / Data
instance ReducedThermalModel : DTDFVocab:Model [
    base:desc "Reduced thermal dynamics model with two free parameters used for fast simulation of incubator temperature."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance HighOrderThermalModel : DTDFVocab:Model [
    base:desc "Higher‑order thermal dynamics model with four free parameters capturing heat‑bed inertia."
    DTDFVocab:inputTo SimulationEngineEnabler
]

// Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithms that adjust model parameters to minimise prediction error using streamed temperature data."
    DTDFVocab:enables CalibrationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs calibrated thermal models to predict temperature evolution."
    DTDFVocab:enables PredictionService
]

instance MonitoringEngineEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring component that compares measured and simulated temperatures against safety and optimality thresholds."
    DTDFVocab:enables MonitoringService
]

instance OptimizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Optimization service that proposes control actions (heater set‑point, fan speed) to maintain target temperature."
    DTDFVocab:enables OptimizationService
]

instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Visualization service that renders temperature trajectories for engineers and operators."
    DTDFVocab:enables VisualizationService
]

instance FaultDetectionEngineEnabler : DTDFVocab:Enabler [
    base:desc "Fault detection algorithms that detect anomalies in sensor data or actuator behavior."
    DTDFVocab:enables FaultDetectionService
]

// Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Performs calibration of thermal models using incoming temperature data."
    DTDFVocab:provides CalibrationInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Provides simulation‑based prediction of the incubator’s thermal behaviour."
    DTDFVocab:provides PredictedTemperatureInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuously monitors sensor data and model predictions, checks against thresholds, and raises alerts."
    DTDFVocab:provides TemperatureViolationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Suggests optimal control actions to keep temperature within target while respecting constraints."
    DTDFVocab:provides AdjustHeaterSetpointAction, AdjustFanSpeedAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Advanced visualisation of temperature evolution for engineers and operators."
    DTDFVocab:provides TemperatureVisualizationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults in sensors or actuators and notifies operators."
    DTDFVocab:provides FaultDetectionInsight
]

// Insights
instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Result of calibration indicating updated model parameters and confidence level."
]

instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory of the incubator chamber over the forecasting horizon."
]

instance TemperatureViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of measured or predicted temperature exceeding predefined safety or optimality thresholds."
]

instance TemperatureVisualizationInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of current and predicted temperature curves."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of sensor or actuator anomalies with severity rating."
]

// Actions
instance AdjustHeaterSetpointAction : DTDFVocab:Action [
    base:desc "Command to change the heat‑bed heating power set‑point to bring temperature back within target range."
    DTDFVocab:IsAutomatic false
]

instance AdjustFanSpeedAction : DTDFVocab:Action [
    base:desc "Command to modify fan speed for improved temperature uniformity."
    DTDFVocab:IsAutomatic false
]

// Components & Environment
instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi controller that runs control logic, collects sensor data, and communicates with actuators."
]

instance IncubatorEnclosure : DTDFVocab:Component [
    base:desc "Insulated styrofoam box forming the incubator chamber."
]

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains ResistiveHeatBed, IncubatorFan, InternalTempSensorA, InternalTempSensorB, ExternalTempSensor, RaspberryPiController, IncubatorEnclosure
]

// Tooling / Enabler (GitHub repository)
instance IncubatorDigitalTwinRepo : DTDFVocab:Enabler [
    base:desc "Public GitHub repository (https://github.com/INTO-CPS-Association/example-incubator) containing hardware specifications, software, calibration algorithms and model definitions."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin produces control actions such as target temperature set‑points and fan activation commands based on simulation and optimisation algorithms. These commands are sent to the Raspberry Pi, which drives the heatbed and fan actuators of the incubator. The documents do not detail command formats, validation/authentication mechanisms, feedback loops, conflict resolution, or execution confirmation procedures."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin follows a CPS‑based architecture where sensor data collected from the physical incubator are supplied to calibration algorithms that update the cyber‑physical system (CPS) models and environmental models. Updated models feed monitoring components that assess safety and optimality of operation. When a violation is detected, humans or higher‑level algorithms may decide to modify the physical twin. This orchestration integrates data, models, and algorithms as described in Document 1."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed experimentally by comparing predicted temperature trajectories against the measured sensor data. The four‑parameter model demonstrated higher fidelity in reproducing the heat‑bed’s thermal inertia, and therefore was selected for further DT development. Validation consists of running the simulation with the calibrated parameters and quantifying prediction error. Uncertainty arises from sensor noise, unmodelled environmental influences, and parameter estimation error; the DT mitigates these through calibration algorithms that continuously update model parameters. Quality assurance is provided by the monitoring component that flags deviations beyond acceptable error thresholds."
]