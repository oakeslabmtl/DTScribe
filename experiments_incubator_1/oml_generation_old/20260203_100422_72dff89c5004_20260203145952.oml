// C3: Physical sensing components
instance VehicleVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Collects real‑time velocity data of the vehicle using the sensor suite, providing input for kinematic modeling."
    DTDFVocab:producedData VehicleVelocityRawData
]

instance VehicleForceSensor : DTDFVocab:SensingComponent [
    base:desc "Collects dynamic force measurements on the vehicle chassis, informing force‑response modeling."
    DTDFVocab:producedData VehicleForceRawData
]

// C4: Physical-to-virtual interaction
instance VehicleVelocityRawData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleVelocitySensor
]

instance VehicleForceRawData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleForceSensor
]

// C10: Models/Data
instance VehicleVelocityData : DTDFVocab:Data [
    base:desc "Processed vehicle velocity data used by simulation and monitoring services."
    DTDFVocab:fromData VehicleVelocityRawData
    DTDFVocab:inputTo ModelExecutionEngine
]

instance VehicleForceData : DTDFVocab:Data [
    base:desc "Processed vehicle force data used by simulation and monitoring services."
    DTDFVocab:fromData VehicleForceRawData
    DTDFVocab:inputTo ModelExecutionEngine
]

instance VehicleKinematicModel : DTDFVocab:Model [
    base:desc "Differential‑equation model capturing vehicle kinematic behavior."
    DTDFVocab:inputTo ModelExecutionEngine
]

instance VehicleDynamicModel : DTDFVocab:Model [
    base:desc "Differential‑equation model capturing vehicle force‑response dynamics."
    DTDFVocab:inputTo ModelExecutionEngine
]

// C11: Enablers
instance ModelExecutionEngine : DTDFVocab:Enabler [
    base:desc "Engine that executes models and processes data for calibration, monitoring, and optimization."
    DTDFVocab:enables SimulationService, MonitoringService, FaultDetectionService, SupervisoryControlService, StateEstimationService, OptimizationService, CalibrationService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates and predicts vehicle behavior based on current sensor data and calibrated models."
    DTDFVocab:provides StateEstimateInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitors simulation outputs and sensor data against safety and performance criteria."
    DTDFVocab:provides PerformanceViolationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects fault conditions when safety or performance thresholds are breached."
    DTDFVocab:provides FaultAlert
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Plans supervisory control actions and provides optimal control strategy recommendations."
    DTDFVocab:provides OptimalControlSuggestionInsight, ApplyControlAdjustment
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Estimates system state using state‑estimation filters."
    DTDFVocab:provides StateEstimateInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Runs optimization solvers to suggest parameter adjustments."
    DTDFVocab:provides OptimalControlSuggestionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Iteratively calibrates model parameters to align with observed measurements."
    DTDFVocab:provides ParameterCalibrationInsight, UpdateModelParameters
]

// C17: Insights/Actions
instance FaultAlert : DTDFVocab:Insight [
    base:desc "Alert indicating detected fault conditions."
]

instance PerformanceViolationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating a performance criterion violation."
]

instance StateEstimateInsight : DTDFVocab:Insight [
    base:desc "Insight on the current estimated state of the vehicle."
]

instance OptimalControlSuggestionInsight : DTDFVocab:Insight [
    base:desc "Insight providing optimal control strategy recommendations."
]

instance ParameterCalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight on calibrated model parameters."
]

instance ApplyControlAdjustment : DTDFVocab:Action [
    base:desc "Automatic action to apply control adjustments to the physical twin."
    DTDFVocab:IsAutomatic true
]

instance UpdateModelParameters : DTDFVocab:Action [
    base:desc "Automatic action to update model parameters based on calibration results."
    DTDFVocab:IsAutomatic true
]

instance NotifyHumanOperator : DTDFVocab:Action [
    base:desc "Manual action to notify a human operator of safety or performance violations."
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A Digital Twin system is conceived as a framework that integrates data streams from sensors, model representations of the physical system and its environment, and algorithmic components such as calibration, monitoring, and decision support. These components coordinate through a central orchestrator that updates model parameters, evaluates safety and performance metrics, and triggers human or automated interventions."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle starts with the creation of models describing the CPS and its environment, followed by integration of these models into the DT once the Physical Twin is deployed. During operation a calibration phase updates model parameters using sensor data collected over time, providing best‑estimate parameter values. The calibrated models drive monitoring algorithms that check system performance against safety and optimality criteria; whenever a violation is detected, the system (human or algorithm) may trigger corrective actions on the Physical Twin. This continuous loop of model integration, calibration, monitoring, and intervention constitutes the full lifecycle governance of the DT."
]