// Physical Sensing Components
instance InsideIncubatorTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer inside incubator, unique 64‑bit address, range –55 °C to +125 °C, accuracy 0.5 °C (10 °C‑85 °C)."
    DTDFVocab:producedData TemperatureMessageBus
]

instance InsideIncubatorTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 1‑Wire digital thermometer inside incubator, unique 64‑bit address, same specifications as sensor1."
    DTDFVocab:producedData TemperatureMessageBus
]

instance OutsideIncubatorTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer mounted outside the incubator, unique 64‑bit address, same specifications as sensor1."
    DTDFVocab:producedData TemperatureMessageBus
]

// Physical‑to‑Virtual Interaction (Data Transmission)
instance TemperatureMessageBus : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideIncubatorTempSensor1, InsideIncubatorTempSensor2, OutsideIncubatorTempSensor
]

// Data Produced from Sensors
instance TemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature readings from the three DS18S20 sensors."
    DTDFVocab:fromData TemperatureMessageBus
    DTDFVocab:inputTo RabbitMQBroker, SciPyCalibrationEnabler, ModelSimulationEnabler
]

// Enablers (Tooling & Infrastructure)
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker running on the Raspberry Pi, receives sensor messages and distributes them to DT components."
    DTDFVocab:enables RealTimeTemperatureMonitoring, SafetyMonitoring
]

instance SciPyCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Python SciPy library used for non‑linear least‑squares calibration of thermal model parameters."
    DTDFVocab:enables ParameterCalibrationService
]

instance ModelSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime executing Model A and Model B for model‑based simulation and prediction."
    DTDFVocab:enables ModelSimulationService, OptimizationService
]

instance PythonControlEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level driver on the Pi that commands MOSFET switches via GPIO to actuate heatbed and fan."
    DTDFVocab:enables ActuationControlService
]

instance GitHubRepositoryEnabler : DTDFVocab:Enabler [
    base:desc "Open‑source GitHub repository containing hardware schematics and software code."
    DTDFVocab:enables ParameterCalibrationService, ModelSimulationService, ActuationControlService
]

// Services Provided by the DT
instance RealTimeTemperatureMonitoring : DTDFVocab:Service [
    base:desc "Provides continuous temperature monitoring of incubator interior and exterior."
    DTDFVocab:provides TemperatureDeviationDetection
]

instance SafetyMonitoring : DTDFVocab:Service [
    base:desc "Implements safe‑protocol checks in low‑level driver to prevent overheating."
    DTDFVocab:provides SafeProtocolCompliance
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates thermal parameters (C_air, C_heater, G_box, G_heater) using SciPy non‑linear least‑squares."
    DTDFVocab:provides CalibratedThermalParameters
]

instance ModelSimulationService : DTDFVocab:Service [
    base:desc "Runs Model A (single capacity C_air, conductance G_box) and Model B (adds C_heater, G_heater) to predict temperature trajectories."
    DTDFVocab:provides PredictedTemperatureTrajectories
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimises heating cycles based on calibrated models to minimise energy while maintaining target temperature."
    DTDFVocab:provides HeatingCycleOptimization, AdjustHeatingAction
]

instance ActuationControlService : DTDFVocab:Service [
    base:desc "Commands MOSFET switches on the custom PCB to drive heatbed and fan according to control decisions."
    DTDFVocab:provides AdjustHeatingAction
]

// Insights & Actions
instance TemperatureDeviationDetection : DTDFVocab:Insight [
    base:desc "Detects deviations from target temperature based on real‑time readings."
]

instance SafeProtocolCompliance : DTDFVocab:Insight [
    base:desc "Ensures low‑level driver follows safe protocol to avoid unsafe heating."
]

instance CalibratedThermalParameters : DTDFVocab:Insight [
    base:desc "Derived calibrated parameters C_air, C_heater, G_box, G_heater from experimental data."
]

instance HeatingCycleOptimization : DTDFVocab:Insight [
    base:desc "Identifies optimal heating duration and waiting periods to maintain safe and optimal operation."
]

instance PredictedTemperatureTrajectories : DTDFVocab:Insight [
    base:desc "Model‑predicted temperature trajectories generated by Model A and Model B."
]

instance AdjustHeatingAction : DTDFVocab:Action [
    base:desc "Adjusts heating duration or fan speed to correct temperature deviation."
    DTDFVocab:IsAutomatic true
]

// Model Definitions
instance ModelA : DTDFVocab:Model [
    base:desc "Thermal Model A with single thermal capacity C_air and box conductance G_box."
    DTDFVocab:inputTo SciPyCalibrationEnabler, ModelSimulationEnabler
]

instance ModelB : DTDFVocab:Model [
    base:desc "Thermal Model B adds heat‑bed capacity C_heater and conductance G_heater to Model A."
    DTDFVocab:inputTo SciPyCalibrationEnabler, ModelSimulationEnabler
]

// Physical Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heating element (heatbed) driven through MOSFET switch on custom PCB."
    DTDFVocab:producedData HeatbedControlMessageBus
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V fan circulating air, driven via MOSFET switch on custom PCB."
    DTDFVocab:producedData FanControlMessageBus
]

// Actuation Data Transmission
instance HeatbedControlMessageBus : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatbedActuator
]

instance FanControlMessageBus : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FanActuator
]

instance ActuationCommandData : DTDFVocab:Data [
    base:desc "Control commands for heatbed and fan transmitted via message buses."
    DTDFVocab:fromData HeatbedControlMessageBus, FanControlMessageBus
    DTDFVocab:inputTo PythonControlEnabler
]

// Environment and Static Components
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator, FanActuator, InsideIncubatorTempSensor1, InsideIncubatorTempSensor2, OutsideIncubatorTempSensor,
                RaspberryPiController, CustomPCBCircuit, PowerSupply
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running Linux, hosts drivers, RabbitMQ broker and control software."
]

instance CustomPCBCircuit : DTDFVocab:Component [
    base:desc "Custom PCB with MOSFETs and optocouplers for safe power switching of heatbed and fan."
]

instance PowerSupply : DTDFVocab:Component [
    base:desc "Dedicated power supply providing required voltages for Pi, heatbed and fan."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (heat‑bed ON/OFF, fan ON/OFF, waiting periods) are sent from DT services to the RabbitMQ broker, consumed by the Pi controller which actuates the MOSFET‑based driver to change the heatbed and fan states."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is orchestrated as a set of loosely coupled components: the controller, low‑level driver, and RabbitMQ broker on the Pi; DT services subscribe to the broker to receive sensor streams and publish control commands, enabling a bidirectional message‑driven architecture."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through explicit assumptions (uniform air temperature, negligible wall heat, constant air specific heat, heat‑bed heat loss), validation experiments for temperature uniformity, and calibration of model parameters against measured data; model B is favoured for better prediction of heat‑bed thermal inertia."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses the AMQP protocol of RabbitMQ over the Pi’s built‑in Wi‑Fi/Bluetooth network interface; GPIO pins provide direct hardware interfacing for sensors and actuators."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ broker and controller software are hosted locally on the Raspberry Pi 4; DT services can run on the same device or access the broker remotely (e.g., cloud) via standard network connections."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe‑protocol is embedded in the low‑level driver to keep the device in a safe state; the DT monitors temperature limits (LL, UL) and can halt actuation if safety thresholds are crossed."
]