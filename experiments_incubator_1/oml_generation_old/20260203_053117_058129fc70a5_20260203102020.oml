// ====================
// Physical Sensing Components
// ====================

instance IncubatorAirSensorInside1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire temperature sensor (±0.5 °C accuracy, range –10 °C to +85 °C) mounted inside the incubator."
    DTDFVocab:producedData AirTempDataTransmitted1
]

instance IncubatorAirSensorInside2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 high‑precision 1‑Wire temperature sensor (±0.5 °C accuracy) mounted inside the incubator."
    DTDFVocab:producedData AirTempDataTransmitted2
]

instance IncubatorAmbientRoomSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire temperature sensor (±0.5 °C accuracy) measuring ambient room temperature."
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// ====================
// Data Transmitted (PT → DT)
// ====================

instance AirTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorAirSensorInside1
]

instance AirTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorAirSensorInside2
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorAmbientRoomSensor
]

// ====================
// Data (DT internal representation)
// ====================

instance AirTemperatureData1 : DTDFVocab:Data [
    base:desc "Temperature time‑series from internal sensor 1 (°C)."
    DTDFVocab:fromData AirTempDataTransmitted1
    DTDFVocab:inputTo RabbitMQEnabler, SciPyCalibrationEnabler
]

instance AirTemperatureData2 : DTDFVocab:Data [
    base:desc "Temperature time‑series from internal sensor 2 (°C)."
    DTDFVocab:fromData AirTempDataTransmitted2
    DTDFVocab:inputTo RabbitMQEnabler, SciPyCalibrationEnabler
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Ambient room temperature time‑series (°C)."
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo RabbitMQEnabler, SciPyCalibrationEnabler
]

// ====================
// Enablers
// ====================

instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP message broker running on the Raspberry Pi; receives sensor streams and forwards them to DT services."
    DTDFVocab:enables RealTimeTemperatureMonitoringService,
                 ModelCalibrationService,
                 SafetyMonitoringService,
                 TemperaturePredictionService,
                 DataVisualizationService
]

instance SciPyCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Python SciPy library providing non‑linear least‑squares solvers for model parameter estimation."
    DTDFVocab:enables ModelCalibrationService
]

// ====================
// Services
// ====================

instance RealTimeTemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Continuously monitors temperature streams from all sensors."
    DTDFVocab:provides RealTimeTemperatureInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates ThermalModelA and ThermalModelB using experimental temperature trajectories via SciPy non‑linear least‑squares."
    DTDFVocab:provides CalibratedModelParametersInsight
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Detects temperature limit violations and triggers appropriate safety actions."
    DTDFVocab:provides TemperatureViolationInsight,
                 HeatingAction,
                 CoolingAction
]

instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Predicts future temperature trajectories using the calibrated ThermalModelA and ThermalModelB."
    DTDFVocab:provides PredictedTemperatureTrajectoryInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Visualizes sensor data streams via RabbitMQ messages for operator dashboards."
    DTDFVocab:provides RealTimeTemperatureInsight
]

// ====================
// Insights
// ====================

instance RealTimeTemperatureInsight : DTDFVocab:Insight [
    base:desc "Current temperature values from internal and ambient sensors delivered in real time."
]

instance CalibratedModelParametersInsight : DTDFVocab:Insight [
    base:desc "Calibrated thermal model parameters (C_air, G_box, C_heater, G_heater, etc.) obtained from experiment data."
]

instance TemperatureViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature exceeding configured safety limits."
]

instance PredictedTemperatureTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Forecasted temperature curve for the incubator over a specified horizon based on Model A/B."
]

// ====================
// Actions
// ====================

instance HeatingAction : DTDFVocab:Action [
    base:desc "Turns on the resistive heat‑bed via MOSFET driver on the custom PCB."
    DTDFVocab:IsAutomatic true
]

instance CoolingAction : DTDFVocab:Action [
    base:desc "Activates the circulation fan to reduce temperature via MOSFET driver."
    DTDFVocab:IsAutomatic true
]

// ====================
// Models
// ====================

instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single‑state air temperature model with parameters C_air and G_box."
    DTDFVocab:inputTo SciPyCalibrationEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Dual‑state model (air and heat‑bed) with parameters C_air, C_heater, G_box, G_heater."
    DTDFVocab:inputTo SciPyCalibrationEnabler
]

// ====================
// Physical Acting Components
// ====================

instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed (≈100 W) controlled on/off via MOSFET driver on the custom PCB."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V circulation fan (≈0.02 m³·s⁻¹) controlled on/off via MOSFET driver."
]

// ====================
// Physical Environment & Components
// ====================

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running low‑level drivers, RabbitMQ broker, and digital‑twin software."
]

instance CustomPCB : DTDFVocab:Component [
    base:desc "Custom PCB containing MOSFET power switches and optocouplers for safe actuation of heat‑bed and fan."
]

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator,
                 FanActuator,
                 IncubatorAirSensorInside1,
                 IncubatorAirSensorInside2,
                 IncubatorAmbientRoomSensor,
                 RaspberryPiController,
                 CustomPCB
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by DT components are sent via RabbitMQ to the controller on the Raspberry Pi, which forwards them through the low‑level driver to the MOSFET driver circuit to toggle the heat‑bed and fan power states."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture comprises the PT hardware (container, heat‑bed, fan, sensors, PCB), the Raspberry Pi controller hosting a low‑level driver, a RabbitMQ server for publish/subscribe communication, DT modules that subscribe to sensor topics for monitoring and model calibration, and actuator command producers that publish control messages back to the PT; all components run on the same Raspberry Pi host."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated through two assumptions (uniform air temperature, negligible wall heat storage) and validated by experiments measuring temperature uniformity with the fan at 12 V and 18 V; calibration error is minimized using a least‑squares cost function; the validity of Model B is higher because it accounts for heat‑bed thermal inertia."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses the AMQP protocol via RabbitMQ running locally on the Raspberry Pi; sensor data are transmitted over the 1‑Wire bus to the GPIO, and actuator commands are issued over GPIO through MOSFET drivers; all network traffic remains within the local Pi host."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT services (RabbitMQ broker, low‑level driver, controller code, calibration modules) are all hosted on the Raspberry Pi 4 Model B, which provides both compute and network interfaces for the DT."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol that forces the PT into a safe state on communication loss; hardware isolation is achieved with MOSFET switches and optocouplers to prevent back‑feeding; safety monitoring monitors temperature limits (LL, UL) and can halt actuation to avoid overheating."
]