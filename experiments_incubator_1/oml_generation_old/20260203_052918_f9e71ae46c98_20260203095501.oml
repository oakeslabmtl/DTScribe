// C17: Insights
instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted internal temperature trajectory based on current conditions."
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Calibrated model parameters (C_air, G_box, C_heater, G_heater) after optimization."
]

instance TemperatureAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when temperature deviates from desired bounds."
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Alert for safety violations such as overheating."
]

instance TemperatureTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of temperature over time."
]

// C17: Actions
instance HeatingAdjustmentRecommendation : DTDFVocab:Action [
    base:desc "Recommendation to adjust heating duration or waiting period to bring temperature within desired range.",
    DTDFVocab:IsAutomatic false
]

// C11: Enablers
instance EnablerRabbitMQ : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker deployed on the Raspberry Pi, transports sensor data, actuator status, and service requests.",
    DTDFVocab:enables SimulationService, CalibrationService, MonitoringService, VisualizationService, DecisionSupportService
]

instance EnablerSciPy : DTDFVocab:Enabler [
    base:desc "Python SciPy library used for non‑linear least‑squares calibration of model parameters.",
    DTDFVocab:enables CalibrationService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Provides temperature forecasts using calibrated Model A and Model B.",
    DTDFVocab:provides TemperatureForecastInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Runs non‑linear least‑squares optimization (SciPy) to calibrate model parameters from experimental temperature data.",
    DTDFVocab:provides CalibrationInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Detects safety or performance violations such as temperature out‑of‑bounds.",
    DTDFVocab:provides TemperatureAlertInsight, SafetyViolationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualizes temperature trajectories over time for operators.",
    DTDFVocab:provides TemperatureTrajectoryInsight
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Generates operational recommendations based on forecasts and safety status.",
    DTDFVocab:provides HeatingAdjustmentRecommendation
]

// C4: Physical‑to‑Virtual Interaction (Data Transmission)
instance InteriorTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTemperatureSensor1
]

instance InteriorTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTemperatureSensor2
]

instance ExteriorTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExteriorTemperatureSensor
]

instance ActuatorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Controller publishes actuator status (heatbed and fan on/off states) via RabbitMQ."
]

// C3: Physical Sensing Components
instance InteriorTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer (range –55 °C to +125 °C, accuracy ±0.5 °C) measuring interior temperature of the incubator.",
    DTDFVocab:producedData InteriorTempDataTransmitted1
]

instance InteriorTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 high‑precision 1‑Wire digital thermometer measuring interior temperature of the incubator.",
    DTDFVocab:producedData InteriorTempDataTransmitted2
]

instance ExteriorTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer measuring ambient room temperature.",
    DTDFVocab:producedData ExteriorTempDataTransmitted
]

// C10: Data
instance InteriorTemperatureData1 : DTDFVocab:Data [
    base:desc "Temperature reading from interior sensor 1 in °C.",
    DTDFVocab:fromData InteriorTempDataTransmitted1,
    DTDFVocab:inputTo EnablerRabbitMQ
]

instance InteriorTemperatureData2 : DTDFVocab:Data [
    base:desc "Temperature reading from interior sensor 2 in °C.",
    DTDFVocab:fromData InteriorTempDataTransmitted2,
    DTDFVocab:inputTo EnablerRabbitMQ
]

instance ExteriorTemperatureData : DTDFVocab:Data [
    base:desc "Ambient room temperature reading in °C.",
    DTDFVocab:fromData ExteriorTempDataTransmitted,
    DTDFVocab:inputTo EnablerRabbitMQ
]

instance ActuatorStatusData : DTDFVocab:Data [
    base:desc "Current on/off state of heatbed and fan.",
    DTDFVocab:fromData ActuatorStatusDataTransmitted,
    DTDFVocab:inputTo EnablerRabbitMQ
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Physics‑based temperature model A with parameters C_air and G_box derived from heat‑balance equations.",
    DTDFVocab:inputTo EnablerRabbitMQ
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Physics‑based temperature model B extending Model A with additional parameters C_heater and G_heater.",
    DTDFVocab:inputTo EnablerRabbitMQ
]

// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed actuation (on/off heating) performed via Raspberry Pi controller and MOSFET driver circuit on the PCB."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan actuation (on/off speed control) performed via Raspberry Pi controller and MOSFET driver circuit on the PCB."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin publishes control commands (heatbed ON/OFF, fan ON/OFF or speed) to the RabbitMQ broker; the low‑level driver on the Raspberry Pi subscribes to these messages and forwards them to the MOSFET drivers to actuate the heatbed and fan."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture comprises the PT (box, heatbed, fan, sensors, PCB, Raspberry Pi), a cyber layer with a low‑level driver, a controller implementing the control logic, a RabbitMQ communication server linking PT and DT, and model/calibration modules that consume sensor data and produce predictions and alerts."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through four explicit assumptions (uniform temperature, negligible wall heat storage, constant air specific heat, negligible fan heat), experimental validation of temperature uniformity (maximum ±7 °C discrepancy), and calibration of model parameters via non‑linear least squares to minimise residual error between model predictions and measured data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical devices communicate with the DT via the RabbitMQ message broker that runs locally on the Raspberry Pi. Sensor data is collected over the 1‑Wire bus and sent to the broker by the low‑level driver; control commands are retrieved from the broker by the controller and dispatched to the MOSFET/optocoupler circuit through GPIO pins. The Raspberry Pi’s network interfaces (Wi‑Fi/Bluetooth) provide the underlying IP connectivity for RabbitMQ."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT software components (RabbitMQ broker, controller, driver, and model services) are deployed on the same Raspberry Pi 4 Model B that also hosts the PT hardware; source code and hardware designs are stored in a public GitHub repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the device in a safe state, and the DT includes monitoring services that detect safety violations (e.g., temperature out of bounds) before allowing actuator commands to be executed."
]