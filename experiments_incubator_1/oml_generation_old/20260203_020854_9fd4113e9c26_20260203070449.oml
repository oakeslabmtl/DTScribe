// ---------- Acting Components ----------
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that provides heating power to the incubator interior, controlled via Raspberry Pi GPIO."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Air‑circulating fan that distributes warm air inside the incubator, driven by commands from the Raspberry Pi."
]

// ---------- Sensing Components ----------
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor placed inside the styrofoam enclosure to measure cavity temperature."
    DTDFVocab:producedData InternalTempDataTransmitted1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second temperature sensor inside the enclosure for redundant cavity temperature measurement."
    DTDFVocab:producedData InternalTempDataTransmitted2
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted externally to record ambient temperature."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// ---------- Data Transmitted ----------
instance InternalTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// ---------- Data ----------
instance InternalTempData1 : DTDFVocab:Data [
    base:desc "Scalar temperature reading from InternalTempSensor1, sampled continuously."
    DTDFVocab:fromData InternalTempDataTransmitted1
    DTDFVocab:inputTo CalibrationEngine, PredictionEngine, MonitoringEngine
]

instance InternalTempData2 : DTDFVocab:Data [
    base:desc "Scalar temperature reading from InternalTempSensor2, sampled continuously."
    DTDFVocab:fromData InternalTempDataTransmitted2
    DTDFVocab:inputTo CalibrationEngine, PredictionEngine, MonitoringEngine
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Scalar temperature reading from ExternalTempSensor, sampled continuously."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo CalibrationEngine, PredictionEngine, MonitoringEngine
]

// ---------- Models ----------
instance ThermalModelTwoParam : DTDFVocab:Model [
    base:desc "Analytical thermal simulation model containing two free parameters representing basic heat‑bed dynamics."
    DTDFVocab:inputTo CalibrationEngine, PredictionEngine
]

instance ThermalModelFourParam : DTDFVocab:Model [
    base:desc "Analytical thermal simulation model containing four free parameters to capture heat‑bed thermal inertia."
    DTDFVocab:inputTo CalibrationEngine, PredictionEngine
]

// ---------- Enablers ----------
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ server used for AMQP communication of sensor readings from the driver to DT components."
    DTDFVocab:enables DataIngestionService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that updates model parameters using the latest temperature data."
    DTDFVocab:enables CalibrationService
]

instance PredictionEngine : DTDFVocab:Enabler [
    base:desc "Prediction algorithm that runs the calibrated thermal models to forecast future internal temperature."
    DTDFVocab:enables PredictionService
]

instance MonitoringEngine : DTDFVocab:Enabler [
    base:desc "Monitoring component that compares real‑time sensor data against calibrated model outputs."
    DTDFVocab:enables MonitoringService
]

instance OptimizationEngine : DTDFVocab:Enabler [
    base:desc "Optimization/decision‑support engine that assesses safety and optimality and suggests corrective actions."
    DTDFVocab:enables OptimizationService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Visualization module that renders simulation results and current state for operators."
    DTDFVocab:enables VisualizationService
]

instance DataIngestionService : DTDFVocab:Service [
    base:desc "Continuous acquisition of temperature measurements from the physical twin via RabbitMQ."
    DTDFVocab:provides DataAcquisitionInsight
]

// ---------- Services ----------
instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration/parameter‑estimation service that fits model parameters to recent sensor data."
    DTDFVocab:provides ParameterUpdateAction
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Prediction service that generates future temperature trajectories using the calibrated thermal models."
    DTDFVocab:provides TemperatureForecastInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitoring service that detects safety or performance violations by comparing live sensor data with model predictions."
    DTDFVocab:provides SafetyViolationInsight, PerformanceViolationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that evaluates operational safety and optimality and recommends actuator set‑points."
    DTDFVocab:provides AdjustHeatingAction, AdjustFanSpeedAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Advanced visualization service presenting simulation results and real‑time state to operators."
    DTDFVocab:provides VisualizationInsight
]

// ---------- Insights ----------
instance DataAcquisitionInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful acquisition of sensor data."
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that real‑time temperature deviates from safe operating bounds."
]

instance PerformanceViolationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that temperature performance targets are not being met."
]

instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasted temperature trajectory generated by the prediction models."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of current system state and simulation outcomes."
]

// ---------- Actions ----------
instance ParameterUpdateAction : DTDFVocab:Action [
    base:desc "Automatic update of model parameters after calibration."
    DTDFVocab:IsAutomatic true
]

instance AdjustHeatingAction : DTDFVocab:Action [
    base:desc "Command to modify the heat‑bed power set‑point to restore safe temperature."
    DTDFVocab:IsAutomatic false
]

instance AdjustFanSpeedAction : DTDFVocab:Action [
    base:desc "Command to change fan speed for better temperature distribution."
    DTDFVocab:IsAutomatic false
]

// ---------- Environment ----------
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, FanActuator, InternalTempSensor1, InternalTempSensor2, ExternalTempSensor
]

// ---------- Physical Components ----------
instance HeatBedComponent : DTDFVocab:Component [
    base:desc "Resistive heating element forming the heat‑bed."
]

instance FanComponent : DTDFVocab:Component [
    base:desc "DC fan used for air circulation inside the incubator."
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi that hosts the driver, calibration, prediction, and optimization software."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The controller (running on a Raspberry Pi) sends control commands to the low‑level driver through RabbitMQ messages. Commands include turning the heat‑bed on/off, fan activation, and parameters such as heating duration (H) and waiting duration (C). Messages are formatted as RabbitMQ payloads (AMQP). The low‑level driver validates incoming commands using an incorporated safe protocol before acting on the physical actuators, and it publishes status updates and sensor readings back to the broker, providing feedback to the controller. Conflict‑resolution and explicit execution acknowledgements are not detailed in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT streams sensor and controller messages from the physical incubator to a time‑series database in real‑time, enabling immediate dashboard updates for status monitoring."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT follows a centralized orchestration where the physical controller and low‑level driver feed data to a time‑series database; calibration, Kalman‑filter based anomaly detection, what‑if co‑simulation, and controller re‑configuration are coordinated in a self‑adaptation loop that closes the digital‑physical feedback cycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the two thermal models against experimental temperature traces; the four‑parameter model shows higher accuracy in reproducing the heat‑bed’s thermal inertia. Validation is performed through laboratory experiments that record temperature responses and compute prediction errors. Calibration algorithms update model parameters to reduce mismatch, providing a form of error correction. Sources of uncertainty include simplifications in the thermal model and sensor measurement noise; quantitative uncertainty quantification is not detailed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between all components (controller, low‑level driver, and Digital Twin services) is mediated by a RabbitMQ message broker. RabbitMQ uses the AMQP protocol over TCP/IP, forming a star‑topology where each participant connects to the central broker. The broker can be deployed on‑premise or in the cloud and is described as lightweight, mature, and supporting reliable message delivery, though specific bandwidth, latency, redundancy or security mechanisms (e.g., TLS, authentication) are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ communication server, which underpins the Digital Twin, can be hosted either on‑premises or in a cloud environment, as stated in the documents. No quantitative specifications for computational power, storage capacity, scalability mechanisms, deployment models (e.g., containers, VMs) or availability guarantees are provided."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT integrates with external components such as a time‑series database and a visualization dashboard, and exchanges data with co‑simulation modules that can consume historical or real‑time PT data."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The described Digital Twin includes safety‑oriented mechanisms: calibration algorithms update the cyber‑physical system and environment models with the best parameter estimates, and the resulting data feed monitors that continuously verify that the physical twin is operating safely and optimally. When a safety violation is detected, the system can invoke human operators or automated algorithms to adjust or halt the physical twin. No specific security protocols, access control, or privacy measures are mentioned in the provided documents."
]