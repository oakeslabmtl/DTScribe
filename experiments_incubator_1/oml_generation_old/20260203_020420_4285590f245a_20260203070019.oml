// C3: Physical sensing components
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted inside the insulated styrofoam box (internal sensor A) measuring air temperature in °C."
    DTDFVocab:producedData InternalTempSensorADataTransmitted
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted inside the insulated styrofoam box (internal sensor B) measuring air temperature in °C."
    DTDFVocab:producedData InternalTempSensorBDataTransmitted
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring ambient room temperature outside the incubator box in °C."
    DTDFVocab:producedData AmbientTempSensorDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance InternalTempSensorADataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempSensorBDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance AmbientTempSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// C10: Data
instance InternalTempSensorAData : DTDFVocab:Data [
    base:desc "Raw temperature measurement from InternalTempSensorA in °C."
    DTDFVocab:fromData InternalTempSensorADataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, KalmanFilterEnabler, VisualizationEnabler
]

instance InternalTempSensorBData : DTDFVocab:Data [
    base:desc "Raw temperature measurement from InternalTempSensorB in °C."
    DTDFVocab:fromData InternalTempSensorBDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, KalmanFilterEnabler, VisualizationEnabler
]

instance AmbientTempSensorData : DTDFVocab:Data [
    base:desc "Raw ambient temperature measurement from AmbientTempSensor in °C."
    DTDFVocab:fromData AmbientTempSensorDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, VisualizationEnabler
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical thermal Model A with two free parameters derived from Q = cm·ΔT, assuming all electrical power converts to heat."
    DTDFVocab:inputTo CalibrationEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Analytical thermal Model B with four free parameters capturing heat‑bed inertia, used as the process model in the Kalman filter."
    DTDFVocab:inputTo KalmanFilterEnabler
]

// C11: Enablers
instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker mediates AMQP messages between low‑level driver, controller and DT components."
    DTDFVocab:enables RealTimeVisualizationService, OnDemandCalibrationService, AnomalyDetectionStateEstimationService, WhatIfSimulationService, SelfAdaptationLoopService
]

instance TimeSeriesDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Time‑series database stores streamed temperature data for visualization, calibration and monitoring."
    DTDFVocab:enables RealTimeVisualizationService, OnDemandCalibrationService, AnomalyDetectionStateEstimationService, WhatIfSimulationService, SelfAdaptationLoopService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm updates free parameters of Model A and Model B using collected sensor data."
    DTDFVocab:enables OnDemandCalibrationService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter consumes Model B and sensor data to estimate hidden heat‑bed temperature and detect anomalies."
    DTDFVocab:enables AnomalyDetectionStateEstimationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard visualizes real‑time temperature streams and controller states."
    DTDFVocab:enables RealTimeVisualizationService
]

instance CoSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Co‑simulation framework replays historical or live PT data together with models for what‑if scenario evaluation."
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationEnabler : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop detects plant‑behavior changes, schedules experiments, recalibrates models, reconfigures the Kalman filter and controller, and applies optimized actions."
    DTDFVocab:enables SelfAdaptationLoopService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of incubator status via time‑series database and web dashboard plotting sensor streams."
    DTDFVocab:provides TemperatureVisualizationInsight, AdjustControllerParametersAction
]

instance OnDemandCalibrationService : DTDFVocab:Service [
    base:desc "On‑demand calibration of thermal models by executing the calibration routine using collected sensor data."
    DTDFVocab:provides ModelParameterUpdateInsight, TriggerCalibrationAction
]

instance AnomalyDetectionStateEstimationService : DTDFVocab:Service [
    base:desc "Anomaly detection and heat‑bed state estimation using a Kalman filter built on Model B."
    DTDFVocab:provides AnomalyAlertInsight, GenerateAnomalyAlertAction
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What‑if simulation through co‑simulation that replays PT data to evaluate alternative controller parameters."
    DTDFVocab:provides WhatIfSimulationInsight, RunCoSimulationAction
]

instance SelfAdaptationLoopService : DTDFVocab:Service [
    base:desc "Self‑adaptation loop that detects changes, schedules experiments, recalibrates models, reconfigures Kalman filter and controller, and applies optimized control actions."
    DTDFVocab:provides SelfAdaptationInsight, ScheduleExperimentAction
]

// C17: Insights
instance TemperatureVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides operators with up‑to‑date temperature and controller state visualizations."
]

instance ModelParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Delivers updated model parameters after calibration, improving prediction accuracy."
]

instance AnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Generates alerts when sensor data deviate from Kalman‑filter expectations, indicating possible faults."
]

instance WhatIfSimulationInsight : DTDFVocab:Insight [
    base:desc "Shows results of alternative controller settings evaluated via co‑simulation."
]

instance SelfAdaptationInsight : DTDFVocab:Insight [
    base:desc "Informs stakeholders about detected plant‑behavior changes and recommended adaptation actions."
]

// C17: Actions
instance AdjustControllerParametersAction : DTDFVocab:Action [
    base:desc "Automatically adjust bang‑bang controller parameters (LL, UL, H, C) based on insights."
    DTDFVocab:IsAutomatic true
]

instance TriggerCalibrationAction : DTDFVocab:Action [
    base:desc "Invoke calibration routine for thermal models."
    DTDFVocab:IsAutomatic false
]

instance GenerateAnomalyAlertAction : DTDFVocab:Action [
    base:desc "Create an anomaly alert message for operators."
    DTDFVocab:IsAutomatic true
]

instance RunCoSimulationAction : DTDFVocab:Action [
    base:desc "Execute co‑simulation with selected controller parameter set."
    DTDFVocab:IsAutomatic true
]

instance ScheduleExperimentAction : DTDFVocab:Action [
    base:desc "Schedule and launch a new experiment to collect data for re‑calibration."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The bang‑bang controller (with parameters LL, UL, H, C) issues control commands for the heat‑bed and fan (e.g., turn‑on, turn‑off, heating duration, waiting duration) as AMQP messages to the RabbitMQ server. The low‑level driver subscribes to these command topics, validates them through an embedded safe‑protocol, forwards the commands to the physical actuators, and sends acknowledgment or state‑update messages back to the controller. This feedback loop confirms command execution and allows the controller to adjust its logic accordingly."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The incubator Digital Twin uses a centralized message‑bus architecture centred on a RabbitMQ server for synchronization and communication. The physical twin includes a low‑level driver that periodically reads temperature sensors and publishes measurements, and a bang‑bang controller that receives commands and publishes its control state. All DT services—such as calibration algorithms, a Kalman‑filter based state estimator, what‑if co‑simulation, and a real‑time visualisation dashboard—are implemented as independent components that subscribe to the relevant RabbitMQ topics, consume PT data, and publish results back onto the bus. The DT orchestrates the system by listening to the message flow between controller and driver, updating model parameters via calibration, detecting anomalies, and reconfiguring the controller as needed."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin lifecycle for the incubator case study follows the stages described in the literature: (1) model creation – two simulation models (Model A and Model B) are built using the heat transfer equations; (2) model integration – the selected model is incorporated into the DT together with sensor data streams; (3) calibration – automatic calibration algorithms (section 3.3) adjust free parameters using measured temperature data; (4) runtime monitoring – calibrated models feed monitors that evaluate safety and optimality; (5) feedback and adaptation – when violations are detected, the DT triggers controller re‑configuration or further experiments, completing the loop."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by selecting Model B (four‑parameter model) because experimental results show it better predicts the thermal inertia of the heatbed than Model A (two‑parameter model). Validation is performed through calibration experiments that compare model predictions against measured temperature data (section 4). Sources of uncertainty include the simplifying assumptions: uniform temperature distribution (Assumption 1), negligible wall heat storage (Assumption 2), constant specific heat capacity of air (Assumption 3), and complete conversion of electrical power to heat (Assumption 4, which is omitted in Model B). Uncertainty quantification is implicit in the calibration process, which adjusts model parameters to minimise prediction error. Quality assurance involves continuous monitoring for safety and optimal operation, anomaly detection via Kalman‑filter‑based state estimation, and on‑demand re‑calibration. Errors detected by monitors can trigger a self‑adaptation loop that re‑calibrates models, updates the Kalman filter, and re‑optimises controller parameters."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the digital twin components (controller, low‑level driver, DT analytics) is mediated by a RabbitMQ server using the AMQP protocol. The architecture follows a client‑server publish/subscribe topology where each component connects over the local network (e.g., Ethernet or Wi‑Fi) to the RabbitMQ broker. RabbitMQ provides reliable message delivery with persistence and can be deployed on‑premise, offering basic redundancy; explicit bandwidth, latency, or additional security mechanisms are not detailed in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is realized through the RabbitMQ message broker, which carries data between the physical twin components and the DT services. The DT also streams sensor data into a time‑series database and renders it on a dashboard for real‑time visualisation, enabling interoperability with monitoring tools and allowing external applications to access DT data via the broker."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The incubator Digital Twin uses a low‑level driver that incorporates a safe protocol to keep the physical twin in a safe state; the driver periodically reads temperature sensors, validates incoming commands from the controller, and only forwards approved actions to the heat‑bed and fan actuators. Communication between the controller, driver, and other DT components is mediated by a RabbitMQ message broker, providing a lightweight, centralized messaging infrastructure. The controller implements a bang‑bang control algorithm with explicit lower‑limit (LL) and upper‑limit (UL) temperature thresholds, a heating duration (H) and a waiting duration (C) to avoid temperature overshoot, which serves as a safety‑critical control measure. The documents do not detail additional cybersecurity measures such as authentication, encryption, or fine‑grained access control."
]