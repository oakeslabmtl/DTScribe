// C3: Physical sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor inside incubator chamber, interfaced via 1‑Wire bus to Raspberry Pi"
    DTDFVocab:producedData InternalTempDataMsg1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second internal temperature sensor inside incubator chamber, interfaced via 1‑Wire bus to Raspberry Pi"
    DTDFVocab:producedData InternalTempDataMsg2
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor monitoring ambient environment, interfaced via 1‑Wire bus to Raspberry Pi"
    DTDFVocab:producedData ExternalTempDataMsg
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance InternalTempDataMsg1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempDataMsg2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance ExternalTempDataMsg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// C10: Data
instance InternalTempTimeSeries1 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements from InternalTempSensor1, converted to °C and published via AMQP"
    DTDFVocab:fromData InternalTempDataMsg1
    DTDFVocab:inputTo RabbitMQEnabler, CalibrationEnabler, MonitoringEnabler, StateEstimationEnabler, FaultDetectionEnabler
]

instance InternalTempTimeSeries2 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements from InternalTempSensor2, converted to °C and published via AMQP"
    DTDFVocab:fromData InternalTempDataMsg2
    DTDFVocab:inputTo RabbitMQEnabler, CalibrationEnabler, MonitoringEnabler, StateEstimationEnabler, FaultDetectionEnabler
]

instance ExternalTempTimeSeries : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements from ExternalTempSensor, representing ambient conditions"
    DTDFVocab:fromData ExternalTempDataMsg
    DTDFVocab:inputTo RabbitMQEnabler, CalibrationEnabler, MonitoringEnabler, StateEstimationEnabler, FaultDetectionEnabler
]

// C10: Models
instance ThermalIncubatorModel : DTDFVocab:Model [
    base:desc "Analytical/simulation model of the incubator thermal dynamics, capturing heater, insulation, and chamber temperature"
    DTDFVocab:inputTo SimulationEnabler, OptimisationEnabler
]

instance EnvironmentalDynamicsModel : DTDFVocab:Model [
    base:desc "Model of the surrounding environment temperature influencing heat losses from the incubator"
    DTDFVocab:inputTo SimulationEnabler, OptimisationEnabler
]

// C11: Enablers
instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ broker providing AMQP messaging, queues, and durability for ingesting sensor streams"
    DTDFVocab:enables DataIngestionService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that consumes temperature time‑series to estimate model parameters"
    DTDFVocab:enables CalibrationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring algorithm that checks safety and optimality criteria from sensor data"
    DTDFVocab:enables MonitoringService
]

instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "State‑estimation routine that fuses sensor data to infer current system state"
    DTDFVocab:enables StateEstimationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Fault‑detection algorithm that analyses residuals between measurements and model predictions"
    DTDFVocab:enables FaultDetectionService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs ThermalIncubatorModel and EnvironmentalDynamicsModel under current conditions"
    DTDFVocab:enables PredictionSimulationService
]

instance OptimisationEnabler : DTDFVocab:Enabler [
    base:desc "Optimisation routine that generates control setpoints to achieve target temperature while minimizing energy"
    DTDFVocab:enables OptimisationService
]

// C6: Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service that receives AMQP messages from RabbitMQ and makes sensor data available to DT components"
    DTDFVocab:provides DataIngestionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that calibrates model parameters using incoming temperature data"
    DTDFVocab:provides CalibrationInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors safety and optimality criteria and raises alerts on violations"
    DTDFVocab:provides SafetyAlertInsight, OptimalityAlertInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Service that provides real‑time estimated state of the incubator"
    DTDFVocab:provides StateEstimateInsight
]

instance PredictionSimulationService : DTDFVocab:Service [
    base:desc "Service that executes predictive simulations reproducing PT behaviour under current operating conditions"
    DTDFVocab:provides PredictedTemperatureInsight
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Service that computes optimal control actions to reach target temperature efficiently"
    DTDFVocab:provides OptimisationAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service that detects faults by comparing sensor data with model predictions"
    DTDFVocab:provides FaultAlertInsight
]

// C17: Insights
instance DataIngestionInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data have been successfully ingested into the Digital Twin"
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Updated model parameters resulting from the calibration routine"
]

instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating violation of safety criteria (e.g., temperature exceeds safe limit)"
]

instance OptimalityAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating deviation from optimal operating condition (e.g., energy inefficiency)"
]

instance StateEstimateInsight : DTDFVocab:Insight [
    base:desc "Estimated current state of the incubator (temperature, heater power, etc.)"
]

instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory over a forecast horizon generated by simulation"
]

instance FaultAlertInsight : DTDFVocab:Insight [
    base:desc "Detected fault condition based on mismatch between measured and modelled temperatures"
]

// C17: Actions
instance OptimisationAction : DTDFVocab:Action [
    base:desc "Recommended adjustment of heater setpoint to achieve target temperature efficiently"
    DTDFVocab:IsAutomatic false
]

instance ModifyPhysicalTwinAction : DTDFVocab:Action [
    base:desc "Human operator executes control command to modify heater power in the Physical Twin"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin (or the controller component running on the Raspberry Pi) computes heating commands using a bang‑bang control strategy: when the measured temperature falls below a lower set‑point it commands the heat‑bed on, and when it exceeds an upper set‑point it commands it off; similarly, the fan is driven to distribute heat. Commands are issued as binary on/off signals through the Pi’s GPIO pins, which drive MOSFET switches and optocouplers to isolate the high‑power heat‑bed and fan circuits. The command format is a simple digital level (high/low). Validation is limited to the controller’s internal logic; acknowledgement of command execution is inferred from subsequent sensor readings. No explicit authentication, conflict‑resolution, or feedback protocol beyond the sensor loop is documented."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The incubator Digital Twin uses a RabbitMQ message broker for synchronization between the physical sensors and the cyber components. A low‑level driver periodically reads temperature data from the two internal sensors and the external sensor and publishes these readings over RabbitMQ to the controller and calibration algorithms. Although exact sampling frequencies are not specified, the architecture relies on a regular polling loop that defines the temporal granularity of data acquisition and the latency is limited to the message‑passing delay of the broker."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT follows a three‑layer architecture deployed on the Raspberry Pi: (1) a low‑level driver that directly interfaces with the heat‑bed, fan and temperature sensors; (2) a RabbitMQ communication server that provides message‑based integration, synchronization, and decoupling between components; (3) a higher‑level controller that hosts calibration, monitoring, and optimisation algorithms and updates the cyber models of the CPS and its environment. This arrangement links the physical plant (insulated box, heat‑bed, fan) to the digital twin via the driver and broker, constituting a CPS‑based digital twin constellation as shown in the schematic overview."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by continuous calibration algorithms that adjust model parameters using the latest sensor measurements, providing the best‑estimate of the physical twin’s state. Validation is performed by monitors that compare model predictions against live sensor data to detect safety or optimality violations. When discrepancies are identified, the system can trigger re‑calibration or human‑in‑the‑loop corrective actions, constituting an error‑detection and correction mechanism. The description does not enumerate explicit uncertainty quantification methods, but the reliance on best‑estimate parameter updates implies an implicit handling of measurement uncertainty."
]