// C3: Physical sensing components
instance InternalAirTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital temperature sensor (‑55 °C to +125 °C, 0.5 °C accuracy) measuring internal air temperature of the incubator"
    DTDFVocab:producedData InternalAirTempDataTx1
]

instance InternalAirTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital temperature sensor (‑55 °C to +125 °C, 0.5 °C accuracy) measuring internal air temperature of the incubator (second sensor for redundancy)"
    DTDFVocab:producedData InternalAirTempDataTx2
]

instance AmbientRoomTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital temperature sensor (‑55 °C to +125 °C, 0.5 °C accuracy) measuring ambient room temperature outside the incubator"
    DTDFVocab:producedData AmbientRoomTempDataTx
]

// C4: Physical‑to‑virtual interaction (data transmitted)
instance InternalAirTempDataTx1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalAirTempSensor1
]

instance InternalAirTempDataTx2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalAirTempSensor2
]

instance AmbientRoomTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientRoomTempSensor
]

// C10: Data (temperature readings)
instance InternalAirTemperature1 : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from internal air sensor 1"
    DTDFVocab:fromData InternalAirTempDataTx1
    DTDFVocab:inputTo EnablerRabbitMQBroker, EnablerSciPyOptimizer
]

instance InternalAirTemperature2 : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from internal air sensor 2"
    DTDFVocab:fromData InternalAirTempDataTx2
    DTDFVocab:inputTo EnablerRabbitMQBroker, EnablerSciPyOptimizer
]

instance AmbientRoomTemperature : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from ambient room sensor"
    DTDFVocab:fromData AmbientRoomTempDataTx
    DTDFVocab:inputTo EnablerRabbitMQBroker, EnablerSciPyOptimizer
]

// C11: Enablers
instance EnablerRabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker hosted on the Raspberry Pi that receives sensor messages and forwards them to DT services"
    DTDFVocab:enables ServiceRealTimeMonitoring,
                    ServiceSafetyOptimalityCheck,
                    ServiceDataLoggingVisualization
]

instance EnablerSciPyOptimizer : DTDFVocab:Enabler [
    base:desc "SciPy non‑linear least‑squares optimization routine used for model calibration"
    DTDFVocab:enables ServiceModelCalibration
]

instance EnablerPythonController : DTDFVocab:Enabler [
    base:desc "Python controller (low‑level driver abstraction layer) that runs simulation models and can command actuators via GPIO"
    DTDFVocab:enables ServiceSimulationModelA,
                    ServiceSimulationModelB
]

// C6: Services
instance ServiceRealTimeMonitoring : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature values streaming from the incubator"
    DTDFVocab:provides InsightTemperatureMonitoring
]

instance ServiceSafetyOptimalityCheck : DTDFVocab:Service [
    base:desc "Safety and optimality checks that generate alerts when temperature deviates from predefined limits"
    DTDFVocab:provides InsightTemperatureDeviationAlert
]

instance ServiceDataLoggingVisualization : DTDFVocab:Service [
    base:desc "Data logging and visualisation for post‑run analysis"
    DTDFVocab:provides InsightDataVisualization
]

instance ServiceModelCalibration : DTDFVocab:Service [
    base:desc "Model calibration using non‑linear least‑squares optimisation (SciPy) on experimental temperature trajectories"
    DTDFVocab:provides InsightCalibratedModelParameters
]

instance ServiceSimulationModelA : DTDFVocab:Service [
    base:desc "Simulation of Model A (energy balance with thermal capacity C_air and heat‑loss coefficient G_box)"
    DTDFVocab:provides InsightSimulationResultA
]

instance ServiceSimulationModelB : DTDFVocab:Service [
    base:desc "Simulation of Model B (adds heater capacity C_heater and heat‑transfer coefficient G_heater to Model A)"
    DTDFVocab:provides InsightSimulationResultB
]

// C17: Insights / Actions
instance InsightTemperatureMonitoring : DTDFVocab:Insight [
    base:desc "Current temperature state of the incubator for operator awareness"
]

instance InsightTemperatureDeviationAlert : DTDFVocab:Insight [
    base:desc "Alert generated when temperature exceeds safety limits"
]

instance InsightDataVisualization : DTDFVocab:Insight [
    base:desc "Visualization of logged temperature data for analysis"
]

instance InsightCalibratedModelParameters : DTDFVocab:Insight [
    base:desc "Calibrated free parameters for Model A and Model B obtained from optimisation"
]

instance InsightSimulationResultA : DTDFVocab:Insight [
    base:desc "Predicted air temperature trajectory from Model A"
]

instance InsightSimulationResultB : DTDFVocab:Insight [
    base:desc "Predicted air temperature trajectory from Model B"
]

instance ActionControlAdjustmentRecommendation : DTDFVocab:Action [
    base:desc "Recommendation to modify heating duration or waiting time to keep temperature within optimal range"
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed element (≈214 × 214 × 3 mm) switched on/off via MOSFET driver on the PCB"
]

instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "12‑24 V fan circulating air inside the incubator, controlled through MOSFET driver on the PCB"
]

// Environment and physical components
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InsulatedPolystyreneBox,
                HeatBedElement,
                InternalFan,
                PCBControllerBoard,
                RaspberryPi4,
                PowerSupplyUnit,
                MOSFETSwitches,
                OptocouplerIsolation,
                InternalAirTempSensor1,
                InternalAirTempSensor2,
                AmbientRoomTempSensor
]

instance InsulatedPolystyreneBox : DTDFVocab:Component [
    base:desc "Insulated polystyrene (styrofoam) box with ≈0.03 m³ internal air volume"
]

instance HeatBedElement : DTDFVocab:Component [
    base:desc "Resistive heating element (≈214 mm × 214 mm × 3 mm) providing thermal input to the air"
]

instance InternalFan : DTDFVocab:Component [
    base:desc "12‑24 V fan that circulates air inside the incubator"
]

instance PCBControllerBoard : DTDFVocab:Component [
    base:desc "Custom PCB hosting MOSFET switches (≈4 A) and optocouplers for isolation, interfaced to the Raspberry Pi GPIO"
]

instance RaspberryPi4 : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running the low‑level driver, controller logic and RabbitMQ broker"
]

instance PowerSupplyUnit : DTDFVocab:Component [
    base:desc "Dedicated power supply providing the required voltage/current for heater, fan and electronics"
]

instance MOSFETSwitches : DTDFVocab:Component [
    base:desc "MOSFET drivers on the PCB used to switch the heat‑bed and fan on/off"
]

instance OptocouplerIsolation : DTDFVocab:Component [
    base:desc "Optocouplers on the PCB ensuring electrical isolation between Raspberry Pi GPIO and power stage"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (heat‑bed ON/OFF, fan ON/OFF, waiting durations) are sent from DT components to the Raspberry Pi via RabbitMQ; the low‑level driver receives the commands and actuates the MOSFET switches to affect the heat‑bed and fan."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture comprises the Physical Twin (box, heat‑bed, fan, sensors, PCB), a controller on the Raspberry Pi, a low‑level driver, a RabbitMQ communication server, and external DT components that subscribe to sensor data, run the simulation models, perform calibration, and publish actuator commands. The DT components can be distributed but share the same message broker."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity relies on four explicit assumptions (uniform temperature, negligible wall heat storage, constant air specific heat, negligible heat loss to fan). Validity is assessed through uniform‑temperature experiments (fan on, temperature discrepancy ≤7 °C) and calibration error minimisation. The calibrated parameters are obtained only when the residual error becomes sufficiently small."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses RabbitMQ (AMQP over TCP/IP). The Raspberry Pi provides Wi‑Fi and Bluetooth connectivity, enabling networked message exchange. GPIO signals are isolated via MOSFETs and optocouplers for safe physical actuation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ broker and the controller software are deployed on the Raspberry Pi itself (on‑premises). Additional DT services (model simulation, calibration) can run on any computer that connects to the same RabbitMQ server."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver implements a safe‑state protocol and uses optocouplers to electrically isolate control signals, reducing risk of accidental actuator activation. The DT monitors for safety violations and can halt operation, but detailed security standards are not described."
]