// C3: Physical sensing components
instance TemperatureSensorInside1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer inside the incubator box, range -55°C to +125°C, 0.5°C accuracy"
    DTDFVocab:producedData TemperatureDataTxInside1
]

instance TemperatureSensorInside2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer inside the incubator box (second sensor), range -55°C to +125°C, 0.5°C accuracy"
    DTDFVocab:producedData TemperatureDataTxInside2
]

instance TemperatureSensorOutside : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer mounted outside the incubator, range -55°C to +125°C, 0.5°C accuracy"
    DTDFVocab:producedData TemperatureDataTxOutside
]

// C4: Physical‑to‑virtual interaction (data transmitted)
instance TemperatureDataTxInside1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorInside1
]

instance TemperatureDataTxInside2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorInside2
]

instance TemperatureDataTxOutside : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorOutside
]

// C10: Data produced from sensors
instance TemperatureDataInside1 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from inside sensor 1"
    DTDFVocab:fromData TemperatureDataTxInside1
    DTDFVocab:inputTo RabbitMQBroker
]

instance TemperatureDataInside2 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from inside sensor 2"
    DTDFVocab:fromData TemperatureDataTxInside2
    DTDFVocab:inputTo RabbitMQBroker
]

instance TemperatureDataOutside : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from outside sensor"
    DTDFVocab:fromData TemperatureDataTxOutside
    DTDFVocab:inputTo RabbitMQBroker
]

// C10: Calibration data set (aggregated)
instance CalibrationDataSet : DTDFVocab:Data [
    base:desc "Aggregated calibration data set: time‑stamped temperature readings from the three DS18S20 sensors and measured power input (V·I·Δt)"
    DTDFVocab:fromData TemperatureDataTxInside1, TemperatureDataTxInside2, TemperatureDataTxOutside
    DTDFVocab:inputTo SciPyOptimizer
]

// C11: Enablers (tooling)
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker using AMQP protocol over the Raspberry Pi network interface"
    DTDFVocab:enables RealTimeMonitoring, SafetyChecking, ModelCalibration, PredictiveSimulation, ParameterUpdate
]

instance SciPyOptimizer : DTDFVocab:Enabler [
    base:desc "Python SciPy optimisation library for non‑linear least‑squares parameter estimation"
    DTDFVocab:enables ModelCalibration
]

// C6: Services
instance RealTimeMonitoring : DTDFVocab:Service [
    base:desc "Real‑time temperature monitoring service for the incubator"
    DTDFVocab:provides TemperatureTrendInsight
]

instance SafetyChecking : DTDFVocab:Service [
    base:desc "Safety/optimality checking service that generates alerts when temperature exceeds defined limits"
    DTDFVocab:provides TemperatureSafetyAlert
]

instance ModelCalibration : DTDFVocab:Service [
    base:desc "Model calibration service employing non‑linear least‑squares via SciPy"
    DTDFVocab:provides CalibrationInsight, ParameterUpdateAction
]

instance PredictiveSimulation : DTDFVocab:Service [
    base:desc "Predictive simulation service that forecasts box temperature using calibrated thermal models"
    DTDFVocab:provides PredictiveTemperatureInsight
]

instance ParameterUpdate : DTDFVocab:Service [
    base:desc "Parameter‑update service that stores calibrated model parameters in the digital twin"
    DTDFVocab:provides ParameterStoredInsight
]

// C17: Insights
instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Current temperature trend derived from live sensor data"
]

instance TemperatureSafetyAlert : DTDFVocab:Insight [
    base:desc "Alert indicating that temperature has exceeded the safety threshold"
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Result of calibration updating thermal model parameters (C_air, G_box, C_heater, G_heater, etc.)"
]

instance PredictiveTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted future temperature trajectory generated by the thermal model"
]

instance ParameterStoredInsight : DTDFVocab:Insight [
    base:desc "Confirmation that calibrated parameters have been stored in the digital twin"
]

// C2: Acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed actuator (ON/OFF) driven via MOSFET driver circuit with optocouplers"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan actuator (ON/OFF or voltage‑controlled) driven via MOSFET driver circuit with optocouplers"
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Dynamic thermal Model A with air thermal capacity C_air and heat‑loss conductance G_box"
    DTDFVocab:inputTo SciPyOptimizer
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Dynamic thermal Model B extending Model A with heat‑bed capacity C_heater and conductance G_heater"
    DTDFVocab:inputTo SciPyOptimizer
]

// C17: Action
instance ParameterUpdateAction : DTDFVocab:Action [
    base:desc "Automatic update of digital twin model parameters after successful calibration"
    DTDFVocab:IsAutomatic true
]

// C13: Additional hardware components
instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B controller providing GPIO and running the low‑level driver software"
]

instance MOSFETDriverCircuit : DTDFVocab:Component [
    base:desc "MOSFET driver circuit with optocouplers used for heat‑bed and fan actuation"
]

// C14: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensorInside1, TemperatureSensorInside2, TemperatureSensorOutside,
               HeatBedActuator, FanActuator, RaspberryPiController, MOSFETDriverCircuit
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin sends control commands (heat‑bed ON/OFF, fan ON/OFF or voltage setting) to the Raspberry Pi via RabbitMQ; the controller consumes these messages and drives the actuators through GPIO pins and the MOSFET/optocoupler circuit."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture comprises the Physical Twin (hardware), a low‑level driver layer, a RabbitMQ communication server on the Raspberry Pi, and DT components (model calibrator, monitor, simulator) that subscribe to RabbitMQ topics. The controller bridges PT and DT, enabling bidirectional message flow."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated through assumptions (uniform temperature, negligible wall heat storage, constant air specific heat, heat‑bed power conversion). Validation experiments test temperature uniformity (max deviation 6–7 °C) and calibrate model parameters against measured temperature trajectories, providing uncertainty assessment of the calibrated parameters."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses the AMQP protocol implemented by RabbitMQ over TCP/IP; the Raspberry Pi provides Wi‑Fi/Bluetooth connectivity for network access."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "RabbitMQ and the controller software are hosted on the Raspberry Pi 4 Model B. Additional DT components (e.g., calibrator, monitor) are described as listeners to the broker but their deployment location is not specified; they may run on the same Pi or on any external machine that can connect to the broker."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe‑protocol to keep the hardware in a safe state on communication failures; the DT includes monitoring of temperature limits to ensure safe operation, and control commands are mediated through the controller to prevent unsafe actuation."
]