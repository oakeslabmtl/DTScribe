// C2: Acting Components
instance PhysicalTwinSensorNetwork : DTDFVocab:SensingComponent [
    base:desc "Network of sensors continuously gathering data from the Physical Twin."
    DTDFVocab:producedData PTDataTransmission
]

// C4: Physical-to-virtual interaction
instance PTDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalTwinSensorNetwork
]

// C10: Models/Data
instance PhysicalTwinData : DTDFVocab:Data [
    base:desc "Continuous sensor data streams from the Physical Twin received via PTDataTransmission."
    DTDFVocab:fromData PTDataTransmission
    DTDFVocab:inputTo CalibrationAlgorithmEnabler
]

instance CADGeometricModel : DTDFVocab:Model [
    base:desc "Geometric representation of the asset using CAD models."
    DTDFVocab:inputTo CalibrationAlgorithmEnabler
]

instance DynamicsBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral dynamics model represented by differential equations."
    DTDFVocab:inputTo CalibrationAlgorithmEnabler
]

instance AnalyticalRelationsModel : DTDFVocab:Model [
    base:desc "Analytical relationships between cyber and physical aspects of the twin."
    DTDFVocab:inputTo CalibrationAlgorithmEnabler
]

// C11: Enablers
instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm enabler that adjusts model parameters to best match incoming data."
    DTDFVocab:enables CalibrationService, MonitoringService, OptimizationService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that calibrates the DT models by adjusting parameters to match observed data."
    DTDFVocab:provides CalibrationResultInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that evaluates safety and performance criteria using calibrated models."
    DTDFVocab:provides PerformanceMetricsInsight, AnomalyAlertInsight, ConfidenceScoreInsight, RiskAssessmentInsight, FaultDetectionAction, StateEstimationAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that computes parameter adjustments to elevate efficiency or reduce costs."
    DTDFVocab:provides OptimizedOperationalParametersInsight, OptimizationAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that executes real-time numerical simulations replicating the twin's operational dynamics."
    DTDFVocab:provides SimulationResultInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Service that forecasts the twin's future behavior under prevailing conditions."
    DTDFVocab:provides PredictionForecastInsight
]

// C17: Insights/Actions
instance CalibrationResultInsight : DTDFVocab:Insight [
    base:desc "Insight indicating updated model parameters after calibration."
]

instance PerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Insight providing performance metrics of the system."
]

instance AnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Insight alerting stakeholders of detected anomalies."
]

instance ConfidenceScoreInsight : DTDFVocab:Insight [
    base:desc "Insight expressing algorithmic confidence scores for recommendations."
]

instance RiskAssessmentInsight : DTDFVocab:Insight [
    base:desc "Insight providing risk assessment of system states."
]

instance FaultDetectionAction : DTDFVocab:Action [
    base:desc "Action enabling operators to respond to fault detections."
    DTDFVocab:IsAutomatic false
]

instance StateEstimationAction : DTDFVocab:Action [
    base:desc "Action providing real-time state estimation to operators."
    DTDFVocab:IsAutomatic false
]

instance OptimizationAction : DTDFVocab:Action [
    base:desc "Action applying optimized operational parameters to the Digital Twin."
    DTDFVocab:IsAutomatic true
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight providing real-time simulation results of the Digital Twin."
]

instance PredictionForecastInsight : DTDFVocab:Insight [
    base:desc "Insight forecasting future behavior of the twin under current conditions."
]

instance OptimizedOperationalParametersInsight : DTDFVocab:Insight [
    base:desc "Insight providing optimized operational parameters derived from optimization algorithms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system orchestrates sensor data ingestion, model calibration, monitoring, and decision making. Data collected from the physical twin through sensors feeds calibration algorithms that continuously update cyber‑physical and environmental models. The updated models then feed a monitoring component that evaluates safety and optimality against predefined thresholds. When violations are detected, a human operator or supervisory algorithm can intervene to modify the physical twin. The overall architecture thus implements a continuous feedback loop between data, models, and decision logic, aligning computational effort with the real‑time behavior of the system, although specific resource management mechanisms are not detailed in the document."
]