// -------------------------------------------------------------
// Physical Sensing Components
// -------------------------------------------------------------
instance InternalAirTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "First temperature sensor monitoring internal air temperature of the styrofoam‑insulated incubator box."
    DTDFVocab:producedData InternalAirTempDataTransmitted1
]

instance InternalAirTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second temperature sensor monitoring internal air temperature of the styrofoam‑insulated incubator box."
    DTDFVocab:producedData InternalAirTempDataTransmitted2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring ambient temperature outside the incubator box."
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// -------------------------------------------------------------
// Data Transmission (Physical‑to‑Virtual Interaction)
// -------------------------------------------------------------
instance InternalAirTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalAirTempSensor1
]

instance InternalAirTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalAirTempSensor2
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// -------------------------------------------------------------
// Raw Data extracted from transmissions
// -------------------------------------------------------------
instance InternalAirTempData1 : DTDFVocab:Data [
    base:desc "Raw temperature reading from InternalAirTempSensor1."
    DTDFVocab:fromData InternalAirTempDataTransmitted1
    DTDFVocab:inputTo RabbitMQBroker
]

instance InternalAirTempData2 : DTDFVocab:Data [
    base:desc "Raw temperature reading from InternalAirTempSensor2."
    DTDFVocab:fromData InternalAirTempDataTransmitted2
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Raw temperature reading from AmbientTempSensor."
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

// -------------------------------------------------------------
// Acting Components (Actuators)
// -------------------------------------------------------------
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed used to raise temperature inside the incubator box."
]

instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal fan circulating air within the insulated styrofoam box."
]

// -------------------------------------------------------------
// Models
// -------------------------------------------------------------
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical temperature prediction model (Model A) with two free parameters derived from a basic energy‑balance equation."
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Higher‑fidelity analytical temperature prediction model (Model B) with four free parameters that accounts for heat‑bed thermal inertia."
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine
]

// -------------------------------------------------------------
// Enablers (Tools & Algorithms)
// -------------------------------------------------------------
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker that transports sensor readings and actuator commands between physical twin and digital twin components."
    DTDFVocab:enables RealTimeVisualizationService, ModelCalibrationService, AnomalyDetectionService, WhatIfSimulationService, SelfAdaptationService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "On‑demand calibration routine that updates parameters of Model B (and Model A) by comparing measured temperature data with model outputs."
    DTDFVocab:enables ModelCalibrationService
]

instance KalmanFilterEngine : DTDFVocab:Enabler [
    base:desc "Kalman filter that fuses temperature measurements with Model B predictions to estimate heat‑bed state and detect anomalies."
    DTDFVocab:enables AnomalyDetectionService
]

instance CoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation platform that replays historical or live PT data to evaluate alternative controller parameters (what‑if analysis)."
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationEngine : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop that detects behavioural changes, schedules experiments, re‑calibrates Model B, updates the Kalman filter, runs predictive simulations and re‑configures the controller."
    DTDFVocab:enables SelfAdaptationService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Time‑series database and dashboard that store controller/driver messages and render real‑time visualisations."
    DTDFVocab:enables RealTimeVisualizationService
]

// -------------------------------------------------------------
// Services
// -------------------------------------------------------------
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of incubator status by streaming messages into a time‑series database and displaying them on a dashboard."
    DTDFVocab:provides InsightVisualization
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Executes on‑demand calibration of thermal models using the latest sensor data."
    DTDFVocab:provides ActionCalibrateModelB
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Detects anomalies and estimates heat‑bed state using a Kalman filter applied to Model B together with measured data."
    DTDFVocab:provides InsightAnomalyDetection
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Runs what‑if simulations via co‑simulation that replay PT data to evaluate alternative controller settings."
    DTDFVocab:provides InsightWhatIfSimulation
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Runs the self‑adaptation loop that adapts the controller based on detected behavioural changes."
    DTDFVocab:provides ActionReconfigureController
]

// -------------------------------------------------------------
// Insights / Actions
// -------------------------------------------------------------
instance InsightVisualization : DTDFVocab:Insight [
    base:desc "Interactive dashboard visualising temperature trends, controller commands and actuator states in real time."
]

instance ActionCalibrateModelB : DTDFVocab:Action [
    base:desc "Automatic invocation of the calibration routine to adjust Model B parameters."
    DTDFVocab:IsAutomatic true
]

instance InsightAnomalyDetection : DTDFVocab:Insight [
    base:desc "Identification of deviations between measured temperatures and Model B predictions, including estimated heat‑bed temperature."
]

instance InsightWhatIfSimulation : DTDFVocab:Insight [
    base:desc "Predictive analysis of alternative controller configurations based on replayed PT data."
]

instance ActionReconfigureController : DTDFVocab:Action [
    base:desc "Re‑programs the Raspberry Pi bang‑bang controller with optimized parameters after self‑adaptation decisions."
    DTDFVocab:IsAutomatic true
]

// -------------------------------------------------------------
// Environment (Physical Twin Composition)
// -------------------------------------------------------------
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InternalAirTempSensor1, InternalAirTempSensor2, AmbientTempSensor,
                     HeatBedActuator, InternalFanActuator,
                     RaspberryPiController, LowLevelDriver
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi executing the bang‑bang control logic with configurable lower/upper limits, heating duration (H) and waiting duration (C)."
]

instance LowLevelDriver : DTDFVocab:Component [
    base:desc "Driver that reads sensors, publishes data via RabbitMQ, receives actuator commands, enforces safety protocol and forwards commands to hardware."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Virtual‑to‑physical interaction is performed by the controller running on the Raspberry Pi, which subscribes to command messages from the RabbitMQ communication server and forwards actuation commands for the fan and the heatbed to the low‑level driver. The controller also publishes its current control state back to RabbitMQ, enabling the physical twin to be driven according to the digital twin’s decisions."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The incubator Digital Twin follows a centralized orchestration pattern built around a RabbitMQ message broker. The physical twin (PT) is instrumented with a low‑level driver that reads temperature sensors and publishes measurement messages to RabbitMQ. A cyber component (the controller) subscribes to these messages, executes a bang‑bang control law, and publishes actuation commands (fan and heat‑bed on/off) back to the broker. Additional DT services—calibration algorithms, monitors, anomaly‑detection filters and visualization dashboards—listen to the same message streams, consume data, and optionally publish derived information (e.g., calibrated parameters, Kalman‑filter estimates). All cyber components run on a Raspberry Pi or associated host machines, and coordination is achieved through the shared RabbitMQ topic/queue infrastructure, allowing synchronous or asynchronous processing of data and commands."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is governed by four explicit assumptions: (1) uniform temperature distribution inside the box ensured by the fan, (2) negligible heat accumulation in box walls, (3) constant specific heat capacity of the enclosed air, and (4) the majority of electrical power is converted to heat for the air, ignoring heat absorbed by the heat‑bed and heat generated by the fan. Validity is evaluated by comparing Model A and Model B against experimental temperature traces, with Model B shown to more accurately capture the heat‑bed’s thermal inertia. Calibration procedures serve to quantify and reduce uncertainty in model parameters using the measured temperature data, thereby addressing the uncertainties introduced by the simplifying assumptions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection between the physical and cyber elements is based on a RabbitMQ message broker. RabbitMQ serves as the communication backbone; the low‑level driver, the controller and other DT modules connect to it using RabbitMQ’s standard messaging interface. The broker is described as mature, lightweight and easy to deploy on premises or in the cloud."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The documents state that the RabbitMQ communication server may be deployed either on‑premises or in a cloud environment, and that Digital Twin components (e.g., visualization dashboard, calibration engine) run on machines that can connect to this broker. No explicit details are given regarding computational or storage capacities, scalability mechanisms, deployment models (such as containers or virtual machines), or availability guarantees beyond the broker’s own capabilities."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is realized via the RabbitMQ message broker using the AMQP protocol. The low‑level driver and controller expose their telemetry and control interfaces as RabbitMQ messages, enabling other applications (e.g., dashboards, data‑logging services, or external analytics platforms) to subscribe to or publish on the same topics. No additional enterprise‑level standards or APIs are described; the DT relies exclusively on RabbitMQ for interoperability and data exchange with any external consumer that implements AMQP."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The incubator DT incorporates several safety mechanisms documented in the case study. The low‑level driver embeds a 'safe protocol' that enforces a safe state for the physical twin when abnormal conditions are detected. The DT includes runtime monitors that continuously evaluate sensor data against configured lower‑limit (LL) and upper‑limit (UL) temperature thresholds, flagging violations for human or automated intervention. Anomaly detection is performed by a Kalman‑filter‑based estimator that fuses measured sensor data with Model B to estimate the unmeasured heat‑bed temperature and to identify deviations from expected behavior. Calibration algorithms update model parameters in real time, and the DT framework can trigger reconfiguration of the controller when safety limits are breached. Communication between components uses RabbitMQ as a message broker, but no specific authentication or encryption mechanisms are described."
]