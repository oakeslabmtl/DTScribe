// C3: Physical sensing components
instance TimeSeriesPhysicalSensor : DTDFVocab:SensingComponent [
    base:desc "Collects time-series data from the physical twin via sensors located on the twin."
    DTDFVocab:producedData PhysicalSensorDataTransmission
]

// C4: Physical-to-virtual interaction
instance PhysicalSensorDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TimeSeriesPhysicalSensor
]

// C10: Models/Data
instance PhysicalSensorTimeSeriesData : DTDFVocab:Data [
    base:desc "Continuous time-series data stream originating from the physical sensor."
    DTDFVocab:fromData PhysicalSensorDataTransmission
    DTDFVocab:inputTo CalibrationAlgorithmEnabler
]

// C10: Models
instance GeometricModel : DTDFVocab:Model [
    base:desc "CAD model describing the macroscopic structure of the physical twin."
    DTDFVocab:inputTo CalibrationAlgorithmEnabler
]
instance BehavioralModel : DTDFVocab:Model [
    base:desc "Differential equation model capturing the dynamic response of the system."
    DTDFVocab:inputTo CalibrationAlgorithmEnabler
]

// C11: Enablers
instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Enables calibration algorithms that process historical and real‑time sensor data to update model parameters."
    DTDFVocab:enables RealTimeMonitoringService, SafetyPerformanceCheckService, CalibrationService, FaultDetectionService, SupervisoryControlService, StateEstimationService, OptimisationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of sensor data streams."
    DTDFVocab:provides SensorDataDashboardInsight
]
instance SafetyPerformanceCheckService : DTDFVocab:Service [
    base:desc "Performs safety and performance checks on the twin's operation."
    DTDFVocab:provides SafetyComplianceInsight
]
instance CalibrationService : DTDFVocab:Service [
    base:desc "Runs calibration algorithms that update CPS and environment models."
    DTDFVocab:provides CalibrationUpdateAction
]
instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults in the physical twin."
    DTDFVocab:provides FaultAlarmAction
]
instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Provides supervisory control commands."
    DTDFVocab:provides ControlCommandAction
]
instance StateEstimationService : DTDFVocab:Service [
    base:desc "Estimates the state of the physical twin."
    DTDFVocab:provides StateEstimateInsight
]
instance OptimisationService : DTDFVocab:Service [
    base:desc "Runs optimisation routines to improve system performance."
    DTDFVocab:provides OptimisationRecommendationAction
]

// C17: Insights
instance SensorDataDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time dashboard insight into the current sensor data streams."
]
instance SafetyComplianceInsight : DTDFVocab:Insight [
    base:desc "Insight indicating whether safety and performance checks are within acceptable limits."
]
instance StateEstimateInsight : DTDFVocab:Insight [
    base:desc "Insight providing the estimated state of the system."
]

// C17: Actions
instance CalibrationUpdateAction : DTDFVocab:Action [
    base:desc "Action to apply updated model parameters after calibration."
    DTDFVocab:IsAutomatic false
]
instance FaultAlarmAction : DTDFVocab:Action [
    base:desc "Action to trigger an alarm when a fault is detected."
    DTDFVocab:IsAutomatic true
]
instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Action to generate control commands for the physical twin."
    DTDFVocab:IsAutomatic true
]
instance OptimisationRecommendationAction : DTDFVocab:Action [
    base:desc "Action providing recommended system configuration changes to optimize performance."
    DTDFVocab:IsAutomatic false
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by calibration algorithms that continuously adjust model parameters based on live sensor data, thereby aligning the simulated behavior with observed physical twin behavior. Validation and verification are performed implicitly through monitors that compare simulated outputs with incoming sensor data to assess safety and optimality. When violations are detected, alarms or corrective directives can be issued to human operators or automatic control agents. The text does not specify formal uncertainty quantification, error correction procedures, or data quality assurance protocols beyond these monitoring mechanisms."
]