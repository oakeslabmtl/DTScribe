// ===============================
// Physical Sensing Components
// ===============================

instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor located inside the insulated styrofoam box (first sensor)."
    DTDFVocab:producedData InternalTempDataTransmittedA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor located inside the insulated styrofoam box (second sensor)."
    DTDFVocab:producedData InternalTempDataTransmittedB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor placed outside the styrofoam box to measure ambient temperature."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// ===============================
// Data Transmitted (Physical → Virtual)
// ===============================

instance InternalTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// ===============================
// Digital Twin Data Objects
// ===============================

instance InternalTemperatureDataA : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from the first internal sensor."
    DTDFVocab:fromData InternalTempDataTransmittedA
    DTDFVocab:inputTo DataIngestionEnabler, CalibrationAlgorithmEnabler, MonitoringAlgorithmEnabler
]

instance InternalTemperatureDataB : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from the second internal sensor."
    DTDFVocab:fromData InternalTempDataTransmittedB
    DTDFVocab:inputTo DataIngestionEnabler, CalibrationAlgorithmEnabler, MonitoringAlgorithmEnabler
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped ambient temperature reading from the external sensor."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo DataIngestionEnabler, CalibrationAlgorithmEnabler, MonitoringAlgorithmEnabler
]

// ===============================
// Physical Acting Components
// ===============================

instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed that provides heating power to raise the temperature inside the incubator."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan that distributes the heat generated by the heat‑bed throughout the insulated box."
]

// ===============================
// Enablers (Software/Infrastructure)
// ===============================

instance DataIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Low‑Level Driver that reads sensor values periodically, validates them and publishes them via RabbitMQ (AMQP) to DT components."
    DTDFVocab:enables SimulationPredictionService, ModelCalibrationService, TemperatureMonitoringService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Runtime engine that executes thermal simulation models to predict internal temperature dynamics."
    DTDFVocab:enables SimulationPredictionService
]

instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that consumes time‑series temperature data to estimate free parameters of the thermal models."
    DTDFVocab:enables ModelCalibrationService
]

instance MonitoringAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring algorithm that compares simulated temperature trajectories with measured data to detect safety or optimality violations."
    DTDFVocab:enables TemperatureMonitoringService
]

instance ControlActionEnabler : DTDFVocab:Enabler [
    base:desc "Control module that translates approved actions into commands for the heat‑bed and fan actuators."
    DTDFVocab:enables OptimisationDecisionService
]

// ===============================
// Models
// ===============================

instance ThermalDynamicsModelTwoParam : DTDFVocab:Model [
    base:desc "Analytical thermal dynamics model of the incubator with two free parameters."
    DTDFVocab:inputTo SimulationEngineEnabler, CalibrationAlgorithmEnabler
]

instance ThermalDynamicsModelFourParam : DTDFVocab:Model [
    base:desc "Analytical thermal dynamics model of the incubator with four free parameters, capturing heat‑bed inertia more accurately."
    DTDFVocab:inputTo SimulationEngineEnabler, CalibrationAlgorithmEnabler
]

// ===============================
// Services
// ===============================

instance SimulationPredictionService : DTDFVocab:Service [
    base:desc "Provides simulation‑based prediction of the incubator’s temperature dynamics under current operating conditions."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates thermal models by updating free parameters using streamed temperature measurements."
    DTDFVocab:provides ModelParameterInsight
]

instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Continuously monitors temperature safety and optimality, detecting violations by comparing measured and simulated data."
    DTDFVocab:provides SafetyViolationInsight
]

instance OptimisationDecisionService : DTDFVocab:Service [
    base:desc "Runs optimisation algorithms to decide corrective heating or fan actions for maintaining target temperature."
    DTDFVocab:provides TemperatureControlAction
]

// ===============================
// Insights & Actions
// ===============================

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted future temperature trajectory of the incubator derived from simulation models."
]

instance ModelParameterInsight : DTDFVocab:Insight [
    base:desc "Updated values of the free parameters for the thermal dynamics models after calibration."
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature safety or optimality violations based on deviation between measured and predicted temperatures."
]

instance TemperatureControlAction : DTDFVocab:Action [
    base:desc "Command to adjust heat‑bed power or fan speed in order to bring temperature back to the predefined set‑point."
    DTDFVocab:IsAutomatic true
]

// ===============================
// Environment (Physical Context)
// ===============================

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InternalTempSensorA, InternalTempSensorB, ExternalTempSensor, HeatBedActuator, FanActuator, RaspberryPiController
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Embedded Raspberry Pi that runs the plant controller, collects sensor data, issues actuator commands, and hosts the DT software stack."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin issues control commands (heat‑bed on/off and fan on/off) by publishing messages to the same RabbitMQ broker. The Controller, executed on a Raspberry Pi, listens to these messages, interprets parameters such as lower limit (LL), upper limit (UL), heating duration (H) and waiting duration (C), and drives the actuators. The Low‑Level Driver validates incoming commands using an embedded safe protocol before applying them to the physical actuators and acknowledges execution by publishing its control state back to the broker. Command messages are transmitted via AMQP; exact format is not specified."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT provides real-time visualization by continuously listening to controller and low-level driver messages, streaming the sensor data into a time-series database and updating a dashboard, thus operating on a continuous sub-second data ingestion and display loop."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT follows a modular orchestration where sensed data from the physical twin are fed to calibration algorithms that update physics-based models of the CPS and its environment; the updated models feed monitors that assess safety and optimality, and upon detection of violations a human operator or higher-level algorithm may issue commands back to the physical twin. This loop integrates data, models, and algorithms as illustrated in Figure 1 of Document 1."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the two thermal simulation models against experimental temperature data. The four‑parameter model showed higher fidelity by more accurately reproducing the heat‑bed’s thermal inertia. Model validation is performed through calibration experiments where sensor data are used to adjust model parameters, thereby reducing prediction error. Uncertainty sources such as sensor noise and model simplifications are implicitly considered during calibration, though explicit quantification methods are not detailed. The DT relies on these calibrated models for reliable prediction and control of the physical twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between all components (Physical Twin, controller, low‑level driver and DT modules) is realized through a RabbitMQ server acting as a central message broker. RabbitMQ uses the AMQP protocol over TCP/IP, deployed either on‑premise or in the cloud. The network topology is a hub‑and‑spoke model where each component connects as a client to the broker. The broker provides reliable message delivery, but bandwidth, latency requirements and explicit security mechanisms (e.g., TLS) are not described in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The controller runs on a Raspberry Pi (edge device) while the RabbitMQ broker can be hosted on‑premise or in the cloud, as stated. RabbitMQ is described as mature, lightweight and easy to deploy, supporting scalability to tens of thousands of users. No detailed computational, storage or deployment model (e.g., containerisation) is provided, nor are specific availability or redundancy strategies beyond the general reliability of RabbitMQ."
]