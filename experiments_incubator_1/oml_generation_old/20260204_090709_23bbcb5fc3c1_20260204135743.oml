// C10: Models/Data
instance GeometricModel : DTDFVocab:Model [
    base:desc "Abstract representation of physical attributes using CAD models focusing on structural and spatial dimensions of the Physical Twin."
    DTDFVocab:inputTo CADModelingEngine
]

instance BehavioralModel : DTDFVocab:Model [
    base:desc "Dynamic simulation model using differential equations to describe system behavior under forces, environmental interactions, or operational conditions."
    DTDFVocab:inputTo SimulationEngine
]

instance AnalyticalModel : DTDFVocab:Model [
    base:desc "Mathematical formulation for predictive analysis, fault detection, or optimization using physics-based or data-driven approaches."
    DTDFVocab:inputTo OptimizationEngine
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Continuous stream of real-time sensor data from the Physical Twin used for ongoing model updates and calibration."
    DTDFVocab:fromData EnvironmentalParameterDataTransmitted, OperationalMetricsDataTransmitted, CyberSystemStateDataTransmitted, PhysicalStateVariableDataTransmitted
    DTDFVocab:inputTo DataPreprocessingEngine, CalibrationAlgorithm
]

instance HistoricalOperationalData : DTDFVocab:Data [
    base:desc "Archived operational data used for baseline comparisons, trend analysis, and model calibration."
    DTDFVocab:fromData EventLogDataTransmitted
    DTDFVocab:inputTo TrendAnalysisEngine, ModelCalibrationEngine
]

instance CalibratedModelParameters : DTDFVocab:Data [
    base:desc "Updated model parameters derived from calibration algorithms using real-time sensor data to ensure model accuracy."
    DTDFVocab:fromData RealTimeSensorData
    DTDFVocab:inputTo ModelUpdateService
]

// C11: Enablers
instance OPCUAProtocol : DTDFVocab:Enabler [
    base:desc "Industrial communication protocol enabling high-frequency data transmission between sensors and the Digital Twin."
    DTDFVocab:enables DataTransmissionService
]

instance MQTTProtocol : DTDFVocab:Enabler [
    base:desc "Lightweight messaging protocol for low-latency communication of event-triggered data between Physical Twin and Digital Twin."
    DTDFVocab:enables EventDataService
]

instance ModbusProtocol : DTDFVocab:Enabler [
    base:desc "Industrial communication protocol for medium-frequency data transmission of cyber-system states."
    DTDFVocab:enables CyberSystemMonitoringService
]

instance DataPreprocessingEngine : DTDFVocab:Enabler [
    base:desc "Engine performing normalization, filtering, and validation of sensor data to ensure accuracy before incorporation into models."
