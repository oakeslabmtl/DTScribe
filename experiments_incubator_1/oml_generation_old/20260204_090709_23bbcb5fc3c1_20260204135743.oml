// C3: Physical Sensing Components
instance EnvironmentalParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor measuring environmental parameters such as temperature, pressure, and humidity from the Physical Twin for real-time operational monitoring."
