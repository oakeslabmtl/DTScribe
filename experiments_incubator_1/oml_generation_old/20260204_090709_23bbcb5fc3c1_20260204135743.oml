]

instance FaultDetectionAlgorithm : DTDFVocab:Enabler [
    base:desc "Algorithm employing rule-based systems or AI/ML models to identify anomalies or faults in the Physical Twin's operation."
    DTDFVocab:enables FaultDetectionService
]

instance StateEstimationEngine : DTDFVocab:Enabler [
    base:desc "Engine using state estimators to refine system understanding and validate model accuracy against real-time data."
