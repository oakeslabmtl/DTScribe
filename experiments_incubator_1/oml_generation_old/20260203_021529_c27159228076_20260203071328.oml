// C3: Physical sensing components
instance IncubatorInnerTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer measuring temperature inside the incubator (range –55 °C to +125 °C, accuracy ±0.5 °C)."
    DTDFVocab:producedData IncubatorInnerTempDataTrans1
]

instance IncubatorInnerTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer measuring temperature inside the incubator (range –55 °C to +125 °C, accuracy ±0.5 °C)."
    DTDFVocab:producedData IncubatorInnerTempDataTrans2
]

instance IncubatorAmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer measuring ambient room temperature (range –55 °C to +125 °C, accuracy ±0.5 °C)."
    DTDFVocab:producedData IncubatorAmbientTempDataTrans
]

// C4: Physical-to-virtual interaction
instance IncubatorInnerTempDataTrans1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInnerTempSensor1
]

instance IncubatorInnerTempDataTrans2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInnerTempSensor2
]

instance IncubatorAmbientTempDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorAmbientTempSensor
]

// C10: Data
instance IncubatorInnerTempData1 : DTDFVocab:Data [
    base:desc "Timestamped temperature measurement from IncubatorInnerTempSensor1."
    DTDFVocab:fromData IncubatorInnerTempDataTrans1
    DTDFVocab:inputTo RabbitMQBrokerEnabler, SciPyOptimizationEnabler
]

instance IncubatorInnerTempData2 : DTDFVocab:Data [
    base:desc "Timestamped temperature measurement from IncubatorInnerTempSensor2."
    DTDFVocab:fromData IncubatorInnerTempDataTrans2
    DTDFVocab:inputTo RabbitMQBrokerEnabler, SciPyOptimizationEnabler
]

instance IncubatorAmbientTempData : DTDFVocab:Data [
    base:desc "Timestamped ambient temperature measurement from IncubatorAmbientTempSensor."
    DTDFVocab:fromData IncubatorAmbientTempDataTrans
    DTDFVocab:inputTo RabbitMQBrokerEnabler, SciPyOptimizationEnabler
]

// C11: Enablers
instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker (AMQP) running on the Raspberry Pi; publishes sensor data and receives model updates."
    DTDFVocab:enables TemperatureSimulationService, ModelCalibrationService, SafetyMonitoringService, ParameterUpdateService
]

instance SciPyOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "SciPy library used for non‑linear least‑squares optimisation during real‑time model calibration."
    DTDFVocab:enables ModelCalibrationService
]

// C6: Services
instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Simulates internal incubator temperature using calibrated Model A and Model B."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Performs real‑time calibration of thermal models via non‑linear least‑squares optimisation (SciPy)."
    DTDFVocab:provides CalibratedParameterInsight
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Continuously monitors temperature for safety and optimality, issuing alerts on deviations."
    DTDFVocab:provides SafetyAlertInsight
]

instance ParameterUpdateService : DTDFVocab:Service [
    base:desc "Updates controller parameters and issues actuation commands based on calibrated models."
    DTDFVocab:provides HeatingBangBangAction, FanSpeedAdjustmentAction
]

// C17: Insights
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted internal temperature trajectory derived from calibrated Model A and Model B."
]

instance CalibratedParameterInsight : DTDFVocab:Insight [
    base:desc "Refined model parameters (C_air, G_box, C_heater, G_heater) obtained from real‑time calibration."
]

instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Safety/optimality alert indicating temperature exceeds predefined thresholds."
]

// C17: Actions
instance HeatingBangBangAction : DTDFVocab:Action [
    base:desc "Bang‑bang control action to switch the heat‑bed on or off based on setpoint and calibrated parameters."
    DTDFVocab:IsAutomatic true
]

instance FanSpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic fan speed adjustment via GPIO to maintain uniform temperature distribution."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET‑driven heat‑bed on/off power control for the incubator."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan speed control via Raspberry Pi GPIO to circulate air inside the incubator."
]

// Physical components
instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running low‑level driver, RabbitMQ client, and DT services."
]

instance InsulatedBoxComponent : DTDFVocab:Component [
    base:desc "Polystyrene insulated box (≈0.03 m³) housing the heat‑bed, sensors, and fan."
]

instance HeatBedElement : DTDFVocab:Component [
    base:desc "Heater element (214 mm × 214 mm × 3 mm) providing thermal energy to the incubator."
]

instance FanElement : DTDFVocab:Component [
    base:desc "12‑24 V fan delivering approx. 0.02 m³ s⁻¹ airflow for temperature uniformity."
]

instance PowerSupplyUnit : DTDFVocab:Component [
    base:desc "External power supply capable of ≥100 W for heater and fan operation."
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains RaspberryPiController, InsulatedBoxComponent, HeatBedActuator, FanActuator,
               HeatBedElement, FanElement, PowerSupplyUnit,
               IncubatorInnerTempSensor1, IncubatorInnerTempSensor2, IncubatorAmbientTempSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (heat‑bed ON/OFF, fan speed) to the same RabbitMQ broker; the controller subscribes, interprets the messages and issues actuation signals through the low‑level driver to the MOSFET/optocoupler interface."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized architecture where the Physical Twin components (sensors, actuators, controller) communicate via the low‑level driver to a RabbitMQ broker on the Raspberry Pi; DT modules (model simulator, calibrator, monitor) subscribe/publish to the broker, forming a closed loop between PT and DT."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle includes model design (creation of Model A and Model B), calibration (parameter identification using experimental temperature trajectories), deployment (RabbitMQ and DT services running on the Raspberry Pi), and operational monitoring during runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by explicit assumptions (uniform temperature, negligible wall heat, constant air specific heat, heat‑bed heat loss), validated through uniformity experiments (≤7 °C deviation across sensors) and calibration error minimisation via non‑linear least‑squares; Model B shows higher fidelity for heat‑bed inertia."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT is realized over the local network using RabbitMQ (AMQP protocol) running on the Raspberry Pi; messages are exchanged via TCP/IP between the controller, low‑level driver, and DT services."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT software (RabbitMQ broker, model simulators, calibration routine) is hosted on the Raspberry Pi 4 Model B that also runs the controller and low‑level driver."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the device in a safe state; the DT includes monitoring for safety violations and can halt actuation commands. Communication uses RabbitMQ, which provides user authentication and encryption options (though not explicitly detailed)."
]