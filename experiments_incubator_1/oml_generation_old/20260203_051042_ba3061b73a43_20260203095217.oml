// --------------------------------------------------
// Environment and Physical Components
// --------------------------------------------------
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains PolystyreneBox, ResistiveHeatBed, CirculationFan,
                  RaspberryPiController, CustomPCB, PowerSupply
]

instance PolystyreneBox : DTDFVocab:Component [
    base:desc "Polystyrene insulated box with ≈0.03 m³ air volume"
]

instance ResistiveHeatBed : DTDFVocab:Component [
    base:desc "Resistive heat‑bed capable of ≤100 W power, on/off actuator"
]

instance CirculationFan : DTDFVocab:Component [
    base:desc "Air‑circulation fan with airflow ≈0.02 m³ s⁻¹, turning box air over in ~2 s"
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running RabbitMQ broker and Python services"
]

instance CustomPCB : DTDFVocab:Component [
    base:desc "Custom PCB with MOSFET power stage and optocouplers to drive heater and fan"
]

instance PowerSupply : DTDFVocab:Component [
    base:desc "Dedicated power supply for heat‑bed, fan and controller"
]

// --------------------------------------------------
// Acting Components
// --------------------------------------------------
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "On/off control of the resistive heat‑bed via MOSFET driver"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "On/off control of the circulation fan via MOSFET driver"
]

// --------------------------------------------------
// Sensing Components
// --------------------------------------------------
instance IncubatorAirTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (±0.5 °C accuracy) placed inside incubator air volume"
    DTDFVocab:producedData AirTempDataTransmitted1
]

instance IncubatorAirTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (±0.5 °C accuracy) placed inside incubator air volume"
    DTDFVocab:producedData AirTempDataTransmitted2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (±0.5 °C accuracy) measuring ambient room temperature"
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// --------------------------------------------------
// Data Transmitted (Physical → Virtual)
// --------------------------------------------------
instance AirTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorAirTempSensor1
]

instance AirTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorAirTempSensor2
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// --------------------------------------------------
// Virtual Data Objects
// --------------------------------------------------
instance AirTemperatureData1 : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from internal sensor 1"
    DTDFVocab:fromData AirTempDataTransmitted1
    DTDFVocab:inputTo RabbitMQBroker
]

instance AirTemperatureData2 : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from internal sensor 2"
    DTDFVocab:fromData AirTempDataTransmitted2
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from ambient external sensor"
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

// --------------------------------------------------
// Physics‑Based Models
// --------------------------------------------------
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single‑energy‑balance model with parameters C_air and G_box"
    DTDFVocab:inputTo RabbitMQBroker
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Dual‑energy‑balance model with parameters C_air, C_heater, G_box, G_heater"
    DTDFVocab:inputTo RabbitMQBroker
]

// --------------------------------------------------
// Enablers (Tools & Middleware)
// --------------------------------------------------
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker on Raspberry Pi for inter‑process communication"
    DTDFVocab:enables SimulationService, CalibrationService,
                     MonitoringService, DecisionSupportService
]

instance SciPyLeastSquaresOptimizer : DTDFVocab:Enabler [
    base:desc "SciPy non‑linear least‑squares optimizer used for model parameter calibration"
    DTDFVocab:enables CalibrationService
]

instance PythonLowLevelDriver : DTDFVocab:Enabler [
    base:desc "Python driver library that reads DS18S20 sensors and publishes AMQP messages"
    DTDFVocab:enables MonitoringService
]

// --------------------------------------------------
// Services Provided by the Digital Twin
// --------------------------------------------------
instance SimulationService : DTDFVocab:Service [
    base:desc "Model‑based simulation of incubator box temperature using Model A and Model B"
    DTDFVocab:provides SimulationResultInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Parameter calibration of thermal models via SciPy non‑linear least‑squares optimizer"
    DTDFVocab:provides CalibratedParametersInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature limits (LL, UL) and detection of violations"
    DTDFVocab:provides TemperatureLimitViolationInsight, AlertOperatorAction
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Generates operational insights and recommended set‑point adjustments"
    DTDFVocab:provides SetpointAdjustmentInsight, AdjustSetpointAction
]

// --------------------------------------------------
// Insights
// --------------------------------------------------
instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Calibrated model parameters (C_air, G_box, C_heater, G_heater) obtained after optimisation"
]

instance TemperatureLimitViolationInsight : DTDFVocab:Insight [
    base:desc "Detected breach of lower or upper temperature limits"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory from simulation models"
]

instance SetpointAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Suggested heat‑bed set‑point changes to maintain target temperature"
]

// --------------------------------------------------
// Actions
// --------------------------------------------------
instance AlertOperatorAction : DTDFVocab:Action [
    base:desc "Send an alert to the operator when temperature limits are violated"
    DTDFVocab:IsAutomatic false
]

instance AdjustSetpointAction : DTDFVocab:Action [
    base:desc "Automatically adjust the heat‑bed set‑point based on DT recommendations"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT components send control commands (heat‑bed ON/OFF, fan ON/OFF, set‑point changes) as AMQP messages to the RabbitMQ server; the controller on the Raspberry Pi consumes these messages and actuates the heat‑bed and fan via the PCB drivers."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of the physical plant (box, heat‑bed, fan, sensors, PCB, controller) connected to a communication server (RabbitMQ) on the same Raspberry Pi. DT software components—model simulators, calibrator, monitor, and user interface—listen to and publish on RabbitMQ, forming a loosely coupled, message‑driven architecture."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the design stage (model creation for thermal dynamics), the manufacturing/implementation stage (hardware assembly, PCB, Raspberry Pi integration), and the operational stage (continuous data acquisition, model calibration, monitoring, and runtime prediction)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is based on four assumptions (uniform temperature, negligible wall heat, constant air specific heat, negligible fan heat). Validity is tested by uniformity experiments (temperature spread ≤7 °C) and by comparing Model A vs. Model B, where Model B better captures the heat‑bed thermal inertia. Calibration error minimisation provides quantitative validation of the parameters."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses the AMQP protocol over TCP/IP via the RabbitMQ server running locally on the Raspberry Pi. Messages are exchanged over the Pi's Ethernet/Wi‑Fi network interface; the 1‑Wire bus provides sensor data to the controller."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT services (RabbitMQ broker, low‑level driver, controller logic, model simulators, calibrator) are hosted on the same Raspberry Pi 4 hardware. The open‑source code repository contains the deployment scripts and configuration files for the Pi environment."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the device in a safe state, and the monitoring twin checks for violations of temperature limits (LL, UL). No explicit cybersecurity standards are mentioned."
]