// C3: Physical sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor located inside the incubator box to monitor internal air temperature.",
    DTDFVocab:producedData InternalTempDataTransmitted1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second temperature sensor inside the incubator box for redundancy and averaging.",
    DTDFVocab:producedData InternalTempDataTransmitted2
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor placed outside the incubator to record ambient room temperature.",
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance InternalTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// C10: Data (temperature measurements)
instance InternalTempData1 : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from internal sensor 1.",
    DTDFVocab:fromData InternalTempDataTransmitted1,
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, AnomalyDetectionEnabler, KalmanFilterEnabler, CoSimulationEngineEnabler, SelfAdaptationLoopEnabler
]

instance InternalTempData2 : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from internal sensor 2.",
    DTDFVocab:fromData InternalTempDataTransmitted2,
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, AnomalyDetectionEnabler, KalmanFilterEnabler, CoSimulationEngineEnabler, SelfAdaptationLoopEnabler
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from external ambient sensor.",
    DTDFVocab:fromData ExternalTempDataTransmitted,
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, AnomalyDetectionEnabler, KalmanFilterEnabler, CoSimulationEngineEnabler, SelfAdaptationLoopEnabler
]

// C2: Acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heating element (heat‑bed) that raises the temperature inside the incubator box."
]

instance AirCirculatingFan : DTDFVocab:ActingComponent [
    base:desc "Fan inside the incubator that distributes heated air uniformly."
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model A with two free parameters derived from Q = c·m·ΔT.",
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, AnomalyDetectionEnabler, KalmanFilterEnabler, CoSimulationEngineEnabler, SelfAdaptationLoopEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Analytical thermal model B with four free parameters (does not assume all electrical power converts to air heating).",
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, AnomalyDetectionEnabler, KalmanFilterEnabler, CoSimulationEngineEnabler, SelfAdaptationLoopEnabler
]

// C11: Enablers
instance RabbitMQMessageBroker : DTDFVocab:Enabler [
    base:desc "Asynchronous AMQP broker that transports sensor readings and actuator commands between components.",
    DTDFVocab:enables RealTimeVisualizationService, OnDemandCalibrationService, AnomalyDetectionService, WhatIfSimulationService, SelfAdaptationService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time‑series store that persists timestamped temperature data for dashboard rendering and historical analysis.",
    DTDFVocab:enables RealTimeVisualizationService
]

instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Algorithm that calibrates Model A and Model B parameters using the latest temperature data.",
    DTDFVocab:enables OnDemandCalibrationService
]

instance AnomalyDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Statistical routine that flags deviations between measured temperatures and model predictions.",
    DTDFVocab:enables AnomalyDetectionService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter that fuses live sensor data with Model B to estimate the unmeasured heat‑bed temperature.",
    DTDFVocab:enables StateEstimationService
]

instance CoSimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Co‑simulation engine that replays historical or live PT data to evaluate alternative controller settings.",
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationLoopEnabler : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop that orchestrates experiments, re‑calibration, filter update and controller re‑configuration.",
    DTDFVocab:enables SelfAdaptationService
]

instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard that visualizes sensor streams, model predictions and detected anomalies in real time.",
    DTDFVocab:enables RealTimeVisualizationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Streams sensor data and model outputs to a dashboard for real‑time incubator status monitoring.",
    DTDFVocab:provides TemperatureVisualizationInsight
]

instance OnDemandCalibrationService : DTDFVocab:Service [
    base:desc "Executes calibration routine on request, updating Model A and Model B parameters.",
    DTDFVocab:provides CalibrationInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Detects anomalies by comparing measured temperatures with model predictions.",
    DTDFVocab:provides AnomalyInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Estimates heat‑bed temperature using a Kalman filter that combines sensor data with Model B.",
    DTDFVocab:provides HeatBedStateInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Runs what‑if co‑simulations to evaluate alternative controller parameters using historical or live data.",
    DTDFVocab:provides SimulationInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Self‑adaptation loop that triggers experiments, re‑calibrates models, updates the Kalman filter, and re‑configures the controller.",
    DTDFVocab:provides AdaptiveControlAction
]

// C17: Insights
instance TemperatureVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides operators with a live view of internal and external temperature trends."
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Indicates the current calibrated parameter values for Model A and Model B."
]

instance AnomalyInsight : DTDFVocab:Insight [
    base:desc "Highlights temperature readings that deviate from model‑based expectations."
]

instance HeatBedStateInsight : DTDFVocab:Insight [
    base:desc "Estimates the unmeasured heat‑bed temperature for better control decisions."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Shows projected system behavior under alternative controller settings."
]

// C17: Actions
instance AdaptiveControlAction : DTDFVocab:Action [
    base:desc "Re‑configures the bang‑bang controller with new thresholds, heating duration and waiting duration.",
    DTDFVocab:IsAutomatic true
]

// Optional environment grouping
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InternalTempSensor1, InternalTempSensor2, ExternalTempSensor,
                 HeatBedActuator, AirCirculatingFan,
                 ThermalModelA, ThermalModelB
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the DT (or by the DT‑based controller) and sent via RabbitMQ to the low‑level driver. Command messages specify fan actuation (on/off) and heat‑bed parameters (heating duration H, waiting duration C, lower and upper temperature limits LL/UL). The low‑level driver validates each command against its built‑in safe protocol, acknowledges receipt, and executes the actuation on the physical twin. The controller also publishes its current state back to the broker, providing feedback for confirmation of command execution."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The incubator DT follows a centralized message‑bus architecture built around a RabbitMQ server (AMQP). The physical twin (PT) consists of temperature sensors and actuators (heatbed, fan) accessed by a low‑level driver that periodically reads sensor values and publishes them to RabbitMQ. The Raspberry‑Pi controller subscribes to the same broker to receive commands and to publish its control states. Digital‑twin services (real‑time visualisation dashboard, on‑demand calibration, Kalman‑filter based anomaly detection, what‑if co‑simulation) are implemented as separate components that also subscribe to the broker, thereby receiving PT data and issuing configuration or calibration commands. Coordination is achieved by message passing; calibration algorithms update model parameters which are then used by monitors and optimisers. Resource management relies on the RabbitMQ broker to route messages and on a time‑series database for persistence."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through two competing models: Model A assumes all supplied electrical power heats the air, whereas Model B relaxes this assumption to account for heatbed inertia, resulting in higher predictive accuracy as shown in calibration results (Figure 13). Validation is performed by comparing model outputs against measured temperature trajectories and by conducting calibration experiments (Section 3.3). Uncertainty sources include four explicit assumptions: uniform temperature distribution enforced by the fan, negligible wall heat storage, constant specific heat capacity of air, and near‑complete conversion of electrical power to heat (the latter omitted in Model B). Model verification uses the Kalman filter for state estimation and anomaly detection, providing error correction during runtime."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All DT components communicate through a RabbitMQ server using the AMQP protocol over TCP/IP. The architecture follows a publish‑subscribe pattern where the low‑level driver and controller publish sensor and state topics, and DT services subscribe to them. RabbitMQ is described as a mature, lightweight, and easy‑to‑deploy message broker that can run on‑premise or in the cloud, offering reliable message delivery; specific bandwidth, latency, or security protocol details are not provided in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The controller and low‑level driver are hosted on a Raspberry Pi attached to the incubator. RabbitMQ, the central communication backbone, can be deployed either on‑premise or in the cloud as mentioned in the documents. DT services such as visualisation dashboards, calibration modules, and anomaly detection run as separate software components that connect to the broker. The documents do not specify exact computational or storage requirements, scalability mechanisms, or detailed availability/reliability assurances beyond the inherent reliability of RabbitMQ."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is realised through the RabbitMQ message broker using the AMQP protocol, which enables the DT components to listen to controller and driver messages. Sensor data are forwarded to a time‑series database and visualised on a web‑based dashboard. Calibration and anomaly‑detection services are invoked on‑demand via messages, and co‑simulation tools can ingest real‑time or historical data through the same broker, allowing interoperability with external simulation environments and enterprise data stores. The open‑source hardware and software repository on GitHub provides further access for external developers."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Incubator DT incorporates safety measures through a 'safe protocol' embedded in the low‑level driver, which periodically reads temperature data, validates incoming commands from the controller, and ensures the physical twin remains in a safe state before forwarding commands. Communication between the controller, low‑level driver, and other DT components is performed via a RabbitMQ message broker, providing reliable message delivery, though the documents do not specify authentication, encryption, or access‑control mechanisms for the broker."
]