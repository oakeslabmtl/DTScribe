// C2: Acting Components
instance HeatbedHeaterActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed providing controllable heating power, driven by the Raspberry Pi controller"
]
instance CirculationFanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan that distributes heat inside the insulated styrofoam box, driven by the Raspberry Pi controller"
]

// C3: Physical sensing components
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor placed at the first internal location of the incubator box"
    DTDFVocab:producedData InternalTempDataMessageA
]
instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor placed at the second internal location of the incubator box"
    DTDFVocab:producedData InternalTempDataMessageB
]
instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor placed outside the incubator box for ambient temperature measurement"
    DTDFVocab:producedData ExternalTempDataMessage
]

// C4: Physical-to-virtual interaction – Data transmitted via RabbitMQ
instance InternalTempDataMessageA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
    base:desc "Numeric temperature reading with timestamp from InternalTempSensorA, published to RabbitMQ"
]
instance InternalTempDataMessageB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
    base:desc "Numeric temperature reading with timestamp from InternalTempSensorB, published to RabbitMQ"
]
instance ExternalTempDataMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
    base:desc "Numeric temperature reading with timestamp from ExternalTempSensor, published to RabbitMQ"
]

// C5: Data objects derived from transmitted messages
instance InternalTemperatureDataA : DTDFVocab:Data [
    base:desc "Processed temperature data stream from InternalTempSensorA used for modelling and monitoring"
    DTDFVocab:fromData InternalTempDataMessageA
    DTDFVocab:inputTo CalibrationEngine, PredictionEngine, SafetyMonitorEngine
]
instance InternalTemperatureDataB : DTDFVocab:Data [
    base:desc "Processed temperature data stream from InternalTempSensorB used for modelling and monitoring"
    DTDFVocab:fromData InternalTempDataMessageB
    DTDFVocab:inputTo CalibrationEngine, PredictionEngine, SafetyMonitorEngine
]
instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Processed temperature data stream from ExternalTempSensor used for modelling and monitoring"
    DTDFVocab:fromData ExternalTempDataMessage
    DTDFVocab:inputTo CalibrationEngine, PredictionEngine, SafetyMonitorEngine
]

// C10: Models
instance TwoParamThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model of the incubator with two free parameters"
    DTDFVocab:inputTo PredictionEngine, SafetyMonitorEngine
]
instance FourParamThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model of the incubator with four free parameters (captures heat‑bed inertia more accurately)"
    DTDFVocab:inputTo PredictionEngine, SafetyMonitorEngine
]

// C11: Enablers (algorithms / tools)
instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that continuously updates model parameters using the three temperature data streams"
    DTDFVocab:enables CalibrationService
]
instance PredictionEngine : DTDFVocab:Enabler [
    base:desc "Prediction engine that runs the calibrated thermal models to forecast temperature trajectories"
    DTDFVocab:enables PredictiveSimulationService
]
instance SafetyMonitorEngine : DTDFVocab:Enabler [
    base:desc "Safety monitor that evaluates real‑time temperature against target bounds and model predictions"
    DTDFVocab:enables SafetyMonitoringService
]
instance OptimizationEngine : DTDFVocab:Enabler [
    base:desc "Optimization component that selects heater power and fan speed set‑points to achieve the temperature target efficiently"
    DTDFVocab:enables OptimizationSupportService
]
instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Visualization tool that renders predicted temperature trajectories and current sensor readings for operators"
    DTDFVocab:enables VisualizationService
]
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ server that transports sensor messages from the Raspberry Pi driver to DT components"
    DTDFVocab:enables RealTimeMonitoringService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that performs continuous calibration of the two thermal models"
    DTDFVocab:provides ModelCalibrationInsight
]
instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Service that delivers real‑time predictions of incubator temperature based on calibrated models"
    DTDFVocab:provides TemperatureForecastInsight
]
instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Service that detects violations of temperature limits (over‑/under‑heat) and raises alerts"
    DTDFVocab:provides TemperatureViolationInsight, AutomaticHeaterAdjustmentAction, AutomaticFanAdjustmentAction
]
instance OptimizationSupportService : DTDFVocab:Service [
    base:desc "Service that suggests optimal heater power and fan speed to maintain target temperature with minimal energy"
    DTDFVocab:provides AutomaticHeaterAdjustmentAction, AutomaticFanAdjustmentAction, ManualOperatorAdjustmentAction
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that visualises current and forecasted temperature data for operators"
    DTDFVocab:provides TemperatureVisualizationInsight
]
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service that streams raw temperature measurements in real time to dashboards and other DT components"
    DTDFVocab:provides RealTimeTemperatureInsight
]

// C17: Insights
instance TemperatureViolationInsight : DTDFVocab:Insight [
    base:desc "Alert generated when measured temperature exceeds or falls below the configured safe range"
]
instance ModelCalibrationInsight : DTDFVocab:Insight [
    base:desc "Information about the latest calibrated parameter values for the thermal models"
]
instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature values over the next planning horizon"
]
instance TemperatureVisualizationInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of current and forecasted temperature trends"
]
instance RealTimeTemperatureInsight : DTDFVocab:Insight [
    base:desc "Live view of raw temperature readings from all three sensors"
]

// C17: Actions
instance AutomaticHeaterAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatically adjust heater power set‑point to bring temperature back within target bounds"
    DTDFVocab:IsAutomatic true
]
instance AutomaticFanAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatically adjust fan speed to improve temperature uniformity"
    DTDFVocab:IsAutomatic true
]
instance ManualOperatorAdjustmentAction : DTDFVocab:Action [
    base:desc "Operator‑initiated change of heater or fan settings via the Raspberry Pi control interface"
    DTDFVocab:IsAutomatic false
]

// C9: Physical Components (optional, for completeness)
instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi running the incubator software stack; interfaces to sensors, actuators and RabbitMQ"
]

// C8: Environment (optional)
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedHeaterActuator, CirculationFanActuator, InternalTempSensorA, InternalTempSensorB, ExternalTempSensor, RaspberryPiController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by DT components and sent as messages to the RabbitMQ server. The controller, listening on the RabbitMQ queues, receives these messages and translates them into actuator commands for the heat‑bed and fan (e.g., turn heating on/off, set heating duration, fan speed). After execution, the controller publishes the resulting control state back to RabbitMQ, providing implicit execution confirmation. The low‑level driver incorporates a safe protocol that validates incoming commands before they are applied to the physical actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The incubator DT processes data in (near) real‑time: controller and low‑level driver messages are streamed continuously to a time‑series database and visualized on a dashboard; a Kalman‑filter based anomaly detector runs on the incoming measurements, and calibration of Model B can be triggered on demand. Co‑simulations can use either historical or live PT data, implying that the digital twin can operate both in offline (batch) and online (real‑time) modes. No explicit sampling period or latency bound is given in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture comprises (i) data acquisition from the PT via controller and driver messages, (ii) storage in a time‑series database, (iii) real‑time visualization on a dashboard, (iv) an on‑demand calibration module that updates Model B parameters, (v) a Kalman‑filter based anomaly detection and heat‑bed state estimator, (vi) what‑if simulations performed by co‑simulation that consume historical or live PT data, and (vii) a self‑adaptation loop that sequences detection, experiment planning, controller re‑configuration, data collection, recalibration, filter re‑tuning and optimisation. This constitutes a closed feedback (MAPE‑style) orchestration of monitoring, analysis, planning and execution components."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by providing two variants: a low‑fidelity model with two free parameters and a higher‑fidelity model with four free parameters that better captures the heatbed’s thermal inertia. Validation is performed experimentally by comparing model predictions against the temperature data collected from the sensors, with the higher‑fidelity model demonstrating superior predictive accuracy. Uncertainty arises from parameter estimation errors and sensor measurement noise. Calibration algorithms are employed to minimize these uncertainties by continuously updating model parameters based on incoming data. Monitors within the DT architecture detect deviations from expected behaviour, enabling error correction and ensuring the reliability of both models and data throughout operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital‑twin communication backbone is a RabbitMQ message broker that mediates all message exchange between PT components (low‑level driver, controller) and DT software. All participants connect as clients to this central broker, forming a star‑like topology where the broker routes messages. RabbitMQ offers reliable delivery and persistence; specific bandwidth, latency, redundancy or security configurations are not detailed in the provided documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The physical twin runs on a Raspberry Pi that hosts both the low‑level driver and the controller software. The RabbitMQ server, which provides the communication platform for the DT, is deployed as a separate service (the documents do not specify whether it is on‑premise or cloud‑based). No explicit computational or storage requirements, scalability mechanisms, or availability guarantees are described in the source material."
]