// Physical Acting Components
instance HeatbedResistiveHeater : DTDFVocab:ActingComponent [
    base:desc "Resistive heater constituting the heatbed of the thermal incubator, actuated via MOSFET drivers"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Cooling fan driven through MOSFET drivers to regulate internal airflow"
]

instance RaspberryPi4ModelB : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B serving as the primary controller for sensor reading and actuator command"
]

instance MOSFETDriverCircuit : DTDFVocab:Component [
    base:desc "MOSFET driver circuit enabling PWM control of heatbed heater and fan through Raspberry Pi GPIO"
]

instance Optocouplers : DTDFVocab:Component [
    base:desc "Optocouplers providing electrical isolation between Raspberry Pi logic and high‑current MOSFET drivers"
]

instance PCBCustomDesign : DTDFVocab:Component [
    base:desc "Custom PCB integrating MOSFET driver circuitry, optocouplers, and power routing"
]

// Physical Sensing Components
instance DS18S20InteriorSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor measuring interior box temperature (position 1)"
    DTDFVocab:producedData DS18S20InteriorSensor1Message
]

instance DS18S20InteriorSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor measuring interior box temperature (position 2)"
    DTDFVocab:producedData DS18S20InteriorSensor2Message
]

instance DS18S20InteriorSensor3 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor measuring interior box temperature (position 3)"
    DTDFVocab:producedData DS18S20InteriorSensor3Message
]

instance DS18S20AmbientSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor measuring ambient room temperature"
    DTDFVocab:producedData DS18S20AmbientSensorMessage
]

// Data Transmitted via RabbitMQ
instance DS18S20InteriorSensor1Message : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20InteriorSensor1
]

instance DS18S20InteriorSensor2Message : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20InteriorSensor2
]

instance DS18S20InteriorSensor3Message : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20InteriorSensor3
]

instance DS18S20AmbientSensorMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20AmbientSensor
]

// Data Captured
instance DS18S20InteriorTempData1 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature sample from interior sensor 1"
    DTDFVocab:fromData DS18S20InteriorSensor1Message
    DTDFVocab:inputTo PythonSciPyNumPy
]

instance DS18S20InteriorTempData2 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature sample from interior sensor 2"
    DTDFVocab:fromData DS18S20InteriorSensor2Message
    DTDFVocab:inputTo PythonSciPyNumPy
]

instance DS18S20InteriorTempData3 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature sample from interior sensor 3"
    DTDFVocab:fromData DS18S20InteriorSensor3Message
    DTDFVocab:inputTo PythonSciPyNumPy
]

instance DS18S20AmbientTempData : DTDFVocab:Data [
    base:desc "Time‑stamped ambient room temperature sample"
    DTDFVocab:fromData DS18S20AmbientSensorMessage
    DTDFVocab:inputTo PythonSciPyNumPy
]

instance TemperatureTimeSeriesData : DTDFVocab:Data [
    base:desc "Aggregated time‑series of interior temperature samples used for model prediction"
    DTDFVocab:inputTo PythonSciPyNumPy
]

instance PowerSupplyData : DTDFVocab:Data [
    base:desc "Recorded power supply voltage and current data during operation"
    DTDFVocab:inputTo PythonSciPyNumPy
]

instance ActuatorStateData : DTDFVocab:Data [
    base:desc "Recorded states (on/off) of heatbed heater and fan actuators"
    DTDFVocab:inputTo PythonSciPyNumPy
]

instance CalibrationResidualsData : DTDFVocab:Data [
    base:desc "Residuals from the least‑squares calibration of the dynamic models"
    DTDFVocab:inputTo PythonSciPyNumPy
]

// Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker facilitating publish/subscribe communication between sensors and digital twin components"
    DTDFVocab:enables TemperatureDynamicsSimulationService, BangBangControllerMonitoringService, DigitalTwinControllerService
]

instance PythonSciPyNumPy : DTDFVocab:Enabler [
    base:desc "Python ecosystem (SciPy, NumPy) providing numerical libraries for model simulation, optimisation and data analysis"
    DTDFVocab:enables TemperatureDynamicsSimulationService, ModelParameterCalibrationService, DigitalTwinControllerService
]

instance LowLevelDriverAbstraction : DTDFVocab:Enabler [
    base:desc "Low‑level driver abstraction layer running on Raspberry Pi, converting physical inputs/outputs to digital twin events"
    DTDFVocab:enables DigitalTwinControllerService
]

// Services
instance TemperatureDynamicsSimulationService : DTDFVocab:Service [
    base:desc "Simulates and predicts internal temperature dynamics using parametric models A and B"
    DTDFVocab:provides ThermalInertiaEstimationInsight
]

instance ModelParameterCalibrationService : DTDFVocab:Service [
    base:desc "Performs online calibration of model parameters via least‑squares optimisation in SciPy"
    DTDFVocab:provides UpdateModelParametersAction
]

instance BangBangControllerMonitoringService : DTDFVocab:Service [
    base:desc "Monitors temperature regulation through a bang‑bang controller interface"
    DTDFVocab:provides AdjustBangBangControllerDurationAction
]

instance DigitalTwinControllerService : DTDFVocab:Service [
    base:desc "Coordinated service interfacing with sensor data, model predictions and actuator command"
    DTDFVocab:provides AdjustBangBangControllerDurationAction, UpdateModelParametersAction
]

// Models
instance TemperatureDynamicModelA : DTDFVocab:Model [
    base:desc "Model A assumes all supplied power heats the air with parameter G_box"
    DTDFVocab:inputTo PythonSciPyNumPy
]

instance TemperatureDynamicModelB : DTDFVocab:Model [
    base:desc "Model B includes heatbed thermal inertia with parameters G_box, G_heater, C_air, and C_heater"
    DTDFVocab:inputTo PythonSciPyNumPy
]

// Insights and Actions
instance ThermalInertiaEstimationInsight : DTDFVocab:Insight [
    base:desc "Insight into the heatbed thermal inertia derived from calibrated models, enabling efficient temperature scheduling"
]

instance AdjustBangBangControllerDurationAction : DTDFVocab:Action [
    base:desc "Adjusts heating duration (H) and waiting duration (C) of the bang‑bang controller based on model insights"
    DTDFVocab:IsAutomatic true
]

instance UpdateModelParametersAction : DTDFVocab:Action [
    base:desc "Updates model parameters with recent calibration residuals to improve prediction accuracy"
    DTDFVocab:IsAutomatic true
]

// Environment
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:contains RaspberryPi4ModelB, MOSFETDriverCircuit, Optocouplers, PCBCustomDesign, HeatbedResistiveHeater, FanActuator, DS18S20InteriorSensor1, DS18S20InteriorSensor2, DS18S20InteriorSensor3, DS18S20AmbientSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital twin issues control commands (heatbed on/off, fan on/off, heating duration, waiting duration) via RabbitMQ messages back to the Raspberry Pi, which thresholds the MOSFET drivers to actuate the physical hardware."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A CI/CD pipeline consists of the Raspberry Pi hosting the low‑level driver, controller, and RabbitMQ server; the DT runs alongside on the same Pi or a connected host, ingesting messages from RabbitMQ, executing the simulation models, performing calibration, and publishing control commands back to RabbitMQ. The overall architecture resembles Fig. 6 of the case study."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin is employed during the operated phase of the incubator, continuously interfacing with the physical twin, collecting sensor data, updating models, and optionally calibrating parameters based on experimental runs."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation is performed by comparing simulated temperature trajectories with measured data; assumptions 1–4 are explicitly stated. Nonlinear least‑squares optimisation minimizes residual error, yielding calibrated parameters. Sensitivity to model structure is acknowledged, with Model B offering improved fidelity to capture thermal inertia. Uncertainty in measured temperature (±0.5 °C) and parameter estimation error are considered."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical sensors communicate with the Raspberry Pi over a 1‑Wire bus. The PI interfaces with the DT via a local RabbitMQ broker using AMQP protocol over Wi‑Fi/Bluetooth. Actuators are driven through MOSFETs controlled by GPIO pins on the Pi. This creates a bidirectional message flow between PT and DT."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital twin components are hosted locally on the same Raspberry Pi machine as the controller, with RabbitMQ running on the Pi. The code repository is open‑source and can be deployed on cloud or on‑premises; however, the provided implementation uses on‑premises deployment."
]