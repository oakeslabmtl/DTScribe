// Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrically powered heating element in the incubator, controlled via MOSFETs driven by the Raspberry Pi GPIO pins"
]
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V DC fan motor driven through MOSFETs, used to circulate air within the insulated box"
]
instance LoadLevelDriver : DTDFVocab:ActingComponent [
    base:desc "Low‑level driver that actuates the heatbed and fan components via GPIO pins on the Raspberry Pi"
]

// Physical Sensing Components
instance AirTemperatureSensorInside1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire digital thermometer with 64‑bit serial code 0x28FF641D8017021A, placed inside the insulated box for air temperature"
    DTDFVocab:producedData AirTempInside1DataTransmitted
]
instance AirTemperatureSensorInside2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire digital thermometer with 64‑bit serial code 0x28FF3A4C8017021C, placed inside the insulated box for air temperature"
    DTDFVocab:producedData AirTempInside2DataTransmitted
]
instance RoomTemperatureSensorOutside : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire digital thermometer with 64‑bit serial code 0x28FF6E2B8017021E, placed outside the box to monitor room temperature"
    DTDFVocab:producedData RoomTempOutsideDataTransmitted
]

// Data Transmitted Instances
instance AirTempInside1DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirTemperatureSensorInside1
]
instance AirTempInside2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirTemperatureSensorInside2
]
instance RoomTempOutsideDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTemperatureSensorOutside
]

// Data Instances
instance AirTemperatureDataInside1 : DTDFVocab:Data [
    base:desc "Time‑series temperature data from the first inside air sensor"
    DTDFVocab:fromData AirTempInside1DataTransmitted
    DTDFVocab:inputTo RaspberryPiEnabler
]
instance AirTemperatureDataInside2 : DTDFVocab:Data [
    base:desc "Time‑series temperature data from the second inside air sensor"
    DTDFVocab:fromData AirTempInside2DataTransmitted
    DTDFVocab:inputTo RaspberryPiEnabler
]
instance RoomTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series temperature data from the outside room sensor"
    DTDFVocab:fromData RoomTempOutsideDataTransmitted
    DTDFVocab:inputTo RaspberryPiEnabler
]
instance TemperatureSeriesData : DTDFVocab:Data [
    base:desc "Aggregated temperature time‑series used for monitoring, simulation, and calibration"
    DTDFVocab:inputTo RaspberryPiEnabler
]
instance ControlCommandData : DTDFVocab:Data [
    base:desc "Record of control commands issued to the heatbed and fan during operation"
    DTDFVocab:inputTo RaspberryPiEnabler
]
instance PowerConsumptionData : DTDFVocab:Data [
    base:desc "Power consumption measurements for the heatbed and fan"
    DTDFVocab:inputTo RaspberryPiEnabler
]
instance ModelOutputData : DTDFVocab:Data [
    base:desc "Outputs from the calibrated thermal models stored for validation"
    DTDFVocab:inputTo RaspberryPiEnabler
]
instance ResidualErrorData : DTDFVocab:Data [
    base:desc "Residual error metrics from the nonlinear least‑squares calibration of models A and B"
    DTDFVocab:inputTo RaspberryPiEnabler
]

// Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Dynamic thermal model A describing air and heatbed temperature dynamics with parameters C_air, G_box, C_heater, G_heater"
    DTDFVocab:inputTo RaspberryPiEnabler
]
instance ThermalModelB : DTDFVocab:Model [
    base:desc "Iteratively improved thermal model B derived from experimental calibration"
    DTDFVocab:inputTo RaspberryPiEnabler
]
instance AirTemperatureDynamics : DTDFVocab:Model [
    base:desc "State‐equation model for air temperature dynamics within the incubator enclosure"
    DTDFVocab:inputTo RaspberryPiEnabler
]
instance HeatbedTemperatureDynamics : DTDFVocab:Model [
    base:desc "State‑equation model for heatbed temperature dynamics"
    DTDFVocab:inputTo RaspberryPiEnabler
]
instance FanDynamics : DTDFVocab:Model [
    base:desc "Dynamic model describing fan speed and airflow characteristics"
    DTDFVocab:inputTo RaspberryPiEnabler
]

// Enablers
instance RaspberryPiEnabler : DTDFVocab:Enabler [
    base:desc "Python/Paho‑MQTT stack running on Raspberry Pi Model B that reads sensor data, forwards it via RabbitMQ, runs the calibrated models, and exposes services over AMQP"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveSimulationService, CalibrationService, VisualizationService, FaultDetectionService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature and actuator status, providing live temperature trajectories and actuator health indicators"
    DTDFVocab:provides TemperatureMonitoringInsight
]
instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation using calibrated models A and B to project future temperature trajectories"
    DTDFVocab:provides TemperatureTrajectoryInsight, SuggestFanVoltageAction, SuggestHeatingDurationAction
]
instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration engine performing nonlinear least‑squares optimization to update model parameters G_box and G_heater"
    DTDFVocab:provides ParameterEstimatesInsight
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualization of temperature trajectories and residual error metrics over time"
    DTDFVocab:provides VisualizationInsight
]
instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Basic fault detection by monitoring anomalies in sensor data and actuator command consistency, raising safety alerts"
    DTDFVocab:provides SafetyAlertInsight, SafetyAlertAction
]

// Insights
instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Live temperature status and actuator operation visualized as time‑series plots"
]
instance TemperatureTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Projected temperature trajectories generated by the predictive models"
]
instance ParameterEstimatesInsight : DTDFVocab:Insight [
    base:desc "Calibrated parameter estimates G_box and G_heater derived from experimental data"
]
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of temperature and residual error metrics"
]
instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Safety alerts triggered when temperature boundaries are approached or internal consistency violations are detected"
]

// Actions
instance SuggestFanVoltageAction : DTDFVocab:Action [
    base:desc "Automatic recommendation of optimal fan voltage to achieve desired temperature trajectory"
    DTDFVocab:IsAutomatic true
]
instance SuggestHeatingDurationAction : DTDFVocab:Action [
    base:desc "Automatic suggestion of heating duration needed for target temperature"
    DTDFVocab:IsAutomatic true
]
instance SafetyAlertAction : DTDFVocab:Action [
    base:desc "Automatic notification action when safety limits are approached"
    DTDFVocab:IsAutomatic true
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, FanActuator, LoadLevelDriver, AirTemperatureSensorInside1, AirTemperatureSensorInside2, RoomTemperatureSensorOutside
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Command messages (e.g., enable/disable fan, adjust heatbed power) are sent from the DT via RabbitMQ to the Raspberry Pi, which then drives the MOSFETs controlling the actuators; DT also publishes control state back to the Pi for redundancy."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real‑time operation of the control loop (sensing, decision, actuation) with a resolution of seconds; model calibration and simulation performed offline when new experimental data is available"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Device hardware (styrofoam box, heatbed, fan, sensors); embedded Raspberry Pi controller; PCB connecting MOSFETs and optocouplers; low‑level driver polling sensors and publishing to RabbitMQ; communication server (RabbitMQ) hosting AMQP topics; model and control logic executed on the Pi, all orchestrated to form the digital twin ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (model derivation and hardware design), manufacturing (deployment of Raspberry Pi, sensors, PCB, and open‑source software), and operation (runtime monitoring, calibration, re‑commissioning after maintenance), with continuous model refinement during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model A calibrated to capture thermal inertia; model B incorporates heatbed thermal mass; calibration minimizes least‑squares residual, verified against experimental temperature trajectories; assumptions explicitly tested (uniform temperature, negligible wall heat accumulation); further validation through controlled experiments with varied fan voltage."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical PT communicates with DT via RabbitMQ over local network (AMQP protocol); the DT handles sensor data and control commands through this broker; 1‑Wire bus used between Pi and DS18S20 sensors."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted locally on the Raspberry Pi 4; all software components (controller, driver, RabbitMQ, DT models) run on this single board computer; the repository is open‑source and can be redeployed elsewhere"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Low‑level driver incorporates a safe protocol to prevent unsafe actuator states; control logic includes wait periods (C) after heating to avoid overheating; RabbitMQ allows message isolation; no explicit cybersecurity hardening documented, but safe operating limits are enforced via firmware."
]