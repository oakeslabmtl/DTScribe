// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heating element embedded in the heatbed; controlled via MOSFET and provides up to 4A."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12V to 24V fan mounted on the top of the insulated box; controlled via MOSFET and isolated by optocoupler."
]

// C3: Physical sensing components
instance ProcessTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 thermal sensor placed inside the insulated box monitoring process temperature."
    DTDFVocab:producedData TemperatureReadingsAMQPMessage
]

instance ProcessTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 sensor inside the insulated box for temperature redundancy."
    DTDFVocab:producedData TemperatureReadingsAMQPMessage
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor positioned outside the box to record ambient room temperature."
    DTDFVocab:producedData TemperatureReadingsAMQPMessage
]

// C4: Physical-to-virtual interaction
instance TemperatureReadingsAMQPMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProcessTempSensor1, ProcessTempSensor2, AmbientTempSensor
]

// C10: Models/Data
instance TemperatureDataCollection : DTDFVocab:Data [
    base:desc "Collected temperature timestamps and sensor values streamed via RabbitMQ."
    DTDFVocab:fromData TemperatureReadingsAMQPMessage
    DTDFVocab:inputTo RabbitMQBroker
]

instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single temperature dynamics ODE model with parameters C_air and G_box."
    DTDFVocab:inputTo ScipyOptimizer, PythonSimulationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Coupled ODE model including heatbed temperature with parameters C_heater, G_heater, G_box."
    DTDFVocab:inputTo ScipyOptimizer, PythonSimulationEngine
]

instance ModelAOutputData : DTDFVocab:Data [
    base:desc "Predicted temperature trajectory from Model A simulation."
    DTDFVocab:fromData TemperatureReadingsAMQPMessage
    DTDFVocab:inputTo PythonSimulationEngine
]

instance ModelBOutputData : DTDFVocab:Data [
    base:desc "Predicted temperature trajectory from Model B simulation."
    DTDFVocab:fromData TemperatureReadingsAMQPMessage
    DTDFVocab:inputTo PythonSimulationEngine
]

// C11: Enablers
instance RaspberryPiLowLevelDriver : DTDFVocab:Enabler [
    base:desc "Python driver reading 1‑Wire sensors and publishing AMQP messages via RabbitMQ."
    DTDFVocab:enables TemperatureMonitoringService, ActuationService, DataLoggingService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker handling MQTT messages between physical sensors and digital twin."
    DTDFVocab:enables TemperatureMonitoringService, DataLoggingService
]

instance PythonSimulationEngine : DTDFVocab:Enabler [
    base:desc "Python script executing physics‑based simulations of Model A and Model B."
    DTDFVocab:enables TemperatureSimulationService, PredictiveAnalyticsService
]

instance ScipyOptimizer : DTDFVocab:Enabler [
    base:desc "Scipy least‑squares optimizer calibrating model parameters using experimental data."
    DTDFVocab:enables ModelValidationService
]

// C6: Services
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature and alert on non‑uniform readings."
    DTDFVocab:provides TemperatureUniformityInsight
]

instance ActuationService : DTDFVocab:Service [
    base:desc "Control logic commanding heatbed and fan via Raspberry Pi."
    DTDFVocab:provides AdjustFanVoltageAction, AdjustHeatbedPowerAction
]

instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Simulates future temperature trajectories using Model A and Model B."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Provides adjustment recommendations based on simulation outputs."
    DTDFVocab:provides AdjustmentDecisionInsight
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs raw sensor streams, actuator states, and simulation outputs for auditing."
]

instance ModelValidationService : DTDFVocab:Service [
    base:desc "Validates calibrated model parameters against experimental temperature data."
    DTDFVocab:provides ModelValidationInsight
]

// C17: Insights/Actions
instance TemperatureUniformityInsight : DTDFVocab:Insight [
    base:desc "Flags non‑uniform temperature cases and prompts user to reposition sensors or modify fan speed."
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Provides predictive temperature curves for future time points to support decision making."
]

instance AdjustmentDecisionInsight : DTDFVocab:Insight [
    base:desc "Suggests adjustments such as fan voltage or heatbed power to reach target temperature set‑points."
]

instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Compares simulation predictions with experimental data to assess model fidelity."
]

instance AdjustFanVoltageAction : DTDFVocab:Action [
    base:desc "Automatically adjusts fan voltage to modify air circulation."
    DTDFVocab:IsAutomatic true
]

instance AdjustHeatbedPowerAction : DTDFVocab:Action [
    base:desc "Automatically adjusts heatbed power to reach desired temperature."
    DTDFVocab:IsAutomatic true
]

// C3: Physical sensing components (continued)
instance HeatbedComponent : DTDFVocab:Component [
    base:desc "Heatbed lining the floor of the insulated box; includes heating element and MOSFET driver."
]

instance FanComponent : DTDFVocab:Component [
    base:desc "Fan mounted on top of the insulated box; drives air around the incubator."
]

instance RaspberryPiComponent : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B acting as controller and processor."
]

instance PCBComponent : DTDFVocab:Component [
    base:desc "Printed circuit board connecting sensors, actuators, and Raspberry Pi."
]

instance StyrofoamInsulatedBox : DTDFVocab:Component [
    base:desc "Styrofoam polystyrene insulated box forming the incubator enclosure."
]

// C2: Environment
instance LaboratoryEnvironment : DTDFVocab:Environment [
    base:contains HeatbedComponent, FanComponent, RaspberryPiComponent, PCBComponent, StyrofoamInsulatedBox
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Commands generated by the DT’s control logic (bang‑bang controller) are sent as AMQP messages through RabbitMQ to the low‑level driver, which toggles the MOSFET‑controlled heatbed and fan. Output signals include heatbed power commands and fan speed control, all transmitted via the message broker."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin comprises: a low‑level driver interfacing with hardware; a controller implementing the bang‑bang logic; a RabbitMQ communication server as middleware; and simulation modules (Model A/B) running in Python on the same Raspberry Pi. All components are orchestrated via AMQP queues, producing a centralized but modular twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design & modelling of the incubator and the digital twin, calibration of model parameters using experimental data, validation of model accuracy, ongoing runtime operation with real‑time control, and planned future extensions (additional models, optimisation). The twin covers the PT from design through to operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Models assume uniform temperature (verified via experimental sensor comparison), negligible wall heat accumulation, constant air specific heat, and negligible fan heat. Calibration minimises residual error between measured and simulated temperatures; parameter uncertainty is reduced via repeated experiments. Validity is verified by comparing model predictions to measured data and testing temperature uniformity across sensors."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical sensors connect to the Pi via 1‑Wire; actuators interface through MOSFETs controlled by Raspberry Pi GPIO, isolated with optocouplers. The communication server (RabbitMQ) runs on the Pi and bridges sensor/actuator data to the digital‑twin logic over TCP/IP using AMQP. All communication occurs within a local Wi‑Fi network on the Raspberry Pi."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire twin stack—including controller, driver, message broker, and simulation modules—is hosted on a Raspberry Pi 4 running a Linux distribution. Source code and scripts are open‑source and available via GitHub, allowing deployment on any similar embedded platform."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is embedded in the low‑level driver to prevent unsafe actuator states. Optocouplers isolate Pi GPIO from high‑current MOSFET drivers. RabbitMQ is used as a lightweight, mature message broker; however, specific encryption or authentication measures are not described."
]