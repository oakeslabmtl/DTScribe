// C2: Acting Components
instance ForceActuator : DTDFVocab:ActingComponent [
    base:desc "Embedded actuator system that applies corrective forces to the Physical Twin based on Digital Twin recommendations for performance optimization and safety adjustments."
]

// C3: Physical Sensing Components
instance ForceSensor : DTDFVocab:SensingComponent [
    base:desc "High-fidelity accelerometer-based force transducer measuring dynamic forces acting on the Physical Twin's chassis and wheels with engineering-grade precision (±1%)."
    DTDFVocab:producedData ForceDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Multi-parameter sensor suite capturing environmental interactions including temperature, pressure, and aerodynamic forces affecting the Physical Twin's operational domain."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

instance StructuralHealthMonitor : DTDFVocab:SensingComponent [
    base:desc "Distributed strain gauge network monitoring structural integrity and detecting fatigue indicators in the Physical Twin's chassis and critical components."
    DTDFVocab:producedData StructuralHealthDataTransmitted
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency vibration transducer array capturing dynamic response characteristics across the Physical Twin's operational spectrum."
    DTDFVocab:producedData VibrationDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance ForceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ForceSensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance StructuralHealthDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralHealthMonitor
]

instance VibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
]

// C10: Models/Data
instance GeometricModel : DTDFVocab:Model [
    base:desc "CAD-based geometric representation capturing the Physical Twin's chassis dimensions, wheel profiles, and structural topology for physics-based simulations."
    DTDFVocab:inputTo CADModelingTool
]

instance DynamicBehaviorModel : DTDFVocab:Model [
    base:desc "Differential equation-based behavioral model simulating the Physical Twin's dynamic response to forces, movements, and environmental interactions using physics-based algorithms."
    DTDFVocab:inputTo SimulationEngine
]

instance FaultDetectionModel : DTDFVocab:Model [
    base:desc "Machine learning-based anomaly detection model trained to identify deviations from expected behavior patterns in the Physical Twin's operational data."
    DTDFVocab:inputTo FaultDetectionAlgorithm
]

instance OptimizationModel : DTDFVocab:Model [
    base:desc "Mathematical optimization framework using linear programming and gradient-based techniques to recommend optimal control parameters for the Physical Twin's performance."
    DTDFVocab:inputTo OptimizationAlgorithm
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Continuous stream of time-series sensor data from the Physical Twin including force measurements, environmental parameters, and structural health indicators."
    DTDFVocab:fromData ForceDataTransmitted, EnvironmentalDataTransmitted, StructuralHealthDataTransmitted, VibrationDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithm, StateEstimationAlgorithm
]

instance HistoricalOperationalData : DTDFVocab:Data [
    base:desc "Archived time-series dataset containing the Physical Twin's operational history for trend analysis, predictive maintenance, and model calibration refinement."
    DTDFVocab:fromData ForceDataTransmitted, EnvironmentalDataTransmitted
    DTDFVocab:inputTo PredictiveAnalysisService
]

instance EnvironmentalDataset : DTDFVocab:Data [
    base:desc "External environmental data including weather conditions, load profiles, and dynamic load scenarios used to contextualize the Physical Twin's operational environment."
    DTDFVocab:inputTo SimulationEngine
]

// C11: Enablers
instance CADModelingTool : DTDFVocab:Enabler [
    base:desc "Computer-Aided Design platform (e.g., SolidWorks, CATIA) used to create and maintain the Physical Twin's geometric representations and structural models."
    DTDFVocab:enables GeometricModelCreationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Dynamic simulation platform (e.g., MATLAB/Simulink, ANSYS) executing time-domain simulations to reproduce the Physical Twin's behavior under current and hypothetical conditions."
    DTDFVocab:enables BehavioralReproductionService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Parameter estimation framework using Bayesian methods and least squares optimization to continuously update the Digital Twin's models based on real-time sensor data."
    DTDFVocab:enables ModelCalibrationService
]

instance FaultDetectionAlgorithm : DTDFVocab:Enabler [
    base:desc "Machine learning-based anomaly detection system implementing support vector machines and Kalman filters to identify operational deviations in the Physical Twin."
    DTDFVocab:enables AnomalyDetectionService
]

instance OptimizationAlgorithm : DTDFVocab:Enabler [
    base:desc "Numerical optimization solver (e.g., gradient descent, genetic algorithms) tuning the Physical Twin's operational parameters for optimal performance and safety."
    DTDFVocab:enables PerformanceTuningService
]

instance StateEstimationAlgorithm : DTDFVocab:Enabler [
    base:desc "Extended Kalman Filter-based state estimator fusing sensor data and model predictions to provide robust real-time state representations of the Physical Twin."
    DTDFVocab:enables StateEstimationService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "High-performance time-series database (e.g., InfluxDB, TimescaleDB) storing and managing the Digital Twin's real-time and historical sensor data streams."
    DTDFVocab:enables DataStorageService
]

instance DigitalTwinPlatform : DTDFVocab:Enabler [
    base:desc "Specialized Digital Twin platform (e.g., Siemens MindSphere, PTC ThingWorx) orchestrating data flow, simulation execution, and service integration across the Digital Twin ecosystem."
    DTDFVocab:enables MonitoringService, BehavioralReproductionService, PredictiveAnalysisService, ModelCalibrationService, StateEstimationService, AnomalyDetectionService, PerformanceTuningService, ControlService, VisualizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous real-time monitoring service acquiring sensor data from the Physical Twin and maintaining synchronized state estimates between the Digital Twin and Physical Twin."
    DTDFVocab:provides RealTimeStateInsight, AnomalyAlertAction
]

instance BehavioralReproductionService : DTDFVocab:Service [
    base:desc "Dynamic simulation service executing the Physical Twin's behavioral models to reproduce its current and hypothetical operational states for analysis."
    DTDFVocab:provides PredictiveBehaviorInsight
]

instance PredictiveAnalysisService : DTDFVocab:Service [
    base:desc "Forecasting service using time-series data and physics-based models to predict future system states, degradation patterns, and potential failure modes."
    DTDFVocab:provides PredictiveInsight, MaintenanceRecommendationAction
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Parameter estimation service continuously refining the Digital Twin's models using real-time sensor data to maintain predictive accuracy."
    DTDFVocab:provides ModelAccuracyInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "State estimation service providing real-time reconciled state representations by fusing sensor observations with Digital Twin model predictions."
    DTDFVocab:provides CurrentStateInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Fault detection service identifying deviations from expected behavior patterns in the Physical Twin's operational data streams."
    DTDFVocab:provides DiagnosticInsight, FaultAlertAction
]

instance PerformanceTuningService : DTDFVocab:Service [
    base:desc "Optimization service recommending optimal control parameters and operational configurations to enhance the Physical Twin's performance and efficiency."
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Supervisory control service autonomously or semi-autonomously adjusting the Physical Twin's behavior based on Digital Twin-generated insights and state estimates."
    DTDFVocab:provides ControlAdjustmentAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization service providing 3D CAD renderings and real-time dashboards for engineers to interpret Digital Twin insights."
    DTDFVocab:provides VisualInsight
]

// C17: Insights/Actions
instance PredictiveBehaviorInsight : DTDFVocab:Insight [
    base:desc "Dynamic simulation results showing the Physical Twin's expected behavior under current operational conditions, enabling proactive decision-making."
]

instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Forecasted future states of the Physical Twin including potential failure modes, performance degradation trajectories, and operational risk assessments."
]

instance DiagnosticInsight : DTDFVocab:Insight [
    base:desc "Real-time analysis identifying anomalies, faults, or deviations in the Physical Twin's operational data compared against Digital Twin baselines."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Mathematically optimized control parameters and operational configurations recommended to maximize the Physical Twin's performance while maintaining safety constraints."
]

instance RealTimeStateInsight : DTDFVocab:Insight [
    base:desc "Continuously updated state representation of the Physical Twin reconciled from sensor data and Digital Twin model predictions."
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantitative metrics assessing the Digital Twin's model calibration accuracy and predictive reliability based on real-time data validation."
]

instance CurrentStateInsight : DTDFVocab:Insight [
    base:desc "Real-time operational state of the Physical Twin including all critical parameters and environmental interactions."
]

instance VisualInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D visualizations and dashboards presenting Digital Twin insights in an intuitive format for engineering analysis."
]

instance AnomalyAlertAction : DTDFVocab:Action [
    base:desc "Automated alert generation when the Digital Twin detects anomalies or deviations exceeding predefined thresholds."
    DTDFVocab:IsAutomatic true
]

instance FaultAlertAction : DTDFVocab:Action [
    base:desc "Automated fault detection response triggering immediate investigation or corrective actions when structural or operational failures are identified."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Proactive maintenance scheduling recommendations based on predictive insights about potential system degradation or failure modes."
    DTDFVocab:IsAutomatic false
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Autonomous or semi-autonomous adjustment of the Physical Twin's operational parameters based on Digital Twin-generated optimization recommendations."
    DTDFVocab:IsAutomatic true
]

// C18: Environment
