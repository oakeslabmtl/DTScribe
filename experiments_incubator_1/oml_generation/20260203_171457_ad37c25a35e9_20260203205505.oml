// C2: Acting Components
instance HeatBedActingComponent : DTDFVocab:ActingComponent [
    base:desc "Heatbed supplies thermal energy to the insulated incubator interior."
]

instance FanActingComponent : DTDFVocab:ActingComponent [
    base:desc "Mechanical fan circulates air across the heatbed and over the incubator enclosure."
]

instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi hosts low‑level controller firmware, runs calibration and simulation services, and issues on/off commands to the heatbed and fan via low‑level driver messages."
]

// C3: Physical sensing components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the incubator interior, provides inside temperature telemetry."
    DTDFVocab:producedData Internal1TempDataTransmitted
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second temperature sensor embedded in the incubator interior, provides inside temperature telemetry."
    DTDFVocab:producedData Internal2TempDataTransmitted
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted on the exterior of the incubator to monitor ambient temperature."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Physical-to-virtual interaction
instance Internal1TempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1
]

instance Internal2TempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor2
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

// C10: Models/Data
instance Internal1TemperatureData : DTDFVocab:Data [
    base:desc "Timestamped inside temperature measurement from sensor 1."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler, EstimationEnabler, MonitoringEnabler, WhatIfEnabler, AdaptationEnabler, UserInterfaceEnabler
    DTDFVocab:fromData Internal1TempDataTransmitted
]

instance Internal2TemperatureData : DTDFVocab:Data [
    base:desc "Timestamped inside temperature measurement from sensor 2."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler, EstimationEnabler, MonitoringEnabler, WhatIfEnabler, AdaptationEnabler, UserInterfaceEnabler
    DTDFVocab:fromData Internal2TempDataTransmitted
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Timestamped ambient temperature measurement from external sensor."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler, EstimationEnabler, MonitoringEnabler, WhatIfEnabler, AdaptationEnabler, UserInterfaceEnabler
    DTDFVocab:fromData ExternalTempDataTransmitted
]

instance ModelA : DTDFVocab:Model [
    base:desc "Heat dynamics model with two free parameters used for short‑term temperature prediction."
    DTDFVocab:inputTo SimulationEnabler
]

instance ModelB : DTDFVocab:Model [
    base:desc "Extended heat dynamics model with four free parameters capturing heatbed thermal inertia, used for simulation and Kalman filtering."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler, EstimationEnabler
]

// C11: Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibrates ModelA and ModelB parameters using a least‑squares optimiser against measured temperature data."
    DTDFVocab:enables ParameterCalibrationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Executes predictive simulations with ModelA and ModelB based on real‑time sensor data."
    DTDFVocab:enables PredictiveSimulationService
]

instance EstimationEnabler : DTDFVocab:Enabler [
    base:desc "Runs a Kalman filter fusing measured temperatures and ModelB predictions to estimate unmeasured heatbed temperature and anomaly detection."
    DTDFVocab:enables StateEstimationService
]

instance WhatIfEnabler : DTDFVocab:Enabler [
    base:desc "Performs co‑simulations replaying historical or live data to evaluate alternative controller settings."
    DTDFVocab:enables WhatIfOptimizationService
]

instance AdaptationEnabler : DTDFVocab:Enabler [
    base:desc "Orchestrates self‑adaptation triggered by anomalies: schedules calibration, re‑optimises controller, and updates model/filters."
    DTDFVocab:enables SelfAdaptationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Collects and stores telemetry in a time‑series database for real‑time monitoring."
    DTDFVocab:enables RealTimeMonitoringService
]

instance UserInterfaceEnabler : DTDFVocab:Enabler [
    base:desc "Exposes dashboards and configuration interfaces for operators."
    DTDFVocab:enables UserInterfaceService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service capturing sensor streams, persisting them in a time‑series database, and rendering live charts on the dashboard."
    DTDFVocab:provides InsideTemperatureInsight, OutsideTemperatureInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Service that runs ModelA and ModelB to forecast future internal temperature under variable heater and fan inputs."
    DTDFVocab:provides PredictedTemperatureInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Service that updates ModelB free parameters using least‑squares fitting to measured data."
    DTDFVocab:provides CalibrationResultInsight, TriggerCalibrationAction
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Service running Kalman filter to estimate heatbed temperature and detect anomalies."
    DTDFVocab:provides HeatBedTemperatureEstimateInsight, AnomalyDetectionInsight, UpdateKalmanFilterAction
]

instance WhatIfOptimizationService : DTDFVocab:Service [
    base:desc "Service executing what‑if co‑simulations to evaluate alternative controller settings for robustness."
    DTDFVocab:provides WhatIfSimulationInsight, RunWhatIfSimulationAction
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Service that responds to anomalies by triggering calibration, optimizing controllers, and pushing updated configurations."
    DTDFVocab:provides UpdatedControllerConfigurationInsight, TriggerCalibrationAction, RunWhatIfSimulationAction, UpdateControllerAction
]

instance UserInterfaceService : DTDFVocab:Service [
    base:desc "Service offering dashboards and configuration interfaces for engineers and operators to view insights and initiate actions."
    DTDFVocab:provides InsideTemperatureInsight, HeatBedTemperatureEstimateInsight, PredictedTemperatureInsight, CalibrationResultInsight, UpdatedControllerConfigurationInsight
]

// C17: Insights/Actions
instance InsideTemperatureInsight : DTDFVocab:Insight [
    base:desc "Real‑time inside temperature visualization on the dashboard."
]

instance OutsideTemperatureInsight : DTDFVocab:Insight [
    base:desc "Real‑time ambient temperature visualization on the dashboard."
]

instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted future internal temperature forecast produced by the simulation models."
]

instance CalibrationResultInsight : DTDFVocab:Insight [
    base:desc "Resulting calibrated parameters for ModelA and ModelB after least‑squares optimisation."
]

instance HeatBedTemperatureEstimateInsight : DTDFVocab:Insight [
    base:desc "Estimated heatbed temperature derived from Kalman filter."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Flag indicating significant deviation between measured and model‑predicted temperature."
]

instance WhatIfSimulationInsight : DTDFVocab:Insight [
    base:desc "Outcome of alternative controller scenarios evaluated via co‑simulation."
]

instance UpdatedControllerConfigurationInsight : DTDFVocab:Insight [
    base:desc "New controller configuration recommended by the twin after self‑adaptation."
]

// Actions
instance TriggerCalibrationAction : DTDFVocab:Action [
    base:desc "Action to initiate the model calibration routine."
    DTDFVocab:IsAutomatic true
]

instance RunWhatIfSimulationAction : DTDFVocab:Action [
    base:desc "Action to execute what‑if co‑simulation scenario."
    DTDFVocab:IsAutomatic true
]

instance UpdateControllerAction : DTDFVocab:Action [
    base:desc "Action to push updated controller configuration to the Raspberry Pi."
    DTDFVocab:IsAutomatic true
]

instance UpdateKalmanFilterAction : DTDFVocab:Action [
    base:desc "Action to update Kalman filter parameters based on new data."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The controller receives control commands (e.g. to turn the heatbed or fan on/off) from the RabbitMQ broker. It then forwards the actuator orders to the low‑level driver via the same broker. The low‑level driver executes the commands after verifying them against a safe protocol that ensures the incubator remains in a protected state. After execution, the driver publishes the resulting control states back to the broker for telemetry. The controller implements a bang‑bang logic using the received reference temperature to decide heating or cooling actions."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Synchronization between the physical incubator and the Digital Twin is coordinated through a RabbitMQ message broker. A low‑level driver on the Raspberry Pi periodically reads temperature sensor data and publishes it to RabbitMQ, where Digital Twin services consume it. Real‑time monitoring, calibration, Kalman filtering and anomaly detection run on‑the‑fly, providing near‑instantaneous feedback with sub‑second responsiveness. Batch tasks such as what‑if simulations and offline calibrations are executed on demand and do not block the real‑time loop, resulting in a three‑tier temporal architecture: (1) periodic sensor sampling, (2) sub‑second real‑time processing, and (3) asynchronous batch processing."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin of the incubator is organised around a modular architecture that centres on three main stages: (1) *Data ingestion* from the physical twin via two internal temperature sensors and one external temperature sensor, all connected to a Raspberry Pi controller; (2) *Model calibration* where a calibration algorithm updates the parameters of two simulation models (Model A with two free parameters and Model B with four free parameters) to best fit the measured data; and (3) *Monitoring and decision‑making* where any resulting data are fed to safety monitors that check for violations and, if necessary, trigger re‑configuration of the physical controller. The framework follows a clear feed‑forward flow from physical sensing to digital modelling, and ultimately to actuation, with no explicit replication or hierarchical structure described in the documents."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Calibration routines fit Model A and Model B’s free parameters to experimental temperature data collected from the physical incubator by minimizing the discrepancy between measured temperatures and model predictions. Model B, containing two additional parameters, better captures the heat‑bed thermal inertia that Model A cannot, evidencing higher fidelity. Validation is implicit in direct comparison of live sensor data to model outputs, and model adjustments are made during calibration. Sources of uncertainty include sensor noise and variability in heater performance; the documents mention no explicit uncertainty quantification or error‑correction mechanisms beyond the calibration loop."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin’s technical back‑end uses RabbitMQ, an open‑source AMQP messaging broker, as the central communication middleware. All components (controller, low‑level driver, DT models) publish and subscribe to RabbitMQ queues over standard TCP connections. RabbitMQ provides the necessary transport layer; the broker can be deployed on‑premises on a local network. No specific bandwidth or latency targets are detailed, but the system relies on RabbitMQ’s lightweight message passing for near‑real‑time interaction."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Both the DT software (controller, low‑level driver, and associated logic) and the RabbitMQ message broker are deployed on the same physical Raspberry Pi used for the incubator, representing an on‑premises edge deployment. All components run locally within the incubator’s network, with no external cloud or edge servers required."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External integration is achieved through a RabbitMQ message broker that exchanges control and telemetry messages among the Raspberry Pi controller, the low‑level driver, and the Digital Twin services. The Digital Twin publishes telemetry data to a time‑series database, which feeds a real‑time dashboard for visualization. On‑demand calibration and heat‑bed state estimation requests are also routed via the same message bus. No additional enterprise systems are directly connected; integration focuses on these open‑source components."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin includes a monitoring component that continuously evaluates the physical twin’s operation against safety criteria. Sensor data (two interior temperature sensors and one exterior sensor) feed calibration and simulation models; violations trigger alerts or corrective actions. While the documents do not detail specific cybersecurity protocols, access‑control mechanisms, or fail‑safe components, the architecture follows general safety‑critical system practices by integrating real‑time monitoring and calibration to maintain safe operation. The open‑source repository on GitHub indicates a transparent implementation but does not specify privacy or consent handling."
]