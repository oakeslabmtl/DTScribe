// C3: Sensing Component
instance PhysicalTwinSensor : DTDFVocab:SensingComponent [
    base:desc "Collects continuous sensor streams from the Physical Twin."
    DTDFVocab:producedData PhysicalTwinSensorDataTransmission
]

// C4: Data Transmitted
instance PhysicalTwinSensorDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalTwinSensor
    base:desc "Transmitted sensor data from PhysicalTwinSensor."
]

// C10: Data
instance LiveSensorData : DTDFVocab:Data [
    base:desc "Live sensor data, including temperature, pressure, etc., collected from the Physical Twin."
    DTDFVocab:fromData PhysicalTwinSensorDataTransmission
    DTDFVocab:inputTo CalibrationAlgorithm, FaultDetectionAlgorithm, StateEstimationAlgorithm, OptimizationAlgorithm
]

// C10: Models
instance DifferentialEquationDynamicModel : DTDFVocab:Model [
    base:desc "Detailed mathematical model based on differential equations describing the dynamics of the Physical Twin."
    DTDFVocab:inputTo CalibrationAlgorithm, SimulationEngineComponent
]

instance CyberPhysicalModel : DTDFVocab:Model [
    base:desc "Integrated model representing the cyber and physical aspects, including geometric and behavioral properties of the Physical Twin."
    DTDFVocab:inputTo CalibrationAlgorithm, ModelingComponent
]

// C11: Enablers
instance DataAcquisitionComponent : DTDFVocab:Enabler [
    base:desc "Data acquisition layer that collects sensor streams from the Physical Twin."
    DTDFVocab:enables RealTimeSafetyMonitoringService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that persistently updates model parameters based on observed data to refine the model."
    DTDFVocab:enables ModelCalibrationService
]

instance FaultDetectionAlgorithm : DTDFVocab:Enabler [
    base:desc "Fault detection algorithm that identifies anomalies in sensor data against safety and performance thresholds."
    DTDFVocab:enables DiagnosticFaultDetectionService
]

instance StateEstimationAlgorithm : DTDFVocab:Enabler [
    base:desc "State estimation algorithm that infers hidden states from measurements."
    DTDFVocab:enables StateEstimationService
]

instance OptimizationAlgorithm : DTDFVocab:Enabler [
    base:desc "Optimization algorithm that computes optimal control or operational strategies."
    DTDFVocab:enables OptimizationService
]

instance ModelingComponent : DTDFVocab:Enabler [
    base:desc "Modeling layer encapsulating cyber and physical behaviors."
]

instance SimulationEngineComponent : DTDFVocab:Enabler [
    base:desc "Simulation engine that executes dynamic models to reproduce and predict system behavior."
    DTDFVocab:enables SimulationService
]

// C6: Services
instance RealTimeSafetyMonitoringService : DTDFVocab:Service [
    base:desc "Real-time safety and performance monitoring with sensor-derived data streams."
    DTDFVocab:provides SafetyViolationAlert, PerformanceViolationAlert
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Service that performs model calibration via adaptive algorithms based on live sensor data."
    DTDFVocab:provides CalibrationInsight
]

instance DiagnosticFaultDetectionService : DTDFVocab:Service [
    base:desc "Service for diagnostic fault detection."
    DTDFVocab:provides FaultDetectionInsight, FaultCorrectionRecommendation
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Service providing state estimation capabilities."
    DTDFVocab:provides StateEstimationInsight, AutomaticControlAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service computing optimal control or operational strategies."
    DTDFVocab:provides OptimalControlInsight, OptimalControlAction
]

instance AdaptiveSupervisoryControlService : DTDFVocab:Service [
    base:desc "Service offering adaptive supervisory controls that recommend or enact adjustments when constraints violated."
    DTDFVocab:provides ControlInsight, ControlActionImplementation
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Service enabling predictive maintenance."
    DTDFVocab:provides MaintenanceRecommendation, MaintenanceAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service enabling simulation of dynamic behaviors."
    DTDFVocab:provides SimulationResultInsight
]

// C17: Insights
instance SafetyViolationAlert : DTDFVocab:Insight [
    base:desc "Alert indicating safety violation detected by real-time monitoring."
]

instance PerformanceViolationAlert : DTDFVocab:Insight [
    base:desc "Alert indicating performance threshold violation detected by real-time monitoring."
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight reporting calibration status after model update."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight identifying detected faults in sensor data."
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Insight providing inferred hidden state estimates."
]

instance ControlInsight : DTDFVocab:Insight [
    base:desc "Insight recommending control adjustments under supervisory control."
]

instance MaintenanceRecommendation : DTDFVocab:Insight [
    base:desc "Recommendation for maintenance actions based on predictive models."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight providing simulation results of dynamic behavior."
]

instance OptimalControlInsight : DTDFVocab:Insight [
    base:desc "Insight indicating optimal control strategy computed by the optimization service."
]

// C17: Actions
instance AutomaticControlAction : DTDFVocab:Action [
    base:desc "Automatic control action to enforce inferred states."
    DTDFVocab:IsAutomatic true
]

instance FaultCorrectionRecommendation : DTDFVocab:Action [
    base:desc "Recommended corrective action for detected fault."
    DTDFVocab:IsAutomatic false
]

instance ControlActionImplementation : DTDFVocab:Action [
    base:desc "Implementation of supervisory control adjustments."
    DTDFVocab:IsAutomatic false
]

instance MaintenanceAction : DTDFVocab:Action [
    base:desc "Execution of maintenance activity."
    DTDFVocab:IsAutomatic false
]

instance OptimalControlAction : DTDFVocab:Action [
    base:desc "Automatic execution of optimal control strategy."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin integrates modelling, simulation, monitoring, and optimisation within a single framework. Deployment‑time models are continuously updated via calibration algorithms that refine the physics and cyber models of the cyber‑physical system (CPS) and its environment using real‑time sensor data collected from the physical twin. The calibrated models and synthesized data are then provided to safety and optimality monitors which evaluate operational compliance. When a violation is detected, either human operators or autonomous decision‑making algorithms may intervene to modify the physical twin. This orchestration pattern couples data ingestion, model calibration, monitoring, and control within a unified architecture, emphasizing data‑driven updates and closed‑loop decision support."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin life cycle is structured in four main stages: (1) Development and Modeling – engineers construct abstract representations of the physical system, including CAD models for geometry and differential equation‑based dynamic models for physical interactions; (2) Deployment and Integration – the developed models are integrated into the DT framework, making the DT operational alongside the Physical Twin; (3) Data Acquisition and Calibration – sensor data from the PT are continuously collected and used by calibration algorithms to update model parameters and synchronize the cyber‑physical system; (4) Monitoring and Optimization – the calibrated DT runs monitoring algorithms to assess safety and performance, detects violations, and triggers interaction with human operators or supervisory controllers to adjust the Physical Twin. Lifecycle governance involves continuous model refinement and scenario‑based verification but no explicit governance model is detailed in the document."
]