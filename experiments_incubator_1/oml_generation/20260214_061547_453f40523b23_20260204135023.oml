// C2: Acting Components
instance EmbeddedControlActuator : DTDFVocab:ActingComponent [
    base:desc "Cyber component that executes control actions on the Physical Twin based on Digital Twin-generated commands, interfacing with physical actuators to adjust system parameters in real-time."
]

instance CyberPhysicalInterface : DTDFVocab:ActingComponent [
    base:desc "Communication interface between cyber and physical components that facilitates bidirectional data exchange for control and monitoring purposes, supporting protocols like OPC UA and MQTT."
]

// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded sensor measuring real-time temperature parameters of the Physical Twin's operational environment, providing quantitative metrics for model calibration and anomaly detection."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Industrial transducer capturing pressure measurements from the Physical Twin's operational conditions, essential for behavioral model validation and safety monitoring."
    DTDFVocab:producedData PressureDataTransmitted
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency accelerometer array monitoring structural dynamics and mechanical vibrations in the Physical Twin, critical for predictive maintenance and fault detection."
    DTDFVocab:producedData VibrationDataTransmitted
]

instance EnvironmentalWeatherStation : DTDFVocab:SensingComponent [
    base:desc "External sensor network capturing ambient conditions (wind speed, humidity, temperature) that influence the Physical Twin's performance and operational environment."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

instance MotorSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Rotational speed sensor providing real-time operational metrics for dynamic system behavior modeling and control optimization."
    DTDFVocab:producedData SpeedDataTransmitted
]

instance LoadConditionSensor : DTDFVocab:SensingComponent [
    base:desc "Force measurement device capturing operational loads applied to the Physical Twin, used for structural integrity analysis and predictive failure modeling."
    DTDFVocab:producedData LoadDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

instance VibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalWeatherStation
]

instance SpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSpeedSensor
]

instance LoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LoadConditionSensor
]

instance EventLogDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor, PressureSensor, VibrationSensor
    base:desc "Event-based data transmission triggered by system anomalies, sensor failures, or operational threshold breaches."
]

// C10: Models/Data
instance GeometricCADModel : DTDFVocab:Model [
    base:desc "Computer-Aided Design representation of the Physical Twin's structural attributes including dimensions, shapes, and material properties for spatial context in simulations."
    DTDFVocab:inputTo CADModelingTool, VisualizationEngine
]

instance BehavioralDynamicsModel : DTDFVocab:Model [
    base:desc "Physics-based differential equation model simulating the Physical Twin's dynamic behavior under operational forces, environmental conditions, and control inputs."
    DTDFVocab:inputTo SimulationEngine, CalibrationAlgorithm
]

instance AnalyticalForceModel : DTDFVocab:Model [
    base:desc "Mathematical framework modeling force dynamics, thermal behavior, and fluid interactions within the Physical Twin for predictive analysis and optimization."
    DTDFVocab:inputTo PhysicsSimulator, OptimizationSolver
]

instance StateEstimationModel : DTDFVocab:Model [
    base:desc "Kalman filter-based model reconstructing the Physical Twin's current state from noisy sensor data, improving diagnostic accuracy and control precision."
    DTDFVocab:inputTo StateEstimationEngine, FaultDetectionAlgorithm
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Continuous time-series data stream from embedded sensors capturing operational parameters (temperature, pressure, vibration) at high frequencies (100Hz-1kHz)."
    DTDFVocab:fromData TemperatureDataTransmitted, PressureDataTransmitted, VibrationDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithm, AnomalyDetectionService
]

instance HistoricalOperationalData : DTDFVocab:Data [
    base:desc "Archived operational logs, maintenance records, and environmental datasets used for model calibration, trend analysis, and predictive maintenance forecasting."
    DTDFVocab:fromData EventLogDataTransmitted
    DTDFVocab:inputTo PredictiveAnalysisService
]

instance EnvironmentalContextData : DTDFVocab:Data [
    base:desc "External environmental parameters (weather, terrain) integrated with cyber-physical system models to simulate holistic system behavior under varying conditions."
    DTDFVocab:fromData EnvironmentalDataTransmitted
    DTDFVocab:inputTo KnowledgeGraph, SimulationEngine
]

// C11: Enablers
instance CADModelingTool : DTDFVocab:Enabler [
    base:desc "SolidWorks-based tool for creating geometric representations of the Physical Twin's structural components, enabling spatial context for simulations."
    DTDFVocab:enables GeometricModelingService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Modelica-based dynamic simulation platform solving differential equations to replicate the Physical Twin's behavior under current and hypothetical conditions."
    DTDFVocab:enables BehavioralSimulationService, PredictiveAnalysisService
]

instance PhysicsSimulator : DTDFVocab:Enabler [
    base:desc "COMSOL-based computational fluid dynamics and multibody dynamics engine for high-fidelity simulation of force dynamics and structural interactions."
    DTDFVocab:enables AnalyticalSimulationService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Recursive least squares implementation refining model parameters using real-time sensor data to minimize discrepancies between simulated and observed behavior."
    DTDFVocab:enables ModelRefinementService
]

instance StateEstimationEngine : DTDFVocab:Enabler [
    base:desc "Unscented Kalman filter implementation fusing sensor data and model predictions for robust state reconstruction and fault detection."
    DTDFVocab:enables StateEstimationService
]

instance FaultDetectionAlgorithm : DTDFVocab:Enabler [
    base:desc "Machine learning-based anomaly detection system identifying deviations from expected behavior using statistical methods and time-series analysis."
    DTDFVocab:enables AnomalyDetectionService
]

instance OptimizationSolver : DTDFVocab:Enabler [
    base:desc "Gurobi-based mathematical programming tool solving constrained optimization problems for resource allocation and control parameter tuning."
    DTDFVocab:enables PerformanceOptimizationService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unity-based 3D rendering engine creating immersive visualizations with real-time data overlays for interactive monitoring and scenario testing."
    DTDFVocab:enables VisualizationService
]

instance KnowledgeGraph : DTDFVocab:Enabler [
    base:desc "RDF-based semantic framework formalizing relationships between Physical Twin components, sensors, and environmental factors for reasoning over heterogeneous data."
    DTDFVocab:enables KnowledgeIntegrationService
]

instance EdgeComputingNode : DTDFVocab:Enabler [
    base:desc "Raspberry Pi-based edge device preprocessing sensor data locally before transmission, reducing latency and bandwidth requirements."
    DTDFVocab:enables DataPreprocessingService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "InfluxDB-based time-series database storing high-frequency sensor data for efficient querying and real-time analytics."
    DTDFVocab:enables DataStorageService
]

instance DataLake : DTDFVocab:Enabler [
    base:desc "Apache Hadoop-based storage system archiving raw and processed data for historical analysis and machine learning applications."
    DTDFVocab:enables DataArchivingService
]

instance CommunicationProtocol : DTDFVocab:Enabler [
    base:desc "OPC UA-based industrial communication framework enabling secure, platform-independent data exchange between Digital Twin and Physical Twin components."
    DTDFVocab:enables DataExchangeService
]

// C6: Services
instance GeometricModelingService : DTDFVocab:Service [
    base:desc "Service providing structural representations of the Physical Twin's components for spatial context in simulations and visualizations."
    DTDFVocab:provides GeometricModelInsight
]

instance BehavioralSimulationService : DTDFVocab:Service [
    base:desc "Service running dynamic simulations to replicate the Physical Twin's behavior under current operating conditions."
    DTDFVocab:provides BehavioralSimulationInsight
]

instance PredictiveAnalysisService : DTDFVocab:Service [
    base:desc "Service projecting future states using time-series forecasting models to anticipate performance trends and potential failures."
    DTDFVocab:provides PredictiveInsight
]

instance AnalyticalSimulationService : DTDFVocab:Service [
    base:desc "Service executing high-fidelity simulations of force dynamics, thermal behavior, and fluid interactions within the Physical Twin."
    DTDFVocab:provides AnalyticalSimulationInsight
]

instance ModelRefinementService : DTDFVocab:Service [
    base:desc "Service continuously updating model parameters using real-time sensor data to maintain fidelity with the Physical Twin's operational state."
    DTDFVocab:provides ModelAccuracyInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Service reconstructing the Physical Twin's current state from noisy sensor data using state estimation algorithms."
    DTDFVocab:provides StateEstimationInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Service identifying deviations from expected behavior by comparing real-time data against modeled baselines."
    DTDFVocab:provides AnomalyDetectionInsight
]

instance PerformanceOptimizationService : DTDFVocab:Service [
    base:desc "Service applying optimization algorithms to adjust Physical Twin parameters for maximal efficiency, safety, or cost reduction."
    DTDFVocab:provides OptimizationRecommendationAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service providing real-time graphical interfaces and AR overlays for monitoring, diagnostics, and scenario testing."
    DTDFVocab:provides VisualizationInsight
]

instance KnowledgeIntegrationService : DTDFVocab:Service [
    base:desc "Service combining cyber-physical system models and environmental models to simulate holistic system behavior."
    DTDFVocab:provides IntegratedKnowledgeInsight
]

instance DataPreprocessingService : DTDFVocab:Service [
    base:desc "Service filtering, normalizing, and validating sensor data before transmission to ensure data quality and consistency."
    DTDFVocab:provides DataQualityInsight
]

instance DataExchangeService : DTDFVocab:Service [
    base:desc "Service facilitating secure, standardized communication between Digital Twin and Physical Twin components using industrial protocols."
    DTDFVocab:provides CommunicationStatusInsight
]

// C17: Insights/Actions
instance GeometricModelInsight : DTDFVocab:Insight [
    base:desc "Structural representation insights providing spatial context for simulations and visualizations of the Physical Twin's components."
]

instance BehavioralSimulationInsight : DTDFVocab:Insight [
    base:desc "Dynamic behavior insights replicating the Physical Twin's performance under current operational conditions."
]

instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Future state projections identifying potential performance trends, failures, or efficiency drops in the Physical Twin."
]

instance AnalyticalSimulationInsight : DTDFVocab:Insight [
    base:desc "High-fidelity simulation results for force dynamics, thermal behavior, and fluid interactions within the Physical Twin."
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantitative metrics assessing the calibration quality and parameter estimation accuracy of the Digital Twin models."
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Reconstructed state information providing accurate current status of the Physical Twin's operational parameters."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Alerts identifying deviations from expected behavior, including potential sensor failures or component wear."
]

instance OptimizationRecommendationAction : DTDFVocab:Action [
    base:desc "Prescriptive adjustments for Physical Twin parameters to achieve optimal performance, safety, or cost efficiency."
    DTDFVocab:IsAutomatic true
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive graphical representations enabling real-time monitoring, diagnostics, and scenario testing of the Physical Twin."
]

instance IntegratedKnowledgeInsight : DTDFVocab:Insight [
    base:desc "Holistic system behavior insights combining cyber-physical and environmental models for comprehensive analysis."
]

instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Metrics assessing sensor data reliability, including noise levels, outlier rates, and timestamp synchronization accuracy."
]

instance CommunicationStatusInsight : DTDFVocab:Insight [
