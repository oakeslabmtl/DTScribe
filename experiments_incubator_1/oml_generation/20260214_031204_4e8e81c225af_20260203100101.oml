// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed surface heater delivering at least 100 W, capable of raising air temperature from 293 K to 300 K in 2 s"
]

instance CirculationFanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V fan providing airflow ~0.02 m³ s⁻¹, moving the whole box volume in ≤2 s"
]

// C3: Physical sensing components
instance InternalTemperatureSensorA : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer positioned inside the incubator box; measures –55 °C to +125 °C with 0.5 °C accuracy; unique 64‑bit serial code"
    DTDFVocab:producedData InternalTempDataTransmittedA
]

instance InternalTemperatureSensorB : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer positioned inside the incubator box; measures –55 °C to +125 °C with 0.5 °C accuracy; unique 64‑bit serial code"
    DTDFVocab:producedData InternalTempDataTransmittedB
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer positioned outside the incubator to measure room temperature; measures –55 °C to +125 °C with 0.5 °C accuracy; unique 64‑bit serial code"
    DTDFVocab:producedData AmbientTempDataTransmitted
]

instance CalibrationDataRecorder : DTDFVocab:SensingComponent [
    base:desc "Software recorder that captures temperature trajectories and power input during calibration experiments"
    DTDFVocab:producedData CalibrationDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance InternalTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensorA
]

instance InternalTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensorB
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

instance CalibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CalibrationDataRecorder
]

// C10: Data
instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Temperature reading from internal sensor A (°C) transmitted via RabbitMQ"
    DTDFVocab:fromData InternalTempDataTransmittedA
    DTDFVocab:inputTo RabbitMQBroker
]

instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Temperature reading from internal sensor B (°C) transmitted via RabbitMQ"
    DTDFVocab:fromData InternalTempDataTransmittedB
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Ambient temperature reading (°C) transmitted via RabbitMQ"
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

instance TemperatureTrajectoryData : DTDFVocab:Data [
    base:desc "Recorded temperature trajectory data (°C over time) from calibration experiments"
    DTDFVocab:fromData CalibrationDataTransmitted
    DTDFVocab:inputTo SciPyCalibrator
]

instance PowerInputData : DTDFVocab:Data [
    base:desc "Recorded power input data (V·I·Δt) from calibration experiments"
    DTDFVocab:fromData CalibrationDataTransmitted
    DTDFVocab:inputTo SciPyCalibrator
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP message broker running on the Raspberry Pi; receives temperature sensor messages and forwards them to Digital Twin components"
    DTDFVocab:enables RealTimeMonitoringService, TemperaturePredictionService, FaultDetectionService, ControlParameterOptimizationService
]

instance SciPyCalibrator : DTDFVocab:Enabler [
    base:desc "Python SciPy non‑linear least‑squares optimizer used for model calibration"
    DTDFVocab:enables ModelCalibrationService
]

instance PredictionEngine : DTDFVocab:Enabler [
    base:desc "Python runtime engine that executes calibrated models for temperature prediction and optimization"
    DTDFVocab:enables TemperaturePredictionService, FaultDetectionService, ControlParameterOptimizationService
]

// C6: Services
instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates Model A and Model B parameters using temperature trajectories and power input data via SciPy optimizer"
    DTDFVocab:provides InsightCalibrationCompleted
]

instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Runs calibrated Model A and Model B to simulate future temperature trajectories"
    DTDFVocab:provides InsightTemperaturePrediction
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Monitors live temperature data against safety limits in real time"
    DTDFVocab:provides InsightSafetyViolationDetection
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects violations of safety limits from monitoring data"
    DTDFVocab:provides InsightSafetyViolationDetection
]

instance ControlParameterOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes control parameters (temperature limits, heating and waiting durations) based on predictions"
    DTDFVocab:provides InsightControlRecommendation, ActionAdjustHeatingDuration
]

// C17: Insights
instance InsightCalibrationCompleted : DTDFVocab:Insight [
    base:desc "Calibration completed with estimated model parameters"
]

instance InsightTemperaturePrediction : DTDFVocab:Insight [
    base:desc "Predicted future temperature trajectory of the incubator"
]

instance InsightSafetyViolationDetection : DTDFVocab:Insight [
    base:desc "Detection of temperature exceeding safety limits"
]

instance InsightControlRecommendation : DTDFVocab:Insight [
    base:desc "Recommendation to adjust heating duration or waiting time to maintain safety"
]

// C17: Actions
instance ActionAdjustHeatingDuration : DTDFVocab:Action [
    base:desc "Adjust the heating duration or waiting time of the incubator"
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance SingleParameterAirModel : DTDFVocab:Model [
    base:desc "Model A: single‑parameter air model with thermal capacity C_air and conductance G_box"
    DTDFVocab:inputTo PredictionEngine
]

instance FourParameterHeaterModel : DTDFVocab:Model [
    base:desc "Model B: four‑parameter model including heat‑bed thermal capacity C_heater and conductance G_heater"
    DTDFVocab:inputTo PredictionEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT components send control commands (heatbed ON/OFF, fan ON/OFF) to the RabbitMQ server; the controller on the Raspberry Pi subscribes to these command messages, interprets them, and via the low‑level driver and PCB MOSFET drivers actuates the heater and fan accordingly."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data acquisition, command dissemination and model updates occur at a real‑time, second‑scale rhythm: the fan circulates the entire air volume in ~2 s, the controller’s bang‑bang logic operates with heating (H) and waiting (C) durations measured in seconds, and sensor readings are published to RabbitMQ at a comparable periodicity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation consists of a RabbitMQ server on the Raspberry Pi acting as the central bus, a controller component implementing bang‑bang logic, a low‑level driver interfacing with sensors and actuators, and DT services that subscribe to the same broker to receive sensor data, run simulations, and publish control commands, forming a tightly coupled message‑driven architecture."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is grounded on four explicit assumptions (uniform temperature, negligible wall heat, constant air specific heat, heatbed energy handling). Validation experiments test temperature uniformity (maximum 6–7 °C discrepancy across sensors) and calibrate model parameters by minimizing residual error using least‑squares. Residual error thresholds determine acceptable model validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual and virtual‑to‑physical communication is realized through a RabbitMQ message broker hosted on the Raspberry Pi. The controller, low‑level driver, and any DT service publish and subscribe to queues on this broker, enabling asynchronous exchange of sensor readings and actuation commands over the local network connection of the Pi."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ server and the controller software are both deployed on the Raspberry Pi 4 Model B. DT service components can run on the same Pi or on external machines that connect to the broker over the network. All hardware and software artifacts are openly hosted in the GitHub repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the device in a safe state, and the controller includes waiting periods to avoid temperature overshoot, thereby addressing safety. No explicit security mechanisms (authentication, encryption) are described in the document."
]