// C3: Physical sensing components
instance InsideBoxTempSensorOne : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital temperature sensor located inside the insulated styrofoam box (sensor 1)."
    DTDFVocab:producedData InsideBoxTempDataMsgOne
]

instance InsideBoxTempSensorTwo : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital temperature sensor located inside the insulated styrofoam box (sensor 2)."
    DTDFVocab:producedData InsideBoxTempDataMsgTwo
]

instance RoomTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital temperature sensor located outside the insulated box to measure room temperature."
    DTDFVocab:producedData RoomTempDataMsg
]

// C4: Physical-to-virtual interaction
instance InsideBoxTempDataMsgOne : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideBoxTempSensorOne
]

instance InsideBoxTempDataMsgTwo : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideBoxTempSensorTwo
]

instance RoomTempDataMsg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTempSensor
]

// C10: Models/Data
instance InsideBoxTempDataSeriesOne : DTDFVocab:Data [
    base:desc "Temperature time series from InsideBoxTempSensorOne."
    DTDFVocab:fromData InsideBoxTempDataMsgOne
    DTDFVocab:inputTo RabbitMQBrokerEnabler, PythonCalibrationToolEnabler
]

instance InsideBoxTempDataSeriesTwo : DTDFVocab:Data [
    base:desc "Temperature time series from InsideBoxTempSensorTwo."
    DTDFVocab:fromData InsideBoxTempDataMsgTwo
    DTDFVocab:inputTo RabbitMQBrokerEnabler, PythonCalibrationToolEnabler
]

instance RoomTempDataSeries : DTDFVocab:Data [
    base:desc "Temperature time series from RoomTempSensor."
    DTDFVocab:fromData RoomTempDataMsg
    DTDFVocab:inputTo RabbitMQBrokerEnabler, PythonCalibrationToolEnabler
]

instance ModelAThermal : DTDFVocab:Model [
    base:desc "Continuous‑time thermal model that assumes full energy transfer to the air parameterised by C_air, G_box, G_heater, C_heater."
    DTDFVocab:inputTo PythonCalibrationToolEnabler
]

instance ModelBThermal : DTDFVocab:Model [
    base:desc "Continuous‑time thermal model that incorporates heatbed heat capacity parameterised by C_air, G_box, G_heater, C_heater, C_heater."
    DTDFVocab:inputTo PythonCalibrationToolEnabler
]

// C11: Enablers
instance LowLevelDriverEnabler : DTDFVocab:Enabler [
    base:desc "Firmware on the Raspberry Pi that reads DS18S20 sensors over the 1‑Wire bus."
]

instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker (AMQP) running on the Raspberry Pi to publish sensor data and consumption."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveSimulationService, ParameterCalibrationService, BangBangControllerService
]

instance PythonCalibrationToolEnabler : DTDFVocab:Enabler [
    base:desc "Python environment (numpy, scipy) for nonlinear least‑squares calibration of continuous‑time thermal models."
    DTDFVocab:enables ParameterCalibrationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature inside the incubator."
    DTDFVocab:provides RealTimeTemperatureDataInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation of temperature evolution using ModelAThermal and ModelBThermal."
    DTDFVocab:provides PredictedTemperatureEvolutionInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Parameter calibration of thermal models using nonlinear least‑squares optimisation."
    DTDFVocab:provides ParameterMismatchDetectionInsight, HeatingScheduleRecommendationInsight, FanScheduleRecommendationInsight
]

instance BangBangControllerService : DTDFVocab:Service [
    base:desc "Closed‑loop temperature regulation using a bang‑bang controller that maintains temperature within defined limits."
    DTDFVocab:provides ApplyHeatingAdjustmentAction, ApplyFanAdjustmentAction
]

// C17: Insights/Actions
instance PredictedTemperatureEvolutionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature evolution over time based on the calibrated thermal models."
]

instance ParameterMismatchDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of mismatches between predicted and actual temperature profiles indicating the need for model re‑calibration."
]

instance HeatingScheduleRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation to adjust heating schedules to improve thermal performance."
]

instance FanScheduleRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation to adjust fan schedules to improve air circulation."
]

instance RealTimeTemperatureDataInsight : DTDFVocab:Insight [
    base:desc "Real‑time temperature readings from the incubator sensors."
]

instance ApplyHeatingAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of heatbed duty cycle based on controller output."
    DTDFVocab:IsAutomatic true
]

instance ApplyFanAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of fan speed based on controller output."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heating element (heatbed) controlled via MOSFETs to regulate temperature inside the incubator."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Air circulation fan controlled via optocouplers to improve temperature uniformity."
]

instance RaspberryPiControllerAct : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi 4 Model B that orchestrates sensor readouts, message brokering, calibration, and actuator control."
]

// Component instances (for completeness)
instance InsideBoxTempSensorComponentOne : DTDFVocab:Component [
    base:desc "DS18S20 temperature sensor mounted inside the insulated box."
]

instance InsideBoxTempSensorComponentTwo : DTDFVocab:Component [
    base:desc "DS18S20 temperature sensor mounted inside the insulated box."
]

instance RoomTempSensorComponent : DTDFVocab:Component [
    base:desc "DS18S20 temperature sensor mounted outside the insulated box."
]

instance HeatbedComponent : DTDFVocab:Component [
    base:desc "Heating element of the incubator."
]

instance FanComponent : DTDFVocab:Component [
    base:desc "Fan for air circulation."
]

instance RaspberryPiComponent : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running firmware, broker, and calibration tools."
]

// C7: Environment
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator, FanActuator, RaspberryPiControllerAct,
    InsideBoxTempSensorOne, InsideBoxTempSensorTwo, RoomTempSensor,
    InsideBoxTempSensorComponentOne, InsideBoxTempSensorComponentTwo, RoomTempSensorComponent,
    HeatbedComponent, FanComponent, RaspberryPiComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (turning the heatbed and fan ON/OFF, and setting actuators) to the RabbitMQ broker, which the Raspberry Pi controller consumes and forwards to the MOSFETs and fan driver, thereby actuating the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation comprises the PT (incubator), low‑level driver, communication server (RabbitMQ), controller, and the virtual model components that subscribe to sensor messages and publish actuator commands; the figure 7 depiction shows the directed data flow between these elements."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design of the incubator hardware and controller, manufacturing of the physical components, commissioning of the PT, and operational monitoring and simulation during the operated phase; the DT covers all phases through modelling, calibration, and live integration."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Assumptions of uniform temperature, negligible wall heat accumulation, constant air heat capacity, and negligible fan heat; experimental validation with three‑sensor temperature distribution (maximum discrepancy 7 °C); model parameters estimated via least‑squares with minimal residual error, providing quantitative fidelity checks."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT occurs over a local RabbitMQ AMQP broker hosted on the Raspberry Pi. Sensors connect via 1‑Wire bus to Pi GPIO; actuators connect via MOSFETs and optocoupler‑isolated GPIO lines. Optional network interfaces (Wi‑Fi or Bluetooth) are available on the Pi but not required for internal messaging."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire DT stack, including RabbitMQ, low‑level driver, controller, and modeling modules, is hosted locally on the Raspberry Pi 4, leveraging its built‑in Wi‑Fi and Bluetooth, enabling on‑device deployment without external servers."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is incorporated into the low‑level driver to maintain device safety; RabbitMQ provides a mature, lightweight message broker; no explicit security mechanisms are described beyond the standard RabbitMQ usage."
]