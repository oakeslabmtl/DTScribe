// ===============================
// Physical Acting Component
// ===============================
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed providing thermal energy to the insulated incubator enclosure controller sets heating power level via PWM/duty‑cycle commands."
]

// ===============================
// Physical Sensing Components
// ===============================
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor embedded in the incubator chamber, continuously sampled."
    DTDFVocab:producedData IncubatorTempDataTransmitted
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second internal temperature sensor embedded in the incubator chamber, continuously sampled."
    DTDFVocab:producedData IncubatorTempDataTransmitted
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor attached to the incubator outer wall, continuously sampled."
    DTDFVocab:producedData IncubatorTempDataTransmitted
]

// ===============================
// Physical‑to‑Virtual Interaction
// ===============================
instance IncubatorTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1, InternalTempSensor2, ExternalTempSensor
]

// ===============================
// Data Layer
// ===============================
instance IncubatorTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements (°C) collected from the three incubator sensors."
    DTDFVocab:fromData IncubatorTempDataTransmitted
    DTDFVocab:inputTo MonitoringEnabler, SimulationEngineEnabler, OptimisationEnabler, CalibrationEnabler
]

// ===============================
// Models
// ===============================
instance ReducedThermalModel : DTDFVocab:Model [
    base:desc "Reduced thermal dynamics model of the incubator with two free parameters, implemented in software."
    DTDFVocab:inputTo SimulationEngineEnabler, OptimisationEnabler, CalibrationEnabler
]

instance HighOrderThermalModel : DTDFVocab:Model [
    base:desc "Higher‑order thermal dynamics model with four free parameters capturing heat‑bed inertia, implemented in software."
    DTDFVocab:inputTo SimulationEngineEnabler, OptimisationEnabler, CalibrationEnabler
]

// ===============================
// Enablers (modeled as generic components to avoid class disjointness)
// ===============================
instance CalibrationEnabler : DTDFVocab:Component [
    base:desc "Calibration algorithm that adjusts model parameters to minimise prediction error using incoming temperature data."
    DTDFVocab:enables ModelCalibrationService
]

instance SimulationEngineEnabler : DTDFVocab:Component [
    base:desc "Simulation engine that runs calibrated thermal models to predict temperature evolution."
    DTDFVocab:enables SimulationPredictionService
]

instance MonitoringEnabler : DTDFVocab:Component [
    base:desc "Monitoring component that compares measured and simulated temperatures against safety/optimality thresholds."
    DTDFVocab:enables ContinuousMonitoringService, SafetyOptimisationService
]

instance OptimisationEnabler : DTDFVocab:Component [
    base:desc "Optimization routine that proposes control actions to keep temperature within optimal range."
    DTDFVocab:enables SafetyOptimisationService, FaultDetectionService
]

instance FaultDetectionEnabler : DTDFVocab:Component [
    base:desc "Fault detection and supervisory control logic that identifies abnormal behavior and triggers corrective actions."
    DTDFVocab:enables FaultDetectionService
]

instance VisualisationEnabler : DTDFVocab:Component [
    base:desc "Advanced visualisation tool presenting temperature trajectories and alerts to engineers and operators."
    DTDFVocab:enables VisualisationService
]

instance RaspberryPiControllerEnabler : DTDFVocab:Component [
    base:desc "Raspberry Pi hardware and software platform hosting calibration, simulation, monitoring and control algorithms (source code at https://github.com/INTO-CPS-Association/example-incubator)."
    DTDFVocab:enables ModelCalibrationService, SimulationPredictionService, ContinuousMonitoringService, SafetyOptimisationService, FaultDetectionService, VisualisationService
]

// ===============================
// Services
// ===============================
instance SimulationPredictionService : DTDFVocab:Service [
    base:desc "Simulation‑based prediction of the incubator’s thermal behaviour."
    DTDFVocab:provides PredictedTemperatureInsight
]

instance ContinuousMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of sensor data for safety and performance."
    DTDFVocab:provides SafetyViolationAlertInsight, IssueAlertAction
]

instance SafetyOptimisationService : DTDFVocab:Service [
    base:desc "Safety and performance optimisation through calibrated models."
    DTDFVocab:provides PerformanceOptimizationInsight, AdjustHeaterSetpointAction, AdjustFanSpeedAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection and supervisory control of the incubator."
    DTDFVocab:provides FaultDetectionInsight, ExecuteControlCommandAction
]

instance VisualisationService : DTDFVocab:Service [
    base:desc "Advanced visualisation of temperature evolution for engineers and operators."
    DTDFVocab:provides TemperatureEvolutionVisualisationInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Automated calibration of thermal models using incoming temperature data."
    DTDFVocab:provides ModelCalibrationInsight
]

// ===============================
// Insights
// ===============================
instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory of the incubator chamber over the forecasting horizon."
]

instance SafetyViolationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating that measured or predicted temperature exceeds predefined safety thresholds."
]

instance PerformanceOptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommendation to adjust heater power or fan speed to improve temperature regulation performance."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of anomalous sensor readings or actuator behavior requiring supervisory intervention."
]

instance TemperatureEvolutionVisualisationInsight : DTDFVocab:Insight [
    base:desc "Graphical visualisation of historical and predicted temperature evolution for operator situational awareness."
]

instance ModelCalibrationInsight : DTDFVocab:Insight [
    base:desc "Report of calibrated model parameters and associated prediction error statistics."
]

// ===============================
// Actions
// ===============================
instance AdjustHeaterSetpointAction : DTDFVocab:Action [
    base:desc "Command to change the heat‑bed power set‑point via the controller."
    DTDFVocab:IsAutomatic true
]

instance AdjustFanSpeedAction : DTDFVocab:Action [
    base:desc "Command to modify fan speed to influence air circulation."
    DTDFVocab:IsAutomatic true
]

instance IssueAlertAction : DTDFVocab:Action [
    base:desc "Generate and dispatch an alert to operators when safety or optimality thresholds are violated."
    DTDFVocab:IsAutomatic true
]

instance ExecuteControlCommandAction : DTDFVocab:Action [
    base:desc "Execute supervisory control command (e.g., emergency shutdown or safe‑mode activation)."
    DTDFVocab:IsAutomatic false
]

// ===============================
// Environment (aggregation)
// ===============================
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, InternalTempSensor1, InternalTempSensor2, ExternalTempSensor, RaspberryPiControllerEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin produces control actions such as target temperature set‑points and fan activation commands based on simulation and optimisation algorithms. These commands are sent to the Raspberry Pi, which drives the heatbed and fan actuators of the incubator. The documents do not detail command formats, validation/authentication mechanisms, feedback loops, conflict resolution, or execution confirmation procedures."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin follows a CPS‑based architecture where sensor data collected from the physical incubator are supplied to calibration algorithms that update the cyber‑physical system (CPS) models and environmental models. Updated models feed monitoring components that assess safety and optimality of operation. When a violation is detected, humans or higher‑level algorithms may decide to modify the physical twin. This orchestration integrates data, models, and algorithms as described in Document 1."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed experimentally by comparing predicted temperature trajectories against the measured sensor data. The four‑parameter model demonstrated higher fidelity in reproducing the heat‑bed’s thermal inertia, and therefore was selected for further DT development. Validation consists of running the simulation with the calibrated parameters and quantifying prediction error. Uncertainty arises from sensor noise, unmodelled environmental influences, and parameter estimation error; the DT mitigates these through calibration algorithms that continuously update model parameters. Quality assurance is provided by the monitoring component that flags deviations beyond acceptable error thresholds."
]