// Components Definitions
instance StyrofoamInsulatedBox : DTDFVocab:Component [
    base:desc "Polystyrene insulated styrofoam box forming the thermal incubator enclosure"
]

instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed distributed by a MOSFET controlled by the Raspberry Pi, provides uniform heating across the box"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12V or 24V fan, speed controlled via MOSFET, circulates air inside the incubator"
]

instance RaspberryPiControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi 4 Model B receives commands from the Digital Twin and drives the heatbed and fan actuators"
]

instance PCBWithMOSFETs : DTDFVocab:Component [
    base:desc "Printed circuit board managing MOSFETs and optocouplers to drive heatbed and fan"
]

instance PowerSupplyUnit : DTDFVocab:Component [
    base:desc "Power supply delivering required voltage to the incubator system"
]

instance RabbitMQBroker : DTDFVocab:Component [
    base:desc "AMQP broker that transmits sensor data and receives actuator commands between the physical system and the Digital Twin"
]

instance PythonLowLevelDriver : DTDFVocab:Component [
    base:desc "Python driver that reads 1‑Wire sensor data via GPIO and publishes them to RabbitMQ"
]

// Environment Definition
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains StyrofoamInsulatedBox, HeatbedActuator, FanActuator,
                  RaspberryPiControllerActuator, PCBWithMOSFETs,
                  PowerSupplyUnit, RabbitMQBroker, PythonLowLevelDriver
]

// Data Transmitted from Physical to Virtual
instance InBoxTempTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InBoxDS18S20Sensor1
]

instance InBoxTempTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InBoxDS18S20Sensor2
]

instance OutsideTempTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideDS18S20Sensor
]

instance FanStatusTransmitted : DTDFVocab:DataTransmitted [
    // Created by fan actuator status monitoring (no producedFrom relation)
]

instance PowerConsumptionTransmitted : DTDFVocab:DataTransmitted [
    // Created by power supply status monitoring (no producedFrom relation)
]

// Sensing Components
instance InBoxDS18S20Sensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer located inside the incubator, connected via GPIO 18"
    DTDFVocab:producedData InBoxTempTransmitted1
]

instance InBoxDS18S20Sensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer located inside the incubator, connected via GPIO 17"
    DTDFVocab:producedData InBoxTempTransmitted2
]

instance OutsideDS18S20Sensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer located outside the incubator, connected via GPIO 27"
    DTDFVocab:producedData OutsideTempTransmitted
]

// Enablers
instance DataMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Processes raw data streams for real‑time monitoring and alerting"
]

instance ThermalSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Runs predictive simulations using thermal models to forecast temperature trajectory"
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Performs least‑squares optimization using SciPy to calibrate model parameters"
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Detects anomalies in temperature trends and raises alerts"
]

instance BangBangControlEnabler : DTDFVocab:Enabler [
    base:desc "Supervisory bang‑bang controller that issues heating commands based on DT predictions"
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of internal temperature, fan status, and power consumption"
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Provides future temperature trajectory forecasts using two thermal models"
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration of thermal model parameters via least‑squares optimization"
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects abnormal temperature patterns and issues fault alerts"
]

instance BangBangControlService : DTDFVocab:Service [
    base:desc "Issues bang‑bang heating command based on DT predictions and setpoints"
]

// Insights
instance CalibratedModelParametersInsight : DTDFVocab:Insight [
    base:desc "Delivered calibrated parameters: G_box, G_heater, C_air, C_heater"
]

instance FutureTemperatureTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature evolution trajectory for the next 30 minutes"
]

instance AnomalyDetectionAlertInsight : DTDFVocab:Insight [
    base:desc "Alert raised when temperature trend deviates beyond acceptable threshold"
]

instance OptimalHeatingScheduleInsight : DTDFVocab:Insight [
    base:desc "Optimized heating schedule to maintain target temperature while minimizing energy"
]

instance RealTimeTemperatureInsight : DTDFVocab:Insight [
    base:desc "Current live temperature reading from heatbed and external sensors"
]

instance FaultAlertInsight : DTDFVocab:Insight [
    base:desc "General fault alert for hardware or communication failures"
]

// Action
instance BangBangHeatingCommandAction : DTDFVocab:Action [
    base:desc "Bang‑bang heating command issued to the heatbed MOSFET driver via the Raspberry Pi controller"
    DTDFVocab:IsAutomatic true
]

// Data Series
instance InBoxTempSeries1 : DTDFVocab:Data [
    base:desc "Time‑series of internal temperature measurements from InBoxDS18S20Sensor1"
    DTDFVocab:fromData InBoxTempTransmitted1
]

instance InBoxTempSeries2 : DTDFVocab:Data [
    base:desc "Time‑series of internal temperature measurements from InBoxDS18S20Sensor2"
    DTDFVocab:fromData InBoxTempTransmitted2
]

instance OutsideTempSeries : DTDFVocab:Data [
    base:desc "Time‑series of external temperature measurements from OutsideDS18S20Sensor"
    DTDFVocab:fromData OutsideTempTransmitted
]

instance FanStatusSeries : DTDFVocab:Data [
    base:desc "Time‑series of fan status (on/off) information from FanActuator"
    DTDFVocab:fromData FanStatusTransmitted
]

instance PowerConsumptionSeries : DTDFVocab:Data [
    base:desc "Time‑series of power consumption read from PowerSupplyUnit"
    DTDFVocab:fromData PowerConsumptionTransmitted
]

// Derived Model Parameters
instance DerivedG_Box : DTDFVocab:Data [
    base:desc "Estimated thermal conductance between box and environment (G_box)"
]

instance DerivedG_Heater : DTDFVocab:Data [
    base:desc "Estimated thermal conductance of heatbed to enclosure (G_heater)"
]

instance DerivedC_Air : DTDFVocab:Data [
    base:desc "Estimated thermal capacity of air inside the incubator (C_air)"
]

instance DerivedC_Heater : DTDFVocab:Data [
    base:desc "Estimated thermal capacity of the heatbed (C_heater)"
]

// Thermal Models
instance TwoParameterThermalModelA : DTDFVocab:Model [
    base:desc "Two-parameter thermal model (Model A) using measured temperature, power, and fan status"
]

instance FourParameterThermalModelB : DTDFVocab:Model [
    base:desc "Four-parameter thermal model (Model B) incorporating G_box, G_heater, C_air, C_heater"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin publishes control commands (heatbed on/off, fan speed adjustments) to designated RabbitMQ queues, which the low‑level driver consumes and forwards to the GPIO pins via MOSFETs to actuate the heatbed and fan."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of a RabbitMQ broker, a low‑level driver subscribing to sensor data and publishing actuator commands, and a controller implementing bang‑bang logic. The Digital Twin runs in the same physical node and consumes/produces messages via RabbitMQ queues, enabling tight integration between the PT and virtual simulation components."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle includes (i) design – development of mathematical models and simulation tools; (ii) manufacturing – construction of the physical incubator and assembly of hardware; (iii) deployment – installation of the Raspberry Pi, RabbitMQ, and drivers; (iv) operation – continuous monitoring, calibration, and model update during real‑time use."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity governed by simplifying assumptions (1: uniform temperature; 2: negligible heat transfer to walls; 3: constant specific heat; 4: neglecting heat from fan). Validation achieved by experimental comparison, residual error minimization, and iterative parameter update. Uncertainty quantified via least‑squares residuals; model adequacy evaluated by fit to empirical data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical–virtual communication uses the RabbitMQ AMQP broker running on the same Raspberry Pi; commands and sensor data are exchanged via defined message queues. Sensor data is transmitted over the 1‑Wire bus from DS18S20 to the Pi, then forwarded to RabbitMQ. The Pi connects to external network (Wi‑Fi) for optional remote access."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin is hosted locally on the Raspberry Pi 4 Model B running a lightweight Linux (Raspbian) environment; RabbitMQ is installed directly on the Pi; all other software components (driver, controller, simulation scripts) are executed as local processes."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is embedded in the low‑level driver to prevent unsafe actuator states; the bang‑bang controller includes hysteresis (LL, UL, H, C). The system limits fan current to 4 A using MOSFETs, isolating the Pi via optocouplers. No explicit cybersecurity measures are described, but localized deployment reduces exposure."
]