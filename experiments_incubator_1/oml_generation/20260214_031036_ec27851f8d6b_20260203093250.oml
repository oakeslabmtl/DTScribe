// Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heater (heat‑bed) driven through MOSFET switches on the custom PCB, used to raise incubator air temperature."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Low‑speed fan mounted inside the incubator for air circulation, controlled via MOSFET switches on the custom PCB."
]

// Physical Sensing Components
instance IncubatorTempSensorInside1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital temperature sensor mounted inside the incubator box (±0.5 °C accuracy, –10 °C to +85 °C range)."
    DTDFVocab:producedData SensorTelemetryMessage
]

instance IncubatorTempSensorInside2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 sensor inside the incubator box (identical specifications to Inside1)."
    DTDFVocab:producedData SensorTelemetryMessage
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor placed outside the incubator to measure ambient room temperature (±0.5 °C accuracy, –10 °C to +85 °C range)."
    DTDFVocab:producedData SensorTelemetryMessage
]

// Data Transmitted (PT‑to‑DT stream)
instance SensorTelemetryMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorTempSensorInside1, IncubatorTempSensorInside2, AmbientTempSensor
]

// Data Asset
instance IncubatorTelemetryData : DTDFVocab:Data [
    base:desc "Combined temperature readings and actuator states published to RabbitMQ, serving as input for models and visualisation."
    DTDFVocab:fromData SensorTelemetryMessage
    DTDFVocab:inputTo SimulationEngineEnabler, VisualizationEngineEnabler
]

// Thermal Models
instance ModelA : DTDFVocab:Model [
    base:desc "Physics‑based thermal model A: single air capacitance C_air and heat‑transfer conductance G_box."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance ModelB : DTDFVocab:Model [
    base:desc "Physics‑based thermal model B: adds heat‑bed capacitance C_heater and conductance G_heater to Model A."
    DTDFVocab:inputTo SimulationEngineEnabler
]

// Enablers
instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker on the Raspberry Pi providing asynchronous PT‑to‑DT communication."
    DTDFVocab:enables TemperatureMonitoringService, PredictiveSimulationService, ParameterCalibrationService, FaultDetectionService, TemperatureVisualizationService
]

instance SciPyCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Python SciPy non‑linear least‑squares optimiser used for model parameter calibration."
    DTDFVocab:enables ParameterCalibrationService
]

instance StateChartEngineEnabler : DTDFVocab:Enabler [
    base:desc "State‑chart engine monitoring temperature limits and generating safety alerts."
    DTDFVocab:enables FaultDetectionService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python simulation engine that consumes telemetry data and thermal models to produce predictive temperature trajectories."
    DTDFVocab:enables PredictiveSimulationService
]

instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Visualization stack (e.g., Grafana) rendering real‑time temperature trends for operators."
    DTDFVocab:enables TemperatureVisualizationService
]

// Services
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time temperature monitoring service consuming telemetry data."
    DTDFVocab:provides TemperatureTrendInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation service generating future temperature profiles using Model A or Model B."
    DTDFVocab:provides PredictiveTemperatureInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Parameter calibration service that fits model coefficients via SciPy optimisation."
    DTDFVocab:provides CalibratedParametersInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection service employing a state‑chart to detect limit violations."
    DTDFVocab:provides SafetyViolationInsight, OperatorAlertAction
]

instance TemperatureVisualizationService : DTDFVocab:Service [
    base:desc "Visualization service displaying temperature trends and supporting operator decision‑making."
    DTDFVocab:provides TemperatureTrendInsight
]

// Insights
instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Calibrated model parameters are continuously supplied to operators for validation against temperature limits."
]

instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Real‑time temperature trends are presented to help operators maintain the incubator within defined bounds."
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "State‑chart monitor detects temperature limit breaches and flags a safety violation."
]

instance PredictiveTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted future temperature trajectory informs proactive set‑point adjustments."
]

// Actions
instance AdjustSetPointAction : DTDFVocab:Action [
    base:desc "Operator manually adjusts the incubator temperature set‑point based on insights."
    DTDFVocab:IsAutomatic false
]

instance OperatorAlertAction : DTDFVocab:Action [
    base:desc "System automatically sends an alert to the operator when a safety violation is detected."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT components send control commands (heat‑bed on/off, fan on/off) as RabbitMQ messages which are consumed by the low‑level driver and forwarded to the MOSFET drivers on the PCB to actuate the physical devices."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture comprises a controller running on the Raspberry Pi, a low‑level driver that interfaces with sensors and actuators, a RabbitMQ communication server that mediates message exchange, and DT service modules that subscribe to sensor streams, run the calibrated thermal models, and publish control commands; all components are co‑located on the Raspberry Pi platform."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is based on four key assumptions (uniform air temperature, negligible wall heat storage, constant air specific heat, and either full power conversion to air heat or inclusion of heat‑bed dynamics). Uniformity was experimentally verified by comparing temperatures at three locations with the fan on; calibration residuals were minimised using non‑linear least‑squares to ensure validity of the parameter estimates."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "PT‑DT communication uses the AMQP protocol implemented by RabbitMQ running locally on the Raspberry Pi; messages are exchanged over the Pi’s built‑in Wi‑Fi or Ethernet interfaces, and the low‑level driver enforces a safe‑state protocol before applying commands to the MOSFET drivers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components (controller, driver, RabbitMQ broker, model execution) are hosted on the Raspberry Pi 4 Model B itself, providing an on‑edge deployment; the complete hardware schematics, firmware and software source code are publicly available in a GitHub repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe‑protocol that forces the PT into a safe state on communication loss; electrical isolation between the Raspberry Pi and the high‑current MOSFET switches is achieved with optocouplers, reducing risk of accidental over‑current or unintended actuation."
]