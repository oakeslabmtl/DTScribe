// C3: Physical sensing components
instance InsideHotSpotTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer placed at the hot spot inside the incubator (range –55 °C to +125 °C, accuracy ±0.5 °C within 10 °C‑85 °C)"
    DTDFVocab:producedData InsideHotSpotTempDataTransmitted
]

instance InsideColdSpotTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer placed at the cold spot inside the incubator (range –55 °C to +125 °C, accuracy ±0.5 °C within 10 °C‑85 °C)"
    DTDFVocab:producedData InsideColdSpotTempDataTransmitted
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring room temperature (range –55 °C to +125 °C, accuracy ±0.5 °C within 10 °C‑85 °C)"
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance InsideHotSpotTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideHotSpotTempSensor
]

instance InsideColdSpotTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideColdSpotTempSensor
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

instance CalibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideHotSpotTempSensor,
                 InsideColdSpotTempSensor,
                 AmbientTempSensor
]

// C5: Data
instance InsideHotSpotTempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from the hot‑spot sensor"
    DTDFVocab:fromData InsideHotSpotTempDataTransmitted
]

instance InsideColdSpotTempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from the cold‑spot sensor"
    DTDFVocab:fromData InsideColdSpotTempDataTransmitted
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from the ambient sensor"
    DTDFVocab:fromData AmbientTempDataTransmitted
]

instance CalibrationDataset : DTDFVocab:Data [
    base:desc "Time‑stamped temperature series from the three sensors collected for model parameter calibration"
    DTDFVocab:fromData CalibrationDataTransmitted
]

// C11: Enablers
instance RabbitMQMessageBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker running on the Raspberry Pi, transports sensor measurements to the Digital Twin"
    DTDFVocab:enables RuntimeTemperatureMonitoringService,
                 FaultDetectionService,
                 HeatingCycleOptimizationService
]

instance PythonSciPyOptimizerEnabler : DTDFVocab:Enabler [
    base:desc "Python SciPy non‑linear least‑squares optimizer used for calibration of thermal model parameters"
    DTDFVocab:enables ParameterCalibrationService
]

instance BangBangControllerEnabler : DTDFVocab:Enabler [
    base:desc "Bang‑bang controller implementing heating‑cycle optimisation with configurable temperature limits and dwell times"
    DTDFVocab:enables HeatingCycleOptimizationService
]

// C6: Services
instance RuntimeTemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Monitors incoming temperature data against configured lower and upper limits in real time"
    DTDFVocab:provides TemperatureLimitExceededInsight,
                 TemperatureWithinLimitsInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects safety violations such as sensor failure or unexpected power‑switch events"
    DTDFVocab:provides SafetyViolationDetectedInsight
]

instance HeatingCycleOptimizationService : DTDFVocab:Service [
    base:desc "Optimises heating cycles using a bang‑bang controller, adjusting heating and waiting durations based on model predictions"
    DTDFVocab:provides AdjustHeatingAction,
                 AdjustWaitingDurationAction
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates model parameters (C_air, G_box, C_heater, G_heater) using SciPy least‑squares optimisation on collected temperature data"
    DTDFVocab:provides ModelParametersUpdatedInsight
]

instance ModelBasedPredictionService : DTDFVocab:Service [
    base:desc "Provides model‑based temperature trajectory predictions using calibrated Model A or Model B"
    DTDFVocab:provides TemperaturePredictionInsight
]

// C17: Insights
instance TemperatureLimitExceededInsight : DTDFVocab:Insight [
    base:desc "Alert generated when measured temperature exceeds configured safety limits"
]

instance TemperatureWithinLimitsInsight : DTDFVocab:Insight [
    base:desc "Indicates that temperature is within the acceptable operating range"
]

instance SafetyViolationDetectedInsight : DTDFVocab:Insight [
    base:desc "Indicates detection of a safety violation such as unexpected power state or sensor fault"
]

instance ModelParametersUpdatedInsight : DTDFVocab:Insight [
    base:desc "Calibration has updated the thermal model parameters (C_air, G_box, C_heater, G_heater)"
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory generated by the selected thermal model"
]

// C17: Actions
instance AdjustHeatingAction : DTDFVocab:Action [
    base:desc "Automatically turns the heatbed on or off to enforce the bang‑bang setpoint"
    DTDFVocab:IsAutomatic true
]

instance AdjustWaitingDurationAction : DTDFVocab:Action [
    base:desc "Modifies the waiting (cooling) duration in the heating cycle based on model feedback"
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed (214 mm × 214 mm × 3 mm) driven by a MOSFET switch on the PCB to supply heating power"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal fan (≈0.02 m³·s⁻¹) driven by a MOSFET switch on the PCB to circulate air inside the incubator"
]

// C8: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single‑parameter thermal model (Model A) of the incubator"
    DTDFVocab:inputTo PythonSciPyOptimizerEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Four‑parameter thermal model (Model B) including heater thermal inertia"
    DTDFVocab:inputTo PythonSciPyOptimizerEnabler
]

// C9: Components / Environment
instance RaspberryPiHardware : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running Linux, hosts RabbitMQ broker and low‑level driver"
]

instance CustomPCB : DTDFVocab:Component [
    base:desc "Custom PCB with MOSFETs and optocouplers for safe power switching of heatbed and fan"
]

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator,
                 FanActuator,
                 InsideHotSpotTempSensor,
                 InsideColdSpotTempSensor,
                 AmbientTempSensor,
                 RaspberryPiHardware,
                 CustomPCB
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT (or any client) publishes command messages to the same RabbitMQ broker; the controller subscribed to these topics receives commands and drives the heatbed and fan via the PCB, thus forming the DT→PT control path."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture comprises the PT hardware, a Raspberry Pi controller, a low‑level driver that abstracts sensor/actuator I/O, a RabbitMQ communication server that mediates messages, and DT components that subscribe to the broker to receive sensor data, run the predictive models, perform calibration, and publish control commands. All components can be deployed on the same Pi (centralised) or distributed across networked nodes."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity relies on four assumptions: uniform temperature (validated by fan‑induced mixing experiments showing ≤7 °C spread), negligible wall heat storage, constant air specific heat capacity, and (for Model A) full conversion of electrical power to heat. Model B relaxes the last assumption by modelling heater thermal inertia. Calibration reduces residual error, and experimental uniformity tests assess the validity of the uniform‑temperature assumption."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical components are wired to the Raspberry Pi GPIO pins; the low‑level driver accesses sensors and actuators through MOSFET drivers and optocouplers on the PCB. Software communication between driver, controller, and DT services uses the RabbitMQ message broker running locally on the Pi, employing its native messaging protocol over the Pi’s network stack (TCP/IP)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ broker, low‑level driver, and controller all execute on the Raspberry Pi 4 Model B, providing an on‑device, edge‑hosted DT deployment."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver implements a safe protocol that forces the hardware into a known safe state on communication loss. The DT includes monitoring for safety violations (temperature limits) and can trigger shutdown commands. Use of optocouplers isolates the Raspberry Pi control signals from high‑current actuator circuits."
]