// --------------------------------------------------------------
// Physical Sensing Components
// --------------------------------------------------------------
instance IncubatorTempSensorInside1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (range –55 °C to +125 °C, accuracy ±0.5 °C) measuring temperature inside the incubator at location 1."
    DTDFVocab:producedData TempDataTransmittedInside1
]

instance IncubatorTempSensorInside2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (range –55 °C to +125 °C, accuracy ±0.5 °C) measuring temperature inside the incubator at location 2."
    DTDFVocab:producedData TempDataTransmittedInside2
]

instance AmbientTempSensorOutside : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (range –55 °C to +125 °C, accuracy ±0.5 °C) measuring ambient room temperature outside the incubator."
    DTDFVocab:producedData TempDataTransmittedOutside
]

// --------------------------------------------------------------
// Data Transmitted from Sensors (AMQP via RabbitMQ)
// --------------------------------------------------------------
instance TempDataTransmittedInside1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorTempSensorInside1
]

instance TempDataTransmittedInside2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorTempSensorInside2
]

instance TempDataTransmittedOutside : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensorOutside
]

// --------------------------------------------------------------
// Data Objects derived from transmitted messages
// --------------------------------------------------------------
instance TempDataInside1 : DTDFVocab:Data [
    base:desc "Timestamped air temperature reading from incubator location 1."
    DTDFVocab:fromData TempDataTransmittedInside1
    DTDFVocab:inputTo RabbitMQMessageBroker
]

instance TempDataInside2 : DTDFVocab:Data [
    base:desc "Timestamped air temperature reading from incubator location 2."
    DTDFVocab:fromData TempDataTransmittedInside2
    DTDFVocab:inputTo RabbitMQMessageBroker
]

instance TempDataOutside : DTDFVocab:Data [
    base:desc "Timestamped ambient temperature reading from outside the incubator."
    DTDFVocab:fromData TempDataTransmittedOutside
    DTDFVocab:inputTo RabbitMQMessageBroker
]

// --------------------------------------------------------------
// Power Measurement (generated by actuation driver)
// --------------------------------------------------------------
instance PowerMeasurementTransmitted : DTDFVocab:DataTransmitted [
    // Note: producedFrom omitted to avoid disjointness conflict
]

instance PowerMeasurementData : DTDFVocab:Data [
    base:desc "Timestamped power input (V·I·Δt) measured during heating‑bed and fan actuation."
    DTDFVocab:fromData PowerMeasurementTransmitted
    DTDFVocab:inputTo RabbitMQMessageBroker
]

// --------------------------------------------------------------
// Enablers (Software / Middleware)
// --------------------------------------------------------------
instance RabbitMQMessageBroker : DTDFVocab:Enabler [
    base:desc "Local AMQP broker running on the Raspberry Pi, receives sensor and power data streams."
    DTDFVocab:enables TemperatureMonitoringService, ModelCalibrationService, SafetyMonitoringService, RealTimeDataIngestionService
]

instance CalibrationOptimizer : DTDFVocab:Enabler [
    base:desc "Python SciPy non‑linear least‑squares optimizer used for real‑time model parameter calibration."
    DTDFVocab:enables ModelCalibrationService
]

instance ThermalSimulationEngine : DTDFVocab:Enabler [
    base:desc "Runtime engine executing calibrated thermal models (Model A and Model B) for internal temperature prediction."
    DTDFVocab:enables RealTimeThermalSimulationService
]

// --------------------------------------------------------------
// Acting Components
// --------------------------------------------------------------
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET driver controlled by Raspberry Pi providing on/off power to the heat‑bed."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "GPIO‑controlled 12‑24 V fan circulating air inside the incubator."
]

// --------------------------------------------------------------
// Models
// --------------------------------------------------------------
instance ModelA : DTDFVocab:Model [
    base:desc "Dynamic thermal model predicting air temperature only, parameterised by C_air, G_box."
    DTDFVocab:inputTo ThermalSimulationEngine
]

instance ModelB : DTDFVocab:Model [
    base:desc "Dynamic thermal model predicting air temperature with heat‑bed inertia, parameterised by C_air, G_box, C_heater, G_heater."
    DTDFVocab:inputTo ThermalSimulationEngine
]

// --------------------------------------------------------------
// Services
// --------------------------------------------------------------
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Monitors incoming temperature streams, detects stability violations and triggers heating adjustments."
    DTDFVocab:provides TemperatureStabilityInsight, HeatingAdjustmentAction
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Consumes temperature and power data to calibrate Model A and Model B parameters via SciPy optimisation."
    DTDFVocab:provides RefinedParametersInsight, ParameterUpdateAction
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Analyzes temperature trends for safety thresholds and raises alerts or performs emergency shutdown."
    DTDFVocab:provides SafetyAlertInsight, SafetyShutdownAction
]

instance RealTimeThermalSimulationService : DTDFVocab:Service [
    base:desc "Runs calibrated Model A and Model B in real time to simulate internal temperature for decision support."
    DTDFVocab:provides InternalTemperatureInsight
]

instance RealTimeDataIngestionService : DTDFVocab:Service [
    base:desc "Provides a unified data store for raw sensor and power measurements."
    DTDFVocab:provides DataIngestionInsight
]

// --------------------------------------------------------------
// Insights
// --------------------------------------------------------------
instance TemperatureStabilityInsight : DTDFVocab:Insight [
    base:desc "Indicates whether the incubator temperature stays within the target band during operation."
]

instance RefinedParametersInsight : DTDFVocab:Insight [
    base:desc "Shows updated calibrated values for C_air, G_box, C_heater, G_heater after each optimisation cycle."
]

instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Detects unsafe temperature excursions (over‑/under‑temperature) and flags them for immediate action."
]

instance InternalTemperatureInsight : DTDFVocab:Insight [
    base:desc "Provides predicted internal temperature from the calibrated thermal models."
]

instance DataIngestionInsight : DTDFVocab:Insight [
    base:desc "Confirms successful ingestion and storage of latest sensor and power data points."
]

// --------------------------------------------------------------
// Actions
// --------------------------------------------------------------
instance HeatingAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjusts heat‑bed on‑time or fan speed to bring temperature back into the target range."
    DTDFVocab:IsAutomatic false
]

instance ParameterUpdateAction : DTDFVocab:Action [
    base:desc "Pushes newly calibrated model parameters to the controller for next‑run predictions."
    DTDFVocab:IsAutomatic true
]

instance SafetyShutdownAction : DTDFVocab:Action [
    base:desc "Immediately disables heat‑bed and fan to protect the incubated specimens."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (heat‑bed ON/OFF, fan speed) to the same RabbitMQ broker; the controller subscribes, interprets the messages and issues actuation signals through the low‑level driver to the MOSFET/optocoupler interface."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized architecture where the Physical Twin components (sensors, actuators, controller) communicate via the low‑level driver to a RabbitMQ broker on the Raspberry Pi; DT modules (model simulator, calibrator, monitor) subscribe/publish to the broker, forming a closed loop between PT and DT."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle includes model design (creation of Model A and Model B), calibration (parameter identification using experimental temperature trajectories), deployment (RabbitMQ and DT services running on the Raspberry Pi), and operational monitoring during runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by explicit assumptions (uniform temperature, negligible wall heat, constant air specific heat, heat‑bed heat loss), validated through uniformity experiments (≤7 °C deviation across sensors) and calibration error minimisation via non‑linear least‑squares; Model B shows higher fidelity for heat‑bed inertia."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT is realized over the local network using RabbitMQ (AMQP protocol) running on the Raspberry Pi; messages are exchanged via TCP/IP between the controller, low‑level driver, and DT services."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT software (RabbitMQ broker, model simulators, calibration routine) is hosted on the Raspberry Pi 4 Model B that also runs the controller and low‑level driver."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the device in a safe state; the DT includes monitoring for safety violations and can halt actuation commands. Communication uses RabbitMQ, which provides user authentication and encryption options (though not explicitly detailed)."
]