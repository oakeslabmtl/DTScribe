// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InsulatedStyrofoamBox, HeatBedComponent, FanComponent,
                   InteriorTemperatureSensor1, InteriorTemperatureSensor2, InteriorTemperatureSensor3
]

// Components
instance InsulatedStyrofoamBox : DTDFVocab:Component [
    base:desc "Insulated styrofoam enclosure forming the incubator body"
]

instance HeatBedComponent : DTDFVocab:Component [
    base:desc "Integrated heat source that maintains the desired temperature"
]

instance FanComponent : DTDFVocab:Component [
    base:desc "Air circulation fan ensuring uniform temperature distribution"
]

// Sensing Components
instance InteriorTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded near the top rack of the incubator"
    DTDFVocab:producedData TempDataTransmitted1
]

instance InteriorTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded near the middle section of the incubator"
    DTDFVocab:producedData TempDataTransmitted2
]

instance InteriorTemperatureSensor3 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded near the bottom zone of the incubator"
    DTDFVocab:producedData TempDataTransmitted3
]

// Data Transmitted
instance TempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTemperatureSensor1
]

instance TempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTemperatureSensor2
]

instance TempDataTransmitted3 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTemperatureSensor3
]

// Data (time-series)
instance InteriorTempData1 : DTDFVocab:Data [
    base:desc "Time‑series temperature readings from InteriorTemperatureSensor1"
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler,
                 DecisionSupportEnabler, SimulationPredictionEnabler
    DTDFVocab:fromData TempDataTransmitted1
]

instance InteriorTempData2 : DTDFVocab:Data [
    base:desc "Time‑series temperature readings from InteriorTemperatureSensor2"
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler,
                 DecisionSupportEnabler, SimulationPredictionEnabler
    DTDFVocab:fromData TempDataTransmitted2
]

instance InteriorTempData3 : DTDFVocab:Data [
    base:desc "Time‑series temperature readings from InteriorTemperatureSensor3"
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler,
                 DecisionSupportEnabler, SimulationPredictionEnabler
    DTDFVocab:fromData TempDataTransmitted3
]

// Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Module that calibrates the dynamic thermal model using observed sensor data"
    DTDFVocab:enables OptimizationCalibrationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Module that performs safety and performance monitoring by comparing real‑time data to calibrated model predictions"
    DTDFVocab:enables MonitoringService
]

instance DecisionSupportEnabler : DTDFVocab:Enabler [
    base:desc "Module that generates actionable insights and control commands when thresholds are breached"
    DTDFVocab:enables DecisionControlSupportService
]

instance SimulationPredictionEnabler : DTDFVocab:Enabler [
    base:desc "Runs dynamic thermal model to predict future temperature trajectories"
    DTDFVocab:enables SimulationPredictionService
]

// Models
instance ThermalDynamicsModel : DTDFVocab:Model [
    base:desc "Differential‑equation model capturing heat transfer and convection within the incubator"
    DTDFVocab:inputTo CalibrationEnabler, SimulationPredictionEnabler
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of real‑time sensor data against safety and performance constraints"
    DTDFVocab:provides SafetyViolationInsight, TemperatureTrendInsight
]

instance SimulationPredictionService : DTDFVocab:Service [
    base:desc "Generates predictive simulations of incubator temperature based on calibrated model"
    DTDFVocab:provides ForecastInsight
]

instance OptimizationCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates thermal model parameters and identifies efficient operating points"
    DTDFVocab:provides OptimalOperatingPointInsight, ModelParameterCalibrationInsight
]

instance DecisionControlSupportService : DTDFVocab:Service [
    base:desc "Generates actionable control commands and operator notifications when constraints are breached"
    DTDFVocab:provides AdjustThermalOutputAction, AdjustFanSpeedAction, NotifyOperatorAction
]

// Insights
instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Alert indicating temperature has exceeded safety thresholds defined for the incubator"
]

instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Visualization of temperature trends over the monitored period for operator review"
]

instance ForecastInsight : DTDFVocab:Insight [
    base:desc "Prediction of future temperature trajectory based on current conditions and calibrated model"
]

instance OptimalOperatingPointInsight : DTDFVocab:Insight [
    base:desc "Recommendations for efficient operating parameters balancing energy use and temperature stability"
]

instance ModelParameterCalibrationInsight : DTDFVocab:Insight [
    base:desc "Updated model parameters deriving from calibration to improve predictive accuracy"
]

// Actions
instance AdjustThermalOutputAction : DTDFVocab:Action [
    base:desc "Automatically adjusts the heatbed temperature setpoint based on optimization feedback"
    DTDFVocab:IsAutomatic true
]

instance AdjustFanSpeedAction : DTDFVocab:Action [
    base:desc "Automatically adjusts fan speed to maintain desired temperature uniformity"
    DTDFVocab:IsAutomatic true
]

instance NotifyOperatorAction : DTDFVocab:Action [
    base:desc "Sends alert notifications to field engineers via dashboard or messaging API"
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellation is organized into three interlinked layers: (1) a data acquisition layer that gathers time‑stamped sensor streams from the physical twin; (2) a modelling layer that houses both static CAD representations and dynamic physics‑based models describing the cyber, physical and environmental aspects of the system; and (3) an inference/optimization layer that applies calibration, monitoring, fault detection, state estimation, supervisory control, and optimisation algorithms to the combined data and model outputs. In this architecture, sensor data flows into the modelling layer, where calibration algorithms continuously adjust model parameters to reflect current operating conditions. The updated models then feed into the inference layer, where algorithmic processes generate predictions, detect anomalies, and propose corrective actions. Communications between layers follow a publish‑subscribe pattern, ensuring that updates from the data and model layers are concurrently disseminated to monitoring and decision modules, thereby synchronising the digital twin’s state with that of the physical twin."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin framework incorporates a safe protocol within its low‑level driver to ensure the device remains in a safe state, enforcing predefined safety logic on operational commands."
]