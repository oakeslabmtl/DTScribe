// Sensors
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "First internal temperature sensor inside the insulated box with ±0.5 °C accuracy."
    DTDFVocab:producedData InternalTempDataTransmitted1
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second internal temperature sensor inside the insulated box with ±0.5 °C accuracy."
    DTDFVocab:producedData InternalTempDataTransmitted2
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor mounted outside the insulated box."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// DataTransmitted
instance InternalTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1
]

instance InternalTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor2
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

// Datapoints
instance InternalTempData1 : DTDFVocab:Data [
    base:desc "Temperature measurement from InternalTemperatureSensor1 in °C."
    DTDFVocab:fromData InternalTempDataTransmitted1
    DTDFVocab:inputTo LowLevelDriver
]

instance InternalTempData2 : DTDFVocab:Data [
    base:desc "Temperature measurement from InternalTemperatureSensor2 in °C."
    DTDFVocab:fromData InternalTempDataTransmitted2
    DTDFVocab:inputTo LowLevelDriver
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Temperature measurement from ExternalTemperatureSensor in °C."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo LowLevelDriver
]

// Enablers
instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Low‑level driver polling sensors and publishing to RabbitMQ."
    DTDFVocab:enables SensorDataIngestionService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker receiving sensor telemetry."
    DTDFVocab:enables SensorDataIngestionService
]

instance InfluxDB : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database storing real‑time sensor telemetry."
    DTDFVocab:enables RealTimeDashboardService
]

instance KalmanFilterEngine : DTDFVocab:Enabler [
    base:desc "Kalman filter engine fusing Model B predictions and sensor data."
    DTDFVocab:enables KalmanFilterAnomalyService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Least‑squares calibration engine updating model parameters."
    DTDFVocab:enables CalibrationService
]

instance CoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation engine injecting historical or live PT data for simulation."
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationEngine : DTDFVocab:Enabler [
    base:desc "Orchestrates self‑adaptation loop triggered by Kalman filter anomalies."
    DTDFVocab:enables SelfAdaptationService
]

// Services
instance SensorDataIngestionService : DTDFVocab:Service [
    base:desc "Consumes sensor data from LowLevelDriver and publishes to RabbitMQ."
    DTDFVocab:provides IngestSensorDataAction
]

instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Streams ingested data to InfluxDB and renders it on a web dashboard."
    DTDFVocab:provides LiveDashboardInsight
]

instance KalmanFilterAnomalyService : DTDFVocab:Service [
    base:desc "Detects anomalies and estimates heat‑bed temperature using Model B."
    DTDFVocab:provides HeatBedStateInsight, AnomalyDetectionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Triggers on‑demand calibration and updates controller configuration."
    DTDFVocab:provides CalibrateModelAction
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Runs what‑if co‑simulations to evaluate controller parameter alternatives."
    DTDFVocab:provides SimulationOutcomeInsight, OptimizationInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Executes adaptation loop: schedule experiment → recalibrate → update Kalman filter → optimize controller → reconfigure."
    DTDFVocab:provides SelfAdaptationAction, ScheduleExperimentAction, ReconfigureControllerAction, RunOptimizationAction
]

// Insights
instance LiveDashboardInsight : DTDFVocab:Insight [
    base:desc "Live visualization of the incubator temperature and control states on the dashboard."
]

instance HeatBedStateInsight : DTDFVocab:Insight [
    base:desc "Estimated unmeasured heat‑bed temperature and confidence bounds."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of deviations from expected temperature behavior."
]

instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Resulting temperature trajectory and performance metrics from co‑simulation."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized controller parameter set based on simulation outcomes."
]

// Actions
instance IngestSensorDataAction : DTDFVocab:Action [
    base:desc "Automatically ingests sensor data into RabbitMQ."
    DTDFVocab:IsAutomatic true
]

instance CalibrateModelAction : DTDFVocab:Action [
    base:desc "Automatically recalculates model parameters and updates controller settings."
    DTDFVocab:IsAutomatic true
]

instance SelfAdaptationAction : DTDFVocab:Action [
    base:desc "Performs full self‑adaptation cycle based on detected anomaly."
    DTDFVocab:IsAutomatic true
]

instance ScheduleExperimentAction : DTDFVocab:Action [
    base:desc "Schedules calibration experiment to capture load changes."
    DTDFVocab:IsAutomatic true
]

instance ReconfigureControllerAction : DTDFVocab:Action [
    base:desc "Updates controller parameter configuration after calibration."
    DTDFVocab:IsAutomatic true
]

instance RunOptimizationAction : DTDFVocab:Action [
    base:desc "Runs controller optimization simulation after Kalman filter update."
    DTDFVocab:IsAutomatic true
]

// Models
instance IncubatorCADModel : DTDFVocab:Model [
    base:desc "CAD geometric model of the insulated styrofoam box, heatbed, and fan mounting."
    DTDFVocab:inputTo CoSimulationEngine
]

instance ThermalModelSimplified : DTDFVocab:Model [
    base:desc "Simplified thermal model with two free parameters used for calibration."
    DTDFVocab:inputTo CalibrationEngine
]

instance ThermalModelDetailed : DTDFVocab:Model [
    base:desc "Detailed thermal model with four free parameters used for Kalman filter estimation."
    DTDFVocab:inputTo KalmanFilterEngine
]

instance HeatBalanceEquationModel : DTDFVocab:Model [
    base:desc "Analytical heat‑balance equations bridging geometric and behavioral models."
    DTDFVocab:inputTo CalibrationEngine
]

// Actuating Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Bang‑bang controller‑controlled heat‑bed on/off actuator with heating duration H and waiting duration C."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan actuator distributed heat within the incubator, commanded via the same control channel."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The controller implements a bang‑bang logic that receives the latest temperature measurements from the broker, evaluates them against configured lower (LL) and upper (UL) limits, and sends control commands to the low‑level driver through the same RabbitMQ broker. The driver validates each command against its safe protocol, which guarantees that no actuators (fan or heatbed) will be driven beyond safe thresholds, and translates the high‑level commands into hardware‑specific signals (e.g. GPIO toggles). After execution, the driver reports its state back to the broker, allowing the controller to confirm command completion and adjust the next cycle accordingly."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The low‑level driver in the incubator continuously polls the two internal temperature sensors and one external temperature sensor, publishing the read values to RabbitMQ. The controller consumes these messages and executes a bang‑bang control state machine defined in Figure 8. The control state machine uses two timing parameters – H (heating duration) and C (waiting duration) – that determine how long the heatbed is powered on and how long the system waits before re‑reading the temperature. The system’s temporal granularity is therefore dictated by the sensor polling interval and the H/C cycle durations. No explicit synchronisation frequency, latency bounds, or other time‑scale requirements are specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation is orchestrated through a lightweight, message‑broker based architecture. The low‑level driver reads sensor values and writes actuator commands to a RabbitMQ server. RabbitMQ then forwards the data to the controller, which in turn issues HVAC commands and publishes its state back to RabbitMQ. In the conceptual DT layer, data streams from the PT are ingested and processed by the model instances (Model A and Model B) and by algorithmic services (e.g., calibration routines, Kalman‑filter state estimation). All components share the same broker and operate in a tightly coupled, real‑time manner, but there is no explicit separation of concerns beyond the logical division between data acquisition, control, modelling, and analytics. The DT does not mention any separate service for Kalman filtering; it is treated as part of the analytics algorithms rather than an independent module."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through calibration and experimental validation: model B is preferred because it captures the thermal inertia of the heatbed.  Validation experiments compare model predictions with measured temperature traces, and calibration updates free parameters.  Uncertainty sources are the simplifying assumptions (e.g., uniform temperature, negligible wall heat, constant specific heat, ignored fan heat).  Anomaly detection uses a Kalman filter to flag deviations; errors are corrected by re‑calibration.  Quality assurance involves real‑time dashboards, logged sensor data, and systematic comparison of predicted versus actual temperatures during controlled ramp tests.  The process aligns with industry practices of iterative calibration, validation, and what‑if simulation to maintain model validity over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All DT communication is mediated by RabbitMQ (an AMQP 0-9-1 compliant broker) running locally on the Raspberry Pi. Messages flow between the controller, the low‑level driver and any DT components that subscribe to the broker. The network topology is a simple star: all nodes connect to the local RabbitMQ server over the LAN. The use of AMQP ensures reliable, acknowledged message delivery without requiring external network access. No specific bandwidth or latency figures are specified, but the architecture supports the low‑frequency periodic temperature updates and control commands required by the system."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire Digital Twin stack is hosted on‑premises, with all software components (controller, low‑level driver and RabbitMQ broker) running on the same Raspberry Pi that powers the incubator. The repository provides the source code and configuration scripts for local deployment; the DT can also be extended by running additional subscriber processes on the Pi or on other in‑house machines. No cloud hosting or edge servers are described in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is primarily achieved through RabbitMQ, an open‑source AMQP message broker. All Digital Twin components publish and subscribe to messages via RabbitMQ, allowing inter‑component communication without requiring explicit API gateways or REST endpoints. The system relies on standard message queues and topics (e.g., controller‑to‑driver, driver‑to‑controller), adhering to AMQP messaging semantics. No other external integration protocols or enterprise systems are referenced in the documents."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Incubator’s Digital Twin implementation uses a safe protocol within the low‑level driver to keep the device in a safe state. The controller employs a bang‑bang control strategy with defined lower/upper temperature limits (LL, UL), heating duration (H), and waiting duration (C) to prevent temperature overshoot. Communication between the Raspberry Pi controller and the low‑level driver is routed through a RabbitMQ message broker, chosen for its lightweight, mature, and easy deployment in on‑premise and cloud environments. No explicit cybersecurity protocols, access control mechanisms, authentication systems, compliance, or data‑sharing agreements are described in the documents. "
]