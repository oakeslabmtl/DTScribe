// C3: Physical sensing components
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor A placed inside the incubator box measuring temperature distribution"
    DTDFVocab:producedData InternalTempDataTransmittedA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor B placed inside the incubator box measuring temperature distribution"
    DTDFVocab:producedData InternalTempDataTransmittedB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor measuring ambient room temperature"
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Data transmitted from sensors
instance InternalTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// C10: Data objects (sensor streams)
instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Temperature data stream from internal sensor A"
    DTDFVocab:fromData InternalTempDataTransmittedA
    DTDFVocab:inputTo LowLevelDriver, TimeSeriesDatabase, KalmanFilter, DashboardVisualization
]

instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Temperature data stream from internal sensor B"
    DTDFVocab:fromData InternalTempDataTransmittedB
    DTDFVocab:inputTo LowLevelDriver, TimeSeriesDatabase, KalmanFilter, DashboardVisualization
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Temperature data stream from external ambient sensor"
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo LowLevelDriver, TimeSeriesDatabase, KalmanFilter, DashboardVisualization
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical temperature dynamics model A with two free parameters"
    DTDFVocab:inputTo CalibrationAlgorithm, KalmanFilter, CoSimulationFramework
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Analytical temperature dynamics model B with four free parameters, better capturing heat‑bed inertia"
    DTDFVocab:inputTo CalibrationAlgorithm, KalmanFilter, CoSimulationFramework, SelfAdaptationLoopEngine
]

// C11: Enablers
instance RabbitMQMessageBroker : DTDFVocab:Enabler [
    base:desc "AMQP message broker (RabbitMQ) used for publishing low‑level driver messages and receiving control commands"
    DTDFVocab:enables RealTimeVisualizationService, OnDemandCalibrationService, AnomalyDetectionAndStateEstimationService, WhatIfSimulationService, SelfAdaptationLoopService
]

instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Low‑level driver that reads temperature sensors, validates measurements and packages them into AMQP messages"
    DTDFVocab:enables RealTimeVisualizationService, OnDemandCalibrationService, AnomalyDetectionAndStateEstimationService, WhatIfSimulationService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time‑series database for persisting temperature sensor streams"
    DTDFVocab:enables RealTimeVisualizationService, OnDemandCalibrationService, AnomalyDetectionAndStateEstimationService, WhatIfSimulationService
]

instance DashboardVisualization : DTDFVocab:Enabler [
    base:desc "Real‑time dashboard visualising incubator status from stored sensor data"
    DTDFVocab:enables RealTimeVisualizationService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Automated calibration algorithm that updates model parameters using sensor data"
    DTDFVocab:enables OnDemandCalibrationService, SelfAdaptationLoopService
]

instance KalmanFilter : DTDFVocab:Enabler [
    base:desc "Kalman filter implementation for anomaly detection and heat‑bed state estimation using Model B"
    DTDFVocab:enables AnomalyDetectionAndStateEstimationService, SelfAdaptationLoopService
]

instance CoSimulationFramework : DTDFVocab:Enabler [
    base:desc "Co‑simulation framework for what‑if scenarios replaying historical or live PT data"
    DTDFVocab:enables WhatIfSimulationService, SelfAdaptationLoopService
]

instance SelfAdaptationLoopEngine : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop that detects plant behaviour changes, schedules experiments, recalibrates models and reconfigures the controller"
    DTDFVocab:enables SelfAdaptationLoopService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of incubator status by listening to controller and low‑level driver messages, storing data and plotting on a dashboard"
    DTDFVocab:provides IncubatorStatusInsight
]

instance OnDemandCalibrationService : DTDFVocab:Service [
    base:desc "Offers on‑demand calibration of simulation models using automated calibration algorithms"
    DTDFVocab:provides ModelCalibrationInsight
]

instance AnomalyDetectionAndStateEstimationService : DTDFVocab:Service [
    base:desc "Performs anomaly detection and heat‑bed state estimation via a Kalman filter fusing sensor data with Model B"
    DTDFVocab:provides TemperatureAnomalyInsight, HeatBedStateEstimationInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Executes what‑if simulations as co‑simulations that replay PT data to optimise controller parameters"
    DTDFVocab:provides ControllerOptimizationInsight
]

instance SelfAdaptationLoopService : DTDFVocab:Service [
    base:desc "Runs a self‑adaptation loop that detects changes, schedules experiments, recalibrates models, updates Kalman filter and controller settings"
    DTDFVocab:provides UpdateControllerSettingsAction
]

// C17: Insights
instance IncubatorStatusInsight : DTDFVocab:Insight [
    base:desc "Current temperature readings and system status displayed on the dashboard"
]

instance ModelCalibrationInsight : DTDFVocab:Insight [
    base:desc "Model parameters have been updated based on the latest sensor data"
]

instance TemperatureAnomalyInsight : DTDFVocab:Insight [
    base:desc "Detected temperature anomalies compared to expected model behaviour"
]

instance HeatBedStateEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated unmeasured heat‑bed temperature derived from the Kalman filter"
]

instance ControllerOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimised controller parameter set derived from what‑if simulation results"
]

// C17: Action
instance UpdateControllerSettingsAction : DTDFVocab:Action [
    base:desc "Automatically re‑configures controller settings based on new model calibration and simulation outcomes"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the DT (or by the controller logic) and sent as AMQP messages over RabbitMQ to the low‑level driver. The command set includes turn‑on/turn‑off directives for the heat‑bed and the fan, as well as parameters such as heating duration (H) and waiting duration (C). Upon receipt, the driver checks the command against its built‑in safety protocol before actuating the physical twin. The driver then acknowledges execution by publishing the resulting actuation state back to RabbitMQ, allowing the controller/DT to receive feedback."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates with real‑time monitoring: temperature sensor data are continuously streamed from the Raspberry Pi controller to a time‑series database, enabling a dashboard that visualises the incubator status in (near) real time. Calibration of the thermal simulation models is performed on demand by automatically running the calibration routine described in section 3.3. Anomaly detection and heat‑bed state estimation run concurrently using a Kalman filter on the live data stream. What‑if simulations can be executed with either historical or real‑time PT data, but no explicit synchronization frequency, latency bound, or temporal granularity is provided in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT follows a CPS‑based centralized architecture (Fig. 1). The physical twin comprises the insulated box, heat‑bed, fan and temperature sensors, controlled by a Raspberry Pi. The cyber side includes data acquisition (listening to controller and low‑level driver messages), a time‑series database, a dashboard for real‑time visualization, calibration algorithms that update two thermal models, a Kalman‑filter based anomaly detector and heat‑bed state estimator, and a co‑simulation engine for what‑if analyses. These components are orchestrated as outlined in the self‑adaptation loop: detect anomaly → schedule experiment → configure controller → gather data → calibrate model → re‑configure Kalman filter → run simulations → re‑configure controller."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the prediction accuracy of Model A and Model B against experimental measurements; Model B provides higher fidelity for the heat‑bed inertia. Validation is performed through calibration experiments described in the case study, where model parameters are tuned to minimise the error between simulated and measured temperature trajectories. Uncertainty sources include sensor noise and unmodelled environmental influences; the Kalman filter is employed to fuse model predictions with noisy measurements, thereby detecting anomalies and estimating hidden states. Quality assurance is achieved by continuous monitoring of model‑derived predictions and by re‑calibrating the models on demand."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The incubator DT relies on a central RabbitMQ server as the technical communication layer. RabbitMQ implements the AMQP protocol over TCP/IP, providing a publish/subscribe topology where the controller, low‑level driver and any DT analytics components act as clients. The architecture is a star‑shaped network with the broker as the hub. RabbitMQ offers message durability, acknowledgments and clustering for reliability, though specific bandwidth, latency or QoS numbers are not given in the documents. Security mechanisms (e.g., TLS, authentication) are not described."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ broker can be deployed either on‑premise (e.g., on the same Raspberry Pi or a local server) or in the cloud, as noted in the documents. No quantitative computational or storage requirements are provided; the DT components are assumed to run on the Raspberry Pi or on any host that can connect to the broker. Scalability is supported by RabbitMQ’s clustering capability, and availability is achieved through its mature, lightweight design, but exact deployment models and SLA details are not specified."
]