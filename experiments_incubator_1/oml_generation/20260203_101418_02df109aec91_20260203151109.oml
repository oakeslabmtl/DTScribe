// Physical sensing components
instance BoxInsideTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor placed inside the insulated box measuring internal temperature T1."
    DTDFVocab:producedData BoxInsideTempData1
]

instance BoxInsideTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor placed inside the insulated box measuring internal temperature T2."
    DTDFVocab:producedData BoxInsideTempData2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor positioned outside the incubator box measuring ambient room temperature T3."
    DTDFVocab:producedData AmbientTempData
]

instance PiPowerInputSensor : DTDFVocab:SensingComponent [
    base:desc "Electric power input monitor on Raspberry Π 4 Model B, measuring power V·I supplied to the incubator."
    DTDFVocab:producedData PowerInputData
]

instance PiControlSignalSensor : DTDFVocab:SensingComponent [
    base:desc "Controller signal logger reading the control output I registered by the Pi."
    DTDFVocab:producedData ControlSignalData
]

// Physical-to-virtual interaction (Data transmitted via RabbitMQ broker)
instance BoxInsideTempData1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxInsideTempSensor1
]

instance BoxInsideTempData2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxInsideTempSensor2
]

instance AmbientTempData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

instance PowerInputData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PiPowerInputSensor
]

instance ControlSignalData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PiControlSignalSensor
]

// Data instances (time‑series, logs)
instance BoxInsideTempSeries1 : DTDFVocab:Data [
    base:desc "Time‑series temperature data sampled from BoxInsideTempSensor1."
    DTDFVocab:fromData BoxInsideTempData1
    DTDFVocab:inputTo PiPythonEnvironment
]

instance BoxInsideTempSeries2 : DTDFVocab:Data [
    base:desc "Time‑series temperature data sampled from BoxInsideTempSensor2."
    DTDFVocab:fromData BoxInsideTempData2
    DTDFVocab:inputTo PiPythonEnvironment
]

instance AmbientTempSeries : DTDFVocab:Data [
    base:desc "Time‑series ambient temperature data sampled from AmbientTempSensor."
    DTDFVocab:fromData AmbientTempData
    DTDFVocab:inputTo PiPythonEnvironment
]

instance PowerInputSeries : DTDFVocab:Data [
    base:desc "Time‑series power input V·I recorded by PiPowerInputSensor."
    DTDFVocab:fromData PowerInputData
    DTDFVocab:inputTo PiPythonEnvironment
]

instance ControlSignalSeries : DTDFVocab:Data [
    base:desc "Control signal log from PiControlSignalSensor reporting controller output I."
    DTDFVocab:fromData ControlSignalData
    DTDFVocab:inputTo PiPythonEnvironment
]

// Models
instance ModelA : DTDFVocab:Model [
    base:desc "Single‑parameter temperature differential equation with parameters C_air and G_box."
    DTDFVocab:inputTo PiPythonEnvironment
]

instance ModelB : DTDFVocab:Model [
    base:desc "Two‑parameter thermal model with parameters C_air, C_heater, G_box, G_heater."
    DTDFVocab:inputTo PiPythonEnvironment
]

// Virtual twin enabler (Python simulation environment)
instance PiPythonEnvironment : DTDFVocab:Enabler [
    base:desc "Python runtime on Raspberry Pi 4 Model B executing thermal models and calibration routines."
    DTDFVocab:enables RealTimeMonitoringService, BangBangControlService, ThermalSimulationService, ParameterCalibrationService, FaultDetectionService, ForecastProvisioningService
]

// Digital twin services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of temperature trajectories from sensor data."
    DTDFVocab:provides TemperatureMonitoringInsight
]

instance BangBangControlService : DTDFVocab:Service [
    base:desc "Bang‑bang temperature control logic responding to real‑time temperature deviations."
    DTDFVocab:provides BangBangControlAction
]

instance ThermalSimulationService : DTDFVocab:Service [
    base:desc "Digital simulation of thermal dynamics using ModelA and ModelB for forecasted temperature profiles."
    DTDFVocab:provides TemperatureForecastInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Parameter calibration via nonlinear least‑squares optimizing model parameters against measured data."
    DTDFVocab:provides ParameterDriftInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault‑detector‑like monitoring flagging unsafe temperature deviations."
    DTDFVocab:provides FaultAlertInsight
]

instance ForecastProvisioningService : DTDFVocab:Service [
    base:desc "Provision of simulated forecasted temperature profiles to operators or supervisory algorithms."
    DTDFVocab:provides TemperatureDeviationInsight
]

// Insights
instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time temperature trajectory insights for monitoring incubator conditions."
]

instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasted temperature profiles generated from calibrated thermal models."
]

instance ParameterDriftInsight : DTDFVocab:Insight [
    base:desc "Detection of parameter drift indicating model degradation over time."
]

instance FaultAlertInsight : DTDFVocab:Insight [
    base:desc "Alert identifying unsafe temperature deviations beyond safety thresholds."
]

instance TemperatureDeviationInsight : DTDFVocab:Insight [
    base:desc "Insight highlighting deviations of current temperature from desired set‑point."
]

// Actions
instance BangBangControlAction : DTDFVocab:Action [
    base:desc "Bang‑bang control action adjusting PWM duty cycle via MOSFETs to maintain target temperature."
    DTDFVocab:IsAutomatic true
]

instance ControllerAdjustmentRecommendationAction : DTDFVocab:Action [
    base:desc "Recommendation for adjusting controller parameters manually by operators."
    DTDFVocab:IsAutomatic false
]

// Acting components
instance HeatbedMOSFET : DTDFVocab:ActingComponent [
    base:desc "PWM‑driven MOSFET controlling the heatbed heating element on the incubator."
]

instance FanMOSFET : DTDFVocab:ActingComponent [
    base:desc "GPIO‑controlled MOSFET actuating the fan for temperature regulation."
]

instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi 4 Model B running low‑level drivers and PI controller logic."
]

instance CustomPCB : DTDFVocab:ActingComponent [
    base:desc "Custom printed circuit board interfacing sensors, MOSFETs, and optocouplers with the Pi."
]

// Environment containing all components
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains BoxInsideTempSensor1, BoxInsideTempSensor2, AmbientTempSensor, PiPowerInputSensor, PiControlSignalSensor,
    HeatbedMOSFET, FanMOSFET, RaspberryPiController, CustomPCB
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "RabbitMQ messages from the DT to the controller contain control commands (heatbed ON/OFF, fan ON/OFF, heating duration H, waiting duration C) that the low‑level driver executes; the DT also pushes telemetry such as actuator states back to the Pi via RabbitMQ."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Measurement and actuation updates occur at tens of milliseconds (sensor polling interval) on the Pi, while the simulated thermal models advance in discrete steps matching the sensor intervals; the DT synchronizes with the PT at a real‑time clock, typically >1 Hz, facilitating instant feedback and optimization."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation comprises the Raspberry Pi controller, low‑level driver, and controller logic, all communicating through RabbitMQ; the PT (incubator hardware) communicates up to the DT via sensor readings; the DT runs simulation and monitoring modules on the same Pi, co‑located with the PT, forming a tightly integrated single‑site constellation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the designed phase (CAD, thermal simulation), the manufactured phase (assembly of the Raspberry Pi, sensors, heatbed, PCB on the physical twin), and the operated phase (runtime data collection, model calibration, real‑time control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation performed by comparing simulation outputs to experimental temperature curves; fidelity assessed by checking uniformity of temperature across sensors (≤7 °C discrepancy) and sensitivity to fan voltage (18 V reduces mean‑max discrepancy to 6 °C); calibration achieved minimisation of residual error through least‑squares; uncertainties due to unknown specific heat capacity and heat transfer coefficients are encapsulated in parameter estimation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical twin communicates with DT via RabbitMQ over the AMQP protocol running locally on the Raspberry Pi; messages contain JSON payloads for sensor data and control commands; the Pi hosts the broker, eliminating external network dependencies."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT runs natively on the Raspberry Pi 4 Model B, the same hardware that acts as the controller; the RabbitMQ broker, simulation scripts, and monitoring dashboards are included in the open‑source containerised environment deployed on the Pi."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol that ensures the device remains in a safe state if communication is disrupted; interactions with RabbitMQ are local, reducing exposure; the control logic uses bang‑bang with wait durations to prevent overheating; no explicit cybersecurity mechanisms are detailed but the local broker mitigates external attack vectors."
]