// C3: Physical sensing components
instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that captures position of the physical twin."
    DTDFVocab:producedData PositionDataTransmitted
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that captures velocity of the physical twin."
    DTDFVocab:producedData VelocityDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that captures temperature of the physical twin."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that captures pressure of the physical twin."
    DTDFVocab:producedData PressureDataTransmitted
]

// C4: Physical-to-virtual interaction
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

// C10: Models/Data
instance PositionDataStream : DTDFVocab:Data [
    base:desc "Time‑stamped position measurements streamed to the DT backend."
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo SupervisoryController
]

instance VelocityDataStream : DTDFVocab:Data [
    base:desc "Time‑stamped velocity measurements streamed to the DT backend."
    DTDFVocab:fromData VelocityDataTransmitted
    DTDFVocab:inputTo StateEstimator
]

instance TemperatureDataStream : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements streamed to the DT backend."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithm
]

instance PressureDataStream : DTDFVocab:Data [
    base:desc "Time‑stamped pressure measurements streamed to the DT backend."
    DTDFVocab:fromData PressureDataTransmitted
    DTDFVocab:inputTo Optimiser
]

// C11: Enablers
instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that adjusts model parameters from sensor data."
    DTDFVocab:enables PredictiveSimulationService
]

instance FaultDetector : DTDFVocab:Enabler [
    base:desc "Fault detector that identifies anomalies using state estimation and supervisory controller logic."
    DTDFVocab:enables FaultDetectionService
]

instance SupervisoryController : DTDFVocab:Enabler [
    base:desc "Supervisory controller that monitors real‑time operations."
    DTDFVocab:enables RealTimeMonitoringService
]

instance StateEstimator : DTDFVocab:Enabler [
    base:desc "State estimator that monitors safety or performance criteria."
    DTDFVocab:enables SafetyPerformanceCheckService
]

instance Optimiser : DTDFVocab:Enabler [
    base:desc "Optimiser that generates optimisation routines to adjust operating parameters."
    DTDFVocab:enables OptimisationRoutineService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service that delivers real‑time monitoring of the physical twin."
    DTDFVocab:provides RealTimeInsight
]

instance SafetyPerformanceCheckService : DTDFVocab:Service [
    base:desc "Service that performs continuous safety‑and‑performance checks."
    DTDFVocab:provides SafetyPerformanceInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Service that reproduces and forecasts the system's behaviour under current operating conditions."
    DTDFVocab:provides PredictiveSimulationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service that implements fault detection techniques."
    DTDFVocab:provides FaultDetectionInsight
]

instance OptimisationRoutineService : DTDFVocab:Service [
    base:desc "Service that generates optimisation routines to improve performance."
    DTDFVocab:provides AdjustOperatingParametersAction
]

// C17: Insights/Actions
instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time monitoring outputs."
]

instance SafetyPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight indicating safety or performance criterion violations."
]

instance PredictiveSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight forecasting future system behavior based on current conditions."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight identifying anomalies and potential faults."
]

instance AdjustOperatingParametersAction : DTDFVocab:Action [
    base:desc "Action to adjust operating parameters to improve performance."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle begins with the creation of system models that capture both the physical and cyber aspects of the asset. During deployment, these models are integrated into the DT framework. Continuous calibration algorithms update model parameters using real‑time sensor data, ensuring that the virtual representation remains faithful to the physical twin. Runtime monitoring processes the updated models and sensor streams to identify safety or performance violations. When such violations are detected, either human operators or autonomous supervisory algorithms initiate corrective actions that feed back into the system, completing the lifecycle loop and enabling ongoing refinement."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT’s fidelity is ensured through continuous calibration: model parameters are refined using incoming sensor data to minimise discrepancies between simulation and reality. Validation is performed by monitors that compare operational metrics against predefined safety and performance constraints; fault detectors flag deviations. State estimators infer unmeasured states, while optimisers evaluate alternative control actions based on the calibrated models. This closed‑loop data–model–control cycle underpins the DT’s capacity to detect, correct, and prevent faults, thereby maintaining confidence in both the models and the data streams."
]