// C3: Physical sensing components
instance AirTempSensorInside1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one-wire digital thermometer located inside the insulated box measuring air temperature."
    DTDFVocab:producedData DataTransmittedAirTemp1
]

instance AirTempSensorInside2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one-wire digital thermometer located inside the insulated box measuring air temperature."
    DTDFVocab:producedData DataTransmittedAirTemp2
]

instance RoomTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one-wire digital thermometer located outside the insulated box measuring room temperature."
    DTDFVocab:producedData DataTransmittedRoomTemp
]

// C4: Physical-to-virtual interaction
instance DataTransmittedAirTemp1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirTempSensorInside1
]

instance DataTransmittedAirTemp2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirTempSensorInside2
]

instance DataTransmittedRoomTemp : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTempSensor
]

// C10: Models/Data
instance AirTempData1 : DTDFVocab:Data [
    base:desc "Time-series temperature data for inside air temperature from sensor inside the insulated box."
    DTDFVocab:fromData DataTransmittedAirTemp1
    DTDFVocab:inputTo MonitoringEnabler, ScipyCalibrationEnabler, SimulationEnabler
]

instance AirTempData2 : DTDFVocab:Data [
    base:desc "Time-series temperature data for inside air temperature from second sensor inside the insulated box."
    DTDFVocab:fromData DataTransmittedAirTemp2
    DTDFVocab:inputTo MonitoringEnabler, ScipyCalibrationEnabler, SimulationEnabler
]

instance RoomTempData : DTDFVocab:Data [
    base:desc "Time-series temperature data for room temperature from the outside sensor."
    DTDFVocab:fromData DataTransmittedRoomTemp
    DTDFVocab:inputTo MonitoringEnabler, ScipyCalibrationEnabler, SimulationEnabler
]

instance ControlCommandData : DTDFVocab:Data [
    base:desc "Time-series control command data for heater and fan actuators."
    DTDFVocab:inputTo MonitoringEnabler, ScipyCalibrationEnabler, SimulationEnabler
]

instance PowerConsumptionData : DTDFVocab:Data [
    base:desc "Time-series power consumption data for heating element and fan motor."
    DTDFVocab:inputTo MonitoringEnabler, ScipyCalibrationEnabler, SimulationEnabler
]

instance ThermalModelA : DTDFVocab:Model [
    base:desc "Dynamic thermal model A representing air and heatbed temperature dynamics with parameters C_air, G_box, C_heater, G_heater."
    DTDFVocab:inputTo ScipyCalibrationEnabler, SimulationEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Dynamic thermal model B, an iterative improvement of Model A, used for predictive simulation."
    DTDFVocab:inputTo ScipyCalibrationEnabler, SimulationEnabler
]

// C11: Enablers
instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Low-level driver on Raspberry Pi reading sensors and forwarding data to RabbitMQ."
    DTDFVocab:enables RealTimeMonitoringService, FaultDetectionService
]

instance ScipyCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Python script using Scipy for non-linear least squares optimization to calibrate thermal models."
    DTDFVocab:enables CalibrationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python script performing predictive simulation using calibrated models A and B."
    DTDFVocab:enables PredictiveSimulationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service for real-time monitoring of temperature and actuator status."
    DTDFVocab:provides CurrentTemperatureInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Service that uses calibrated models to predict temperature trajectories."
    DTDFVocab:provides TemperatureTrajectoryPredictionInsight, FanVoltageSuggestionInsight, UpdateControlPolicyAction
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that performs calibration of thermal models using experimental data."
    DTDFVocab:provides ParameterEstimatesInsight, ApplyHeatingDurationAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service for basic fault detection monitoring anomalies in sensor data and actuator command consistency."
    DTDFVocab:provides SafetyAlertInsight, AdjustFanSpeedAction, SendSafetyAlertAction
]

// C17: Insights/Actions
instance ParameterEstimatesInsight : DTDFVocab:Insight [
    base:desc "Insight containing calibrated parameters G_box and G_heater."
]

instance TemperatureTrajectoryPredictionInsight : DTDFVocab:Insight [
    base:desc "Insight predicting future temperature trajectories based on calibrated thermal models."
]

instance FanVoltageSuggestionInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting optimal fan voltage or heating duration."
]

instance CurrentTemperatureInsight : DTDFVocab:Insight [
    base:desc "Insight providing current air temperature readings from sensors."
]

instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Insight alerting when safety limits are approached."
]

instance AdjustFanSpeedAction : DTDFVocab:Action [
    base:desc "Action to adjust fan speed to maintain target temperature."
    DTDFVocab:IsAutomatic true
]

instance ApplyHeatingDurationAction : DTDFVocab:Action [
    base:desc "Action to apply heating duration based on predictive simulation."
    DTDFVocab:IsAutomatic false
]

instance UpdateControlPolicyAction : DTDFVocab:Action [
    base:desc "Action to update control policy based on model predictions."
    DTDFVocab:IsAutomatic true
]

instance SendSafetyAlertAction : DTDFVocab:Action [
    base:desc "Action to send safety alert to operator when thresholds are violated."
    DTDFVocab:IsAutomatic true
]

// C3: Acting Components
instance HeatbedHeater : DTDFVocab:ActingComponent [
    base:desc "Heatbed heating element electrically powered and controlled via MOSFETs."
]

instance FanMotor : DTDFVocab:ActingComponent [
    base:desc "12V/24V DC motor fan driven by MOSFETs controlled through Raspberry Pi GPIO."
]

// C17: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains IncubatorBox, HeatbedHeater, FanMotor, AirTempSensorInside1, AirTempSensorInside2, RoomTempSensor, RaspberryPi4
]

// C3: Additional Component
instance IncubatorBox : DTDFVocab:Component [
    base:desc "Styrofoam insulated box forming the main thermal enclosure of the incubator."
]

instance RaspberryPi4 : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B acting as the controller for sensor reading and actuator control."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Command messages (e.g., enable/disable fan, adjust heatbed power) are sent from the DT via RabbitMQ to the Raspberry Pi, which then drives the MOSFETs controlling the actuators; DT also publishes control state back to the Pi for redundancy."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real‑time operation of the control loop (sensing, decision, actuation) with a resolution of seconds; model calibration and simulation performed offline when new experimental data is available"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Device hardware (styrofoam box, heatbed, fan, sensors); embedded Raspberry Pi controller; PCB connecting MOSFETs and optocouplers; low‑level driver polling sensors and publishing to RabbitMQ; communication server (RabbitMQ) hosting AMQP topics; model and control logic executed on the Pi, all orchestrated to form the digital twin ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (model derivation and hardware design), manufacturing (deployment of Raspberry Pi, sensors, PCB, and open‑source software), and operation (runtime monitoring, calibration, re‑commissioning after maintenance), with continuous model refinement during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model A calibrated to capture thermal inertia; model B incorporates heatbed thermal mass; calibration minimizes least‑squares residual, verified against experimental temperature trajectories; assumptions explicitly tested (uniform temperature, negligible wall heat accumulation); further validation through controlled experiments with varied fan voltage."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical PT communicates with DT via RabbitMQ over local network (AMQP protocol); the DT handles sensor data and control commands through this broker; 1‑Wire bus used between Pi and DS18S20 sensors."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted locally on the Raspberry Pi 4; all software components (controller, driver, RabbitMQ, DT models) run on this single board computer; the repository is open‑source and can be redeployed elsewhere"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Low‑level driver incorporates a safe protocol to prevent unsafe actuator states; control logic includes wait periods (C) after heating to avoid overheating; RabbitMQ allows message isolation; no explicit cybersecurity hardening documented, but safe operating limits are enforced via firmware."
]