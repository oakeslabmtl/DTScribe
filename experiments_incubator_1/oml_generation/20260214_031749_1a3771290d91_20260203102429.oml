// C17: Insights
instance TemperatureDeviationInsight : DTDFVocab:Insight [
    base:desc "Detects deviations of internal temperature from target set‑point and triggers alerts"
]

instance TemperatureHistoryInsight : DTDFVocab:Insight [
    base:desc "Provides historical temperature trends for operator analysis"
]

instance CalibrationParameterInsight : DTDFVocab:Insight [
    base:desc "Outputs calibrated parameters (C_air, G_box, C_heater, G_heater) after optimisation"
]

instance TemperatureSafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Indicates unsafe temperature conditions requiring immediate operator attention"
]

instance ControlSuggestionInsight : DTDFVocab:Insight [
    base:desc "Recommends adjustments to heating duration or waiting time to improve temperature uniformity"
]

// C6: Services
instance RealTimeTemperatureMonitoring : DTDFVocab:Service [
    base:desc "Realtime monitoring of incubator temperature using incoming sensor data",
    DTDFVocab:provides = TemperatureDeviationInsight
]

instance DataLoggingVisualization : DTDFVocab:Service [
    base:desc "Logging of temperature data to local storage and visualisation for analysis",
    DTDFVocab:provides = TemperatureHistoryInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Calibration of physics‑based thermal models (Model A & Model B) via non‑linear least‑squares",
    DTDFVocab:provides = CalibrationParameterInsight
]

instance SafetyAlertService : DTDFVocab:Service [
    base:desc "Generates alerts when temperature exceeds predefined safety limits",
    DTDFVocab:provides = TemperatureSafetyAlertInsight
]

instance ControlRecommendationService : DTDFVocab:Service [
    base:desc "Suggests control adjustments (e.g., modify heating duration or waiting time) based on current state",
    DTDFVocab:provides = ControlSuggestionInsight,
    DTDFVocab:provides = AdjustHeatingAction,
    DTDFVocab:provides = AdjustWaitingAction
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "AMQP message broker on the Raspberry Pi that receives sensor data streams",
    DTDFVocab:enables = RealTimeTemperatureMonitoring,
    DTDFVocab:enables = DataLoggingVisualization
]

instance SciPyCalibrationEngine : DTDFVocab:Enabler [
    base:desc "Python SciPy non‑linear least‑squares optimizer used for model parameter calibration",
    DTDFVocab:enables = ModelCalibrationService
]

instance ControlLogicEngine : DTDFVocab:Enabler [
    base:desc "Low‑level driver & controller logic on the Raspberry Pi that evaluates safety limits and generates control suggestions",
    DTDFVocab:enables = SafetyAlertService,
    DTDFVocab:enables = ControlRecommendationService
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance InternalAirTempDataTx1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom = InternalAirTempSensor1
]

instance InternalAirTempDataTx2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom = InternalAirTempSensor2
]

instance AmbientTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom = AmbientTempSensor
]

// C3: Physical sensing components
instance InternalAirTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring internal air temperature (‑55 °C to +125 °C, 0.5 °C accuracy)",
    DTDFVocab:producedData = InternalAirTempDataTx1
]

instance InternalAirTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring internal air temperature (‑55 °C to +125 °C, 0.5 °C accuracy)",
    DTDFVocab:producedData = InternalAirTempDataTx2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring ambient room temperature (‑55 °C to +125 °C, 0.5 °C accuracy)",
    DTDFVocab:producedData = AmbientTempDataTx
]

// C10: Data
instance InternalAirTemperatureData1 : DTDFVocab:Data [
    base:desc "Temperature reading from internal air sensor 1 (°C)",
    DTDFVocab:fromData = InternalAirTempDataTx1,
    DTDFVocab:inputTo = RabbitMQBroker
]

instance InternalAirTemperatureData2 : DTDFVocab:Data [
    base:desc "Temperature reading from internal air sensor 2 (°C)",
    DTDFVocab:fromData = InternalAirTempDataTx2,
    DTDFVocab:inputTo = RabbitMQBroker
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Ambient room temperature reading (°C)",
    DTDFVocab:fromData = AmbientTempDataTx,
    DTDFVocab:inputTo = RabbitMQBroker
]

instance TemperatureTrajectoryData : DTDFVocab:Data [
    base:desc "Time‑series of temperature measurements collected during uniformity tests",
    DTDFVocab:fromData = InternalAirTempDataTx1,
    DTDFVocab:fromData = InternalAirTempDataTx2,
    DTDFVocab:fromData = AmbientTempDataTx,
    DTDFVocab:inputTo = SciPyCalibrationEngine
]

// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed (214 × 214 × 3 mm) switched on/off via MOSFET driver"
]

instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "12‑24 V circulation fan switched on/off via MOSFET driver"
]

// C10: Models
instance ModelA : DTDFVocab:Model [
    base:desc "Energy‑balance model with single thermal capacity C_air and box loss coefficient G_box",
    DTDFVocab:inputTo = SciPyCalibrationEngine
]

instance ModelB : DTDFVocab:Model [
    base:desc "Extended model adding heater capacity C_heater and transfer coefficient G_heater",
    DTDFVocab:inputTo = SciPyCalibrationEngine
]

// C17: Actions
instance AdjustHeatingAction : DTDFVocab:Action [
    base:desc "Modify the heating duration of the heat‑bed",
    DTDFVocab:IsAutomatic = false
]

instance AdjustWaitingAction : DTDFVocab:Action [
    base:desc "Change the waiting time between heating cycles",
    DTDFVocab:IsAutomatic = false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (heat‑bed ON/OFF, fan ON/OFF, waiting durations) are sent from DT components to the Raspberry Pi via RabbitMQ; the low‑level driver receives the commands and actuates the MOSFET switches to affect the heat‑bed and fan."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture comprises the Physical Twin (box, heat‑bed, fan, sensors, PCB), a controller on the Raspberry Pi, a low‑level driver, a RabbitMQ communication server, and external DT components that subscribe to sensor data, run the simulation models, perform calibration, and publish actuator commands. The DT components can be distributed but share the same message broker."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity relies on four explicit assumptions (uniform temperature, negligible wall heat storage, constant air specific heat, negligible heat loss to fan). Validity is assessed through uniform‑temperature experiments (fan on, temperature discrepancy ≤7 °C) and calibration error minimisation. The calibrated parameters are obtained only when the residual error becomes sufficiently small."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses RabbitMQ (AMQP over TCP/IP). The Raspberry Pi provides Wi‑Fi and Bluetooth connectivity, enabling networked message exchange. GPIO signals are isolated via MOSFETs and optocouplers for safe physical actuation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ broker and the controller software are deployed on the Raspberry Pi itself (on‑premises). Additional DT services (model simulation, calibration) can run on any computer that connects to the same RabbitMQ server."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver implements a safe‑state protocol and uses optocouplers to electrically isolate control signals, reducing risk of accidental actuator activation. The DT monitors for safety violations and can halt operation, but detailed security standards are not described."
]