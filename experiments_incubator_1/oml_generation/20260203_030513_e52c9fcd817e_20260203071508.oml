// C3: Physical sensing components
instance TempSensorInternalNearBed : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted inside the incubator near the heat‑bed, accuracy ±0.5 °C, range –10 °C to +85 °C"
    DTDFVocab:producedData TempDataTransmittedInternalNearBed
]

instance TempSensorInternalSide : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted inside the incubator away from the heat‑bed, accuracy ±0.5 °C, range –10 °C to +85 °C"
    DTDFVocab:producedData TempDataTransmittedInternalSide
]

instance TempSensorExternal : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted outside the incubator chamber, accuracy ±0.5 °C, range –10 °C to +85 °C"
    DTDFVocab:producedData TempDataTransmittedExternal
]

// C4: Physical-to-virtual interaction
instance TempDataTransmittedInternalNearBed : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TempSensorInternalNearBed
]

instance TempDataTransmittedInternalSide : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TempSensorInternalSide
]

instance TempDataTransmittedExternal : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TempSensorExternal
]

// C10: Data
instance TemperatureDataInternalNearBed : DTDFVocab:Data [
    base:desc "Time‑stamped temperature readings from the internal sensor near the heat‑bed"
    DTDFVocab:fromData TempDataTransmittedInternalNearBed
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringAlgorithm, OptimisationAlgorithm
]

instance TemperatureDataInternalSide : DTDFVocab:Data [
    base:desc "Time‑stamped temperature readings from the internal sensor on the side of the incubator"
    DTDFVocab:fromData TempDataTransmittedInternalSide
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringAlgorithm, OptimisationAlgorithm
]

instance TemperatureDataExternal : DTDFVocab:Data [
    base:desc "Time‑stamped temperature readings from the external sensor"
    DTDFVocab:fromData TempDataTransmittedExternal
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringAlgorithm, OptimisationAlgorithm
]

// C10: Models
instance SimpleIncubatorThermalModel : DTDFVocab:Model [
    base:desc "Analytical model of incubator internal temperature with two free parameters, capturing basic heat transfer"
    DTDFVocab:inputTo CalibrationAlgorithm, SimulationAlgorithm, MonitoringAlgorithm
]

instance DetailedIncubatorThermalModel : DTDFVocab:Model [
    base:desc "Analytical model of incubator internal temperature with four free parameters, including thermal inertia of the heat‑bed"
    DTDFVocab:inputTo CalibrationAlgorithm, SimulationAlgorithm, MonitoringAlgorithm
]

// C11: Enablers
instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that ingests temperature data to update model parameters for best‑estimate values"
    DTDFVocab:enables TemperatureSimulationService, TemperatureOptimisationService, TemperatureMonitoringService
]

instance SimulationAlgorithm : DTDFVocab:Enabler [
    base:desc "Predictive simulation algorithm that computes temperature trajectories based on calibrated models"
    DTDFVocab:enables TemperatureSimulationService
]

instance MonitoringAlgorithm : DTDFVocab:Enabler [
    base:desc "Monitoring algorithm that continuously evaluates safety and optimality criteria against model expectations"
    DTDFVocab:enables TemperatureMonitoringService, FaultDetectionService
]

instance OptimisationAlgorithm : DTDFVocab:Enabler [
    base:desc "Optimisation algorithm that determines optimal heating set‑points to achieve target temperature"
    DTDFVocab:enables TemperatureOptimisationService
]

instance FaultDetectionAlgorithm : DTDFVocab:Enabler [
    base:desc "Fault‑detector algorithm that generates alerts when safety violations are detected"
    DTDFVocab:enables FaultDetectionService
]

instance StateEstimationAlgorithm : DTDFVocab:Enabler [
    base:desc "State‑estimation algorithm that fuses sensor data with models to estimate the current system state"
    DTDFVocab:enables StateEstimationService
]

// C6: Services
instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Simulation service reproducing and predicting incubator temperature dynamics under current operating conditions"
    DTDFVocab:provides InsightPredictedTemperatureTrajectory
]

instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Monitoring service evaluating safety and performance against model‑based expectations"
    DTDFVocab:provides InsightSafetyViolationDetected
]

instance TemperatureOptimisationService : DTDFVocab:Service [
    base:desc "Optimisation service adjusting control parameters to achieve optimal temperature regulation"
    DTDFVocab:provides ActionAdjustHeatingSetpoint
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Diagnostic service that detects faults and raises alerts when deviations occur"
    DTDFVocab:provides ActionRaiseAlert
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Diagnostic service estimating the internal state for decision‑support"
    DTDFVocab:provides InsightPredictedTemperatureTrajectory
]

// C17: Insights
instance InsightPredictedTemperatureTrajectory : DTDFVocab:Insight [
    base:desc "Quantitative prediction of future temperature trajectory generated by the simulation algorithm"
]

instance InsightSafetyViolationDetected : DTDFVocab:Insight [
    base:desc "Detection of safety or optimality criterion violation based on monitoring of sensor data and model expectations"
]

// C17: Actions
instance ActionAdjustHeatingSetpoint : DTDFVocab:Action [
    base:desc "Recommendation to adjust the heating power set‑point to reach or maintain the target temperature"
    DTDFVocab:IsAutomatic false
]

instance ActionRaiseAlert : DTDFVocab:Action [
    base:desc "Automatic generation of an alert notifying operators of a detected fault or safety breach"
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin follows a centralized orchestration pattern where sensor data collected from the Physical Twin is ingested by a cyber component that stores models of both the cyber‑physical system and its environment. Calibration algorithms continuously estimate the best‑fit parameters and update these models. The updated model outputs are supplied to monitor components that evaluate safety and optimality criteria. Upon detection of a violation, a decision component—either a human operator or an automated algorithm—issues corrective actions back to the Physical Twin. This architecture integrates data acquisition, model management, calibration, monitoring, and a closed feedback loop to the PT."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed by experimental comparison: the four‑parameter model better predicts the thermal inertia of the heat‑bed than the two‑parameter model, indicating higher fidelity for that aspect. Calibration algorithms are employed to update model parameters using measured temperature data, serving as a validation step. The documents do not describe explicit uncertainty quantification, error detection mechanisms, or broader quality assurance processes beyond this calibration and comparative testing."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT architecture incorporates safety monitoring components that continuously evaluate the physical twin's operating state; when a safety violation is detected, the monitor triggers a response—either human intervention or an automated corrective action. A dedicated safe‑state protocol is embedded in the low‑level driver of the incubator controller to ensure the device remains in a safe condition under fault conditions. These mechanisms together provide run‑time safety checks, fail‑safe behavior, and risk mitigation for the CPS."
]