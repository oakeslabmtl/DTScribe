// C3: Physical sensing components // Return code: 1 | Stderr:
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted inside the incubator box, providing interior temperature measurements."
    DTDFVocab:producedData InternalTempDataTransmitted1
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second temperature sensor mounted inside the incubator box, providing redundant interior temperature measurements."
    DTDFVocab:producedData InternalTempDataTransmitted2
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted outside the incubator box, providing ambient temperature measurements."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Physical-to-virtual interaction
instance InternalTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1
]

instance InternalTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor2
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

// C10: Data
instance ConsolidatedTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature series obtained from the three incubator temperature sensors."
    DTDFVocab:fromData InternalTempDataTransmitted1, InternalTempDataTransmitted2, ExternalTempDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, PredictiveSimulationEnabler
]

// C10: Models
instance TwoParameterThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model of the incubator with two free parameters: overall heat transfer coefficient and lumped thermal capacitance."
    DTDFVocab:inputTo PredictiveSimulationEnabler, CalibrationEnabler
]

instance FourParameterThermalModel : DTDFVocab:Model [
    base:desc "Extended analytical thermal model of the incubator with four free parameters: overall heat transfer coefficient, lumped thermal capacitance, heat‑bed‑specific inertia, and additional thermal mass term."
    DTDFVocab:inputTo PredictiveSimulationEnabler, CalibrationEnabler
]

// C11: Enablers
instance PredictiveSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Computational component that runs the thermal simulation models to predict internal temperature under current operating conditions."
    DTDFVocab:enables PredictiveSimulationService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Algorithmic component that calibrates model parameters continuously using incoming temperature data."
    DTDFVocab:enables CalibrationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Logic that evaluates temperature data against safety and optimality thresholds."
    DTDFVocab:enables MonitoringService
]

instance ControlSupportEnabler : DTDFVocab:Enabler [
    base:desc "Component that decides and issues actuation commands to the heat‑bed based on monitor outcomes."
    DTDFVocab:enables ControlSupportService
]

instance CommunicationEnabler : DTDFVocab:Enabler [
    base:desc "Middleware that exchanges state information between the physical incubator and the digital twin."
    DTDFVocab:enables CommunicationService
]

// C6: Services
instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Provides forward prediction of internal incubator temperature using calibrated thermal models."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Updates model parameters based on latest sensor measurements and estimation algorithms."
    DTDFVocab:provides ModelParameterInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuously checks temperature against safety limits and optimality set‑points, generating alerts."
    DTDFVocab:provides SafetyAlertInsight, OptimalityAlertInsight
]

instance ControlSupportService : DTDFVocab:Service [
    base:desc "Generates actuation commands for the heat‑bed to maintain the desired temperature."
    DTDFVocab:provides TemperatureRegulationAction
]

instance CommunicationService : DTDFVocab:Service [
    base:desc "Synchronizes state and data streams between the physical twin and the cyber twin."
    DTDFVocab:provides StateSyncInsight
]

// C17: Insights
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted internal temperature trajectory useful for planning and optimisation."
]

instance ModelParameterInsight : DTDFVocab:Insight [
    base:desc "Current estimated values of the thermal model free parameters."
]

instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating that temperature exceeds predefined safety thresholds."
]

instance OptimalityAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating that temperature deviates from optimal operating set‑point."
]

instance StateSyncInsight : DTDFVocab:Insight [
    base:desc "Information about the current synchronized state of the physical and digital twins."
]

// C17: Actions
instance TemperatureRegulationAction : DTDFVocab:Action [
    base:desc "Command to adjust heat‑bed power to bring temperature toward the set‑point."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Component
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrically heated element inside the incubator box that provides heat power under controller commands."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "When the DT’s monitoring and optimisation algorithms detect a deviation from desired thermal conditions, they generate control commands (e.g., adjust heat‑bed power or fan operation) that are sent to the physical twin to modify its behaviour, with the effect verified by subsequent sensor measurements."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "According to Document 1, the Digital Twin lifecycle starts with the creation of abstract models (e.g., CAD or dynamic differential‑equation models) during system design. After the physical twin (PT) is deployed, those models are retained and integrated with real‑time sensor data, forming the DT. During operation the DT repeatedly runs calibration algorithms that estimate the best model parameters, then feeds the updated models to monitoring components that evaluate safety and optimality. When a violation is detected, a human operator or an automated decision module may trigger a change in the PT, completing the loop. Thus the stages are: model development, integration at deployment, continuous calibration, monitoring, and corrective decision execution."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing predicted temperature trajectories against measured temperature data from the physical incubator. The study reports that the four‑parameter model reproduces the heat‑bed’s thermal inertia more accurately than the two‑parameter model, indicating higher fidelity for dynamic behaviour. Calibration algorithms are applied to update model parameters using the collected sensor data, providing a systematic validation step. Uncertainty originates from sensor noise and the simplified thermal representation; the calibration process quantifies parameter uncertainty by fitting the best‑estimate parameters. The DT also incorporates monitoring algorithms that detect violations of safety or performance thresholds, serving as an error‑detection mechanism."
]