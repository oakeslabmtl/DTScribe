// Sensors
instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensor embedded in the physical twin that captures the position of the vehicle in real time."
    DTDFVocab:producedData PositionDataTransmitted
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Velocity sensor capturing the vehicle's velocity in real time."
    DTDFVocab:producedData VelocityDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring the vehicle's engine and ambient temperature."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Pressure sensor monitoring tire and hydraulic system pressures."
    DTDFVocab:producedData PressureDataTransmitted
]

// Data Transmitted
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

// Data
instance PositionData : DTDFVocab:Data [
    base:desc "Time‑stamped position measurements transmitted from PositionSensor for model calibration and monitoring."
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, FaultDetectorEnabler, SupervisoryControllerEnabler, StateEstimatorEnabler, OptimiserEnabler
    DTDFVocab:fromData PositionDataTransmitted
]

instance VelocityData : DTDFVocab:Data [
    base:desc "Time‑stamped velocity measurements transmitted from VelocitySensor used for state estimation and optimisation."
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, FaultDetectorEnabler, SupervisoryControllerEnabler, StateEstimatorEnabler, OptimiserEnabler
    DTDFVocab:fromData VelocityDataTransmitted
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature readings from TemperatureSensor for thermal model calibration."
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, FaultDetectorEnabler, SupervisoryControllerEnabler, StateEstimatorEnabler, OptimiserEnabler
    DTDFVocab:fromData TemperatureDataTransmitted
]

instance PressureData : DTDFVocab:Data [
    base:desc "Time‑stamped pressure readings from PressureSensor for hydraulic system monitoring."
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, FaultDetectorEnabler, SupervisoryControllerEnabler, StateEstimatorEnabler, OptimiserEnabler
    DTDFVocab:fromData PressureDataTransmitted
]

// Models
instance CADModel : DTDFVocab:Model [
    base:desc "Geometric CAD representation storing dimensions and shapes of the car chassis and components."
    DTDFVocab:inputTo SupervisoryControllerEnabler, OptimiserEnabler
]

instance DynamicModel : DTDFVocab:Model [
    base:desc "Differential equation based dynamic model capturing the car's motion for simulation and prediction."
    DTDFVocab:inputTo StateEstimatorEnabler, OptimiserEnabler, CalibrationAlgorithmEnabler, FaultDetectorEnabler
]

// Enablers
instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm applying parameter estimation from sensor measurements to improve model accuracy."
    DTDFVocab:enables RealTimeMonitoringService
]

instance FaultDetectorEnabler : DTDFVocab:Enabler [
    base:desc "Fault detector using residual monitoring to identify anomalies in model outputs and sensor streams."
    DTDFVocab:enables FaultDetectionService
]

instance SupervisoryControllerEnabler : DTDFVocab:Enabler [
    base:desc "Supervisory controller enforcing safety constraints and control logic on the vehicle."
    DTDFVocab:enables SafetyPerformanceCheckService
]

instance StateEstimatorEnabler : DTDFVocab:Enabler [
    base:desc "State estimator combining sensor data and dynamic model to estimate vehicle state."
    DTDFVocab:enables PredictiveSimulationService
]

instance OptimiserEnabler : DTDFVocab:Enabler [
    base:desc "Optimiser adjusting operating parameters to improve performance based on model predictions."
    DTDFVocab:enables OptimisationRoutineService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of the physical twin, providing continuous safety‑and‑performance checks."
    DTDFVocab:provides MonitoringInsight, ControlAdjustmentAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection techniques that identify anomalies using state estimation and supervisory control logic."
    DTDFVocab:provides FaultDetectionInsight, MaintenanceInterventionAction
]

instance SafetyPerformanceCheckService : DTDFVocab:Service [
    base:desc "Safety‑and‑performance checks performed via online monitoring algorithms."
    DTDFVocab:provides SupervisoryControlInsight, ControlAdjustmentAction
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation capability reproducing and forecasting the system's behavior under current operating conditions."
    DTDFVocab:provides StateEstimationInsight, MonitoringInsight
]

instance OptimisationRoutineService : DTDFVocab:Service [
    base:desc "Optimisation routines that adjust operating parameters to improve performance."
    DTDFVocab:provides OptimisationInsight, ParameterCorrectionAction
]

// Insights
instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring insight detecting violations of safety or performance criteria."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Fault detection insight identifying anomalies through residual monitoring."
]

instance SupervisoryControlInsight : DTDFVocab:Insight [
    base:desc "Insight from supervisory control indicating necessary control adjustments for safety compliance."
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "State estimation insight providing accurate state predictions for simulation and optimization."
]

instance OptimisationInsight : DTDFVocab:Insight [
    base:desc "Optimisation insight detailing performance improvements through parameter adjustments."
]

// Actions
instance ParameterCorrectionAction : DTDFVocab:Action [
    base:desc "Action to correct model parameters to enhance accuracy."
    DTDFVocab:IsAutomatic true
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Action to adjust vehicle control inputs to maintain safety."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceInterventionAction : DTDFVocab:Action [
    base:desc "Action recommending maintenance intervention based on fault detection."
    DTDFVocab:IsAutomatic false
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle begins with the creation of system models that capture both the physical and cyber aspects of the asset. During deployment, these models are integrated into the DT framework. Continuous calibration algorithms update model parameters using real‑time sensor data, ensuring that the virtual representation remains faithful to the physical twin. Runtime monitoring processes the updated models and sensor streams to identify safety or performance violations. When such violations are detected, either human operators or autonomous supervisory algorithms initiate corrective actions that feed back into the system, completing the lifecycle loop and enabling ongoing refinement."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT’s fidelity is ensured through continuous calibration: model parameters are refined using incoming sensor data to minimise discrepancies between simulation and reality. Validation is performed by monitors that compare operational metrics against predefined safety and performance constraints; fault detectors flag deviations. State estimators infer unmeasured states, while optimisers evaluate alternative control actions based on the calibrated models. This closed‑loop data–model–control cycle underpins the DT’s capacity to detect, correct, and prevent faults, thereby maintaining confidence in both the models and the data streams."
]