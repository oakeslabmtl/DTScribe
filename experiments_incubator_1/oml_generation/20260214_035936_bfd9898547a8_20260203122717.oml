{
    class Component {
        base:desc : String
    }
    class SensingComponent {
        subClassOf: Component
        base:desc : String
        DTDFVocab:producedData : DataTransmitted
    }
    class ActingComponent {
        subClassOf: Component
        base:desc : String
    }
    class Insight {
        base:desc : String
    }
    class Action {
        base:desc : String
        DTDFVocab:IsAutomatic : Boolean
    }
    class Service {
        base:desc : String
        DTDFVocab:provides : Insight | Action
    }
    class Enabler {
        base:desc : String
        DTDFVocab:enables : Service
    }
    class DataTransmitted {
        DTDFVocab:producedFrom : SensingComponent
    }
    class Data {
        base:desc : String
        DTDFVocab:fromData : DataTransmitted
        DTDFVocab:inputTo : Enabler
    }
    class Model {
        base:desc : String
        DTDFVocab:inputTo : Enabler
    }
    class Environment {
        base:desc : String
        base:contains : Component
    }
}