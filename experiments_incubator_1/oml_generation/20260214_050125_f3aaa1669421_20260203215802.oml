// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed MOSFET and optocoupler control module driven by Raspberry Pi GPIO pins"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan MOSFET and optocoupler control module driven by Raspberry Pi GPIO pins"
]

// C3: Physical sensing components
instance InsideTemperatureSensorOne : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor, first position inside the insulated styrofoam incubator, unique 64‑bit serial code"
    DTDFVocab:producedData InsideTemp1DataTransmitted
]

instance InsideTemperatureSensorTwo : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor, second position inside the insulation, unique 64‑bit serial code"
    DTDFVocab:producedData InsideTemp2DataTransmitted
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor, located outside the insulated container, unique 64‑bit serial code"
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// C4: Physical-to-virtual interaction
instance InsideTemp1DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensorOne
]

instance InsideTemp2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensorTwo
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

// C10: Models/Data
instance InsideTemp1Data : DTDFVocab:Data [
    base:desc "Temperature measurement from InsideTemperatureSensorOne, published to RabbitMQ"
    DTDFVocab:inputTo DriverEnabler
]

instance InsideTemp2Data : DTDFVocab:Data [
    base:desc "Temperature measurement from InsideTemperatureSensorTwo, published to RabbitMQ"
    DTDFVocab:inputTo DriverEnabler
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Ambient temperature measurement from AmbientTemperatureSensor, published to RabbitMQ"
    DTDFVocab:inputTo DriverEnabler
]

instance ModelA : DTDFVocab:Model [
    base:desc "Single free‑parameter thermal model with parameter C_air"
    DTDFVocab:inputTo ScipyEnabler
]

instance ModelB : DTDFVocab:Model [
    base:desc "Four‑parameter thermal model with parameters C_heater, C_air, G_heater, G_box"
    DTDFVocab:inputTo ScipyEnabler
]

// C11: Enablers
instance DriverEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level driver abstraction for sensor/actuator I/O, converting DS18S20 raw readings and publishing via RabbitMQ"
    DTDFVocab:enables TemperaturePredictionService, CalibrationService, ComplianceMonitoringService,
                  BangBangControllerService, VisualizationService, ModelValidationService, ParameterTuningService
]

instance ScipyEnabler : DTDFVocab:Enabler [
    base:desc "Python SciPy optimization framework enabling nonlinear least‑squares calibration of ModelA and ModelB"
    DTDFVocab:enables CalibrationService, ParameterTuningService
]

// C6: Services
instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Produces real‑time temperature predictions using calibrated ModelA and ModelB"
    DTDFVocab:provides TemperaturePredictionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Non‑linear least‑squares calibration service using historical temperature data"
    DTDFVocab:provides ResidualErrorPlotInsight
]

instance ComplianceMonitoringService : DTDFVocab:Service [
    base:desc "Monitors temperature compliance against safe lower and upper limits (LL/UL)"
    DTDFVocab:provides ComplianceAlertInsight, AdjustControlLimitsAction
]

instance BangBangControllerService : DTDFVocab:Service [
    base:desc "Bang‑bang style controller state machine switching heatbed and fan on/off"
    DTDFVocab:provides FanOnAction, FanOffAction, HeaterOnAction, HeaterOffAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Basic visualization service offering state‑chart of controller state transitions"
    DTDFVocab:provides StateChartInsight
]

instance ModelValidationService : DTDFVocab:Service [
    base:desc "Validates model predictions against real‑time data and generates validation insight"
    DTDFVocab:provides ModelValidationInsight
]

instance ParameterTuningService : DTDFVocab:Service [
    base:desc "Enables parameter tuning of ModelA and ModelB via user‑defined settings"
    DTDFVocab:provides ParameterTuningInsight, TuneModelParametersAction
]

// C17: Insights/Actions
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Real‑time temperature prediction values generated by the DT models"
]

instance ResidualErrorPlotInsight : DTDFVocab:Insight [
    base:desc "Plot of residual errors between measured and predicted temperatures used for model calibration"
]

instance ComplianceAlertInsight : DTDFVocab:Insight [
    base:desc "Alert when temperature falls outside safe limits (LL/UL)"
]

instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Assessment of model accuracy based on recent data comparison"
]

instance ParameterTuningInsight : DTDFVocab:Insight [
    base:desc "Feedback on parameter adjustments and their impact on model performance"
]

instance StateChartInsight : DTDFVocab:Insight [
    base:desc "State‑chart visualization of bang‑bang controller operations"
]

instance AdjustControlLimitsAction : DTDFVocab:Action [
    base:desc "Operator action to adjust safety limits (LL/UL) for temperature monitoring"
    DTDFVocab:IsAutomatic false
]

instance TuneModelParametersAction : DTDFVocab:Action [
    base:desc "Automatic or manual action to retune model parameters"
    DTDFVocab:IsAutomatic false
]

instance FanOnAction : DTDFVocab:Action [
    base:desc "Turn the fan actuator on"
    DTDFVocab:IsAutomatic true
]

instance FanOffAction : DTDFVocab:Action [
    base:desc "Turn the fan actuator off"
    DTDFVocab:IsAutomatic true
]

instance HeaterOnAction : DTDFVocab:Action [
    base:desc "Turn the heatbed actuator on"
    DTDFVocab:IsAutomatic true
]

instance HeaterOffAction : DTDFVocab:Action [
    base:desc "Turn the heatbed actuator off"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin publishes control commands (e.g., heatbed on/off, fan on/off, heating/waiting durations) to the RabbitMQ broker. The Raspberry Pi controller consumes these messages and applies the received commands to the actuators via GPIO, thereby influencing the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation consists of the physical hardware (heatbed, fan, sensors, Raspberry Pi), the low‑level driver, the controller software, and the RabbitMQ message broker. The controller and driver run on the same Pi, exchanging messages through RabbitMQ, while the DT (model and calibration code) may run separately on a host machine accessing the broker. This architecture is decentralized per component but orchestrated via the broker."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity relies on four key assumptions (uniform internal temperature, negligible wall heat accumulation, constant specific heat of air, negligible fan heat). Validation is performed by comparing model output against experimental temperature traces and minimizing the residual error in the least‑squares objective; no stochastic uncertainty quantification is reported."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data flow uses the 1‑Wire bus for sensors and GPIO pins for actuators; inter‑module communication occurs over RabbitMQ using the AMQP protocol on the local network; the Raspberry Pi provides built‑in Wi‑Fi for remote access but the broker runs locally."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT runtime components—controller, low‑level driver, RabbitMQ broker, and simulation/calibration scripts—are deployed on a single Raspberry Pi 4 Model B located inside the incubator enclosure. The Pi powers the PT hardware and hosts the core DT logic. No external cloud deployment is described in the documents."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver implements a safe protocol to guard against erroneous commands, and MOSFETs with optocouplers provide electrical isolation between the Pi and high‑current heatbed. No explicit cybersecurity measures are described, but the use of RabbitMQ on a local network limits exposure to external actors."
]