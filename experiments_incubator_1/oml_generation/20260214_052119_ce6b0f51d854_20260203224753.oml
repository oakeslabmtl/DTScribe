// C3: Physical Sensing Components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "High-precision temperature sensor monitoring the internal box temperature of the incubator for thermal regulation."
    DTDFVocab:producedData InternalTemperatureDataStream1
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "High-precision temperature sensor monitoring the internal box temperature of the incubator for redundancy and spatial coverage."
    DTDFVocab:producedData InternalTemperatureDataStream2
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring ambient conditions outside the incubator to account for environmental variations."
    DTDFVocab:producedData ExternalTemperatureDataStream
]

// C4: Physical-to-Virtual Interaction
instance InternalTemperatureDataStream1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1
]

instance InternalTemperatureDataStream2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor2
]

instance ExternalTemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

// C10: Models/Data
instance LumpedThermalMassModel : DTDFVocab:Model [
    base:desc "Dynamic model implemented via differential equations simulating transient thermal behavior of the incubator, validated against sensor data."
    DTDFVocab:inputTo ThermalCalibrationEnabler, StateEstimationEnabler
]

instance TwoParameterThermalModel : DTDFVocab:Model [
    base:desc "Analytical model with two free parameters for thermal inertia prediction, used for baseline thermal behavior simulation."
    DTDFVocab:inputTo ThermalCalibrationEnabler
]

instance FourParameterThermalModel : DTDFVocab:Model [
    base:desc "Analytical model with four free parameters demonstrating superior accuracy in predicting thermal inertia, validated experimentally."
    DTDFVocab:inputTo ThermalCalibrationEnabler
]

instance SensorDataTimeSeries : DTDFVocab:Data [
    base:desc "Time-series data stream containing raw temperature readings from internal and external sensors for historical analysis."
    DTDFVocab:fromData InternalTemperatureDataStream1, InternalTemperatureDataStream2, ExternalTemperatureDataStream
    DTDFVocab:inputTo DataFusionEnabler, TimeSeriesDatabaseEnabler
]

instance CalibratedModelParameters : DTDFVocab:Data [
    base:desc "Updated model parameters (e.g., thermal conductivity, heat transfer coefficients) derived from calibration algorithms."
    DTDFVocab:fromData InternalTemperatureDataStream1, InternalTemperatureDataStream2, ExternalTemperatureDataStream
    DTDFVocab:inputTo ThermalCalibrationEnabler
]

// C11: Enablers
instance RaspberryPiController : DTDFVocab:Enabler [
    base:desc "Embedded controller interfacing with sensors/actuators and communicating with the DT's cyber components via MQTT/OPC UA."
    DTDFVocab:enables RealTimeMonitoringService
]

instance PythonFramework : DTDFVocab:Enabler [
    base:desc "Python-based framework for model implementation, data processing, and algorithm execution in the DT."
    DTDFVocab:enables PredictiveSimulationService, CalibrationService, StateEstimationService
]

instance ThermalCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithms adjusting model parameters (e.g., thermal conductivity) using real-time sensor data."
    DTDFVocab:enables CalibrationService
]

instance DataFusionEnabler : DTDFVocab:Enabler [
    base:desc "Data fusion algorithms combining noisy sensor readings into a consistent state estimate for internal temperature."
    DTDFVocab:enables StateEstimationService
]

instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "Kalman or particle filters estimating internal states (e.g., true temperature) from noisy sensor data."
    DTDFVocab:enables StateEstimationService, PredictiveSimulationService
]

instance SupervisoryControllerEnabler : DTDFVocab:Enabler [
    base:desc "Supervisory controllers monitoring safety invariants (e.g., temperature bounds) and triggering corrective actions."
    DTDFVocab:enables SafetyMonitoringService
]

instance ModelPredictiveControlEnabler : DTDFVocab:Enabler [
    base:desc "Model-predictive control optimizer adjusting heating/cooling inputs dynamically for energy efficiency."
    DTDFVocab:enables ControlOptimizationService
]

instance TimeSeriesDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database (e.g., InfluxDB) storing sensor data streams for historical analysis and model training."
    DTDFVocab:enables HistoricalAnalysisService
]

instance VisualizationDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Real-time dashboard displaying temperature trajectories, control signals, and fault alerts (e.g., Grafana)."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous acquisition of sensor data from the PT enabling real-time state estimation and anomaly detection."
    DTDFVocab:provides RealTimeTemperatureInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Execution of dynamic models to reproduce and predict the PT's thermal behavior under current or hypothetical conditions."
    DTDFVocab:provides PredictedThermalBehaviorInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Use of calibration algorithms to update cyber-physical models with real-time sensor data for accuracy."
    DTDFVocab:provides UpdatedModelParametersInsight
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Deployment of fault detectors and supervisory controllers to validate safety constraints and detect deviations."
    DTDFVocab:provides SafetyComplianceInsight
]

instance ControlOptimizationService : DTDFVocab:Service [
    base:desc "Integration of optimization algorithms to adjust heating/cooling inputs dynamically for energy efficiency."
    DTDFVocab:provides EnergyOptimizationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Generation of advanced visualizations (e.g., time-series plots, thermal distribution maps) for decision support."
    DTDFVocab:provides ThermalDistributionInsight, PerformanceTrendInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Estimation of internal states (e.g., true temperature) from noisy sensor data using Kalman/particle filters."
    DTDFVocab:provides StateEstimateInsight, SensorFusionInsight
]

instance HistoricalAnalysisService : DTDFVocab:Service [
    base:desc "Analysis of stored time-series data for identifying wear-and-tear patterns and long-term performance trends."
    DTDFVocab:provides MaintenancePredictionInsight, PerformanceTrendInsight
]

// C17: Insights/Actions
instance RealTimeTemperatureInsight : DTDFVocab:Insight [
    base:desc "Continuous real-time monitoring of internal and external temperatures for immediate state awareness."
]

instance PredictedThermalBehaviorInsight : DTDFVocab:Insight [
    base:desc "Predicted thermal behavior of the incubator under current or hypothetical operating conditions."
]

instance UpdatedModelParametersInsight : DTDFVocab:Insight [
    base:desc "Calibrated model parameters (e.g., thermal conductivity, heat transfer coefficients) aligned with real-time data."
]

instance SafetyComplianceInsight : DTDFVocab:Insight [
    base:desc "Validation of adherence to safety constraints (e.g., maximum/minimum temperature thresholds)."
]

instance FaultAlertAction : DTDFVocab:Action [
    base:desc "Automatic alert generation when deviations (e.g., sensor failures, actuator malfunctions) are detected."
    DTDFVocab:IsAutomatic true
]

instance CorrectiveActionAction : DTDFVocab:Action [
    base:desc "Triggering of corrective actions (e.g., shutting down heaters) when safety thresholds are violated."
    DTDFVocab:IsAutomatic true
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized heating/cooling inputs to minimize energy consumption while maintaining temperature stability."
]

instance DynamicControlAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of heating/cooling inputs based on real-time optimization algorithms."
    DTDFVocab:IsAutomatic true
]

instance ThermalDistributionInsight : DTDFVocab:Insight [
    base:desc "Visual representation of thermal distribution within the incubator for spatial analysis."
]

instance PerformanceTrendInsight : DTDFVocab:Insight [
    base:desc "Historical performance trends and degradation patterns for predictive maintenance."
]

instance StateEstimateInsight : DTDFVocab:Insight [
    base:desc "Estimated internal states (e.g., true temperature) derived from noisy sensor data fusion."
]

instance SensorFusionInsight : DTDFVocab:Insight [
    base:desc "Consolidated sensor data into a single, reliable state estimate for internal temperature."
]

instance MaintenancePredictionInsight : DTDFVocab:Insight [
    base:desc "Proactive identification of wear-and-tear patterns (e.g., fan degradation, sensor drift)."
]

instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Validation of model predictions against real-world behavior for accuracy assessment."
]

// C1: Physical Components
instance IncubatorContainer : DTDFVocab:Component [
    base:desc "Insulated styrofoam box providing thermal insulation to maintain internal temperature."
]

instance HeatBed : DTDFVocab:Component [
    base:desc "Heating element generating and distributing heat inside the incubator container."
]

instance IncubatorFan : DTDFVocab:Component [
    base:desc "Air circulation component ensuring uniform temperature distribution within the incubator."
]

instance RaspberryPiHardware : DTDFVocab:Component [
    base:desc "Hardware platform acting as the central controller for monitoring and regulating the incubator system."
]

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Operational environment of the incubator including ambient conditions and internal load variations."
    base:contains IncubatorContainer, HeatBed, IncubatorFan, InternalTemperatureSensor1, InternalTemperatureSensor2, ExternalTemperatureSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT exerts control over the Physical Twin (PT) via **command signals** generated by **supervisory controllers** or optimization algorithms. These commands are transmitted to the **Raspberry Pi**, which acts as the interface between the DT and the PT. The control messages include **temperature setpoints** and **actuation commands** (e.g., adjusting the heatbed or fan speed) to maintain the desired internal temperature. **Validation and authentication mechanisms** are not explicitly described, but the system implies **closed-loop feedback** where the DT continuously compares predicted vs. actual PT behavior. Conflict resolution is handled implicitly by the **calibration algorithms**, which adjust models to minimize discrepancies between the DT and PT. Command execution confirmation is inferred through **monitoring algorithms** that verify the PT's response (e.g., temperature stabilization) against the DT's predictions."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system operates with a temporal synchronization mechanism that relies on **real-time data collection** from the Physical Twin (PT) via sensors, enabling continuous monitoring of the system's state. The system incorporates **calibration algorithms** to periodically update the models of the Cyber-Physical System (CPS) and its environment, ensuring the Digital Twin's models reflect the PT's current operating conditions. While the documents do not specify exact synchronization frequencies or latency requirements, the framework implies **low-latency data exchange** to support real-time monitoring, fault detection, and dynamic adjustments (e.g., via supervisory controllers or state estimators). The temporal granularity is dictated by the sensor sampling rates and the computational overhead of model updates, with a trade-off between accuracy and simulation speed (e.g., high-fidelity models may require longer processing times)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a **closed-loop orchestration pattern**, as illustrated in Fig. 1, where the **Cyber-Physical System (CPS)-based Digital Twin** integrates three core components: **data** (sensor-collected from the PT), **models** (multi-aspect representations of the PT and environment), and **algorithms** (e.g., calibration, fault detection, supervisory control). The architecture employs **feedback loops** to dynamically adjust the PT based on real-time violations detected by monitors. Resource management is implicit, with **calibration algorithms** prioritizing model accuracy (e.g., via parameter estimation) and **monitors/controllers** ensuring operational safety. The system-wide coordination relies on **tight coupling** between data acquisition, model updates, and decision-making, with no explicit mention of middleware or orchestration frameworks (e.g., Kubernetes, ROS) but a clear dependency on **real-time data processing pipelines**."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The lifecycle of a Digital Twin (DT) as described in the provided documents encompasses the following phases: **1) Model Development**: Abstract representations of the Physical Twin (PT) are created at varying levels of abstraction (e.g., CAD models for geometric properties or dynamic models described by differential equations for behavioral analysis). These models may include cyber-physical system (CPS) components and environmental interactions. **2) Integration into DT Framework**: Post-deployment, models are retained and integrated into the DT framework, which combines **data** (collected via sensors from the PT over time), **models** (knowledge of PT and environment), and **algorithms** (e.g., calibration, fault detection, state estimation). **3) Calibration and Validation**: The DT employs **calibration algorithms** to update models with real-time sensor data, ensuring accurate parameter estimation. **4) Monitoring and Control**: The DT continuously monitors the PT’s performance (e.g., safety and optimality checks) and enables **human-in-the-loop** or algorithmic interventions when deviations are detected. **5) Evolution and Adaptation**: The DT supports **reconfigurability** and **robustness** by dynamically adjusting to environmental changes, leveraging updated models and algorithms. Governance is implicit through iterative validation and feedback loops between the DT and PT, ensuring alignment with operational goals. Transition management between phases is facilitated by **data-driven model updates** and **algorithm-driven decision-making**, with no explicit mention of formal governance frameworks (e.g., ISO standards) in the provided context."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin emphasizes **model fidelity** through:
  - **Validation and verification methods**: Comparative experiments (e.g., the incubator’s two-parameter vs. four-parameter thermal models) to assess predictive accuracy, where the four-parameter model was selected for its superior thermal inertia representation.
  - **Uncertainty sources and quantification**: Free parameters in models (e.g., thermal properties) introduce uncertainty, mitigated via calibration algorithms that refine parameter estimates using real-time sensor data.
  - **Error detection and correction mechanisms**: Monitors within the DT framework detect performance violations (e.g., unsafe or suboptimal operation) and trigger corrective actions, either autonomously via algorithms or through human intervention.
  - **Quality assurance processes**: Continuous integration of sensor data and model updates ensures the DT remains synchronized with the PT, while open-source accessibility (e.g., incubator case study) facilitates third-party validation and refinement of methodologies."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT relies on a **cyber-physical system (CPS) architecture** where the **Raspberry Pi** serves as the central node for data acquisition and command execution. The **communication protocols** are not explicitly specified, but the system implies **local, low-latency connections** between sensors, the controller, and the DT. The network topology is **star-based**, with the Raspberry Pi aggregating sensor data and distributing control signals. **Bandwidth requirements** are minimal due to the low-frequency, high-precision temperature readings, but **latency must be sufficiently low** to ensure real-time calibration and monitoring. **Reliability mechanisms** are not detailed, though redundancy in sensor readings (two internal temperature sensors) suggests fault tolerance. **Security protocols** are not mentioned, but the system’s closed-loop nature implies criticality for integrity and availability."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed on a **local/edge computing platform** (Raspberry Pi) to minimize latency and ensure real-time interaction with the PT. **Computational requirements** are modest, focusing on **model calibration, simulation, and monitoring** of temperature dynamics. **Storage requirements** are minimal, as the system primarily retains **time-series sensor data** and **model parameters** for short-term analysis. **Scalability mechanisms** are not discussed, but the modular design (e.g., separate models for cyber/physical aspects) suggests potential for extension. The deployment model is **hybrid**, combining **on-premise execution** (Raspberry Pi) with potential **cloud-based optimization** (e.g., for complex simulations). **Availability/reliability assurance** is implied through **continuous monitoring** and **model validation**, though no explicit redundancy or failover strategies are described."
]