// Acting components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET-controlled electrical heater mounted on the 214 mm × 214 mm × 3 mm heatbed, powered via Raspberry Pi GPIO."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V circulation fan driven by MOSFETs, controlled through Raspberry Pi GPIO."
]

// Physical sensing components
instance TemperatureSensorT1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one-wire temperature sensor placed inside the incubator box (sensor T1), 64‑bit serial code 0x0043AA00123456."
    DTDFVocab:producedData TemperatureDataT1Transmitted
]

instance TemperatureSensorT3 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor placed inside the incubator box (sensor T3), 64‑bit serial code 0x0043AA00765432."
    DTDFVocab:producedData TemperatureDataT3Transmitted
]

instance RoomTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located outside the box to measure room temperature, 64‑bit serial code 0x0043AA00987654."
    DTDFVocab:producedData RoomTemperatureDataTransmitted
]

// Physical-to-virtual interaction (Data transmitted)
instance TemperatureDataT1Transmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT1
]

instance TemperatureDataT3Transmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorT3
]

instance RoomTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTemperatureSensor
]

// Data from the knowledge layer
instance TemperatureDataT1 : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from sensor T1."
    DTDFVocab:fromData TemperatureDataT1Transmitted
    DTDFVocab:inputTo OneWireCommunication
]

instance TemperatureDataT3 : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from sensor T3."
    DTDFVocab:fromData TemperatureDataT3Transmitted
    DTDFVocab:inputTo OneWireCommunication
]

instance RoomTemperatureData : DTDFVocab:Data [
    base:desc "Timestamped room temperature reading."
    DTDFVocab:fromData RoomTemperatureDataTransmitted
    DTDFVocab:inputTo OneWireCommunication
]

// Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Lumped‑parameter thermal model A with single temperature, parameters C_air and G_box."
    DTDFVocab:inputTo Python3Runtime, ScipyOptimization
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Lumped‑parameter thermal model B with dual temperatures, parameters C_heater, C_air, G_heater, G_box."
    DTDFVocab:inputTo Python3Runtime, ScipyOptimization
]

// Enablers
instance RaspberryPi4Controller : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B acting as the central controller, GPIO and Wi‑Fi."
    DTDFVocab:enables ModelSimulationService, OnlineCalibrationService, TemperatureMonitoringService, SafetyCheckService, TemperatureVisualizationService, BangBangControllerService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker for publishing sensor data and alerts."
    DTDFVocab:enables TemperatureMonitoringService, BangBangControllerService
]

instance Python3Runtime : DTDFVocab:Enabler [
    base:desc "Python 3 runtime executing model simulations and optimisations."
    DTDFVocab:enables ModelSimulationService, OnlineCalibrationService
]

instance ScipyOptimization : DTDFVocab:Enabler [
    base:desc "SciPy optimize package for non‑linear least‑squares calibration."
    DTDFVocab:enables OnlineCalibrationService
]

instance OneWireCommunication : DTDFVocab:Enabler [
    base:desc "1‑Wire communication protocol for DS18S20 sensor polling."
    DTDFVocab:enables TemperatureMonitoringService
]

instance GitHubRepository : DTDFVocab:Enabler [
    base:desc "Open‑source GitHub repository hosting code, data, and calibration results."
    DTDFVocab:enables ModelSimulationService
]

// Services
instance ModelSimulationService : DTDFVocab:Service [
    base:desc "Provides model‑based simulation of temperature dynamics using Model A and Model B."
    DTDFVocab:provides TemperatureTrajectoryInsight
]

instance OnlineCalibrationService : DTDFVocab:Service [
    base:desc "Performs online calibration using non‑linear least squares via SciPy."
    DTDFVocab:provides GapInsight, RecalibrateAction
]

instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Monitors measured temperatures against model predictions and performs safety checks."
    DTDFVocab:provides GapInsight, AlertInsight
]

instance SafetyCheckService : DTDFVocab:Service [
    base:desc "Runs safety checks on temperature deviations to ensure safe operation."
    DTDFVocab:provides SafetyCheckInsight
]

instance TemperatureVisualizationService : DTDFVocab:Service [
    base:desc "Visualises temperature trajectories and uniformity analysis."
    DTDFVocab:provides TemperatureTrajectoryInsight, UniformityAnalysisInsight
]

instance BangBangControllerService : DTDFVocab:Service [
    base:desc "Provides bang‑bang controller interface for real‑time operation."
    DTDFVocab:provides AdjustHeatingAction, AdjustFanAction
]

// Insights
instance GapInsight : DTDFVocab:Insight [
    base:desc "Highlights the difference between predicted temperatures (Model A/B) and measured sensor data in real time."
]

instance AlertInsight : DTDFVocab:Insight [
    base:desc "Triggers alert when deviation exceeds user‑defined threshold; alert sent via RabbitMQ."
]

instance TemperatureTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Displays temperature trajectories over time for monitoring."
]

instance UniformityAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analyzes temperature uniformity within the insulating box."
]

instance SafetyCheckInsight : DTDFVocab:Insight [
    base:desc "Indicates whether safety checks regarding temperature limits have passed."
]

// Actions
instance AdjustHeatingAction : DTDFVocab:Action [
    base:desc "Adjusts heating duty cycle of the heatbed."
    DTDFVocab:IsAutomatic false
]

instance AdjustFanAction : DTDFVocab:Action [
    base:desc "Adjusts fan speed to control air circulation."
    DTDFVocab:IsAutomatic false
]

instance RecalibrateAction : DTDFVocab:Action [
    base:desc "Recommends recalibration of the thermal model when drift is detected."
    DTDFVocab:IsAutomatic false
]

instance SendAlertAction : DTDFVocab:Action [
    base:desc "Sends an alert message via RabbitMQ when temperature deviation is high."
    DTDFVocab:IsAutomatic true
]

// Physical components
instance StyrofoamInsulatingBox : DTDFVocab:Component [
    base:desc "Styrofoam® insulating box (~0.03 m³) enclosing the heatbed and sensors."
]

instance HeatbedHeater : DTDFVocab:Component [
    base:desc "214 mm × 214 mm × 3 mm electrical heater mounted on the box, powered via MOSFET."
]

instance CirculationFan : DTDFVocab:Component [
    base:desc "12 V/24 V fan for air circulation within the box."
]

instance RaspberryPi4Hardware : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B controller providing GPIO, Wi‑Fi, and computational capability."
]

instance MOSFETSwitch : DTDFVocab:Component [
    base:desc "MOSFET switch with optocoupler isolation controlling heater and fan."
]

instance OptocouplerIsolation : DTDFVocab:Component [
    base:desc "Optocoupler used to isolate the Raspberry Pi GPIO from the MOSFET circuitry."
]

instance LowLevelDriver : DTDFVocab:Component [
    base:desc "Low‑level driver interfacing DS18S20 sensors over 1‑Wire bus."
]

instance RabbitMQServer : DTDFVocab:Component [
    base:desc "RabbitMQ AMQP broker server running on the Raspberry Pi."
]

instance GitHubRepoComponent : DTDFVocab:Component [
    base:desc "GitHub open‑source repository hosting the twin’s code, data, and calibration results."
]

// Environment
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:contains StyrofoamInsulatingBox, HeatbedHeater, CirculationFan, RaspberryPi4Hardware, MOSFETSwitch, OptocouplerIsolation, LowLevelDriver, RabbitMQServer, GitHubRepoComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The controller logic, implemented on the Raspberry Pi, subscribes to control messages on RabbitMQ. Upon receiving a command (e.g., turn the heatbed / fan on or off, or set a duty cycle), it issues corresponding GPIO signals to the MOSFET driver circuitry, thereby actuating the heatbed and fan. The controller’s state machine (a bang‑bang style with lower/upper temperature limits, heating and waiting durations) is also part of this virtual‑to‑physical interaction layer."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is composed of a low‑level driver, a controller (bang‑bang logic), a RabbitMQ communication server running on the Pi, a Python calibration module, and simulation models. All components run on the same hardware and publish/subscribe via RabbitMQ topics."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model assumptions: uniform temperature distribution (validated by fan tests), negligible heat transfer to box walls, constant specific heat capacity of air, negligible fan heat contribution. Validation uses uniformity experiments comparing sensor positions and calibration error minimization with Scipy least‑squares. Remaining uncertainty is in the heat transfer coefficient G_box and G_heater."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All physical–virtual communication occurs locally on the Raspberry Pi. Sensors connect via the 1‑Wire bus to the Pi’s GPIO; MOSFET drivers interface with the Pi through optocouplers for electrical isolation. The virtual components (controller, simulator) communicate with the driver and each other through a RabbitMQ broker running on the same device, using standard AMQP protocol over the Pi’s TCP/IP stack. Optional Wi‑Fi/Bluetooth interfaces are present but not used for the twin’s core communication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components (low‑level driver, controller, simulation models, RabbitMQ broker) run on the same Raspberry Pi 4 Model B under Linux, sharing the PT enclosure."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is embedded in the low‑level driver to prevent runaway operation (e.g., overheating). Electrical isolation is achieved via optocouplers between the Pi and MOSFETs, and the Mosfet current limits avoid over‑current scenarios. The RabbitMQ broker provides reliable, queued message delivery; however, encryption or authentication layers are not reported in the document."
]