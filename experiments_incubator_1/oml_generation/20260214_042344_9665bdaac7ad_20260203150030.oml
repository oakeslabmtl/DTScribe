// C3: Physical sensing components
instance EngineTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Engine temperature sensor mounted on the internal combustion engine, capturing real‑time state data."
    DTDFVocab:producedData EngineTempDataTx
]

instance WheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel speed sensor measuring rotational speed of each wheel in real‑time."
    DTDFVocab:producedData WheelSpeedDataTx
]

instance ChassisAccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Acceleration sensor mounted on the chassis, measuring vehicle longitudinal and lateral acceleration."
    DTDFVocab:producedData ChassisAccelDataTx
]

instance BatteryVoltageSensor : DTDFVocab:SensingComponent [
    base:desc "Voltage sensor monitoring battery pack voltage during operation."
    DTDFVocab:producedData BatteryVoltageDataTx
]

// C4: Physical-to-virtual interaction
instance EngineTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EngineTemperatureSensor
]

instance WheelSpeedDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedSensor
]

instance ChassisAccelDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChassisAccelerationSensor
]

instance BatteryVoltageDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BatteryVoltageSensor
]

// C10: Models/Data
instance EngineTempData : DTDFVocab:Data [
    base:desc "Continuous time‑series data stream of engine temperature recorded over time."
    DTDFVocab:inputTo CalibrationAlgorithm
    DTDFVocab:fromData EngineTempDataTx
]

instance WheelSpeedData : DTDFVocab:Data [
    base:desc "Continuous time‑series data stream of wheel rotational speeds."
    DTDFVocab:inputTo FaultDetector
    DTDFVocab:fromData WheelSpeedDataTx
]

instance ChassisAccelData : DTDFVocab:Data [
    base:desc "Continuous time‑series data stream of chassis accelerations."
    DTDFVocab:inputTo StateEstimator
    DTDFVocab:fromData ChassisAccelDataTx
]

instance BatteryVoltageData : DTDFVocab:Data [
    base:desc "Continuous time‑series data stream of battery voltage."
    DTDFVocab:inputTo Optimizer
    DTDFVocab:fromData BatteryVoltageDataTx
]

instance CADShapeModel : DTDFVocab:Model [
    base:desc "Geometric representation of the vehicle chassis, wheels, and engine based on CAD files."
    DTDFVocab:inputTo SimulationEngine
]

instance DynamicBehaviourModel : DTDFVocab:Model [
    base:desc "Physics‑based model expressed as differential equations capturing vehicle dynamics."
    DTDFVocab:inputTo SimulationEngine
]

instance AnalyticalStateMappingModel : DTDFVocab:Model [
    base:desc "Model that maps sensor data to hidden physical state variables such as vehicle stability and load distribution."
    DTDFVocab:inputTo StateEstimator
]

// C11: Enablers
instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that estimates model parameters from sensor data to update the CPS model."
    DTDFVocab:enables CalibrationService
]

instance FaultDetector : DTDFVocab:Enabler [
    base:desc "Fault detection algorithm that identifies anomalies in vehicle state data."
    DTDFVocab:enables FaultDetectionService
]

instance StateEstimator : DTDFVocab:Enabler [
    base:desc "State estimation algorithm that reconstructs hidden system states from sensor data."
    DTDFVocab:enables StateEstimationService
]

instance SupervisoryController : DTDFVocab:Enabler [
    base:desc "Supervisory controller that issues corrective commands to the vehicle based on safety constraints."
    DTDFVocab:enables SupervisoryControlService
]

instance Optimizer : DTDFVocab:Enabler [
    base:desc "Optimisation algorithm that calculates optimal parameter settings to improve vehicle efficiency."
    DTDFVocab:enables OptimisationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine that performs predictive simulation using dynamic behaviour models."
    DTDFVocab:enables PredictiveSimulationService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that performs model calibration using the calibration algorithm and sensor data."
    DTDFVocab:provides CalibrationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service that monitors data via fault detection algorithm to flag anomalies."
    DTDFVocab:provides FaultDetectionInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Service that provides state estimation using the state estimation algorithm."
    DTDFVocab:provides StateEstimationInsight
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Service that issues corrective commands via the supervisory controller."
    DTDFVocab:provides SupervisoryControlAction
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Service that computes optimal parameters for vehicle efficiency."
    DTDFVocab:provides OptimisationRecommendationAction
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Service that simulates future vehicle performance under current operating conditions using predictive simulation."
    DTDFVocab:provides PredictiveSimulationInsight
]

// C17: Insights/Actions
instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating calibration status and updated model parameters."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating detected faults in vehicle components."
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Insight providing estimated vehicle state variables."
]

instance SupervisoryControlAction : DTDFVocab:Action [
    base:desc "Action to adjust throttle, braking, or steering to maintain safety."
    DTDFVocab:IsAutomatic true
]

instance OptimisationRecommendationAction : DTDFVocab:Action [
    base:desc "Action suggesting optimal parameter adjustments for improved efficiency."
    DTDFVocab:IsAutomatic false
]

instance PredictiveSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight predicting vehicle performance under current operating conditions."
]

// C2: Acting component
instance ThrottleActuator : DTDFVocab:ActingComponent [
    base:desc "Throttle actuator enabling adjustment of engine throttle position during operation."
]

// C18: Environment
instance VehicleSystem : DTDFVocab:Environment [
    base:desc "Physical vehicle comprising sensors, actuators, and associated models."
]