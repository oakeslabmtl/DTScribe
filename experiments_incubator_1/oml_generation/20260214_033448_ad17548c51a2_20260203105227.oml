{
    class Insight {
        base:desc String
    }
    class Action {
        base:desc String
        DTDFVocab:IsAutomatic Boolean
    }
    class Service {
        base:desc String
        DTDFVocab:provides Insight | Action
    }
    class Enabler {
        base:desc String
        DTDFVocab:enables Service
    }
    class Model {
        base:desc String
        DTDFVocab:inputTo Enabler
    }
    class SensingComponent {
        base:desc String
        DTDFVocab:producedData DataTransmitted
    }
    class DataTransmitted {
        base:desc String
        DTDFVocab:producedFrom SensingComponent
    }
    class Data {
        base:desc String
        DTDFVocab:fromData DataTransmitted
        DTDFVocab:inputTo Enabler
    }
}