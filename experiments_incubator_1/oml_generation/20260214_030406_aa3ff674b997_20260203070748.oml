// C3: Physical sensing components
instance InteriorTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor monitoring interior temperature of the incubator (first interior sensor)."
    DTDFVocab:producedData InteriorTempDataTransmittedA
]

instance InteriorTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor monitoring interior temperature of the incubator (second interior sensor)."
    DTDFVocab:producedData InteriorTempDataTransmittedB
]

instance ExteriorTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor monitoring exterior temperature of the incubator."
    DTDFVocab:producedData ExteriorTempDataTransmitted
]

// C4: Physical‑to‑virtual interaction (data transmission)
instance InteriorTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTempSensorA
]

instance InteriorTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTempSensorB
]

instance ExteriorTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExteriorTempSensor
]

// C10: Data (raw temperature streams)
instance InteriorTempDataA : DTDFVocab:Data [
    base:desc "Time‑stamped interior temperature readings from InteriorTempSensorA."
    DTDFVocab:fromData InteriorTempDataTransmittedA
    DTDFVocab:inputTo MonitoringEnabler, CalibrationEnabler
]

instance InteriorTempDataB : DTDFVocab:Data [
    base:desc "Time‑stamped interior temperature readings from InteriorTempSensorB."
    DTDFVocab:fromData InteriorTempDataTransmittedB
    DTDFVocab:inputTo MonitoringEnabler, CalibrationEnabler
]

instance ExteriorTempData : DTDFVocab:Data [
    base:desc "Time‑stamped exterior temperature readings from ExteriorTempSensor."
    DTDFVocab:fromData ExteriorTempDataTransmitted
    DTDFVocab:inputTo MonitoringEnabler, CalibrationEnabler
]

// C10: Models (simulation of temperature dynamics)
instance SimpleIncubatorThermalModel : DTDFVocab:Model [
    base:desc "Simple analytical model of incubator temperature dynamics with two free parameters."
    DTDFVocab:inputTo SimulationEnabler, OptimisationEnabler
]

instance RichIncubatorThermalModel : DTDFVocab:Model [
    base:desc "Rich analytical model of incubator temperature dynamics with four free parameters."
    DTDFVocab:inputTo SimulationEnabler, OptimisationEnabler
]

// C2: Acting component
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed actuator that supplies heat to raise the internal temperature, driven by set‑points from the digital twin."
]

// C11: Enablers (algorithms / engines)
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration engine that fits model parameters to live temperature data."
    DTDFVocab:enables CalibrationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring engine that processes incoming temperature streams for real‑time analysis."
    DTDFVocab:enables RealTimeMonitoringService, SafetyCheckService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs the thermal models to predict future temperature behaviour."
    DTDFVocab:enables PredictionService
]

instance OptimisationEnabler : DTDFVocab:Enabler [
    base:desc "Optimisation engine that computes optimal set‑points for the heatbed to maintain target temperature."
    DTDFVocab:enables OptimisationService
]

instance VisualisationEnabler : DTDFVocab:Enabler [
    base:desc "Visualisation engine that prepares temperature evolution graphics for operators."
    DTDFVocab:enables VisualisationService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that produces calibrated model parameters from sensor data."
    DTDFVocab:provides ModelCalibrationInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service that continuously monitors temperature streams for performance deviations."
    DTDFVocab:provides PerformanceViolationInsight
]

instance SafetyCheckService : DTDFVocab:Service [
    base:desc "Service that checks temperature data against safety thresholds."
    DTDFVocab:provides TemperatureSafetyInsight, SendAlertAction
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Service that predicts future internal temperature using the selected thermal model."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Service that recommends optimal heatbed set‑points to achieve the target temperature."
    DTDFVocab:provides ControlSetpointRecommendationInsight, AdjustHeatbedAction
]

instance VisualisationService : DTDFVocab:Service [
    base:desc "Service that generates visualisations of temperature evolution for operators."
    DTDFVocab:provides VisualiseTemperatureAction
]

// C17: Insights
instance TemperatureSafetyInsight : DTDFVocab:Insight [
    base:desc "Detects safety violations such as overheating of the incubator interior."
]

instance PerformanceViolationInsight : DTDFVocab:Insight [
    base:desc "Detects performance violations where temperature deviates from the desired set‑point."
]

instance ControlSetpointRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommends optimal control set‑points to maintain the target temperature efficiently."
]

instance ModelCalibrationInsight : DTDFVocab:Insight [
    base:desc "Provides the calibrated parameter values for the thermal model after fitting sensor data."
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicts future internal temperature based on the current model and set‑points."
]

// C17: Actions
instance AdjustHeatbedAction : DTDFVocab:Action [
    base:desc "Command to adjust the heatbed power level according to the recommended set‑point."
    DTDFVocab:IsAutomatic true
]

instance SendAlertAction : DTDFVocab:Action [
    base:desc "Automatic alert sent to operators when a safety violation is detected."
    DTDFVocab:IsAutomatic true
]

instance VisualiseTemperatureAction : DTDFVocab:Action [
    base:desc "Displays temperature evolution on the operator dashboard."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Raspberry Pi serves as the controller for the physical twin, issuing control actions to the heat‑bed and the fan based on the digital twin’s algorithms; the documents state that the plant is controlled by a Raspberry Pi but give no details on command types, message formats, validation/authentication, feedback loops, conflict resolution, or execution confirmation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The lifecycle described consists of (i) model development, where abstract representations (e.g., CAD or dynamic differential‑equation models) of the physical system are created; (ii) deployment/integration, where these models are incorporated into the Digital Twin together with sensor data streams; (iii) runtime operation, in which continuous data collection from the physical twin triggers calibration algorithms that update model parameters, monitors that check safety and optimality, and possibly human or higher‑level algorithmic interventions; and (iv) maintenance, where updated models and algorithms replace outdated ones. Transitions between phases are managed by the calibration‑monitoring loop illustrated in Figure 1, providing implicit governance through continuous model updates and safety monitoring."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the two temperature prediction models against the measured sensor data; the four‑parameter model was found to better capture the thermal inertia of the heatbed, indicating higher validity. Calibration algorithms update model parameters to minimise prediction error, providing a quantitative validation step. Monitors continuously check the calibrated model predictions for safety and optimality violations, and any detected deviation triggers corrective actions, constituting an ongoing verification and quality‑assurance process."
]