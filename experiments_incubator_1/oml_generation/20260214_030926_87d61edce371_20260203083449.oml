// ---------- Sensing Components ----------
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "High‑precision DS18S20 1‑Wire digital thermometer mounted inside the incubator box (range –55 °C to +125 °C, accuracy ±0.5 °C)."
    DTDFVocab:producedData InternalTempDataStreamA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "High‑precision DS18S20 1‑Wire digital thermometer mounted inside the incubator box (range –55 °C to +125 °C, accuracy ±0.5 °C)."
    DTDFVocab:producedData InternalTempDataStreamB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "High‑precision DS18S20 1‑Wire digital thermometer placed outside to monitor ambient room temperature (range –55 °C to +125 °C, accuracy ±0.5 °C)."
    DTDFVocab:producedData ExternalTempDataStream
]

// ---------- Data Transmitted ----------
instance InternalTempDataStreamA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempDataStreamB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// ---------- Data ----------
instance InternalTemperatureDataA : DTDFVocab:Data [
    base:desc "Time‑stamped temperature series from internal sensor A, stored for calibration and monitoring."
    DTDFVocab:fromData InternalTempDataStreamA
    DTDFVocab:inputTo MonitoringEngine, OptimisationEngine, VisualisationEngine
]

instance InternalTemperatureDataB : DTDFVocab:Data [
    base:desc "Time‑stamped temperature series from internal sensor B, stored for calibration and monitoring."
    DTDFVocab:fromData InternalTempDataStreamB
    DTDFVocab:inputTo MonitoringEngine, OptimisationEngine, VisualisationEngine
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped ambient temperature series from external sensor, used for environmental context."
    DTDFVocab:fromData ExternalTempDataStream
    DTDFVocab:inputTo MonitoringEngine, VisualisationEngine
]

// ---------- Models ----------
instance TwoParamThermalModel : DTDFVocab:Model [
    base:desc "Analytical simulation model of incubator internal temperature dynamics with two free parameters (heat‑bed power coefficient and thermal loss coefficient)."
    DTDFVocab:inputTo PredictionEngine, OptimisationEngine
]

instance FourParamThermalModel : DTDFVocab:Model [
    base:desc "Analytical simulation model of incubator internal temperature dynamics with four free parameters to capture thermal inertia of the heat‑bed."
    DTDFVocab:inputTo PredictionEngine, OptimisationEngine
]

// ---------- Enablers ----------
instance MonitoringEngine : DTDFVocab:Enabler [
    base:desc "Algorithmic monitor that consumes temperature data streams to evaluate safety and performance thresholds."
    DTDFVocab:enables TemperatureMonitoringService, SafetyVerificationService
]

instance PredictionEngine : DTDFVocab:Enabler [
    base:desc "State estimator that uses calibrated thermal models to predict future temperature evolution under current operating conditions."
    DTDFVocab:enables TemperaturePredictionService
]

instance OptimisationEngine : DTDFVocab:Enabler [
    base:desc "Calibration and optimisation module (SciPy) that adjusts model parameters and computes optimal heating set‑points."
    DTDFVocab:enables HeatingOptimisationService
]

instance VisualisationEngine : DTDFVocab:Enabler [
    base:desc "Visualization component that renders real‑time system state for operators."
    DTDFVocab:enables SystemVisualisationService
]

// ---------- Services ----------
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Continuously monitors internal and external temperatures against predefined safety and performance thresholds."
    DTDFVocab:provides TemperatureSafetyInsight, PerformanceComplianceInsight
]

instance SafetyVerificationService : DTDFVocab:Service [
    base:desc "Verifies system safety by detecting temperature excursions and triggering alerts or corrective actions."
    DTDFVocab:provides TemperatureSafetyInsight, NotifyOperatorAction
]

instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Predicts temperature evolution using calibrated thermal models under current operating conditions."
    DTDFVocab:provides TemperatureForecastInsight
]

instance HeatingOptimisationService : DTDFVocab:Service [
    base:desc "Optimises heating parameters via calibration algorithms to maintain target temperature with minimal energy use."
    DTDFVocab:provides OptimisedHeatingInsight, HeatBedOnAction, CoolingFanOnAction
]

instance SystemVisualisationService : DTDFVocab:Service [
    base:desc "Provides operators with visualisation of the incubator’s state, including temperature trends and actuator status."
    DTDFVocab:provides VisualisationInsight
]

// ---------- Insights ----------
instance TemperatureSafetyInsight : DTDFVocab:Insight [
    base:desc "Detects unsafe temperature conditions (over‑heating or under‑heating) based on sensor data."
]

instance PerformanceComplianceInsight : DTDFVocab:Insight [
    base:desc "Assesses whether the incubator meets performance specifications (e.g., stability around target temperature)."
]

instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of future temperature trajectory derived from model predictions."
]

instance OptimisedHeatingInsight : DTDFVocab:Insight [
    base:desc "Recommendation of optimal heating set‑point to achieve target temperature efficiently."
]

instance VisualisationInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of real‑time temperature data and actuator states for operator situational awareness."
]

// ---------- Actions ----------
instance HeatBedOnAction : DTDFVocab:Action [
    base:desc "Command to activate the resistive heat‑bed to raise chamber temperature."
    DTDFVocab:IsAutomatic true
]

instance CoolingFanOnAction : DTDFVocab:Action [
    base:desc "Command to activate the cooling fan to reduce chamber temperature."
    DTDFVocab:IsAutomatic true
]

instance NotifyOperatorAction : DTDFVocab:Action [
    base:desc "Send notification to human operator when a safety violation is detected."
    DTDFVocab:IsAutomatic false
]

// ---------- Acting Components ----------
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that raises the incubator chamber temperature, driven by digital output signals from the Raspberry Pi controller."
]

instance CoolingFanActuator : DTDFVocab:ActingComponent [
    base:desc "Cooling fan that circulates air to reduce temperature, driven by digital output signals from the Raspberry Pi controller."
]

// ---------- Environment ----------
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, CoolingFanActuator, InternalTempSensorA, InternalTempSensorB, ExternalTempSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin can issue control actions to the physical incubator (e.g., adjust heat‑bed power or fan speed) when monitors detect violations. Commands are generated by algorithms and sent to the Raspberry Pi which actuates the hardware. Specific command formats, validation, authentication, feedback, conflict resolution, or execution confirmation mechanisms are not described in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin follows a layered orchestration pattern as illustrated in Figure 1 of the documents. Sensor data collected from the Physical Twin is streamed into the DT, where calibration algorithms continuously update the parameters of the cyber‑physical system (CPS) and environment models. The refreshed models are then consumed by monitoring components that evaluate safety and optimality criteria. If a violation is detected, decision logic—either human operators or automated algorithms—may initiate corrective actions on the Physical Twin. This architecture integrates data acquisition, model management, algorithmic processing, and feedback loops within a single coordinated framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing predicted temperature trajectories against the measured temperature from the incubator. Experiments showed that the four‑parameter model more accurately reproduces the thermal inertia of the heat‑bed, thereby meeting higher fidelity requirements. Validation is performed through empirical testing and calibration algorithms that estimate the model parameters. Uncertainty originates from sensor noise and parameter estimation errors; the calibration step provides updated best‑estimate parameters to reduce these uncertainties."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The incubator DT relies on a hybrid network topology: sensors communicate with the Raspberry Pi over a wired 1‑Wire bus, while the Pi connects to the wider Digital Twin infrastructure via its built‑in Wi‑Fi using a TCP/IP network. All higher‑level Twin‑to‑PT messaging (both sensor data publication and actuator command delivery) uses the AMQP protocol implemented by a RabbitMQ broker. The expected bandwidth is modest (a few kilobytes per second) given the low data rate of temperature readings and discrete actuator commands, and latency is limited to the Wi‑Fi round‑trip time (tens of milliseconds). Reliability is enhanced by RabbitMQ’s message acknowledgement and persistence features; optional TLS encryption can be configured for secure transport, though the document does not specify exact security settings."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin incorporates safety‑focused mechanisms such as calibration algorithms that continuously update the cyber‑physical system and environment models with the best‑estimate parameters, and monitoring components that assess whether the system is operating safely and optimally. When a safety violation is detected, the DT can trigger human operators or automated algorithms to intervene and modify the Physical Twin. These safety considerations are described as part of the DT framework, but no explicit cybersecurity protocols, access‑control mechanisms, authentication systems, threat‑mitigation strategies, fail‑safe mechanisms, or risk‑assessment procedures are detailed in the document."
]