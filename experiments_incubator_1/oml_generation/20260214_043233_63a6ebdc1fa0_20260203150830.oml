// ---------- Physical Sensing Components ----------
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor inside the styrofoam box measuring internal temperature (0.5°C accuracy from 10°C to +85°C)"
    DTDFVocab:producedData InternalTemp1DataTransmitted
]
instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor inside the styrofoam box measuring internal temperature (0.5°C accuracy from 10°C to +85°C)"
    DTDFVocab:producedData InternalTemp2DataTransmitted
]
instance InternalTempSensor3 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor inside the styrofoam box measuring internal temperature (0.5°C accuracy from 10°C to +85°C)"
    DTDFVocab:producedData InternalTemp3DataTransmitted
]
instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor external to the styrofoam box measuring ambient temperature (0.5°C accuracy from 10°C to +85°C)"
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// ---------- Data Transmitted ----------
instance InternalTemp1DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]
instance InternalTemp2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]
instance InternalTemp3DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor3
]
instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]
instance ControlStateDataTransmitted : DTDFVocab:DataTransmitted [
]
instance PowerConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
]

// ---------- Physical Data ----------
instance InternalTempRawData : DTDFVocab:Data [
    base:desc "Raw temperature log from InternalTempSensor1"
    DTDFVocab:fromData InternalTemp1DataTransmitted
]
instance InternalTempRawData2 : DTDFVocab:Data [
    base:desc "Raw temperature log from InternalTempSensor2"
    DTDFVocab:fromData InternalTemp2DataTransmitted
]
instance InternalTempRawData3 : DTDFVocab:Data [
    base:desc "Raw temperature log from InternalTempSensor3"
    DTDFVocab:fromData InternalTemp3DataTransmitted
]
instance AmbientTempRawData : DTDFVocab:Data [
    base:desc "Raw temperature log from AmbientTempSensor"
    DTDFVocab:fromData AmbientTempDataTransmitted
]
instance ControlStateHistoryData : DTDFVocab:Data [
    base:desc "Control state history (on/off status) recorded by Raspberry Pi"
    DTDFVocab:fromData ControlStateDataTransmitted
]
instance PowerConsumptionData : DTDFVocab:Data [
    base:desc "Power consumption metrics from the heatbed and fan"
    DTDFVocab:fromData PowerConsumptionDataTransmitted
]

// ---------- Models ----------
instance ModelA : DTDFVocab:Model [
    base:desc "Differential equation model for internal temperature dynamics (Model A) with parameters G_box, G_heater, C_air, C_heater"
]
instance ModelB : DTDFVocab:Model [
    base:desc "Differential equation model for internal temperature dynamics (Model B) with the same structural parameters"
]

// ---------- Enablers ----------
instance RaspberryPiLowLevelDriver : DTDFVocab:Enabler [
    base:desc "Low-level driver on Raspberry Pi 4 Model B handling GPIO reads, MQTT/RabbitMQ publishing"
    DTDFVocab:enables RealTimeMonitoringService, CalibrationService, SimulationService
]
instance SciPyCalibrationTool : DTDFVocab:Enabler [
    base:desc "Python SciPy-based tool performing nonlinear least-squares calibration of model parameters"
    DTDFVocab:enables CalibrationService
]
instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine executing Models A and B to forecast temperature profiles"
    DTDFVocab:enables SimulationService
]
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker mediating AMQP communication between sensors, services, and the Digital Twin"
    DTDFVocab:enables RealTimeMonitoringService, CalibrationService, SimulationService, BangBangControllerService
]

// ---------- Services ----------
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring dashboard for temperature, control state, and power consumption"
    DTDFVocab:provides AlertDeviationInsight
]
instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Model-based temperature prediction using Models A and B"
    DTDFVocab:provides ForecastAdjustmentInsight
]
instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration of model parameters via nonlinear least-squares optimization with SciPy"
    DTDFVocab:provides CalibrationUpdatesInsight, CandidateDesignInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of thermal dynamics to validate models against experimental data"
    DTDFVocab:provides ForecastAdjustmentInsight, PowerRecommendationInsight
]
instance BangBangControllerService : DTDFVocab:Service [
    base:desc "Bang-bang supervisory controller orchestrating the heatbed and fan via PWM or on/off control"
    DTDFVocab:provides AdjustControlThresholdAction
]

// ---------- Insights ----------
instance CalibrationUpdatesInsight : DTDFVocab:Insight [
    base:desc "Updates to model parameters derived from calibration"
]
instance CandidateDesignInsight : DTDFVocab:Insight [
    base:desc "Potential candidate designs for future thermal incubator models"
]
instance ForecastAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Simulation forecast adjustments informing control threshold changes"
]
instance AlertDeviationInsight : DTDFVocab:Insight [
    base:desc "Monitoring alerts for temperature deviations from setpoints"
]
instance PowerRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommended power settings derived from historical data"
]

// ---------- Actions ----------
instance AdjustControlThresholdAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of control thresholds based on simulation forecasts"
    DTDFVocab:IsAutomatic true
]

// ---------- Actions (optional) ----------
instance RecommendPowerSettingAction : DTDFVocab:Action [
    base:desc "Recommend power settings based on historical performance data"
    DTDFVocab:IsAutomatic true
]

// ---------- Physical Activers ----------
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed driven by a MOSFET via the PCB, controllable through GPIO PWM signals"
]
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12/24 V DC fan controllable via a MOSFET driver on the PCB"
]

// ---------- Components ----------
instance Rpi4ModelB : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B managing all embedded logic and communication"
]
instance HeatbedPCB : DTDFVocab:Component [
    base:desc "PCB driving the heatbed MOSFETs and optocouplers"
]
instance StyrofoamBox : DTDFVocab:Component [
    base:desc "Insulated styrofoam enclosure housing the internal environment"
]

// ---------- Environment ----------
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Thermal incubator system comprising an insulated styrofoam box fitted with a heatbed, fan, four DS18S20 temperature sensors, and a Raspberry Pi 4 Model B"
    base:contains Rpi4ModelB, HeatbedPCB, HeatbedActuator, FanActuator, InternalTempSensor1, InternalTempSensor2, InternalTempSensor3, AmbientTempSensor, StyrofoamBox
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (controller) are sent via RabbitMQ to the low‑level driver, which actuates the heatbed and fan by toggling MOSFETs; the DT also publishes scheduling or calibration updates that may adjust future actuation parameters."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture comprises: a communication server (RabbitMQ) on the Raspberry Pi; a low‑level driver that interfaces with sensors and actuators; a controller executing bang‑bang logic; simulation modules (Python scripts implementing Models A/B); and a calibration service that processes experimental data to update model parameters. All components run centrally on the Pi and exchange messages through RabbitMQ."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The system traverses the design phase (ideal model), manufacturing phase (construction of the incubator with Raspberry Pi and components), calibration/validation phase (parameter optimisation against experimental data), and operation phase (continuous monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Assumptions include: uniform temperature distribution (validated by fan tests), no heat accumulation in box walls, constant specific heat of air, negligible heat from fan; model validation performed by comparing simulated temperature with experimental trajectories; uncertainty arises from sensor noise, heat loss variations, and simplified heat transfer; calibration reduces residual error by optimizing C_air, G_box, G_heater."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT and PT are connected via a local Wi‑Fi network; RabbitMQ uses the AMQP protocol over TCP; GPIO pins on the Raspberry Pi communicate with the PCB and sensors via 1‑Wire and GPIO interfaces."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin is hosted on the Raspberry Pi 4 Model B itself, running the RabbitMQ broker, Python services, and the control logic; the Pi acts as both the physical controller and the virtual hosting node, providing a single‑node deployment."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Low‑level driver includes a safe protocol to avoid unsafe states; controller employs bang‑bang control with a delay to prevent overheating; but no explicit cybersecurity measures are described beyond RabbitMQ usage."
]