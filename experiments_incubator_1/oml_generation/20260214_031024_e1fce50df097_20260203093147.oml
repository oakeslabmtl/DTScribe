// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heating element (heatbed) driven through MOSFET switch on custom PCB"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V fan that circulates air, driven through MOSFET switch on custom PCB"
]

// C3: Physical sensing components
instance InsideTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (inside), –55 °C to +125 °C, 0.5 °C accuracy from –10 °C to +85 °C, unique 64‑bit address"
    DTDFVocab:producedData TempDataTxInside1
]

instance InsideTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (inside), –55 °C to +125 °C, 0.5 °C accuracy from –10 °C to +85 °C, unique 64‑bit address"
    DTDFVocab:producedData TempDataTxInside2
]

instance OutsideTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (outside), –55 °C to +125 °C, 0.5 °C accuracy from –10 °C to +85 °C, unique 64‑bit address"
    DTDFVocab:producedData TempDataTxOutside
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance TempDataTxInside1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensor1
]

instance TempDataTxInside2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensor2
]

instance TempDataTxOutside : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideTempSensor
]

// C10: Data (temperature readings)
instance InsideTempData1 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from InsideTempSensor1"
    DTDFVocab:fromData TempDataTxInside1
    DTDFVocab:inputTo RabbitMQMessageBroker
]

instance InsideTempData2 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from InsideTempSensor2"
    DTDFVocab:fromData TempDataTxInside2
    DTDFVocab:inputTo RabbitMQMessageBroker
]

instance OutsideTempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from OutsideTempSensor"
    DTDFVocab:fromData TempDataTxOutside
    DTDFVocab:inputTo RabbitMQMessageBroker
]

// C11: Enablers
instance RabbitMQMessageBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker running on the Raspberry Pi, mediating messages between low‑level driver and DT services"
    DTDFVocab:enables RealTimeTemperatureMonitoring,
                      SafetyMonitoring,
                      ParameterCalibration,
                      ModelBasedSimulation,
                      HeatingCycleOptimization
]

instance PythonSciPyCalibrationEngine : DTDFVocab:Enabler [
    base:desc "Python SciPy non‑linear least‑squares engine used for calibrating thermal model parameters"
    DTDFVocab:enables ParameterCalibration,
                      HeatingCycleOptimization,
                      ModelBasedSimulation
]

instance RaspberryPiLowLevelDriver : DTDFVocab:Enabler [
    base:desc "Low‑level driver on the Raspberry Pi that reads DS18S20 sensors via GPIO, packages readings into AMQP messages"
    DTDFVocab:enables RealTimeTemperatureMonitoring,
                      SafetyMonitoring
]

// C6: Services
instance RealTimeTemperatureMonitoring : DTDFVocab:Service [
    base:desc "Real‑time temperature monitoring service"
    DTDFVocab:provides TemperatureDeviationDetection
]

instance SafetyMonitoring : DTDFVocab:Service [
    base:desc "Safety monitoring via the safe‑protocol implemented in the low‑level driver"
    DTDFVocab:provides SafetyDeviationInsight
]

instance ParameterCalibration : DTDFVocab:Service [
    base:desc "Parameter calibration using non‑linear least‑squares (SciPy) on model data"
    DTDFVocab:provides CalibratedParametersInsight
]

instance ModelBasedSimulation : DTDFVocab:Service [
    base:desc "Model‑based simulation service employing Model A and Model B"
    DTDFVocab:provides PredictedTemperatureTrajectoryInsight
]

instance HeatingCycleOptimization : DTDFVocab:Service [
    base:desc "Optimisation of heating cycles through calibrated thermal models"
    DTDFVocab:provides AdjustHeatingAction
]

// C17: Insights / Actions
instance TemperatureDeviationDetection : DTDFVocab:Insight [
    base:desc "Detects deviations from the target temperature set‑point"
]

instance SafetyDeviationInsight : DTDFVocab:Insight [
    base:desc "Detects unsafe temperature conditions requiring immediate intervention"
]

instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Provides calibrated thermal parameters (C_air, C_heater, G_box, G_heater)"
]

instance PredictedTemperatureTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Predicts future temperature trajectories based on calibrated models"
]

instance AdjustHeatingAction : DTDFVocab:Action [
    base:desc "Triggers adjustments to heating duration or waiting periods to maintain safe and optimal operation"
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance ModelA : DTDFVocab:Model [
    base:desc "Thermal model A with single thermal capacity C_air and box conductance G_box"
    DTDFVocab:inputTo PythonSciPyCalibrationEngine
]

instance ModelB : DTDFVocab:Model [
    base:desc "Thermal model B adds heat‑bed capacity C_heater and conductance G_heater"
    DTDFVocab:inputTo PythonSciPyCalibrationEngine
]

// Physical components not directly sensed/actuated
instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running Linux, hosts driver, RabbitMQ broker and DT services"
]

instance CustomPCBActuationCircuit : DTDFVocab:Component [
    base:desc "Custom PCB with MOSFETs and optocouplers providing safe power switching for heatbed and fan"
]

// Environment definition
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator,
                      FanActuator,
                      InsideTempSensor1,
                      InsideTempSensor2,
                      OutsideTempSensor,
                      RaspberryPiController,
                      CustomPCBActuationCircuit
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (heat‑bed ON/OFF, fan ON/OFF, waiting periods) are sent from DT services to the RabbitMQ broker, consumed by the Pi controller which actuates the MOSFET‑based driver to change the heatbed and fan states."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is orchestrated as a set of loosely coupled components: the controller, low‑level driver, and RabbitMQ broker on the Pi; DT services subscribe to the broker to receive sensor streams and publish control commands, enabling a bidirectional message‑driven architecture."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through explicit assumptions (uniform air temperature, negligible wall heat, constant air specific heat, heat‑bed heat loss), validation experiments for temperature uniformity, and calibration of model parameters against measured data; model B is favoured for better prediction of heat‑bed thermal inertia."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses the AMQP protocol of RabbitMQ over the Pi’s built‑in Wi‑Fi/Bluetooth network interface; GPIO pins provide direct hardware interfacing for sensors and actuators."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ broker and controller software are hosted locally on the Raspberry Pi 4; DT services can run on the same device or access the broker remotely (e.g., cloud) via standard network connections."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe‑protocol is embedded in the low‑level driver to keep the device in a safe state; the DT monitors temperature limits (LL, UL) and can halt actuation if safety thresholds are crossed."
]