// Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi controlled heatbed (heater) implementing a bang‑bang sequence to maintain temperature within limits"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi controlled fan providing heat distribution during heating cycles"
]

// Sensing Components
instance ThermistorInsideTemp1 : DTDFVocab:SensingComponent [
    base:desc "Thermistor‑based temperature sensor located inside the styrofoam box, providing voltage proportional to temperature with ±0.5°C accuracy"
    DTDFVocab:producedData DMQInsideTemp1
]

instance ThermistorInsideTemp2 : DTDFVocab:SensingComponent [
    base:desc "Thermistor‑based temperature sensor located inside the styrofoam box, providing voltage proportional to temperature with ±0.5°C accuracy"
    DTDFVocab:producedData DMQInsideTemp2
]

instance ThermistorExternalTemp : DTDFVocab:SensingComponent [
    base:desc "Thermistor‑based temperature sensor mounted externally, measuring ambient temperature with ±0.5°C accuracy"
    DTDFVocab:producedData DMQExternalTemp
]

// Data Transmitted
instance DMQInsideTemp1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ThermistorInsideTemp1
]

instance DMQInsideTemp2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ThermistorInsideTemp2
]

instance DMQExternalTemp : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ThermistorExternalTemp
]

// Data
instance InsideTemp1Data : DTDFVocab:Data [
    base:desc "Time‑stamped inside temperature reading from ThermistorInsideTemp1"
    DTDFVocab:fromData DMQInsideTemp1
    DTDFVocab:inputTo InfluxDBEnabler, KalmanFilterEnabler, SimulationEnabler, CalibrationEnabler, ControlEnabler
]

instance InsideTemp2Data : DTDFVocab:Data [
    base:desc "Time‑stamped inside temperature reading from ThermistorInsideTemp2"
    DTDFVocab:fromData DMQInsideTemp2
    DTDFVocab:inputTo InfluxDBEnabler, KalmanFilterEnabler, SimulationEnabler, CalibrationEnabler, ControlEnabler
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Time‑stamped ambient temperature reading from ThermistorExternalTemp"
    DTDFVocab:fromData DMQExternalTemp
    DTDFVocab:inputTo InfluxDBEnabler, KalmanFilterEnabler, SimulationEnabler, CalibrationEnabler, ControlEnabler
]

// Enablers
instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB data store for real‑time and historical temperature telemetry"
    DTDFVocab:enables MonitoringService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter estimator configured with ModelB, fusing measured inside temperature with unmeasured heatbed temperature"
    DTDFVocab:enables AnomalyDetectionService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Exposes ModelA and ModelB predictive simulation services"
    DTDFVocab:enables SimulationService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Least‑squares calibration routine for ModelA and ModelB using experimental data"
    DTDFVocab:enables CalibrationService
]

instance ControlEnabler : DTDFVocab:Enabler [
    base:desc "Bang‑bang controller abstraction on Raspberry Pi translating temperature measurements into heating and fan actuation commands via RabbitMQ"
    DTDFVocab:enables ControlService
]

instance WhatIfSimulatorEnabler : DTDFVocab:Enabler [
    base:desc "Co‑simulation engine running what‑if scenarios with historical or live PT data"
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationEnabler : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop that orchestrates anomaly detection, experiment scheduling, re‑calibration, and controller update"
    DTDFVocab:enables SelfAdaptationService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard for internal and ambient temperatures via Grafana"
    DTDFVocab:provides InsightRealTimeStatus
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection service based on Kalman filter alerts"
    DTDFVocab:provides InsightAnomalyDetected
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation using ModelA and ModelB to forecast temperature evolution"
    DTDFVocab:provides InsightPredictiveSimulation
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Model calibration routine invoking least‑squares optimization of model parameters"
    DTDFVocab:provides ActionModelCalibrate
]

instance ControlService : DTDFVocab:Service [
    base:desc "Bang‑bang temperature controller running on Raspberry Pi"
    DTDFVocab:provides ActionControlCommand
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What‑if simulation service for controller tuning and scenario analysis"
    DTDFVocab:provides ActionWhatIfOptimization
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Self‑adaptation engine that dynamically adjusts controller and model parameters"
    DTDFVocab:provides ActionSelfAdaptationExecute
]

// Insights
instance InsightRealTimeStatus : DTDFVocab:Insight [
    base:desc "Real‑time status of internal and ambient temperatures displayed on Grafana dashboard"
]

instance InsightAnomalyDetected : DTDFVocab:Insight [
    base:desc "Anomaly flagged by Kalman filter when temperature deviates beyond safety thresholds"
]

instance InsightPredictiveSimulation : DTDFVocab:Insight [
    base:desc "Predicted temperature evolution from ModelA and ModelB simulations"
]

// Actions
instance ActionModelCalibrate : DTDFVocab:Action [
    base:desc "Invoke least‑squares calibration routine to update ModelA and ModelB parameters"
    DTDFVocab:IsAutomatic true
]

instance ActionControlCommand : DTDFVocab:Action [
    base:desc "Bang‑bang control command to turn heatbed and fan on/off"
    DTDFVocab:IsAutomatic true
]

instance ActionWhatIfOptimization : DTDFVocab:Action [
    base:desc "Execute what‑if simulation scenarios to optimize controller tuning"
    DTDFVocab:IsAutomatic true
]

instance ActionSelfAdaptationExecute : DTDFVocab:Action [
    base:desc "Orchestrate self‑adaptation loop: schedule test, reconfigure controller, re‑run calibration, update models"
    DTDFVocab:IsAutomatic true
]

// Models
instance ModelA : DTDFVocab:Model [
    base:desc "Thermal model assuming all electrical power converted to air heating within the insulated styrofoam box"
    DTDFVocab:inputTo SimulationEnabler
]

instance ModelB : DTDFVocab:Model [
    base:desc "Thermal model including heat‑bed inertia term for more accurate prediction during heating cycles"
    DTDFVocab:inputTo SimulationEnabler
]

// Environment
instance EnvironmentIncubator : DTDFVocab:Environment [
    base:contains ThermistorInsideTemp1, ThermistorInsideTemp2, ThermistorExternalTemp, HeatbedActuator, FanActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The virtual Twin issues control commands back to the PT through the same RabbitMQ broker. The controller component listens on a command queue for “set‑state” messages that specify actuator targets for the heatbed and fan. Upon receiving a command, the controller executes a bang‑bang policy: the heatbed stays ON for the configured heating duration H until the measured temperature rises to the upper limit UL, then the fan drives for the waiting duration C before the heatbed shuts off until the temperature drops to the lower limit LL. The low‑level driver enforces a safe protocol, validates command payloads against the actuator state machine, and, after actuating the devices, publishes the confirmation (e.g., actuator status and timestamps) back to RabbitMQ. Thus the DT’s control logic is continuously validated by feedback data from the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin architecture comprises three core components: a low‑level driver that abstracts sensor/actuator communication and publishes temperature data; a controller running on a Raspberry Pi that implements a bang‑bang temperature regulator; and a RabbitMQ communication server that provides AMQP‑based message exchange between the driver and controller. The architecture is loosely coupled through the broker, with data routed as messages; coordination is achieved by the driver interpreting the controller’s commands and vice versa."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Conceptual Design & Modelling – A thermal incubator model is built from the physical laws using the energy equation Q = cmΔT and four simplifying assumptions (A–D). Two dynamic models are derived: Model A (all assumptions) and Model B (excluding Assumption 4 to capture heat‑bed inertia). Physical Twin Deployment – Hardware (styrofoam enclosure, heatbed, fan, two inside‑box temperature sensors, one outside sensor) is assembled on a Raspberry Pi and controlled by a bang‑bang controller parameterised by LL, UL, H and C. Digital Twin Integration – Model B is wrapped in a calibration routine that updates model parameters using a non‑linear least‑squares solver. Data from the PT are streamed through RabbitMQ by the low‑level driver and reused by the DT to keep the simulation synchronised. Runtime Monitoring & Iterative Refinement – During operation the DT continually (a) runs calibration on demand, (b) feeds observed temperatures into the model, and (c) checks safety/optimality metrics; anomalies are flagged using a Kalman filter estimating the unmeasured heatbed temperature. Governance & Evolution – All code, models and calibration scripts are stored in an open‑source GitHub repository (https://github.com/INTO‑CPS‑Association/example‑incubator) and versioned, allowing the Digital Twin to evolve with changing plant dynamics while preserving a clear audit trail of model updates."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The model fidelity is governed by four key assumptions: (1) the temperature inside the box is spatially uniform thanks to active fan circulation (Assumption 1); (2) the box walls do not accumulate significant heat that would affect the air temperature (Assumption 2); (3) the specific heat capacity of the air is treated as constant across the operating range (Assumption 3); and (4) the majority of electrical power is assumed to be converted to heat energy, thus the heatbed’s own heat absorption and fan heating are neglected (Assumption 4). Model validity is assessed through calibration experiments – sensor data are compared against the predictions of Model A and Model B, and a least‑squares optimiser adjusts the free parameters until residuals are minimized. Anomaly detection is integrated via a Kalman filter that estimates the unmeasured heatbed temperature; deviations from expected residuals trigger alerts. Validation also includes experiments verifying the uniform temperature distribution, verifying the negligible wall heat effect, and measuring sensor accuracy. All models and data undergo version control and are stored in the repository for reproducibility."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the physical and digital twins uses a RabbitMQ broker that implements the AMQP messaging protocol over TCP/IP. Telemetry and control messages are exchanged over the local network between the low‑level driver, controller, and other DT services. The broker’s message persistence and routing features provide basic reliability; bandwidth, latency, and security requirements are not specified explicitly in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT stack is hosted on‑premises on a Raspberry Pi 4 Model B. The Pi runs the RabbitMQ broker, the controller process, and the low‑level driver. Storage of telemetry and model data is performed locally on the Pi’s filesystem or forwarded to external storage; the documentation does not detail the exact storage architecture. The deployment is a single-node, non-clustered edge deployment suitable for laboratory or small-scale field environments."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Incubator Digital Twin architecture relies on RabbitMQ, a mature lightweight message broker, to mediate all communication between the Raspberry Pi controller, the low‑level driver, and the DT monitoring components. The low‑level driver implements a safety‑oriented protocol that validates incoming commands, only accepts them when the device is in a safe operational state, and uploads sensor readings via the RabbitMQ server. The controller is a bang‑bang logic that enforces temperature limits – it only permits the heatbed to be activated when the measured temperature is below a lower bound (LL) and the temperature remains acceptable for a dwell period (C) after heating. The control logic also ensures a waiting period (H) after heating to avoid overshoot, thereby providing a fail‑safe behaviour. Although explicit cybersecurity mechanisms (such as encryption, authentication or access control) are not described, the architecture includes fundamental safety checks and boundary‑condition enforcement that help mitigate risk of unsafe operation. No explicit data privacy or governance measures are mentioned in the documents."
]