// C3: Physical sensing components
instance InternalBoxTemperatureDataTX1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalBoxTemperatureSensor1
]

instance InternalBoxTemperatureDataTX2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalBoxTemperatureSensor2
]

instance AmbientTemperatureDataTX : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

instance InternalBoxTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer monitoring internal box temperature (33.5 °C – +125 °C, 0.5 °C accuracy)."
    DTDFVocab:producedData InternalBoxTemperatureDataTX1
]

instance InternalBoxTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer monitoring internal box temperature (33.5 °C – +125 °C, 0.5 °C accuracy)."
    DTDFVocab:producedData InternalBoxTemperatureDataTX2
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer monitoring ambient temperature outside the incubator box."
    DTDFVocab:producedData AmbientTemperatureDataTX
]

// C10: Models/Data
instance RawSensorDataInsight : DTDFVocab:Insight [
    base:desc "Insight containing raw temperature samples from the incubator sensors."
]

instance CalibrationParametersInsight : DTDFVocab:Insight [
    base:desc "Insight reporting calibrated parameters (C_air, G_box, C_heater, G_heater)."
]

instance SafetyViolationDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating when temperature excursions exceed critical safety limits."
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Insight showing predicted temperature trajectories from the calibrated models."
]

instance TemperatureDataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight visualising real‑time temperature data and predicted trajectories."
]

instance DataBroadcastInsight : DTDFVocab:Insight [
    base:desc "Insight representing published sensor and actuator data to RabbitMQ."
]

instance FanStateAction : DTDFVocab:Action [
    base:desc "Automatic action to turn the fan ON or OFF."
    DTDFVocab:IsAutomatic true
]

instance HeaterStateAction : DTDFVocab:Action [
    base:desc "Automatic action to turn the heat‑bed ON or OFF."
    DTDFVocab:IsAutomatic true
]

instance HeatingCycleScheduleAction : DTDFVocab:Action [
    base:desc "Automatic scheduling of heating cycles based on temperature setpoints and predictions."
    DTDFVocab:IsAutomatic true
]

// C11: Enablers and Services
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Service that ingests raw temperature data from sensor streams."
    DTDFVocab:provides RawSensorDataInsight
]

instance DataPublicationService : DTDFVocab:Service [
    base:desc "Service that publishes sensor data and current actuator status to RabbitMQ exchanges."
    DTDFVocab:provides DataBroadcastInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that calibrates thermal model parameters using non‑linear least‑squares optimisation with Scipy."
    DTDFVocab:provides CalibrationParametersInsight, SafetyViolationDetectionInsight
]

instance BangBangControllerService : DTDFVocab:Service [
    base:desc "Bang‑bang controller that issues ON/OFF commands to heat‑bed and fan actuators based on temperature predictions."
    DTDFVocab:provides FanStateAction, HeaterStateAction, HeatingCycleScheduleAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that visualises real‑time temperature data and actuator status via RabbitMQ interfaces."
    DTDFVocab:provides TemperatureDataVisualizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs numerical integration of the thermal models and produces predicted temperature data."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance RaspberryPiSensorDriver : DTDFVocab:Enabler [
    base:desc "Low‑level driver on Raspberry Pi 4 Model B that reads DS18S20 sensors from the 1‑Wire bus."
    DTDFVocab:enables DataAcquisitionService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP message broker running on the Raspberry Pi 4 for publishing sensor streams and querying actuator states."
    DTDFVocab:enables DataPublicationService
]

instance PythonRuntime : DTDFVocab:Enabler [
    base:desc "Python runtime executing control, calibration, and simulation logic (includes Scipy and custom modules)."
    DTDFVocab:enables BangBangControllerService, CalibrationService, VisualizationService
]

instance ScipyOptimizer : DTDFVocab:Enabler [
    base:desc "Scipy non‑linear least‑squares optimizer used for calibrating Model A and Model B parameters."
    DTDFVocab:enables CalibrationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine integrating Model A and Model B over time to generate predicted temperature trajectories."
    DTDFVocab:enables SimulationService
]

// C10: Sensor Data
instance InternalBoxTemperatureData1 : DTDFVocab:Data [
    base:desc "Temperature time series from Internal Box Sensor 1."
    DTDFVocab:fromData InternalBoxTemperatureDataTX1
    DTDFVocab:inputTo RaspberryPiSensorDriver, RabbitMQBroker, PythonRuntime
]

instance InternalBoxTemperatureData2 : DTDFVocab:Data [
    base:desc "Temperature time series from Internal Box Sensor 2."
    DTDFVocab:fromData InternalBoxTemperatureDataTX2
    DTDFVocab:inputTo RaspberryPiSensorDriver, RabbitMQBroker, PythonRuntime
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Ambient temperature time series."
    DTDFVocab:fromData AmbientTemperatureDataTX
    DTDFVocab:inputTo RaspberryPiSensorDriver, RabbitMQBroker, PythonRuntime
]

// C10: Models/Data
instance ModelA : DTDFVocab:Model [
    base:desc "Thermal model of the incubator using parameters C_air and G_box."
    DTDFVocab:inputTo SimulationEngine
]

instance ModelB : DTDFVocab:Model [
    base:desc "Extended thermal model with additional parameters C_heater and G_heater."
    DTDFVocab:inputTo SimulationEngine
]

instance ModelSimulationDataTXA : DTDFVocab:DataTransmitted [
    // No producedFrom (model does not produce sensor data)
]

instance ModelSimulationDataTXB : DTDFVocab:DataTransmitted [
    // No producedFrom (model does not produce sensor data)
]

instance ModelSimulationDataA : DTDFVocab:Data [
    base:desc "Simulated temperature time series from Model A."
    DTDFVocab:fromData ModelSimulationDataTXA
    DTDFVocab:inputTo SimulationEngine
]

instance ModelSimulationDataB : DTDFVocab:Data [
    base:desc "Simulated temperature time series from Model B."
    DTDFVocab:fromData ModelSimulationDataTXB
    DTDFVocab:inputTo SimulationEngine
]

// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed surface heater switched via a MOSFET controlled by the Raspberry Pi 4."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V fan switched via a MOSFET controlled by the Raspberry Pi 4 for airflow."
]

// Physical components
instance RaspberryPi4 : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B acting as the central controller and host for the digital twin."
]

instance MOSFETHeatBedActuator : DTDFVocab:Component [
    base:desc "MOSFET switching the heat‑bed relay circuit with optocoupler isolation."
]

instance MOSFETFANActuator : DTDFVocab:Component [
    base:desc "MOSFET switching the fan relay circuit with optocoupler isolation."
]

instance OptocouplerHeatBed : DTDFVocab:Component [
    base:desc "Optocoupler providing electrical isolation for the heat‑bed MOSFET control line."
]

instance OptocouplerFan : DTDFVocab:Component [
    base:desc "Optocoupler providing electrical isolation for the fan MOSFET control line."
]

// C17: Environment
instance EnvironmentIncubator : DTDFVocab:Environment [
    base:contains HeatBedActuator, FanActuator, RaspberryPi4, MOSFETHeatBedActuator, MOSFETFANActuator, OptocouplerHeatBed, OptocouplerFan, InternalBoxTemperatureSensor1, InternalBoxTemperatureSensor2, AmbientTemperatureSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Commands generated by the DT (controller logic or external supervisory commands) are sent via RabbitMQ to the controller on the Pi, which translates them into GPIO pulses to the MOSFETs, toggling the heat‑bed and fan. The DT also reports actuator states back through the same channel."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sensor readings are acquired and published periodically by the low‑level driver (exact sampling period not specified); calibration and offline experiments are conducted at a lower frequency; simulation and monitoring run continuously while the PT operates."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation is a centralized architecture: the low‑level driver, controller, and simulation model all reside on the Raspberry Pi; they communicate via RabbitMQ to each other and to any external tools, forming a closed loop between PT and DT."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin is developed through design (creation of CAE models and initial code), manufacture (assembly of hardware), and operation phases. Calibration experiments on the operated device refine the model parameters, indicating the twin is primarily used during the operated life‑cycle stage, with continuous monitoring and potential updates."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is constrained by Assumptions 1–4 (uniform temperature, no wall heat accumulation, constant specific heat, heat‑bed energy transfer). Validation is performed by comparing simulation outputs to experimental temperature traces; parameter uncertainty is reduced through optimisation. The authors note that discretization and sensor noise may introduce errors."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual communication uses RabbitMQ over the local network. Sensors connect via the 1‑Wire bus to the Pi’s GPIO; actuator control uses GPIO outputs wired through optocouplers to MOSFETs. All interactions exploit standard TCP/IP sockets under the AMQP protocol."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT services run directly on the embedded Raspberry Pi host; RabbitMQ is also locally instantiated on the Pi. This edge deployment enables low‑latency communication between PT and DT. The repository indicates the possibility of extending to cloud hosts, but the presented implementation is edge‑based."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to prevent unsafe states, and optocouplers provide electrical isolation between the Pi and the high‑current MOSFETs driving the heat‑bed and fan. No explicit encryption or authentication mechanisms are described, and the system operates in a controlled laboratory environment."
]