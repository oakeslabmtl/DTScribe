// Sensing Components
instance IncubatorAirTemperatureSensorLeft : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor positioned inside the left side of the incubator, 0.5 °C accuracy, 10 °C to +85 °C range"
    DTDFVocab:producedData TemperatureDataLeft
]

instance IncubatorAirTemperatureSensorRight : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor positioned inside the right side of the incubator, 0.5 °C accuracy, 10 °C to +85 °C range"
    DTDFVocab:producedData TemperatureDataRight
]

instance RoomTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor positioned outside the incubator to measure ambient room temperature, 0.5 °C accuracy, 10 °C to +85 °C range"
    DTDFVocab:producedData TemperatureDataRoom
]

// Data Transmitted (AMQP messages)
instance TemperatureDataLeft : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorAirTemperatureSensorLeft
]

instance TemperatureDataRight : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorAirTemperatureSensorRight
]

instance TemperatureDataRoom : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTemperatureSensor
]

// Logged Data
instance TemperatureReadingLeft : DTDFVocab:Data [
    base:desc "Logged temperature measurement from the left‑side incubator sensor"
    DTDFVocab:inputTo LowLevelDriver
    DTDFVocab:inputTo SciPyOptimizer
    DTDFVocab:fromData TemperatureDataLeft
]

instance TemperatureReadingRight : DTDFVocab:Data [
    base:desc "Logged temperature measurement from the right‑side incubator sensor"
    DTDFVocab:inputTo LowLevelDriver
    DTDFVocab:inputTo SciPyOptimizer
    DTDFVocab:fromData TemperatureDataRight
]

instance TemperatureReadingRoom : DTDFVocab:Data [
    base:desc "Logged temperature measurement from the ambient room sensor"
    DTDFVocab:inputTo LowLevelDriver
    DTDFVocab:inputTo SciPyOptimizer
    DTDFVocab:fromData TemperatureDataRoom
]

// Models
instance ThermalModelSingleNode : DTDFVocab:Model [
    base:desc "Model A: single‑node heat balance model representing air temperature and heat loss to the insulated Styrofoam box"
    DTDFVocab:inputTo LowLevelDriver
]

instance ThermalModelTwoNode : DTDFVocab:Model [
    base:desc "Model B: two‑node model consisting of the heatbed and air with separate heat capacities"
    DTDFVocab:inputTo LowLevelDriver
]

// Enablers
instance RaspberryPiHighLevelController : DTDFVocab:Enabler [
    base:desc "Python controller executing on Raspberry Pi 4, orchestrating heating and fan control based on model predictions"
    DTDFVocab:enables TemperatureMonitoringService
    DTDFVocab:enables SafetyBangBangService
    DTDFVocab:enables ThermalSimulationService
    DTDFVocab:enables ParameterOptimisationService
]

instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Python low‑level driver collecting sensor data via 1‑Wire, publishing to RabbitMQ, and performing GPIO writes to actuators via MOSFETs and optocouplers"
    DTDFVocab:enables TemperatureMonitoringService
    DTDFVocab:enables SafetyBangBangService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "Local RabbitMQ AMQP broker facilitating communication between low‑level driver and high‑level controller"
]

instance SciPyOptimizer : DTDFVocab:Enabler [
    base:desc "SciPy least‑squares optimiser for parameter calibration and optimisation of thermal models"
    DTDFVocab:enables ParameterOptimisationService
]

// Services
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature, displaying live temperature trajectories"
    DTDFVocab:provides PredictedTemperatureInsight
]

instance SafetyBangBangService : DTDFVocab:Service [
    base:desc "Bang‑bang safety controller ensuring temperature remains within designed limits"
    DTDFVocab:provides SafetyAlertInsight
    DTDFVocab:provides AdjustControllerParametersAction
]

instance ThermalSimulationService : DTDFVocab:Service [
    base:desc "Simulation of thermal behaviour using calibrated Model A and Model B"
    DTDFVocab:provides SimulationInsight
]

instance ParameterOptimisationService : DTDFVocab:Service [
    base:desc "Parameter optimisation and calibration using SciPy least‑squares optimiser"
    DTDFVocab:provides OptimisationInsight
    DTDFVocab:provides AdjustModelParametersAction
]

// Insights
instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predictive temperature trajectory generated by the calibrated thermal model"
]

instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Safety alert raised when temperature exceeds pre‑defined thresholds by the bang‑bang controller"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results from Model A and Model B under current operating conditions"
]

instance OptimisationInsight : DTDFVocab:Insight [
    base:desc "Updated calibration parameters resulting from least‑squares optimisation"
]

// Actions
instance AdjustControllerParametersAction : DTDFVocab:Action [
    base:desc "Automatically adjust controller parameters H (heating/on‑time) and C (waiting) based on residual error metrics"
    DTDFVocab:IsAutomatic true
]

instance AdjustModelParametersAction : DTDFVocab:Action [
    base:desc "Update model parameters (e.g., heat capacities, loss coefficients) following optimisation results"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Components in the digital twin (e.g., a monitoring supervisor or simulation worker) subscribe to the RabbitMQ message stream that carries sensor data and actuator state notifications; the twin does not directly command the hardware but reacts to the messages that originate from the controller and driver."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT synchronises with the PT at the granularity of the controller state machine. A heating interval of H seconds is followed by a waiting interval of C seconds. Temperature samples are taken periodically (every read cycle) by the low‑level driver, and all DT updates—including model predictions and actuator commands—are scheduled at the same H + C periodicity.
"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated, event‑driven architecture: sensor nodes → low‑level driver → RabbitMQ broker → controller logic → actuator drivers; all communication via AMQP messages ensures decoupling between digital twin and physical twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (ideal model creation), construction (incubator hardware assembly), calibration (parameter estimation from experimental data), deployment (controller and RabbitMQ on Pi), operation (real‑time monitoring, control and model validation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Four core assumptions are verified: (1) uniform temperature inside the box (validated by the 7 °C discrepancy experiment), (2) negligible heat transfer to walls, (3) constant specific heat of air, and (4) negligible heatbed energy loss. Model validation is performed by comparing simulation outputs to experimental temperature trajectories and measuring residual error post‑calibration."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange occurs via local RabbitMQ message broker running on the Raspberry Pi; the broker uses the AMQP protocol over the Pi’s built‑in Wi‑Fi/Ethernet interface. Sensor readings, actuator commands, and status messages are transmitted as text/JSON payloads."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components—including the controller, driver, RabbitMQ broker, and simulation models—are hosted on a single Raspberry Pi 4 Model B board; the Pi also powers the heatbed, fan, and PCB; no external cloud hosting is used."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of standardized DS18S20 1‑Wire protocol for temperature sensing, AMQP protocol via RabbitMQ for message passing, and open‑source code/hardware design for reproducibility; no explicit industry standard beyond these."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Low‑level driver implements a safe protocol to prevent unsafe states, bang‑bang controller enforces waiting durations to avoid overheating, optocoupler isolation protects the controller from high currents, and hardware limits ensure safe operation."
]