// Acting components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed that supplies thermal energy to the incubator interior."
]
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Mechanical fan that circulates air across the heatbed and interior."
]
instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi host controller issuing on/off commands to heatbed and fan."
]

// Physical sensing components
instance InsideTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded inside the insulated styrofoam incubator (Sensor 1)."
    DTDFVocab:producedData InsideTemp1DataTransmitted
]
instance InsideTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded inside the insulated styrofoam incubator (Sensor 2)."
    DTDFVocab:producedData InsideTemp2DataTransmitted
]
instance OutsideTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted on the exterior of the incubator box to monitor ambient temperature."
    DTDFVocab:producedData OutsideTempDataTransmitted
]

// Physical-to-virtual interaction
instance InsideTemp1DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensor1
]
instance InsideTemp2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensor2
]
instance OutsideTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideTempSensor
]

// Data created from transmitted data
instance InsideTemp1Data : DTDFVocab:Data [
    base:desc "Timestamped inside temperature measurement streamed from InsideTempSensor1."
    DTDFVocab:fromData InsideTemp1DataTransmitted
    DTDFVocab:inputTo RabbitMQ_Broker
]
instance InsideTemp2Data : DTDFVocab:Data [
    base:desc "Timestamped inside temperature measurement streamed from InsideTempSensor2."
    DTDFVocab:fromData InsideTemp2DataTransmitted
    DTDFVocab:inputTo RabbitMQ_Broker
]
instance OutsideTempData : DTDFVocab:Data [
    base:desc "Timestamped ambient temperature measurement streamed from OutsideTempSensor."
    DTDFVocab:fromData OutsideTempDataTransmitted
    DTDFVocab:inputTo RabbitMQ_Broker
]

// Models/Data
instance ModelA_Thermal : DTDFVocab:Model [
    base:desc "Thermal dynamics model with two free parameters adapting heatbed and fan behaviour."
    DTDFVocab:inputTo Simulation_Engine
]
instance ModelB_Thermal : DTDFVocab:Model [
    base:desc "Extended thermal dynamics model with four free parameters capturing heatbed thermal inertia."
    DTDFVocab:inputTo Simulation_Engine
]
instance KalmanFilter_Estimator : DTDFVocab:Model [
    base:desc "Kalman filter fusing measured temperatures with ModelB predictions to estimate heatbed temperature and produce confidence metrics."
    DTDFVocab:inputTo Estimation_Engine
]

// Enablers
instance RabbitMQ_Broker : DTDFVocab:Enabler [
    base:desc "AMQP message broker receiving telemetry from Raspberry Pi low‑level driver."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveSimulationService, ParameterCalibrationService
]
instance Simulation_Engine : DTDFVocab:Enabler [
    base:desc "Physics‑based simulation engine executing ModelA and ModelB."
    DTDFVocab:enables PredictiveSimulationService, ParameterCalibrationService
]
instance Estimation_Engine : DTDFVocab:Enabler [
    base:desc "Estimation engine running Kalman filter for state estimation and anomaly detection."
    DTDFVocab:enables StateEstimationAnomalyDetectionService
]
instance UserInterface_Enabler : DTDFVocab:Enabler [
    base:desc "Component gateway exposing dashboard and configuration UI to engineers and operators."
    DTDFVocab:enables UserInterfaceService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring and visualization of temperature telemetry on a live dashboard."
    DTDFVocab:provides TemperatureDashboardInsight
]
instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Co‑simulation service forecasting future thermal states under varying input conditions."
    DTDFVocab:provides ForecastInsight
]
instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Least‑squares calibration service updating free parameters of ModelB in response to sensor data."
    DTDFVocab:provides CalibrationInsight, RunCalibrationAction
]
instance StateEstimationAnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection service flagging significant deviations between measured and predicted temperatures."
    DTDFVocab:provides AnomalyInsight, RunCalibrationAction
]
instance WhatIfOptimizationService : DTDFVocab:Service [
    base:desc "What‑if analysis service running co‑simulations to evaluate alternative controller settings."
    DTDFVocab:provides WhatIfInsight
]
instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Self‑adaptation loop orchestrating calibration, controller re‑optimization, and deployment."
    DTDFVocab:provides UpdateControllerConfigAction
]
instance UserInterfaceService : DTDFVocab:Service [
    base:desc "User‑interface service exposing dashboards and configuration tools to operators."
    DTDFVocab:provides OperationInsight
]

// Insights / Actions
instance TemperatureDashboardInsight : DTDFVocab:Insight [
    base:desc "Live temperature and heating power visualization provided to operators."
]
instance ForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted future temperature trajectories for given heating and fan inputs."
]
instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Resulting new parameter estimates from the calibration routine."
]
instance AnomalyInsight : DTDFVocab:Insight [
    base:desc "Flag indicating significant deviation between measured and model‑predicted temperatures."
]
instance WhatIfInsight : DTDFVocab:Insight [
    base:desc "Outcome of scheduled what‑if simulations evaluating controller robustness."
]
instance OperationInsight : DTDFVocab:Insight [
    base:desc "Operational status and configurations displayed on the dashboard."
]

// Actions
instance RunCalibrationAction : DTDFVocab:Action [
    base:desc "Automated execution of the calibration routine on anomaly detection."
    DTDFVocab:IsAutomatic true
]
instance UpdateControllerConfigAction : DTDFVocab:Action [
    base:desc "Deployment of updated controller configuration back to Raspberry Pi."
    DTDFVocab:IsAutomatic true
]
instance AdjustHeatbedPowerAction : DTDFVocab:Action [
    base:desc "Dynamic adjustment of heatbed on/off state to maintain target temperature."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The controller receives control commands (e.g. to turn the heatbed or fan on/off) from the RabbitMQ broker. It then forwards the actuator orders to the low‑level driver via the same broker. The low‑level driver executes the commands after verifying them against a safe protocol that ensures the incubator remains in a protected state. After execution, the driver publishes the resulting control states back to the broker for telemetry. The controller implements a bang‑bang logic using the received reference temperature to decide heating or cooling actions."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Synchronization between the physical incubator and the Digital Twin is coordinated through a RabbitMQ message broker. A low‑level driver on the Raspberry Pi periodically reads temperature sensor data and publishes it to RabbitMQ, where Digital Twin services consume it. Real‑time monitoring, calibration, Kalman filtering and anomaly detection run on‑the‑fly, providing near‑instantaneous feedback with sub‑second responsiveness. Batch tasks such as what‑if simulations and offline calibrations are executed on demand and do not block the real‑time loop, resulting in a three‑tier temporal architecture: (1) periodic sensor sampling, (2) sub‑second real‑time processing, and (3) asynchronous batch processing."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin of the incubator is organised around a modular architecture that centres on three main stages: (1) *Data ingestion* from the physical twin via two internal temperature sensors and one external temperature sensor, all connected to a Raspberry Pi controller; (2) *Model calibration* where a calibration algorithm updates the parameters of two simulation models (Model A with two free parameters and Model B with four free parameters) to best fit the measured data; and (3) *Monitoring and decision‑making* where any resulting data are fed to safety monitors that check for violations and, if necessary, trigger re‑configuration of the physical controller. The framework follows a clear feed‑forward flow from physical sensing to digital modelling, and ultimately to actuation, with no explicit replication or hierarchical structure described in the documents."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Calibration routines fit Model A and Model B’s free parameters to experimental temperature data collected from the physical incubator by minimizing the discrepancy between measured temperatures and model predictions. Model B, containing two additional parameters, better captures the heat‑bed thermal inertia that Model A cannot, evidencing higher fidelity. Validation is implicit in direct comparison of live sensor data to model outputs, and model adjustments are made during calibration. Sources of uncertainty include sensor noise and variability in heater performance; the documents mention no explicit uncertainty quantification or error‑correction mechanisms beyond the calibration loop."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin’s technical back‑end uses RabbitMQ, an open‑source AMQP messaging broker, as the central communication middleware. All components (controller, low‑level driver, DT models) publish and subscribe to RabbitMQ queues over standard TCP connections. RabbitMQ provides the necessary transport layer; the broker can be deployed on‑premises on a local network. No specific bandwidth or latency targets are detailed, but the system relies on RabbitMQ’s lightweight message passing for near‑real‑time interaction."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Both the DT software (controller, low‑level driver, and associated logic) and the RabbitMQ message broker are deployed on the same physical Raspberry Pi used for the incubator, representing an on‑premises edge deployment. All components run locally within the incubator’s network, with no external cloud or edge servers required."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External integration is achieved through a RabbitMQ message broker that exchanges control and telemetry messages among the Raspberry Pi controller, the low‑level driver, and the Digital Twin services. The Digital Twin publishes telemetry data to a time‑series database, which feeds a real‑time dashboard for visualization. On‑demand calibration and heat‑bed state estimation requests are also routed via the same message bus. No additional enterprise systems are directly connected; integration focuses on these open‑source components."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin includes a monitoring component that continuously evaluates the physical twin’s operation against safety criteria. Sensor data (two interior temperature sensors and one exterior sensor) feed calibration and simulation models; violations trigger alerts or corrective actions. While the documents do not detail specific cybersecurity protocols, access‑control mechanisms, or fail‑safe components, the architecture follows general safety‑critical system practices by integrating real‑time monitoring and calibration to maintain safe operation. The open‑source repository on GitHub indicates a transparent implementation but does not specify privacy or consent handling."
]