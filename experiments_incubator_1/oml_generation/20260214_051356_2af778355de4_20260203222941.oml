// C3: Physical sensing components
instance InteriorTemperatureSensorLeft : DTDFVocab:SensingComponent [
    base:desc "First DS18S20 1‑Wire digital temperature sensor mounted inside the insulated box, monitoring interior temperature."
    DTDFVocab:producedData InteriorTemperatureDataLeftTransmitted
]

instance InteriorTemperatureSensorRight : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 1‑Wire digital temperature sensor mounted inside the insulated box, monitoring interior temperature."
    DTDFVocab:producedData InteriorTemperatureDataRightTransmitted
]

instance ExteriorTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital temperature sensor mounted outside the insulated box, measuring room temperature."
    DTDFVocab:producedData ExteriorTemperatureDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmitted via RabbitMQ)
instance InteriorTemperatureDataLeftTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTemperatureSensorLeft
]

instance InteriorTemperatureDataRightTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTemperatureSensorRight
]

instance ExteriorTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExteriorTemperatureSensor
]

// Actuation status messages
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed controlled via a MOSFET driver circuit, sending ON/OFF commands from the virtual side."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan controlled via an optocoupler circuit, receiving ON/OFF commands from the virtual side."
]

instance ActuatorStatusDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Status data transmitted from actuators, used for synchronization and safety monitoring."
]

// C10: Models/Data
instance TemperatureModelA : DTDFVocab:Model [
    base:desc "Single‑temperature heat‑transfer model with calibrated parameters C_air and G_box."
    DTDFVocab:inputTo PythonScipyEnabler
]

instance TemperatureModelB : DTDFVocab:Model [
    base:desc "Two‑temperature model with calibrated parameters C_air, C_heater, G_box, and G_heater."
    DTDFVocab:inputTo PythonScipyEnabler
]

// Data instances
instance InteriorTemperatureDataLeft : DTDFVocab:Data [
    base:desc "Time‑stamped interior temperature data stream from the left sensor."
    DTDFVocab:fromData InteriorTemperatureDataLeftTransmitted
    DTDFVocab:inputTo PythonScipyEnabler
]

instance InteriorTemperatureDataRight : DTDFVocab:Data [
    base:desc "Time‑stamped interior temperature data stream from the right sensor."
    DTDFVocab:fromData InteriorTemperatureDataRightTransmitted
    DTDFVocab:inputTo PythonScipyEnabler
]

instance ExteriorTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped exterior temperature data stream from the room sensor."
    DTDFVocab:fromData ExteriorTemperatureDataTransmitted
    DTDFVocab:inputTo PythonScipyEnabler
]

instance ActuatorStateLogsData : DTDFVocab:Data [
    base:desc "Log of actuator state changes received from the low‑level driver, used for synchronisation and safety monitoring."
    DTDFVocab:fromData ActuatorStatusDataTransmitted
    DTDFVocab:inputTo PythonScipyEnabler
]

// C11: Enablers
instance PythonScipyEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime with Scipy optimisation used to run differential‑equation models and calibrate parameters."
    DTDFVocab:enables MonitoringService, SimulationService, CalibrationService, SafetyMonitoringService, DecisionSupportService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature states and actuator logs."
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulate temperature dynamics using Model A and Model B."
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibrate and optimise model parameters via nonlinear least‑squares."
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Detect operating violations and safety violations."
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Provide suggestions for control adjustments and model selection based on data."
    DTDFVocab:provides InsightCalibratedParameterEstimates, InsightPredictedTemperatureProfiles, InsightFaultDetectionAlerts, InsightControlAdjustmentSuggestions, ActionAdjustHeatingDuration, ActionAdjustWaitingDuration, ActionSwitchModelSelection
]

// C17: Insights/Actions
instance InsightCalibratedParameterEstimates : DTDFVocab:Insight [
    base:desc "Calibrated parameter estimates derived from model calibration."
]

instance InsightPredictedTemperatureProfiles : DTDFVocab:Insight [
    base:desc "Predicted temperature profiles generated by the simulation models."
]

instance InsightFaultDetectionAlerts : DTDFVocab:Insight [
    base:desc "Alerts indicating detected fault or safety violations in system operation."
]

instance InsightControlAdjustmentSuggestions : DTDFVocab:Insight [
    base:desc "Suggested adjustments to heating duration, waiting duration, and model selection."
]

instance ActionAdjustHeatingDuration : DTDFVocab:Action [
    base:desc "Command to adjust heating duration (parameter H)."
    DTDFVocab:IsAutomatic true
]

instance ActionAdjustWaitingDuration : DTDFVocab:Action [
    base:desc "Command to adjust waiting duration (parameter C)."
    DTDFVocab:IsAutomatic true
]

instance ActionSwitchModelSelection : DTDFVocab:Action [
    base:desc "Command to switch between Model A and Model B."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (heatbed ON/OFF, fan ON/OFF, heating duration H, waiting duration C) are transmitted from the DT to the Raspberry Pi via RabbitMQ; the low‑level driver translates these into GPIO pulses that drive the MOSFET/optocoupler circuits."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centrally hosted constellation comprising: a RabbitMQ broker; a Python‑based controller that implements bang‑bang temperature control; a low‑level driver on the Raspberry Pi that interfaces with sensors and actuators; and the two simulation models (A and B) that receive sensor data and generate predictions."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design – derivation of the dynamic heat transfer models; Manufacture – construction of the physical incubator and assembly of the Raspberry Pi, PCB, sensors and actuators; Operation – deployment of the DT for real‑time monitoring, simulation, calibration, and control during daily use."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is assessed by minimising the residual error between measured and simulated temperatures during calibration; validity depends on the assumptions (uniform temperature, negligible wall heat, constant specific heat, negligible fan heat) which are verified via experiments; model parameters are calibrated to fit the observed temperature trajectories."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data flow between PT and DT occurs over a RabbitMQ message broker; the Raspberry Pi uses its built‑in Wi‑Fi for network connectivity, and sensors are connected via the 1‑Wire bus while actuators are commanded through GPIO pins."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted on the Raspberry Pi 4 itself, running the Python control and calibration services, with all models and data stored locally in the project repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is incorporated in the low‑level driver to prevent unsafe actuation states; however specific cybersecurity measures (e.g., encryption) are not detailed in the document."
]