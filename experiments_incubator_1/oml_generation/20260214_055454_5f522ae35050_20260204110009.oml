    DTDFVocab:inputTo CalibrationFeedbackService
]

instance ControlAdjustmentFramework : DTDFVocab:Enabler [
    base:desc "Supervisory control framework that implements state estimators and fault detectors to autonomously adjust actuators based on model predictions"
