instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Parameter estimation algorithms that update thermal models in real-time using sensor data for alignment between physical and virtual domains"
    DTDFVocab:inputTo ModelValidationFramework
]

instance DynamicParameterOptimizer : DTDFVocab:Enabler [
    base:desc "Optimization algorithms that adjust model parameters to minimize temperature deviations from target values using sensor feedback"
]

instance SpatialStateEstimator : DTDFVocab:Enabler [
    base:desc "State estimation techniques that infer hidden temperature states from noisy sensor data to improve model accuracy"
    DTDFVocab:inputTo TemperatureRegulationService
]

instance ModelValidationFramework : DTDFVocab:Enabler [
