// C1: Components
instance Wheel : DTDFVocab:Component [
    base:desc "Component comprising tire, rim, and axle used for vehicle movement."
]

instance Chassis : DTDFVocab:Component [
    base:desc "Structural frame providing mechanical support for the vehicle."
]

instance Body : DTDFVocab:Component [
    base:desc "Exterior shell of the passenger car enclosing occupants and equipment."
]

instance Engine : DTDFVocab:Component [
    base:desc "Internal combustion engine driving the vehicle."
]

instance ControlUnit : DTDFVocab:Component [
    base:desc "Electronic control unit coordinating vehicle subsystems."
]

// C2: Environment containing the components
instance VehicleEnv : DTDFVocab:Environment [
    base:contains Wheel, Chassis, Body, Engine, ControlUnit
]

// C3: Physical sensing components
instance EngineTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors the temperature of the passenger car engine."
    DTDFVocab:producedData EngineTemperatureTransmission
]

instance WheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Measures the rotational speed of each wheel in the passenger car."
    DTDFVocab:producedData WheelSpeedTransmission
]

// C4: Data transmitted from sensors
instance EngineTemperatureTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EngineTemperatureSensor
]

instance WheelSpeedTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedSensor
]

// C10: Data from transmitted data
instance EngineTemperatureSeries : DTDFVocab:Data [
    base:desc "Continuous time-series data of engine temperature collected from the car."
    DTDFVocab:inputTo CalibrationAlgorithm
    DTDFVocab:fromData EngineTemperatureTransmission
]

instance WheelSpeedSeries : DTDFVocab:Data [
    base:desc "Continuous time-series data of wheel speed collected from the car."
    DTDFVocab:inputTo CalibrationAlgorithm
    DTDFVocab:fromData WheelSpeedTransmission
]

// C10: Models
instance CADModel : DTDFVocab:Model [
    base:desc "Geometric representation of the car, including wheel sizes, chassis shapes, and body style."
    DTDFVocab:inputTo ValidationLayer
]

instance DynamicBehaviorModel : DTDFVocab:Model [
    base:desc "Differential‑equation‑based dynamic model capturing the vehicle’s physics and cyber‑physical interactions."
    DTDFVocab:inputTo ValidationLayer
    DTDFVocab:inputTo MonitoringLayer
    DTDFVocab:inputTo FaultDetectionAlgorithm
    DTDFVocab:inputTo SupervisoryController
    DTDFVocab:inputTo OptimisationAlgorithm
]

instance PerformanceModel : DTDFVocab:Model [
    base:desc "Analytical performance model evaluating efficiency, emissions, and safety of the car."
    DTDFVocab:inputTo ValidationLayer
    DTDFVocab:inputTo MonitoringLayer
]

// C11: Enablers
instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Algorithm that calibrates dynamic model parameters using real‑time sensor data."
    DTDFVocab:enables PredictiveSimulationService
    DTDFVocab:enables OptimizationService
]

instance ValidationLayer : DTDFVocab:Enabler [
    base:desc "Layer validating the fidelity of models against sensor data."
    DTDFVocab:enables RealTimeMonitoringService
]

instance MonitoringLayer : DTDFVocab:Enabler [
    base:desc "Layer monitoring the vehicle’s operation and detecting safety or optimisation violations."
    DTDFVocab:enables FaultDetectionService
    DTDFVocab:enables SupervisoryControlService
]

instance FaultDetectionAlgorithm : DTDFVocab:Enabler [
    base:desc "Diagnostic algorithm identifying abnormal states in vehicle operation."
    DTDFVocab:enables FaultDetectionService
]

instance SupervisoryController : DTDFVocab:Enabler [
    base:desc "Algorithm computing corrective actions to maintain vehicle safety."
    DTDFVocab:enables SupervisoryControlService
]

instance OptimisationAlgorithm : DTDFVocab:Enabler [
    base:desc "Suggests parameter adjustments to improve vehicle performance."
    DTDFVocab:enables OptimizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of the passenger car’s state based on sensor data and calibrated models."
    DTDFVocab:provides SafetyViolationDetected
    DTDFVocab:provides PerformanceDeviationDetected
    DTDFVocab:provides StateEstimateUpdated
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation of the vehicle’s dynamic behavior under current operating conditions."
    DTDFVocab:provides SimulationResultAvailable
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection service that identifies abnormal vehicle states."
    DTDFVocab:provides FaultDetected
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Supervisory control service computing corrective actions to maintain safety."
    DTDFVocab:provides ApplyCorrectiveAction
    DTDFVocab:provides TriggerAlarmAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service suggesting performance‑enhancing parameter adjustments."
    DTDFVocab:provides AdjustOperatingParametersAction
]

// C17: Insights
instance SafetyViolationDetected : DTDFVocab:Insight [
    base:desc "Indicates that a safety violation has been detected by the monitoring layer."
]

instance PerformanceDeviationDetected : DTDFVocab:Insight [
    base:desc "Signals a deviation from expected performance metrics."
]

instance StateEstimateUpdated : DTDFVocab:Insight [
    base:desc "Updates internal state estimates based on the latest sensor data."
]

instance SimulationResultAvailable : DTDFVocab:Insight [
    base:desc "Simulation results reflecting the predicted vehicle behavior."
]

instance FaultDetected : DTDFVocab:Insight [
    base:desc "An abnormal vehicle state has been identified by the diagnostic algorithm."
]

instance ParameterCalibrationUpdated : DTDFVocab:Insight [
    base:desc "Calibration parameters for the dynamic model have been updated."
]

// C17: Actions
instance ApplyCorrectiveAction : DTDFVocab:Action [
    base:desc "Applies corrective action to adjust vehicle control inputs for safety."
    DTDFVocab:IsAutomatic false
]

instance AdjustOperatingParametersAction : DTDFVocab:Action [
    base:desc "Adjusts operating parameters to improve efficiency and performance."
    DTDFVocab:IsAutomatic true
]

instance TriggerAlarmAction : DTDFVocab:Action [
    base:desc "Triggers an alarm to notify human operator of detected violation."
    DTDFVocab:IsAutomatic true
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through automated calibration algorithms that update model parameters to align simulated behaviour with real‑world sensor data. Validation occurs by monitoring the system’s performance in operation: safety and optimality checks run on the calibrated model outputs; violations trigger human or algorithmic interventions that can modify the physical twin. The monitoring layer also provides error detection, while calibration and monitoring collectively form the quality‑assurance process for models and data."
]