import DTDFVocab
instance SafetyInsight : DTDFVocab:Insight [
    base:desc "Indicates potential safety violations in the system"
]

instance OperationalOptimalityInsight : DTDFVocab:Insight [
    base:desc "Indicates opportunities for operational improvement"
]

instance FaultDetectedInsight : DTDFVocab:Insight [
    base:desc "Signals occurrence of a fault in the system"
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Provides estimated system state for decision-making"
]

instance OptimizedParametersInsight : DTDFVocab:Insight [
    base:desc "Optimal parameter settings derived from optimization algorithms"
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Adjusts heatbed and fan to maintain safe operating conditions",
    DTDFVocab:IsAutomatic true
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Assesses safety and operational optimality through real-time sensor data analysis",
    DTDFVocab:provides SafetyInsight, OperationalOptimalityInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects system faults using algorithm-based analysis",
    DTDFVocab:provides FaultDetectedInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Estimates system state using predictive algorithms",
    DTDFVocab:provides StateEstimationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimizes system parameters for operational efficiency",
    DTDFVocab:provides OptimizedParametersInsight
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Provides automated control adjustments based on system state",
    DTDFVocab:provides ControlAction
]

instance ScipyOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Provides optimization and parameter estimation algorithms using Python Scipy package",
    DTDFVocab:enables FaultDetectionService, StateEstimationService, OptimizationService, SupervisoryControlService
]

instance RaspberryPi4Controller : DTDFVocab:Enabler [
    base:desc "Embedded controller for hardware interfacing with sensors and actuators using Raspberry Pi 4 Model B",
    DTDFVocab:enables MonitoringService, SupervisoryControlService
]

instance RabbitMQCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "Enables real-time message-oriented communication between Physical Twin and Digital Twin using RabbitMQ server",
    DTDFVocab:enables MonitoringService
]

instance DS18S20Sensor1 : DTDFVocab:SensingComponent [
    base:desc "High-Precision 1-Wire Digital Thermometer sensor for internal temperature monitoring",
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance DS18S20Sensor2 : DTDFVocab:SensingComponent [
    base:desc "High-Precision 1-Wire Digital Thermometer sensor for internal temperature monitoring",
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20Sensor1, DS18S20Sensor2
]

instance InternalTemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature data collected from DS18S20 sensors via 1-Wire protocol",
    DTDFVocab:fromData TemperatureDataTransmitted,
    DTDFVocab:inputTo ScipyOptimizationEnabler
]

instance ThermalModel : DTDFVocab:Model [
    base:desc "Dynamic thermal model represented by differential equations calibrated with real-time temperature data",
    DTDFVocab:inputTo ScipyOptimizationEnabler
]

instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed for heating the styrofoam box interior, actuated via digital control signals with hardware-implemented safety constraints"
]

instance AirCirculationFan : DTDFVocab:ActingComponent [
    base:desc "Fan for air circulation, actuated via digital control signals with hardware-implemented safety constraints"
]

instance StyrofoamBoxEnvironment : DTDFVocab:Environment [
    base:contains DS18S20Sensor1, DS18S20Sensor2, HeatbedActuator, AirCirculationFan
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Raspberry Pi controller listens to RabbitMQ for commands to control the fan and heatbed operations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Calibration algorithms update the models of the cyber-physical system and environment with the best parameter estimates from sensor data; monitors validate system performance against safety and optimality criteria, detecting violations that trigger corrective actions by humans or algorithms."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "RabbitMQ server deployed for synchronization and communication between Physical and Digital Twins using AMQP protocol over TCP/IP, with message acknowledgments and persistent queues ensuring reliable data delivery."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Edge deployment on Raspberry Pi 4 Model B hardware with RabbitMQ server running locally, providing on-premise computational resources for real-time data processing and storage."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin employs monitoring systems to evaluate the Physical Twin's operational safety and optimality. Upon detecting safety violations, corrective actions are executed by human operators or automated algorithms to adjust the Physical Twin's state."
]