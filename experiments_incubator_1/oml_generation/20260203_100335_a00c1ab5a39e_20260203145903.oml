// Sensing component
instance PT_Sensor : DTDFVocab:SensingComponent [
    base:desc "Pressure/temperature sensor collecting data for the vehicle digital twin"
    DTDFVocab:producedData PTDataTransmitted
]

// Data transmitted by the sensor
instance PTDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PT_Sensor
]

// Data received from sensor, used by calibration enabler
instance PTTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series vehicle data obtained from PT sensor"
    DTDFVocab:fromData PTDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithmSuite
]

// Enablers and services for calibration
instance CalibrationAlgorithmSuite : DTDFVocab:Enabler [
    base:desc "Calibration algorithms that continuously update cyber‑physical and environmental models"
    DTDFVocab:enables CalibrationService
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that estimates calibration parameters and provides insights for model adjustment"
    DTDFVocab:provides CalibrationInsight
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight into calibrated model parameters and their uncertainty"
]

// Enabler and service for physics‑based simulation
instance PhysicsBasedModelEngine : DTDFVocab:Enabler [
    base:desc "Physics‑based modeling engine for vehicle dynamics"
    DTDFVocab:enables PredictiveSimulationService
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation of vehicle dynamic behaviour under current operating conditions"
    DTDFVocab:provides SimulationPredictionInsight
]

instance SimulationPredictionInsight : DTDFVocab:Insight [
    base:desc "Prediction of vehicle behaviour based on physical models and current sensor data"
]

// Enabler and service for optimisation
instance OptimisationEngine : DTDFVocab:Enabler [
    base:desc "Optimisation engine that suggests parameter adjustments to improve performance"
    DTDFVocab:enables OptimisationService
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Optimisation service that recommends adjustments for efficiency"
    DTDFVocab:provides ParameterAdjustmentAction
]

instance ParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated adjustment of vehicle parameters to optimise performance"
    DTDFVocab:IsAutomatic true
]

// Enabler and service for fault detection
instance FaultDetectionEngine : DTDFVocab:Enabler [
    base:desc "Fault detection algorithms that identify abnormal states"
    DTDFVocab:enables FaultDetectionService
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection service that evaluates data for safety violations"
    DTDFVocab:provides FaultDetectionInsight, SafetyViolationInsight
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating detected fault conditions"
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating safety violations in vehicle operation"
]

// Enabler and service for supervisory control
instance SupervisoryControllerEngine : DTDFVocab:Enabler [
    base:desc "Supervisory controller algorithms that compute corrective actions"
    DTDFVocab:enables SupervisoryControlService
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Service that computes corrective actions to maintain safety"
    DTDFVocab:provides CorrectiveAction, AlarmTriggerAction
]

instance CorrectiveAction : DTDFVocab:Action [
    base:desc "Corrective action applied to the physical vehicle to address fault"
    DTDFVocab:IsAutomatic true
]

instance AlarmTriggerAction : DTDFVocab:Action [
    base:desc "Alarm triggered when safety violation cannot be corrected automatically"
    DTDFVocab:IsAutomatic false
]

// Real‑time monitoring service
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of physical car through data streams"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight from real‑time monitoring indicating operational status"
]

// Models
instance CADVehicleModel : DTDFVocab:Model [
    base:desc "Geometric representation of vehicle containing wheel sizes, chassis shapes, and car styles"
    DTDFVocab:inputTo PhysicsBasedModelEngine
]

instance DynamicBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral dynamical model based on differential equations capturing vehicle physics"
    DTDFVocab:inputTo PhysicsBasedModelEngine
]

instance AnalyticalPerformanceModel : DTDFVocab:Model [
    base:desc "Analytical performance model predicting vehicle efficiency"
    DTDFVocab:inputTo OptimisationEngine
]

// Components of the vehicle
instance VehicleWheel : DTDFVocab:Component [
    base:desc "Wheel component of the vehicle"
]

instance VehicleChassis : DTDFVocab:Component [
    base:desc "Chassis component of the vehicle"
]

instance VehicleBody : DTDFVocab:Component [
    base:desc "Body component of the vehicle"
]

instance VehicleEngine : DTDFVocab:Component [
    base:desc "Engine component of the vehicle"
]

instance VehicleECU : DTDFVocab:Component [
    base:desc "Electronic Control Unit of the vehicle"
]

// Environment containing all components
instance VehicleEnvironment : DTDFVocab:Environment [
    base:contains VehicleWheel, VehicleChassis, VehicleBody, VehicleEngine, VehicleECU
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through automated calibration algorithms that update model parameters to align simulated behaviour with real‑world sensor data. Validation occurs by monitoring the system’s performance in operation: safety and optimality checks run on the calibrated model outputs; violations trigger human or algorithmic interventions that can modify the physical twin. The monitoring layer also provides error detection, while calibration and monitoring collectively form the quality‑assurance process for models and data."
]