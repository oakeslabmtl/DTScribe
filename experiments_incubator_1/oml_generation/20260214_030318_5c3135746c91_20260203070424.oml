// ---------------------------------------------------------------
// C2: Acting Components
// ---------------------------------------------------------------
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that provides heating power to the interior of the incubator’s insulated styrofoam box. Controlled via commands from the Digital Twin over the network."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan that circulates heated air inside the incubator to improve temperature uniformity. Driven by the Raspberry Pi controller per Digital Twin commands."
]

// ---------------------------------------------------------------
// C3: Physical Sensing Components
// ---------------------------------------------------------------
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor placed inside the insulated styrofoam box to measure internal temperature (sensor 1)."
    DTDFVocab:producedData TemperatureReadingTransmitted1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor placed inside the insulated styrofoam box to measure internal temperature (sensor 2)."
    DTDFVocab:producedData TemperatureReadingTransmitted2
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor placed outside the box to monitor ambient temperature."
    DTDFVocab:producedData TemperatureReadingTransmittedExt
]

// ---------------------------------------------------------------
// C4: Physical‑to‑Virtual Interaction (Data Transmitted)
// ---------------------------------------------------------------
instance TemperatureReadingTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance TemperatureReadingTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance TemperatureReadingTransmittedExt : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// ---------------------------------------------------------------
// C5: Data (raw temperature readings)
// ---------------------------------------------------------------
instance TemperatureDataInternal1 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature value read from InternalTempSensor1, uploaded via AMQP to RabbitMQ."
    DTDFVocab:fromData TemperatureReadingTransmitted1
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringAlgorithm
]

instance TemperatureDataInternal2 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature value read from InternalTempSensor2, uploaded via AMQP to RabbitMQ."
    DTDFVocab:fromData TemperatureReadingTransmitted2
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringAlgorithm
]

instance TemperatureDataExternal : DTDFVocab:Data [
    base:desc "Time‑stamped ambient temperature value read from ExternalTempSensor, uploaded via AMQP to RabbitMQ."
    DTDFVocab:fromData TemperatureReadingTransmittedExt
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringAlgorithm
]

// ---------------------------------------------------------------
// C8: Models (thermal dynamics)
// ---------------------------------------------------------------
instance ThermalModelTwoParam : DTDFVocab:Model [
    base:desc "Thermal dynamics model of the incubator with two free parameters, used for quick prediction of internal temperature."
    DTDFVocab:inputTo SimulationEngine
]

instance ThermalModelFourParam : DTDFVocab:Model [
    base:desc "Thermal dynamics model of the incubator with four free parameters, capturing heat‑bed inertia more accurately."
    DTDFVocab:inputTo SimulationEngine
]

// ---------------------------------------------------------------
// C11: Enablers (software/tools)
// ---------------------------------------------------------------
instance RaspberryPiController : DTDFVocab:Enabler [
    base:desc "Raspberry Pi that runs low‑level drivers, calibration, monitoring and optimisation algorithms; provides the network interface to the Digital Twin."
    DTDFVocab:enables ModelCalibrationService, SafetyMonitoringService, PerformanceMonitoringService, HeatingOptimizationService, VisualizationService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "AMQP broker (RabbitMQ) that receives temperature messages from the Raspberry Pi and forwards them to the Digital Twin."
    DTDFVocab:enables DataIngestionService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Algorithm that calibrates the free parameters of the thermal models using collected temperature data."
    DTDFVocab:enables ModelCalibrationService
]

instance MonitoringAlgorithm : DTDFVocab:Enabler [
    base:desc "Algorithm that continuously evaluates calibrated model predictions against incoming sensor data to detect safety or optimality violations."
    DTDFVocab:enables SafetyMonitoringService, PerformanceMonitoringService
]

instance OptimizationAlgorithm : DTDFVocab:Enabler [
    base:desc "Algorithm that computes optimal heating set‑points based on model predictions and current system state."
    DTDFVocab:enables HeatingOptimizationService
]

instance VisualizationModule : DTDFVocab:Enabler [
    base:desc "Software module that prepares advanced visualisations for re‑configuration, maintenance reduction and decision‑making."
    DTDFVocab:enables VisualizationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Runtime engine that executes the thermal models to provide temperature predictions."
    DTDFVocab:enables TemperaturePredictionService
]

// ---------------------------------------------------------------
// C6: Services
// ---------------------------------------------------------------
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service that ingests temperature messages from RabbitMQ and stores them for downstream use."
    DTDFVocab:provides InsightDataIngestion
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Service that calibrates thermal model parameters using the latest temperature data."
    DTDFVocab:provides InsightModelCalibration
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors system safety by checking model‑sensor consistency and raises alerts on violations."
    DTDFVocab:provides InsightSafetyAlert
]

instance PerformanceMonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors performance (e.g., energy usage, temperature tracking error) and reports degradations."
    DTDFVocab:provides InsightPerformanceDegradation
]

instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Service that provides simulation‑based prediction of the incubator’s internal temperature."
    DTDFVocab:provides InsightTemperaturePrediction
]

instance HeatingOptimizationService : DTDFVocab:Service [
    base:desc "Service that optimises heating control settings to achieve target temperature efficiently."
    DTDFVocab:provides ActionAdjustHeating
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that generates advanced visualisations supporting re‑configuration and maintenance decisions."
    DTDFVocab:provides InsightVisualizationReady
]

// ---------------------------------------------------------------
// C17: Insights / Actions
// ---------------------------------------------------------------
instance InsightDataIngestion : DTDFVocab:Insight [
    base:desc "Indicates that temperature data have been successfully ingested and stored."
]

instance InsightModelCalibration : DTDFVocab:Insight [
    base:desc "Indicates that thermal model parameters have been calibrated with the latest data."
]

instance InsightSafetyAlert : DTDFVocab:Insight [
    base:desc "Safety violation detected (e.g., temperature exceeds safe bounds); requires operator or automated response."
]

instance InsightPerformanceDegradation : DTDFVocab:Insight [
    base:desc "Performance degradation detected (e.g., increased prediction error or excessive energy consumption)."
]

instance InsightTemperaturePrediction : DTDFVocab:Insight [
    base:desc "Provides predicted internal temperature for the next control horizon."
]

instance ActionAdjustHeating : DTDFVocab:Action [
    base:desc "Automatically modifies heat‑bed power set‑point to restore safe/optimal temperature."
    DTDFVocab:IsAutomatic true
]

instance InsightVisualizationReady : DTDFVocab:Insight [
    base:desc "Visualization artefacts are ready for operator consumption."
]

// ---------------------------------------------------------------
// C16: Environment and Physical Components (optional contextualisation)
// ---------------------------------------------------------------
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, FanActuator, InternalTempSensor1, InternalTempSensor2, ExternalTempSensor
]

instance HeatBedComponent : DTDFVocab:Component [
    base:desc "Physical heat‑bed used as the primary heating element inside the incubator."
]

instance FanComponent : DTDFVocab:Component [
    base:desc "Physical fan that circulates heated air within the incubator."
]

instance InternalTempSensorComponent1 : DTDFVocab:Component [
    base:desc "Physical temperature sensor inside the incubator (sensor 1)."
]

instance InternalTempSensorComponent2 : DTDFVocab:Component [
    base:desc "Physical temperature sensor inside the incubator (sensor 2)."
]

instance ExternalTempSensorComponent : DTDFVocab:Component [
    base:desc "Physical temperature sensor mounted outside the incubator."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin sends control commands (e.g., heat‑bed ON/OFF, fan ON/OFF) to the Physical Twin via the RabbitMQ broker. The controller on the Raspberry Pi publishes command messages—containing command type and parameters such as heating duration (H) and waiting duration (C)—to RabbitMQ; the low‑level driver receives the messages, validates them through its safe protocol, actuates the hardware, and can acknowledge execution as part of its regular data upload."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin operates in real‑time: it continuously listens to controller and low‑level driver messages, streams the data into a time‑series database and updates a dashboard for visualization. Calibration and anomaly detection (Kalman filter) are performed on‑demand using the latest sensor readings. No explicit synchronization frequencies or latency requirements are stated in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT follows a CPS‑based architecture: sensor data and controller messages from the Physical Twin are ingested into a time‑series database, which feeds a real‑time dashboard. Two simulation models (one with two free parameters, one with four) are calibrated on‑demand; the calibrated Model B is used by a Kalman filter for heat‑bed state estimation and anomaly detection. What‑if simulations are carried out via co‑simulation that consumes historical or live PT data. These services are orchestrated in a self‑adaptation loop that can re‑configure the controller based on detected changes."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the two thermal models: the four‑parameter model shows higher fidelity in reproducing the heat‑bed’s thermal inertia, as demonstrated by experimental validation described in the case study. Model validation is performed through calibration against the recorded sensor data and by evaluating prediction errors in the experimental results. Uncertainty sources include sensor noise and model simplifications, though quantitative uncertainty quantification is not detailed. The calibration step serves as an error‑correction mechanism, and the overall quality assurance relies on experimentally verifying that the model predictions match measured temperatures."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between physical components and the Digital Twin relies on a RabbitMQ message broker. The broker uses the AMQP protocol over a local network connecting the Raspberry Pi controller, the low‑level driver and any DT services. The network topology is essentially a star with RabbitMQ as the central hub. RabbitMQ provides reliable message delivery, persistence and supports clustering for redundancy, though specific bandwidth or latency requirements are not specified in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin is deployed on‑premise: the controller runs on an edge device (Raspberry Pi) and the RabbitMQ server can be hosted locally or in the cloud, as RabbitMQ is described as lightweight and easy to deploy on premises or in the cloud. Computational load is modest (temperature acquisition and simple bang‑bang control) and storage needs are limited to recent sensor logs. Scalability is achieved by adding consumers or clustering RabbitMQ; availability and reliability are supported by RabbitMQ’s mature fault‑tolerance mechanisms."
]