// C3: Physical sensing components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "Measures air temperature inside the styrofoam box at the hottest position. Part of the three DS18S20 temperature sensors used for feedback control and model calibration. Validates uniform temperature distribution assumption through fan operation."
    DTDFVocab:producedData InternalTemperatureData1
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Measures air temperature inside the styrofoam box at the coldest position. Part of the three DS18S20 temperature sensors used for feedback control and model calibration. Validates uniform temperature distribution assumption through fan operation."
    DTDFVocab:producedData InternalTemperatureData2
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors ambient temperature outside the insulated styrofoam box. Provides environmental context for model calibration and anomaly detection."
    DTDFVocab:producedData ExternalTemperatureData
]

// C4: Physical-to-virtual interaction
instance InternalTemperatureData1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1
    base:desc "Raw temperature data from the hottest position inside the incubator box. Periodically read by the low-level driver and streamed to RabbitMQ for real-time processing."
]

instance InternalTemperatureData2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor2
    base:desc "Raw temperature data from the coldest position inside the incubator box. Periodically read by the low-level driver and streamed to RabbitMQ for real-time processing."
]

instance ExternalTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
    base:desc "Raw ambient temperature data outside the incubator box. Periodically read by the low-level driver and streamed to RabbitMQ for real-time processing."
]

instance SystemStateData : DTDFVocab:DataTransmitted [
    base:desc "System state data including heatbed status, fan status, and power input. Generated by the low-level driver and transmitted via RabbitMQ for controller and DT synchronization."
]

instance ControllerStateData : DTDFVocab:DataTransmitted [
    base:desc "Controller state data including heating duration, waiting duration, temperature limits (LL, UL). Generated by the Raspberry Pi controller and transmitted via RabbitMQ for DT monitoring."
]

// C10: Models/Data
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Simplified thermal model assuming all electrical power from the heatbed is directly transferred to the air inside the box. Uses the heat equation Q = cmΔT with 2 parameters. Less accurate for thermal inertia prediction."
    DTDFVocab:inputTo ModelCalibrationEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Enhanced thermal model relaxing Assumption 4 (ignoring heat absorption by the heatbed). Uses the heat equation Q = cmΔT with 4 parameters (E_power = VIΔt) for improved thermal inertia prediction. Selected for further development due to superior accuracy."
    DTDFVocab:inputTo ModelCalibrationEnabler
]

instance AveragedTemperatureData : DTDFVocab:Data [
    base:desc "Processed temperature data representing the average temperature inside the incubator box. Generated by averaging readings from InternalTemperatureSensor1 and InternalTemperatureSensor2 to account for uniform distribution."
    DTDFVocab:fromData InternalTemperatureData1, InternalTemperatureData2
    DTDFVocab:inputTo ModelCalibrationEnabler
]

instance HistoricalTemperatureData : DTDFVocab:Data [
    base:desc "Time-series historical temperature data stored for visualization and what-if simulations. Includes both internal and external temperature readings over time."
    DTDFVocab:fromData InternalTemperatureData1, InternalTemperatureData2, ExternalTemperatureData
    DTDFVocab:inputTo WhatIfSimulationEnabler
]

instance SystemStateDataProcessed : DTDFVocab:Data [
    base:desc "Processed system state data including validated heatbed status, fan status, and power input. Used for real-time monitoring and anomaly detection."
    DTDFVocab:fromData SystemStateData
    DTDFVocab:inputTo RealTimeMonitoringEnabler
]

instance ControllerStateDataProcessed : DTDFVocab:Data [
    base:desc "Processed controller state data including validated heating duration, waiting duration, and temperature limits. Used for model calibration and control adaptation."
    DTDFVocab:fromData ControllerStateData
    DTDFVocab:inputTo ModelCalibrationEnabler
]

// C11: Enablers
instance RabbitMQMessageBroker : DTDFVocab:Enabler [
    base:desc "Asynchronous message broker facilitating communication between the low-level driver, controller, and Digital Twin components. Enables real-time data exchange and decoupled system architecture."
]

instance ModelCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Automated calibration process using non-linear least squares solver to minimize prediction errors between models and real-time data. Updates model parameters (Model A/B) based on sensor feedback."
    DTDFVocab:enables ModelCalibrationService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "State estimation algorithm correlating measured temperature data with non-measured states (e.g., heatbed temperature). Provides anomaly detection and thermal inertia estimation."
    DTDFVocab:enables AnomalyDetectionService, ControlAdaptationService
]

instance WhatIfSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Co-simulation framework enabling hypothetical scenario testing using historical or real-time Physical Twin data. Optimizes controller parameters (LL, UL, H, C) for improved performance."
    DTDFVocab:enables PredictionAndWhatIfSimulationService
]

instance RealTimeMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Time-series data processing and visualization infrastructure relaying data to dashboards for operators. Listens to controller and low-level driver messages via RabbitMQ."
    DTDFVocab:enables MonitoringService, VisualizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous real-time visualization of the incubator's status including temperature trends, controller states, and system health metrics. Targets engineers, operators, and maintenance teams."
    DTDFVocab:provides RealTimeTemperatureVisualizationInsight, ControllerStateInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "On-demand calibration of simulation models to align with real-world behavior. Uses historical or real-time data from the Physical Twin to update Model A/B parameters dynamically."
    DTDFVocab:provides ModelAccuracyInsight, CalibrationUpdateAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Identifies deviations from expected behavior using statistical and model-based methods. Detects anomalies when Physical Twin behavior changes (e.g., introduction of cold objects) and triggers adaptive responses."
    DTDFVocab:provides AnomalyAlertInsight, ControllerReconfigurationAction
]

instance PredictionAndWhatIfSimulationService : DTDFVocab:Service [
    base:desc "Simulates future scenarios to optimize controller parameters or test system responses. Runs co-simulations using historical or real-time Physical Twin data to evaluate hypothetical changes."
    DTDFVocab:provides SimulationResultInsight, ControllerOptimizationAction
]

instance ControlAdaptationService : DTDFVocab:Service [
    base:desc "Self-adaptation loop dynamically reconfiguring the system based on detected changes. Detects behavioral changes, schedules experiments, recalibrates models, and optimizes controller parameters."
    DTDFVocab:provides AdaptationRecommendationInsight, SystemReconfigurationAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides intuitive interfaces for interpreting system data and simulations. Displays real-time and historical temperature trends, model calibration results, and interactive simulation outcomes."
    DTDFVocab:provides DataVisualizationInsight, InteractiveExplorationAction
]

// C17: Insights/Actions
instance RealTimeTemperatureVisualizationInsight : DTDFVocab:Insight [
    base:desc "Continuous visualization of internal and external temperature trends with historical comparison. Enables operators to monitor system stability and detect gradual deviations."
]

instance ControllerStateInsight : DTDFVocab:Insight [
    base:desc "Real-time status of controller parameters (LL, UL, H, C) and actuation commands. Provides transparency into system control logic and operational state."
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Comparison of Model A and Model B prediction accuracy against real-time sensor data. Includes mean squared error metrics and calibration confidence intervals."
]

instance CalibrationUpdateAction : DTDFVocab:Action [
    base:desc "Automated adjustment of model parameters (Model A/B) based on calibration results. Triggers when prediction errors exceed thresholds or during scheduled maintenance cycles."
    DTDFVocab:IsAutomatic true
]

instance AnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Alerts generated when Kalman filter residuals exceed thresholds or when unexpected temperature patterns are detected. Includes severity classification and likely root causes."
]

instance ControllerReconfigurationAction : DTDFVocab:Action [
    base:desc "Dynamic adjustment of controller parameters (LL, UL, H, C) in response to detected anomalies or environmental changes. May include temporary overrides for safety-critical scenarios."
    DTDFVocab:IsAutomatic true
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Predicted system behavior under hypothetical scenarios (e.g., target temperature changes, new object introduction). Includes performance metrics and risk assessments."
]

instance ControllerOptimizationAction : DTDFVocab:Action [
    base:desc "Optimization of controller parameters based on what-if simulation results. Implements changes only after validation against real-time data."
    DTDFVocab:IsAutomatic false
]

instance AdaptationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Suggested system adaptations including model updates, controller parameter changes, and operational procedure modifications. Prioritized based on impact assessment."
]

instance SystemReconfigurationAction : DTDFVocab:Action [
    base:desc "Comprehensive system reconfiguration including model recalibration, Kalman filter updates, and controller parameter adjustments. Executed during self-adaptation loops."
    DTDFVocab:IsAutomatic true
]

instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive visual representations of temperature data, model predictions, and system states. Supports comparative analysis between Model A and Model B performance."
]

instance InteractiveExplorationAction : DTDFVocab:Action [
    base:desc "User-driven exploration of simulation scenarios and historical data. Allows operators to test hypothetical conditions and visualize outcomes."
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heating element controlled via modified bang-bang control logic. Operates within electrical supply constraints and safety protocols to regulate internal temperature. Governed by controller parameters LL, UL, H, and C."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Passive air circulation device ensuring uniform temperature distribution inside the incubator box. Validates Assumption 1 of uniform temperature distribution. Operates continuously or in synchronization with heatbed cycles."
]

instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "Embedded controller implementing bang-bang control logic to regulate temperature based on sensor feedback. Receives commands via RabbitMQ and issues actuation signals to the low-level driver for heatbed and fan control."
]

// C1: Physical Components
instance InsulatedStyrofoamBox : DTDFVocab:Component [
    base:desc "Thermally insulated container maintaining temperature isolation to minimize heat loss/gain from the environment. Houses the heatbed, fan, and temperature sensors."
]

instance LowLevelDriver : DTDFVocab:Component [
    base:desc "Software abstraction layer managing communication with sensors and actuators. Periodically reads temperature data, applies safety checks, and publishes validated data to RabbitMQ. Enforces safety protocols to prevent system damage."
]

instance RabbitMQCommunicationServer : DTDFVocab:Component [
    base:desc "Message broker facilitating asynchronous communication between the controller, low-level driver, and Digital Twin components. Enables decoupled system architecture with RabbitMQ queues/topics for component addressing."
]

// C16: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Controlled thermal environment for biological experiments or material processing. Subject to external temperature fluctuations and internal content variability."
    base:contains InsulatedStyrofoamBox, HeatbedActuator, FanActuator, InternalTemperatureSensor1, InternalTemperatureSensor2, ExternalTemperatureSensor
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:desc "Virtual representation of the Physical Twin enabling real-time monitoring, simulation, and optimization. Hosts all Digital Twin services and enablers."
    base:contains ThermalModelA, ThermalModelB, AveragedTemperatureData, HistoricalTemperatureData, SystemStateDataProcessed, ControllerStateDataProcessed, RabbitMQMessageBroker, ModelCalibrationEnabler, KalmanFilterEnabler, WhatIfSimulationEnabler, RealTimeMonitoringEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "
The **virtual-to-physical interaction** in the incubator DT system is constrained to the following verified components, with unsupported claims explicitly excluded:

1. **Command Types**:
   - **Heating commands**: Binary signals to activate/deactivate the **heatbed** (via low-level driver) based on **bang-bang control logic** (modified to include waiting durations).
   - **Fan control**: Adjustments to fan speed (voltage: 12V or 18V) to improve temperature uniformity (Assumption 1 validation).

2. **Control Message Formats**:
   - **Statechart-based logic** (Fig. 8): The controller implements a **modified bang-bang strategy** with parameters:
     - **LL (Lower Limit)**: Minimum target temperature.
     - **UL (Upper Limit)**: Maximum target temperature.
     - **H (Heating Duration)**: Time the heatbed remains ON after activation.
     - **C (Waiting Duration)**: Delay after heating to prevent overshoot.
   - **Commands transmitted via RabbitMQ**: The controller sends actuation commands (e.g., `HEATBED_ON`, `FAN_ADJUST`) to the low-level driver, which translates them into physical actions.

3. **Validation and Authentication Mechanisms**:
   - **Safe protocol**: Embedded in the **low-level driver** to ensure the PT remains in a **safe state** during command execution (e.g., preventing overheating).
   - **Parameter validation**: Controller parameters (LL, UL, H, C) are validated against **physical constraints** (e.g., max temperature, power limits).

4. **Feedback Systems**:
   - **Closed-loop control**: The controller receives **real-time temperature feedback** from the low-level driver (via RabbitMQ) to adjust commands dynamically.
   - **Anomaly detection (Kalman filter)**: *Not implemented in the current system* (only mentioned as a **future DT goal** for self-adaptation).

5. **Conflict Resolution**:
   - **Priority-based**: The controller prioritizes **safety constraints** (e.g., UL breaches) over optimization goals. No explicit conflict resolution mechanisms are documented for concurrent commands.

6. **Command Execution Confirmation**:
   - **Implicit acknowledgment**: The low-level driver confirms command execution by updating RabbitMQ with the **new PT state** (e.g., heatbed status, temperature readings). The controller monitors these updates to validate outcomes.

**Exclusions (Not in Document)**:
   - Dashboards, self-adaptation loops, or real-time visualization are **future work** and not part of the current implementation.
   - No details on **authentication protocols**, **encryption**, or **command logging** are provided.
"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system for the incubator case study operates with **real-time synchronization** between the Physical Twin (PT) and Digital Twin (DT) components. The **low-level driver** periodically reads temperature data from sensors (e.g., two internal sensors and one external sensor) and uploads it to the **RabbitMQ communication server** for processing. While the exact synchronization frequency is not explicitly stated, the system is designed to support **real-time visualization** of the incubator status by relaying controller and driver messages to a time-series database and dashboard. The **Kalman filter** for anomaly detection and heatbed state estimation operates in **real-time**, correlating measured data with non-measured heatbed temperature. Additionally, the **what-if simulations** leverage **co-simulations** with historical or real-time PT data, implying a need for low-latency data exchange to ensure predictive accuracy. The **self-adaptation loop** involves sequential steps (e.g., anomaly detection, experiment scheduling, calibration, and controller reconfiguration), which must adhere to the PT’s operational time scales to avoid disruptions. The **controller** (a modified bang-bang controller) enforces **temporal constraints** via parameters like **heating duration (H)** and **waiting duration (C)**, ensuring stable temperature regulation within defined **lower (LL)** and **upper (UL)** limits. The system’s temporal granularity is further influenced by the **fan’s voltage adjustments** (e.g., 12V vs. 18V), which affect temperature uniformity and sensor response times (e.g., discrepancies of ≤7°C between sensors)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system for the incubator follows a **message-driven architecture** centered around **RabbitMQ**, a lightweight, open-source message broker facilitating communication between the **Physical Twin (PT)**, **controller**, **low-level driver**, and **Digital Twin (DT) components**. The **data flow** is unidirectional and bidirectional:
  - The **low-level driver** periodically reads temperature data from sensors and uploads it to RabbitMQ.
  - The **controller** listens to RabbitMQ for commands (e.g., heating/fan control) and shares its state back to the broker.
  - The **DT components** (e.g., calibration algorithms, Kalman filter, what-if simulations) **listen to messages** passed between the controller and driver, enabling real-time visualization, anomaly detection, and state estimation. The system does not explicitly describe a **layered architecture** or **orchestration layer**, but the **calibration algorithms** (e.g., updating Model B parameters) and **Kalman filter** (for heatbed state estimation) operate as **autonomous services** integrated via RabbitMQ. Resource management is implicit, with the **controller’s bang-bang logic** and **driver’s safety protocols** ensuring operational constraints are met. The **self-adaptation loop** (e.g., dynamic recalibration) is proposed as future work but not implemented in the provided documents."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The **model fidelity** trade-off is explicitly addressed via **Model A** (simpler, ignores heatbed energy loss) and **Model B** (higher fidelity, accounts for thermal inertia). **Validation** is performed through **experimental calibration** using a **non-linear least squares solver** to minimize prediction errors, with **Model B** demonstrated to better match PT behavior. **Uncertainty sources** include sensor inaccuracies (±0.5°C), model assumptions (e.g., uniform temperature distribution), and environmental variability (e.g., external temperature fluctuations). **Error detection** relies on **anomaly detection** (implied via calibration residuals but not explicitly detailed as a Kalman filter in the provided documents). **Quality assurance** processes include **real-time monitoring** of PT behavior and **on-demand recalibration** when anomalies or environmental changes (e.g., adding cold objects) are detected. No formal verification methods (e.g., statistical hypothesis testing) are mentioned beyond empirical comparison of Model A/B predictions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "
The **technical network infrastructure** for the incubator DT system is defined by the following documented components:

1. **Communication Protocols**:
   - **RabbitMQ**: Deployed as the **message broker** for all inter-component communication. It supports:
     - **Publish-subscribe model**: The low-level driver publishes sensor data, while the controller subscribes to commands.
     - **Lightweight design**: Optimized for **on-premise deployment** on the Raspberry Pi (no cloud dependencies mentioned).
   - **No explicit transport protocols**: The documents do not specify TCP/UDP, MQTT, or other layer details beyond RabbitMQ’s use.

2. **Network Topology and Architecture**:
   - **Centralized star topology**: All components (low-level driver, controller, DT) connect to the **RabbitMQ server** (Fig. 7). The controller and driver are co-located on the **Raspberry Pi**, with no distributed nodes.
   - **Single-hop communication**: Messages travel directly between components and RabbitMQ without intermediate gateways.

3. **Bandwidth and Latency Requirements**:
   - **Not quantified**: The documents do not specify:
     - Minimum/maximum bandwidth (e.g., for sensor data or control commands).
     - Latency thresholds (e.g., for real-time control loops).
   - **Assumed low-latency**: Given the **periodic polling** of temperature data and **immediate command execution**, the system likely operates within **sub-second intervals** (typical for embedded CPS).

4. **Reliability and Redundancy Mechanisms**:
   - **No redundancy**: Single RabbitMQ instance deployed on the Raspberry Pi. No clustering, failover, or backup brokers are mentioned.
   - **Safe protocol**: The low-level driver includes **safety checks** to prevent PT damage (e.g., overheating), but no network-level redundancy is documented.

5. **Security Protocols**:
   - **Not specified**: The documents do not mention:
     - Encryption (e.g., TLS for RabbitMQ).
     - Authentication/authorization for message access.
     - Firewall or network segmentation rules.

**Note**: The infrastructure is **minimalist**, focusing on **functionality over robustness**, with all components tightly coupled to the Raspberry Pi environment.
"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "
The **hosting and deployment infrastructure** for the incubator DT system is constrained to the following verified details:

1. **Hosting Platforms**:
   - **On-premise (embedded)**: The **controller** and **communication server (RabbitMQ)** are deployed on a **Raspberry Pi**, co-located with the **low-level driver**.
   - **No cloud/edge deployment**: The documents do not mention hybrid or distributed hosting models.

2. **Computational and Storage Requirements**:
   - **Controller**: Runs on the Raspberry Pi with **no specific CPU/RAM requirements** documented. Implements a **bang-bang control algorithm** with minimal computational overhead.
   - **RabbitMQ**: Lightweight broker with **no scaling constraints** mentioned. Assumed to operate within the Pi’s resource limits.
   - **Storage**: No explicit storage requirements are documented. Sensor data and control logs are likely stored **temporarily in memory** or relayed to external systems (e.g., dashboards) as part of future work.

3. **Scalability Mechanisms**:
   - **Not applicable**: The system is **monolithic** and designed for a **single incubator instance**. No horizontal/vertical scaling mechanisms (e.g., load balancing, containerization) are mentioned.

4. **Deployment Models Supported**:
   - **Single-node deployment**: All components (hardware + software) are deployed on the **Raspberry Pi** with **direct sensor/actuator integration**.
   - **No modular deployment**: The DT is not designed as a **microservices architecture** or **containerized** (e.g., Docker/Kubernetes).

5. **Availability/Reliability Assurance**:
   - **No redundancy**: Single point of failure (Raspberry Pi). No high-availability (HA) clusters or backup systems are documented.
   - **Safe protocol**: The low-level driver includes **safety checks** to prevent PT damage, but no DT-specific reliability mechanisms (e.g., checkpointing, failover) are described.
   - **Assumed uptime**: The system is designed for **continuous operation** but lacks explicit SLAs or recovery procedures.

**Exclusions (Not in Document)**:
   - Time-series databases, dashboards, or cloud integrations are **future work** and not part of the current deployment.
   - No details on **monitoring tools**, **logging**, or **automated recovery** are provided.
"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates horizontally via the **RabbitMQ message broker**, which facilitates **synchronized communication** between the **low-level driver**, **controller**, and **Digital Twin components** (Document 5, Section 2.2.1). The **interoperability standard** relies on **RabbitMQ’s open-source protocol**, enabling **on-premises or cloud deployment** (Document 5, Section 2.2.1). The **Digital Twin listens to messages** exchanged between the **controller and low-level driver**, allowing real-time data relay for visualization and adaptation (Document 5, Figure 7). No explicit **enterprise integration standards** (e.g., OPC UA, MQTT) or **external system dependencies** (e.g., ERP, SCADA) are documented. The system supports **co-simulation** for *what-if analysis* using historical or real-time PT data (Document 4, Section 5), but lacks details on **specific co-simulation tools** or **time-series database integrations**. The **Kalman filter** and **controller** rely on internal data flows without external library dependencies mentioned."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system for the incubator implements **safety-critical mechanisms** through the following technical measures:

1. **Safe Protocol in Low-Level Driver**: The low-level driver incorporates a **safe protocol** to ensure the Physical Twin (PT) remains in a safe operational state, including periodic validation of temperature data and controlled actuator commands.

2. **Bang-Bang Controller with Hard Limits**: The controller enforces **temperature bounds** via predefined parameters:
   - **LL (Lower Limit)**: Minimum acceptable temperature threshold to prevent overheating risks.
   - **UL (Upper Limit)**: Maximum acceptable temperature threshold to ensure safety.
   - **H (Heating Duration)**: Time-based control for the heatbed activation to avoid thermal overshoot.
   - **C (Cooling Duration)**: Mandatory waiting period post-heating to stabilize temperature and prevent unsafe conditions.

3. **Communication Safety**: The system uses **RabbitMQ**, an open-source message broker, to synchronize data between the controller and low-level driver. This ensures **real-time, fault-tolerant communication** with redundant state validation.

4. **Anomaly Detection via Non-Linear Least Squares Calibration**: The Digital Twin employs **Model B** (a 4-parameter thermal model) calibrated using a **non-linear least squares solver** to detect deviations in PT behavior, such as unexpected thermal inertia changes (e.g., due to external objects like a bucket of cold water). This calibration is triggered **on-demand** to maintain model accuracy.

5. **Fail-Safe Mechanisms**: The controller’s statechart (Figure 8) explicitly includes **safety checks** between heating and cooling phases to prevent thermal runaway. The system also supports **what-if simulations** to preemptively optimize controller parameters (e.g., LL, UL, H, C) before deployment.

**Note**: While the documents mention a **Kalman filter** for state estimation in future work (Section 5), it is not implemented in the current system. The current anomaly detection relies on **calibration-driven model validation** rather than real-time filtering."
]