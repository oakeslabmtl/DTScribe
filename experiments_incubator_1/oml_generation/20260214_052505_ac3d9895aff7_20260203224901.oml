]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second internal temperature sensor monitoring the insulated styrofoam box's internal environment with analog readings in °C, interfaced via Raspberry Pi GPIO or ADC module."
