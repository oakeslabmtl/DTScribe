// Component definitions
instance StyrofoamInsulationBox : DTDFVocab:Component [
    base:desc "Insulated Styrofoam box forming the thermal incubator enclosure."
]

instance HeatbedPad : DTDFVocab:Component [
    base:desc "Heatbed pad providing heating surface to the incubator contents."
]

instance AirCirculationFan : DTDFVocab:Component [
    base:desc "12/24 V fan for air circulation inside the incubator."
]

instance RaspberryPi4B : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B controller node driving actuators and data acquisition."
]

instance CustomPCBWithMOSFETs : DTDFVocab:Component [
    base:desc "Custom PCB containing MOSFETs and optocouplers for switching the heatbed and fan."
]

instance PowerSupply : DTDFVocab:Component [
    base:desc "Power supply delivering voltage and current to all actuators and sensors."
]

// Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET switch controlled by Raspberry Pi GPIO to turn the heatbed pad on/off."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET switch controlled by Raspberry Pi GPIO to turn the 12/24 V fan on/off."
]

// Sensing Components
instance TemperatureSensorInsideOne : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire thermometer (ID 0x28FF…1) inside the Styrofoam box for internal temperature measurement."
    DTDFVocab:producedData AMQPTemperatureMessage
]

instance TemperatureSensorInsideTwo : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire thermometer (ID 0x28FF…2) inside the Styrofoam box for internal temperature measurement."
    DTDFVocab:producedData AMQPTemperatureMessage
]

instance TemperatureSensorOutside : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire thermometer (ID 0x28FF…3) outside the box for ambient temperature measurement."
    DTDFVocab:producedData AMQPTemperatureMessage
]

// Physical-to-virtual data transmission
instance AMQPTemperatureMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorInsideOne, TemperatureSensorInsideTwo, TemperatureSensorOutside
]

// Raw data collected from messages
instance RawTemperatureData : DTDFVocab:Data [
    base:desc "Aggregated raw temperature readings from all DS18S20 sensors."
    DTDFVocab:fromData AMQPTemperatureMessage
    DTDFVocab:inputTo PythonScipyEnabler
]

// Thermal prediction models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Thermal model A, parameterized by ambient thermal capacitance C_air."
    DTDFVocab:inputTo PythonScipyEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Thermal model B, parameterized by C_air, G_box, G_heater, and C_heater."
    DTDFVocab:inputTo PythonScipyEnabler
]

// Enablers
instance PythonScipyEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime with SciPy for non‑linear least‑squares optimization of model parameters."
    DTDFVocab:enables CalibrationService, SimulationService
]

instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "Local RabbitMQ broker for AMQP message exchange between the Twin and hardware."
    DTDFVocab:enables SimulationService, MonitoringService, OptimizationService
]

// Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Real‑time temperature simulation using ThermalModelA and ThermalModelB."
    DTDFVocab:provides RealTimeTemperaturePredictionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration of thermal model parameters via non‑linear least‑squares optimization."
    DTDFVocab:provides CalibratedParametersInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitoring of temperature compliance against system constraints."
    DTDFVocab:provides TemperatureComplianceAlertInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization engine that determines optimal heating schedules and duty cycles."
    DTDFVocab:provides OptimalHeatingScheduleInsight, RecommendDutyCycleAction, RecommendHeatingScheduleAction
]

// Insights
instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "The calibrated model parameters (C_air, G_box, G_heater, C_heater)."
]

instance RealTimeTemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Current temperature prediction from thermal models."
]

instance TemperatureComplianceAlertInsight : DTDFVocab:Insight [
    base:desc "Alert when temperature constraints are violated."
]

instance OptimalHeatingScheduleInsight : DTDFVocab:Insight [
    base:desc "Recommended optimal heating schedule generated by the optimization engine."
]

// Actions
instance RecommendHeatingScheduleAction : DTDFVocab:Action [
    base:desc "Action to implement the recommended heating schedule."
    DTDFVocab:IsAutomatic true
]

instance RecommendDutyCycleAction : DTDFVocab:Action [
    base:desc "Action to implement the recommended duty cycle for the heatbed or fan."
    DTDFVocab:IsAutomatic true
]

// Environment
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:contains StyrofoamInsulationBox, HeatbedPad, AirCirculationFan, RaspberryPi4B,
                      CustomPCBWithMOSFETs, PowerSupply, TemperatureSensorInsideOne,
                      TemperatureSensorInsideTwo, TemperatureSensorOutside, HeatbedActuator,
                      FanActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin publishes control commands (e.g., heatbed on/off, fan on/off, heating and waiting durations) via RabbitMQ messages to the controller module on the Pi; the controller forwards these commands to the GPIO outputs that drive the MOSFETs, thereby actuating the physical twin."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of a local RabbitMQ AMQP broker, a low‑level driver module on the Pi, a Bang‑Bang controller module, and a simulation‑/optimization module; all components communicate over AMQP, with the Pi providing Wi‑Fi/Bluetooth network connectivity."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through assumptions of uniform temperature, negligible heat conduction to the box walls, constant air heat capacity, and ignoring fan heat; sensor accuracy is 0.5 °C between –10 °C and +85 °C; calibration reduces parameter uncertainty, and validation compares simulated trajectories to experimental data with a maximum discrepancy of less than 7 °C."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data flows from PT to DT via a 1‑Wire DS18S20 sensor bus attached to the Pi’s GPIO; commands flow from DT to PT through AMQP messages sent over RabbitMQ on the local network. The low‑level driver isolates GPIO outputs with optocouplers and drives MOSFETs to actuate the heater and fan."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All Digital Twin components run on the Raspberry Pi 4 Model B: the RabbitMQ broker, Python-based simulation, calibration, and control modules. The Pi provides Wi‑Fi and Bluetooth for network access, and can host a containerised deployment for the entire twin stack."
]