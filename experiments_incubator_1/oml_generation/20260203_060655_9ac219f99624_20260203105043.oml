namespace DTDFVocab = "http://example.org/DTDFVocab"
instance WheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for measuring wheel speed in the car's Physical Twin",
    DTDFVocab:producedData WheelSpeedDataTransmitted
]
instance EngineTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for measuring engine temperature in the car's Physical Twin",
    DTDFVocab:producedData EngineTemperatureDataTransmitted
]
instance ChassisVibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for measuring chassis vibration in the car's Physical Twin",
    DTDFVocab:producedData ChassisVibrationDataTransmitted
]
instance WheelSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedSensor
]
instance EngineTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EngineTemperatureSensor
]
instance ChassisVibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChassisVibrationSensor
]
instance WheelSpeedData : DTDFVocab:Data [
    base:desc "Wheel speed data collected from Physical Twin",
    DTDFVocab:fromData WheelSpeedDataTransmitted,
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringSystem
]
instance EngineTemperatureData : DTDFVocab:Data [
    base:desc "Engine temperature data collected from Physical Twin",
    DTDFVocab:fromData EngineTemperatureDataTransmitted,
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringSystem
]
instance ChassisVibrationData : DTDFVocab:Data [
    base:desc "Chassis vibration data collected from Physical Twin",
    DTDFVocab:fromData ChassisVibrationDataTransmitted,
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringSystem
]
instance CADModel : DTDFVocab:Model [
    base:desc "Geometric model for physical dimensions like wheel sizes and chassis shapes",
    DTDFVocab:inputTo CADSystem
]
instance DynamicModel : DTDFVocab:Model [
    base:desc "Dynamic model described by differential equations for system behavior",
    DTDFVocab:inputTo SimulationEngine
]
instance CADSystem : DTDFVocab:Enabler [
    base:desc "Computer-Aided Design system for geometric modeling",
    DTDFVocab:enables RealTimeMonitoringService
]
instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Differential equation-based simulation engine for dynamic analysis",
    DTDFVocab:enables PredictiveSimulationService
]
instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Calibration algorithm for parameter estimation",
    DTDFVocab:enables RealTimeMonitoringService, FaultDetectionService
]
instance MonitoringSystem : DTDFVocab:Enabler [
    base:desc "Monitoring system for performance validation",
    DTDFVocab:enables RealTimeMonitoringService
]
instance FaultDetectionAlgorithm : DTDFVocab:Enabler [
    base:desc "Fault detection algorithm for anomaly identification",
    DTDFVocab:enables FaultDetectionService
]
instance SupervisoryController : DTDFVocab:Enabler [
    base:desc "Supervisory controller for system management",
    DTDFVocab:enables RealTimeMonitoringService
]
instance StateEstimatorAlgorithm : DTDFVocab:Enabler [
    base:desc "State estimator algorithm for system state inference",
    DTDFVocab:enables StateEstimatorService
]
instance OptimizerAlgorithm : DTDFVocab:Enabler [
    base:desc "Optimizer algorithm for performance enhancement",
    DTDFVocab:enables OptimizationService
]
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring for safety and optimal performance using sensor data",
    DTDFVocab:provides SafetyViolationDetected, OptimizationViolationDetected, HumanInitiatedCorrectiveAction, AutomatedCorrectiveAction
]
instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation to model PT behavior under current conditions",
    DTDFVocab:provides PredictedSystemState
]
instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection algorithms for anomaly identification",
    DTDFVocab:provides FaultDetected
]
instance StateEstimatorService : DTDFVocab:Service [
    base:desc "State estimators for system state inference",
    DTDFVocab:provides SystemStateInference
]
instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization tools for performance enhancement",
    DTDFVocab:provides OptimalPerformanceConfiguration
]
instance SafetyViolationDetected : DTDFVocab:Insight [
    base:desc "Detection of safety violation during real-time monitoring"
]
instance OptimizationViolationDetected : DTDFVocab:Insight [
    base:desc "Detection of optimization violation during real-time monitoring"
]
instance FaultDetected : DTDFVocab:Insight [
    base:desc "Anomaly identified by fault detection algorithms"
]
instance SystemStateInference : DTDFVocab:Insight [
    base:desc "System state inferred by state estimators"
]
instance OptimalPerformanceConfiguration : DTDFVocab:Insight [
    base:desc "Optimal configuration for performance enhancement"
]
instance PredictedSystemState : DTDFVocab:Insight [
    base:desc "Predicted system state from simulation"
]
instance HumanInitiatedCorrectiveAction : DTDFVocab:Action [
    base:desc "Corrective action initiated by human operators in response to detected violations",
    DTDFVocab:IsAutomatic false
]
instance AutomatedCorrectiveAction : DTDFVocab:Action [
    base:desc "Corrective action initiated by automated algorithms in response to detected violations",
    DTDFVocab:IsAutomatic true
]
instance CarPhysicalTwin : DTDFVocab:SystemUnderStudy [
    base:desc "Car as the Physical Twin with mechanical components including wheels, chassis, and structural elements",
    DTDFVocab:hasEnvironment AutomotiveEnvironment
]
instance AutomotiveEnvironment : DTDFVocab:Environment [
    base:contains CarPhysicalTwin
]