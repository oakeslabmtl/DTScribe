// 1. Sensing Components
instance PTSensors : DTDFVocab:SensingComponent [
    base:desc "Suite of sensors deployed on the system capturing time-series measurements of physical quantities."
    DTDFVocab:producedData PTDataTransmitted
]

// 2. Data Transmitted
instance PTDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PTSensors
    base:desc "Time-series data stream transmitted from PT sensors and routed to the digital twin processing pipeline."
]

// 3. Raw Data
instance PTRawTimeSeriesData : DTDFVocab:Data [
    DTDFVocab:fromData PTDataTransmitted
    DTDFVocab:inputTo DataAcquisitionEnabler
    base:desc "Raw time-series data captured from physical sensors and streamed into the digital twin."
]

// 4. Models
instance GeometricCADModel : DTDFVocab:Model [
    DTDFVocab:inputTo ModelingEnabler
    base:desc "Static CAD representation of the Physical Twin."
]

instance DynamicSystemEquationsModel : DTDFVocab:Model [
    DTDFVocab:inputTo ModelingEnabler
    base:desc "Behavioral dynamic model defined by differential equations to simulate system behavior."
]

instance CyberPhysicalAnalyticalModel : DTDFVocab:Model [
    DTDFVocab:inputTo ModelingEnabler
    base:desc "Analytical model of the cyber‑physical landscape."
]

// 5. Enablers
instance DataAcquisitionEnabler : DTDFVocab:Enabler [
    base:desc "Data acquisition layer streams sensor outputs from the PT into a time‑series database."
    DTDFVocab:enables MonitoringService
]

instance ModelingEnabler : DTDFVocab:Enabler [
    base:desc "Modelling subsystem encapsulates physics‑based differential equations, empirical models, and agent‑based representations."
    DTDFVocab:enables OptimizationService, VisualizationService
]

instance AlgorithmicEnabler : DTDFVocab:Enabler [
    base:desc "Algorithmic layer includes calibration routines, fault‑detection logic, supervisory controllers, state estimation filters, and optimisation solvers."
    DTDFVocab:enables PredictiveService, ControlService
]

// 6. Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitoring service ingests time‑series sensor data and evaluates it against calibrated models via real‑time monitors to detect deviations from safety and optimal operating envelopes."
    DTDFVocab:provides SafetyDeviationInsight, PerformanceDeviationInsight, AlertOperatorAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service runs simulation‑based optimisation algorithms to identify parameter decisions that improve performance metrics."
    DTDFVocab:provides OptimizationInsight, OptimizationAction
]

instance PredictiveService : DTDFVocab:Service [
    base:desc "Predictive service uses state estimators and fault detectors to extrapolate future system states and anticipate faults."
    DTDFVocab:provides FaultPredictionInsight, FaultMitigationAction
]

instance ControlService : DTDFVocab:Service [
    base:desc "Control service provides supervisory control adjustments to regulate the Physical Twin or recommend manual interventions."
    DTDFVocab:provides StateEstimationInsight, StateEstimationAction, SupervisoryControlAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualization service presents simulation outputs, sensor streams, and diagnostic reports on dashboards for engineers and stakeholders."
    DTDFVocab:provides VisualizationInsight, VisualizationAction
]

// 7. Insights
instance SafetyDeviationInsight : DTDFVocab:Insight [
    base:desc "Identifies deviations from safety thresholds during real‑time monitoring."
]

instance PerformanceDeviationInsight : DTDFVocab:Insight [
    base:desc "Identifies deviations from performance thresholds during real‑time monitoring."
]

instance FaultPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicts future fault onset based on current state estimates."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Suggests parameter values that yield improved performance."
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Provides current system state estimate from sensor data."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Maps simulation outputs and sensor data into visual dashboards."
]

// 8. Actions
instance AlertOperatorAction : DTDFVocab:Action [
    base:desc "Alerts human operator upon safety or performance violations."
    DTDFVocab:IsAutomatic false
]

instance SupervisoryControlAction : DTDFVocab:Action [
    base:desc "Automatically adjusts Physical Twin to maintain safe operation."
    DTDFVocab:IsAutomatic true
]

instance FaultMitigationAction : DTDFVocab:Action [
    base:desc "Automatically initiates fault mitigation procedures when a fault is detected."
    DTDFVocab:IsAutomatic true
]

instance OptimizationAction : DTDFVocab:Action [
    base:desc "Applies optimized control parameters to enhance performance."
    DTDFVocab:IsAutomatic true
]

instance StateEstimationAction : DTDFVocab:Action [
    base:desc "Computes state estimate from sensor data to inform control."
    DTDFVocab:IsAutomatic true
]

instance VisualizationAction : DTDFVocab:Action [
    base:desc "Generates visual dashboards for engineers."
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin orchestrates data, models, and algorithms within a layered architecture. Data are ingested continuously from the Physical Twin via its sensors and stored in a time‑series repository. A calibration layer of algorithms iteratively updates the cyber and physical models, producing a calibrated model set that represents the CPS and its environment. Monitoring services consume the calibrated data to enforce safety and performance constraints. Violations trigger either automated corrective action or human intervention. The system manages resources by coordinating model updates, simulation cycles, and monitor executions, ensuring that data, computational models, and control logic are coherently integrated and deployed across the Digital Twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Development Phase: creation of abstract models (e.g., CAD representations of a car’s geometry and dynamic differential‑equation models of its motion). Representation Transition: conversion of these design‑time models into runtime models that incorporate streamed sensor data; calibration algorithms iteratively adjust model parameters to align simulated dynamics with measured physical behavior. Deployment Phase: launch of the Digital Twin framework alongside the Physical Twin, enabling real‑time monitoring and simulation. Transition Management: continuous calibration loops and parameter estimation embedded in the Digital Twin’s core engine. Governance: safety and performance monitors evaluate operational metrics; upon detection of violations, alerts trigger human review or automated corrective actions, thereby enforcing lifecycle control."
]