// C3: Physical sensing components
instance InsideIncubatorTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital temperature sensor (±0.5 °C accuracy) mounted inside the incubator box"
    DTDFVocab:producedData TempDataMessageInside1
]

instance InsideIncubatorTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital temperature sensor (±0.5 °C accuracy) mounted inside the incubator box"
    DTDFVocab:producedData TempDataMessageInside2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital temperature sensor (±0.5 °C accuracy) placed outside to measure room temperature"
    DTDFVocab:producedData TempDataMessageAmbient
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance TempDataMessageInside1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideIncubatorTempSensor1
]

instance TempDataMessageInside2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideIncubatorTempSensor2
]

instance TempDataMessageAmbient : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// C10: Data assets
instance TemperatureDataInside1 : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from InsideIncubatorTempSensor1"
    DTDFVocab:fromData TempDataMessageInside1
    DTDFVocab:inputTo EnablerRabbitMQ
]

instance TemperatureDataInside2 : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from InsideIncubatorTempSensor2"
    DTDFVocab:fromData TempDataMessageInside2
    DTDFVocab:inputTo EnablerRabbitMQ
]

instance TemperatureDataAmbient : DTDFVocab:Data [
    base:desc "Ambient temperature reading (°C) from AmbientTempSensor"
    DTDFVocab:fromData TempDataMessageAmbient
    DTDFVocab:inputTo EnablerRabbitMQ
]

instance ModelAParametersData : DTDFVocab:Data [
    base:desc "Calibrated parameters of Model A (C_air, G_box, etc.)"
    DTDFVocab:inputTo EnablerPythonSciPy, EnablerRaspberryPiController
]

instance ModelBParametersData : DTDFVocab:Data [
    base:desc "Calibrated parameters of Model B (C_air, G_box, C_heater, G_heater, etc.)"
    DTDFVocab:inputTo EnablerPythonSciPy, EnablerRaspberryPiController
]

// C11: Enablers (tooling and low‑level infrastructure)
instance EnablerRabbitMQ : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on Raspberry Pi for asynchronous PT‑to‑DT data streaming"
    DTDFVocab:enables ServiceRealTimeMonitoring, ServiceFaultDetection, ServiceTemperatureVisualization
]

instance EnablerPythonSciPy : DTDFVocab:Enabler [
    base:desc "Python SciPy non‑linear least‑squares optimizer used for calibrating thermal model parameters"
    DTDFVocab:enables ServiceParameterCalibration
]

instance EnablerRaspberryPiController : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 controller executing low‑level driver, publishing sensor data and receiving actuator commands"
    DTDFVocab:enables ServicePredictiveSimulationA, ServicePredictiveSimulationB, ServiceActuationControl
]

// C6: Services
instance ServiceRealTimeMonitoring : DTDFVocab:Service [
    base:desc "Provides real‑time temperature monitoring of incubator interior and ambient environment"
    DTDFVocab:provides InsightTemperatureWithinLimits
]

instance ServicePredictiveSimulationA : DTDFVocab:Service [
    base:desc "Runs Model A (single thermal capacitance C_air and conductance G_box) to predict air temperature"
    DTDFVocab:provides InsightPredictedTemperatureA
]

instance ServicePredictiveSimulationB : DTDFVocab:Service [
    base:desc "Runs Model B (adds heat‑bed capacitance C_heater and conductance G_heater) to predict air temperature"
    DTDFVocab:provides InsightPredictedTemperatureB
]

instance ServiceParameterCalibration : DTDFVocab:Service [
    base:desc "Calibrates Model A and Model B parameters against experimental temperature trajectories"
    DTDFVocab:provides InsightCalibratedParameters
]

instance ServiceFaultDetection : DTDFVocab:Service [
    base:desc "Monitors state‑chart for temperature limit violations and raises alerts"
    DTDFVocab:provides InsightLimitViolationDetected, ActionOperatorAlert
]

instance ServiceTemperatureVisualization : DTDFVocab:Service [
    base:desc "Visualises temperature trends for operator decision‑making"
    DTDFVocab:provides InsightTrendVisualization
]

instance ServiceActuationControl : DTDFVocab:Service [
    base:desc "Issues commands to heat‑bed and fan via MOSFET switches on custom PCB"
    DTDFVocab:provides ActionSetPointAdjustment, ActionCorrectiveAction
]

// C17: Insights
instance InsightTemperatureWithinLimits : DTDFVocab:Insight [
    base:desc "Operator can verify that interior temperature stays within defined lower and upper limits using calibrated model parameters and real‑time trends"
]

instance InsightPredictedTemperatureA : DTDFVocab:Insight [
    base:desc "Model A predicts incubator air temperature based on current conditions"
]

instance InsightPredictedTemperatureB : DTDFVocab:Insight [
    base:desc "Model B predicts incubator air temperature including heat‑bed dynamics"
]

instance InsightCalibratedParameters : DTDFVocab:Insight [
    base:desc "Calibration outcomes provide updated model parameters for future set‑point selection"
]

instance InsightLimitViolationDetected : DTDFVocab:Insight [
    base:desc "State‑chart monitor detects temperature limit violation and generates an alert"
]

instance InsightTrendVisualization : DTDFVocab:Insight [
    base:desc "Visualization of temperature trajectories enables operator to assess performance"
]

// C17: Actions
instance ActionOperatorAlert : DTDFVocab:Action [
    base:desc "Alert sent to operator when a temperature limit violation is detected"
    DTDFVocab:IsAutomatic false
]

instance ActionSetPointAdjustment : DTDFVocab:Action [
    base:desc "Operator decides on set‑point adjustments based on DT insights"
    DTDFVocab:IsAutomatic false
]

instance ActionCorrectiveAction : DTDFVocab:Action [
    base:desc "Operator initiates corrective actions (e.g., increase heating) after alert"
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance ModelA : DTDFVocab:Model [
    base:desc "Physics‑based thermal Model A with single capacitance C_air and conductance G_box (four calibrated parameters)"
    DTDFVocab:inputTo EnablerPythonSciPy, EnablerRaspberryPiController
]

instance ModelB : DTDFVocab:Model [
    base:desc "Physics‑based thermal Model B adding heat‑bed capacitance C_heater and conductance G_heater (four calibrated parameters plus heat‑bed dynamics)"
    DTDFVocab:inputTo EnablerPythonSciPy, EnablerRaspberryPiController
]

// C2: Acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heater (heat‑bed) driven through MOSFET switch on custom PCB under Raspberry Pi commands"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Low‑speed fan for air circulation driven through MOSFET switch on custom PCB under Raspberry Pi commands"
]

// C5: Physical components
instance CustomPCB : DTDFVocab:Component [
    base:desc "Custom printed‑circuit board with MOSFET switches and optocouplers for safe actuation"
]

instance PowerSupply : DTDFVocab:Component [
    base:desc "12 V/24 V power supply for heater and fan"
]

instance InsulatedBox : DTDFVocab:Component [
    base:desc "Styrofoam insulated box (≈0.03 m³ volume) housing the incubator environment"
]

// C9: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InsideIncubatorTempSensor1, InsideIncubatorTempSensor2, AmbientTempSensor,
                HeatBedActuator, FanActuator, CustomPCB, PowerSupply, InsulatedBox
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT components send control commands (heat‑bed on/off, fan on/off) as RabbitMQ messages which are consumed by the low‑level driver and forwarded to the MOSFET drivers on the PCB to actuate the physical devices."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture comprises a controller running on the Raspberry Pi, a low‑level driver that interfaces with sensors and actuators, a RabbitMQ communication server that mediates message exchange, and DT service modules that subscribe to sensor streams, run the calibrated thermal models, and publish control commands; all components are co‑located on the Raspberry Pi platform."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is based on four key assumptions (uniform air temperature, negligible wall heat storage, constant air specific heat, and either full power conversion to air heat or inclusion of heat‑bed dynamics). Uniformity was experimentally verified by comparing temperatures at three locations with the fan on; calibration residuals were minimised using non‑linear least‑squares to ensure validity of the parameter estimates."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "PT‑DT communication uses the AMQP protocol implemented by RabbitMQ running locally on the Raspberry Pi; messages are exchanged over the Pi’s built‑in Wi‑Fi or Ethernet interfaces, and the low‑level driver enforces a safe‑state protocol before applying commands to the MOSFET drivers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components (controller, driver, RabbitMQ broker, model execution) are hosted on the Raspberry Pi 4 Model B itself, providing an on‑edge deployment; the complete hardware schematics, firmware and software source code are publicly available in a GitHub repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe‑protocol that forces the PT into a safe state on communication loss; electrical isolation between the Raspberry Pi and the high‑current MOSFET switches is achieved with optocouplers, reducing risk of accidental over‑current or unintended actuation."
]