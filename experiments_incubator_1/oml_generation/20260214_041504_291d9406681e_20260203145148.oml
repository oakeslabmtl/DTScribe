// C3: Physical sensing components
instance AccelerometerSensor : DTDFVocab:SensingComponent [
    base:desc "Accelerometer embedded in the vehicle chassis to capture dynamic acceleration for calibration and simulation"
    DTDFVocab:producedData AccDataTransmitted
]
instance GyroscopeSensor : DTDFVocab:SensingComponent [
    base:desc "Gyroscope embedded in the vehicle chassis to capture rotational dynamics"
    DTDFVocab:producedData GyroDataTransmitted
]
instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Torque sensor measuring drivetrain torque used for dynamic model calibration"
    DTDFVocab:producedData TorqueDataTransmitted
]

// C4: DataTransmitted
instance AccDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AccelerometerSensor
]
instance GyroDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GyroscopeSensor
]
instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
]

// C5: Data
instance AccTimeStampedData : DTDFVocab:Data [
    base:desc "Time‑stamped acceleration stream from AccelerometerSensor"
    DTDFVocab:fromData AccDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, ModelUpdateEnabler
]
instance GyroTimeStampedData : DTDFVocab:Data [
    base:desc "Time‑stamped gyroscope stream from GyroscopeSensor"
    DTDFVocab:fromData GyroDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, ModelUpdateEnabler
]
instance TorqueTimeStampedData : DTDFVocab:Data [
    base:desc "Time‑stamped torque stream from TorqueSensor"
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, ModelUpdateEnabler
]

// C10: Models
instance GeometricCADModel : DTDFVocab:Model [
    base:desc "Parametric solid model derived from CAD, containing wheel diameter, chassis shape, and styling attributes"
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, ModelUpdateEnabler
]
instance BehavioralDynamicModel : DTDFVocab:Model [
    base:desc "Differential equation model capturing vehicle dynamics as per reference [3]"
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, ModelUpdateEnabler
]
instance AnalyticalForceDistanceModel : DTDFVocab:Model [
    base:desc "Static force–distance tables encoded as analytical relationships"
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, ModelUpdateEnabler
]

// C17: Insights
instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time diagnostics monitoring vehicle performance and safety constraints"
]
instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Predictive simulation insight forecasting future states of vehicle dynamics"
]
instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Calibration insight reflecting parameter adjustments to maintain model fidelity"
]
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Fault detection insight identifying anomalies in sensor data or model outputs"
]
instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization insight for performance and energy efficiency"
]

// C17: Actions
instance AdjustParametersAction : DTDFVocab:Action [
    base:desc "Automatically adjust operating parameters based on supervisory control decisions"
    DTDFVocab:IsAutomatic true
]
instance FaultShutdownAction : DTDFVocab:Action [
    base:desc "Trigger immediate vehicle shutdown upon critical fault detection"
    DTDFVocab:IsAutomatic true
]

// C11: Enablers
instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "High‑throughput calibration algorithm reconciling simulation outputs with real measurements"
    DTDFVocab:enables CalibrationService
]
instance ModelUpdateEnabler : DTDFVocab:Enabler [
    base:desc "Model update enabler applying calibrated parameters to dynamic models"
    DTDFVocab:enables PredictiveSimulationService
]
instance MonitoringAgentEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring agent evaluating safety and performance constraints in real time"
    DTDFVocab:enables RealTimeMonitoringService
]
instance DecisionLogicEnabler : DTDFVocab:Enabler [
    base:desc "Decision‑logic component determining supervisory controls for vehicle operation"
    DTDFVocab:enables SupervisoryControlService
]
instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Fault‑detection component identifying anomalies in the vehicle's operation"
    DTDFVocab:enables FaultDetectionService
]
instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimization module executing performance optimization algorithms"
    DTDFVocab:enables OptimizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of the vehicle's physical twin through continuous sensor data acquisition"
    DTDFVocab:provides MonitoringInsight
]
instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Pipeline executing dynamic model simulations to forecast future vehicle states"
    DTDFVocab:provides SimulationInsight
]
instance CalibrationService : DTDFVocab:Service [
    base:desc "Supervisory service calibrating model parameters via iterative algorithms"
    DTDFVocab:provides CalibrationInsight
]
instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Supervisory control service applying safety and performance optimizations to vehicle operation"
    DTDFVocab:provides AdjustParametersAction
]
instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection service generating diagnostic insights and potential shutdown actions"
    DTDFVocab:provides FaultDetectionInsight, FaultShutdownAction
]
instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service delivering performance enhancements adhering to plant operator requirements"
    DTDFVocab:provides OptimizationInsight
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin system is orchestrated through a modular architecture that integrates a data ingestion layer (sensor streams from the physical twin), a model calibration module that applies calibration algorithms to update computational models, a monitoring module that uses fault detectors, supervisory controllers, and state estimators to assess safety and performance, and an optimization engine that generates actionable data for the physical twin. These components are coordinated via a central orchestration service that manages resource allocation, synchronizes model updates, and ensures consistency across the digital representation, forming the overall constellation of the DT."
]