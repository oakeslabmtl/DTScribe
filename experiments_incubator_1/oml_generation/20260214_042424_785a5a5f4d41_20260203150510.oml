// C3: Physical sensing components
instance PhysicalTwinSensorNetwork : DTDFVocab:SensingComponent [
    base:desc "Network of sensors that gather data streams from the physical twin."
    DTDFVocab:producedData VehicleSensorDataFeed
]

// C4: Physical-to-virtual interaction
instance VehicleSensorDataFeed : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalTwinSensorNetwork
]

// C10: Models/Data
instance VehicleSensorData : DTDFVocab:Data [
    base:desc "Real‑time time‑series data collected from the physical twin sensors."
    DTDFVocab:fromData VehicleSensorDataFeed
    DTDFVocab:inputTo CalibrationAlgorithm, FaultDetector, SupervisoryController, StateEstimator, Optimiser
]

instance CADModel : DTDFVocab:Model [
    base:desc "Geometric CAD model encoding structural attributes such as wheel dimensions and chassis shape."
    DTDFVocab:inputTo CalibrationAlgorithm, FaultDetector, SupervisoryController, StateEstimator, Optimiser
]

instance DynamicModel : DTDFVocab:Model [
    base:desc "Behavioral dynamic model expressed by system of differential equations representing car motion."
    DTDFVocab:inputTo CalibrationAlgorithm, FaultDetector, SupervisoryController, StateEstimator, Optimiser
]

instance AnalyticalModel : DTDFVocab:Model [
    base:desc "Auxiliary analytical model representing additional physical processes."
    DTDFVocab:inputTo CalibrationAlgorithm, FaultDetector, SupervisoryController, StateEstimator, Optimiser
]

// C11: Enablers
instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that processes incoming sensor data to update model parameters with best‑estimate values."
    DTDFVocab:enables SimulationService
]

instance FaultDetector : DTDFVocab:Enabler [
    base:desc "Fault detector that analyzes sensor streams for anomalies by comparing simulated states against real sensor data."
    DTDFVocab:enables FaultDetectionService
]

instance SupervisoryController : DTDFVocab:Enabler [
    base:desc "Supervisory controller that imposes safety constraints based on model predictions."
    DTDFVocab:enables SupervisoryControlService
]

instance StateEstimator : DTDFVocab:Enabler [
    base:desc "State estimator that infers unmeasured states from sensor data."
    DTDFVocab:enables StateEstimationService
]

instance Optimiser : DTDFVocab:Enabler [
    base:desc "Optimiser that computes operating points to improve performance, using model predictions and sensor data."
    DTDFVocab:enables OptimisationService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service that provides reproduction and prediction of the physical twin's behavior under current operating conditions."
    DTDFVocab:provides PerformanceMetricInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring service that verifies safe and optimal performance."
    DTDFVocab:provides PerformanceMetricInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection service that generates alerts when anomalies are detected."
    DTDFVocab:provides AnomalyInsight, AdjustPhysicalTwinAction
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Supervisory control service that enforces safety constraints and triggers corrective actions."
    DTDFVocab:provides ViolationInsight, TriggerAlarmAction
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "State estimation service that infers unmeasured states from data."
    DTDFVocab:provides StateEstimationInsight
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Optimisation service that calculates optimal operating points to improve performance."
    DTDFVocab:provides OptimalOperatingPointInsight, OptimizeFuelEfficiencyAction
]

// C17: Insights
instance AnomalyInsight : DTDFVocab:Insight [
    base:desc "Indicates that an anomaly has been detected in the physical twin's sensor streams."
]

instance ViolationInsight : DTDFVocab:Insight [
    base:desc "Indicates that a safety constraint violation has been detected based on model predictions."
]

instance PerformanceMetricInsight : DTDFVocab:Insight [
    base:desc "Provides real‑time performance metrics compared against simulated states."
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Insight providing the inferred unmeasured states derived from sensor data."
]

instance OptimalOperatingPointInsight : DTDFVocab:Insight [
    base:desc "Identifies optimal operating points to improve performance as calculated by the optimiser."
]

// C17: Actions
instance AdjustPhysicalTwinAction : DTDFVocab:Action [
    base:desc "Action to adjust physical twin parameters based on fault detection recommendations."
    DTDFVocab:IsAutomatic false
]

instance TriggerAlarmAction : DTDFVocab:Action [
    base:desc "Action to trigger an alarm when a safety violation is detected."
    DTDFVocab:IsAutomatic false
]

instance OptimizeFuelEfficiencyAction : DTDFVocab:Action [
    base:desc "Action to adjust operating conditions to optimize fuel efficiency as suggested by the optimiser."
    DTDFVocab:IsAutomatic false
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Lifecycle stages include: 1) Conceptual modelling of system aspects such as geometry (CAD) and physics (differential equations); 2) Concrete modelling of cyber‑physical interactions and environment dynamics; 3) Integration of models and time‑series data acquired from PT sensors into a Digital Twin framework; 4) Calibration, where algorithms update model parameters to reconcile the DT with PT; 5) Monitoring, where DT‑hosted monitors assess safety and performance and detect violations; 6) Optimization/control, where fault detectors, supervisory controllers, state estimators, or optimisers generate decision data; 7) Evolution, where detected violations trigger human or algorithmic modifications to the PT and corresponding updates to the DT; governance hinges on continuous feedback loops and parameter re‑calibration, but formal lifecycle governance is not explicitly described."
]