// Sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor attached to the physical twin, measuring ambient temperature for real‑time monitoring."
    DTDFVocab:producedData TemperatureStream
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Pressure sensor attached to the physical twin, measuring system pressure during operation."
    DTDFVocab:producedData PressureStream
]

// Data transmitted from sensors
instance TemperatureStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

// Data collected from transmitted streams
instance TemperatureData : DTDFVocab:Data [
    base:desc "Time‑series temperature data collected during normal operation."
    DTDFVocab:fromData TemperatureStream
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

instance PressureData : DTDFVocab:Data [
    base:desc "Time‑series pressure data collected during normal operation."
    DTDFVocab:fromData PressureStream
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

// Computational model
instance ThermalModel : DTDFVocab:Model [
    base:desc "Computational thermal model incorporating geometric, behavioral, and analytical knowledge about the physical twin's structure and dynamics."
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

// Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that continually adjusts the ThermalModel parameters based on incoming temperature and pressure data to align with observed behavior."
    DTDFVocab:enables CalibrationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring module that evaluates thermal performance, identifies deviations from expected behavior, and informs fault detectors and supervisory controllers."
    DTDFVocab:enables MonitoringService, FaultDetectionService, SupervisoryControlService
]

// Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that applies updated model parameters and generates calibration insights."
    DTDFVocab:provides CalibrationInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors performance against safety and optimality thresholds."
    DTDFVocab:provides PerformanceInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service that detects deviations from expected thermal behavior and raises fault alerts."
    DTDFVocab:provides FaultInsight
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Service that triggers automatic supervisory actions or forwards decisions to human operators."
    DTDFVocab:provides AdjustControlAction
]

// Insights
instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating current calibration status and required parameter adjustments."
]

instance PerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight evaluating current thermal performance against safety thresholds."
]

instance FaultInsight : DTDFVocab:Insight [
    base:desc "Insight identifying a fault due to deviation from expected behavior."
]

// Actions
instance AdjustControlAction : DTDFVocab:Action [
    base:desc "Automatic supervisory control adjustment to bring the physical twin back to safe operating conditions."
    DTDFVocab:IsAutomatic true
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by ongoing calibration against real‑time sensor data; validation relies on the DT’s monitoring components that compare model predictions with actual PT measurements, flagging deviations that exceed safety or performance thresholds. Although the document does not specify quantitative verification metrics or formal uncertainty quantification, it implies that error detection occurs through violation detection in monitors, with corrective actions taken either automatically by algorithms or by human operators. Quality assurance is therefore achieved through this continuous observation–correction cycle, ensuring that models remain accurate and trustworthy over the PT’s lifecycle."
]