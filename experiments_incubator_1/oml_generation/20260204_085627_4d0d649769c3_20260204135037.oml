// C3: Physical Sensing Components
instance ForceSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded sensor capturing real-time force data from the Physical Twin for dynamic behavior analysis and fault detection"
    DTDFVocab:producedData ForceSensorData
]

instance MotionTracker : DTDFVocab:SensingComponent [
    base:desc "IoT device tracking displacement, velocity, and acceleration of physical components in real-time for behavioral modeling"
    DTDFVocab:producedData MotionTrackerData
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor measuring thermal conditions affecting system performance and material properties"
    DTDFVocab:producedData TemperatureSensorData
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency sensor detecting mechanical vibrations for structural health monitoring and fault detection"
    DTDFVocab:producedData VibrationSensorData
]

instance EnvironmentalConditionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor suite capturing external environmental factors (pressure, humidity, wind) impacting system behavior"
    DTDFVocab:producedData EnvironmentalConditionData
]

// C4: Physical-to-Virtual Interaction
instance ForceSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ForceSensor
]

instance MotionTrackerData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionTracker
]

instance TemperatureSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance VibrationSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
]

instance EnvironmentalConditionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalConditionSensor
]

instance SensorDataStream : DTDFVocab:Data [
    base:desc "Aggregated time-series data stream combining all sensor inputs for unified processing"
    DTDFVocab:fromData ForceSensorData, MotionTrackerData, TemperatureSensorData, VibrationSensorData, EnvironmentalConditionData
]

// C10: Models/Data
instance GeometricModel : DTDFVocab:Model [
    base:desc "CAD-based geometric representation of physical components (e.g., chassis, wheels) for structural analysis"
    DTDFVocab:inputTo CADSystem
]

instance DynamicBehaviorModel : DTDFVocab:Model [
    base:desc "Differential equation-based simulation modeling forces, movement, and system interactions under operational conditions"
    DTDFVocab:inputTo SimulationEngine, StateEstimationAlgorithm
]

instance AnalyticalModel : DTDFVocab:Model [
    base:desc "State-space representation and control-theoretic model describing Cyber-Physical System behavior and environmental interactions"
    DTDFVocab:inputTo ControlAlgorithm
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Current operational state data from embedded sensors capturing real-world system health metrics"
    DTDFVocab:fromData SensorDataStream
    DTDFVocab:inputTo DataPreprocessing, ModelCalibration
]

instance HistoricalPerformanceData : DTDFVocab:Data [
    base:desc "Archived operational logs, maintenance records, and performance benchmarks for trend analysis and predictive maintenance"
    DTDFVocab:inputTo ValidationTool
]

instance CalibratedModelParameters : DTDFVocab:Data [
    base:desc "Dynamic model parameters continuously updated via calibration algorithms to align DT with real-world behavior"
    DTDFVocab:fromData ModelCalibrationOutput
    DTDFVocab:inputTo SimulationEngine, ControlAlgorithm
]

// C11: Enablers
instance CADSystem : DTDFVocab:Enabler [
    base:desc "Computer-Aided Design system (e.g., AutoCAD, SolidWorks) for creating and managing geometric models of physical components"
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Physics-based simulation environment (e.g., MATLAB/Simulink, ANSYS) executing dynamic and analytical models"
    DTDFVocab:enables BehaviorSimulation
]

instance ControlAlgorithm : DTDFVocab:Enabler [
    base:desc "Supervisory control system implementing adaptive decision-making and fault recovery protocols"
    DTDFVocab:enables SupervisoryControl
]

instance OptimizationSolver : DTDFVocab:Enabler [
    base:desc "Mathematical optimization framework (e.g., genetic algorithms, interior-point methods) for parameter tuning and resource allocation"
    DTDFVocab:enables PerformanceOptimization
]

instance StateEstimationAlgorithm : DTDFVocab:Enabler [
    base:desc "Kalman filter or particle filter implementation for reconstructing system states from noisy sensor data"
    DTDFVocab:enables StateReconstruction
]

instance DataPreprocessing : DTDFVocab:Enabler [
    base:desc "Real-time data pipeline performing filtering, outlier detection, and normalization on sensor inputs"
    DTDFVocab:enables DataQualityAssurance
]

instance ModelIntegrationFramework : DTDFVocab:Enabler [
    base:desc "Digital Twin platform (e.g., Siemens MindSphere) unifying geometric, dynamic, and analytical models with sensor data"
    DTDFVocab:enables ModelCoupling
]

instance ModelCalibration : DTDFVocab:Enabler [
    base:desc "Parameter estimation system using recursive least squares or Bayesian updating to adjust DT models with real-time data"
    DTDFVocab:enables ModelAccuracyImprovement
]

instance DataStorage : DTDFVocab:Enabler [
    base:desc "Time-series database (e.g., InfluxDB) storing historical and real-time sensor data for analysis and validation"
    DTDFVocab:enables DataPersistence
]

instance VisualizationTool : DTDFVocab:Enabler [
    base:desc "3D visualization platform (e.g., Unity, Siemens Xcelerator) enabling immersive interaction with DT models and simulations"
    DTDFVocab:enables ModelVisualization
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous performance tracking service using sensor data to validate system health and operational boundaries"
    DTDFVocab:provides OperationalHealthInsight, SafetyViolationAlert
]

instance PredictiveAnalysisService : DTDFVocab:Service [
    base:desc "Forecasting service simulating future system behavior under current or modified conditions"
    DTDFVocab:provides FailurePredictionInsight, PerformanceTrendInsight
]

instance ScenarioTestingService : DTDFVocab:Service [
    base:desc "Hypothetical scenario evaluation service testing design modifications or environmental changes"
    DTDFVocab:provides ImpactAssessmentInsight, DesignRecommendation
]

instance PerformanceOptimizationService : DTDFVocab:Service [
    base:desc "Parameter tuning and resource allocation service improving system efficiency and safety"
    DTDFVocab:provides OptimizationRecommendation, ResourceAllocationInsight
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Automated decision-making service enabling real-time adjustments to system parameters"
    DTDFVocab:provides ControlAdjustmentAction, FaultRecoveryAction
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Continuous model refinement service maintaining alignment between DT and Physical Twin"
    DTDFVocab:provides ModelAccuracyImprovementInsight
]

// C17: Insights/Actions
instance OperationalHealthInsight : DTDFVocab:Insight [
    base:desc "Continuous assessment of system degradation or wear based on real-time sensor data"
]

instance SafetyViolationAlert : DTDFVocab:Insight [
    base:desc "Notification of detected deviations from safe operational boundaries requiring immediate attention"
]

instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive analysis identifying potential failure modes and their likelihood under current conditions"
]

instance PerformanceTrendInsight : DTDFVocab:Insight [
    base:desc "Analysis of historical performance data showing system efficiency degradation or improvement trends"
]

instance ImpactAssessmentInsight : DTDFVocab:Insight [
    base:desc "Evaluation of hypothetical scenario impacts on system behavior and performance metrics"
]

instance DesignRecommendation : DTDFVocab:Insight [
    base:desc "Suggested modifications to system design based on simulation results and performance analysis"
]

instance OptimizationRecommendation : DTDFVocab:Insight [
    base:desc "Parameter adjustments or operational changes improving system efficiency and safety"
]

instance ResourceAllocationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for optimal distribution of system resources based on current operational conditions"
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated adjustment of system control parameters based on DT-generated insights"
    DTDFVocab:IsAutomatic true
]

instance FaultRecoveryAction : DTDFVocab:Action [
    base:desc "Automated fault recovery protocol triggered by detected system anomalies"
    DTDFVocab:IsAutomatic true
]

instance ParameterUpdateAction : DTDFVocab:Action [
    base:desc "Dynamic adjustment of model parameters to maintain DT accuracy through calibration algorithms"
    DTDFVocab:IsAutomatic true
]

instance HumanInTheLoopAction : DTDFVocab:Action [
    base:desc "Manual intervention opportunity for engineers to validate or override automated DT recommendations"
    DTDFVocab:IsAutomatic false
]

// C12: Environment
instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:desc "Operational domain encompassing physical components, cyber systems, and environmental interactions"
    base:contains PhysicalComponents, CyberComponents, EnvironmentalConditions
]

instance PhysicalComponents : DTDFVocab:Component [
    base:desc "Mechanical elements (e.g., chassis, wheels) with geometric and structural properties modeled in the DT"
    base:isContainedIn PhysicalTwinEnvironment
]

instance CyberComponents : DTDFVocab:Component [
    base:desc "Sensor networks, control systems, and data processing units enabling real-time monitoring and control"
    base:isContainedIn PhysicalTwinEnvironment
]

instance EnvironmentalConditions : DTDFVocab:Component [
    base:desc "External factors (temperature, pressure, humidity) affecting system behavior and performance"
    base:isContainedIn PhysicalTwinEnvironment
]

// Additional required instances for relationships
instance ModelCalibrationOutput : DTDFVocab:Data [
    base:desc "Output data from model calibration process containing updated model parameters"
]

instance UnifiedSimulation : DTDFVocab:Service [
