// ==================== Sensing Components ====================
// Internal temperature sensor A
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer mounted inside the enclosure at corner A range -55 °C to +125 °C accuracy ±0.5 °C"
    DTDFVocab:producedData InternalTempDataTransmittedA
]

// Internal temperature sensor B
instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer mounted inside the enclosure at corner B range -55 °C to +125 °C accuracy ±0.5 °C"
    DTDFVocab:producedData InternalTempDataTransmittedB
]

// External temperature sensor
instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer mounted on the exterior wall to monitor ambient conditions range -55 °C to +125 °C accuracy ±0.5 °C"
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// ==================== Data Transmitted ====================
// Data transmitted from internal sensor A
instance InternalTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

// Data transmitted from internal sensor B
instance InternalTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

// Data transmitted from external sensor
instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// ==================== Data Instances ====================
// Temperature data from internal sensor A
instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from internal sensor A streamed at 1 Hz via 1‑Wire"
    DTDFVocab:fromData InternalTempDataTransmittedA
    DTDFVocab:inputTo RabbitMQBroker, InfluxDBStorage, CalibrationAlgorithm, MonitoringAlgorithm
]

// Temperature data from internal sensor B
instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from internal sensor B streamed at 1 Hz via 1‑Wire"
    DTDFVocab:fromData InternalTempDataTransmittedB
    DTDFVocab:inputTo RabbitMQBroker, InfluxDBStorage, CalibrationAlgorithm, MonitoringAlgorithm
]

// Temperature data from external sensor
instance ExternalTempData : DTDFVocab:Data [
    base:desc "Time‑stamped ambient temperature reading from external sensor streamed at 1 Hz via 1‑Wire"
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker, InfluxDBStorage, CalibrationAlgorithm, MonitoringAlgorithm
]

// ==================== Enablers ====================
// Message broker for reliable streaming
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "AMQP RabbitMQ broker running on the Raspberry Pi, handles reliable sensor data streaming and command delivery"
    DTDFVocab:enables SimulationBasedPredictionService, RealTimeMonitoringService, CalibrationService, FaultDetectionService, OptimisationService, SupervisoryControlService
]

// Time‑series storage
instance InfluxDBStorage : DTDFVocab:Enabler [
    base:desc "InfluxDB instance storing time‑stamped temperature readings for historic analysis and dashboarding"
    DTDFVocab:enables RealTimeMonitoringService, CalibrationService, OptimisationService
]

// Calibration algorithm
instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "SciPy least‑squares calibration algorithm that adjusts thermal model parameters using the latest sensor data"
    DTDFVocab:enables CalibrationService
]

// Monitoring algorithm
instance MonitoringAlgorithm : DTDFVocab:Enabler [
    base:desc "Real‑time safety and performance monitor evaluating calibrated model outputs against defined thresholds"
    DTDFVocab:enables RealTimeMonitoringService, FaultDetectionService
]

// Optimisation algorithm
instance OptimisationAlgorithm : DTDFVocab:Enabler [
    base:desc "SciPy differential‑evolution optimiser generating optimal heat‑bed PWM set‑points and fan speeds"
    DTDFVocab:enables OptimisationService, SupervisoryControlService
]

// Simulation engine
instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Python NumPy‑based thermal simulation reproducing incubator dynamics under current operating conditions"
    DTDFVocab:enables SimulationBasedPredictionService
]

// Control interface (GPIO/MOSFET driver)
instance ControlInterface : DTDFVocab:Enabler [
    base:desc "GPIO‑driven MOSFET drivers on the controller board that command the heat‑bed and fan"
    DTDFVocab:enables SupervisoryControlService
]

// ==================== Models ====================
// Cyber‑physical thermal model
instance ThermalModel : DTDFVocab:Model [
    base:desc "Thermal physics model of the insulated chamber, heat‑bed, and forced‑air fan"
    DTDFVocab:inputTo SimulationEngine, CalibrationAlgorithm, MonitoringAlgorithm, OptimisationAlgorithm
]

// Laboratory environment model
instance AmbientEnvironmentModel : DTDFVocab:Model [
    base:desc "Model of laboratory ambient temperature influencing heat transfer to the incubator"
    DTDFVocab:inputTo SimulationEngine, MonitoringAlgorithm
]

// ==================== Services ====================
// Simulation‑based prediction service
instance SimulationBasedPredictionService : DTDFVocab:Service [
    base:desc "Generates forecast of incubator temperature using the calibrated thermal model"
    DTDFVocab:provides FutureTemperatureInsight
]

// Real‑time monitoring service
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuously assesses safety margins and performance optimality of the incubator"
    DTDFVocab:provides SafetyAlertInsight, PerformanceStabilityInsight
]

// Calibration service
instance CalibrationService : DTDFVocab:Service [
    base:desc "Updates model parameters by ingesting the latest sensor data"
    DTDFVocab:provides CalibrationQualityInsight
]

// Fault detection service
instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects anomalies in temperature readings or communication loss"
    DTDFVocab:provides FaultAlertInsight
]

// Optimisation service
instance OptimisationService : DTDFVocab:Service [
    base:desc "Computes optimal set‑points for heat‑bed power and fan speed to maintain stability"
    DTDFVocab:provides OptimizationRecommendationAction
]

// Supervisory control service
instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Issues control commands to actuators based on insights and optimisation results"
    DTDFVocab:provides AdjustSetPointAction
]

// ==================== Insights ====================
// Future temperature insight
instance FutureTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted future temperature trajectory generated by the simulation‑based prediction service"
]

// Safety alert insight
instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Alert raised when temperature exceeds safety limit (e.g., 80 °C) or sensor feedback is missing/out of range"
]

// Performance stability insight
instance PerformanceStabilityInsight : DTDFVocab:Insight [
    base:desc "Indicates that incubator temperature is within ±0.5 °C of the set‑point over the last monitoring interval"
]

// Calibration quality insight
instance CalibrationQualityInsight : DTDFVocab:Insight [
    base:desc "Reports goodness‑of‑fit metrics for the latest model calibration"
]

// Fault alert insight
instance FaultAlertInsight : DTDFVocab:Insight [
    base:desc "Identifies sensor anomalies such as stuck readings or communication failures"
]

// ==================== Actions ====================
// Optimisation recommendation action
instance OptimizationRecommendationAction : DTDFVocab:Action [
    base:desc "Suggested adjustment of heat‑bed PWM duty cycle and fan speed to improve temperature stability"
    DTDFVocab:IsAutomatic false
]

// Adjust set‑point action
instance AdjustSetPointAction : DTDFVocab:Action [
    base:desc "Command sent to the heat‑bed MOSFET driver to change the PWM set‑point"
    DTDFVocab:IsAutomatic true
]

// ==================== Acting Components ====================
// Heat‑bed actuator
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed powered from 12 V, PWM‑controlled via MOSFET driver on the controller PCB"
]

// Fan actuator
instance AirFanActuator : DTDFVocab:ActingComponent [
    base:desc "DC fan driven by MOSFET switch, variable speed to distribute heat uniformly"
]

// ==================== Environment ====================
instance LabIncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, AirFanActuator, InternalTempSensorA, InternalTempSensorB, ExternalTempSensor
]

// ==================== Component Definitions ====================
instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 running Linux, hosts Python acquisition scripts, RabbitMQ broker, InfluxDB, and DT services"
]

instance ControllerBoard : DTDFVocab:Component [
    base:desc "Microcontroller board with GPIO lines for sensors, heat‑bed MOSFET driver, and fan driver"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin sends actuation commands to the physical incubator by publishing messages to the RabbitMQ server on the Raspberry Pi. The controller on the Raspberry Pi listens to these messages and drives the fan and the heatbed accordingly. The heatbed is switched using MOSFETs and optocouplers capable of handling the required 4 A current. Command execution is reflected back through updated temperature sensor readings that are sent back to the digital twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by calibration algorithms that adjust model parameters to best match the latest sensor measurements, providing a continuous validation loop. Monitors evaluate the calibrated models against safety and optimality criteria, detecting violations. The DT therefore uses calibration‑based verification and runtime monitoring as its primary quality‑assurance mechanisms, though specific uncertainty quantification or formal V&V methods are not described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The incubator’s technical network consists of temperature sensors linked via a 1‑Wire bus to a Raspberry Pi, which provides built‑in Wi‑Fi connectivity. The Raspberry Pi hosts a local RabbitMQ server that mediates messaging between the physical sensors/actuators and the digital twin software. Communication between components relies on the RabbitMQ messaging infrastructure over the Wi‑Fi network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is deployed on‑edge on the Raspberry Pi that runs both the controller software and a local RabbitMQ server. All required hardware and software components are open‑source and available in the publicly‑accessible repository linked in the case‑study documentation. The deployment therefore uses an on‑premise edge platform without external cloud services."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin incorporates monitors that continuously evaluate operational data to confirm the system is performing safely and optimally; when a safety violation is detected, humans or other algorithms may decide to modify the physical twin. No specific cybersecurity protocols, access‑control mechanisms, authentication systems, threat‑mitigation strategies, fail‑safe designs, or formal risk‑assessment methods are described in the document."
]