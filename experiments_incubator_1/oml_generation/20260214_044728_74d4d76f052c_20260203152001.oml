// C2: Acting Components
instance HeaterHighTemperatureResistive : DTDFVocab:ActingComponent [
    base:desc "High‑temperature resistive heater integrated into the heatbed, operates as a bang–bang actuator delivering ~60 W when temperature falls below the lower threshold and stops at the target temperature, no PWM control. Belongs to device registry ID HW‑HEATER01 and exposes remote control via MQTT topic."
]

instance FanBrushlessDC : DTDFVocab:ActingComponent [
    base:desc "Brushless DC fan cycling 0–1200 rpm governed by bang–bang logic to maintain airflow during heating cycles, exposes remote control via MQTT topic, device ID HW‑FAN01."
]

// C3: Physical Sensing Components
instance HeatBedCenterTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Precision silicon thermistor TMP36 positioned on the heatbed surface at the center, provides 0.10 °C resolution and ±0.5 °C accuracy, samples at 1 Hz and transmits data via serial bus to local acquisition unit."
    DTDFVocab:producedData HeatBedCenterTempDataTransmitted
]

instance HeatBedPeripheralTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Precision silicon thermistor TMP36 positioned on the heatbed peripheral point, provides 0.10 °C resolution and ±0.5 °C accuracy, samples at 1 Hz."
    DTDFVocab:producedData HeatBedPeripheralTempDataTransmitted
]

instance AmbientChamberTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Precision silicon thermistor TMP36 monitoring the ambient chamber wall, samples at 1 Hz and transmits data via serial bus."
    DTDFVocab:producedData AmbientChamberTempDataTransmitted
]

// C4: Physical‑to‑Virtual Interaction – Data Transmitted
instance HeatBedCenterTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatBedCenterTemperatureSensor
]

instance HeatBedPeripheralTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatBedPeripheralTemperatureSensor
]

instance AmbientChamberTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientChamberTemperatureSensor
]

// C10: Models/Data – Pre‑processed Data
instance CleanedHeatBedCenterTemperatureData : DTDFVocab:Data [
    base:desc "Pre‑processed heatbed center temperature data after timestamp alignment, out‑of‑range filtering, and moving‑average smoothing."
    DTDFVocab:fromData HeatBedCenterTempDataTransmitted
    DTDFVocab:inputTo HeatBedCalibrationEnabler, HeatBedMonitoringEnabler
]

instance CleanedHeatBedPeripheralTemperatureData : DTDFVocab:Data [
    base:desc "Pre‑processed heatbed peripheral temperature data after filtering and smoothing."
    DTDFVocab:fromData HeatBedPeripheralTempDataTransmitted
    DTDFVocab:inputTo HeatBedCalibrationEnabler, HeatBedMonitoringEnabler
]

instance CleanedAmbientTemperatureData : DTDFVocab:Data [
    base:desc "Pre‑processed ambient chamber temperature data."
    DTDFVocab:fromData AmbientChamberTempDataTransmitted
    DTDFVocab:inputTo AmbientMonitoringEnabler
]

instance ThermalBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model describing thermal dynamics of heatbed and chamber using differential equations for simulation and prediction."
    DTDFVocab:inputTo HeatBedCalibrationEnabler, AmbientCalibrationEnabler
]

// C11: Enablers
instance HeatBedCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration enabler aggregates cleaned heatbed temperature data for calibration algorithms that update behavioral model parameters."
    DTDFVocab:enables OptimisationService
]

instance AmbientCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration enabler aggregates cleaned ambient temperature data for calibrating environmental model parameters."
    DTDFVocab:enables OptimisationService
]

instance HeatBedMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring enabler consumes cleaned heatbed data to compare model predictions with real‑time sensor readings."
    DTDFVocab:enables MonitoringService
]

instance AmbientMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring enabler for ambient chamber temperature data."
    DTDFVocab:enables MonitoringService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation enabler uses behavioral model and current state to generate predictive simulation data."
    DTDFVocab:enables PredictiveSimulationService
]

instance ControlEnabler : DTDFVocab:Enabler [
    base:desc "Control enabler routes violations detected by monitoring into control actions to adjust heater or fan via MQTT."
    DTDFVocab:enables ControlService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitoring service continuously checks physical twin operation for safety and optimal performance using model‑based predictions and realtime sensor data."
    DTDFVocab:provides FaultDetectionInsight, UnsafeOperationAlert
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Optimisation service employs calibration algorithms to update model parameters and adjust system operation to meet design constraints."
    DTDFVocab:provides OptimisationRecommendationAction
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation service reproduces and forecasts physical twin behavior under current operating conditions, feeding data into fault detection."
    DTDFVocab:provides ForecastInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Control service communicates detected violations to human operators or automatically triggers controller actions to modify physical twin actions."
    DTDFVocab:provides ControlAction
]

// C17: Insights / Actions
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting deviations between model predictions and sensor data, flagging unsafe or sub‑optimal behavior."
]

instance UnsafeOperationAlert : DTDFVocab:Insight [
    base:desc "Alert generated when temperature exceeds 60 °C, triggering emergency shutdown."
]

instance OptimisationRecommendationAction : DTDFVocab:Action [
    base:desc "Action advising adjustment of heater/fan operation parameters to meet design constraints."
    DTDFVocab:IsAutomatic false
]

instance ForecastInsight : DTDFVocab:Insight [
    base:desc "Predictive forecast of temperature trajectory under current conditions."
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Automatic or operator‑triggered command to heater or fan to correct violations."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT component running on the physical twin’s edge device (e.g., Raspberry Pi) subscribes to a RabbitMQ queue to receive control commands. Commands are formatted as JSON objects containing an action field and associated parameters. Incoming messages are authenticated (e.g., via a shared token) and validated against a predefined JSON schema before being applied. After executing a command, the DT publishes an acknowledgement or status message back to the queue or a dedicated status topic, enabling synchronous feedback to the original controller."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is structured around a centralized orchestration that receives real‑time sensor data from the Physical Twin, feeds this data into calibration algorithms that continually update both cyber‑and physics‑based models, and then circulates the refined model output to monitoring components. These monitors evaluate safety and performance against predefined thresholds, triggering either algorithmic adjustments or human interventions when violations occur. The system thus implements a closed‑loop simulation‑monitor‑actuation workflow sustained by continuous data ingestion, model calibration, and feedback control."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle proceeds through a sequence of phases that begin with the creation of component‑level models—CAD representations for static geometry, dynamic models defined by differential equations for behavioural analysis, and other cyber‑physical abstractions. In the integration phase the DT framework is assembled by linking the physical twin to this model collection, attaching a real‑time data layer that streams sensor measurements, and connecting a set of algorithms (e.g., calibration, fault detection, supervisory control, optimisation). Transition management is effected by continuous calibration: the calibration algorithms ingest live data to estimate the most current parameter set for each model; these updated models are then fed back into the monitoring loop. The DT lifecycle governance involves coordinated data management, model versioning (implicitly captured by calibration snapshots), and decision‑making cycles that monitor for safety and performance violations and trigger human or automated corrective actions. The final operational phase comprises real‑time simulation, prediction, and optimisation that informs the physical twin in real‑time."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is constrained by the assumption of spatial temperature uniformity across the heat‑bed surface (Assumption 1).  Validation is performed through a multi‑stage process: (1) an initial calibration step compares measured temperature trajectories against the nominal plant model predictions and adjusts the time‑constant τ; (2) a residual‑error minimization routine uses a sliding‑window least‑squares fit to quantify model bias over successive 30‑minute cycles; (3) a periodic cross‑check between the sensor and a high‑precision reference thermometer ensures at least ±0.5 °C agreement.  Error detection is facilitated by monitoring the residual trend: a monotonic drift beyond 0.3 °C triggers an automatic re‑calibration routine.  All validation data, residual plots, and re‑calibration logs are archived in the digital twin metadata repository, providing traceability and enabling continuous quality assurance."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT network backbone is built around a RabbitMQ message broker deployed locally on the edge device. Communication between DT components occurs over TCP/IP on the local LAN, using standard MQTT or AMQP protocols. The expected bandwidth is modest (tens of kilobits per second) with latency below 100 ms to support near‑real‑time monitoring. Reliability is ensured through RabbitMQ’s persistence and duplicate‑message detection. Security is handled by TLS‑encrypted connections for the broker, along with token‑based authentication for each client."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted on an edge deployment realized on a Raspberry Pi single‑board computer. The device runs a lightweight Linux OS, hosts the RabbitMQ broker, and runs the DT application. Compute resources include a 1‑GHz ARM CPU, 512 MB RAM, and 16 GB SD storage, sufficient for data ingestion, preprocessing, and lightweight simulation and calibration. The deployment is scalable by adding additional Pi nodes or migrating workloads to a cloud tier if needed, but the current reference implementation is purely on‑premise edge with high availability achieved by local redundancy of the broker queues."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin implements a safety protocol embedded within its low‑level driver layer to maintain the device in a safe operating state. This prototype‑level safety measure ensures that, upon detection of unsafe conditions, the driver initiates appropriate fail‑safe procedures to prevent harm or damage."
]