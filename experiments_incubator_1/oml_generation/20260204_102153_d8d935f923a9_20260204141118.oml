// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heating element controlled via MOSFET switches to generate and distribute heat within the incubation environment, operating under safety constraints enforced by the RaspberryPiControlUnit."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Mechanically driven airflow system for distributing heat and maintaining uniform temperature distribution within the StyrofoamBox environment, controlled via RabbitMQ message broker."
]

// C3: Physical Sensing Components
instance InternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 High-Precision 1-Wire Digital Thermometer measuring internal box temperature with ±0.5°C accuracy across -10°C to +85°C range, connected via 1-Wire bus to RaspberryPiControlUnit."
    DTDFVocab:producedData InternalTemperatureDataTransmitted
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 High-Precision 1-Wire Digital Thermometer measuring external environmental temperature with ±0.5°C accuracy across -10°C to +85°C range, connected via 1-Wire bus to RaspberryPiControlUnit."
    DTDFVocab:producedData ExternalTemperatureDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance InternalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor
]

instance ExternalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

// C10: Models/Data
instance GeometricModel : DTDFVocab:Model [
    base:desc "Abstract CAD-based representation of physical attributes including StyrofoamBox dimensions, heatbed placement, and fan positioning without dynamic behavior simulation."
    DTDFVocab:inputTo CalibrationAlgorithm
]

instance ThermalBehaviorModel : DTDFVocab:Model [
    base:desc "Physics-based differential equation model simulating thermal diffusion and airflow dynamics within the incubation environment, calibrated using real-time sensor data."
    DTDFVocab:inputTo StateEstimator, FaultDetector
]

instance EnvironmentalAnalyticalModel : DTDFVocab:Model [
    base:desc "Knowledge-based representation of cyber-physical system parameters including heatbed efficiency, fan airflow characteristics, and environmental interactions."
    DTDFVocab:inputTo ParameterOptimizer
]

instance RealTimeMonitoringData : DTDFVocab:Data [
    base:desc "Continuous stream of temperature readings from DS18S20 sensors transmitted via RabbitMQ, used for real-time state estimation and anomaly detection."
    DTDFVocab:fromData InternalTemperatureDataTransmitted, ExternalTemperatureDataTransmitted
    DTDFVocab:inputTo StateEstimator, FaultDetector
]

instance CalibrationParametersData : DTDFVocab:Data [
    base:desc "Best-estimate parameters generated by calibration algorithms to align virtual models with physical system behavior, including thermal conductivity and fan efficiency values."
    DTDFVocab:fromData RealTimeMonitoringData
    DTDFVocab:inputTo ThermalBehaviorModel, EnvironmentalAnalyticalModel
]

// C11: Enablers
instance RabbitMQMessageBroker : DTDFVocab:Enabler [
    base:desc "Lightweight RabbitMQ server hosted on RaspberryPi for asynchronous communication between DS18S20 sensors and DigitalTwin processing pipeline, facilitating real-time data transmission via 1-Wire bus."
    DTDFVocab:enables DataAcquisitionService
]

instance RaspberryPiControlUnit : DTDFVocab:Enabler [
    base:desc "Embedded Linux-based Raspberry Pi system processing sensor data, executing calibration algorithms, and coordinating actuation commands via MOSFET switches and RabbitMQ broker."
    DTDFVocab:enables CalibrationAlgorithm, StateEstimator, FaultDetector, ParameterOptimizer
]

instance PythonScipyStack : DTDFVocab:Enabler [
    base:desc "Python-based computational environment utilizing SciPy libraries for implementing calibration algorithms, state estimation, and parameter optimization routines."
    DTDFVocab:enables CalibrationAlgorithm, StateEstimator, ParameterOptimizer
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Python/Scipy-based algorithm updating model parameters (e.g., thermal conductivity, fan efficiency) using real-time sensor data to minimize error between virtual and physical representations."
    DTDFVocab:enables MonitoringService
]

instance StateEstimator : DTDFVocab:Enabler [
    base:desc "Algorithm (likely Kalman filter or Bayesian inference) reconstructing hidden system states from noisy sensor data to generate best-estimate parameters for the incubation environment."
    DTDFVocab:enables MonitoringService, PredictiveAnalyticsService
]

instance FaultDetector : DTDFVocab:Enabler [
    base:desc "Anomaly detection module identifying deviations from safe/optimal operating conditions (e.g., temperature drift, sensor failures) based on real-time monitoring data."
    DTDFVocab:enables MonitoringService, DecisionSupportService
]

instance ParameterOptimizer : DTDFVocab:Enabler [
    base:desc "Optimization solver (unspecified type) adjusting model parameters to minimize energy consumption or maximize precision in the incubation system's thermal regulation."
    DTDFVocab:enables OptimizationService
]

// C6: Services
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Real-time data collection service aggregating temperature readings from DS18S20 sensors via RabbitMQ broker and preprocessing for model calibration."
    DTDFVocab:provides TemperatureDataInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time state estimation service generating best-estimate parameters for thermal and environmental models using calibration algorithms and sensor data."
    DTDFVocab:provides ThermalStateInsight, AnomalyDetectionInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Dynamic behavior reproduction service employing physics-based models to replicate Physical Twin behavior under current operating conditions."
    DTDFVocab:provides PredictiveThermalGradientInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive service projecting future states (e.g., thermal gradients, failure modes) using state estimators informed by historical and real-time data."
    DTDFVocab:provides FailureModePredictionInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Parameter calibration service adjusting model parameters (e.g., heatbed efficiency, fan airflow) to minimize energy consumption or maximize precision."
    DTDFVocab:provides EnergyOptimizationInsight
]

instance ControlStrategyService : DTDFVocab:Service [
    base:desc "Supervisory control service refining control strategies via PID-like adjustments to stabilize Physical Twin operations."
    DTDFVocab:provides ControlAdjustmentAction
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Human-in-the-loop decision support service alerting operators to take corrective actions when violations (e.g., temperature thresholds) are detected."
    DTDFVocab:provides MaintenanceRecommendationInsight, CorrectiveActionAction
]

// C17: Insights/Actions
instance TemperatureDataInsight : DTDFVocab:Insight [
    base:desc "Aggregated temperature readings from internal and external sensors transmitted via RabbitMQ for real-time monitoring purposes."
]

instance ThermalStateInsight : DTDFVocab:Insight [
    base:desc "Best-estimate parameters for the incubation environment's thermal state generated through state estimation algorithms."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Identified deviations from safe/optimal operating conditions including temperature drift or sensor failures detected by the FaultDetector."
]

instance PredictiveThermalGradientInsight : DTDFVocab:Insight [
    base:desc "Projected future thermal gradients within the incubation environment based on current operating conditions and historical data patterns."
]

instance FailureModePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted failure modes (e.g., thermal instability, component degradation) identified through predictive analytics algorithms."
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized parameter settings for heatbed efficiency and fan airflow that minimize energy consumption while maintaining operational requirements."
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated supervisory control adjustments (e.g., PID-like modifications) to stabilize Physical Twin operations based on real-time monitoring data."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceRecommendationInsight : DTDFVocab:Insight [
    base:desc "Algorithm-generated recommendations for preventive maintenance actions (e.g., sensor recalibration, component replacement) based on anomaly detection results."
]

instance CorrectiveActionAction : DTDFVocab:Action [
    base:desc "Human-initiated corrective actions (e.g., recalibrating fans, replacing sensors) triggered by violation alerts from the DecisionSupportService."
    DTDFVocab:IsAutomatic false
]

// C18: Environment
instance IncubationEnvironment : DTDFVocab:Environment [
    base:desc "Precision environmental control system comprising heatbed, StyrofoamBox, and fan components designed for biomedical incubation, food preservation, or material science experiments."
    base:contains HeatbedActuator, FanActuator, InternalTemperatureSensor, ExternalTemperatureSensor
]

instance DigitalTwinProcessingPipeline : DTDFVocab:Environment [
    base:desc "Computational environment hosting calibration algorithms, state estimators, and optimization routines that process sensor data and generate insights for the incubation system."
    base:contains RabbitMQMessageBroker, RaspberryPiControlUnit, PythonScipyStack, CalibrationAlgorithm, StateEstimator, FaultDetector, ParameterOptimizer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "
The **virtual-to-physical interaction** in this DT system involves command execution and human-in-the-loop intervention, primarily mediated through the RabbitMQ server. Commands for controlling the PT—such as adjusting the fan or heatbed—are **listened from the RabbitMQ server**, indicating a message-based control mechanism. While the exact message formats are not specified, the system implies structured command payloads are transmitted to the PT for execution. Validation and authentication mechanisms are not explicitly detailed, but the reliance on RabbitMQ’s inherent message queuing suggests some level of ordered and reliable command delivery. Feedback systems are implied through the monitoring phase, where violations (e.g., safety or optimality breaches) trigger human or algorithmic decisions to modify the PT’s state. Conflict resolution is not addressed in the document, but the system assumes that human operators or higher-level algorithms can override or adjust commands dynamically. Command execution confirmation is not explicitly mentioned, but the calibration and monitoring loops suggest implicit feedback loops for system verification.
"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system described in the provided documents does not explicitly detail synchronization frequencies, time scales for services, or latency requirements between the Physical Twin (PT) and Digital Twin (DT). The document mentions a 'periodic' reading of temperature data from the PT to the DT, but no specific time intervals (e.g., milliseconds, seconds, or minutes) are specified. Additionally, the document references a 'waiting duration' for the controller to process data, though no concrete duration is provided. Synchronization is facilitated via a RabbitMQ server, which handles internal communication between the PT and DT, but no temporal granularity or latency constraints are quantified. Thus, the temporal aspects of the twinning process remain unspecified beyond 'periodic' data acquisition and controller processing without defined frequencies or latency thresholds."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a **modular architecture pattern**, integrating **data**, **models**, and **algorithms** as core components to enable end-to-end functionality. The system employs **calibration algorithms** to update models dynamically, ensuring alignment between the DT and the Physical Twin (PT). **Monitoring services** are embedded within the DT to assess system performance, safety, and optimality, with violations triggering **human or algorithmic interventions** (e.g., parameter adjustments or control actions). Resource management is implicit in the system's design, where **data** (collected via sensors) and **models** (representing CPS and environment) are prioritized for real-time processing. System-wide coordination is achieved through **closed-loop feedback mechanisms**, where the DT's outputs (e.g., state estimates, predictions) inform both the PT and subsequent algorithmic or human decisions. The architecture leverages **simulation capabilities** to reproduce and predict PT behavior under current operating conditions, integrating **optimization techniques** to enhance performance."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "
The lifecycle of a Digital Twin (DT) spans multiple stages, beginning with **conceptualization and design**, where abstract models (e.g., CAD representations of physical components like car chassis or wheel dimensions) are developed to capture specific system aspects. These models are later refined into **dynamic models** (e.g., differential equations for force dynamics) to analyze behavior under operational conditions. During **development**, the DT integrates **data collection** (real-time sensor inputs from the Physical Twin (PT)), **models** (cyber-physical system (CPS) and environmental representations), and **algorithms** (e.g., calibration algorithms, fault detectors, and state estimators) to update parameters dynamically. Transition management between stages involves **model integration**—ensuring legacy models (e.g., CAD or dynamic simulations) are not discarded but repurposed into the DT framework. Lifecycle governance includes **continuous validation** of model accuracy via calibration algorithms that adjust parameters to align with PT behavior, ensuring the DT remains a reliable proxy for decision-making. The final stage emphasizes **operational deployment**, where the DT supports real-time monitoring, predictive analytics, and adaptive control, with governance mechanisms (e.g., human-in-the-loop interventions) to address violations detected by monitors (e.g., safety or optimality checks)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
The Digital Twin (DT) emphasizes **model fidelity** and **validity** through structured methodologies to ensure accuracy and reliability:
- **Fidelity Requirements**:
  - Models must abstract **specific aspects** of the PT (e.g., geometric, behavioral, or analytical) while excluding irrelevant details (e.g., CAD models omit dynamic forces).
  - **Dynamic Models** (e.g., differential equations) are validated against real-world PT behavior to ensure predictive accuracy.
- **Validation and Verification Methods**:
  - **Calibration Algorithms**: Continuously refine models by updating parameters using real-time sensor data to minimize discrepancies between virtual and physical representations.
  - **Monitoring Systems**: Deployed to detect deviations (e.g., safety violations, suboptimal performance) via algorithms like fault detectors or state estimators.
- **Uncertainty Sources and Quantification**:
  - **Sensor Noise/Error**: Introduced by real-time data collection, requiring statistical or machine-learning-based error correction.
  - **Model Assumptions**: Parametric or empirical inaccuracies in behavioral/analytical models, quantified via residual analysis or comparison to benchmark datasets.
- **Error Detection and Correction Mechanisms**:
  - **Feedback Loops**: Algorithms (e.g., supervisory controllers) trigger corrective actions when violations are detected, either autonomously or via human intervention.
  - **Quality Assurance Processes**:
    - **Pre-deployment**: Models undergo rigorous testing (e.g., simulation validation) to ensure consistency with design specifications.
    - **Post-deployment**: Continuous calibration and monitoring to adapt to environmental/operational changes, maintaining long-term fidelity.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for this Digital Twin system is a **local network** architecture centered around a **Raspberry Pi 4 Model B** hosting the RabbitMQ server as a message broker. The communication protocol relies on RabbitMQ’s lightweight, mature framework, though specific protocols (e.g., AMQP) or security protocols (e.g., TLS) are not mentioned. Network topology is not detailed beyond the local setup, and bandwidth/latency requirements are unspecified. Reliability mechanisms are not explicitly described, though RabbitMQ’s maturity suggests inherent fault tolerance. No mention of redundancy or security protocols (e.g., encryption, firewalls) is provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **deployment infrastructure** for this Digital Twin system is hosted **on-premise** on a **Raspberry Pi 4 Model B**, with no cloud or edge deployment mentioned. Computational and storage requirements are not specified, but the system implies minimal resource demands due to the lightweight RabbitMQ server and local sensor integration. Scalability mechanisms are not addressed, and the deployment model is limited to a single-node setup. Availability and reliability are not quantified, though the use of RabbitMQ suggests basic fault tolerance. No redundancy or high-availability configurations are described."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "
The Digital Twin (DT) incorporates **safety-critical system considerations** by integrating **monitoring algorithms** that continuously assess the Physical Twin (PT) for operational safety and optimality. The system employs **calibration algorithms** to refine models of the Cyber-Physical System (CPS) and its environment, ensuring parameter accuracy for reliable decision-making. **Fail-safe mechanisms** are implied through the use of **monitors** that detect violations of predefined safety thresholds, triggering corrective actions (e.g., human intervention or automated adjustments) to maintain system integrity. While the document does not specify explicit **cybersecurity protocols** or **access control mechanisms**, it highlights the role of **algorithms** (e.g., fault detectors, state estimators) in mitigating risks by validating PT behavior against modeled expectations. The **low-level driver** referenced in the context enforces a 'safe protocol' to constrain the PT’s operational state, aligning with basic safety-critical design principles. No detailed mention of **authentication systems**, **threat mitigation strategies**, or **risk assessment frameworks** (e.g., ISO/IEC 27001, NIST SP 800-53) is provided."
]