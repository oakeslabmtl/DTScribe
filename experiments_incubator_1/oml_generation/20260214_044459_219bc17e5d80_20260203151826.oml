// Components of the thermal incubator
instance InsulatedBox : DTDFVocab:Component [
    base:desc "Insulated enclosure that houses the heatbed, fan, and sensors."
]

instance HeatBed : DTDFVocab:Component [
    base:desc "Heatbed that provides heating to maintain the internal temperature."
]

instance CirculatingFan : DTDFVocab:Component [
    base:desc "Air circulator fan to ensure uniform temperature distribution."
]

instance TemperatureSensorDS18S20 : DTDFVocab:Component [
    base:desc "1‑Wire digital thermometer DS18S20 located inside the incubator."
]

instance RaspberryPi4ModelBController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running control software."
]

instance DrivingPCBWithMOSFETOptocoupler : DTDFVocab:Component [
    base:desc "PCB containing MOSFETs and optocouplers to drive the heating element."
]

instance PowerSupply : DTDFVocab:Component [
    base:desc "Power supply providing electrical power to the control board and heating element."
]

// Environment containing the components
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:contains InsulatedBox, HeatBed, CirculatingFan, TemperatureSensorDS18S20, RaspberryPi4ModelBController, DrivingPCBWithMOSFETOptocoupler, PowerSupply
]

// Sensing component
instance TemperatureSensorDS18S20_Sensing : DTDFVocab:SensingComponent [
    base:desc "1‑Wire digital thermometer DS18S20 placed inside the thermal incubator."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// Data transmitted from sensor
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorDS18S20_Sensing
]

// Aggregated temperature data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Aggregated temperature data collected over time for monitoring and modeling."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo MonitoringEnabler, SimulationEngineEnabler, SupervisoryControlEnabler, OptimizationEnabler, CalibrationEnabler
]

// Thermal model used for simulation and optimization
instance ThermalModel : DTDFVocab:Model [
    base:desc "Dynamic thermal model encapsulating geometry, heat conduction, and control dynamics."
    DTDFVocab:inputTo CalibrationEnabler, OptimizationEnabler, SimulationEngineEnabler
]

// Enablers (algorithms/tools)
instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Software component that ingests temperature data streams and applies safety and optimality checks."
    DTDFVocab:enables MonitoringService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that executes calibrated dynamic thermal models to predict temperature behavior."
    DTDFVocab:enables SimulationService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimizer that adjusts model parameters and control actions to improve thermal performance."
    DTDFVocab:enables OptimizationService
]

instance SupervisoryControlEnabler : DTDFVocab:Enabler [
    base:desc "Supervisory controller that detects anomalies in temperature readings and coordinates corrective actions."
    DTDFVocab:enables SupervisoryControlService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that updates the thermal model parameters based on observed data."
    DTDFVocab:enables CalibrationService
]

// Digital Twin services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of the physical twin through real‑time sensor data streams and safety/optimality checks."
    DTDFVocab:provides SafetyComplianceInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation that reproduces the twin’s behaviour under current operating conditions using calibrated dynamic models."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization services that adjust model parameters and control actions to improve performance."
    DTDFVocab:provides PerformanceImprovementInsight
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Supervisory control mechanisms that detect anomalies and, together with human operators, initiate corrective interventions."
    DTDFVocab:provides FaultDetectionInsight, HeatingActuationAction
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration service that provides insights on model accuracy."
    DTDFVocab:provides ModelCalibrationInsight
]

// Insights generated by services
instance SafetyComplianceInsight : DTDFVocab:Insight [
    base:desc "Indicates that the temperature stays within safety thresholds."
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicts future temperature trajectory based on the current state."
]

instance PerformanceImprovementInsight : DTDFVocab:Insight [
    base:desc "Measures objective performance improvement achieved by the optimizer."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects and flags temperature anomalies in real‑time."
]

instance ModelCalibrationInsight : DTDFVocab:Insight [
    base:desc "Shows calibration status and confidence of the thermal model."
]

// Action generated by supervisory control
instance HeatingActuationAction : DTDFVocab:Action [
    base:desc "Controls MOSFET switching to adjust heating element power."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central architecture that orchestrates data acquisition from the physical twin via sensors, applies calibration algorithms to update the models of the cyber‑physical system and its environment, and forwards the calibrated data to monitors that assess safety and optimal performance. This pattern layers data collection, model calibration, simulation, and monitoring, enabling continuous value generation by integrating modelling, simulation, monitoring, and optimisation technologies."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is upheld through calibration algorithms that incorporate real‑time sensor data to refine parameter estimates of the CPS and environmental models, ensuring the digital twin reflects observed physical behaviour. Operational monitors continuously evaluate safety and performance metrics; detected violations trigger alerts and may lead to corrective actions in the physical twin. Although specific validation, error‑correction, and quality assurance processes are not detailed in the document, the described calibration and monitoring loops provide a foundational framework for assessing and preserving model fidelity and data integrity."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin framework incorporates safety‑monitoring components that continuously compare real‑time sensor data with model‑based predictions to determine whether the physical system is operating safely and optimally. When the monitors detect a safety or performance violation, they trigger alert mechanisms that allow either human operators or autonomous decision‑making algorithms to intervene and adjust the physical twin. Fault‑detection algorithms, among other diagnostic tools, are included as part of the safety validation process. "
]