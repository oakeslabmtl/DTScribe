// C3: Physical sensing components
instance IncubatorInternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer inside the incubator measuring temperature (-55 °C to +125 °C, 0.5 °C accuracy)"
    DTDFVocab:producedData IncubatorInternalTempDataTransmitted1
]

instance IncubatorInternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 digital thermometer inside the incubator measuring temperature (-55 °C to +125 °C, 0.5 °C accuracy)"
    DTDFVocab:producedData IncubatorInternalTempDataTransmitted2
]

instance AmbientRoomTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer placed in the room measuring ambient temperature (-55 °C to +125 °C, 0.5 °C accuracy)"
    DTDFVocab:producedData AmbientRoomTempDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance IncubatorInternalTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInternalTempSensor1
]

instance IncubatorInternalTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInternalTempSensor2
]

instance AmbientRoomTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientRoomTempSensor
]

// C10: Data (from DataTransmitted)
instance IncubatorInternalTempData1 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurement from internal sensor 1"
    DTDFVocab:fromData IncubatorInternalTempDataTransmitted1
    DTDFVocab:inputTo GPIODriverEnabler, PythonSimulationEngineEnabler, ScipyLeastSquaresEnabler
]

instance IncubatorInternalTempData2 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurement from internal sensor 2"
    DTDFVocab:fromData IncubatorInternalTempDataTransmitted2
    DTDFVocab:inputTo GPIODriverEnabler, PythonSimulationEngineEnabler, ScipyLeastSquaresEnabler
]

instance AmbientRoomTempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurement from ambient room sensor"
    DTDFVocab:fromData AmbientRoomTempDataTransmitted
    DTDFVocab:inputTo GPIODriverEnabler, PythonSimulationEngineEnabler, ScipyLeastSquaresEnabler
]

// C11: Enablers (tooling and enablers)
instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "AMQP RabbitMQ broker running on the Raspberry Pi handling publish/subscribe of sensor messages"
    DTDFVocab:enables TemperatureMonitoringService
]

instance ScipyLeastSquaresEnabler : DTDFVocab:Enabler [
    base:desc "SciPy non‑linear least‑squares optimizer used for calibration of thermal model parameters"
    DTDFVocab:enables ParameterCalibrationService
]

instance GPIODriverEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level driver abstracting Raspberry Pi GPIO access for sensor acquisition and actuator control"
    DTDFVocab:enables HeatingCycleOptimizationService, FaultDetectionService
]

instance PythonSimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime executing thermal simulation models (Model A and Model B)"
    DTDFVocab:enables ThermalSimulationService
]

// C6: Services (DT services)
instance ThermalSimulationService : DTDFVocab:Service [
    base:desc "Physics‑based thermal simulation using Model A or Model B"
    DTDFVocab:provides SimulationResultInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibration of model parameters via SciPy least‑squares optimisation"
    DTDFVocab:provides CalibratedParametersInsight
]

instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature limits, consuming sensor data via RabbitMQ"
    DTDFVocab:provides TemperatureLimitViolationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection and safety checks based on sensor streams"
    DTDFVocab:provides TemperatureLimitViolationInsight
]

instance HeatingCycleOptimizationService : DTDFVocab:Service [
    base:desc "Bang‑bang controller optimising heating duration and waiting periods"
    DTDFVocab:provides AdjustHeatingDurationAction
]

// C17: Insights
instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Provides calibrated thermal model parameters after optimisation"
]

instance TemperatureLimitViolationInsight : DTDFVocab:Insight [
    base:desc "Detects violations of defined temperature upper and lower limits"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Outputs simulated temperature trajectories from the thermal models"
]

// C17: Actions
instance AdjustHeatingDurationAction : DTDFVocab:Action [
    base:desc "Adjusts heating duration and waiting periods to maintain safety and optimality"
    DTDFVocab:IsAutomatic true
]

// C10: Models (DT models and data)
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Dynamic thermal model A with parameters C_air (thermal capacitance of air) and G_box (conductance to ambient box)"
    DTDFVocab:inputTo PythonSimulationEngineEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Extended thermal model B adding heater capacitance C_heater and heater conductance G_heater"
    DTDFVocab:inputTo PythonSimulationEngineEnabler
]

// C2: Acting components (physical acting components)
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed power on/off via MOSFET driver isolated by optocoupler"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal fan speed control (on/off or PWM) via MOSFET driver isolated by optocoupler"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT services publish control commands (heat‑bed on/off, fan on/off, waiting durations) to the same RabbitMQ broker; the controller subscribes to these messages and forwards them to the low‑level driver, which drives the MOSFETs on the PCB to affect the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture comprises the PT (box, heat‑bed, fan, sensors, PCB, Pi), a low‑level driver interfacing hardware, a controller implementing the bang‑bang logic, a RabbitMQ communication server on the Pi, and DT components (simulation, calibration, monitoring) that subscribe/publish to the broker, forming a closed feedback loop."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is based on four assumptions (uniform temperature, negligible wall heat storage, constant air specific heat, negligible heat‑bed loss). Validity is assessed via (a) uniformity experiments confirming fan‑induced mixing, (b) calibration against measured temperature trajectories, and (c) comparison of Model A vs Model B residual errors."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual and virtual‑to‑physical messages are exchanged over the RabbitMQ message broker using the AMQP protocol over TCP/IP on the local Raspberry Pi network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ server and all DT software components (controller, low‑level driver, simulation and calibration modules) are deployed on the Raspberry Pi 4 Model B that also hosts the PT controller."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the device in a safe state; electrical isolation is provided by optocouplers on the PCB, reducing risk of uncontrolled actuation. Safety monitoring is performed by DT monitors that check temperature limits before allowing actuator commands."
]