// C3: Physical sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor monitoring internal air temperature of the incubator box (sensor 1)."
    DTDFVocab:producedData InternalTempMessage1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor monitoring internal air temperature of the incubator box (sensor 2)."
    DTDFVocab:producedData InternalTempMessage2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring ambient temperature outside the incubator box."
    DTDFVocab:producedData AmbientTempMessage
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance InternalTempMessage1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempMessage2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance AmbientTempMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// C10: Data
instance InternalTemperatureData1 : DTDFVocab:Data [
    base:desc "Raw internal temperature measurement from sensor 1."
    DTDFVocab:fromData InternalTempMessage1
    DTDFVocab:inputTo RabbitMQBroker, CalibrationEngine
]

instance InternalTemperatureData2 : DTDFVocab:Data [
    base:desc "Raw internal temperature measurement from sensor 2."
    DTDFVocab:fromData InternalTempMessage2
    DTDFVocab:inputTo RabbitMQBroker, CalibrationEngine
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Raw ambient temperature measurement from external sensor."
    DTDFVocab:fromData AmbientTempMessage
    DTDFVocab:inputTo RabbitMQBroker, CalibrationEngine
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker used to transport sensor and controller messages."
    DTDFVocab:enables RealTimeVisualizationService,
                    OnDemandCalibrationService,
                    AnomalyDetectionAndEstimationService,
                    WhatIfSimulationService,
                    SelfAdaptationService
]

instance KalmanFilterEngine : DTDFVocab:Enabler [
    base:desc "Kalman filter that fuses temperature measurements with Model B predictions for anomaly detection and heat‑bed state estimation."
    DTDFVocab:enables AnomalyDetectionAndEstimationService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Calibration routine that updates parameters of Model A and Model B using latest sensor data."
    DTDFVocab:enables OnDemandCalibrationService
]

instance CoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation engine that replays PT data to evaluate alternative controller settings."
    DTDFVocab:enables WhatIfSimulationService
]

instance VisualizationDashboard : DTDFVocab:Enabler [
    base:desc "Time‑series database and interactive dashboard displaying real‑time controller and driver messages."
    DTDFVocab:enables RealTimeVisualizationService
]

instance SelfAdaptationEngine : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop that orchestrates experiments, recalibration, predictive simulation and controller re‑programming."
    DTDFVocab:enables SelfAdaptationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of incubator status by streaming messages into a time‑series database and rendering a dashboard."
    DTDFVocab:provides TemperatureTrendInsight
]

instance OnDemandCalibrationService : DTDFVocab:Service [
    base:desc "On‑demand calibration of thermal models using latest temperature data."
    DTDFVocab:provides CalibrationInsight
]

instance AnomalyDetectionAndEstimationService : DTDFVocab:Service [
    base:desc "Anomaly detection and heat‑bed state estimation using a Kalman filter."
    DTDFVocab:provides AnomalyInsight, HeatBedStateInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What‑if simulations through co‑simulation that evaluate alternative controller parameters."
    DTDFVocab:provides SimulationResultInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Self‑adaptation loop that reconfigures the controller based on detected behavioural changes."
    DTDFVocab:provides ReconfigureControllerAction,
                    UpdateModelParametersAction,
                    ScheduleExperimentAction
]

// C17: Insights
instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Insight into temperature trends and uniformity inside the incubator."
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight about model parameter convergence after calibration."
]

instance AnomalyInsight : DTDFVocab:Insight [
    base:desc "Detection of deviations from expected temperature behaviour."
]

instance HeatBedStateInsight : DTDFVocab:Insight [
    base:desc "Estimated heat‑bed temperature derived from Kalman filter fusion."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Predictive outcomes of alternative controller configurations."
]

// C17: Actions
instance ReconfigureControllerAction : DTDFVocab:Action [
    base:desc "Re‑programs the Raspberry Pi controller with optimized bang‑bang parameters."
    DTDFVocab:IsAutomatic true
]

instance UpdateModelParametersAction : DTDFVocab:Action [
    base:desc "Updates Model B parameters after calibration."
    DTDFVocab:IsAutomatic true
]

instance ScheduleExperimentAction : DTDFVocab:Action [
    base:desc "Schedules and executes an experiment to collect data for re‑calibration."
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical temperature prediction model A with two free parameters derived from the energy‑balance equation."
    DTDFVocab:inputTo CalibrationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Analytical temperature prediction model B with four free parameters, accounting for heat‑bed thermal inertia."
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine, CoSimulationEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Virtual‑to‑physical interaction is performed by the controller running on the Raspberry Pi, which subscribes to command messages from the RabbitMQ communication server and forwards actuation commands for the fan and the heatbed to the low‑level driver. The controller also publishes its current control state back to RabbitMQ, enabling the physical twin to be driven according to the digital twin’s decisions."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The incubator Digital Twin follows a centralized orchestration pattern built around a RabbitMQ message broker. The physical twin (PT) is instrumented with a low‑level driver that reads temperature sensors and publishes measurement messages to RabbitMQ. A cyber component (the controller) subscribes to these messages, executes a bang‑bang control law, and publishes actuation commands (fan and heat‑bed on/off) back to the broker. Additional DT services—calibration algorithms, monitors, anomaly‑detection filters and visualization dashboards—listen to the same message streams, consume data, and optionally publish derived information (e.g., calibrated parameters, Kalman‑filter estimates). All cyber components run on a Raspberry Pi or associated host machines, and coordination is achieved through the shared RabbitMQ topic/queue infrastructure, allowing synchronous or asynchronous processing of data and commands."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is governed by four explicit assumptions: (1) uniform temperature distribution inside the box ensured by the fan, (2) negligible heat accumulation in box walls, (3) constant specific heat capacity of the enclosed air, and (4) the majority of electrical power is converted to heat for the air, ignoring heat absorbed by the heat‑bed and heat generated by the fan. Validity is evaluated by comparing Model A and Model B against experimental temperature traces, with Model B shown to more accurately capture the heat‑bed’s thermal inertia. Calibration procedures serve to quantify and reduce uncertainty in model parameters using the measured temperature data, thereby addressing the uncertainties introduced by the simplifying assumptions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection between the physical and cyber elements is based on a RabbitMQ message broker. RabbitMQ serves as the communication backbone; the low‑level driver, the controller and other DT modules connect to it using RabbitMQ’s standard messaging interface. The broker is described as mature, lightweight and easy to deploy on premises or in the cloud."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The documents state that the RabbitMQ communication server may be deployed either on‑premises or in a cloud environment, and that Digital Twin components (e.g., visualization dashboard, calibration engine) run on machines that can connect to this broker. No explicit details are given regarding computational or storage capacities, scalability mechanisms, deployment models (such as containers or virtual machines), or availability guarantees beyond the broker’s own capabilities."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is realized via the RabbitMQ message broker using the AMQP protocol. The low‑level driver and controller expose their telemetry and control interfaces as RabbitMQ messages, enabling other applications (e.g., dashboards, data‑logging services, or external analytics platforms) to subscribe to or publish on the same topics. No additional enterprise‑level standards or APIs are described; the DT relies exclusively on RabbitMQ for interoperability and data exchange with any external consumer that implements AMQP."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The incubator DT incorporates several safety mechanisms documented in the case study. The low‑level driver embeds a 'safe protocol' that enforces a safe state for the physical twin when abnormal conditions are detected. The DT includes runtime monitors that continuously evaluate sensor data against configured lower‑limit (LL) and upper‑limit (UL) temperature thresholds, flagging violations for human or automated intervention. Anomaly detection is performed by a Kalman‑filter‑based estimator that fuses measured sensor data with Model B to estimate the unmeasured heat‑bed temperature and to identify deviations from expected behavior. Calibration algorithms update model parameters in real time, and the DT framework can trigger reconfiguration of the controller when safety limits are breached. Communication between components uses RabbitMQ as a message broker, but no specific authentication or encryption mechanisms are described."
]