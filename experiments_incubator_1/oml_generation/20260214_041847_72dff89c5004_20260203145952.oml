// C3: Physical sensing component
instance VehicleSensorSuite : DTDFVocab:SensingComponent [
    base:desc "Collection of vehicle‑mounted sensors that generate temporally‑sampled data streams used for calibration, monitoring, and control."
    DTDFVocab:producedData VehicleDataTransmitted
]

// C4: Physical‑to‑virtual interaction
instance VehicleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSensorSuite
]

// C10: Data
instance VehicleOperationalData : DTDFVocab:Data [
    base:desc "Aggregated vehicle operational data including kinematic state, force responses, and raw sensor measurements."
    DTDFVocab:fromData VehicleDataTransmitted
    DTDFVocab:inputTo SimulationEngineEnabler, CalibrationEnabler, MonitoringEnabler, OptimizationEnabler
]

// C10: Models
instance VehicleDynamicBehaviorModel : DTDFVocab:Model [
    base:desc "Differential‑equation model that captures vehicle kinematic and force‑response characteristics."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance VehicleStaticGeometryModel : DTDFVocab:Model [
    base:desc "CAD‑based geometric model detailing wheel radii, chassis shape, and vehicle styling."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance VehicleCalibrationAlgorithmModel : DTDFVocab:Model [
    base:desc "Calibration algorithm that iteratively adjusts model parameters to align with observed measurements."
    DTDFVocab:inputTo CalibrationEnabler
]

instance VehicleOptimizationAlgorithmModel : DTDFVocab:Model [
    base:desc "Optimization solver that computes optimal control actions and system parameter adjustments."
    DTDFVocab:inputTo OptimizationEnabler
]

// C11: Enablers
instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Execution engine that runs dynamic and geometric models using incoming vehicle data."
    DTDFVocab:enables ModelExecutionService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Runtime component that executes calibration algorithms on streaming data."
    DTDFVocab:enables CalibrationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Runtime component that runs fault‑detection, supervisory control, and safety monitoring logic."
    DTDFVocab:enables MonitoringService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Runtime component that evaluates optimization solutions and recommends control adjustments."
    DTDFVocab:enables OptimizationService
]

// C6: Services
instance ModelExecutionService : DTDFVocab:Service [
    base:desc "Service that executes vehicle models to generate state estimates."
    DTDFVocab:provides StateEstimateInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that applies calibration updates to model parameters."
    DTDFVocab:provides CalibrationStatusInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors for safety and performance violations and triggers fault detectors."
    DTDFVocab:provides FaultDetectionInsight, ManualPhysicalTwinUpdateAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that computes optimal control suggestions and updates system parameters."
    DTDFVocab:provides OptimalControlInsight, AutomaticPhysicalTwinUpdateAction
]

// C17: Insights
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating a detected fault or safety violation in the physical twin."
]

instance OptimalControlInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting optimal control actions to improve performance or safety."
]

instance StateEstimateInsight : DTDFVocab:Insight [
    base:desc "Estimated current state of the vehicle derived from dynamic models."
]

instance CalibrationStatusInsight : DTDFVocab:Insight [
    base:desc "Status report indicating the results and convergence of the latest calibration routine."
]

// C17: Actions
instance AutomaticPhysicalTwinUpdateAction : DTDFVocab:Action [
    base:desc "Automatically applied update to the physical twin based on optimization outputs."
    DTDFVocab:IsAutomatic true
]

instance ManualPhysicalTwinUpdateAction : DTDFVocab:Action [
    base:desc "Human‑initiated update to the physical twin following monitoring alerts."
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A Digital Twin system is conceived as a framework that integrates data streams from sensors, model representations of the physical system and its environment, and algorithmic components such as calibration, monitoring, and decision support. These components coordinate through a central orchestrator that updates model parameters, evaluates safety and performance metrics, and triggers human or automated interventions."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle starts with the creation of models describing the CPS and its environment, followed by integration of these models into the DT once the Physical Twin is deployed. During operation a calibration phase updates model parameters using sensor data collected over time, providing best‑estimate parameter values. The calibrated models drive monitoring algorithms that check system performance against safety and optimality criteria; whenever a violation is detected, the system (human or algorithm) may trigger corrective actions on the Physical Twin. This continuous loop of model integration, calibration, monitoring, and intervention constitutes the full lifecycle governance of the DT."
]