// Sensing components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted inside the incubator to monitor internal air temperature (sensor 1)."
    DTDFVocab:producedData InternalTempMessage1
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted inside the incubator to monitor internal air temperature (sensor 2)."
    DTDFVocab:producedData InternalTempMessage2
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted outside the incubator to monitor ambient temperature."
    DTDFVocab:producedData ExternalTempMessage
]

// Data transmitted messages
instance InternalTempMessage1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1
]

instance InternalTempMessage2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor2
]

instance ExternalTempMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

// Data instances
instance InternalTemperatureData1 : DTDFVocab:Data [
    base:desc "Raw temperature reading from internal sensor 1 (°C)."
    DTDFVocab:fromData InternalTempMessage1
    DTDFVocab:inputTo LowLevelDriverEnabler, CalibrationAlgorithmEnabler, KalmanFilterEnabler, VisualizationEnabler, SelfAdaptationEnabler
]

instance InternalTemperatureData2 : DTDFVocab:Data [
    base:desc "Raw temperature reading from internal sensor 2 (°C)."
    DTDFVocab:fromData InternalTempMessage2
    DTDFVocab:inputTo LowLevelDriverEnabler, CalibrationAlgorithmEnabler, KalmanFilterEnabler, VisualizationEnabler, SelfAdaptationEnabler
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Raw temperature reading from external ambient sensor (°C)."
    DTDFVocab:fromData ExternalTempMessage
    DTDFVocab:inputTo LowLevelDriverEnabler, CalibrationAlgorithmEnabler, KalmanFilterEnabler, VisualizationEnabler, SelfAdaptationEnabler
]

// Acting components
instance ResistiveHeatBed : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed providing on/off heating inside the incubator."
]

instance InternalFan : DTDFVocab:ActingComponent [
    base:desc "Small fan mounted inside the incubator to homogenise air temperature (on/off)."
]

// Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model A based on all four modelling assumptions; two free parameters."
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, KalmanFilterEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Analytical thermal model B relaxes Assumption 4 (heat‑bed does not absorb heat); four free parameters."
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, KalmanFilterEnabler, CoSimulationEnabler
]

// Enablers
instance LowLevelDriverEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level driver abstracts sensor/actuator communication, enforces safe protocol, and publishes data via RabbitMQ."
    DTDFVocab:enables RealTimeVisualizationService
]

instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Automated calibration routine that consumes temperature data to estimate free parameters of Model A and Model B."
    DTDFVocab:enables CalibrationService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter algorithm fuses Model B predictions with measured temperatures for heat‑bed state estimation and anomaly detection."
    DTDFVocab:enables AnomalyDetectionService
]

instance CoSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Co‑simulation capability replays historical or live PT data with calibrated models for what‑if analysis."
    DTDFVocab:enables WhatIfSimulationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Time‑series database and dashboard ingest controller and driver messages for real‑time incubator status visualization."
    DTDFVocab:enables RealTimeVisualizationService
]

instance SelfAdaptationEnabler : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop detects behavioral changes, triggers data‑gathering experiments, recalibrates Model B, updates Kalman filter, and reconfigures controller."
    DTDFVocab:enables SelfAdaptationService
]

// Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of incubator status on a dashboard."
    DTDFVocab:provides Insight_TemperatureMonitoring
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Performs on‑demand calibration of thermal models using fresh temperature data."
    DTDFVocab:provides Insight_ModelAccuracyImprovement
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Detects anomalies and estimates unseen heat‑bed temperature using Kalman filter."
    DTDFVocab:provides Insight_AnomalyDetection
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Executes what‑if simulations via co‑simulation to evaluate alternative controller parameters."
    DTDFVocab:provides Insight_WhatIfAnalysis
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Orchestrates self‑adaptation loop: data gathering, re‑calibration, filter update, and controller re‑configuration."
    DTDFVocab:provides Action_ReconfigureController, Action_ScheduleDataExperiment
]

// Insights
instance Insight_TemperatureMonitoring : DTDFVocab:Insight [
    base:desc "Enables operators to monitor and maintain target temperature in real time."
]

instance Insight_ModelAccuracyImprovement : DTDFVocab:Insight [
    base:desc "Improves predictive accuracy of thermal models for better control decisions."
]

instance Insight_AnomalyDetection : DTDFVocab:Insight [
    base:desc "Alerts when measured temperatures deviate from Kalman‑filter predictions, indicating possible faults."
]

instance Insight_WhatIfAnalysis : DTDFVocab:Insight [
    base:desc "Supports exploration of alternative controller settings and their impact on temperature stability."
]

// Actions
instance Action_ReconfigureController : DTDFVocab:Action [
    base:desc "Automatically updates bang‑bang controller thresholds, heating and waiting durations based on new model parameters."
    DTDFVocab:IsAutomatic true
]

instance Action_ScheduleDataExperiment : DTDFVocab:Action [
    base:desc "Schedules and executes data‑gathering experiments to collect fresh temperature data for recalibration."
    DTDFVocab:IsAutomatic true
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains ResistiveHeatBed, InternalFan, InternalTemperatureSensor1, InternalTemperatureSensor2, ExternalTemperatureSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital Twin components send control commands (e.g., turn fan on/off, start heating, set heating duration H, waiting duration C, adjust lower/upper temperature limits LL/UL) as RabbitMQ messages to the controller. The controller, implemented as a bang‑bang style controller, receives these messages from the RabbitMQ server, translates them into actuator commands, and forwards them to the low‑level driver, which applies them to the physical actuators (fan and heat‑bed). The low‑level driver incorporates a safe protocol that validates commands before execution and reports the resulting control state back to RabbitMQ, providing execution confirmation and feedback to the DT."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Synchronization between the Physical Twin and Digital Twin components is realised through a RabbitMQ message broker. The low‑level driver periodically reads temperature sensors and publishes the measurements to RabbitMQ; the controller subscribes to these measurement messages and publishes command messages for the fan and heat‑bed. DT services such as the real‑time visualisation dashboard, Kalman‑filter based anomaly detector, and on‑demand calibration consume the same streams, enabling near‑real‑time operation. The documents do not provide explicit sampling rates, latency bounds, or temporal granularity, only that the driver performs periodic reads."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is orchestrated as a component‑based system where data, models and algorithms are separate services coordinated by a central RabbitMQ communication server. Sensors feed data to a low‑level driver, which forwards measurements to RabbitMQ; the controller receives the data, computes control actions and publishes its state. Calibration algorithms subscribe to the same streams to update model parameters, while monitors subscribe to detect safety or performance violations. Humans or higher‑level algorithms can trigger re‑configuration. This matches the generic CPS‑based Digital Twin pattern (Fig. 1) with a centralized message broker mediating all interactions."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The fidelity of the digital twin models is governed by four explicit modelling assumptions: (1) uniform temperature distribution inside the box, ensured by the internal fan; (2) negligible heat accumulation in the box walls; (3) constant specific heat capacity of the air; and (4) nearly all electrical power is converted to heat transferred directly to the air (Model A) – Model B relaxes assumption 4. Model validity is established experimentally by calibrating the free parameters against the sensor data; calibration experiments showed that Model B provides a more accurate prediction of the heat‑bed’s thermal inertia. Calibration algorithms update the model parameters using the collected temperature measurements, thereby maintaining consistency between the physical twin and its digital representation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All software components (low‑level driver, controller, DT modules) communicate via a centrally deployed RabbitMQ message broker. RabbitMQ provides the synchronization and message‑passing backbone; each component publishes to or subscribes from the broker. The deployment is described as lightweight and easy to install on‑premise or in the cloud, suitable for large numbers of users. The network thus consists of a Raspberry Pi hosting the controller and driver connected to the RabbitMQ server over the local network."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external components is achieved through the RabbitMQ message broker, which enables publish/subscribe exchange of sensor data and controller commands. The DT can forward these streams to a time‑series database and a dashboard for real‑time visualisation, and can supply historical or live data to co‑simulation modules for what‑if simulations, as outlined in the digital‑twinning goals. No further external systems or interoperability standards are specified."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT incorporates safety mechanisms through a low‑level driver that embeds a safe protocol to keep the physical incubator in a safe state. Communication among the controller, low‑level driver, and the DT is performed via a RabbitMQ message broker, which provides reliable, lightweight messaging deployed on‑premises or in the cloud. The documents do not describe additional cybersecurity measures such as authentication, encryption, access‑control, or threat mitigation; thus, security considerations are limited to the safe protocol in the driver and the use of RabbitMQ for dependable data exchange."
]