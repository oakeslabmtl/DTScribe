// C3: Physical sensing components
instance BoxTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer inside the incubator box (‑55 °C to +125 °C, ±0.5 °C accuracy 10 °C‑85 °C)"
    DTDFVocab:producedData IncubatorTempDataTransmitted
    base:isContainedIn IncubatorEnvironment
]

instance BoxTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer inside the incubator box (second sensor, same specs as above)"
    DTDFVocab:producedData IncubatorTempDataTransmitted
    base:isContainedIn IncubatorEnvironment
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring ambient temperature outside the box"
    DTDFVocab:producedData IncubatorTempDataTransmitted
    base:isContainedIn IncubatorEnvironment
]

// C4: Physical-to-virtual interaction (data transmitted)
instance IncubatorTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxTemperatureSensor1, BoxTemperatureSensor2, AmbientTemperatureSensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature readings (°C) from the three DS18S20 sensors, periodically read by the Raspberry‑Pi low‑level driver"
    DTDFVocab:fromData IncubatorTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker, PythonSciPyEngine
]

// C10: Models/Data
instance AirSingleParameterModel : DTDFVocab:Model [
    base:desc "Model A – single‑parameter air thermal model (parameter C_air) for incubator temperature dynamics"
    DTDFVocab:inputTo PythonSciPyEngine
]

instance HeatBedDynamicModel : DTDFVocab:Model [
    base:desc "Model B – four‑parameter model (C_air, C_heater, G_heater, G_box) including heat‑bed dynamics"
    DTDFVocab:inputTo PythonSciPyEngine
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP message broker running on the Raspberry Pi, transports sensor telemetry to DT services"
    DTDFVocab:enables SafetyMonitoringService, SensorVisualizationService, TemperatureSimulationService, ControlCommandService
]

instance PythonSciPyEngine : DTDFVocab:Enabler [
    base:desc "Python runtime with SciPy optimisation library, performs non‑linear least‑squares calibration of model parameters"
    DTDFVocab:enables ParameterCalibrationService
]

instance RaspberryPiController : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B controller executing low‑level drivers and issuing GPIO commands to the PCB"
    DTDFVocab:enables ControlCommandService
]

// C6: Services
instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature against safety and performance thresholds"
    DTDFVocab:provides SafetyAlertInsight, AdjustSetpointAction
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Non‑linear least‑squares calibration of C_air, C_heater, G_heater, G_box using temperature trajectories"
    DTDFVocab:provides CalibrationUpdateInsight
]

instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Simulation of incubator temperature dynamics using Model A and Model B"
    DTDFVocab:provides TemperaturePredictionInsight
]

instance SensorVisualizationService : DTDFVocab:Service [
    base:desc "Visualization of live sensor temperature data via the communication server"
    DTDFVocab:provides VisualizationInsight
]

instance ControlCommandService : DTDFVocab:Service [
    base:desc "Issuing control commands to actuators (heat‑bed and ventilation fan) through GPIO"
    DTDFVocab:provides AdjustSetpointAction, ModifyHardwareAction
]

// C17: Insights/Actions
instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when temperature exceeds defined safety or performance limits"
]

instance CalibrationUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight that calibrated model parameters (C_air, G_box, etc.) have been updated"
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory from the selected simulation model"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight presented through live temperature plots in the UI"
]

instance AdjustSetpointAction : DTDFVocab:Action [
    base:desc "Operator‑initiated adjustment of heater or fan set‑points"
    DTDFVocab:IsAutomatic false
]

instance ModifyHardwareAction : DTDFVocab:Action [
    base:desc "Operator decision to modify hardware configuration (e.g., change MOSFET duty cycle)"
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed (heating element) switched via MOSFET power stage on the custom PCB"
]

instance VentilationFanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal circulation fan switched via MOSFET power stage on the custom PCB"
]

// C15: Environment and components
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains IncubatorBox, HeatBed, VentilationFan, CustomPCB,
                BoxTemperatureSensor1, BoxTemperatureSensor2, AmbientTemperatureSensor
]

instance IncubatorBox : DTDFVocab:Component [
    base:desc "Polystyrene insulated box (~0.03 m³ volume) housing the thermal incubator interior"
]

instance HeatBed : DTDFVocab:Component [
    base:desc "Resistive heating element (heat‑bed) providing controlled thermal input"
]

instance VentilationFan : DTDFVocab:Component [
    base:desc "Internal circulation fan for air mixing within the incubator"
]

instance CustomPCB : DTDFVocab:Component [
    base:desc "Custom printed circuit board with MOSFETs and optocouplers for power switching"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (heat‑bed ON/OFF, fan ON/OFF, and set‑point parameters) to RabbitMQ; the controller on the Raspberry Pi subscribes to these messages and drives the MOSFET/optocoupler circuitry to actuate the physical devices."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system architecture consists of the Physical Twin (sensors, actuators, PCB, Raspberry Pi) connected to a RabbitMQ server; the DT comprises components that subscribe to sensor topics for monitoring, run the simulation/calibration models, and publish actuator commands, forming a closed‑loop cyber‑physical loop."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the design stage (model development), the calibration stage (parameter identification using experimental data), and the operation stage (real‑time monitoring, simulation and control during runtime)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through explicit assumptions (uniform temperature, negligible wall heat, constant air specific heat, etc.) and validated by experiments testing temperature uniformity and by comparing Model A and Model B predictions against measured data. Calibration minimizes residual error using a least‑squares cost function."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses the RabbitMQ message broker (AMQP protocol) running on the Raspberry Pi, leveraging the Pi's built‑in Wi‑Fi/Bluetooth for network connectivity."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT services (RabbitMQ server, simulation and calibration code) are hosted directly on the Raspberry Pi 4; all source code, hardware schematics, and documentation are publicly available in a GitHub repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the device in a safe state, and the controller continuously monitors temperature limits (LL, UL) to prevent overheating; safety is enforced before executing actuations."
]