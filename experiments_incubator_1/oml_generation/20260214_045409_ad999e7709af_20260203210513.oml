// -------- C3: Physical Sensing Components --------
instance InternalTemperatureSensorOne : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire temperature sensor mounted inside the insulated box near the heatbed ☑ accuracy ±0.5 °C over 10 °C–85 °C range"
    DTDFVocab:producedData InternalTempDataTransmittedOne
]

instance InternalTemperatureSensorTwo : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire temperature sensor mounted inside the insulated box near the heatbed, second sensor"
    DTDFVocab:producedData InternalTempDataTransmittedTwo
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire temperature sensor mounted externally next to the box to capture ambient temperature"
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// -------- C4: Data Transmitted --------
instance InternalTempDataTransmittedOne : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensorOne
]

instance InternalTempDataTransmittedTwo : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensorTwo
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

// -------- Data Instances --------
instance InternalTempDataOne : DTDFVocab:Data [
    base:desc "Raw numeric temperature from internal sensor #1 received by the twin"
    DTDFVocab:fromData InternalTempDataTransmittedOne
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler
]

instance InternalTempDataTwo : DTDFVocab:Data [
    base:desc "Raw numeric temperature from internal sensor #2 received by the twin"
    DTDFVocab:fromData InternalTempDataTransmittedTwo
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Raw numeric ambient temperature from external sensor received by the twin"
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler
]

// -------- C2: Acting Components --------
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed (heater) that delivers thermal energy to the content of the styrofoam box"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan that circulates air inside the insulated enclosure to distribute heat uniformly"
]

// -------- C11: Enablers --------
instance DataAcquisitionEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ messaging interface that receives pushed temperature readings from the Raspberry Pi"
    DTDFVocab:enables MonitoringService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime using SciPy that hosts the two‑parameter and four‑parameter thermal models"
    DTDFVocab:enables PredictiveModelingService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Python calibration routine that applies non‑linear least squares to update model parameters"
    DTDFVocab:enables CalibrationService
]

instance ActuatorControlEnabler : DTDFVocab:Enabler [
    base:desc "Raspberry Pi control interface that issues on/off commands to the heatbed and fan"
    DTDFVocab:enables ActuatorControlService
]

// -------- C6: Services --------
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring that checks temperature against safety thresholds and model predictions"
    DTDFVocab:provides FaultDetectionInsight, HeatbedBangBangControlAction
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Automated parameter calibration that uses the latest sensor data to refine the thermal models"
    DTDFVocab:provides CalibrationInsight
]

instance PredictiveModelingService : DTDFVocab:Service [
    base:desc "Forward simulation of temperature dynamics using the calibrated thermal models"
    DTDFVocab:provides TemperatureForecastInsight
]

instance ActuatorControlService : DTDFVocab:Service [
    base:desc "Bang‑bang control of the heatbed and fan based on monitored temperature and model forecasts"
    DTDFVocab:provides HeatbedBangBangControlAction, FanSpeedControlAction
]

// -------- C17: Insights & Actions --------
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of safety violations when internal temperature leaves the target band despite actuator activity"
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Updated model parameters with confidence metrics derived from least‑squares fit to recent temperature data"
]

instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory over the next 5 minutes based on current state and model parameters"
]

instance HeatbedBangBangControlAction : DTDFVocab:Action [
    base:desc "Command to turn the heatbed on or off based on Bang‑Bang logic relative to target temperature and forecast"
    DTDFVocab:IsAutomatic true
]

instance FanSpeedControlAction : DTDFVocab:Action [
    base:desc "Command to adjust fan speed to homogenize temperature distribution inside the enclosure"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands for the heater and fan are sent from the digital twin via RabbitMQ to the low‑level driver on the Raspberry Pi. The driver checks the RabbitMQ server for such commands and forwards the appropriate actuator signals to the heater and fan. The bang‑bang controller on the Pi generates command messages based on the temperature thresholds (LL, UL, H, C). No explicit message format, validation, authentication, or conflict‑resolution details are provided in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is orchestrated by a Raspberry Pi controller that runs the low‑level driver and a bespoke communication server (RabbitMQ). It consumes sensor data (temperature readings) in real‑time, updates the simulation model (Model B with four free parameters) by a non‑linear least‑squares calibration routine, and runs a Kalman filter to estimate the unmeasured heat‑bed temperature. Co‑simulation modules retrieve historical or live data from the PT and execute what‑if scenarios, while a dashboard displays real‑time state. This logical layering couples cyber and physical models under a single, centrally managed framework."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle for the incubator begins with *Data Acquisition*—continuous readings from two inside temperature sensors and an outside sensor, streamed via the Raspberry Pi to a cloud or local storage. Next is *Model Development*, where two thermal simulation models (one with two free parameters and one with four) are implemented in an open‑source repository (see https://github.com/INTO-CPS-Association/example-incubator). *Model Calibration* follows, utilizing a calibration algorithm that fuses real‑time sensor data with the parameterized models to obtain the most accurate physical–cyber representation. The *Simulation* phase runs the calibrated models to predict future temperature trajectories and evaluate control actions. *Monitoring* then compares simulated predictions with live sensor data, feeding safety and optimality checks back into the system. Finally, *Decision Support* allows human operators or automated supervisors to modify the physical twin (e.g., adjust heater duty cycle) based on detected violations or optimization outputs, thereby completing the loop. Transition management is handled via continuous integration of new sensor data into the model repository, while governance is enforced by version control on GitHub and regular model validation against experimental results."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by comparing the two analytical models against experimental temperature profiles. The four‑parameter model demonstrates superior prediction of the heatbed’s thermal inertia, making it the preferred model for subsequent DT development. Calibration involves fitting free parameters to measured sensor data, thus grounding the model in physical reality. Validation methods include experimental evaluation of temperature control performance and monitoring of safety/marginal violations. Uncertainty sources, such as unmodeled heat losses and sensor noise, are implicitly addressed through continual monitoring and calibration updates. Error detection is performed by the DT monitors, which flag deviations from acceptable temperature ranges or predicted behavior, prompting corrective action by the controller or human operators. Quality assurance is supported by publicly available open‑source hardware and software specifications, facilitating reproducibility and independent verification.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin communication relies on a RabbitMQ message broker deployed locally on the Raspberry Pi. All interactions between the DT components, controller, and low‑level driver occur over RabbitMQ queues, providing synchronization and message passing. The documents describe RabbitMQ as a mature, lightweight, on‑premises or cloud‑compatible broker, but do not specify network topology, bandwidth, latency, redundancy, or security protocols beyond the use of RabbitMQ."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital‑twin software—including RabbitMQ, the controller, and the low‑level driver—is run on a Raspberry Pi (edge/on‑premises). No separate cloud, container, or other deployment infrastructure is described, and the documents give no explicit computational or storage requirements beyond the presence of the Raspberry Pi."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Within the incubator, temperature sensors (DS18S20) are bus‑connected via a 1‑Wire interface, and all sensor and control messages are transmitted through a RabbitMQ broker. No additional external enterprise protocols such as OPC‑UA or MQTT are referenced in the documents."
]