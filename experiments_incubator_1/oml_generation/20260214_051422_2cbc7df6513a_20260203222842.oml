// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET switch controlling the heatbed via optocoupler, driven by the Raspberry Pi 4 Model B"
]
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET switch controlling the circulating fan via optocoupler, driven by the Raspberry Pi 4 Model B"
]

// C3: Physical sensing components
instance IncubatorTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor inside the incubator (64‑bit serial 00:51:12:....)"
    DTDFVocab:producedData IncubatorTempData1
]
instance IncubatorTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor inside the incubator (64‑bit serial 01:23:45:....)"
    DTDFVocab:producedData IncubatorTempData2
]
instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor measuring ambient temperature outside the incubator"
    DTDFVocab:producedData AmbientTempData
]

// C4: Physical‑to‑virtual interaction
instance IncubatorTempData1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorTempSensor1
]
instance IncubatorTempData2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorTempSensor2
]
instance AmbientTempData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]
instance HeatbedStatusData : DTDFVocab:DataTransmitted [
]
instance FanStatusData : DTDFVocab:DataTransmitted [
]

// C10: Data
instance IncubatorTempSeriesData1 : DTDFVocab:Data [
    base:desc "Time‑series of temperature readings from IncubatorTempSensor1"
    DTDFVocab:fromData IncubatorTempData1
    DTDFVocab:inputTo SimulationEnabler
]
instance IncubatorTempSeriesData2 : DTDFVocab:Data [
    base:desc "Time‑series of temperature readings from IncubatorTempSensor2"
    DTDFVocab:fromData IncubatorTempData2
    DTDFVocab:inputTo SimulationEnabler
]
instance AmbientTempSeriesData : DTDFVocab:Data [
    base:desc "Ambient temperature time‑series from AmbientTempSensor"
    DTDFVocab:fromData AmbientTempData
    DTDFVocab:inputTo SimulationEnabler
]
instance HeatbedActuatorStatus : DTDFVocab:Data [
    base:desc "Current ON/OFF status of the heatbed MOSFET switch"
    DTDFVocab:fromData HeatbedStatusData
    DTDFVocab:inputTo RabbitMQBrokerEnabler
]
instance FanActuatorStatus : DTDFVocab:Data [
    base:desc "Current ON/OFF status of the fan MOSFET switch"
    DTDFVocab:fromData FanStatusData
    DTDFVocab:inputTo RabbitMQBrokerEnabler
]

// C10: Models
instance ModelAInstance : DTDFVocab:Model [
    base:desc "Dynamic thermal Model A derived from energy balance equations"
    DTDFVocab:inputTo SimulationEnabler
]
instance ModelBInstance : DTDFVocab:Model [
    base:desc "Dynamic thermal Model B derived from energy balance equations"
    DTDFVocab:inputTo SimulationEnabler
]

// C11: Enablers
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python simulation environment executing Models A and B"
    DTDFVocab:enables PredictiveSimulationService
]
instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Local RabbitMQ AMQP broker publishing sensor and actuator data"
    DTDFVocab:enables RealTimeMonitoringService, VisualizationService
]
instance RaspberryPiControllerEnabler : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B controlling heatbed and fan via MOSFET driver board"
    DTDFVocab:enables BangBangControlService
]
instance SciPyCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "SciPy Optimize module performing nonlinear least‑squares calibration"
    DTDFVocab:enables AutomatedCalibrationService
]

// C6: Services
instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation service using calibrated Models A and B to forecast temperature"
    DTDFVocab:provides PredictedTemperatureTrendInsight
]
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time temperature monitoring service reading sensor data via RabbitMQ"
    DTDFVocab:provides CurrentTemperatureInsight
]
instance AutomatedCalibrationService : DTDFVocab:Service [
    base:desc "Automated calibration service applying SciPy nonlinear least‑squares to update model parameters"
    DTDFVocab:provides CalibratedParametersInsight, UpdateModelParametersAction
]
instance BangBangControlService : DTDFVocab:Service [
    base:desc "Bang‑bang style temperature control service commanding heatbed and fan actuators"
    DTDFVocab:provides BangBangSetTemperatureAction
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualization service displaying temperature trends and actuator states"
    DTDFVocab:provides TemperatureTrendVisualizationInsight
]

// C17: Insights
instance PredictedTemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory over next hours, enabling proactive set‑point adjustments"
]
instance CurrentTemperatureInsight : DTDFVocab:Insight [
    base:desc "Current measured temperature inside the incubator from real‑time monitoring"
]
instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Calibration results showing updated values for C_air, G_box, C_heater, G_heater"
]
instance TemperatureTrendVisualizationInsight : DTDFVocab:Insight [
    base:desc "Graphical display of temperature trends and actuator states over time"
]

// C17: Actions
instance UpdateModelParametersAction : DTDFVocab:Action [
    base:desc "Automatic update of model parameters in simulation after calibration"
    DTDFVocab:IsAutomatic true
]
instance BangBangSetTemperatureAction : DTDFVocab:Action [
    base:desc "Bang‑bang control command to adjust heatbed and fan based on set‑point"
    DTDFVocab:IsAutomatic true
]

// C17: Environment
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:contains IncubatorTempSensor1, IncubatorTempSensor2, AmbientTempSensor, HeatbedActuator, FanActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT subscribes to actuator command messages via RabbitMQ and forwards them to the Raspberry Pi controller, which outputs GPIO signals to the MOSFET driver to energise the heatbed and fan accordingly."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized architecture: the Raspberry Pi hosts the controller, low‑level driver, and RabbitMQ server; sensors feed data, while the DT component receives messages via RabbitMQ, performs modeling/calibration, and publishes actuator commands back to the Pi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design → Manufacture (hardware assembly & software deployment) → Calibration & Validation (parameter estimation, uniform temperature experiments) → Operation (runtime monitoring and control), with ability to evolve models and firmware over time."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Models rest on Assumptions 1‑4 (uniform temperature, negligible wall heat, constant specific heat, and heatbed power transfer); validation via controlled experiments; calibration using least‑squares to minimize residual error; uncertainty arises from parameter estimation and sensor accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "AMQP over TCP via RabbitMQ broker on the Raspberry Pi, with publisher/subscriber pattern between DT and PT components."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Local deployment on the Raspberry Pi 4, with all DT services (model, controller, communication server) running on the same hardware as the physical twin."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safety protocol is embedded in the low‑level driver to prevent over‑current and overheating during actuation; all messages are transmitted over the local RabbitMQ broker, minimizing external exposure. The use of opto‑isolated MOSFET drivers safeguards the Pi from high‑current faults and enhances overall system safety."
]