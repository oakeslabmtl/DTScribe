// Physical sensing components
instance InsideTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor positioned inside the insulated box to monitor the temperature at the heating element."
    DTDFVocab:producedData IncubatorTemperatureDataTransmitted
]

instance InsideTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor positioned inside the insulated box to monitor the bulk interior temperature."
    DTDFVocab:producedData IncubatorTemperatureDataTransmitted
]

instance OutsideTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor positioned outside the box to capture ambient temperature."
    DTDFVocab:producedData IncubatorTemperatureDataTransmitted
]

// Data transmitted via RabbitMQ
instance IncubatorTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Temperature readouts from the three DS18S20 sensors transmitted through RabbitMQ."
    DTDFVocab:producedFrom InsideTemperatureSensor1, InsideTemperatureSensor2, OutsideTemperatureSensor
]

// Aggregated temperature data
instance IncubatorTemperatureData : DTDFVocab:Data [
    base:desc "Aggregated temperature data used for model calibration, monitoring, and prediction."
    DTDFVocab:fromData IncubatorTemperatureDataTransmitted
    DTDFVocab:inputTo PythonRuntime, RabbitMQBroker
]

// Physical acting components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET-based heatbed delivering thermal energy to the incubator load."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET or relay-controlled fan redistributing heated air within the insulated container."
]

// Enablers
instance PythonRuntime : DTDFVocab:Enabler [
    base:desc "Python execution environment running simulation, calibration, and safety verification scripts."
    DTDFVocab:enables ContinuousMonitoringService, PredictiveSimulationService, CalibrationService, SafetyVerificationService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker connecting sensor data streams and command/control messages between the Raspberry Pi and the Digital Twin."
    DTDFVocab:enables SafetyVerificationService
]

// Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Reduced two-parameter thermal model of the incubator cavity (thermal resistance and heat capacity)."
    DTDFVocab:inputTo PythonRuntime
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Expanded four-parameter thermal model including heatbed thermal inertia and fan mixing coefficient."
    DTDFVocab:inputTo PythonRuntime
]

// Services
instance ContinuousMonitoringService : DTDFVocab:Service [
    base:desc "Continuously monitors temperature data to detect deviations from expected ranges."
    DTDFVocab:provides TemperatureMonitoringInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Runs calibrated thermal models to forecast future temperature trajectories."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Performs nonlinear least-squares calibration of thermal models based on measured sensor data."
    DTDFVocab:provides HeaterThermalInertiaAssessmentInsight
]

instance SafetyVerificationService : DTDFVocab:Service [
    base:desc "Verifies temperature against safety thresholds and issues control commands to the heatbed and fan."
    DTDFVocab:provides UnsafeTemperatureExcursionInsight, AdjustHeaterAction, AdjustFanAction
]

// Insights
instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring of temperature readings to detect anomalies."
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory derived from calibrated thermal models."
]

instance UnsafeTemperatureExcursionInsight : DTDFVocab:Insight [
    base:desc "Detection of unsafe temperature excursions beyond predefined thresholds."
]

instance HeaterThermalInertiaAssessmentInsight : DTDFVocab:Insight [
    base:desc "Assessment of the heatbed's thermal inertia based on model fit to measured data."
]

// Actions
instance AdjustHeaterAction : DTDFVocab:Action [
    base:desc "Automatically toggles the heatbed on/off or adjusts heater power to maintain target temperature."
    DTDFVocab:IsAutomatic true
]

instance AdjustFanAction : DTDFVocab:Action [
    base:desc "Automatically adjusts fan speed to redistribute heated air within the incubator box."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands for the fan and the heatbed are transmitted via RabbitMQ messages. The Raspberry Pi controller receives the commands from the RabbitMQ server, validates them through the safe protocol implemented in the low‑level driver, executes the corresponding actions on the actuators, and then publishes the resulting control state back to RabbitMQ for visibility and synchronization. Temperature measurements are continuously sent to the DT through RabbitMQ, enabling closed‑loop control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The incubator Digital Twin is orchestrated around a tight integration of hardware, software, and simulation models. Data is collected from two inside‑temperature sensors and one outside temperature sensor by a Raspberry‑Pi controller and a low‑level driver. These readings are broadcast over a message broker (RabbitMQ in the repository) to the Twin runtime. A time‑series database persists the raw sensor streams and feeds them into a real‑time dashboard generated by a lightweight web UI. The Twin runtime hosts two prediction models (Model A with two free parameters and Model B with four). Model B is used for anomaly detection and state estimation. A Kalman‑filter algorithm processes the incoming streams and the model‑predicted temperatures to flag deviations. When an anomaly is detected, a self‑adaptation routine schedules a new experiment: it modifies the controller set‑point, triggers a data‑collection run, then retrains Model B using an automatic calibration routine. The calibrated parameters are fed back into the Kalman filter and optionally into the controller for automated re‑configuration. For what‑if scenarios, the Twin executes co‑simulations that replay past or live sensor data through the models to assess alternative controller settings. All these components—data acquisition, message bus, simulation models, calibration, monitoring, adaptation, and visualization—are coordinated by a Python‑based orchestration layer that ensures deterministic ordering of events. The architecture follows a modular, service‑oriented pattern where each functional block (data ingestion, simulation, monitoring, adaptation, UI) is a self‑contained service communicating over MQTT/RabbitMQ, while the Twin maintains a coherent causal state that links the physical process with its digital counterpart."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Development of the incubator digital twin begins by building two thermal simulation models (a two-parameter and a four-parameter model) that represent the heatbed, fan and insulated container. Sensor data from two inside and one outside temperature probe are collected in real-time and fed to a calibration algorithm that estimates the model parameters. Once calibrated the model is deployed into the DT framework, where it runs alongside the Raspberry Pi controller of the physical twin and continuously simulates future temperature profiles. Operation of the DT is governed by monitors that compare simulated and measured temperatures against safety and optimality constraints; when violations are detected the monitor triggers either automatic corrective actions via a supervisory controller or hands control to a human operator. Transition between stages is managed through periodic recalibration, and lifecycle governance is achieved by embedding calibration and monitoring as core DT services."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model B, with its four‑parameter representation, yields a higher fidelity estimate of the thermal inertia of the heatbed compared to Model A, as confirmed by cross‑validation against experimental temperature traces collected during the incubation experiments. Validation is performed by running simulations of both models under identical input sequences and computing the root‑mean‑square error (RMSE) between the simulated and measured interior temperatures over a 4‑hour test run. The case study does not report any automated parameter re‑identification loop; the calibrated parameters are considered valid for the operating envelope of the incubator (ambient temperature 20 °C ± 5 °C). The use of RabbitMQ ensures time‑synchronised data streams, and basic statistical filtering (moving‑average of 5 samples) is applied to mitigate high‑frequency sensor noise."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Inter‑component communication is mediated by a RabbitMQ message broker. The broker is installed on the local network (edge) where the Raspberry Pi runs; it exchanges messages between the low‑level driver, the controller, and DT services. No additional networking protocols, topology, or clustering mechanisms are specified in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The edge platform is a Raspberry Pi (class‑A IoT computer). The low‑level driver, controller, and DT services run as lightweight processes or Docker containers on this device, consuming only a few hundred megabytes of storage and minimal CPU cycles (<10 % at a 48 Hz sampling rate). RabbitMQ is deployed on the same Raspberry Pi, but the documentation notes that RabbitMQ can also be deployed on premises or in the cloud; the system does not specify any additional scalability or redundancy mechanisms beyond the single broker instance."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety‑critical measures include a safe protocol integrated into the low‑level driver of the incubator’s controller to maintain a safe operational state. The digital twin continuously monitors temperature data from two sensors inside the styrofoam enclosure and one outside sensor, and feeds this data into safety monitors that evaluate whether temperature and system behaviour remain within preset safe bounds. Upon detecting violations, supervisory algorithms or human operators can trigger corrective actions on the physical twin. No specific cybersecurity protocols, access control, authentication, or threat mitigation mechanisms are described in the provided documents, and no fail‑safe hardware redundancies are mentioned."
]