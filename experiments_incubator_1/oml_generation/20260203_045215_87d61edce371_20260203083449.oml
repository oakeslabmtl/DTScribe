// C3: Physical sensing components
instance IncubatorInternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted inside the incubator box; range –55 °C to +125 °C, accuracy ±0.5 °C."
    DTDFVocab:producedData IncubatorInternalTempDataTransmitted1
]

instance IncubatorInternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 sensor mounted inside the incubator box; same specifications as sensor 1."
    DTDFVocab:producedData IncubatorInternalTempDataTransmitted2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor placed outside the incubator to monitor ambient room temperature; same specifications as internal sensors."
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance IncubatorInternalTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInternalTempSensor1
]

instance IncubatorInternalTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInternalTempSensor2
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// C10: Data
instance InternalTempData1 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature series from internal sensor 1."
    DTDFVocab:fromData IncubatorInternalTempDataTransmitted1
    DTDFVocab:inputTo SciPyCalibrationEngine, MonitoringEngine
]

instance InternalTempData2 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature series from internal sensor 2."
    DTDFVocab:fromData IncubatorInternalTempDataTransmitted2
    DTDFVocab:inputTo SciPyCalibrationEngine, MonitoringEngine
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature series from external ambient sensor."
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo SciPyCalibrationEngine, MonitoringEngine
]

// C2: Acting components
instance ResistiveHeatBed : DTDFVocab:ActingComponent [
    base:desc "Resistive heating element (heat‑bed) that raises the incubator chamber temperature; driven by digital output from the Raspberry Pi."
]

instance CoolingFan : DTDFVocab:ActingComponent [
    base:desc "Cooling fan that reduces chamber temperature; driven by digital output from the Raspberry Pi."
]

// C10: Models
instance TwoParameterThermalModel : DTDFVocab:Model [
    base:desc "Analytical simulation model of internal temperature dynamics based on differential heat‑transfer equations; contains two free parameters."
    DTDFVocab:inputTo SciPyCalibrationEngine, PredictionEngine
]

instance FourParameterThermalModel : DTDFVocab:Model [
    base:desc "Analytical simulation model of internal temperature dynamics with four free parameters to capture heat‑bed thermal inertia."
    DTDFVocab:inputTo SciPyCalibrationEngine, PredictionEngine
]

// C11: Enablers
instance SciPyCalibrationEngine : DTDFVocab:Enabler [
    base:desc "Python SciPy library used for calibration of thermal model parameters from sensor data."
    DTDFVocab:enables CalibrationService, OptimisationService
]

instance RabbitMQMessageBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker handling runtime data exchange between the physical incubator controller and the digital twin."
    DTDFVocab:enables DataIngestionService, CommandDispatchService
]

instance PythonControlRuntime : DTDFVocab:Enabler [
    base:desc "Python runtime on the Raspberry Pi executing control software, monitoring algorithms, and interfacing with other enablers."
    DTDFVocab:enables MonitoringService, PredictionService, VisualizationService
]

instance MonitoringEngine : DTDFVocab:Enabler [
    base:desc "Algorithmic engine that consumes temperature data for health monitoring and fault detection."
    DTDFVocab:enables MonitoringService
]

instance PredictionEngine : DTDFVocab:Enabler [
    base:desc "Engine that uses calibrated thermal models to predict future temperature evolution."
    DTDFVocab:enables PredictionService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuously monitors internal and external temperatures, detects faults and safety violations."
    DTDFVocab:provides TemperatureHealthInsight, SafetyViolationInsight, NotifyOperatorAction
]

instance SafetyVerificationService : DTDFVocab:Service [
    base:desc "Verifies that temperature predictions stay within predefined safety thresholds."
    DTDFVocab:provides SafetyViolationInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Predicts temperature evolution under current operating conditions using calibrated models."
    DTDFVocab:provides PredictedTemperatureInsight
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Optimises heating parameters by calibrating model parameters and suggests set‑point adjustments."
    DTDFVocab:provides OptimalParameterInsight, AdjustHeatingAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualises system state, temperature trends, and model predictions for operators."
    DTDFVocab:provides VisualisationInsight
]

instance CommandDispatchService : DTDFVocab:Service [
    base:desc "Exposes actuation commands to higher‑level components; translates decisions into digital outputs for heat‑bed and fan."
    DTDFVocab:provides TriggerCoolingAction, AdjustHeatingAction
]

instance DataIngestionService : DTDFVocab:Service [
    base:desc "Ingests streamed temperature data from sensors via RabbitMQ into the digital twin."
    DTDFVocab:provides DataReceptionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibrates thermal model parameters using incoming temperature data."
    DTDFVocab:provides CalibrationInsight, AdjustHeatingAction
]

// C17: Insights
instance TemperatureHealthInsight : DTDFVocab:Insight [
    base:desc "Assessment of temperature sensor health and consistency between internal sensors."
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature exceeding safety limits or other unsafe operating conditions."
]

instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Forecast of internal temperature trajectory based on calibrated thermal model."
]

instance OptimalParameterInsight : DTDFVocab:Insight [
    base:desc "Identification of optimal heating parameters that minimize temperature error."
]

instance VisualisationInsight : DTDFVocab:Insight [
    base:desc "Aggregated visual representation of current temperatures, model predictions, and alerts."
]

instance DataReceptionInsight : DTDFVocab:Insight [
    base:desc "Confirmation that sensor data have been successfully received and stored."
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Indicates successful calibration of model parameters and their confidence levels."
]

// C17: Actions
instance NotifyOperatorAction : DTDFVocab:Action [
    base:desc "Send a notification to the human operator about a safety violation or fault."
    DTDFVocab:IsAutomatic true
]

instance TriggerCoolingAction : DTDFVocab:Action [
    base:desc "Command the cooling fan to activate to reduce chamber temperature."
    DTDFVocab:IsAutomatic true
]

instance AdjustHeatingAction : DTDFVocab:Action [
    base:desc "Adjust heat‑bed power set‑point to achieve the target temperature."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin can issue control actions to the physical incubator (e.g., adjust heat‑bed power or fan speed) when monitors detect violations. Commands are generated by algorithms and sent to the Raspberry Pi which actuates the hardware. Specific command formats, validation, authentication, feedback, conflict resolution, or execution confirmation mechanisms are not described in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin follows a layered orchestration pattern as illustrated in Figure 1 of the documents. Sensor data collected from the Physical Twin is streamed into the DT, where calibration algorithms continuously update the parameters of the cyber‑physical system (CPS) and environment models. The refreshed models are then consumed by monitoring components that evaluate safety and optimality criteria. If a violation is detected, decision logic—either human operators or automated algorithms—may initiate corrective actions on the Physical Twin. This architecture integrates data acquisition, model management, algorithmic processing, and feedback loops within a single coordinated framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing predicted temperature trajectories against the measured temperature from the incubator. Experiments showed that the four‑parameter model more accurately reproduces the thermal inertia of the heat‑bed, thereby meeting higher fidelity requirements. Validation is performed through empirical testing and calibration algorithms that estimate the model parameters. Uncertainty originates from sensor noise and parameter estimation errors; the calibration step provides updated best‑estimate parameters to reduce these uncertainties."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The incubator DT relies on a hybrid network topology: sensors communicate with the Raspberry Pi over a wired 1‑Wire bus, while the Pi connects to the wider Digital Twin infrastructure via its built‑in Wi‑Fi using a TCP/IP network. All higher‑level Twin‑to‑PT messaging (both sensor data publication and actuator command delivery) uses the AMQP protocol implemented by a RabbitMQ broker. The expected bandwidth is modest (a few kilobytes per second) given the low data rate of temperature readings and discrete actuator commands, and latency is limited to the Wi‑Fi round‑trip time (tens of milliseconds). Reliability is enhanced by RabbitMQ’s message acknowledgement and persistence features; optional TLS encryption can be configured for secure transport, though the document does not specify exact security settings."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin incorporates safety‑focused mechanisms such as calibration algorithms that continuously update the cyber‑physical system and environment models with the best‑estimate parameters, and monitoring components that assess whether the system is operating safely and optimally. When a safety violation is detected, the DT can trigger human operators or automated algorithms to intervene and modify the Physical Twin. These safety considerations are described as part of the DT framework, but no explicit cybersecurity protocols, access‑control mechanisms, authentication systems, threat‑mitigation strategies, fail‑safe mechanisms, or risk‑assessment procedures are detailed in the document."
]