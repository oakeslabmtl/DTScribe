// C2: Acting Component
instance ResistiveHeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that raises the internal temperature of the insulated incubator power settings are remotely controllable via the Raspberry Pi controller."
]

// C3: Physical sensing components
instance InsideIncubatorTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "Maxim Integrated DS18S20 high‑precision 1‑Wire digital thermometer mounted inside the incubator chamber, operating over –55 °C to +125 °C with ±0.5 °C accuracy."
    DTDFVocab:producedData IncubatorTemperatureDataStream
]

instance InsideIncubatorTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Maxim Integrated DS18S20 high‑precision 1‑Wire digital thermometer mounted inside the incubator chamber, operating over –55 °C to +125 °C with ±0.5 °C accuracy."
    DTDFVocab:producedData IncubatorTemperatureDataStream
]

instance OutsideIncubatorTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Maxim Integrated DS18S20 high‑precision 1‑Wire digital thermometer mounted outside the incubator enclosure, operating over –55 °C to +125 °C with ±0.5 °C accuracy."
    DTDFVocab:producedData IncubatorTemperatureDataStream
]

// C4: Physical‑to‑virtual interaction
instance IncubatorTemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideIncubatorTemperatureSensor1, InsideIncubatorTemperatureSensor2, OutsideIncubatorTemperatureSensor
]

// C10: Data (sensor readings)
instance IncubatorTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature readings (°C) streamed from the three DS18S20 sensors for model calibration and monitoring."
    DTDFVocab:fromData IncubatorTemperatureDataStream
    DTDFVocab:inputTo CalibrationEnabler
]

// C10: Models
instance ThermalModelTwoParams : DTDFVocab:Model [
    base:desc "Analytical thermal simulation model with two free parameters capturing basic heat transfer in the incubator."
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

instance ThermalModelFourParams : DTDFVocab:Model [
    base:desc "Analytical thermal simulation model with four free parameters to capture the thermal inertia of the heat‑bed."
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

// C10: Model output data
instance ThermalModelTwoParamsOutput : DTDFVocab:Data [
    base:desc "Predicted temperature trajectory from the two‑parameter thermal model."
    DTDFVocab:inputTo MonitoringEnabler
]

instance ThermalModelFourParamsOutput : DTDFVocab:Data [
    base:desc "Predicted temperature trajectory from the four‑parameter thermal model accounting for heat‑bed inertia."
    DTDFVocab:inputTo MonitoringEnabler
]

// C11: Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithms that estimate model parameters using streamed temperature data."
    DTDFVocab:enables CalibrationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring algorithms that assess safety and optimality by comparing sensor data with model predictions."
    DTDFVocab:enables MonitoringService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimization algorithm that generates recommended heater power set‑points to achieve target temperature efficiently."
    DTDFVocab:enables OptimizationService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that provides calibrated model parameter estimates."
    DTDFVocab:provides ParameterEstimationInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that evaluates operational safety and performance."
    DTDFVocab:provides AnomalyAlertInsight, PerformanceMetricInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that computes optimal heater power adjustments."
    DTDFVocab:provides OptimizationRecommendationAction
]

// C17: Insights
instance ParameterEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated values of the free parameters for the thermal models."
]

instance AnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when temperature deviates outside defined safety bounds."
]

instance PerformanceMetricInsight : DTDFVocab:Insight [
    base:desc "Metric indicating how closely the incubator temperature follows the target profile."
]

// C17: Action
instance OptimizationRecommendationAction : DTDFVocab:Action [
    base:desc "Recommended heater power adjustments to maintain target temperature while minimizing energy consumption."
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is organized as a pipeline of distinct services: sensor data are continuously collected from the physical twin, calibration algorithms use these data to update the parameters of cyber models that represent the CPS and its environment, the calibrated models produce information that feeds monitoring components which assess whether the system is operating safely and optimally, and when a violation is detected a decision component (either a human operator or an automated algorithm) triggers corrective actions on the physical twin. This structure integrates data acquisition, model calibration, monitoring, and decision-making in a coordinated sequence."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the two thermal simulation models against experimental temperature traces. The four‑parameter model was found to better predict the heat‑bed’s thermal inertia, indicating higher fidelity. Calibration algorithms continuously adjust model parameters using the incoming sensor data, while monitors detect deviations from expected behaviour. Validation is performed experimentally, and uncertainty is mitigated through recalibration, but quantitative uncertainty metrics are not provided."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The incubator digital twin incorporates a safety protocol directly within the low‑level driver to ensure that the device remains in a safe state during operation. This embedded protocol is designed to monitor critical parameters and trigger predefined safe actions when anomalous conditions are detected, thereby providing a fail‑safe mechanism for the physical twin."
]