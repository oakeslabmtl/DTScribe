// ---------- Sensing Components ----------
instance InteriorTempSensorA : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer for interior temperature (range –55 °C to +125 °C, 0.5 °C accuracy) – sensor A"
    DTDFVocab:producedData InteriorTempMsgA
]

instance InteriorTempSensorB : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer for interior temperature (range –55 °C to +125 °C, 0.5 °C accuracy) – sensor B"
    DTDFVocab:producedData InteriorTempMsgB
]

instance ExteriorTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer for exterior temperature (range –55 °C to +125 °C, 0.5 °C accuracy)"
    DTDFVocab:producedData ExteriorTempMsg
]

// ---------- Data Transmitted ----------
instance InteriorTempMsgA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTempSensorA
]

instance InteriorTempMsgB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTempSensorB
]

instance ExteriorTempMsg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExteriorTempSensor
]

// ---------- Data ----------
instance InteriorTemperatureDataA : DTDFVocab:Data [
    base:desc "Timestamped interior temperature reading from sensor A"
    DTDFVocab:fromData InteriorTempMsgA
    DTDFVocab:inputTo LowLevelDriverSoftware
]

instance InteriorTemperatureDataB : DTDFVocab:Data [
    base:desc "Timestamped interior temperature reading from sensor B"
    DTDFVocab:fromData InteriorTempMsgB
    DTDFVocab:inputTo LowLevelDriverSoftware
]

instance ExteriorTemperatureData : DTDFVocab:Data [
    base:desc "Timestamped exterior temperature reading from the outside sensor"
    DTDFVocab:fromData ExteriorTempMsg
    DTDFVocab:inputTo LowLevelDriverSoftware
]

instance CalibrationDataset : DTDFVocab:Data [
    base:desc "Time‑stamped temperature traces collected from all three sensors during calibration experiments"
    DTDFVocab:fromData InteriorTempMsgA, InteriorTempMsgB, ExteriorTempMsg
    DTDFVocab:inputTo PythonSciPyOptimizer
]

// ---------- Models ----------
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single‑capacity air thermal model with heat loss G_box"
    DTDFVocab:inputTo PythonSciPyOptimizer, LowLevelDriverSoftware
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Extended thermal model adding heater thermal capacity and heat loss G_heater"
    DTDFVocab:inputTo PythonSciPyOptimizer, LowLevelDriverSoftware
]

// ---------- Enablers ----------
instance LowLevelDriverSoftware : DTDFVocab:Enabler [
    base:desc "Low‑level driver on the Raspberry Pi that samples DS18S20 sensors, packages readings as AMQP messages and publishes them to RabbitMQ"
    DTDFVocab:enables RealTimeMonitoringService, FaultDetectionService, PredictiveOptimizationService
]

instance PythonSciPyOptimizer : DTDFVocab:Enabler [
    base:desc "Python SciPy least‑squares optimizer used to calibrate thermal model parameters (C_air, C_heater, G_box, G_heater)"
    DTDFVocab:enables ParameterCalibrationService
]

// ---------- Services ----------
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of interior and exterior temperature readings via RabbitMQ"
    DTDFVocab:provides TemperatureMonitoringInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection using safe‑protocol checks on actuator commands and sensor status"
    DTDFVocab:provides FaultDetectedInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibration of thermal model parameters using non‑linear least‑squares optimisation"
    DTDFVocab:provides CalibrationParametersInsight
]

instance PredictiveOptimizationService : DTDFVocab:Service [
    base:desc "Predictive optimisation of heating cycles based on calibrated models"
    DTDFVocab:provides OptimizedHeatingScheduleInsight, AdjustHeatingCycleAction
]

instance ModelBasedSimulationService : DTDFVocab:Service [
    base:desc "Model‑based simulation of incubator thermal dynamics using Model A and Model B"
    DTDFVocab:provides SimulationResultInsight
]

// ---------- Insights ----------
instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Current interior and exterior temperature status"
]

instance FaultDetectedInsight : DTDFVocab:Insight [
    base:desc "Detected fault in actuator or sensor based on safe‑protocol violation"
]

instance CalibrationParametersInsight : DTDFVocab:Insight [
    base:desc "Updated model parameters (C_air, C_heater, G_box, G_heater) after calibration"
]

instance OptimizedHeatingScheduleInsight : DTDFVocab:Insight [
    base:desc "Recommended heating duration (H), waiting duration (C) and temperature limits (LL, UL) for the next cycle"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory from simulation of Model A or Model B"
]

// ---------- Actions ----------
instance AdjustHeatingCycleAction : DTDFVocab:Action [
    base:desc "Automatically adjust heating duration, waiting duration and temperature limits according to calibrated parameters"
    DTDFVocab:IsAutomatic true
]

// ---------- Acting Components ----------
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Planar heat‑bed (214 × 214 × 3 mm) delivering up to 100 W, driven via MOSFET on PCB"
]

instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "12‑24 V fan circulating air at ~0.02 m³ s⁻¹, driven via MOSFET on PCB"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (heat‑bed ON/OFF, fan ON/OFF, waiting durations) to the RabbitMQ broker; the controller on the Raspberry Pi subscribes, interprets the messages, and drives the MOSFETs to actuate the heat‑bed and fan."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture consists of the PT hardware layer, a low‑level driver layer, a RabbitMQ communication server hosted on the Raspberry Pi, and separate DT software modules that subscribe to the broker for sensor data and publish control commands. All components run on or communicate with the Pi, forming a tightly coupled CPS‑DT loop."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is limited by assumptions: uniform temperature (validated by fan‑induced mixing experiments), negligible wall heat storage, constant air specific heat, and ignored fan heat generation (Model A). Validation experiments measured temperature spread (≤7 °C, reduced to ≤6 °C with higher fan voltage) to assess uniformity. Calibration residuals guide validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual and virtual‑to‑physical data exchange uses the RabbitMQ message broker running on the Raspberry Pi, communicating over TCP/IP with the AMQP protocol. Messages carry temperature sensor values and control commands."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ server and all DT software components are deployed on the same Raspberry Pi 4 that also hosts the controller and low‑level driver; the PCB and sensors are physically attached to this platform."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the PT in a safe state; the controller includes monitoring for temperature limits and can trigger human intervention on violations. Communication via RabbitMQ can be secured by standard AMQP authentication, although specific security measures are not detailed."
]