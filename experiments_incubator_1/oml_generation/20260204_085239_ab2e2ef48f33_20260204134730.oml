    DTDFVocab:provides ControlStrategyInsight
]

instance DataTransmissionService : DTDFVocab:Service [
    base:desc "Bidirectional data flow service enabling real-time synchronization between Physical Twin and Digital Twin."
    DTDFVocab:provides DataSynchronizationInsight
]

instance DataQualityService : DTDFVocab:Service [
    base:desc "Comprehensive data validation and quality assurance service ensuring sensor data reliability."
    DTDFVocab:provides DataQualityInsight
]

instance DataFusionService : DTDFVocab:Service [
    base:desc "Heterogeneous data integration service combining multiple sensor sources for robust state estimation."
    DTDFVocab:provides StateEstimationInsight
]

instance GeometricModelingService : DTDFVocab:Service [
    base:desc "CAD-based geometric modeling service providing static structural representations of Physical Twin."
    DTDFVocab:provides StructuralRepresentationInsight
]

instance ModelValidationService : DTDFVocab:Service [
    base:desc "Model validation framework comparing Digital Twin predictions against historical operational data."
    DTDFVocab:provides ModelFidelityInsight
]

instance DataValidationService : DTDFVocab:Service [
    base:desc "Service validating sensor data against expected patterns and historical baselines."
    DTDFVocab:provides DataValidationInsight
]

instance PreprocessingService : DTDFVocab:Service [
    base:desc "Service normalizing and preprocessing raw sensor data for consistent analysis."
    DTDFVocab:provides PreprocessingInsight
]

