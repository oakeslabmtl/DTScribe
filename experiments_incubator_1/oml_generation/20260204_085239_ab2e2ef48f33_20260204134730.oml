// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded sensor collecting real-time temperature measurements from the Physical Twin for model calibration and anomaly detection."
    DTDFVocab:producedData TemperatureRawData
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded sensor capturing real-time pressure measurements to monitor operational conditions and validate model predictions."
    DTDFVocab:producedData PressureRawData
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency sensor measuring dynamic vibrations to detect mechanical anomalies and validate structural models."
    DTDFVocab:producedData VibrationRawData
]

instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor tracking spatial coordinates of the Physical Twin for localization and movement analysis."
    DTDFVocab:producedData PositionRawData
]

instance VelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring velocity through numerical differentiation of accelerometer data for dynamic system analysis."
    DTDFVocab:producedData VelocityRawData
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor measuring humidity levels affecting the Physical Twin's operational environment."
    DTDFVocab:producedData HumidityRawData
]

instance EventTriggerSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor detecting operational events such as alarms, anomalies, or state transitions for event-driven data acquisition."
    DTDFVocab:producedData EventLogData
]

// C4: Physical-to-Virtual Interaction
instance TemperatureRawData : DTDFVocab:DataTransmitted [
    base:desc "Raw temperature data transmitted from TemperatureSensor at 10-100Hz for real-time model validation."
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureRawData : DTDFVocab:DataTransmitted [
    base:desc "Raw pressure data transmitted from PressureSensor with event-driven sampling for operational monitoring."
    DTDFVocab:producedFrom PressureSensor
]

instance VibrationRawData : DTDFVocab:DataTransmitted [
    base:desc "High-frequency vibration data transmitted from VibrationSensor for dynamic system analysis and fault detection."
    DTDFVocab:producedFrom VibrationSensor
]

instance PositionRawData : DTDFVocab:DataTransmitted [
    base:desc "Position data transmitted from PositionSensor with time-based triggers for localization and movement tracking."
    DTDFVocab:producedFrom PositionSensor
]

instance VelocityRawData : DTDFVocab:DataTransmitted [
    base:desc "Derived velocity data transmitted after feature extraction from accelerometer data for dynamic modeling."
    DTDFVocab:producedFrom VelocitySensor
]

instance HumidityRawData : DTDFVocab:DataTransmitted [
    base:desc "Environmental humidity data transmitted for contextual analysis of Physical Twin's operational environment."
    DTDFVocab:producedFrom HumiditySensor
]

instance EventLogData : DTDFVocab:DataTransmitted [
    base:desc "Event log data containing alarms, anomalies, and state transitions triggered by system conditions."
    DTDFVocab:producedFrom EventTriggerSensor
]

// C10: Models/Data
instance GeometricModel : DTDFVocab:Model [
    base:desc "CAD-based geometric representation of Physical Twin's static dimensions and shapes without dynamic behaviors."
    DTDFVocab:inputTo CADModelingEnabler
]

instance BehavioralModel : DTDFVocab:Model [
    base:desc "Differential equation-based dynamic model simulating forces, movement, and system interactions under operating conditions."
    DTDFVocab:inputTo SimulationEngine
]

instance AnalyticalModel : DTDFVocab:Model [
    base:desc "Mathematical abstraction using system dynamics and control theory for predictive analysis and optimization."
    DTDFVocab:inputTo OptimizationEngine
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Aggregated real-time sensor data from Physical Twin used for continuous model calibration and monitoring."
    DTDFVocab:fromData TemperatureRawData, PressureRawData, VibrationRawData, PositionRawData, VelocityRawData, HumidityRawData, EventLogData
]

instance HistoricalData : DTDFVocab:Data [
    base:desc "Archived operational data from past deployments used for model validation and predictive analytics."
    DTDFVocab:fromData EventLogData
    DTDFVocab:inputTo ModelValidationEnabler
]

instance EnvironmentalModel : DTDFVocab:Model [
    base:desc "Model representing external environmental factors affecting Physical Twin's behavior and operational context."
    DTDFVocab:inputTo DataFusionEnabler
]

// C11: Enablers
instance OPCUAProtocol : DTDFVocab:Enabler [
    base:desc "Standardized industrial protocol enabling secure, interoperable data exchange between Physical Twin and Digital Twin."
    DTDFVocab:enables DataTransmissionService
]

instance MQTTProtocol : DTDFVocab:Enabler [
    base:desc "Lightweight publish-subscribe protocol for efficient IoT/edge communication in real-time data transmission."
    DTDFVocab:enables RealTimeMonitoringService
]

instance KalmanFilter : DTDFVocab:Enabler [
    base:desc "State estimation algorithm reducing noise and improving accuracy of sensor data for model calibration."
    DTDFVocab:enables DataQualityService
]

instance AnomalyDetectionML : DTDFVocab:Enabler [
    base:desc "Machine learning-based classifier identifying corrupt or implausible sensor readings for data validation."
    DTDFVocab:enables DataValidationService
]

instance DataNormalization : DTDFVocab:Enabler [
    base:desc "Preprocessing algorithm converting raw sensor data to standardized physical units for consistent analysis."
    DTDFVocab:enables PreprocessingService
]

instance RecursiveLeastSquares : DTDFVocab:Enabler [
    base:desc "Model calibration algorithm adjusting differential equation parameters using real-time sensor data."
    DTDFVocab:enables ModelCalibrationService
]

instance DempsterShaferFusion : DTDFVocab:Enabler [
    base:desc "Sensor fusion technique combining heterogeneous data sources for improved state estimation."
    DTDFVocab:enables DataFusionService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Physics-based simulator replicating Physical Twin's dynamics under real-world conditions for predictive analysis."
    DTDFVocab:enables BehavioralSimulationService
]

instance OptimizationEngine : DTDFVocab:Enabler [
    base:desc "Algorithm optimizing Physical Twin's performance through parameter adjustments and control strategy refinement."
    DTDFVocab:enables ControlOptimizationService
]

instance CADModelingEnabler : DTDFVocab:Enabler [
    base:desc "Computer-Aided Design tool providing geometric and structural representations for Digital Twin modeling."
    DTDFVocab:enables GeometricModelingService
]

instance ModelValidationEnabler : DTDFVocab:Enabler [
    base:desc "Validation framework comparing Digital Twin models against historical data for accuracy assessment."
    DTDFVocab:enables ModelValidationService
]

instance DataFusionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler combining heterogeneous data sources for improved state estimation."
    DTDFVocab:enables DataFusionService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous collection and analysis of real-time sensor data to maintain Digital Twin's state estimates."
    DTDFVocab:provides RealTimeStateInsight
]

