// -------------------------------------------------
// Acting Components
// -------------------------------------------------
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heated plate (heat‑bed) powered from 12 V/24 V rail, PWM‑controlled via MOSFET driver for set‑point temperature regulation."
]

instance AirFanActuator : DTDFVocab:ActingComponent [
    base:desc "Forced‑air fan driven by MOSFET switch on 12 V/24 V rail, variable speed to distribute heat uniformly inside the incubator."
]

// -------------------------------------------------
// Sensing Components
// -------------------------------------------------
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer mounted at corner A inside the insulated chamber (‑55 °C – +125 °C, ±0.5 °C)."
    DTDFVocab:producedData TemperatureDataStream
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer mounted at corner B inside the insulated chamber (‑55 °C – +125 °C, ±0.5 °C)."
    DTDFVocab:producedData TemperatureDataStream
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer affixed to the box wall to capture ambient temperature (‑55 °C – +125 °C, ±0.5 °C)."
    DTDFVocab:producedData TemperatureDataStream
]

// -------------------------------------------------
// Data Transmitted
// -------------------------------------------------
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA, InternalTempSensorB, ExternalTempSensor
    base:desc "Timestamped temperature readings (°C) streamed from the three DS18S20 sensors via 1‑Wire to the RabbitMQ broker."
]

// -------------------------------------------------
// Data
// -------------------------------------------------
instance TemperatureData : DTDFVocab:Data [
    base:desc "Continuous temperature time‑series (°C) consumed by calibration, monitoring and prediction algorithms."
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo PythonRuntimeEnabler, InfluxDBEnabler
]

// -------------------------------------------------
// Enablers
// -------------------------------------------------
instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "AMQP broker (RabbitMQ) running on the edge Raspberry Pi for reliable sensor streaming and command delivery."
    DTDFVocab:enables RealTimeMonitoringService, CalibrationService, PredictionService, SupervisoryControlService
]

instance InfluxDBEnabler : DTDFVocab:Enabler [
    base:desc "InfluxDB time‑series database storing historic temperature data for analysis and dashboarding."
    DTDFVocab:enables DataVisualizationService
]

instance GrafanaEnabler : DTDFVocab:Enabler [
    base:desc "Grafana dashboards rendering temperature trends and model outputs for operators."
    DTDFVocab:enables DataVisualizationService
]

instance SciPyEnabler : DTDFVocab:Enabler [
    base:desc "SciPy library (least_squares, differential_evolution) used for model calibration, fault detection and optimisation."
    DTDFVocab:enables CalibrationService, FaultDetectionService, OptimisationService
]

instance NumPyEnabler : DTDFVocab:Enabler [
    base:desc "NumPy numerical engine powering the thermal simulation model."
    DTDFVocab:enables PredictionService
]

instance PythonRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python 3 runtime on Raspberry Pi executing acquisition scripts, simulation code and algorithmic services."
    DTDFVocab:enables RealTimeMonitoringService, CalibrationService, PredictionService, FaultDetectionService, OptimisationService, SupervisoryControlService, DataVisualizationService
]

// -------------------------------------------------
// Models
// -------------------------------------------------
instance ThermalPhysicsModel : DTDFVocab:Model [
    base:desc "First‑order thermal model of the incubator (heat‑bed, airflow, insulation) based on energy balance equations."
    DTDFVocab:inputTo NumPyEnabler, PythonRuntimeEnabler
]

instance CalibrationModel : DTDFVocab:Model [
    base:desc "Parameter estimation model that adjusts thermal model coefficients using latest temperature data via SciPy least‑squares."
    DTDFVocab:inputTo SciPyEnabler, PythonRuntimeEnabler
]

instance MonitoringModel : DTDFVocab:Model [
    base:desc "Safety‑monitoring model evaluating temperature against operational limits (20 °C – 45 °C, ±0.5 °C stability)."
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance FaultDetectionModel : DTDFVocab:Model [
    base:desc "Anomaly detection model applying SciPy differential evolution to identify sensor drift or actuator failures."
    DTDFVocab:inputTo SciPyEnabler, PythonRuntimeEnabler
]

instance OptimisationModel : DTDFVocab:Model [
    base:desc "Control‑optimisation model that computes optimal heater set‑point and fan speed to minimize energy while respecting temperature constraints."
    DTDFVocab:inputTo SciPyEnabler, PythonRuntimeEnabler
]

// -------------------------------------------------
// Services
// -------------------------------------------------
instance PredictionService : DTDFVocab:Service [
    base:desc "Simulation‑based prediction of future incubator temperature using the calibrated thermal physics model."
    DTDFVocab:provides PredictedTemperatureInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous evaluation of live temperature data against safety margins and performance targets."
    DTDFVocab:provides SafetyViolationInsight, TriggerAlertAction
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Automatic calibration of model parameters from incoming temperature data using SciPy optimisation."
    DTDFVocab:provides CalibrationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detection of sensor or actuator faults by analysing deviations from the calibrated model."
    DTDFVocab:provides FaultDetectionInsight, ShutoffPowerAction
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Generation of optimal control actions (heater set‑point, fan speed) to achieve energy efficiency and temperature stability."
    DTDFVocab:provides OptimisationRecommendationInsight, AdjustSetPointAction
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Issue of set‑point commands to the HeatBedActuator and AirFanActuator based on optimisation outcomes."
    DTDFVocab:provides AdjustSetPointAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Rendering of temperature trends and model predictions on Grafana dashboards."
    DTDFVocab:provides VisualizationInsight
]

// -------------------------------------------------
// Insights
// -------------------------------------------------
instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Forecasted temperature trajectory for the next operational horizon."
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detected breach of temperature limits or stability requirement."
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Updated model parameter set after successful calibration run."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identified anomaly indicating possible sensor drift or actuator malfunction."
]

instance OptimisationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommended heater set‑point and fan speed that minimize energy consumption while meeting temperature targets."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Current temperature plot with overlay of model prediction on Grafana."
]

// -------------------------------------------------
// Actions
// -------------------------------------------------
instance TriggerAlertAction : DTDFVocab:Action [
    base:desc "Send an alarm notification to operators via the dashboard."
    DTDFVocab:IsAutomatic true
]

instance ShutoffPowerAction : DTDFVocab:Action [
    base:desc "Immediately cut power to the heat‑bed and fan in case of critical fault."
    DTDFVocab:IsAutomatic true
]

instance AdjustSetPointAction : DTDFVocab:Action [
    base:desc "Update the PWM set‑point of the heat‑bed and fan speed to the values supplied by the optimisation service."
    DTDFVocab:IsAutomatic true
]

// -------------------------------------------------
// Environment & Component Aggregation
// -------------------------------------------------
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, AirFanActuator, InternalTempSensorA, InternalTempSensorB, ExternalTempSensor
]

instance IncubatorComponent : DTDFVocab:Component [
    base:desc "Low‑cost thermal incubator (styrofoam chamber, heat‑bed, fan, sensors) powered by 12 V supply and controlled by a Raspberry Pi 4."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin sends actuation commands to the physical incubator by publishing messages to the RabbitMQ server on the Raspberry Pi. The controller on the Raspberry Pi listens to these messages and drives the fan and the heatbed accordingly. The heatbed is switched using MOSFETs and optocouplers capable of handling the required 4 A current. Command execution is reflected back through updated temperature sensor readings that are sent back to the digital twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by calibration algorithms that adjust model parameters to best match the latest sensor measurements, providing a continuous validation loop. Monitors evaluate the calibrated models against safety and optimality criteria, detecting violations. The DT therefore uses calibration‑based verification and runtime monitoring as its primary quality‑assurance mechanisms, though specific uncertainty quantification or formal V&V methods are not described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The incubator’s technical network consists of temperature sensors linked via a 1‑Wire bus to a Raspberry Pi, which provides built‑in Wi‑Fi connectivity. The Raspberry Pi hosts a local RabbitMQ server that mediates messaging between the physical sensors/actuators and the digital twin software. Communication between components relies on the RabbitMQ messaging infrastructure over the Wi‑Fi network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is deployed on‑edge on the Raspberry Pi that runs both the controller software and a local RabbitMQ server. All required hardware and software components are open‑source and available in the publicly‑accessible repository linked in the case‑study documentation. The deployment therefore uses an on‑premise edge platform without external cloud services."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin incorporates monitors that continuously evaluate operational data to confirm the system is performing safely and optimally; when a safety violation is detected, humans or other algorithms may decide to modify the physical twin. No specific cybersecurity protocols, access‑control mechanisms, authentication systems, threat‑mitigation strategies, fail‑safe designs, or formal risk‑assessment methods are described in the document."
]