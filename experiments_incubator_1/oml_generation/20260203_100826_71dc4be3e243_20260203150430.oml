// C3: Physical sensing components
instance WheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors the rotational speed of each wheel to provide data for dynamic interaction models."
]
instance EngineTempSensor : DTDFVocab:SensingComponent [
    base:desc "Measures engine temperature to monitor thermal conditions in real time."
]
instance ChassisVibSensor : DTDFVocab:SensingComponent [
    base:desc "Detects chassis vibration amplitudes for structural health monitoring."
]

// C4: Physical-to-virtual interaction
instance WheelSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedSensor
]
instance EngineTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EngineTempSensor
]
instance ChassisVibDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChassisVibSensor
]

// C10: Models/Data
instance WheelSpeedSensorData : DTDFVocab:Data [
    base:desc "Time‑stamped wheel speed measurements."
    DTDFVocab:fromData WheelSpeedDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, FaultDetectionEnabler, StateEstimationEnabler, OptimizationEnabler, SupervisoryControlEnabler, MonitoringEnabler
]
instance EngineTempSensorData : DTDFVocab:Data [
    base:desc "Time‑stamped engine temperature measurements."
    DTDFVocab:fromData EngineTempDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, FaultDetectionEnabler, StateEstimationEnabler, OptimizationEnabler, SupervisoryControlEnabler, MonitoringEnabler
]
instance ChassisVibSensorData : DTDFVocab:Data [
    base:desc "Time‑stamped chassis vibration measurements."
    DTDFVocab:fromData ChassisVibDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, FaultDetectionEnabler, StateEstimationEnabler, OptimizationEnabler, SupervisoryControlEnabler, MonitoringEnabler
]

instance GeometricCADModel : DTDFVocab:Model [
    base:desc "CAD representation capturing wheel sizes and chassis shape for boundary condition definition."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler
]
instance BehavioralDynamicModel : DTDFVocab:Model [
    base:desc "Differential‑equation based dynamic model capturing vehicle interactions and response."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler
]

// C11: Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Processes sensor data to calibrate geometric and behavioral model parameters."
    DTDFVocab:enables CalibrationService
]
instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Analyzes residuals between sensor data and model predictions to detect faults."
    DTDFVocab:enables FaultDetectionService
]
instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "Combines sensor data and model outputs to estimate hidden states."
    DTDFVocab:enables StateEstimationService
]
instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimizes control actions or model parameters to improve performance."
    DTDFVocab:enables OptimizationService
]
instance SupervisoryControlEnabler : DTDFVocab:Enabler [
    base:desc "Overrides physical twin actions based on simulation and fault detection outcomes."
    DTDFVocab:enables SupervisoryControlService
]
instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Verifies safe and optimal operation by comparing sensor data with model thresholds."
    DTDFVocab:enables MonitoringService
]
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Runs simulations of the behavioral dynamic model under current operating conditions."
    DTDFVocab:enables SimulationService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Performs dynamic calibration of models using real‑time sensor data."
    DTDFVocab:provides CalibrationOutcomeInsight, UpdateModelParametersAction
]
instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults through residual analysis and informs supervisory decisions."
    DTDFVocab:provides FaultDetectionInsight, FaultAlertAction
]
instance StateEstimationService : DTDFVocab:Service [
    base:desc "Provides accurate estimates of hidden states for safety and performance monitoring."
    DTDFVocab:provides StateEstimationInsight, EstimatingAction
]
instance OptimizationService : DTDFVocab:Service [
    base:desc "Recommends optimal control actions to enhance system performance."
    DTDFVocab:provides OptimizationInsight, OptimizedControlAction
]
instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Authorizes supervisory overrides of physical twin actions when necessary."
    DTDFVocab:provides SupervisoryControlInsight, OverrideControlAction
]
instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitors real‑time sensor data against safety parameters."
    DTDFVocab:provides SafetyComplianceInsight, SafetyAlertAction
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Executes simulations to predict future behavior of the physical twin."
    DTDFVocab:provides SimulationResultInsight, SimulationExecutionAction
]

// C17: Insights
instance CalibrationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Provides updated model parameter estimates based on calibration."
]
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects abnormal behavior by comparing model predictions to live sensor data."
]
instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Provides estimates of hidden system states derived from sensor data."
]
instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommends optimal control actions to improve system performance."
]
instance SupervisoryControlInsight : DTDFVocab:Insight [
    base:desc "Provides supervisory control decisions to override physical twin actions."
]
instance SafetyComplianceInsight : DTDFVocab:Insight [
    base:desc "Indicates safety compliance status of the physical twin."
]
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Represents the outcome of a simulation run under current conditions."
]

// C17: Actions
instance UpdateModelParametersAction : DTDFVocab:Action [
    base:desc "Automatically updates model parameters within the digital twin."
    DTDFVocab:IsAutomatic true
]
instance FaultAlertAction : DTDFVocab:Action [
    base:desc "Sends an alert to operators when a fault is detected."
    DTDFVocab:IsAutomatic true
]
instance EstimatingAction : DTDFVocab:Action [
    base:desc "Applies estimation update to internal state representation."
    DTDFVocab:IsAutomatic true
]
instance OptimizedControlAction : DTDFVocab:Action [
    base:desc "Automatically applies optimized control to the physical twin."
    DTDFVocab:IsAutomatic true
]
instance OverrideControlAction : DTDFVocab:Action [
    base:desc "Overrides existing control commands to ensure safe operation."
    DTDFVocab:IsAutomatic true
]
instance SafetyAlertAction : DTDFVocab:Action [
    base:desc "Sends a safety alert when compliance is violated."
    DTDFVocab:IsAutomatic true
]
instance SimulationExecutionAction : DTDFVocab:Action [
    base:desc "Executes a simulation run of the behavioral model."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A digital twin is structured as a framework that integrates three core components: data ingestion, modelling, and algorithms. Data is collected from the physical twin via sensors over continuous operational periods and fed into the system for real‑time update. Modelling comprises physical, cyber‑physical, and environmental knowledge bases; these models are continuously refined through calibration algorithms that adjust parameters based on incoming sensor data. The algorithmic layer includes fault detectors, supervisory controllers, state estimators, and optimisers that process the calibrated models and data to generate new insights and actionable outputs. The output from algorithms fuels monitors that evaluate safety and performance; when violations are detected, humans or autonomous decision‑making modules can issue corrective actions to the physical twin. This orchestrated interaction between data, model calibration, monitoring, and control constitutes the overall digital‑twin constellation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital Twin lifecycle begins with the creation of CAD or dynamic simulation models of the physical system; during deployment the models are integrated with real‑time sensor data from the Physical Twin, followed by continuous calibration and monitoring that update model parameters and evaluate safety/optimisation; governance is achieved by periodic audit of model–data consistency and traceable configuration changes."
]