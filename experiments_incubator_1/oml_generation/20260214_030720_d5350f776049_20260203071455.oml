// C3: Physical sensing components
instance BoxAirTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer (range -55 °C to +125 °C, accuracy ±0.5 °C 10‑85 °C) mounted inside the incubator box, identified by a unique 64‑bit serial code, connected to Raspberry Pi 1‑Wire bus"
    DTDFVocab:producedData BoxAirTempDataTransmitted
]

instance BoxHeaterTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer (range -55 °C to +125 °C, accuracy ±0.5 °C 10‑85 °C) positioned on the heat‑bed, unique 64‑bit serial code, on the same 1‑Wire bus"
    DTDFVocab:producedData BoxHeaterTempDataTransmitted
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer (range -55 °C to +125 °C, accuracy ±0.5 °C 10‑85 °C) measuring ambient temperature outside the box, unique 64‑bit serial code, on 1‑Wire bus"
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance BoxAirTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxAirTemperatureSensor
]

instance BoxHeaterTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxHeaterTemperatureSensor
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

// C11: Data
instance BoxAirTempData : DTDFVocab:Data [
    base:desc "Timestamped temperature value (°C) from BoxAirTemperatureSensor"
    DTDFVocab:fromData BoxAirTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

instance BoxHeaterTempData : DTDFVocab:Data [
    base:desc "Timestamped temperature value (°C) from BoxHeaterTemperatureSensor"
    DTDFVocab:fromData BoxHeaterTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Timestamped temperature value (°C) from AmbientTemperatureSensor"
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

// C10: Models/Data
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Physics‑based thermal Model A with a single air capacitance C_air and conductance G_box"
    DTDFVocab:inputTo SimulationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Physics‑based thermal Model B with separate air capacitance C_air, heater capacitance C_heater and conductances G_box, G_heater"
    DTDFVocab:inputTo SimulationEngine
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker running on Raspberry Pi, receives temperature Data messages from sensors"
    DTDFVocab:enables SimulationService, RealTimePredictionService, FaultMonitoringService, VisualizationService
]

instance SciPyLeastSquaresOptimizer : DTDFVocab:Enabler [
    base:desc "SciPy nonlinear least‑squares optimizer used for calibration of thermal model parameters"
    DTDFVocab:enables CalibrationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine that executes thermal models for prediction and visualization"
    DTDFVocab:enables SimulationService, VisualizationService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Executes Model A or Model B to simulate temperature dynamics"
    DTDFVocab:provides PredictedTemperatureTrajectoryInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibrates model parameters by minimizing squared residuals between measurements and simulations using SciPy optimizer"
    DTDFVocab:provides CalibratedThermalParametersInsight
]

instance RealTimePredictionService : DTDFVocab:Service [
    base:desc "Provides real‑time temperature prediction based on the calibrated thermal model"
    DTDFVocab:provides PredictedTemperatureTrajectoryInsight
]

instance FaultMonitoringService : DTDFVocab:Service [
    base:desc "Monitors temperature against defined limits and triggers a safe‑state driver on deviation"
    DTDFVocab:provides TemperatureDeviationAlertAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualises temperature trajectories for experimental validation"
    DTDFVocab:provides PredictedTemperatureTrajectoryInsight
]

// C17: Insights/Actions
instance CalibratedThermalParametersInsight : DTDFVocab:Insight [
    base:desc "Calibrated thermal parameters (C_air, G_box, C_heater, G_heater) estimated by the DT"
]

instance PredictedTemperatureTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature curves generated by the DT for monitoring and validation"
]

instance TemperatureDeviationAlertAction : DTDFVocab:Action [
    base:desc "Alert emitted when temperature deviates from defined limits; requires operator intervention"
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET‑driven heating element (heat‑bed) controlled via Raspberry Pi GPIO through an optocoupler; can be turned on/off and duty‑cycle set"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET‑driven fan for air circulation, controlled via Raspberry Pi GPIO through an optocoupler; can be started/stopped or supply voltage adjusted"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT services send control commands (heat‑bed ON/OFF, fan ON/OFF or voltage level) as AMQP messages to the same RabbitMQ broker; the controller subscribes to these topics, interprets the commands and drives the MOSFETs/optocouplers to actuate the heat‑bed and fan."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture comprises the PT, a low‑level driver that captures sensor data and forwards it to RabbitMQ, the RabbitMQ broker mediating communication, DT components that subscribe to sensor streams for monitoring and model calibration, and the controller that receives DT commands and drives the actuators; all components are co‑located on the Raspberry Pi, forming a tightly coupled CPS‑based DT."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is examined through four explicit assumptions (uniform air temperature, negligible wall heat storage, constant air specific heat, negligible fan heat). Validation is performed by uniform‑temperature experiments (comparing three sensor readings) and by calibrating model parameters against measured temperature trajectories; the calibrated Model B showed superior prediction of thermal inertia, indicating higher validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses the AMQP protocol over TCP/IP via the RabbitMQ broker; the Raspberry Pi provides Wi‑Fi (and Bluetooth) connectivity, enabling the broker to be accessed locally or remotely. Sensor data and control commands are exchanged as discrete messages on dedicated topics."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT software components (RabbitMQ server, low‑level driver, model calibration scripts, controller logic) are deployed on the same Raspberry Pi 4 Model B that also hosts the physical controller, thus the DT runs on‑edge without external cloud resources."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe‑state protocol that forces the actuators into a defined safe configuration if communication fails; MOSFET control is isolated by optocouplers to protect the Raspberry Pi, and the RabbitMQ broker can be secured via standard AMQP authentication mechanisms (though specific security settings are not detailed in the document)."
]