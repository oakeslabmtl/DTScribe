// C3: Physical sensing component
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire digital thermometer embedded in the incubator's heatbed"
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C10: Models/Data
instance TemperatureTimeSeriesData : DTDFVocab:Data [
    base:desc "Temperature data stored in InfluxDB time‑series database, ingested via MQTT"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo ThermalModelEnabler, OptimizationEnabler, FaultDetectionEnabler, StateEstimationEnabler
]

// C11: Enablers
instance ThermalModelEnabler : DTDFVocab:Enabler [
    base:desc "Enables the real‑time thermal simulation model that predicts heat exchange in the incubator"
    DTDFVocab:enables SimulationService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Enables the optimisation engine that determines optimal heatbed duty cycle and fan airflow"
    DTDFVocab:enables OptimizationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Enables fault‑detection classifiers that monitor temperature predictions against safety limits (34 – 39 °C)"
    DTDFVocab:enables FaultDetectionService
]

instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "Enables state estimation that fuses sensor streams to produce latent state trajectories"
    DTDFVocab:enables SupervisoryControlService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Provides real‑time temperature prediction using coupled ODE thermal model"
    DTDFVocab:provides RealTimePredictionInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Provides optimisation insight to maximize safety metrics and performance"
    DTDFVocab:provides OptimizationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults in the temperature control loop and triggers alerts"
    DTDFVocab:provides FaultDetectionInsight, AlertAction
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Computes corrective control actions for heatbed and fan based on state estimation"
    DTDFVocab:provides ControlAdjustmentAction
]

// C17: Insights/Actions
instance RealTimePredictionInsight : DTDFVocab:Insight [
    base:desc "Real‑time prediction of incubator temperature based on calibrated thermal model"
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization insight to select duty cycle values for heatbed and fan that maximize safety and performance"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects deviations between predicted temperatures and user‑defined operating limits (34–39 °C)"
]

instance AlertAction : DTDFVocab:Action [
    base:desc "Notifies operator of fault condition and can trigger automated policy change"
    DTDFVocab:IsAutomatic true
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Computes corrective duty cycle for heatbed and fan based on state estimation"
    DTDFVocab:IsAutomatic true
]

// C4: Physical components
instance HeatBed : DTDFVocab:Component [
    base:desc "Heatbed that regulates incubator temperature"
]

instance Fan : DTDFVocab:Component [
    base:desc "Fan that provides airflow to distribute heat within the enclosure"
]

// C17: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBed, Fan
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is architected around three core layers: data acquisition, modelling, and control/optimization algorithms. Sensors on the physical twin emit raw telemetry that is streamed in real‑time (latency typically in the order of milliseconds) into the DT’s data layer, where it is stored in a time‑series database. Calibration algorithms continuously ingest this data to refine the parameters of both cyber (software) and physical (mechanical, environmental) models, ensuring that model predictions remain aligned with actual measurements. A monitoring service consumes the updated predictions and real‑time data to evaluate safety and performance metrics; any detected violations trigger either automated corrective actions or human operators via a decision‑support interface. The system employs a publish/subscribe messaging pattern (e.g., MQTT or RabbitMQ) to coordinate between components, enabling low‑latency communication between the calibration, monitoring, and optimization layers. Resource management is handled through container orchestration (e.g., Docker Compose or Kubernetes), allocating CPU, memory, and network bandwidth to each service based on demand and QoS requirements. This layered orchestration pattern allows tight coupling between physical behavior and digital reaction, while preserving scalability and modularity."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Calibration algorithms update the models of the CPS and environment with the best estimate of parameters, and the resulting data is used by monitors to verify whether the system is performing safely and optimally. Detailed validation and verification methods, uncertainty quantification, error‑correction mechanisms, and quality assurance processes are not specified in the document."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT framework incorporates runtime safety monitoring by continuously evaluating the system's operating parameters against predefined safety and performance thresholds. The monitored sensor outputs are fed into safety monitors which, upon detecting a violation, can trigger a safe‑mode response or halt system operation to prevent hazards. These safety checks are integral to the calibration workflow that updates models based on real‑time data, ensuring that any deviations from expected behavior are identified and addressed before they propagate to the physical twin. No explicit cybersecurity or access‑control mechanisms are described in the provided material."
]