// --------------------------------------------------------
// Physical Sensing Components
// --------------------------------------------------------
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor #1 placed inside the incubator to measure internal temperature"
    DTDFVocab:producedData InternalTempDataTx1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor #2 placed inside the incubator to measure internal temperature"
    DTDFVocab:producedData InternalTempDataTx2
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor placed outside the incubator to monitor ambient temperature"
    DTDFVocab:producedData ExternalTempDataTx
]

// --------------------------------------------------------
// Data Transmitted (Physical → Virtual)
// --------------------------------------------------------
instance InternalTempDataTx1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempDataTx2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance ExternalTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// --------------------------------------------------------
// Virtual Data (Sensor Readings)
// --------------------------------------------------------
instance InternalTemperatureData1 : DTDFVocab:Data [
    base:desc "Temperature reading from internal sensor #1"
    DTDFVocab:fromData InternalTempDataTx1
    DTDFVocab:inputTo DataAcquisitionEnabler
]

instance InternalTemperatureData2 : DTDFVocab:Data [
    base:desc "Temperature reading from internal sensor #2"
    DTDFVocab:fromData InternalTempDataTx2
    DTDFVocab:inputTo DataAcquisitionEnabler
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Ambient temperature reading from external sensor"
    DTDFVocab:fromData ExternalTempDataTx
    DTDFVocab:inputTo DataAcquisitionEnabler
]

// --------------------------------------------------------
// Acting Components (Physical Actuators & Controller)
// --------------------------------------------------------
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed that generates heat for the incubator"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan that distributes heat inside the styrofoam container"
]

instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi that drives the heat‑bed and fan based on DT commands"
]

// --------------------------------------------------------
// Simulation Models
// --------------------------------------------------------
instance SimpleThermalModel : DTDFVocab:Model [
    base:desc "Incubator thermal model with two free parameters for fast calibration"
    DTDFVocab:inputTo SimulationEnabler
]

instance DetailedThermalModel : DTDFVocab:Model [
    base:desc "Detailed thermal model with four free parameters to capture heat‑bed inertia"
    DTDFVocab:inputTo SimulationEnabler
]

// --------------------------------------------------------
// Enablers
// --------------------------------------------------------
instance DataAcquisitionEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ (AMQP) broker that receives sensor messages from the low‑level driver"
    DTDFVocab:enables MonitoringService, PredictionService, SafetyVerificationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs the thermal models and produces temperature predictions"
    DTDFVocab:enables PredictionService, OptimisationService
]

instance OptimisationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration and optimisation algorithms that estimate model parameters and compute optimal control actions"
    DTDFVocab:enables OptimisationService
]

// --------------------------------------------------------
// Services
// --------------------------------------------------------
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature data and detection of anomalies"
    DTDFVocab:provides FaultDetectionInsight, StateEstimationInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Prediction of temperature evolution inside the incubator using calibrated simulation models"
    DTDFVocab:provides TemperatureEvolutionInsight
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Parameter calibration, fault detection and generation of confidence‑based controller recommendations"
    DTDFVocab:provides TemperatureOptimizationInsight, ControllerAdjustmentAction
]

instance SafetyVerificationService : DTDFVocab:Service [
    base:desc "Continuous safety verification checking for temperature limit violations"
    DTDFVocab:provides SafetyViolationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Advanced visualisation and reconfiguration interface for system engineers and operators"
    DTDFVocab:provides VisualizationInsight
]

// --------------------------------------------------------
// Insights
// --------------------------------------------------------
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of sensor or actuator faults based on inconsistency between observed and predicted temperatures"
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimation of the current thermal state of the incubator using sensor fusion"
]

instance TemperatureEvolutionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory for the upcoming control interval"
]

instance TemperatureOptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommendation of optimal heating and fan settings to maintain target temperature with minimal energy"
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Identification of safety violations such as temperature exceeding safe thresholds"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of temperature trends, model predictions and control actions"
]

// --------------------------------------------------------
// Actions
// --------------------------------------------------------
instance ControllerAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of heat‑bed power and fan speed based on optimisation results"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin sends control commands (e.g., turn heat‑bed on/off, fan on/off, heating duration, waiting duration) as messages to the RabbitMQ broker. The controller, listening on RabbitMQ, receives these commands, executes a bang‑bang style control logic on the Raspberry Pi, and the low‑level driver forwards the actuation signals to the physical actuators. The low‑level driver incorporates a safety protocol that validates incoming commands before execution and uploads the resulting control state back to RabbitMQ as feedback."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT adopts a cyclic orchestration where data collected from the Physical Twin’s sensors are fed to calibration algorithms that update the parameters of cyber‑physical system and environment models; the refreshed models are then consumed by monitoring algorithms to assess safety and optimality, and when violations are detected a human operator or higher‑level controller can issue corrective actions back to the Physical Twin. This integrated flow of Data → Calibration → Updated Models → Monitoring → Decision/Control reflects the architecture outlined in Figure 1 of Document 1."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle described in the documents consists of (1) data acquisition where sensor streams from the physical twin are continuously collected; (2) model creation and integration, where abstract representations of the CPS physics and environment are built; (3) calibration, where algorithms estimate the best‑fit parameters for the models using the latest data; (4) monitoring, where the calibrated models feed runtime monitors that evaluate safety and optimality criteria; and (5) adaptation/feedback, where detected violations trigger human operators or automated algorithms to modify the physical twin or update the models. Transitions between stages are managed by the calibration and monitoring algorithms, and governance is implied by the continuous loop of data‑model‑monitor‑action."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed experimentally by comparing each model’s temperature predictions with the actual sensor measurements. The four‑parameter model showed higher accuracy in reproducing the heat‑bed’s thermal inertia and was selected for further development. Calibration algorithms update model parameters to reduce prediction error, and monitoring components detect violations of expected behaviour, prompting re‑calibration to maintain validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All components communicate through a RabbitMQ server using the AMQP protocol. The architecture follows a central broker topology: sensors → low‑level driver → RabbitMQ; controller ↔ RabbitMQ; DT components ↔ RabbitMQ. RabbitMQ provides reliable message delivery, queuing, and can be deployed on‑premise or in the cloud, offering a lightweight, mature networking layer with built‑in reliability mechanisms. Specific bandwidth or latency requirements are not stated in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The control software runs on a Raspberry Pi (edge device). The RabbitMQ broker that underpins the DT communication may be deployed either on‑premise or in a cloud environment, as indicated in the documents. No further details on storage, compute scaling, or additional availability mechanisms are provided."
]