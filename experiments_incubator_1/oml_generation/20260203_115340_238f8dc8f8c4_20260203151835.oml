// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Thermistor placed at critical points inside the sealed chamber"
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring humidity within the chamber via low‑voltage signal"
    DTDFVocab:producedData HumidityDataTransmitted
]
instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing vibration data from the incubator housing"
    DTDFVocab:producedData VibrationDataTransmitted
]
instance PositionalSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor providing positional data to detect chamber displacement"
    DTDFVocab:producedData PositionalDataTransmitted
]

// C4: DataTransmitted
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]
instance VibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
]
instance PositionalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionalSensor
]

// C10: Models/Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Time‑series temperature data after routing through calibration and filtering"
    DTDFVocab:inputTo DataCalibrationModule, FaultDetectionModule, MonitoringModule, SupervisoryControlModule, OptimizationModule
    DTDFVocab:inputTo PredictiveAnalyticsModule
    DTDFVocab:fromData TemperatureDataTransmitted
]
instance HumidityData : DTDFVocab:Data [
    base:desc "Time‑series humidity data after routing through calibration and filtering"
    DTDFVocab:inputTo DataCalibrationModule, FaultDetectionModule, MonitoringModule, SupervisoryControlModule, OptimizationModule
    DTDFVocab:inputTo PredictiveAnalyticsModule
    DTDFVocab:fromData HumidityDataTransmitted
]
instance VibrationData : DTDFVocab:Data [
    base:desc "Time‑series vibration data after routing through calibration and filtering"
    DTDFVocab:inputTo DataCalibrationModule, FaultDetectionModule, MonitoringModule, SupervisoryControlModule, OptimizationModule
    DTDFVocab:inputTo PredictiveAnalyticsModule
    DTDFVocab:fromData VibrationDataTransmitted
]
instance PositionalData : DTDFVocab:Data [
    base:desc "Time‑series positional data after routing through calibration and filtering"
    DTDFVocab:inputTo DataCalibrationModule, FaultDetectionModule, MonitoringModule, SupervisoryControlModule, OptimizationModule
    DTDFVocab:inputTo PredictiveAnalyticsModule
    DTDFVocab:fromData PositionalDataTransmitted
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Integrated monitoring service that ingests live sensor data and compares simulation outputs against real‑time measurements to identify safety violations or performance degradations"
    DTDFVocab:provides SafetyStatusInsight, PerformanceDegradationInsight
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service that forecasts future system states and performs state estimation using calibrated sensor data"
    DTDFVocab:provides FaultPredictionInsight, StateEstimationInsight
]
instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection service that identifies deviations indicative of faults in real time"
    DTDFVocab:provides FaultDetectedInsight
]
instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Supervisory control service that generates control actions or recommendations for operators or automated actuators"
    DTDFVocab:provides AutomatedControlAction
]
instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that explores model parameter space to maximize performance or minimize cost using calibrated models"
    DTDFVocab:provides OptimalOperationPointInsight
]
instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration service that applies low‑pass filtering and unit normalisation to incoming sensor data and outputs best‑estimate parameters"
    DTDFVocab:provides "CalibrationResult"
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ broker on Raspberry Pi 4 that receives sensor samples via local Wi‑Fi/Bluetooth and forwards them to calibration modules"
    DTDFVocab:enables "DataIngestionService"
]
instance DataCalibrationModule : DTDFVocab:Enabler [
    base:desc "Calibration module that normalises units, applies a low‑pass filter, and performs CRC integrity checks"
    DTDFVocab:enables CalibrationService
]
instance PredictiveAnalyticsModule : DTDFVocab:Enabler [
    base:desc "Module executing predictive analytics and state estimation algorithms on calibrated data streams"
    DTDFVocab:enables PredictiveAnalyticsService
]
instance FaultDetectionModule : DTDFVocab:Enabler [
    base:desc "Fault detection module that processes real‑time data to flag anomalies and trigger interventions"
    DTDFVocab:enables FaultDetectionService
]
instance MonitoringModule : DTDFVocab:Enabler [
    base:desc "Monitoring module that compares simulation outputs with live data to maintain safety and performance thresholds"
    DTDFVocab:enables MonitoringService
]
instance SupervisoryControlModule : DTDFVocab:Enabler [
    base:desc "Supervisory control module that generates automated control actions for the heating element based on model predictions"
    DTDFVocab:enables SupervisoryControlService
]
instance OptimizationModule : DTDFVocab:Enabler [
    base:desc "Optimization module that uses calibrated models to identify parameter sets maximizing performance or minimizing costs"
    DTDFVocab:enables OptimizationService
]

// C17: Insights/Actions
instance SafetyStatusInsight : DTDFVocab:Insight [
    base:desc "Real‑time safety status derived from monitoring of temperature thresholds and sensor integrity"
]
instance PerformanceDegradationInsight : DTDFVocab:Insight [
    base:desc "Indicator of gradual performance loss detected by comparing historical and real‑time data"
]
instance FaultPredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive fault insight forecasting potential future failures based on state estimation"
]
instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated future system state derived from grey‑box ODE models"
]
instance FaultDetectedInsight : DTDFVocab:Insight [
    base:desc "Immediate fault detection alert based on anomaly thresholds"
]
instance OptimalOperationPointInsight : DTDFVocab:Insight [
    base:desc "Optimal control parameter recommendation for maximum performance or minimal cost"
]
instance AutomatedControlAction : DTDFVocab:Action [
    base:desc "Automatic control action to switch heating element on or off based on supervisory control logic"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance HeatingElement : DTDFVocab:ActingComponent [
    base:desc "Electrical heating element that is switched on/off via peripheral relays"
]
instance RaspberryPi4 : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi 4 Model B microcontroller that hosts RabbitMQ broker and calibration algorithms"
]

// C5: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatingElement, RaspberryPi4, TemperatureSensor, HumiditySensor, VibrationSensor, PositionalSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the DT’s supervisory controller as JSON payloads published to RabbitMQ queues. Each command contains a target device (e.g., fan, heatbed), desired state (ON/OFF, speed, temperature set‑point) and a priority flag. The Raspberry Pi subscribes to these queues, validates the payload signature against a locally stored HMAC key, authenticates the publisher via AMQPS, and forwards the instruction to the corresponding actuator through a dedicated GPIO interface. The system collects feedback via the 1‑Wire bus sensors and acknowledges receipt and execution by publishing an acknowledgment message back to the DT, thereby closing the control loop and preventing command conflicts via a first‑come‑first‑served arbitration algorithm."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin operates on a centralized, event‑driven architecture comprising a controller host on a Raspberry Pi, a low‑level driver interfacing directly with hardware sensors, and a communication server implemented as a RabbitMQ broker. The controller subscribes to sensor data topics published by the driver, performs calibration, state estimation, and publishes control commands back to the hardware via the broker. All components are integrated through a publish‑subscribe messaging pattern over a local network, enabling loosely coupled yet tightly orchestrated coordination within the twin constellation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained through an iterative calibration loop in which real‑time sensor data are compared against model predictions and parameter estimates are updated using bespoke calibration algorithms. Validation proceeds by running monitors that evaluate safety and performance metrics; deviations are flagged as violations, triggering human or automated corrective actions. Whilst the document does not specify formal verification techniques, it emphasizes continual error detection via violation detection and subsequent model refinement, ensuring that the DT remains a trustworthy surrogate of the Physical Twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT’s communication layer is built around an AMQP‑based RabbitMQ server running on the Raspberry Pi 4. Sensors connect to the Pi through a 1‑Wire serial bus; actuators and the DT controller communicate over Wi‑Fi or Bluetooth to the Pi’s network interface. The network topology is a star with the edge node acting as hub, connected to an optional cloud gateway for remote monitoring. Bandwidth per sensor is 50–100 kbps, while command traffic is limited to <500 bytes per message; average round‑trip latency <200 ms. Reliability is achieved by RabbitMQ message persistence and local queue replication, while security is enforced via TLS‑encrypted AMQPS, username/password authentication, and per‑queue ACLs."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed exclusively on an edge device: a Raspberry Pi 4 Model B with 4 GB RAM, 32 GB micro‑SD storage, and a Wi‑Fi/Bluetooth dual‑band transceiver. All software components (RabbitMQ broker, calibration engines, simulation models, database) run as Docker containers on the Pi. Computational requirements are modest (<1 CPU core for sensors, <2 CPU cores for simulation), but the architecture allows horizontal scaling by chaining multiple Pis in a cluster. Data persistence is local, with optional push to a cloud object store via HTTPS. The deployment model is on‑premise edge, with high availability ensured through local power backups and a redundant backup Pi that can assume control in case of hardware failure. The system is scalable via adding additional sensor nodes over the 1‑Wire bus or extra Pis connected through the network backbone."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin controller incorporates a dedicated safety protocol within the low‑level driver of the underlying Cyber‑Physical System. This protocol monitors critical state variables and, if any parameter deviates beyond predefined safe limits, automatically engages protective measures that prevent the system from entering unsafe operational modes. The safety protocol is explicitly invoked during system calibration and routine monitoring, thereby ensuring that the device remains in a safe state throughout all Digital Twin operations."
]