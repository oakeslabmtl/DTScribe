// C3: Physical sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring the internal temperature inside the incubator’s insulated box (first internal sensor)."
    DTDFVocab:producedData InternalTempDataTransmitted
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring the internal temperature inside the incubator’s insulated box (second internal sensor)."
    DTDFVocab:producedData InternalTemp2DataTransmitted
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring the external temperature of the incubator."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Physical‑to‑virtual interaction (data streams)
instance InternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTemp2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// C11: Data artifacts
instance InternalTempData : DTDFVocab:Data [
    base:desc "Time‑series of internal temperature measurements from sensor 1."
    DTDFVocab:fromData InternalTempDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithm, MonitorAlgorithm, OptimiserAlgorithm, FaultDetector, StateEstimator
]

instance InternalTemp2Data : DTDFVocab:Data [
    base:desc "Time‑series of internal temperature measurements from sensor 2."
    DTDFVocab:fromData InternalTemp2DataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithm, MonitorAlgorithm, OptimiserAlgorithm, FaultDetector, StateEstimator
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Time‑series of external temperature measurements."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithm, MonitorAlgorithm, OptimiserAlgorithm, FaultDetector, StateEstimator
]

// C10: Models
instance LightweightTempModel : DTDFVocab:Model [
    base:desc "Lightweight internal temperature model with two free parameters."
    DTDFVocab:inputTo CalibrationAlgorithm, MonitorAlgorithm, OptimiserAlgorithm
]

instance DetailedTempModel : DTDFVocab:Model [
    base:desc "Detailed internal temperature model with four free parameters capturing the thermal inertia of the heat‑bed."
    DTDFVocab:inputTo CalibrationAlgorithm, MonitorAlgorithm, OptimiserAlgorithm
]

// C2: Acting component
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed that provides thermal power to raise the air temperature inside the insulated box; driven by commands from the DT software layer."
]

// C11: Enablers (tooling and algorithmic enablers)
instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that updates cyber‑physical and environment models with best‑estimate parameters using sensor data."
    DTDFVocab:enables OptimisationService
]

instance MonitorAlgorithm : DTDFVocab:Enabler [
    base:desc "Monitor that continuously checks for safety and optimal operation violations."
    DTDFVocab:enables MonitoringService
]

instance OptimiserAlgorithm : DTDFVocab:Enabler [
    base:desc "Optimisation algorithm that computes optimal operating points and adjusts model parameters."
    DTDFVocab:enables OptimisationService, ReconfigurabilityService
]

instance FaultDetector : DTDFVocab:Enabler [
    base:desc "Fault detector that anticipates faults for predictive‑maintenance purposes."
    DTDFVocab:enables PredictiveMaintenanceService
]

instance StateEstimator : DTDFVocab:Enabler [
    base:desc "State estimator that provides model‑based estimations for prediction services."
    DTDFVocab:enables PredictionService
]

instance SupervisoryController : DTDFVocab:Enabler [
    base:desc "Supervisory controller that issues set‑points to the heat‑bed actuator."
    DTDFVocab:enables ReconfigurabilityService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitoring service continuously ingesting sensor data and detecting safety or performance violations."
    DTDFVocab:provides TemperatureSafetyInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Prediction service that runs simulations reproducing and forecasting the Physical Twin’s behaviour under current conditions."
    DTDFVocab:provides PredictionInsight
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Optimization service that adjusts model parameters (calibration) and computes optimal operating points."
    DTDFVocab:provides OperatingPointInsight
]

instance VisualisationService : DTDFVocab:Service [
    base:desc "Advanced visualisation service exposing system state to engineers."
    DTDFVocab:provides VisualisationInsight
]

instance ReconfigurabilityService : DTDFVocab:Service [
    base:desc "Reconfigurability and robustness service allowing the Twin to adapt to changing environmental conditions."
    DTDFVocab:provides ReconfigurationInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive‑maintenance service that reduces upkeep by anticipating faults."
    DTDFVocab:provides MaintenanceAction
]

// C17: Insights / Actions
instance TemperatureSafetyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating a temperature safety violation (e.g., potential overshoot)."
]

instance PredictionInsight : DTDFVocab:Insight [
    base:desc "Insight delivering predicted future temperature trajectory based on simulation output."
]

instance OperatingPointInsight : DTDFVocab:Insight [
    base:desc "Insight recommending the optimal operating point for heating power."
]

instance VisualisationInsight : DTDFVocab:Insight [
    base:desc "Insight providing a visual representation of current system state."
]

instance ReconfigurationInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting reconfiguration actions to maintain robustness under new environmental conditions."
]

instance MaintenanceAction : DTDFVocab:Action [
    base:desc "Action to schedule maintenance or replace components based on anticipated faults."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin can issue actuation commands to the physical incubator via the Raspberry Pi controller, such as turning the heat‑bed on/off or adjusting the fan speed. When the DT’s monitors detect a violation, the DT (or a human operator) may decide to modify the physical twin, as noted in Document 1."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin continuously acquires sensor data from the incubator and supplies it to the cyber side; calibration algorithms periodically refine model parameters, and monitors evaluate system state in near‑real‑time. Synchronisation between the physical twin and the digital twin therefore occurs at the sensor sampling rate and at each calibration cycle, although exact frequencies or latency bounds are not specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Document 1 describes the Digital Twin as a framework that integrates three primary artefacts: (1) Data continuously collected from the physical twin via sensors, (2) Models representing cyber‑physical and environmental knowledge, and (3) Algorithms—including calibration, fault detection, state estimation, and optimisation—that manipulate data and models to generate updated parameters and higher‑level insights. Figure 1 illustrates a cyclic orchestration: calibration algorithms periodically refine the CPS and environment models with the best‑estimate parameters; the updated models feed monitoring components that assess safety and optimality; upon detection of violations, humans or other algorithms may initiate corrective actions on the physical twin. This architecture defines the overall orchestration (dt_constellation) of the incubator Digital Twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated experimentally by comparing the temperature predictions of the two simulation models against measured temperature traces from the incubator. The four‑parameter model was found to better reproduce the thermal inertia of the heat‑bed, indicating higher fidelity for dynamic behaviour. Validation is performed through repeated runs under varying operating conditions, and calibration algorithms adjust model parameters to minimise prediction error. Uncertainty originates from sensor noise and unmodelled environmental influences; the DT framework uses monitors to detect violations of expected behaviour and can trigger re‑calibration. Quality assurance follows the DT lifecycle described in Document 1, where calibrated models are continually verified against incoming sensor data and updated to maintain validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication is built around a RabbitMQ broker implementing AMQP 0‑9‑1. Sensors connect to the Raspberry Pi via a 1‑Wire bus; actuators are driven through the Pi’s GPIO (PWM for the fan, digital output for the heater). The Pi acts as both data‑acquisition node and message client, publishing sensor readings and subscribing to actuator command topics. The network topology is a simple star: the physical twin (sensors/actuators) and the Digital Twin (running on a host that subscribes to the broker) exchange messages over Ethernet or Wi‑Fi through the Pi‑hosted broker. Bandwidth is only a few kilobytes per second, latency is on the order of tens of milliseconds, and reliability is enhanced by RabbitMQ’s message persistence and automatic reconnection. Security is provided by TLS encryption for AMQP and optional username/password authentication."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT framework described includes safety‑related components: calibration algorithms continuously update the cyber‑physical models, and monitors ingest the refreshed data to check whether the system is performing safely and optimally. In the Incubator case study, safety is explicitly listed among the benefits of the digital twin (e.g., enabling safety and predictability). No specific cybersecurity protocols, authentication mechanisms, or access‑control measures are mentioned in the provided documents."
]