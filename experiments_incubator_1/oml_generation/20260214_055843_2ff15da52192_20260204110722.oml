// C1: Physical Acting Components
instance HeatBedController : DTDFVocab:ActingComponent [
    base:desc "Actuated via Raspberry Pi GPIO → MOSFETs → optocouplers (current isolation for 4A) for temperature regulation"
]

instance FanController : DTDFVocab:ActingComponent [
    base:desc "Controlled via RabbitMQ commands with adjustable thermal mixing (18V vs. 12V experiments)"
]

instance BangBangController : DTDFVocab:ActingComponent [
    base:desc "Implements bang-bang logic with hysteresis (LL/UL) and delays (H/C) to prevent overshoot"
]

// C2: Physical Sensing Components
instance RoomTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor measuring room temperature (±0.5°C) on 1-Wire bus"
]

instance ChamberTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor measuring chamber temperature (±0.5°C) on 1-Wire bus"
]

instance ChamberSurfaceTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor measuring surface temperature (±0.5°C) on 1-Wire bus"
]

instance HeatBedPowerSensor : DTDFVocab:SensingComponent [
    base:desc "Measures power input (V, I) to heatbed for energy monitoring"
]

// C3: Data Transmitted
instance RoomTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTemperatureSensor
]

instance ChamberTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChamberTemperatureSensor
]

instance ChamberSurfaceTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChamberSurfaceTemperatureSensor
]

instance PowerInputData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatBedPowerSensor
]

// C4: Data
instance TemperatureReadings : DTDFVocab:Data [
    DTDFVocab:fromData RoomTemperatureData, ChamberTemperatureData, ChamberSurfaceTemperatureData
    DTDFVocab:inputTo RabbitMQBroker
]

instance PowerMeasurements : DTDFVocab:Data [
    DTDFVocab:fromData PowerInputData
    DTDFVocab:inputTo RabbitMQBroker
]

instance ExperimentalTrajectories : DTDFVocab:Data [
    DTDFVocab:inputTo RabbitMQBroker
    base:desc "Temperature trajectories from uniformity tests (Figs. 10-12) and calibration experiments"
]

// C5: Models
instance AirThermalModel : DTDFVocab:Model [
    base:desc "Differential equation model (Eq. 5) with parameters C_air, G_box for temperature regulation"
    DTDFVocab:inputTo RabbitMQBroker
]

instance ExtendedThermalModel : DTDFVocab:Model [
    base:desc "Extended model (Eqs. 9-8) with parameters C_air, G_box, C_heater, G_heater for comprehensive thermal analysis"
    DTDFVocab:inputTo RabbitMQBroker
]

// C6: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "Message broker implementing publish-subscribe model for real-time data exchange"
    DTDFVocab:enables TemperatureRegulationService
]

instance PythonScipy : DTDFVocab:Enabler [
    base:desc "Python environment with SciPy library for non-linear least squares optimization"
    DTDFVocab:enables ModelCalibrationService
]

instance RaspberryPiHardware : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B with GPIO for actuator/sensor control"
]

// C7: Services
instance TemperatureRegulationService : DTDFVocab:Service [
    base:desc "Implements bang-bang control with hysteresis (LL/UL) for temperature stabilization"
    DTDFVocab:provides TemperatureStabilizationInsight, FanAdjustmentAction
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Non-linear least squares optimization (Scipy) for Model A/B parameter calibration"
    DTDFVocab:provides ParameterOptimizationInsight
]

instance ThermalUniformityService : DTDFVocab:Service [
    base:desc "Processes temperature readings for uniformity verification (Figs. 10-12)"
    DTDFVocab:provides UniformityVerificationInsight
]

// C8: Insights/Actions
instance TemperatureStabilizationInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectories showing stabilization around 26.85°C"
]

instance ParameterOptimizationInsight : DTDFVocab:Insight [
    base:desc "Calibrated model parameters (G_box, G_heater) from experimental data"
]

instance UniformityVerificationInsight : DTDFVocab:Insight [
    base:desc "Verification of thermal uniformity (±0.5°C) across chamber sensors"
]

instance FanAdjustmentAction : DTDFVocab:Action [
    base:desc "Real-time adjustment of fan speed (12V/24V) based on thermal mixing requirements"
    DTDFVocab:IsAutomatic true
]

instance HeatBedAdjustmentAction : DTDFVocab:Action [
    base:desc "Controlled MOSFET activation for heatbed power delivery (4A isolation)"
    DTDFVocab:IsAutomatic true
]

// C9: System Environment
instance ThermalIncubatorContainer : DTDFVocab:Environment [
    base:contains StyrofoamInsulation, ChamberVolume
]

instance ChamberVolume : DTDFVocab:Component [
    base:desc "Styrofoam insulated container (polystyrene) with volume = 0.03 m³ for energy retention"
]

instance StyrofoamInsulation : DTDFVocab:Component [
    base:desc "Polystyrene insulation providing thermal retention for temperature maintenance"
]

instance PhysicalTwinSystem : DTDFVocab:Environment [
    base:contains HeatBedPhysicalComponent, FanPhysicalComponent
]

instance HeatBedPhysicalComponent : DTDFVocab:Component [
    base:desc "214×214×3 mm surface heat source delivering ≥100W power to warm air (mass = 0.04 kg, specific heat = 700 J/kg·K)"
]

instance FanPhysicalComponent : DTDFVocab:Component [
    base:desc "12V/24V motor circulating air at ~0.02 m³/s for thermal mixing verification"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The **virtual-to-physical interaction** includes:
  - **Control Commands**: DT sends ON/OFF signals to heatbed/fan via RabbitMQ and GPIO.
  - **Actuation**: Heatbed/fan controlled via MOSFETs/optocouplers (for high-current isolation).
  - **Feedback**: DT monitors PT response (e.g., temperature deviations) to adjust virtual models."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The **twinning time scale** is defined by:
  - **Data Sampling**: Implied real-time (<=2 seconds) due to fan air turnover.
  - **Control Loop**: Bang-bang strategy with discrete steps (H/C durations).
  - **Calibration**: Iterative optimization (gradient descent) during experiments."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is a **centralized system** with:
  - **PT**: Incubator hardware.
  - **DT**: Virtual models, algorithms, and RabbitMQ communication layer.
  - **Orchestration**: Real-time PT-DT synchronization via RabbitMQ."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT operates in:
  - **Design**: Model development (Model A/B).
  - **Manufacturing**: Calibration experiments (e.g., Fig. 11).
  - **Operational**: Real-time monitoring/control with dynamic model updates."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT’s fidelity is ensured by:
  - **Assumptions**: Uniform temperature (verified via Fig. 10–12), constant air heat capacity.
  - **Validation**: Non-linear least squares calibration (Scipy) and experimental trajectories (e.g., Fig. 12).
  - **Uncertainty**: Sensor accuracy (±0.5°C), model parameter estimates."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The connection uses:
  - **Protocol**: RabbitMQ AMQP.
  - **Network**: 1-Wire bus (sensors) + GPIO (actuators) + RabbitMQ (communication)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted on the Raspberry Pi 4 with:
  - **Software Stack**: RabbitMQ, Python (Scipy), low-level driver.
  - **Scalability**: Open-source hardware/software (GitHub)."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT includes:
  - **Safety**: Current isolation (MOSFETs/optocouplers), hysteresis (LL/UL).
  - **Cybersecurity**: RabbitMQ (open-source, no explicit hardening).
  - **Human Safety**: Controlled lab environment (no remote execution risks mentioned)."
]