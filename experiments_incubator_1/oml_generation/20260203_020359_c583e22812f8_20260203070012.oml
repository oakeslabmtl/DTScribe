// ------------------------------------------------------------
// C3: Physical sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor inside incubator box (internal) #1 measuring °C"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor inside incubator box (internal) #2 measuring °C"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor outside incubator monitoring ambient room temperature in °C"
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1, InternalTempSensor2, ExternalTempSensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Raw temperature readings (°C) from internal and external sensors"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo VisualizationEnabler,
                CalibrationEnabler,
                KalmanFilterEnabler,
                CoSimulationEnabler
]

// ------------------------------------------------------------
// C10: Models/Data
instance ModelA : DTDFVocab:Model [
    base:desc "Analytical temperature dynamics model (Model A) derived from heat‑transfer equations assuming uniform air temperature and negligible wall heat storage"
    DTDFVocab:inputTo CalibrationEnabler,
                CoSimulationEnabler
]

instance ModelB : DTDFVocab:Model [
    base:desc "Enhanced analytical model (Model B) including heat‑bed thermal inertia; used for higher‑fidelity estimation and Kalman filtering"
    DTDFVocab:inputTo CalibrationEnabler,
                KalmanFilterEnabler,
                CoSimulationEnabler
]

// ------------------------------------------------------------
// C11: Enablers (tooling & enablers)
instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker providing AMQP over TCP for sensor data and control commands"
    DTDFVocab:enables RealTimeVisualizationService,
                OnDemandCalibrationService,
                AnomalyDetectionService,
                WhatIfSimulationService,
                SelfAdaptationService
]

instance LowLevelDriverEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level driver on Raspberry Pi abstracting sensor/actuator I/O, publishing sensor readings to RabbitMQ and receiving actuation commands"
    DTDFVocab:enables RealTimeVisualizationService,
                OnDemandCalibrationService,
                AnomalyDetectionService,
                WhatIfSimulationService,
                SelfAdaptationService
]

instance TimeSeriesDBEnabler : DTDFVocab:Enabler [
    base:desc "Time‑series database storing real‑time temperature data for dashboard visualisation"
    DTDFVocab:enables RealTimeVisualizationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Component that streams temperature data from the time‑series database to the web‑based dashboard"
    DTDFVocab:enables RealTimeVisualizationService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that updates parameters of Model A and Model B on‑demand using latest temperature data"
    DTDFVocab:enables OnDemandCalibrationService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter that fuses Model B predictions with temperature measurements for heat‑bed state estimation and anomaly detection"
    DTDFVocab:enables AnomalyDetectionService
]

instance CoSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Co‑simulation component that ingests PT data and calibrated models to run what‑if scenarios"
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationEnabler : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop that detects behavioural changes, schedules experiments, triggers re‑calibration, updates the Kalman filter and re‑configures the controller"
    DTDFVocab:enables SelfAdaptationService
]

// ------------------------------------------------------------
// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualisation of temperature readings and controller states on a web dashboard"
    DTDFVocab:provides RealTimeTemperatureInsight,
                VisualizeTemperatureAction
]

instance OnDemandCalibrationService : DTDFVocab:Service [
    base:desc "Executes calibration algorithms to adjust Model A and Model B parameters using the latest sensor measurements"
    DTDFVocab:provides CalibrationInsight,
                CalibrateModelAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Performs anomaly detection and heat‑bed state estimation using a Kalman filter"
    DTDFVocab:provides AnomalyDetectionInsight,
                TriggerAlarmAction
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Runs predictive what‑if simulations through co‑simulation combining historical or live PT data with calibrated models"
    DTDFVocab:provides WhatIfSimulationInsight,
                RunCoSimulationAction
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Manages the self‑adaptation loop: detects changes, schedules experiments, re‑calibrates models, updates Kalman filter and re‑configures the controller"
    DTDFVocab:provides SelfAdaptationInsight,
                ScheduleExperimentAction
]

// ------------------------------------------------------------
// C17: Insights / Actions
instance RealTimeTemperatureInsight : DTDFVocab:Insight [
    base:desc "Live insight into internal and ambient temperature trends displayed on the dashboard"
]

instance VisualizeTemperatureAction : DTDFVocab:Action [
    base:desc "Automatically streams temperature data to the dashboard for visualisation"
    DTDFVocab:IsAutomatic true
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight that model parameters have been updated after calibration"
]

instance CalibrateModelAction : DTDFVocab:Action [
    base:desc "Triggers on‑demand calibration of Model A and Model B using recent sensor data"
    DTDFVocab:IsAutomatic false
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects deviations from expected temperature behaviour indicating possible faults"
]

instance TriggerAlarmAction : DTDFVocab:Action [
    base:desc "Raises an alarm when an anomaly is detected"
    DTDFVocab:IsAutomatic true
]

instance WhatIfSimulationInsight : DTDFVocab:Insight [
    base:desc "Predictive insight showing impact of alternative controller parameters on temperature regulation"
]

instance RunCoSimulationAction : DTDFVocab:Action [
    base:desc "Executes a co‑simulation run using historical or live PT data and calibrated models"
    DTDFVocab:IsAutomatic false
]

instance SelfAdaptationInsight : DTDFVocab:Insight [
    base:desc "Identifies a behavioural change (e.g., introduction of a cold object) prompting adaptation"
]

instance ScheduleExperimentAction : DTDFVocab:Action [
    base:desc "Automatically schedules an experiment, re‑calibrates models and re‑configures the controller"
    DTDFVocab:IsAutomatic true
]

// ------------------------------------------------------------
// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heating element (heat‑bed) that provides thermal energy to the incubator"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan that circulates warm air inside the insulated styrofoam box"
]

instance BangBangController : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi based bang‑bang controller with configurable lower/upper temperature limits, heating duration (H) and waiting duration (C)"
]

// ------------------------------------------------------------
// Environment grouping (optional)
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InternalTempSensor1, InternalTempSensor2, ExternalTempSensor,
                    HeatBedActuator, FanActuator, BangBangController,
                    LowLevelDriverEnabler, RabbitMQEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT issues actuation commands (e.g., turn heat‑bed on/off, set heating duration, activate fan) by publishing command messages to RabbitMQ. The controller on the Raspberry Pi subscribes to these command topics, validates the payload against expected formats (temperature limits, heating/waiting durations), and forwards the resulting control signals to the hardware drivers that drive the heat‑bed and fan. After execution the controller publishes status updates back to RabbitMQ, allowing the DT to confirm command execution."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The incubator Digital Twin is orchestrated around a RabbitMQ message broker that synchronises the physical twin (PT) components—the low‑level driver that reads sensor data and issues actuator commands—and the cyber components such as the controller, calibration service, Kalman‑filter based anomaly detector, co‑simulation engine, and visualization dashboard. All cyber services subscribe to the same RabbitMQ topics, allowing a loosely‑coupled, publish‑subscribe architecture where data flows from the PT to a time‑series database for real‑time visualisation and to analysis services. The DT components operate as independent processes that consume the same streams of measurement and command messages, providing a centralized coordination point (the broker) without a single monolithic application. This constitutes the system‑wide coordination and resource management pattern described in the documents."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing Model A (simpler) and Model B (includes heat‑bed inertia); experimental results (section 4) show Model B yields higher prediction accuracy for thermal dynamics. Model validity is ensured through on‑demand calibration that updates model parameters using observed sensor data, and through Kalman‑filter‑based state estimation that detects anomalies. Uncertainties stem from modeling assumptions (uniform temperature distribution, negligible wall heat storage, constant specific heat capacity, and power‑to‑heat conversion). Validation is performed via empirical experiments and calibration results (Figure 13). Errors are identified by the anomaly detection module, and model updates are performed to maintain accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All components of the incubator DT are interconnected through a RabbitMQ message broker deployed on‑premise (or in the cloud). Communication uses RabbitMQ’s AMQP protocol over TCP/IP, forming a star‑like topology where the Raspberry Pi (low‑level driver and controller) and DT services are clients that publish/subscribe to the broker. RabbitMQ provides message persistence and acknowledgement, offering reliable delivery with low latency suitable for near‑real‑time control. Security is handled by RabbitMQ’s built‑in authentication (username/password), though specific mechanisms are not detailed in the documents."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin implementation for the incubator incorporates safety measures through a 'safe protocol' embedded in the low‑level driver, which continuously monitors temperature readings and command messages to ensure the physical twin remains in a safe state before issuing actuator commands. Communication between the Raspberry Pi controller and the physical twin is mediated by a RabbitMQ message broker, providing reliable message passing; however, the documents do not detail authentication, encryption, or access‑control mechanisms, so only the presence of the safe protocol and the use of RabbitMQ are documented safety‑related aspects."
]