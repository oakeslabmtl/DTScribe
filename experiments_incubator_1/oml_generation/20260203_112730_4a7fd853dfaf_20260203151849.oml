// Sensing components
instance TopTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted at the top of the incubator to capture temperature."
    DTDFVocab:producedData TopTemperatureDataTransmitted
]

instance BottomTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted at the bottom of the incubator to capture temperature."
    DTDFVocab:producedData BottomTemperatureDataTransmitted
]

instance SideTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted on the side of the incubator to capture temperature."
    DTDFVocab:producedData SideTemperatureDataTransmitted
]

// Data transmitted from sensors
instance TopTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TopTemperatureSensor
]

instance BottomTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BottomTemperatureSensor
]

instance SideTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SideTemperatureSensor
]

// Data stored from transmitted data
instance TopTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from TopTemperatureSensor, stored in a local file‑based database."
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringAlgorithm, FaultDetectionAlgorithm, SupervisoryControlAlgorithm, OptimisationAlgorithm, StateEstimationAlgorithm, PredictiveAnalyticsAlgorithm
    DTDFVocab:fromData TopTemperatureDataTransmitted
]

instance BottomTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from BottomTemperatureSensor, stored in a local file‑based database."
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringAlgorithm, FaultDetectionAlgorithm, SupervisoryControlAlgorithm, OptimisationAlgorithm, StateEstimationAlgorithm, PredictiveAnalyticsAlgorithm
    DTDFVocab:fromData BottomTemperatureDataTransmitted
]

instance SideTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from SideTemperatureSensor, stored in a local file‑based database."
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringAlgorithm, FaultDetectionAlgorithm, SupervisoryControlAlgorithm, OptimisationAlgorithm, StateEstimationAlgorithm, PredictiveAnalyticsAlgorithm
    DTDFVocab:fromData SideTemperatureDataTransmitted
]

// Enablers
instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Python algorithm using SciPy to calibrate the thermal model with experimental data."
    DTDFVocab:enables CalibrationService
]

instance MonitoringAlgorithm : DTDFVocab:Enabler [
    base:desc "Python monitoring routine that checks simulated behavior against actual temperature data."
    DTDFVocab:enables MonitoringService
]

instance FaultDetectionAlgorithm : DTDFVocab:Enabler [
    base:desc "Python fault detector that flags safety or optimality violations in the incubator system."
    DTDFVocab:enables FaultDetectionService
]

instance SupervisoryControlAlgorithm : DTDFVocab:Enabler [
    base:desc "Python supervisory controller that adjusts control parameters to maintain target temperature."
    DTDFVocab:enables SupervisoryControlService
]

instance OptimisationAlgorithm : DTDFVocab:Enabler [
    base:desc "Python optimisation routine that improves energy efficiency of the heating element."
    DTDFVocab:enables OptimisationService
]

instance StateEstimationAlgorithm : DTDFVocab:Enabler [
    base:desc "Python state estimator that predicts internal temperature states."
    DTDFVocab:enables StateEstimationService
]

instance PredictiveAnalyticsAlgorithm : DTDFVocab:Enabler [
    base:desc "Python predictive analytics engine that forecasts future temperature trajectories."
    DTDFVocab:enables PredictiveAnalyticsService
]

// Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that calibrates both cyber and physical models using calibration algorithms."
    DTDFVocab:provides CalibrationInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors simulated behavior against actual operating conditions, detecting anomalies."
    DTDFVocab:provides AnomalyInsight, SendAlertToOperator
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service that implements fault detection algorithms to identify safety or optimality violations."
    DTDFVocab:provides FaultDetectionInsight
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Service that supervises control actions to maintain target temperature."
    DTDFVocab:provides ControlOptimisationInsight, AdjustControlParameters
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Service that optimizes the heating element operation to improve energy efficiency."
    DTDFVocab:provides OptimisationInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Service that estimates the internal state of the incubator temperature distribution."
    DTDFVocab:provides StateEstimationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service that provides predictive analytics for future temperature profiles."
    DTDFVocab:provides PredictionInsight
]

// Insights
instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Result of calibrating the thermal model indicates updated model parameters."
]

instance AnomalyInsight : DTDFVocab:Insight [
    base:desc "Detection that current temperature deviates from model predictions beyond acceptable threshold."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of a fault condition within the heating element or sensor."
]

instance ControlOptimisationInsight : DTDFVocab:Insight [
    base:desc "Recommendation to adjust control parameters for optimal temperature maintenance."
]

instance OptimisationInsight : DTDFVocab:Insight [
    base:desc "Optimized heating schedule to reduce energy consumption while meeting target."
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated temperature distribution across incubator enclosure."
]

instance PredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted future temperature trajectory under current operating conditions."
]

// Actions
instance SendAlertToOperator : DTDFVocab:Action [
    base:desc "Alert delivered to human operator via notification system."
    DTDFVocab:IsAutomatic false
]

instance AdjustControlParameters : DTDFVocab:Action [
    base:desc "Automatic adjustment of heating element power to maintain target temperature."
    DTDFVocab:IsAutomatic true
]

// Environment and components
instance InsulatedEnclosureComponent : DTDFVocab:Component [
    base:desc "Insulated enclosure providing thermal isolation for the incubator."
]

instance HeatingElementComponent : DTDFVocab:Component [
    base:desc "Built‑in heating element that generates heat for the incubator."
]

instance RaspberryPiBComponent : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B embedded controller controlling heating and collecting sensor data."
]

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InsulatedEnclosureComponent, HeatingElementComponent, RaspberryPiBComponent, TopTemperatureSensor, BottomTemperatureSensor, SideTemperatureSensor
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin architecture is structured around a sensor‑data ingestion pipeline that feeds real‑time measurements into a calibration module. This module continuously adjusts the parameters of the system’s cyber‑physical and environmental models, ensuring that the simulated representation remains aligned with the Physical Twin. The calibrated models are consumed by a monitoring subsystem that performs safety, performance, and operational compliance checks in near‑real time. Any detected violations are flagged to an alerting mechanism, which can trigger automated remediation logic or hand over control to human operators via a supervisory interface. The coordination workflow involves a central data orchestration layer that routes information between data acquisition, model calibration, monitoring, and decision‑making components, facilitating resource allocation and temporal synchronization across these layers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle as described involves: 1) Creation and integration of the PT’s development models into a digital framework; 2) Continuous data acquisition from PT sensors over time; 3) Calibration of the integrated models through calibration algorithms that update model parameters to best fit observed data trajectories; 4) Deployment of the calibrated models into a digital twin that continuously monitors the PT’s safety and optimality via monitors informed by the updated data. The document does not detail additional governance phases or formal transition management beyond this data–model–monitor loop."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin framework incorporates monitoring mechanisms that evaluate whether the system is performing safely and optimally. These monitors utilize data generated from the Physical Twin (collected by sensors over time) and the calibrated models to detect violations. When a safety or performance violation is detected, either human operators or automated algorithms may decide to modify the Physical Twin. Additionally, the Algorithms layer includes fault detectors, supervisory controllers, and state estimators that support safety‑critical decision making. No further explicit cybersecurity, access control, or fail‑safe mechanisms are detailed in the provided document."
]