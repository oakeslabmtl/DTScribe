// C2: Acting Components
instance HeatbedHeater : DTDFVocab:ActingComponent [
    base:desc "Electrical heater (heatbed) delivering up to 100 W to maintain incubator temperature."
]

instance FanBlower : DTDFVocab:ActingComponent [
    base:desc "Blower fan providing 0.02 m³/s airflow, controlled via MOSFET and optocoupler."
]

// C3: Physical sensing components
instance DS18S20BoxSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer inside the incubator box (–55 °C to +125 °C, ±0.5 °C accuracy)."
    DTDFVocab:producedData BoxSensor1DataTrans
]

instance DS18S20BoxSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer inside the incubator box, second temperature monitoring point."
    DTDFVocab:producedData BoxSensor2DataTrans
]

instance DS18S20RoomSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer outside the incubator box measuring ambient room temperature."
    DTDFVocab:producedData RoomSensorDataTrans
]

instance PowerSupplyMeter : DTDFVocab:SensingComponent [
    base:desc "Meter measuring voltage and current of the incubator’s power supply."
    DTDFVocab:producedData PowerSupplyDataTrans
]

instance CalibrationResidualCollector : DTDFVocab:SensingComponent [
    base:desc "Component capturing calibration residuals generated during parameter estimation."
    DTDFVocab:producedData CalibrationResidualDataTrans
]

// C4: Physical‑to‑virtual interaction
instance BoxSensor1DataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20BoxSensor1
]

instance BoxSensor2DataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20BoxSensor2
]

instance RoomSensorDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20RoomSensor
]

instance PowerSupplyDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerSupplyMeter
]

instance CalibrationResidualDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CalibrationResidualCollector
]

// C10: Models/Data
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single‑state temperature model parameterised by C_air (thermal capacitance) and G_box (heat‑transfer coefficient)."
    DTDFVocab:inputTo PredictionEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Dual‑state model with parameters C_air, C_heater, G_box, G_heater enabling heater dynamics."
    DTDFVocab:inputTo PredictionEnabler
]

instance TemperatureMeasurementsData : DTDFVocab:Data [
    base:desc "Aggregated temperature measurements from the three DS18S20 sensors."
    DTDFVocab:fromData BoxSensor1DataTrans, BoxSensor2DataTrans, RoomSensorDataTrans
    DTDFVocab:inputTo PredictionEnabler
]

instance PowerSupplyData : DTDFVocab:Data [
    base:desc "Voltage and current measurements of the incubator power supply."
    DTDFVocab:fromData PowerSupplyDataTrans
    DTDFVocab:inputTo PredictionEnabler
]

instance CalibrationResidualsData : DTDFVocab:Data [
    base:desc "Calibration residuals resulting from nonlinear least‑squares optimisation."
    DTDFVocab:fromData CalibrationResidualDataTrans
    DTDFVocab:inputTo CalibrationEnabler
]

// C11: Enablers
instance PredictionEnabler : DTDFVocab:Enabler [
    base:desc "Service enabler executing real‑time temperature prediction using ThermalModelA and B."
    DTDFVocab:enables TemperaturePredictionService, MonitoringService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Service enabler performing nonlinear least‑squares calibration of model parameters."
    DTDFVocab:enables CalibrationService
]

// C6: Services
instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Dynamic temperature prediction based on simulation models, with runtime monitoring."
    DTDFVocab:provides TemperatureTrajectoriesInsight, ControllerTuningAction
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Model‑based monitoring of the incubator, assessing temperature uniformity."
    DTDFVocab:provides TemperatureUniformityInsight, FanVoltageAdjustmentAction, HeatbedPowerAdjustmentAction
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Parameter estimation service leveraging least‑squares to update thermal mass and heat‑transfer coefficients."
    DTDFVocab:provides ThermalMassEstimateInsight, HeatTransferCoefficientInsight
]

// C17: Insights/Actions
instance ThermalMassEstimateInsight : DTDFVocab:Insight [
    base:desc "Updated estimate of the incubator’s thermal mass derived from calibration."
]

instance HeatTransferCoefficientInsight : DTDFVocab:Insight [
    base:desc "Updated heat‑transfer coefficient between the incubator box and the environment."
]

instance TemperatureTrajectoriesInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectories for the incubator over the next time horizon."
]

instance TemperatureUniformityInsight : DTDFVocab:Insight [
    base:desc "Assessment of temperature uniformity inside the incubator box."
]

instance FanVoltageAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of fan blower voltage to improve temperature uniformity."
    DTDFVocab:IsAutomatic true
]

instance HeatbedPowerAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of heatbed power to track desired temperature set‑points."
    DTDFVocab:IsAutomatic true
]

instance ControllerTuningAction : DTDFVocab:Action [
    base:desc "Direct controller tuning based on predicted temperature evolution."
    DTDFVocab:IsAutomatic false
]

// C16: Environment and Components
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedHeater, FanBlower, DS18S20BoxSensor1, DS18S20BoxSensor2, DS18S20RoomSensor, RaspberryPiDevice, PowerSupplyMeter, CalibrationResidualCollector
]

instance RaspberryPiDevice : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running low‑level driver and controller."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital‑twin commands (e.g., turn heatbed on/off, adjust fan speed) are sent from the virtual layer to the Raspberry Pi via RabbitMQ, which forwards them to the low‑level driver for actuation of the heatbed and fan"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centric architecture where the Raspberry Pi hosts the low‑level driver and communication server (RabbitMQ); the DT models and processing run locally, all exchanging messages via AMQP over the local network"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the design (ideal models), manufacturing (hardware assembly of the incubator), and operation (real‑time monitoring, calibration, and prediction) stages of the twin"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model A and Model B calibration and validation against experimental temperature trajectories; Model B better captures thermal inertia due to inclusion of heatbed heat capacity; residual error minimization via least‑squares provides quantitative validity; assumptions (e.g., uniform temperature, negligible wall heat) are explicitly tested experimentally"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical connections: DS18S20 sensors on a 1‑Wire bus wired to a Raspberry Pi GPIO pin; MOSFETs and optocouplers interface Pi GPIO to heater and fan drivers. Communication between PT and DT is via RabbitMQ message broker running on the Raspberry Pi, accessed over local TCP/IP (Wi‑Fi or Ethernet). All data is serialized in standard JSON/CSV messages."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components—including the RabbitMQ broker, low‑level driver, controller, and Python‑based model scripts—are deployed and executed on the Raspberry Pi 4 Model B. The code repository is hosted on GitHub for version control and reproducibility."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safety protocol that ensures the system maintains a safe operating state, preventing over‑temperature or over‑current conditions. While the RabbitMQ broker runs locally, no explicit encryption or authentication mechanisms are described."
]