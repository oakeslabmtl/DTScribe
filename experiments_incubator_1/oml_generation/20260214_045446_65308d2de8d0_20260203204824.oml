// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:desc "The digital twin environment encompassing the styrofoam container, Raspberry Pi controller, actuators, and temperature sensors."
    base:contains StyrofoamBoxEnclosure, RaspberryPiController, HeatbedActuator, FanActuator, InternalTemperatureSensor1, InternalTemperatureSensor2, ExternalTemperatureSensor
]

// Physical constructs
instance StyrofoamBoxEnclosure : DTDFVocab:Component [
    base:desc "Thermally insulated styrofoam container housing the incubator."
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running firmware that reads 1‑Wire DS18S20 sensors and publishes data to RabbitMQ."
]

// Acting components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Bang–bang heater element controlled via GPIO pins on the Raspberry Pi."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Binary fan driven by GPIO pins to circulate air within the enclosure."
]

// Sensing components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer mounted inside the styrofoam box (point 1)."
    DTDFVocab:producedData InternalTempData1
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer mounted inside the styrofoam box (point 2)."
    DTDFVocab:producedData InternalTempData2
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer mounted externally to monitor ambient temperature."
    DTDFVocab:producedData ExternalTempData
]

// Data transmitted over RabbitMQ
instance InternalTempData1 : DTDFVocab:DataTransmitted [
    base:desc "Raw temperature reading from InternalTemperatureSensor1, published to RabbitMQ."
    DTDFVocab:producedFrom InternalTemperatureSensor1
]

instance InternalTempData2 : DTDFVocab:DataTransmitted [
    base:desc "Raw temperature reading from InternalTemperatureSensor2, published to RabbitMQ."
    DTDFVocab:producedFrom InternalTemperatureSensor2
]

instance ExternalTempData : DTDFVocab:DataTransmitted [
    base:desc "Raw temperature reading from ExternalTemperatureSensor, published to RabbitMQ."
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

// Recorded temperature data
instance TemperatureReading1 : DTDFVocab:Data [
    base:desc "Timestamped temperature measurement derived from InternalTempData1."
    DTDFVocab:fromData InternalTempData1
    DTDFVocab:inputTo RabbitMQBrokerEnabler, CalibrationEnabler, SimulationEnabler, PredictionEnabler, SupervisoryEnabler
]

instance TemperatureReading2 : DTDFVocab:Data [
    base:desc "Timestamped temperature measurement derived from InternalTempData2."
    DTDFVocab:fromData InternalTempData2
    DTDFVocab:inputTo RabbitMQBrokerEnabler, CalibrationEnabler, SimulationEnabler, PredictionEnabler, SupervisoryEnabler
]

instance TemperatureReading3 : DTDFVocab:Data [
    base:desc "Timestamped temperature measurement derived from ExternalTempData."
    DTDFVocab:fromData ExternalTempData
    DTDFVocab:inputTo RabbitMQBrokerEnabler, CalibrationEnabler, SimulationEnabler, PredictionEnabler, SupervisoryEnabler
]

// Thermal simulation models
instance TwoParameterLinearModel : DTDFVocab:Model [
    base:desc "Two‑parameter linear thermal model capturing overall heat‑transfer coefficient and effective thermal capacitance."
    DTDFVocab:inputTo SimulationEnabler
]

instance FourParameterNonlinearModel : DTDFVocab:Model [
    base:desc "Four‑parameter nonlinear model adding thermal inertia of the heatbed and fan dynamics."
    DTDFVocab:inputTo SimulationEnabler
]

// Enablers (facilitating services)
instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker ingesting sensor data for the digital twin."
    DTDFVocab:enables MonitoringService, SimulationService, CalibrationService, PredictionService, SupervisoryControlService, VisualizationService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Python service performing non‑linear least‑squares calibration of the thermal models."
    DTDFVocab:enables CalibrationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python service running Scipy optimization and simulation of thermal dynamics."
    DTDFVocab:enables SimulationService
]

instance PredictionEnabler : DTDFVocab:Enabler [
    base:desc "Python service forecasting short‑term temperature trajectories."
    DTDFVocab:enables PredictionService
]

instance SupervisoryEnabler : DTDFVocab:Enabler [
    base:desc "Fault‑detection and supervisory control logic applying safety thresholds."
    DTDFVocab:enables SupervisoryControlService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Flask web server hosting an interactive dashboard for real‑time data visualization."
    DTDFVocab:enables VisualizationService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuously ingests temperature telemetry, publishes via RabbitMQ, and archives for trend analysis."
    DTDFVocab:provides TemperatureTrendInsight, AnomalyAlertInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs the two thermal models to simulate internal temperature response to heater power and ambient conditions."
    DTDFVocab:provides SimulationInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Auto‑calibrates the thermal model parameters using live telemetry."
    DTDFVocab:provides CalibrationReportInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Forecasts short‑term temperature trajectories to enable pre‑emptive adjustments."
    DTDFVocab:provides PredictionInsight
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Generates safety alerts and recommended power setpoints does not directly command the Pi."
    DTDFVocab:provides ControlRecommendationInsight, SendAlertAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Displays real‑time sensor data, model state, and prediction traces on a web dashboard."
    DTDFVocab:provides VisualizationInsight
]

// Insights
instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing temperature trends over time from the monitoring service."
]

instance AnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Alert triggered when temperature deviations exceed safety thresholds."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Result of the thermal simulation comparing predicted and actual temperatures."
]

instance CalibrationReportInsight : DTDFVocab:Insight [
    base:desc "Report detailing calibrated model parameters and fit quality."
]

instance PredictionInsight : DTDFVocab:Insight [
    base:desc "Short‑term temperature trajectory forecast for the next few minutes."
]

instance ControlRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommended heater power setpoint based on supervisory control logic."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of sensor data, simulation outputs, and prediction traces on the dashboard."
]

// Actions
instance SendAlertAction : DTDFVocab:Action [
    base:desc "Sends an alert notification to operators when safety thresholds are breached."
    DTDFVocab:IsAutomatic true
]

instance RecommendPowerSetpointAction : DTDFVocab:Action [
    base:desc "Recommends a specific heater power setpoint for the operator."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands, issued by the DT’s controller logic, are sent over RabbitMQ to the low‑level driver. The controller, which implements a bang‑bang strategy, receives temperature feedback, decides on fan and heatbed states, and instructs the driver to actuate the respective hardware. Confirmation is implicitly handled by the driver’s safe protocol when publishing the actuator states back to RabbitMQ."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sensor data from the incubator’s temperature sensors is read by the Raspberry Pi controller and fed into the digital twin. The twin performs model calibration and Kalman‑filter state estimation within the loop defined by the controller’s driver messages. The documents do not specify any explicit synchronization frequency, latency requirement, or temporal granularity for these processes."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin orchestrates sensor data collection, online calibration of the parameterised thermal model (Model B), a Kalman‑filter based estimation of the heat‑bed temperature, anomaly detection via filter innovations, and what‑if co‑simulation runs that evaluate and optimise controller parameters. All modules run on the Raspberry Pi host; sensor readings and low‑level driver messages are transmitted through a local messaging bus, allowing the twin to update models and adjust control logic in real time."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Modeling, calibration, real‑time data integration, monitoring, optimisation and supervisory control. During the development phase the digital twin is constructed as a set of numerical simulation models (two versions described in the paper), accompanied by a calibration algorithm that continuously updates model parameters based on sensor data. In runtime the data stream from the physical twin (two internal and one external temperature sensor) feeds the monitoring component, which checks safety and performance constraints; when violations are detected a supervisory controller or human operator can modify the physical twin or the model. This flow represents the typical lifecycle phases: design, calibration, validation, deployment, monitoring, and evolution."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed by comparing simulated temperature trajectories (from both two‑parameter and four‑parameter thermal models) against experimentally recorded temperature data during calibration runs. The four‑parameter model is deemed superior due to its better representation of the heatbed’s thermal inertia, making it the preferred model for ongoing DT development. Validation procedures involve periodic injection of test temperature profiles and measurement of prediction error; however, explicit uncertainty quantification sources, error correction mechanisms, or formal quality assurance processes are not detailed in the documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT and PT interact over a RabbitMQ broker that implements the AMQP protocol over TCP. The networking topology is a star configuration with the Raspberry Pi controller as a client and the RabbitMQ server as a central message broker (local to the incubator enclosure). Communication occurs over the local network (Wi‑Fi or Ethernet). While RabbitMQ supports high availability and clustering, the documentation indicates that the broker can be deployed on‑premises (e.g., on the Raspberry Pi) or in the cloud; however, no explicit redundancy or load‑balancing configuration is described in the case study. The batch size and latency are not quantified, but the control loop requires sub‑second latency to maintain temperature stability."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT’s core components—controller, low‑level driver, and simulation models—are deployed on a Raspberry Pi 4 Model B, serving as an edge device that runs on‑premises. The RabbitMQ message broker is also instantiated locally on the same Pi (or on a local network) according to the repository’s deployment scripts. Computational resources are modest (single‑core CPU, 2 GB RAM) and storage is sufficient to host the software stack and log files. The system is designed for small‑scale deployment; scalability mechanisms (horizontal scaling, clustering) or high‑availability redundancy are not included in the documented setup."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Twin interfaces with the physical incubator through the Raspberry Pi’s GPIO pins (for connecting sensors, fan, and heatbed controls).  Software data exchange within the Twin relies on the local RabbitMQ broker; no external communication protocols or enterprise interoperability standards (such as OPC‑UA, MQTT, REST) are documented.  Consequently, the Twin’s horizontal integration scope is limited to the immediate physical plant and its internal, locally‑hosted components."
]