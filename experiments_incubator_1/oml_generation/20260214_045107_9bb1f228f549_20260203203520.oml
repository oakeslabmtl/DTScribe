// Actuating components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator that supplies thermal energy to the incubator enclosure, controlled by the Raspberry Pi to achieve target temperature."
]
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator that circulates heat within the enclosure, driven by PWM from Raspberry Pi."
]
instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi computational hub running low-level firmware interfacing with sensors, heatbed, and fan, and communicating via RabbitMQ."
]

// Physical sensing components
instance InsideTemperatureSensorA : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor located inside the insulated styrofoam box, measuring internal temperature."
    DTDFVocab:producedData InsideTempReadingsViaRabbitMQ_A
]
instance InsideTemperatureSensorB : DTDFVocab:SensingComponent [
    base:desc "Second internal temperature sensor inside the insulated styrofoam box."
    DTDFVocab:producedData InsideTempReadingsViaRabbitMQ_B
]
instance OutsideTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor positioned outside the insulation box, measuring ambient temperature."
    DTDFVocab:producedData OutsideTempReadingsViaRabbitMQ
]

// Data transmitted to the Digital Twin via RabbitMQ
instance InsideTempReadingsViaRabbitMQ_A : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensorA
]
instance InsideTempReadingsViaRabbitMQ_B : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensorB
]
instance OutsideTempReadingsViaRabbitMQ : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideTemperatureSensor
]

// Processed data stored in the twin
instance InsideTemperatureData_A : DTDFVocab:Data [
    base:desc "Processed internal temperature data for InsideTemperatureSensorA, sourced from RabbitMQ."
    DTDFVocab:fromData InsideTempReadingsViaRabbitMQ_A
    DTDFVocab:inputTo CalibrationAlgorithm
    DTDFVocab:inputTo MonitoringEngine
]
instance InsideTemperatureData_B : DTDFVocab:Data [
    base:desc "Processed internal temperature data for InsideTemperatureSensorB, sourced from RabbitMQ."
    DTDFVocab:fromData InsideTempReadingsViaRabbitMQ_B
    DTDFVocab:inputTo CalibrationAlgorithm
    DTDFVocab:inputTo MonitoringEngine
]
instance OutsideTemperatureData : DTDFVocab:Data [
    base:desc "Processed ambient temperature data from OutsideTemperatureSensor."
    DTDFVocab:fromData OutsideTempReadingsViaRabbitMQ
    DTDFVocab:inputTo CalibrationAlgorithm
    DTDFVocab:inputTo MonitoringEngine
]

// Enablers
instance RabbitMQMessaging : DTDFVocab:Enabler [
    base:desc "RabbitMQ message queue transporting sensor readings, control commands, and calibration requests between Physical and Digital Twins."
]
instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Calibration routine that updates model parameters by comparing simulated outputs with actual sensor data, yielding best‑estimation model."
    DTDFVocab:enables CalibrationService
]
instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation layer executing two physics‑based thermal models (coupled ODEs) on the same platform, updated by calibration."
]
instance MonitoringEngine : DTDFVocab:Enabler [
    base:desc "Monitoring algorithm that flags deviations from expected behaviour and triggers corrective action recommendations."
    DTDFVocab:enables RealTimeMonitoringService
]

// Models
instance MinimalThermalModel : DTDFVocab:Model [
    base:desc "Physics-based thermal model with two free parameters: thermal resistance and bulk heat capacity."
    DTDFVocab:inputTo SimulationEngine
    DTDFVocab:inputTo CalibrationAlgorithm
]
instance DetailedThermalModel : DTDFVocab:Model [
    base:desc "Extended thermal model with four parameters, capturing heatbed inertia and ambient coupling."
    DTDFVocab:inputTo SimulationEngine
    DTDFVocab:inputTo CalibrationAlgorithm
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing continuous telemetry of internal and external temperatures for safety and performance verification."
    DTDFVocab:provides FaultDetectionInsight, FanSpeedAdjustmentAction, HeatingPowerAdjustmentAction, FaultAlertAction
]
instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Service forecasting internal temperature trajectories under varying conditions using physics-based models."
    DTDFVocab:provides TemperatureForecastInsight
]
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that updates model parameters by comparing sensor data with simulation outputs."
    DTDFVocab:provides UpdatedModelInsight
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Service offering advanced visualisation of measurement and simulation results for intuitive graphical insight."
    DTDFVocab:provides VisualizationAction
]

// Insights
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating fault detection events such as sensor failure or temperature drift."
]
instance ThermalInertiaInferenceInsight : DTDFVocab:Insight [
    base:desc "Insight inferring internal thermal inertia of the heatbed from calibrated models."
]
instance HeatingScheduleInsight : DTDFVocab:Insight [
    base:desc "Insight providing optimal heating schedules derived from state estimation and optimisation."
]
instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Insight forecasting future internal temperature trajectory from predictive models."
]
instance UpdatedModelInsight : DTDFVocab:Insight [
    base:desc "Insight reporting updated model parameters after calibration."
]

// Actions
instance FanSpeedAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic action to modify fan speed via PWM to correct temperature deviations."
    DTDFVocab:IsAutomatic true
]
instance HeatingPowerAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic action to change heating power to achieve target temperature."
    DTDFVocab:IsAutomatic true
]
instance FaultAlertAction : DTDFVocab:Action [
    base:desc "Automatic action to notify human operator of fault detection."
    DTDFVocab:IsAutomatic true
]
instance HeatingScheduleAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust heating schedule based on optimisation results."
    DTDFVocab:IsAutomatic true
]
instance VisualizationAction : DTDFVocab:Action [
    base:desc "Automatic action to present graphical visualisation of measurement and simulation data."
    DTDFVocab:IsAutomatic true
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator, FanActuator, RaspberryPiController,
    InsideTemperatureSensorA, InsideTemperatureSensorB, OutsideTemperatureSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT realizes control commands by publishing messages to the RabbitMQ server, which the Raspberry Pi controller receives. The controller implements a bang‑bang logic using the parameters LL (lower limit), UL (upper limit), H (heating duration), and C (waiting duration). It turns the heatbed on/off and adjusts the fan to regulate temperature, and it publishes current control states back to RabbitMQ. The low‑level driver ensures that commands are executed safely; however, the documents provide no specific authentication, validation, or conflict resolution details."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin is built around the plant’s sensor data stream, which is collected via two inside temperature sensors and one outside temperature sensor. Sensor data are fed into a simulation module that contains two deterministic models: a two‑parameter model (Model A) and a four‑parameter model (Model B). The twin performs online calibration using least‑squares estimation on recent sensor data to update the models. A Kalman‑filter based estimator fuses the measured inside temperature with the modelled heat‑bed temperature to estimate the unmeasured heat‑bed state. Detection of anomalies in the plant behaviour is performed by comparing the real sensor data against the model predictions. The control strategy is implemented on the Raspberry Pi controller and is re‑configured by the twin after calibration and estimation steps. All these components are coordinated by a lightweight runtime located on the same embedded system, which orchestrates data flow between sensors, models, and control logic."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle in the incubation case follows a cyclic process: (1) Model development – creation of a dynamic model (differential‑equation based) that captures the thermal dynamics of the incubator; (2) Integration – embedding the model within the DT framework alongside real‑time sensor data streams; (3) Deployment – coupling the DT to the physical twin (the incubator box, heatbed, fan, sensors) for online operation; (4) Runtime data acquisition – continuous collection of temperature readings via wired or wireless sensors; (5) Calibration – application of calibration algorithms that update model parameters to minimise the residual between prediction and observation; (6) Monitoring and safety checks – execution of monitoring algorithms that evaluate whether the system remains within predefined safety and performance envelopes; (7) Decision and actuation – if violations are detected, either a human operator or an autonomous supervisory controller issues corrective commands to the physical twin; (8) Iteration – the schedule of calibration and monitoring repeats, refining the model and control logic, thereby creating a governance loop that ensures the DT remains an accurate and actionable representation of the PT."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is driven by the need to accurately capture the thermal inertia of the incubator’s heatbed and enclosure. Calibration of the two simulation models is performed using experimental data from controlled heating tests; the calibration procedure updates the models’ free parameters to minimize the error between predicted and measured temperatures. The twin relies on the model with four free parameters because experiments show it better predicts heatbed inertia. Validation is conducted through uniform temperature experiments that verify model assumptions about temperature homogeneity. While formal verification metrics are not reported, the documents emphasize experimental comparison as a validation method, and use calibration algorithms—described in the literature as nonlinear least‑squares solvers—to refine the models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All interactions between the DT and PT are mediated by RabbitMQ, an open‑source message broker described as mature, lightweight, and easy to deploy on premises and in the cloud. The specific underlying protocol (e.g., AMQP) is not mentioned, and documentation offers no detailed network topology, bandwidth, latency, or redundancy specifications."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT implementation is deployed on a Raspberry Pi controlling the incubator. The RabbitMQ server and controller software run on the same Pi (on‑premise deployment). The source documents also acknowledge that RabbitMQ can be run on premises or in the cloud, but the current case study is on‑premise. No explicit scalability mechanisms, multiple deployment models, or availability guarantees are detailed beyond the generic statement that the server is lightweight and easy to deploy."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin incorporates runtime monitoring components that evaluate the state of the physical twin. Calibration algorithms continuously update the process and environment models using incoming sensor data. The monitors compare model predictions with real‑time measurements to detect deviations from safe operating envelopes; when a violation is detected the system notifies human operators or supervisory algorithms that may intervene to adjust control signals or recommend corrective actions. This runtime safety oversight is a core part of the DT’s role in ensuring safe and optimal operation of the physical incubator."
]