// Sensing components: DS18S20 temperature sensors
instance InsideTemperatureSensorOne : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside the incubator for process monitoring."
    DTDFVocab:producedData InsideTempDataTransmitted
]

instance InsideTemperatureSensorTwo : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside the incubator for process monitoring."
    DTDFVocab:producedData InsideTempDataTransmittedTwo
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor measuring ambient temperature outside the incubator."
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// Data transmitted from sensors over RabbitMQ AMQP
instance InsideTempDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Temperature data transmitted from InsideTemperatureSensorOne via AMQP over RabbitMQ."
    DTDFVocab:producedFrom InsideTemperatureSensorOne
    DTDFVocab:fromData InsideTemperatureData
]

instance InsideTempDataTransmittedTwo : DTDFVocab:DataTransmitted [
    base:desc "Temperature data transmitted from InsideTemperatureSensorTwo via AMQP over RabbitMQ."
    DTDFVocab:producedFrom InsideTemperatureSensorTwo
    DTDFVocab:fromData InsideTemperatureDataTwo
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Temperature data transmitted from AmbientTemperatureSensor via AMQP over RabbitMQ."
    DTDFVocab:producedFrom AmbientTemperatureSensor
    DTDFVocab:fromData AmbientTemperatureData
]

// Time series data of sensor readings
instance InsideTemperatureData : DTDFVocab:Data [
    base:desc "Time series of temperature readings from InsideTemperatureSensorOne."
    DTDFVocab:inputTo PythonSimulationEngine, RealTimeTemperatureMonitoringService, RabbitMQBroker
    DTDFVocab:fromData InsideTempDataTransmitted
]

instance InsideTemperatureDataTwo : DTDFVocab:Data [
    base:desc "Time series of temperature readings from InsideTemperatureSensorTwo."
    DTDFVocab:inputTo PythonSimulationEngine, RealTimeTemperatureMonitoringService, RabbitMQBroker
    DTDFVocab:fromData InsideTempDataTransmittedTwo
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Time series of ambient temperature readings from AmbientTemperatureSensor."
    DTDFVocab:inputTo PythonSimulationEngine, RealTimeTemperatureMonitoringService, RabbitMQBroker
    DTDFVocab:fromData AmbientTempDataTransmitted
]

// Acting components: heatbed and fan controlled via MOSFET drivers
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET-driven heatbed controlled by the Raspberry Pi with optocoupler isolation."
    DTDFVocab:producedData HeatbedStateDataTransmitted
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET-driven fan controlled by the Raspberry Pi with optocoupler isolation."
    DTDFVocab:producedData FanStateDataTransmitted
]

// Data transmitted from actuators representing their status
instance HeatbedStateDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Heatbed actuator state transmitted over RabbitMQ AMQP."
    DTDFVocab:producedFrom HeatbedActuator
    DTDFVocab:fromData HeatbedStateData
]

instance FanStateDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Fan actuator state transmitted over RabbitMQ AMQP."
    DTDFVocab:producedFrom FanActuator
    DTDFVocab:fromData FanStateData
]

// Actuator state logs
instance HeatbedStateData : DTDFVocab:Data [
    base:desc "Log of heatbed actuator on/off states."
    DTDFVocab:inputTo PythonSimulationEngine, RabbitMQBroker
    DTDFVocab:fromData HeatbedStateDataTransmitted
]

instance FanStateData : DTDFVocab:Data [
    base:desc "Log of fan actuator on/off states."
    DTDFVocab:inputTo PythonSimulationEngine, RabbitMQBroker
    DTDFVocab:fromData FanStateDataTransmitted
]

// Dynamic thermal models
instance ModelA : DTDFVocab:Model [
    base:desc "Dynamic thermal model A derived from energy balance equations with calibrated parameters (C_air, G_box, C_heater, G_heater)."
    DTDFVocab:inputTo PythonSimulationEngine
]

instance ModelB : DTDFVocab:Model [
    base:desc "Dynamic thermal model B derived from energy balance equations with calibrated parameters (C_air, G_box, C_heater, G_heater)."
    DTDFVocab:inputTo PythonSimulationEngine
]

// Enablers
instance PythonSimulationEngine : DTDFVocab:Enabler [
    base:desc "Python-based simulation engine executing calibrated Models A and B for predictive simulation and control."
    DTDFVocab:enables PredictiveSimulationService, BangBangControlService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker facilitating data exchange between physical sensors/actuators and the Digital Twin."
    DTDFVocab:enables RealTimeTemperatureMonitoringService, VisualizationService
]

instance SciPyCalibrationEngine : DTDFVocab:Enabler [
    base:desc "SciPy optimization engine performing nonlinear least-squares calibration of model parameters."
    DTDFVocab:enables AutomatedCalibrationService
]

// Services
instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation using calibrated Models A and B."
    DTDFVocab:provides ThermalInertiaInsight, HeatbedEfficiencyInsight
]

instance RealTimeTemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of temperature via streamed data from sensors."
    DTDFVocab:provides TemperatureTrendVisualization
]

instance AutomatedCalibrationService : DTDFVocab:Service [
    base:desc "Automated calibration of models using nonlinear least-squares with SciPy."
    DTDFVocab:provides PredictiveAdjustmentAction, MaintenanceRecommendationAction
]

instance BangBangControlService : DTDFVocab:Service [
    base:desc "Bang-bang style temperature control based on setpoints."
    DTDFVocab:provides BangBangControlAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualization of temperature trends and actuator states."
    DTDFVocab:provides TemperatureTrendVisualization
]

// Insights
instance ThermalInertiaInsight : DTDFVocab:Insight [
    base:desc "Insight into thermal inertia derived from calibrated models."
]

instance HeatbedEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight into heatbed efficiency informing predictive adjustments."
]

instance TemperatureTrendVisualization : DTDFVocab:Insight [
    base:desc "Visualization of temperature trends over time."
]

// Actions
instance PredictiveAdjustmentAction : DTDFVocab:Action [
    base:desc "Action to adjust temperature setpoints based on model predictions."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Action recommending maintenance if model predictions deviate beyond thresholds."
    DTDFVocab:IsAutomatic false
]

instance BangBangControlAction : DTDFVocab:Action [
    base:desc "Action controlling actuator state in a bang-bang fashion."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT subscribes to actuator command messages via RabbitMQ and forwards them to the Raspberry Pi controller, which outputs GPIO signals to the MOSFET driver to energise the heatbed and fan accordingly."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized architecture: the Raspberry Pi hosts the controller, low‑level driver, and RabbitMQ server; sensors feed data, while the DT component receives messages via RabbitMQ, performs modeling/calibration, and publishes actuator commands back to the Pi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design → Manufacture (hardware assembly & software deployment) → Calibration & Validation (parameter estimation, uniform temperature experiments) → Operation (runtime monitoring and control), with ability to evolve models and firmware over time."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Models rest on Assumptions 1‑4 (uniform temperature, negligible wall heat, constant specific heat, and heatbed power transfer); validation via controlled experiments; calibration using least‑squares to minimize residual error; uncertainty arises from parameter estimation and sensor accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "AMQP over TCP via RabbitMQ broker on the Raspberry Pi, with publisher/subscriber pattern between DT and PT components."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Local deployment on the Raspberry Pi 4, with all DT services (model, controller, communication server) running on the same hardware as the physical twin."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safety protocol is embedded in the low‑level driver to prevent over‑current and overheating during actuation; all messages are transmitted over the local RabbitMQ broker, minimizing external exposure. The use of opto‑isolated MOSFET drivers safeguards the Pi from high‑current faults and enhances overall system safety."
]