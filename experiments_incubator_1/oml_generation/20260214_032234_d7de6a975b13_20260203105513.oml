// C2: Sensing Components
instance PhysicalTwinSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors on Physical Twin providing data for Digital Twin"
    DTDFVocab:producedData SensorDataTransmitted
]

// C3: Data Transmitted
instance SensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalTwinSensor
]

// C4: Data
instance SensorData : DTDFVocab:Data [
    base:desc "Real-time sensor data collected from Physical Twin"
    DTDFVocab:fromData SensorDataTransmitted
]

// C10: Models
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "CAD representations of physical components for geometric modeling"
    DTDFVocab:inputTo CalibrationAlgorithm, FaultDetector, StateEstimator, Optimizer
]

instance MotionAnalysisBehavioralModel : DTDFVocab:Model [
    base:desc "Dynamic systems model described by differential equations for motion analysis"
    DTDFVocab:inputTo CalibrationAlgorithm, FaultDetector, StateEstimator, Optimizer
]

instance CyberPhysicalAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model capturing cyber-physical interactions"
    DTDFVocab:inputTo CalibrationAlgorithm, FaultDetector, StateEstimator, Optimizer
]

// C11: Enablers
instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that updates model parameters using sensor data"
    DTDFVocab:enables MonitoringService
]

instance FaultDetector : DTDFVocab:Enabler [
    base:desc "Algorithm detecting faults in system behavior using sensor data and model outputs"
    DTDFVocab:enables MonitoringService, ControlService
]

instance StateEstimator : DTDFVocab:Enabler [
    base:desc "Algorithm estimating system state from sensor data and models"
    DTDFVocab:enables MonitoringService, PredictiveService
]

instance Optimizer : DTDFVocab:Enabler [
    base:desc "Algorithm optimizing system efficiency by analyzing causes and effects"
    DTDFVocab:enables OptimizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Assesses safety and operational efficiency using real-time sensor data"
    DTDFVocab:provides SafetyInsight, OperationalEfficiencyInsight
]

instance PredictiveService : DTDFVocab:Service [
    base:desc "Simulates and forecasts Physical Twin behavior under current conditions"
    DTDFVocab:provides PredictiveInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Enhances system efficiency by discovering causes and effects"
    DTDFVocab:provides OptimizationInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Enacts physical adjustments upon detecting system violations"
    DTDFVocab:provides CorrectiveAction
]

// C17: Insights and Actions
instance SafetyInsight : DTDFVocab:Insight [
    base:desc "Real-time assessment of system safety based on sensor data and model outputs"
]

instance OperationalEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Real-time evaluation of operational efficiency using processed sensor data"
]

instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Forecasted system behavior under current conditions from predictive simulations"
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Insights on system efficiency improvements from optimization analysis"
]

instance CorrectiveAction : DTDFVocab:Action [
    base:desc "Initiated response to system violations for physical adjustments"
    DTDFVocab:IsAutomatic true
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Calibration algorithms continuously update model parameters to match the Physical Twin's current state, ensuring model fidelity. Monitors verify system performance against safety and optimality criteria, detecting violations which initiate corrective actions through human or algorithmic intervention."
]