// C3: Physical sensing components
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor inside the incubator chamber, providing scalar temperature measurements sampled continuously."
    DTDFVocab:producedData InternalTempDataTxA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Second internal temperature sensor inside the incubator chamber, providing scalar temperature measurements sampled continuously."
    DTDFVocab:producedData InternalTempDataTxB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor mounted on the incubator exterior, providing scalar temperature measurements sampled continuously."
    DTDFVocab:producedData ExternalTempDataTx
]

// C4: Physical-to-virtual interaction – Data transmission
instance InternalTempDataTxA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempDataTxB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// C10: Data objects
instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from internal sensor A."
    DTDFVocab:fromData InternalTempDataTxA
    DTDFVocab:inputTo MonitoringEnabler, SafetyEnabler, PredictionEnabler, OptimisationEnabler
]

instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from internal sensor B."
    DTDFVocab:fromData InternalTempDataTxB
    DTDFVocab:inputTo MonitoringEnabler, SafetyEnabler, PredictionEnabler, OptimisationEnabler
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from the exterior sensor."
    DTDFVocab:fromData ExternalTempDataTx
    DTDFVocab:inputTo MonitoringEnabler, SafetyEnabler, PredictionEnabler, OptimisationEnabler
]

// C11: Enablers (including CalibrationEnabler)
instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that aggregates real‑time temperature data for continuous monitoring."
    DTDFVocab:enables ContinuousMonitoringService
]

instance PredictionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that uses calibrated simulation models to generate future temperature trajectories."
    DTDFVocab:enables PredictionService
]

instance OptimisationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that runs optimisation algorithms to compute heat‑bed and fan set‑points, updating model parameters in real time."
    DTDFVocab:enables OptimisationService
]

instance SafetyEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that monitors temperature limits and triggers safety actions when violations are detected."
    DTDFVocab:enables SafetyMonitoringService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that prepares simulation results for visualisation to engineers."
    DTDFVocab:enables VisualizationService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that calibrates simulation models using the latest sensor data."
]

// C10: Models
instance TwoParamIncubatorThermalModel : DTDFVocab:Model [
    base:desc "Calibrated thermal model of the incubator plant with two free parameters (heat‑bed power coefficient, fan flow coefficient)."
    DTDFVocab:inputTo PredictionEnabler, OptimisationEnabler, VisualizationEnabler, CalibrationEnabler
]

instance FourParamIncubatorThermalModel : DTDFVocab:Model [
    base:desc "Calibrated thermal model of the incubator plant with four free parameters (heat‑bed power coefficient, fan flow coefficient, environmental heat‑loss factor, sensor bias)."
    DTDFVocab:inputTo PredictionEnabler, OptimisationEnabler, VisualizationEnabler, CalibrationEnabler
]

// C6: Services
instance ContinuousMonitoringService : DTDFVocab:Service [
    base:desc "Provides continuous monitoring of inside and outside temperatures via the sensor streams."
    DTDFVocab:provides TemperatureTrendInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Predicts future temperature trajectories using two calibrated simulation models."
    DTDFVocab:provides FutureTemperaturePredictionInsight
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Optimises heat‑bed and fan set‑points through real‑time calibration algorithms."
    DTDFVocab:provides SetpointOptimisationAction
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Detects violations of temperature limits and initiates safety procedures."
    DTDFVocab:provides TemperatureLimitViolationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualises simulation results for engineers to assess system behaviour."
    DTDFVocab:provides SimulationResultVisualizationInsight
]

// C17: Insights
instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Insight into current temperature trends inside and outside the incubator."
]

instance FutureTemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Insight presenting predicted future temperature trajectory based on calibrated models."
]

instance TemperatureLimitViolationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating a breach of predefined temperature safety limits."
]

instance SimulationResultVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight delivering visualised simulation output for engineering analysis."
]

// C17: Actions
instance SetpointOptimisationAction : DTDFVocab:Action [
    base:desc "Automatically adjusts heat‑bed and fan set‑points to maintain target temperature."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands flow from the digital twin to the physical twin through the same RabbitMQ broker. The DT publishes AMQP messages that encode actuator commands (e.g., “HEATBED_ON”, “HEATBED_OFF”, “FAN_ON”, “FAN_OFF”) together with optional parameters such as heating duration (H) and waiting duration (C). The low‑level driver receives these messages, validates them against the built‑in safety protocol, and forwards the appropriate GPIO signals to the heatbed and fan. After execution the driver acknowledges the command with a response message, allowing the DT to confirm actuation. Conflict resolution is handled by the controller logic that prioritises the latest command."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The incubator Digital Twin follows a CPS‑based orchestration where the physical twin (insulated styrofoam box, heat‑bed, fan, and temperature sensors) is managed by a Raspberry Pi controller. Sensor data are streamed from the PT to a time‑series database; a dashboard consumes this data for real‑time visualization. Calibration algorithms run on the stored data to update the parameters of Model B (the four‑parameter thermal model). The calibrated model feeds a Kalman filter that estimates the unmeasured heat‑bed temperature and performs anomaly detection. Upon detection, a self‑adaptation loop schedules an experiment, re‑configures the controller, gathers new data, re‑calibrates Model B, updates the Kalman filter, runs what‑if co‑simulations to optimise controller settings, and finally re‑configures the controller. This integration of data acquisition, storage, model calibration, state estimation, anomaly detection, simulation and controller re‑configuration constitutes the overall orchestration of the Digital Twin system."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through calibration algorithms that adjust the parameters of the incubator thermal models (a two‑parameter and a four‑parameter model) using the collected temperature data, thereby reducing prediction error of thermal inertia. Validation is performed by comparing model outputs against measured temperature trajectories; deviations trigger violation detection in the monitoring subsystem. Uncertainty arises from sensor noise and simplifications in the thermal models; the DT quantifies it implicitly by tracking residual errors during calibration. Quality assurance is achieved by the monitor that checks for safe and optimal operation and by human or higher‑level algorithmic intervention when violations are detected."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection is built around a RabbitMQ message broker using the AMQP 0‑9‑1 protocol over TCP/IP. All components (low‑level driver, controller, DT services) act as AMQP clients in a star topology with the broker at the centre. RabbitMQ provides message durability, acknowledgements and automatic reconnection, satisfying reliability requirements. No explicit bandwidth or latency figures are given; the system assumes standard Ethernet/Wi‑Fi links sufficient for low‑frequency sensor streams (seconds‑scale). Security is limited to the broker’s native authentication (username/password); no additional encryption is mentioned."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The deployment can be on‑premise or in the cloud; the RabbitMQ server may run on a local machine, a dedicated edge server, or a cloud VM. Compute for the digital‑twin models runs on the same host as the DT services or on separate hardware, though exact CPU or storage needs are not specified. Scalability is achieved by adding RabbitMQ nodes or scaling consumer instances. Availability is addressed by RabbitMQ’s mature clustering and fail‑over capabilities, although the case study does not describe explicit redundancy configurations."
]