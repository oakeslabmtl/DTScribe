import DTDFVocab

// C3: Physical sensing components
instance ChamberTempSensorA : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer located inside the incubation chamber (range –55 °C to +125 °C, 0.5 °C accuracy)",
    DTDFVocab:producedData ChamberTempDataTransmittedA
]

instance ChamberTempSensorB : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer located inside the incubation chamber (second sensor, same specs)",
    DTDFVocab:producedData ChamberTempDataTransmittedB
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer measuring the room temperature (range –55 °C to +125 °C, 0.5 °C accuracy)",
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance ChamberTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChamberTempSensorA
]

instance ChamberTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChamberTempSensorB
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// C10: Data instances
instance ChamberTemperatureDataA : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from ChamberTempSensorA",
    DTDFVocab:fromData ChamberTempDataTransmittedA,
    DTDFVocab:inputTo RabbitMQBroker
]

instance ChamberTemperatureDataB : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from ChamberTempSensorB",
    DTDFVocab:fromData ChamberTempDataTransmittedB,
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Room temperature reading (°C) from AmbientTempSensor",
    DTDFVocab:fromData AmbientTempDataTransmitted,
    DTDFVocab:inputTo RabbitMQBroker
]

instance CalibrationDataset : DTDFVocab:Data [
    base:desc "Aggregated temperature trajectory from chamber sensors used for non‑linear least‑squares calibration",
    DTDFVocab:fromData ChamberTempDataTransmittedA, ChamberTempDataTransmittedB,
    DTDFVocab:inputTo CalibrationEngine
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker on the Raspberry Pi handling messages from the DS18S20 driver",
    DTDFVocab:enables RealTimeMonitoringService, PredictionService, AlertingService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "SciPy non‑linear least‑squares optimiser that calibrates thermal model parameters (C_air, G_box, C_heater, G_heater)",
    DTDFVocab:enables CalibrationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Python simulation engine executing Model A and Model B for temperature dynamics",
    DTDFVocab:enables TemperatureSimulationService, PredictionService
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single‑capacitance air model with heat loss to the environment (Model A)",
    DTDFVocab:inputTo SimulationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Dual‑capacitance model including heat‑bed thermal inertia (Model B)",
    DTDFVocab:inputTo SimulationEngine
]

// C6: Services
instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Simulation of temperature dynamics using Model A and Model B",
    DTDFVocab:provides PredictedTemperatureInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of chamber temperature",
    DTDFVocab:provides CurrentChamberTemperatureInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Parameter calibration via non‑linear least‑squares optimisation (SciPy)",
    DTDFVocab:provides CalibratedModelParametersInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Prediction of future temperature states based on calibrated models",
    DTDFVocab:provides PredictedTemperatureInsight
]

instance AlertingService : DTDFVocab:Service [
    base:desc "Alerting when temperature exceeds configured lower or upper limits",
    DTDFVocab:provides TemperatureAlertAction
]

// C17: Insights
instance CurrentChamberTemperatureInsight : DTDFVocab:Insight [
    base:desc "Current chamber temperature derived from the sensor stream"
]

instance CalibratedModelParametersInsight : DTDFVocab:Insight [
    base:desc "Updated model parameters (C_air, G_box, C_heater, G_heater) after calibration"
]

instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory for the upcoming control horizon"
]

// C17: Actions
instance TemperatureAlertAction : DTDFVocab:Action [
    base:desc "Trigger alarm and suggest heat‑bed activation when temperature exceeds configured limits",
    DTDFVocab:IsAutomatic true
]

instance HeatBedActivationAction : DTDFVocab:Action [
    base:desc "Command to turn on the heat‑bed to raise temperature",
    DTDFVocab:IsAutomatic true
]

instance FanActivationAction : DTDFVocab:Action [
    base:desc "Command to turn on the fan for air circulation",
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed surface heater driven via MOSFET (max 4 A) on the custom PCB"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V fan for air circulation driven via MOSFET on the PCB"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (e.g., heat‑bed ON/OFF, fan ON/OFF, heating duration, waiting duration) are sent from the digital twin to the controller via RabbitMQ; the controller interprets these commands and actuates the heat‑bed and fan through the PCB MOSFET drivers."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A three‑layer architecture: (1) Physical layer – incubator hardware; (2) Communication layer – RabbitMQ server on the Pi mediating messages; (3) Software layer – low‑level driver abstracts sensor/actuator I/O, controller implements a bang‑bang‑like logic, and digital‑twin modules subscribe to sensor data and publish control commands, forming a closed feedback loop."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Assumptions underlying the models (uniform temperature, negligible wall heat storage, constant air specific heat, dominant heat‑bed power) are explicitly listed; uniformity is experimentally verified by comparing three sensor locations; model fidelity is assessed by calibrating parameters and minimizing residual error; validation experiments test temperature discrepancy under different fan voltages."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Message exchange over RabbitMQ (AMQP protocol) running on the Raspberry Pi, linking the low‑level driver, controller, and digital‑twin components; communication uses TCP/IP within the local network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "RabbitMQ broker and all DT software components (driver, controller, calibration and simulation modules) are hosted on the same Raspberry Pi 4 that also runs the physical controller."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the device in a safe state; the controller monitors temperature limits (LL, UL) and can stop actuation if limits are violated, providing basic safety safeguards."
]