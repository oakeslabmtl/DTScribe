// SensingComponents
instance WheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel speed sensor that continuously feeds data into the Digital Twin."
    DTDFVocab:producedData WheelSpeedDataTx
]

instance AccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Accelerometer sensor that captures vehicle acceleration data for real‑time monitoring."
    DTDFVocab:producedData AccelerationDataTx
]

// DataTransmitted
instance WheelSpeedDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedSensor
]

instance AccelerationDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AccelerationSensor
]

// Data
instance WheelSpeedMeasurement : DTDFVocab:Data [
    base:desc "Time‑series wheel speed measurements transmitted from the WheelSpeedSensor."
    DTDFVocab:fromData WheelSpeedDataTx
    DTDFVocab:inputTo MonitoringEnabler, CalibrationAlgorithm
]

instance AccelerationMeasurement : DTDFVocab:Data [
    base:desc "Time‑series acceleration measurements transmitted from the AccelerationSensor."
    DTDFVocab:fromData AccelerationDataTx
    DTDFVocab:inputTo MonitoringEnabler, CalibrationAlgorithm
]

// Models
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "Hyboric geometric model represented by a CAD mesh encoding wheel dimensions, chassis geometry, and styling attributes."
    DTDFVocab:inputTo CalibrationAlgorithm
]

instance BehavioralDynamicModel : DTDFVocab:Model [
    base:desc "Behavioral (dynamic) model expressed through ordinary differential equations relating physical forces to vehicle motion."
    DTDFVocab:inputTo CalibrationAlgorithm
]

// Enablers
instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that aggregates measurement data for monitoring and analysis."
    DTDFVocab:enables MonitoringService, FaultDetectionService, SupervisoryControlService, StateEstimationService, OptimizationService, PredictiveSimulationService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that ingests measurement data to update the hybrid geometric and behavioral models."
    DTDFVocab:enables ModelUpdateService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Service providing continuous monitoring of the Physical Twin using real‑time data."
    DTDFVocab:provides MonitoringInsight, CorrectiveMaintenanceAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service detecting faults by analyzing measurement data against predefined thresholds."
    DTDFVocab:provides FaultDetectionInsight, ControlOverrideAction
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Service performing supervisory control to maintain safe operation of the Physical Twin."
    DTDFVocab:provides SupervisoryControlInsight, CorrectiveMaintenanceAction
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Service estimating the state of the Physical Twin based on sensor measurements."
    DTDFVocab:provides StateEstimationInsight, ParameterUpdateAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing the operation of the Physical Twin for efficiency and performance."
    DTDFVocab:provides OptimizationInsight, ProactiveMaintenanceRecommendationAction
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Service conducting predictive simulations to forecast behavior under various operating conditions."
    DTDFVocab:provides PredictiveSimulationInsight, ProactiveMaintenanceRecommendationAction
]

instance ModelUpdateService : DTDFVocab:Service [
    base:desc "Service updating the Digital Twin models with calibrated parameters."
    DTDFVocab:provides ModelAccuracyInsight, ParameterUpdateAction
]

// Insights
instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight indicating compliance of monitored metrics with safety and performance thresholds."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the detection of a fault or anomaly in the Physical Twin."
]

instance SupervisoryControlInsight : DTDFVocab:Insight [
    base:desc "Insight providing status information about supervisory control actions."
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Insight depicting the estimated state of the vehicle for decision‑making."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight describing optimized operational parameters for the Vehicle."
]

instance PredictiveSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight forecasting future vehicle behavior under predicted scenarios."
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Insight assessing the accuracy of the hybrid geometric and behavioral models."
]

// Actions
instance CorrectiveMaintenanceAction : DTDFVocab:Action [
    base:desc "Action to trigger corrective maintenance when a fault or threshold violation is detected."
    DTDFVocab:IsAutomatic true
]

instance ControlOverrideAction : DTDFVocab:Action [
    base:desc "Action allowing a human operator to override automated control decisions."
    DTDFVocab:IsAutomatic false
]

instance ParameterUpdateAction : DTDFVocab:Action [
    base:desc "Automatic action to update model parameters based on calibration results."
    DTDFVocab:IsAutomatic true
]

instance ProactiveMaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Automatic recommendation for proactive maintenance derived from predictive simulations."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is structured as a framework that integrates data acquisition from the Physical Twin via sensors, computational models representing both cyber‑physical and environmental aspects, and adaptive algorithms (such as calibration, fault detection, supervisory control, and optimisation). Calibration algorithms use incoming sensor data and model predictions to update model parameters; the updated model outputs are then consumed by monitors that assess safety and performance. When violations are detected, the framework allows human operators or autonomous decision‑making algorithms to initiate changes to the physical twin. This orchestration exemplifies the virtual‑physical mapping and continuous refinement cycle described in the document, though explicit architecture patterns or resource‑management details are not specified."
]