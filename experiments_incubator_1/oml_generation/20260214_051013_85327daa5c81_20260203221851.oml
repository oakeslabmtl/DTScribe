// Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed actuator driven via Raspberry Pi GPIO through MOSFETs and optocouplers"
]
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Air fan actuator driven via Raspberry Pi GPIO through MOSFETs and optocouplers"
]

// Physical Sensing Components
instance IncubatorTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside the incubator"
    DTDFVocab:producedData IncubatorTempData1
]
instance IncubatorTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside the incubator"
    DTDFVocab:producedData IncubatorTempData2
]
instance RoomTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor measuring room temperature"
    DTDFVocab:producedData RoomTempData
]

// Physical-to-Virtual Interaction (Data Transmitted)
instance IncubatorTempData1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorTempSensor1
]
instance IncubatorTempData2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorTempSensor2
]
instance RoomTempData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTempSensor
]

// Data Instances
instance IncubatorTempRecord1 : DTDFVocab:Data [
    base:desc "Time‑series of temperature data from IncubatorTempSensor1"
    DTDFVocab:fromData IncubatorTempData1
    DTDFVocab:inputTo RaspberryPiRuntime
    DTDFVocab:inputTo SciPyLibrary
]
instance IncubatorTempRecord2 : DTDFVocab:Data [
    base:desc "Time‑series of temperature data from IncubatorTempSensor2"
    DTDFVocab:fromData IncubatorTempData2
    DTDFVocab:inputTo RaspberryPiRuntime
    DTDFVocab:inputTo SciPyLibrary
]
instance RoomTempRecord : DTDFVocab:Data [
    base:desc "Time‑series of temperature data from RoomTempSensor"
    DTDFVocab:fromData RoomTempData
    DTDFVocab:inputTo RaspberryPiRuntime
    DTDFVocab:inputTo SciPyLibrary
]

// Enablers
instance RaspberryPiRuntime : DTDFVocab:Enabler [
    base:desc "Python runtime on Raspberry Pi 4 Model B executing simulation, control, and monitoring code"
    DTDFVocab:enables ThermodynamicSimulationService
    DTDFVocab:enables RealTimeMonitoringService
    DTDFVocab:enables ControlLogicService
]
instance SciPyLibrary : DTDFVocab:Enabler [
    base:desc "SciPy library used for non‑linear least‑squares calibration"
    DTDFVocab:enables ParameterCalibrationService
]
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker running on the Raspberry Pi"
    DTDFVocab:enables DataIngestionService
]

// Services
instance ThermodynamicSimulationService : DTDFVocab:Service [
    base:desc "Simulates temperature dynamics using ModelA and ModelB"
    DTDFVocab:provides SimulationTrajectoryInsight
]
instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates free parameters using non‑linear least‑squares via SciPy"
    DTDFVocab:provides CalibrationResultInsight
]
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Monitors real‑time PT state and safety conditions"
    DTDFVocab:provides PTStateInsight
    DTDFVocab:provides SafetyFlagInsight
]
instance ControlLogicService : DTDFVocab:Service [
    base:desc "Fault‑ and delay‑aware bang‑bang controller for heatbed and fan"
    DTDFVocab:provides FanDutyCycleAction
    DTDFVocab:provides HeatbedDutyCycleAction
    DTDFVocab:provides RecommendFanDutyCycleAction
    DTDFVocab:provides RecommendHeatbedDutyCycleAction
]
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Consumes AMQP messages from RabbitMQ and forwards sensor data to processing pipeline"
    DTDFVocab:provides BrokerHealthInsight
]

// Insights
instance SimulationTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Real‑time temperature predictions from the dynamic model"
]
instance CalibrationResultInsight : DTDFVocab:Insight [
    base:desc "Updated parameter values after least‑squares calibration"
]
instance PTStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time state of the incubator PT system"
]
instance SafetyFlagInsight : DTDFVocab:Insight [
    base:desc "Flag indicating potential overheating or motor fault"
]
instance BrokerHealthInsight : DTDFVocab:Insight [
    base:desc "Health status of the RabbitMQ broker based on message backlog"
]

// Actions
instance FanDutyCycleAction : DTDFVocab:Action [
    base:desc "Automatically sets fan duty cycle based on bang‑bang control logic"
    DTDFVocab:IsAutomatic true
]
instance HeatbedDutyCycleAction : DTDFVocab:Action [
    base:desc "Automatically sets heatbed duty cycle based on bang‑bang control logic"
    DTDFVocab:IsAutomatic true
]
instance RecommendFanDutyCycleAction : DTDFVocab:Action [
    base:desc "Recommends fan duty cycle for operator intervention"
    DTDFVocab:IsAutomatic false
]
instance RecommendHeatbedDutyCycleAction : DTDFVocab:Action [
    base:desc "Recommends heatbed duty cycle for operator intervention"
    DTDFVocab:IsAutomatic false
]

// Components
instance RaspberryPi4ModelB : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B controller"
]
instance StyrofoamContainer : DTDFVocab:Component [
    base:desc "Styrofoam insulated container of the thermal incubator"
]

// Environment
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator, FanActuator, IncubatorTempSensor1, IncubatorTempSensor2, RoomTempSensor, RaspberryPi4ModelB, StyrofoamContainer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (e.g., heatbed on/off, fan on/off) to RabbitMQ; the Raspberry Pi controller consumes them and toggles the actuators via GPIO."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized DT stack on the Raspberry Pi consisting of the Communication Server (RabbitMQ), Low‑level Driver, Control Logic, and DT models; message exchange via AMQP orchestrates interaction between DT and PT."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (formulating dynamic models and assumptions), Calibration (parameter estimation under operation), and Operation (continuous monitoring and possible re‑calibration)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Models rely on assumptions of uniform temperature, negligible wall heat capacity, constant air specific heat, and neglect of fan heat; validity confirmed by uniform temperature experiments; calibration minimises residual error using SciPy optimisation; uncertainty not explicitly quantified."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Connection between PT and DT is through the local RabbitMQ broker hosted on the Raspberry Pi; the Pi publishes sensor telemetry and consumes actuator command queues; underlying protocol is the standard RabbitMQ messaging (AMQP) over the Pi’s local network; message exchange occurs asynchronously over queues."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "DT logic (communication server, driver, controller) hosted on the Raspberry Pi 4 Model B, with all components running locally on the same device."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safe protocol embedded in low‑level driver to prevent unsafe states; isolation via MOSFETs and optocouplers; RabbitMQ provides reliable messaging; no explicit security or safety certifications mentioned."
]