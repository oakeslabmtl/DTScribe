    DTDFVocab:enables GeometricModelingService
]

instance PhysicsSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Physics-based simulation tools (ANSYS, COMSOL, MATLAB/Simulink) replicating Physical Twin dynamics under real-world conditions"
    DTDFVocab:enables PhysicsSimulationService
]

instance EnvironmentalSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Environmental modeling tools integrating cyber and physical aspects including thermal loads and mechanical interactions"
    DTDFVocab:enables EnvironmentalSimulationService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Data preprocessing pipeline including filtering, noise reduction, and anomaly detection for raw sensor data"
    DTDFVocab:enables DataQualityAssuranceService
]

instance ModelCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithms (Bayesian estimation, machine learning) updating model parameters using real-time sensor data"
    DTDFVocab:enables ModelCalibrationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "State estimators and supervisory controllers analyzing Physical Twin data for anomalies and deviations"
    DTDFVocab:enables FaultDetectionService
]

instance OptimizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Optimization algorithms (genetic algorithms, reinforcement learning) optimizing Physical Twin performance parameters"
    DTDFVocab:enables PerformanceOptimizationService
]

instance TimeSeriesDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Time-series databases (InfluxDB, TimescaleDB) storing sensor data for historical analysis and model validation"
    DTDFVocab:enables DataStorageService
]

instance ModelRepositoryEnabler : DTDFVocab:Enabler [
    base:desc "Centralized storage for CAD models, dynamic equations, and calibration parameters used by Digital Twin components"
    DTDFVocab:enables ModelManagementService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Visualization tools (Tableau, Power BI) presenting Digital Twin insights to engineers through interactive dashboards"
