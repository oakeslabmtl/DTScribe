// C3: Physical sensing components
instance InternalTemperatureSensorA : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor mounted inside the incubator at location A, samples at 1 Hz, accuracy ±0.5 °C, resolution 0.0625 °C"
    DTDFVocab:producedData InternalTempDataTransmittedA
]

instance InternalTemperatureSensorB : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor mounted inside the incubator at location B, samples at 1 Hz, accuracy ±0.5 °C, resolution 0.0625 °C"
    DTDFVocab:producedData InternalTempDataTransmittedB
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor mounted on the exterior of the insulated box, samples at 1 Hz, accuracy ±0.5 °C, resolution 0.0625 °C"
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmitted)
instance InternalTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensorA
]

instance InternalTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensorB
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

// C10: Data
instance InternalTemperatureDataA : DTDFVocab:Data [
    base:desc "Raw temperature reading from internal sensor A (°C) timestamped by Raspberry Pi"
    DTDFVocab:fromData InternalTempDataTransmittedA
    DTDFVocab:inputTo RabbitMQEnabler, CalibrationEnabler, SimulationEnabler, MonitoringEnabler
]

instance InternalTemperatureDataB : DTDFVocab:Data [
    base:desc "Raw temperature reading from internal sensor B (°C) timestamped by Raspberry Pi"
    DTDFVocab:fromData InternalTempDataTransmittedB
    DTDFVocab:inputTo RabbitMQEnabler, CalibrationEnabler, SimulationEnabler, MonitoringEnabler
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Raw temperature reading from external sensor (°C) timestamped by Raspberry Pi"
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo RabbitMQEnabler, CalibrationEnabler, SimulationEnabler, MonitoringEnabler
]

// C2: Acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heating element (heat‑bed) that provides thermal energy to raise incubator temperature, controlled by the Raspberry Pi"
]

// C17: Components (non‑sensing)
instance CoolingFanComponent : DTDFVocab:Component [
    base:desc "Fan that distributes heat generated by the heat‑bed throughout the incubator interior"
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi that runs the plant‑level controller, reads sensor data, timestamps, and forwards via RabbitMQ"
]

// C17: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, CoolingFanComponent, RaspberryPiController, InternalTemperatureSensorA, InternalTemperatureSensorB, ExternalTemperatureSensor
]

// C11: Enablers
instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker used to forward timestamped sensor data from Raspberry Pi to the Digital Twin"
    DTDFVocab:enables DataAcquisitionService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that estimates best‑fit parameters for thermal models using incoming temperature data"
    DTDFVocab:enables CalibrationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs the calibrated thermal models to predict incubator temperature"
    DTDFVocab:enables SimulationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring algorithm that assesses safety and optimality of the incubator temperature and triggers actions"
    DTDFVocab:enables MonitoringService
]

// C10: Models
instance SimpleThermalModel : DTDFVocab:Model [
    base:desc "Simplified temperature model with two free parameters representing overall heat transfer"
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler, MonitoringEnabler
]

instance DetailedThermalModel : DTDFVocab:Model [
    base:desc "Detailed temperature model with four free parameters capturing thermal inertia of the heat‑bed"
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler, MonitoringEnabler
]

// C6: Services
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Acquires temperature data from the physical twin via RabbitMQ"
    DTDFVocab:provides DataAcquisitionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Updates the cyber‑physical system models with best‑estimate parameters through calibration"
    DTDFVocab:provides ModelParameterInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Predicts future incubator temperature under current operating conditions using calibrated models"
    DTDFVocab:provides TemperaturePredictionInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Evaluates temperature safety and optimality, and can trigger corrective heating actions"
    DTDFVocab:provides TemperatureSafetyInsight, TemperatureOptimizationInsight, HeaterAdjustmentAction
]

// C17: Insights
instance DataAcquisitionInsight : DTDFVocab:Insight [
    base:desc "Raw temperature measurements successfully collected from all three sensors"
]

instance ModelParameterInsight : DTDFVocab:Insight [
    base:desc "Best‑fit parameters for the simple and detailed thermal models have been estimated"
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Forecast of incubator internal temperature for the next time horizon based on simulation"
]

instance TemperatureSafetyInsight : DTDFVocab:Insight [
    base:desc "Detected temperature deviation outside safe bounds, indicating potential risk"
]

instance TemperatureOptimizationInsight : DTDFVocab:Insight [
    base:desc "Identified opportunity to reduce energy consumption while maintaining target temperature"
]

// C17: Action
instance HeaterAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjusts heat‑bed power level to correct temperature deviation"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Raspberry Pi generates control commands for the heat‑bed and the fan to regulate temperature; these commands constitute the flow from the digital twin to the physical twin. The document does not provide details on command format, validation, or acknowledgment mechanisms."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the predictive performance of the two temperature simulation models. Experimental results showed that the four‑parameter model more accurately reproduced the thermal inertia of the heat‑bed, indicating higher fidelity. Calibration algorithms are used to update model parameters based on sensor data, providing a validation loop. The documents do not detail quantitative uncertainty quantification, error detection mechanisms, or formal QA processes."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The computational part of the digital twin is hosted on the Raspberry Pi that also acts as the controller for the incubator; the document does not provide further details on cloud/edge deployment, resource specifications, scalability, or redundancy."
]