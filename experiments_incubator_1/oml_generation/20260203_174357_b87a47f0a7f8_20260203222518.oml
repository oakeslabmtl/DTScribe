// Sensing Components
instance InternalBoxTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (47°C to +125°C) with 0.5°C accuracy, positioned on the inside of the incubator box, connected to the Raspberry Pi 4 via GPIO 1‑Wire bus, sensor serial 64‑bit"
    DTDFVocab:producedData BoxTempSensor1Package
]

instance InternalBoxTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer positioned on the opposite side of the incubator box, providing duplicate internal temperature measurements"
    DTDFVocab:producedData BoxTempSensor2Package
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer located outside the incubator box (ambient environment) to provide reference temperature"
    DTDFVocab:producedData AmbientSensorPackage
]

// Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET‑controlled heatbed (surface heater) powered by 12 V DC, driven from Raspberry Pi 4 GPIO via optocoupler for electrical isolation"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V fan MOSFET‑driven airflow actuator, controlled by Raspberry Pi 4 GPIO via optocoupler to prevent back‑EMF damage"
]

// Data Transmitted (from Sensors and Models)
instance BoxTempSensor1Package : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalBoxTempSensor1
]

instance BoxTempSensor2Package : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalBoxTempSensor2
]

instance AmbientSensorPackage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

instance ModelAOutputPackage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ModelAThermal
]

instance ModelBOutputPackage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ModelBThermal
]

// Data (time‑series)
instance BoxTempDataSeries1 : DTDFVocab:Data [
    base:desc "Time‑series of internal box temperature measurements from DS18S20 sensor 1"
    DTDFVocab:fromData BoxTempSensor1Package
    DTDFVocab:inputTo RabbitMQBroker
]

instance BoxTempDataSeries2 : DTDFVocab:Data [
    base:desc "Time‑series of internal box temperature measurements from DS18S20 sensor 2"
    DTDFVocab:fromData BoxTempSensor2Package
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTempDataSeries : DTDFVocab:Data [
    base:desc "Time‑series of ambient temperature measurements from DS18S20 sensor"
    DTDFVocab:fromData AmbientSensorPackage
    DTDFVocab:inputTo RabbitMQBroker
]

instance ModelAOutputSeries : DTDFVocab:Data [
    base:desc "Predicted box temperature time‑series generated by Model A"
    DTDFVocab:fromData ModelAOutputPackage
    DTDFVocab:inputTo PythonSimulationEnabler
]

instance ModelBOutputSeries : DTDFVocab:Data [
    base:desc "Predicted box temperature time‑series generated by Model B"
    DTDFVocab:fromData ModelBOutputPackage
    DTDFVocab:inputTo PythonSimulationEnabler
]

// Models
instance ModelAThermal : DTDFVocab:Model [
    base:desc "Dynamic thermal model A with parameters C_air (air capacitance) and G_box (thermal conductance to ambient) representing the box’s thermal dynamics"
    DTDFVocab:inputTo PythonSimulationEnabler
]

instance ModelBThermal : DTDFVocab:Model [
    base:desc "Dynamic thermal model B extending Model A with parameters C_heater (heater capacitance) and G_heater (heater conductance) to capture heater effects"
    DTDFVocab:inputTo PythonSimulationEnabler
]

// Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP message broker running on the Raspberry Pi 4, serves as the transport layer for sensor data and actuator state messages"
    DTDFVocab:enables SensorDataSubscriptionService
]

instance PythonSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime with scipy.integrate for numerically integrating the thermal models over time"
    DTDFVocab:enables SimulationService
]

instance PythonOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Python tool using scipy.optimize least‑squares for calibration of model parameters (C_air, G_box, C_heater, G_heater)"
    DTDFVocab:enables CalibrationService
]

// Services
instance SensorDataSubscriptionService : DTDFVocab:Service [
    base:desc "DT service that subscribes to sensor data messages from RabbitMQ, performs real‑time monitoring and safety checks"
    DTDFVocab:provides RealTimeTemperatureMonitoringInsight
    DTDFVocab:provides SafetyViolationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "DT service that integrates the thermal models and generates predicted temperature trajectories"
    DTDFVocab:provides TemperaturePredictionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "DT service that calibrates Model A and Model B parameters by fitting to measured data using least‑squares optimization"
    DTDFVocab:provides TemperatureCalibrationInsight
]

instance BangBangControllerService : DTDFVocab:Service [
    base:desc "Bang‑bang controller that issues ON/OFF commands to the heatbed and fan MOSFETs based on setpoint and safety limits"
    DTDFVocab:provides BangBangActuationAction
    DTDFVocab:provides SafetyViolationInsight
]

// Insights
instance RealTimeTemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring of the incubator temperature trajectories as they are received via RabbitMQ"
]

instance TemperatureCalibrationInsight : DTDFVocab:Insight [
    base:desc "Calibration parameters (C_air, G_box, C_heater, G_heater) derived from least‑squares optimisation"
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature evolution under different control sequences generated by the thermal models"
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature violations of safety limits (e.g., exceeding ±5 °C of setpoint) allowing for prompt operator intervention"
]

// Actions
instance BangBangActuationAction : DTDFVocab:Action [
    base:desc "Automatic action that switches the heatbed and fan MOSFETs on or off according to bang‑bang control logic"
    DTDFVocab:IsAutomatic true
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InternalBoxTempSensor1, InternalBoxTempSensor2, AmbientTempSensor, HeatbedActuator, FanActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Commands generated by the DT (controller logic or external supervisory commands) are sent via RabbitMQ to the controller on the Pi, which translates them into GPIO pulses to the MOSFETs, toggling the heat‑bed and fan. The DT also reports actuator states back through the same channel."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sensor readings are acquired and published periodically by the low‑level driver (exact sampling period not specified); calibration and offline experiments are conducted at a lower frequency; simulation and monitoring run continuously while the PT operates."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation is a centralized architecture: the low‑level driver, controller, and simulation model all reside on the Raspberry Pi; they communicate via RabbitMQ to each other and to any external tools, forming a closed loop between PT and DT."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin is developed through design (creation of CAE models and initial code), manufacture (assembly of hardware), and operation phases. Calibration experiments on the operated device refine the model parameters, indicating the twin is primarily used during the operated life‑cycle stage, with continuous monitoring and potential updates."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is constrained by Assumptions 1–4 (uniform temperature, no wall heat accumulation, constant specific heat, heat‑bed energy transfer). Validation is performed by comparing simulation outputs to experimental temperature traces; parameter uncertainty is reduced through optimisation. The authors note that discretization and sensor noise may introduce errors."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual communication uses RabbitMQ over the local network. Sensors connect via the 1‑Wire bus to the Pi’s GPIO; actuator control uses GPIO outputs wired through optocouplers to MOSFETs. All interactions exploit standard TCP/IP sockets under the AMQP protocol."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT services run directly on the embedded Raspberry Pi host; RabbitMQ is also locally instantiated on the Pi. This edge deployment enables low‑latency communication between PT and DT. The repository indicates the possibility of extending to cloud hosts, but the presented implementation is edge‑based."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to prevent unsafe states, and optocouplers provide electrical isolation between the Pi and the high‑current MOSFETs driving the heat‑bed and fan. No explicit encryption or authentication mechanisms are described, and the system operates in a controlled laboratory environment."
]