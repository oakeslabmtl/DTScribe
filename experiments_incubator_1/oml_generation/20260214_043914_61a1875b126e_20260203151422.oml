// Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed actuator controlled via MOSFET driver on PCB"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan actuator controlled via MOSFET driver on PCB"
]

instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi 4 Model B controller managing data acquisition and control logic"
]

instance PowerSupply24V : DTDFVocab:ActingComponent [
    base:desc "12V/24V power supply supplying power to actuators"
]

// Physical sensing components
instance InsideTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire thermometer located inside incubator measuring interior temperature"
    DTDFVocab:producedData TempReadingsRabbitMQ
]

instance InsideTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire thermometer located inside incubator measuring interior temperature"
    DTDFVocab:producedData TempReadingsRabbitMQ
]

instance OutsideTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire thermometer measuring incident outside temperature"
    DTDFVocab:producedData TempReadingsRabbitMQ
]

// Physical-to-virtual interaction
instance TempReadingsRabbitMQ : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensor1, InsideTempSensor2, OutsideTempSensor
    base:desc "Temperature readings forwarded to local RabbitMQ server over TCP for DT ingestion"
]

// Virtual data
instance VirtualTempData : DTDFVocab:Data [
    base:desc "Virtual temperature data stream ingested by DT from RabbitMQ"
    DTDFVocab:fromData TempReadingsRabbitMQ
    DTDFVocab:inputTo RaspberryPiRuntimeEnabler, SimulationEnabler, CalibrationEnabler
]

// Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Dynamic thermal model A (ODE describing heat transfer between heatbed, air, and enclosure)"
    DTDFVocab:inputTo SimulationEnabler, CalibrationEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Dynamic thermal model B (alternative ODE configuration for validation)"
    DTDFVocab:inputTo SimulationEnabler, CalibrationEnabler
]

// Enablers
instance RaspberryPiRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Runtime environment on Raspberry Pi 4 executing control services"
    DTDFVocab:enables BangBangRegulationService, UniformityMonitoringService, DataLoggingService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "SciPy-based simulation engine performing model‑based temperature prediction"
    DTDFVocab:enables SimulationService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Nonlinear least‑squares optimizer enabling parameter calibration"
    DTDFVocab:enables CalibrationUpdateService
]

// Services
instance BangBangRegulationService : DTDFVocab:Service [
    base:desc "Real‑time temperature regulation via bang‑bang controller driving fan voltage"
    DTDFVocab:provides FanVoltageSetAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of interior temperature trajectories using models A and B"
    DTDFVocab:provides TemperatureResponseForecastInsight
]

instance CalibrationUpdateService : DTDFVocab:Service [
    base:desc "Calibration of model parameters using non‑linear least‑squares optimization"
    DTDFVocab:provides UpdateModelParametersAction
]

instance UniformityMonitoringService : DTDFVocab:Service [
    base:desc "Monitoring of temperature uniformity and generation of overheating or cooling lag alerts"
    DTDFVocab:provides OverheatingAlertInsight, CoolingLagAlertInsight
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logging of sensor data for analysis"
    DTDFVocab:provides LogSensorDataAction
]

// Insights and Actions
instance FanVoltageSetAction : DTDFVocab:Action [
    base:desc "Automatically set fan voltage to desired level for temperature regulation"
    DTDFVocab:IsAutomatic true
]

instance UpdateModelParametersAction : DTDFVocab:Action [
    base:desc "Update model parameters with calibration outputs"
    DTDFVocab:IsAutomatic true
]

instance OverheatingAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating detected overheating event"
]

instance CoolingLagAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating cooling lag relative to target"
]

instance TemperatureResponseForecastInsight : DTDFVocab:Insight [
    base:desc "Simulation forecast of temperature response to control actions"
]

instance LogSensorDataAction : DTDFVocab:Action [
    base:desc "Action to log sensor data for archival and analysis"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (e.g., heatbed on/off, fan speed) to the RabbitMQ exchange; the Raspberry Pi 4 subscribes to these messages and actuates the heatbed and fan via the MOSFET drivers."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A locally hosted DT consisting of the communication server (RabbitMQ), the low‑level driver, the temperature controller (bang‑bang), the calibration module, and the simulation engine; all components run on the same Raspberry Pi 4 and communicate via TCP messages."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (system architecture, hardware selection), Fabrication (PCB, HVAC components), Modeling (derivation of Model A and Model B), Calibration (parameter estimation, experimental validation), Deployment (installation of Raspberry Pi, RabbitMQ setup), Operation (continuous monitoring, runtime adjustments)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation performed by comparing simulated temperatures to experimental runs; uniformity tests across multiple sensor positions; calibration minimized residual error using SciPy optimizer; assumptions about heat transfer (no wall heat accumulation, constant specific heat) explicitly noted; uncertainty propagated through parameter estimation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Local network (Wi‑Fi) connecting Raspberry Pi to RabbitMQ over TCP; DTO messages use AMQP protocol; sensor data read over 1‑Wire bus; protection via optocouplers; power distribution via 12V/24V supply."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted on a single Raspberry Pi 4 Model B connected to a local Wi‑Fi router; the repository provides Docker‑style deployment scripts; all software runs in user space on the Pi with no external cloud hosting."
]