// C3: Physical sensing components
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer inside the incubator (sensor A) – range –55 °C to +125 °C, accuracy ±0.5 °C"
    DTDFVocab:producedData InternalTempDataTransmittedA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer inside the incubator (sensor B) – range –55 °C to +125 °C, accuracy ±0.5 °C"
    DTDFVocab:producedData InternalTempDataTransmittedB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring ambient room temperature – range –55 °C to +125 °C, accuracy ±0.5 °C"
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmission)
instance InternalTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// C10: Data
instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from internal sensor A, published via RabbitMQ"
    DTDFVocab:fromData InternalTempDataTransmittedA
    DTDFVocab:inputTo LowLevelDriver, ModelSimulationEngine, CalibrationEngine
]

instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from internal sensor B, published via RabbitMQ"
    DTDFVocab:fromData InternalTempDataTransmittedB
    DTDFVocab:inputTo LowLevelDriver, ModelSimulationEngine, CalibrationEngine
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Ambient temperature reading (°C) from external sensor, published via RabbitMQ"
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo LowLevelDriver, ModelSimulationEngine, CalibrationEngine
]

// C2: Acting components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET‑driven heatbed on/off actuator controlled by Raspberry Pi"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET‑driven fan speed (on/off) actuator controlled by Raspberry Pi"
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker deployed on the Raspberry Pi for sensor and actuator messaging"
]

instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Python low‑level driver that reads DS18S20 sensors and publishes readings to RabbitMQ"
    DTDFVocab:enables CalibrationService, MonitoringService, RecommendationService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Python SciPy based non‑linear least‑squares optimizer used to calibrate temperature models"
    DTDFVocab:enables CalibrationService
]

instance ModelSimulationEngine : DTDFVocab:Enabler [
    base:desc "Engine that runs calibrated physics‑based temperature models for simulation"
    DTDFVocab:enables TemperatureSimulationServiceA, TemperatureSimulationServiceB
]

instance BangBangController : DTDFVocab:Enabler [
    base:desc "Controller code implementing a bang‑bang (with hold) algorithm for heatbed and fan control"
    DTDFVocab:enables MonitoringService, AlertGenerationService, RecommendationService
]

instance VisualizationTool : DTDFVocab:Enabler [
    base:desc "Software component that visualizes temperature trajectories for operators"
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance TemperatureSimulationServiceA : DTDFVocab:Service [
    base:desc "Simulation service using calibrated Model A to predict internal temperature"
    DTDFVocab:provides TemperatureForecastInsightA
]

instance TemperatureSimulationServiceB : DTDFVocab:Service [
    base:desc "Simulation service using calibrated Model B to predict internal temperature"
    DTDFVocab:provides TemperatureForecastInsightB
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Non‑linear least‑squares calibration service (Python SciPy) estimating model parameters from temperature data"
    DTDFVocab:provides ModelParameterCalibrationInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitoring service that detects safety or performance violations based on temperature readings"
    DTDFVocab:provides TemperatureDeviationAlertInsight, TurnHeatbedOnAction, TurnHeatbedOffAction, SetFanSpeedAction
]

instance AlertGenerationService : DTDFVocab:Service [
    base:desc "Service that generates alerts when temperature deviates from desired bounds"
    DTDFVocab:provides TemperatureDeviationAlertInsight
]

instance RecommendationService : DTDFVocab:Service [
    base:desc "Service that provides recommendations (adjust heating duration or waiting period) to operators or autonomous controllers"
    DTDFVocab:provides HeatingDurationRecommendationInsight, WaitingPeriodRecommendationInsight, AdjustHeatbedDurationAction, AdjustWaitingPeriodAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualization service that displays temperature trajectories over time"
    DTDFVocab:provides TemperatureTrajectoryVisualizationInsight
]

// C17: Insights
instance TemperatureForecastInsightA : DTDFVocab:Insight [
    base:desc "Forecast of future internal temperature based on calibrated Model A"
]

instance TemperatureForecastInsightB : DTDFVocab:Insight [
    base:desc "Forecast of future internal temperature based on calibrated Model B"
]

instance ModelParameterCalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight that model parameters (C_air, G_box, C_heater, G_heater) have been calibrated from experimental data"
]

instance TemperatureDeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when temperature deviates from desired bounds"
]

instance HeatingDurationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation to adjust the heatbed ON duration to maintain target temperature"
]

instance WaitingPeriodRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation to modify the waiting period between heating cycles"
]

instance TemperatureTrajectoryVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of temperature trajectories for operator analysis"
]

// C17: Actions
instance AdjustHeatbedDurationAction : DTDFVocab:Action [
    base:desc "Adjust the heatbed ON‑time duration"
    DTDFVocab:IsAutomatic false
]

instance AdjustWaitingPeriodAction : DTDFVocab:Action [
    base:desc "Adjust the waiting period between heating cycles"
    DTDFVocab:IsAutomatic false
]

instance TurnHeatbedOnAction : DTDFVocab:Action [
    base:desc "Turn the heatbed on"
    DTDFVocab:IsAutomatic true
]

instance TurnHeatbedOffAction : DTDFVocab:Action [
    base:desc "Turn the heatbed off"
    DTDFVocab:IsAutomatic true
]

instance SetFanSpeedAction : DTDFVocab:Action [
    base:desc "Set fan speed (on/off) via MOSFET driver"
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance TemperatureModelA : DTDFVocab:Model [
    base:desc "Physics‑based temperature Model A derived from heat‑balance equations, with parameters C_air and G_box"
    DTDFVocab:inputTo ModelSimulationEngine, CalibrationEngine
]

instance TemperatureModelB : DTDFVocab:Model [
    base:desc "Physics‑based temperature Model B extending Model A, adding parameters C_heater and G_heater"
    DTDFVocab:inputTo ModelSimulationEngine, CalibrationEngine
]

// C5: Environment (physical twin composition)
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InsulatedBox, SurfaceHeatbed, CoolingFan, HeatbedActuator, FanActuator, RaspberryPiController, CustomPCB, PowerSupply
]

instance InsulatedBox : DTDFVocab:Component [
    base:desc "Insulated styrofoam box (~0.03 m³ air volume) forming the incubator enclosure"
]

instance SurfaceHeatbed : DTDFVocab:Component [
    base:desc "Surface heatbed (≈214 × 214 × 3 mm) that generates heat for the incubator"
]

instance CoolingFan : DTDFVocab:Component [
    base:desc "12 V/24 V fan that circulates air inside the incubator"
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B controller that runs drivers, enablers, and services"
]

instance CustomPCB : DTDFVocab:Component [
    base:desc "Custom PCB with MOSFET drivers and optocouplers for heatbed current (~4 A)"
]

instance PowerSupply : DTDFVocab:Component [
    base:desc "Power supply providing necessary voltages to the incubator system"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin publishes control commands (heatbed ON/OFF, fan ON/OFF or speed) to the RabbitMQ broker; the low‑level driver on the Raspberry Pi subscribes to these messages and forwards them to the MOSFET drivers to actuate the heatbed and fan."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture comprises the PT (box, heatbed, fan, sensors, PCB, Raspberry Pi), a cyber layer with a low‑level driver, a controller implementing the control logic, a RabbitMQ communication server linking PT and DT, and model/calibration modules that consume sensor data and produce predictions and alerts."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through four explicit assumptions (uniform temperature, negligible wall heat storage, constant air specific heat, negligible fan heat), experimental validation of temperature uniformity (maximum ±7 °C discrepancy), and calibration of model parameters via non‑linear least squares to minimise residual error between model predictions and measured data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical devices communicate with the DT via the RabbitMQ message broker that runs locally on the Raspberry Pi. Sensor data is collected over the 1‑Wire bus and sent to the broker by the low‑level driver; control commands are retrieved from the broker by the controller and dispatched to the MOSFET/optocoupler circuit through GPIO pins. The Raspberry Pi’s network interfaces (Wi‑Fi/Bluetooth) provide the underlying IP connectivity for RabbitMQ."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT software components (RabbitMQ broker, controller, driver, and model services) are deployed on the same Raspberry Pi 4 Model B that also hosts the PT hardware; source code and hardware designs are stored in a public GitHub repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the device in a safe state, and the DT includes monitoring services that detect safety violations (e.g., temperature out of bounds) before allowing actuator commands to be executed."
]