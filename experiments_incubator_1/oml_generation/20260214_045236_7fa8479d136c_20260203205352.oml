// C2: Acting Components
instance HeatBedHeaterActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed heater driven by Raspberry Pi GPIO outputs controlled by the temperature regulation loop."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal fan driven by Raspberry Pi GPIO outputs regulated by the controller’s temperature loop."
]

// C3: Physical sensing components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer mounted inside the styrofoam box measuring interior air temperature."
    DTDFVocab:producedData InternalTemperatureDataTransmitted
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer mounted inside the styrofoam box measuring interior air temperature."
    DTDFVocab:producedData InternalTemperatureDataTransmitted
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer mounted on the external side of the box to monitor ambient temperature."
    DTDFVocab:producedData AmbientTemperatureDataTransmitted
]

// C4: Physical‑to‑virtual interaction
instance InternalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1, InternalTemperatureSensor2
]

instance AmbientTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

// C10: Models/Data
instance ModelA : DTDFVocab:Model [
    base:desc "Thermal dynamics model of the insulated incubator box with two free parameters."
    DTDFVocab:inputTo ModelCalibrationEnabler
]

instance ModelB : DTDFVocab:Model [
    base:desc "Thermal dynamics model with four free parameters capturing heat‑bed inertia."
    DTDFVocab:inputTo ModelCalibrationEnabler
]

instance InternalTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series of interior temperature readings from two DS18S20 sensors."
    DTDFVocab:inputTo DataIngestionEnabler
    DTDFVocab:fromData InternalTemperatureDataTransmitted
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series of ambient temperature readings from one DS18S20 sensor."
    DTDFVocab:inputTo DataIngestionEnabler
    DTDFVocab:fromData AmbientTemperatureDataTransmitted
]

// C11: Enablers
instance DataIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Handles ingestion of temperature data published via RabbitMQ and stores in a time‑series database."
    DTDFVocab:enables RealTimeVisualizationService
]

instance ModelCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Runs non‑linear least‑squares fitting to calibrate ModelA and ModelB using recorded temperature data."
    DTDFVocab:enables OnDemandCalibrationService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Runs a Kalman filter to estimate unmeasured heat‑bed temperature and flag anomalies."
    DTDFVocab:enables AnomalyDetectionService
]

instance WhatIfSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Executes co‑simulation using live or historical data to evaluate controller parameter settings."
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationEnabler : DTDFVocab:Enabler [
    base:desc "Schedules adaptive experiments, recalibrates ModelB, reconfigures Kalman filter, and updates controller when plant behaviour changes."
    DTDFVocab:enables SelfAdaptationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Ingests controller and driver messages into a time‑series database and displays them on a dashboard."
    DTDFVocab:provides DashboardInsight
]

instance OnDemandCalibrationService : DTDFVocab:Service [
    base:desc "Automated execution of calibration routines for ModelA and ModelB."
    DTDFVocab:provides CalibrationResultInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Detects anomalies and estimates heat‑bed state via a Kalman filter."
    DTDFVocab:provides AnomalyInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Runs what‑if co‑simulation scenarios to evaluate controller parameter settings."
    DTDFVocab:provides OptimizationInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Triggers adaptive experiments, recalibrates ModelB, reconfigures Kalman filter, and updates controller to maintain optimal operation."
    DTDFVocab:provides RecalibrateModelAction
]

// C17: Insights/Actions
instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Visual representation of real‑time temperature data and system status."
]

instance CalibrationResultInsight : DTDFVocab:Insight [
    base:desc "Outcome of the on‑demand calibration of ModelA and ModelB."
]

instance AnomalyInsight : DTDFVocab:Insight [
    base:desc "Flagging of anomalous plant behavior and estimation of heat‑bed temperature."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Results of what‑if simulation indicating optimal controller parameters."
]

instance RecalibrateModelAction : DTDFVocab:Action [
    base:desc "Automatic recalibration of ModelB and update of Kalman filter parameters."
    DTDFVocab:IsAutomatic true
]

// Environment and Component hierarchy
instance AmbientEnvironment : DTDFVocab:Environment [
    base:contains AmbientTemperatureSensor
]

instance InsulatedStyrofoamBox : DTDFVocab:Component [
    base:desc "Insulated styrofoam box acting as the physical plant enclosure of the incubator."
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi governing the control logic, sensor polling, and communication."
]

instance HeatBed : DTDFVocab:Component [
    base:desc "Heat‑bed providing thermal input to the incubator."
]

instance Fan : DTDFVocab:Component [
    base:desc "Internal fan used for air circulation within the incubator."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT are transmitted over RabbitMQ to the Raspberry Pi controller, which interprets them as actuation requests for the fan and the heatbed. The controller operates as a bang‑bang regulator, using the parameters lower limit (LL), upper limit (UL), heating duration (H), and waiting duration (C) to decide when to turn the heater or fan on or off. The low‑level driver receives these commands from the controller via the communication server and actuates the hardware. The controller reports its state back to RabbitMQ, providing feedback of the executed command. The documents provide no details on command authentication, conflict resolution, or explicit confirmation protocols beyond this state reporting."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through a two‑step process: first, each model is calibrated using a non‑linear least‑squares solver against a representative set of experimental data; second, the calibrated model is validated by comparing its predictions to an independent measurement trajectory, computing the root‑mean‑square error as the quantitative metric. Uncertainty in the models originates from variability in the heatbed’s thermal inertia and from random sensor noise; these are propagated through a Kalman filter that not only estimates the unmeasured heatbed temperature but also provides real‑time residuals that serve as anomaly indicators. When residuals exceed a statistically-defined threshold, the Twin’s monitor triggers a safety shutdown or logs the violation for further review. The entire calibration and validation workflow is automated and can be re‑run on demand (e.g., when a new load is introduced) to maintain fidelity. Additionally, co‑simulations that replay historical or live data are used to perform “what‑if” analyses, providing an operational validation of controller settings and further reinforcing the quality assurance process."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All data and control flow between the physical and virtual twins is mediated by a RabbitMQ message broker. The broker is deployed as part of the software stack and provides an AMQP‑based messaging layer that connects the low‑level driver, the Raspberry Pi controller, and the DT services. The documents do not describe network topology beyond this single‑broker architecture, nor do they detail bandwidth, latency, or redundancy requirements."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The core software components – the low‑level driver, the controller executing a bang‑bang logic, and the RabbitMQ communication server – are all hosted on a Raspberry Pi 4 Model B. This edge deployment is supported by the open‑source repository released by the authors. The documents do not provide explicit computational or storage resource specifications, nor do they describe additional deployment models, scalability mechanisms, or availability guarantees beyond the single‑device setup."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The digital twin framework for the incubator incorporates real‑time safety monitoring by running dedicated monitor algorithms that continuously evaluate the physical twin’s operating state against safety and optimality thresholds. Calibration algorithms update the embedded physics models using incoming sensor data (two temperature sensors inside the styrofoam box and one outside), ensuring the model predictions stay synchronized with the measured temperature dynamics. When a monitor detects a violation—such as a deviation from the target temperature band or anomalous heat‑bed performance—the system generates an alert that can be handled by a human operator or an automated safety‑action module. This integration of monitoring and calibration establishes a safety‑critical feedback loop that maintains the incubator within safe operating limits while enabling adaptive control of the heater and fan. No specific cybersecurity or access‑control measures are described in the provided documents."
]