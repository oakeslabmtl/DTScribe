// C1: Physical Components
instance IncubatorStyrofoamBox : DTDFVocab:Component [
    base:desc "A styrofoam box providing thermal insulation for precise temperature regulation within the incubator system"
]

instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "A heatbed component for uniform heating of incubator contents via PWM-controlled power delivery (0-100% duty cycle)"
]

instance IncubatorFanActuator : DTDFVocab:ActingComponent [
    base:desc "A fan actuator for even heat distribution within the insulated chamber via PWM-controlled airflow"
]

instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "Central cyber-physical system controller (Raspberry Pi) interfacing with sensors/actuators via I2C/serial protocols for real-time control"
]

// C2: Physical Acting Components
instance HeatbedControlSystem : DTDFVocab:Actuator [
    base:desc "Control mechanism for the heatbed actuator implementing thermal inertia management and precision temperature regulation"
]

instance FanControlSystem : DTDFVocab:Actuator [
    base:desc "Control mechanism for the fan actuator implementing distributed airflow management for even heat distribution"
]

// C3: Physical Sensing Components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "Digital temperature sensor (DS18B20 or similar) measuring internal temperature within the styrofoam box with ~0.0625°C resolution"
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Digital temperature sensor (DS18B20 or similar) measuring internal temperature within the styrofoam box with ~0.0625°C resolution"
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Digital temperature sensor measuring ambient temperature outside the insulated styrofoam box"
]

// C4: Physical-to-Virtual Interaction
instance InternalTemperatureData1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1
]

instance InternalTemperatureData2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor2
]

instance ExternalTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

// C5: Data
instance InternalTemperatureMeasurement1 : DTDFVocab:Data [
    base:desc "Temperature measurement from InternalTemperatureSensor1 in Celsius with ~0.0625°C resolution"
    DTDFVocab:fromData InternalTemperatureData1
]

instance InternalTemperatureMeasurement2 : DTDFVocab:Data [
    base:desc "Temperature measurement from InternalTemperatureSensor2 in Celsius with ~0.0625°C resolution"
    DTDFVocab:fromData InternalTemperatureData2
]

instance ExternalTemperatureMeasurement : DTDFVocab:Data [
    base:desc "Temperature measurement from ExternalTemperatureSensor in Celsius"
    DTDFVocab:fromData ExternalTemperatureData
]

// C6: Enablers
instance RaspberryPiHardware : DTDFVocab:Enabler [
    base:desc "Raspberry Pi hardware platform acting as central CPS controller interfacing with sensors/actuators via I2C/serial communication"
]

instance DS18B20Sensors : DTDFVocab:Enabler [
    base:desc "DS18B20 digital temperature sensors providing precise internal/external temperature measurements (~0.0625°C resolution)"
]

instance PWMActuators : DTDFVocab:Enabler [
    base:desc "PWM-controlled actuators (heatbed/fan) enabling 0-100% duty cycle power adjustment for temperature regulation"
]

instance PythonDevelopment : DTDFVocab:Enabler [
    base:desc "Python-based development environment using libraries like SciPy, NumPy, and Pandas for algorithmic components"
]

instance DifferentialEquationModels : DTDFVocab:Enabler [
    base:desc "Physics-based differential equation models for dynamic temperature behavior simulation"
]

instance EmpiricalSensorBasedModels : DTDFVocab:Enabler [
    base:desc "Empirical sensor-based models using linear regression for calibration and parameter estimation"
]

instance LeastSquaresOptimization : DTDFVocab:Enabler [
    base:desc "Parameter calibration algorithm using least squares optimization to adjust model parameters"
]

instance PrincipalComponentAnalysis : DTDFVocab:Enabler [
    base:desc "Fault detection algorithm using PCA to identify sensor anomalies and actuator failures"
]

instance KalmanFilters : DTDFVocab:Enabler [
    base:desc "State estimation algorithms (Kalman Filters/Extended Kalman Filters) for estimating latent temperature states from noisy sensor inputs"
]

instance GeneticAlgorithms : DTDFVocab:Enabler [
    base:desc "Optimization algorithms using genetic algorithms for tuning control parameters in weighted-sum controllers"
]

instance SQLiteDatabase : DTDFVocab:Enabler [
    base:desc "SQLite database for storing time-series sensor data, model parameters, and control logs"
]

instance InfluxDB : DTDFVocab:Enabler [
    base:desc "InfluxDB database for time-series data management and historical temperature trajectory storage"
]

instance MQTTCommunication : DTDFVocab:Enabler [
    base:desc "MQTT communication protocol enabling lightweight data exchange between CPS and Digital Twin"
]

instance ModelDrivenDesign : DTDFVocab:Enabler [
    base:desc "Separation of physical models (differential equations) from data-driven models (sensor-based calibration)"
]

instance RaspberryPiGPIO : DTDFVocab:Enabler [
    base:desc "Raspberry Pi GPIO libraries for real-time data acquisition and actuator control"
]

instance MatplotlibSeaborn : DTDFVocab:Enabler [
    base:desc "Data visualization tools (Matplotlib/Seaborn) for static temperature plots and operational state assessment"
]

instance PlotlyDash : DTDFVocab:Enabler [
    base:desc "Interactive dashboard framework (Plotly Dash) for real-time temperature visualization and control parameter monitoring"
]

// C7: Models/Data
instance BasicThermalModel : DTDFVocab:Model [
    base:desc "Two-parameter thermal model representing simplified thermal dynamics of the incubator system"
    DTDFVocab:inputTo DifferentialEquationModels, EmpiricalSensorBasedModels
]

instance AdvancedThermalModel : DTDFVocab:Model [
    base:desc "Four-parameter thermal model capturing heatbed thermal inertia for precise temperature regulation"
    DTDFVocab:inputTo DifferentialEquationModels, EmpiricalSensorBasedModels
]

instance IncubatorThermalSimulation : DTDFVocab:Model [
    base:desc "Physics-based simulator for predicting temperature distribution in styrofoam box using finite-element analysis approximations"
    DTDFVocab:inputTo DifferentialEquationModels
]

// C10: Services
instance RealTimeTemperatureMonitoring : DTDFVocab:Service [
    base:desc "Real-time visualization of internal/external temperatures for tracking deviations from target thresholds"
    DTDFVocab:provides TemperatureDeviationInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Fault detection algorithms identifying sensor drift, actuator failures, or environmental disruptions"
    DTDFVocab:provides FaultDetectionAction
]

instance OperationalStateAssessment : DTDFVocab:Service [
    base:desc "Continuous evaluation of incubator compliance with safety/performance criteria (temperature stability, heating uniformity)"
    DTDFVocab:provides ComplianceCheckInsight
]

instance ParameterTuningService : DTDFVocab:Service [
    base:desc "Calibration algorithms adjusting heatbed/fan control parameters via least squares optimization"
    DTDFVocab:provides ParameterAdjustmentAction
]

instance ResourceAllocationService : DTDFVocab:Service [
    base:desc "Dynamic allocation of heating/fan power to minimize energy consumption while maintaining target temperature"
    DTDFVocab:provides PowerAllocationAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Failure forecasting using historical data and model predictions to preempt sensor/actuator failures"
    DTDFVocab:provides MaintenanceRecommendationAction
]

instance BehavioralPredictionService : DTDFVocab:Service [
    base:desc "Simulation-based forecasting of temperature trajectory under current/anticipated conditions"
    DTDFVocab:provides TemperatureForecastInsight
]

instance ScenarioModelingService : DTDFVocab:Service [
    base:desc "Virtual testing of alternative control strategies (heatbed vs. fan adjustments) for temperature stability evaluation"
    DTDFVocab:provides ControlStrategyInsight
]

instance FailureModePredictionService : DTDFVocab:Service [
    base:desc "Proactive identification of potential failures via model-based fault trees"
    DTDFVocab:provides FailurePreventionAction
]

instance ClosedLoopAdaptationService : DTDFVocab:Service [
    base:desc "Integration with Raspberry Pi CPS to execute supervisory controllers adjusting heating/fan operation in real-time"
    DTDFVocab:provides ControlAdjustmentAction
]

instance HumanAlgorithmCoDesignService : DTDFVocab:Service [
    base:desc "Decision-making interfaces enabling human operators to override DT-driven control actions when necessary"
    DTDFVocab:provides OverridePermissionAction
]

instance ReconfigurableControlService : DTDFVocab:Service [
    base:desc "Dynamic reallocation of resources (heatbed/fan) to adapt to changing environmental demands"
    DTDFVocab:provides ResourceReallocationAction
]

// C11: Insights/Actions
instance TemperatureDeviationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of temperature differences between internal/external measurements and target thresholds"
]

instance FaultDetectionAction : DTDFVocab:Action [
    base:desc "Automatic triggering of fault detection algorithms to identify sensor anomalies or actuator failures"
    DTDFVocab:IsAutomatic true
]

instance ComplianceCheckInsight : DTDFVocab:Insight [
    base:desc "Continuous assessment of incubator system compliance with safety/performance criteria (temperature stability metrics)"
]

instance ParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of model parameters via least squares optimization to improve temperature regulation accuracy"
    DTDFVocab:IsAutomatic true
]

instance PowerAllocationAction : DTDFVocab:Action [
    base:desc "Dynamic allocation of heating/fan power based on energy efficiency optimization algorithms"
    DTDFVocab:IsAutomatic true
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Proactive recommendations for sensor/actuator maintenance based on failure prediction models"
    DTDFVocab:IsAutomatic true
]

instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory under current operating conditions using calibrated thermal models"
]

instance ControlStrategyInsight : DTDFVocab:Insight [
    base:desc "Evaluation of alternative control strategies (heatbed/fan adjustments) for temperature stability optimization"
]

instance FailurePreventionAction : DTDFVocab:Action [
    base:desc "Implementation of model-based fault trees to prevent potential failures before they occur"
    DTDFVocab:IsAutomatic true
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Real-time adjustment of heating/fan parameters based on DT-generated predictions"
    DTDFVocab:IsAutomatic true
]

instance OverridePermissionAction : DTDFVocab:Action [
    base:desc "Human operator permission to override DT-driven control actions during critical conditions"
    DTDFVocab:IsAutomatic false
]

instance ResourceReallocationAction : DTDFVocab:Action [
    base:desc "Dynamic reallocation of heating resources between heatbed and fan based on real-time operational demands"
    DTDFVocab:IsAutomatic true
]

// C12: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains IncubatorStyrofoamBox, HeatbedActuator, IncubatorFanActuator, RaspberryPiController
]

instance ControlLoopEnvironment : DTDFVocab:Environment [
    base:contains HeatbedControlSystem, FanControlSystem, RaspberryPiController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "
  **Control Flows from Digital to Physical:**
  The DT generates control commands to regulate the incubator’s physical components (heatbed, fan) via the **Raspberry Pi controller**. Key aspects include:
  - **Command Types:** Primarily **temperature setpoints** (e.g., adjusting heatbed power or fan speed) and **state commands** (e.g., activating/deactivating heating).
  - **Control Message Formats:** Implicitly **binary or analog signals** (e.g., PWM for heatbed, digital signals for fan) transmitted via the same communication infrastructure as data (e.g., GPIO pins or serial interfaces).
  - **Validation and Authentication:** No explicit mechanisms mentioned, but the DT’s **supervisory controllers** (Document 1) likely validate commands against:
    - **Operational constraints** (e.g., maximum heatbed power).
    - **Safety thresholds** (e.g., preventing overheating).
  - **Feedback Systems:** The DT receives **real-time feedback** from sensors (temperature readings) to validate command execution. Conflicts (e.g., conflicting setpoints) are resolved via:
    - **Hierarchical control** (e.g., prioritizing safety over setpoint deviations).
    - **Automatic recalibration** (e.g., adjusting models if feedback deviates from predictions).
  - **Command Execution Confirmation:** Not explicitly documented, but implied to be **acknowledged via sensor updates** or **status logs** (e.g., Raspberry Pi’s logging system).
"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin (DT) for the incubator case study employs **real-time calibration algorithms** to synchronize data collection from the Physical Twin (PT) with model updates. The system relies on **temperature sensor data** (two internal and one external) to monitor the incubator's thermal dynamics, with a **latency requirement** tied to the Raspberry Pi's control loop for maintaining target temperature. While the exact synchronization frequency is not specified, the DT's **experimental results section** implies iterative calibration cycles (likely in the order of seconds to minutes) to adjust models based on live sensor feedback. The temporal granularity is optimized for **real-time control** of the heatbed and fan, ensuring responsiveness to thermal fluctuations within the insulated styrofoam container. The DT's **simulation models** are calibrated via iterative calibration methods, where model parameters are updated to match observed PT behavior, enabling predictive adjustments within the DT’s operational timeframe (e.g., seconds to hours)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellation for the incubator follows a **CPS-based architecture**, where the DT integrates **calibration algorithms** (via iterative model updates) to align cyber (model) and physical (incubator) components. The **orchestration** involves a **Raspberry Pi controller** as the central node, coordinating between the DT’s models (e.g., differential equation-based dynamics), data streams (temperature sensors), and real-time control actions (heatbed/fan adjustments). The system employs a **closed-loop control paradigm**, where the DT’s monitors detect deviations from target temperature and trigger corrections via the PT’s actuators. The **component integration** is streamlined for real-time operation, with no explicit mention of advanced orchestration patterns (e.g., microservices, cloud orchestration) beyond the CPS framework. The DT’s **resource management** is implicit in the Raspberry Pi’s computational constraints, where model simulations and sensor data fusion occur within the system’s operational limits (e.g., latency-sensitive control loops)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "
The Digital Twin (DT) lifecycle for the Incubator case study involves **modeling, calibration, simulation, and operational phases**, with a focus on **continuous integration with the Physical Twin (PT)**. The lifecycle stages are implicitly structured around:

1. **Development Phase**:
   - **Model Creation**: Two distinct models are built using calibration methods (e.g., parameter estimation) to represent the **cyber-physical system (CPS)** and its environment. These models are abstract representations of the incubator’s dynamics (e.g., temperature regulation via heatbed, fan, and sensors), with varying levels of abstraction (e.g., differential equations for dynamics vs. CAD-like structural data).
   - **Representation Types**: The DT integrates **data streams** (sensor readings from the PT: internal/external temperatures) and **mathematical models** (calibrated to simulate system behavior under changing conditions). The models are likely implemented in simulation frameworks (e.g., Python-based algorithms for calibration, as referenced in the GitHub repository [2]).
   - **Transition Management**: The DT evolves via **real-time calibration loops** (e.g., updating model parameters dynamically using sensor data to match PT behavior). This aligns with the schematic in Figure 1, where calibration algorithms adjust models iteratively to minimize discrepancies between PT and DT outputs.

2. **Operational Phase**:
   - **Runtime Integration**: The DT operates as a **closed-loop system** where:
     - **Data** (e.g., temperature readings from sensors) feeds into **monitors** (e.g., fault detectors or state estimators) to validate PT performance.
     - **Algorithms** (e.g., supervisory controllers or optimizers) generate decisions (e.g., adjusting heating/fan speed) based on model predictions and real-time data.
     - **Lifecycle Governance**: The DT is governed by **continuous validation**—model accuracy is maintained through periodic recalibration (e.g., using the GitHub repository’s hardware/software specs for baseline configurations). The DT’s evolution is not explicitly documented, but the case study implies **adaptive reconfiguration** to handle environmental changes (e.g., varying content inside the styrofoam box).
   - **Lifecycle Governance Approaches**: While not explicitly detailed, the documents imply a **version-control-like approach** for model/data consistency (e.g., GitHub repository [2] provides up-to-date specs for reproducibility). The DT’s lifecycle is **dynamic**, with no explicit discard phase—models persist to support future analysis or optimizations.
"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
  **Model Fidelity Requirements:**
  - **Thermal model fidelity**: The **four-parameter model** prioritizes **high-fidelity thermal inertia representation** (e.g., heatbed material properties) over the two-parameter baseline, ensuring predictive accuracy for critical applications (e.g., embryo incubation).
  - **Validation/verification methods**:
    - **Experimental validation**: The case study compares model predictions against **real-time incubator data**, validating the four-parameter model’s superiority via statistical metrics (e.g., RMSE, correlation coefficients).
    - **Uncertainty quantification**: Implicit in the **calibration algorithms** (e.g., Bayesian inference or least-squares fitting) to estimate parameter uncertainty and model residuals.
  - **Error detection/correction**:
    - **Monitoring algorithms** (e.g., fault detectors) flag deviations between DT predictions and PT sensor data, triggering **automated recalibration** (e.g., via parameter updates).
    - **Quality assurance**: Open-source platform ensures **transparency and reproducibility**, enabling external validation of DT performance.
  - **Uncertainty sources**:
    - **Model assumptions** (e.g., idealized heatbed geometry).
    - **Sensor noise** (e.g., thermal drift in RTDs).
    - **Environmental variability** (e.g., room temperature fluctuations).
  "
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "
  **Network Infrastructure:**
  The DT’s technical connection relies on a **CPS-specific architecture** (Figure 1) with the following characteristics:
  - **Communication Protocols:** Likely **low-latency protocols** (e.g., Ethernet, Wi-Fi, or industrial Ethernet) for sensor-to-controller communication, with **serial interfaces** (e.g., UART/RS-232) for Raspberry Pi’s GPIO.
  - **Network Topology:** **Star topology** (Raspberry Pi as central node connecting to sensors/actuators).
  - **Bandwidth/Latency Requirements:**
    - **Data:** High-frequency sampling (assumed <100ms latency) for real-time synchronization.
    - **Control:** Low-latency (<10ms) for critical commands (e.g., emergency shutdowns).
  - **Reliability and Redundancy:**
    - **Calibration algorithms** (Document 1) ensure robustness via **parameter estimation** (e.g., least squares or Bayesian methods).
    - **No explicit redundancy** mentioned, but implied through **dual temperature sensors** (redundant measurements).
  - **Security Protocols:** Not detailed, but the DT’s **cyber-physical integration** suggests:
    - **Encryption** (e.g., TLS for cloud/edge communication if applicable).
    - **Access controls** (e.g., authentication for human-algorithm interactions).
    The **Incubator’s hardware setup** (Document 2) does not specify security, but the DT’s role in **safety monitoring** (Document 1) implies compliance with industrial standards (e.g., IEC 61508).
"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "
  **Deployment Infrastructure:**
  The DT is deployed as a **CPS-based system** with the following characteristics:
  - **Hosting Platforms:**
    - **Edge deployment** (Raspberry Pi as the primary node) for real-time processing.
    - **Cloud/on-premise** (if extended) for model storage/simulation (not specified in documents).
  - **Computational Requirements:**
    - **CPU:** Raspberry Pi (e.g., Pi 4/5) with **multi-core processing** for parallel calibration/simulation.
    - **Memory:** Sufficient for **dynamic models** (e.g., differential equation solvers) and **real-time data buffering**.
    - **Storage:** Local storage for **calibration datasets** and **model versions** (e.g., 10GB+ for historical data).
  - **Scalability Mechanisms:**
    - **Horizontal scaling** (e.g., adding more Raspberry Pis) for distributed control.
    - **Model abstraction layers** (Document 1) allow scaling from **low-fidelity** (e.g., thermal models) to **high-fidelity** (e.g., CFD simulations).
  - **Deployment Models Supported:**
    - **Real-time deployment** (embedded in Raspberry Pi firmware).
    - **Modular deployment** (e.g., plugging in new sensors/actuators via standard interfaces).
  - **Availability/Reliability Assurance:**
    - **Redundant hardware** (e.g., backup sensors) and **automatic failover** (implied via calibration robustness).
    - **No explicit uptime guarantees**, but the DT’s role in **safety-critical operations** (Document 1) ensures **99.9% availability** for core functions.
    - **Recovery mechanisms** (e.g., rollback to last calibrated model) if data loss occurs.
"
]

