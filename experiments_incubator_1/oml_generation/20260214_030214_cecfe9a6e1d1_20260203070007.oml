// ===========================
// Sensing Components & Data Flow
// ===========================

// Internal temperature sensor 1
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor monitoring air temperature inside the incubator."
    DTDFVocab:producedData TemperatureMessageInternal1
]

instance TemperatureMessageInternal1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1
]

instance TemperatureDataInternal1 : DTDFVocab:Data [
    base:desc "Raw temperature measurement (°C) from InternalTemperatureSensor1."
    DTDFVocab:fromData TemperatureMessageInternal1
    DTDFVocab:inputTo TimeSeriesDatabase, CalibrationEngine, StateEstimationEngine
]

// Internal temperature sensor 2
instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor monitoring air temperature inside the incubator."
    DTDFVocab:producedData TemperatureMessageInternal2
]

instance TemperatureMessageInternal2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor2
]

instance TemperatureDataInternal2 : DTDFVocab:Data [
    base:desc "Raw temperature measurement (°C) from InternalTemperatureSensor2."
    DTDFVocab:fromData TemperatureMessageInternal2
    DTDFVocab:inputTo TimeSeriesDatabase, CalibrationEngine, StateEstimationEngine
]

// External temperature sensor
instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor monitoring ambient room temperature outside the incubator."
    DTDFVocab:producedData TemperatureMessageExternal
]

instance TemperatureMessageExternal : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

instance TemperatureDataExternal : DTDFVocab:Data [
    base:desc "Raw temperature measurement (°C) from ExternalTemperatureSensor."
    DTDFVocab:fromData TemperatureMessageExternal
    DTDFVocab:inputTo TimeSeriesDatabase, CalibrationEngine, StateEstimationEngine
]

// ===========================
// Acting Components
// ===========================

instance ThermalActuatorHeatbed : DTDFVocab:ActingComponent [
    base:desc "Resistive heatbed actuator that can be switched on/off and driven for programmable heating duration H."
]

instance AirFlowActuatorFan : DTDFVocab:ActingComponent [
    base:desc "Internal fan that homogenises air temperature inside the incubator."
]

// ===========================
// Enablers (Tools & Infrastructure)
// ===========================

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker using AMQP protocol that connects the Raspberry Pi controller, low‑level driver and DT components."
    DTDFVocab:enables RealTimeVisualizationService, CalibrationService, AnomalyDetectionService, WhatIfSimulationService, SelfAdaptationLoopService
]

instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Low‑level driver abstracts sensor and actuator access, publishing sensor readings to RabbitMQ and forwarding actuation commands."
    DTDFVocab:enables RealTimeVisualizationService, CalibrationService, AnomalyDetectionService, WhatIfSimulationService, SelfAdaptationLoopService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time‑series database storing temperature measurements for dashboard visualisation and model input."
    DTDFVocab:enables RealTimeVisualizationService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Engine executing on‑demand calibration algorithms for Model B."
    DTDFVocab:enables CalibrationService
]

instance StateEstimationEngine : DTDFVocab:Enabler [
    base:desc "Kalman‑filter based engine that fuses sensor data with Model B predictions for anomaly detection and heat‑bed state estimation."
    DTDFVocab:enables AnomalyDetectionService
]

instance CoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation engine running Model A/Model B together with controller logic for what‑if analysis."
    DTDFVocab:enables WhatIfSimulationService
]

instance AdaptationEngine : DTDFVocab:Enabler [
    base:desc "Self‑adaptation engine that detects plant behaviour changes, schedules experiments, recalibrates models, re‑configures the Kalman filter and controller, and executes the updated control strategy."
    DTDFVocab:enables SelfAdaptationLoopService
]

// ===========================
// Services
// ===========================

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualisation of incubator status by ingesting controller and low‑level driver messages into the time‑series database and displaying them on a dashboard."
    DTDFVocab:provides VisualizationInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "On‑demand calibration of the thermal model (Model B) via an automated calibration routine."
    DTDFVocab:provides CalibrationInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection and heat‑bed state estimation using a Kalman filter that fuses measured sensor data with Model B predictions."
    DTDFVocab:provides AnomalyDetectionInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "What‑if simulations through co‑simulation that leverage historical or live PT data to optimise controller parameters."
    DTDFVocab:provides WhatIfRecommendation
]

instance SelfAdaptationLoopService : DTDFVocab:Service [
    base:desc "Self‑adaptation loop that detects plant behaviour changes, schedules data‑gathering experiments, recalibrates models, re‑configures the Kalman filter and controller, and executes the updated control strategy."
    DTDFVocab:provides AdaptationAction
]

// ===========================
// Insights & Actions
// ===========================

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Dashboard visualises temperature trends and system status in real time."
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Provides calibrated parameters of Model B for improved prediction accuracy."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects anomalies and estimates unmeasured heat‑bed temperature."
]

instance WhatIfRecommendation : DTDFVocab:Insight [
    base:desc "Recommends optimal heating duration (H) and waiting interval (C) based on simulation outcomes."
]

instance AdaptationAction : DTDFVocab:Action [
    base:desc "Automatically re‑configures controller limits, Kalman filter parameters and triggers new experiments."
    DTDFVocab:IsAutomatic true
]

// ===========================
// Models
// ===========================

instance ModelA : DTDFVocab:Model [
    base:desc "Analytical temperature dynamics model (Model A) using simplifying assumptions: uniform temperature, negligible wall heat storage, constant air specific heat, all electrical power converted to heat."
    DTDFVocab:inputTo CalibrationEngine, StateEstimationEngine, CoSimulationEngine
]

instance ModelB : DTDFVocab:Model [
    base:desc "Higher‑fidelity analytical model (Model B) that relaxes the assumption of heat‑bed non‑absorption, with four free parameters to capture thermal inertia."
    DTDFVocab:inputTo CalibrationEngine, StateEstimationEngine, CoSimulationEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands for the heat‑bed and the fan are generated by the controller (a bang‑bang controller with parameters LL, UL, H, C) and sent as RabbitMQ messages to the low‑level driver. The driver validates the commands against its safe protocol before forwarding them to the hardware actuators, then confirms execution back to the controller. The DT can also inject or modify commands by publishing to the same RabbitMQ queues, enabling a closed‑loop self‑adaptation flow."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The incubator Digital Twin is orchestrated around a central RabbitMQ message broker (AMQP) that synchronises communication between the physical twin’s low‑level driver, the Raspberry‑Pi controller, and the DT services. The low‑level driver reads temperature sensors and publishes measurements to RabbitMQ; the controller subscribes to these messages, issues fan and heat‑bed commands, and also publishes its state. DT components (real‑time visualisation, calibration service, Kalman‑filter based anomaly detection, what‑if co‑simulation, and the self‑adaptation loop) subscribe to the same topics, consume the data, update model parameters, run monitors, and publish results back through the broker. Calibration algorithms periodically update model parameters (Model A, Model B) which are then used by monitoring and control optimisation services. Thus the system follows a component‑based, message‑driven architecture with the broker acting as the coordination hub and resource manager for all DT services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The incubator Digital Twin lifecycle described in the documents proceeds through (1) initial hardware and software setup of the physical twin (styrofoam box, heat‑bed, fan, temperature sensors, Raspberry‑Pi controller); (2) development of two simulation models (Model A based on four assumptions, Model B relaxing assumption 4) and their implementation; (3) calibration of the models using calibration algorithms that estimate parameters from sensor data; (4) online monitoring where data from the low‑level driver are streamed via RabbitMQ to the DT; (5) anomaly detection and state estimation (Kalman filter) that feed back into the DT; (6) what‑if simulations and optimisation of controller parameters; and (7) a self‑adaptation loop that re‑configures the controller and re‑calibrates the model when the plant behaviour changes. Transition between stages is managed by the calibration process and the self‑adaptation loop, and the lifecycle is governed by continuous monitoring and re‑calibration."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the predictions of Model A (two free parameters) and Model B (four free parameters) against experimental temperature recordings; experiments demonstrated that Model B more accurately captures the thermal inertia of the heatbed. Fidelity uncertainties stem from the simplifying assumptions (uniform temperature distribution, negligible wall heat storage, constant air specific heat, and complete conversion of electrical power to heat) listed in the modelling section. On‑demand calibration algorithms periodically re‑estimate model parameters using the latest sensor data, reducing parametric error. Validation is performed through on‑line anomaly detection and heat‑bed state estimation using a Kalman filter that fuses Model B with measured temperatures, enabling detection of deviations caused by modelling inaccuracies or unforeseen disturbances. Calibration results are visualised (e.g., Figure 13) to assess model‑parameter convergence, and the self‑adaptation loop re‑calibrates models whenever significant anomalies are detected."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All cyber‑physical communication is mediated by a RabbitMQ message broker using the AMQP protocol. The controller runs on a Raspberry Pi and connects to RabbitMQ over the local network (wired or Wi‑Fi). The topology is a star/bus where each component (controller, low‑level driver, DT modules) is a client of the broker. RabbitMQ provides reliable message delivery, persistence, and can be deployed on‑premise or in the cloud, offering redundancy and fault tolerance. No explicit bandwidth, latency, or security protocol details are provided in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The controller software executes on an on‑board Raspberry Pi (edge device). The RabbitMQ broker and DT services (visualisation dashboard, calibration engine, Kalman filter, what‑if simulation) can be hosted either on‑premise or in a cloud environment, as RabbitMQ is described as easy to deploy in both contexts. Time‑series data are stored in a database for dashboarding. Specific computational, storage, scalability or availability specifications are not detailed in the supplied documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through RabbitMQ message exchanges and a time‑series database that stores sensor streams for dashboards. The DT listens to controller and driver messages (AMQP) and forwards processed data to the database for real‑time visualisation. Co‑simulation for what‑if scenarios can ingest historical or live PT data via the same message channel, allowing external simulation tools to be coupled. No additional enterprise‑level standards (e.g., OPC‑UA) are mentioned; the integration relies on open‑source components (RabbitMQ, time‑series DB, dashboards) and the publicly available GitHub repository for hardware/software artifacts."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The incubator Digital Twin incorporates safety measures through a 'safe protocol' embedded in the low‑level driver, which ensures the physical device remains in a safe state while interacting with the Physical Twin. Communication between the controller and the low‑level driver is mediated by a RabbitMQ message broker, providing synchronized, reliable message exchange for temperature readings, control commands, and state updates. The controller on the Raspberry Pi implements a bang‑bang control strategy with defined upper and lower temperature limits (UL, LL), heating duration (H) and waiting duration (C), and it periodically receives temperature measurements before issuing actuation commands. Although no explicit authentication, access‑control, or encryption mechanisms are described, the combination of the safe driver protocol and the controlled message flow via RabbitMQ constitutes the documented safety and security considerations for this DT system."
]