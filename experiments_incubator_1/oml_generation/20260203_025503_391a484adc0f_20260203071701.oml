// C2: Acting Components
instance ResistiveHeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that provides heating power to raise the incubator’s internal temperature."
]

// C3: Physical sensing components
instance InternalAirTemperatureSensorA : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted inside the incubator to monitor air temperature (range –55 °C to +125 °C, accuracy ±0.5 °C)."
    DTDFVocab:producedData InternalAirTempDataTransmittedA
]

instance InternalAirTemperatureSensorB : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted inside the incubator to monitor air temperature (range –55 °C to +125 °C, accuracy ±0.5 °C)."
    DTDFVocab:producedData InternalAirTempDataTransmittedB
]

instance ExternalAmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer placed outside the incubator to monitor ambient temperature (range –55 °C to +125 °C, accuracy ±0.5 °C)."
    DTDFVocab:producedData ExternalAmbientTempDataTransmitted
]

// C4: Physical-to-virtual interaction
instance InternalAirTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalAirTemperatureSensorA
]

instance InternalAirTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalAirTemperatureSensorB
]

instance ExternalAmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalAmbientTemperatureSensor
]

// C10: Data
instance InternalAirTemperatureDataA : DTDFVocab:Data [
    base:desc "Time‑series temperature measurements from InternalAirTemperatureSensorA."
    DTDFVocab:fromData InternalAirTempDataTransmittedA
    DTDFVocab:inputTo CalibrationAlgorithmEnabler,
                MonitoringAlgorithmEnabler,
                DataAcquisitionEnabler
]

instance InternalAirTemperatureDataB : DTDFVocab:Data [
    base:desc "Time‑series temperature measurements from InternalAirTemperatureSensorB."
    DTDFVocab:fromData InternalAirTempDataTransmittedB
    DTDFVocab:inputTo CalibrationAlgorithmEnabler,
                MonitoringAlgorithmEnabler,
                DataAcquisitionEnabler
]

instance ExternalAmbientTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series temperature measurements from ExternalAmbientTemperatureSensor."
    DTDFVocab:fromData ExternalAmbientTempDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithmEnabler,
                MonitoringAlgorithmEnabler,
                DataAcquisitionEnabler
]

// C10: Models/Data
instance SimpleThermalModel : DTDFVocab:Model [
    base:desc "Analytical differential‑equation based thermal model of the incubator using two free parameters to represent heat transfer."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance DetailedThermalModel : DTDFVocab:Model [
    base:desc "Analytical differential‑equation based thermal model using four free parameters to capture thermal inertia of the heat‑bed."
    DTDFVocab:inputTo SimulationEngineEnabler
]

// C11: Enablers
instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that updates model parameters to minimise error between simulated and measured temperature."
    DTDFVocab:enables CalibrationService
]

instance MonitoringAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring algorithm that evaluates calibrated models to detect safety or performance violations."
    DTDFVocab:enables MonitoringService
]

instance OptimizationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Optimization algorithm that analyses model predictions to recommend set‑point adjustments for improved efficiency."
    DTDFVocab:enables OptimizationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs thermal models to predict temperature trajectories under current operating conditions."
    DTDFVocab:enables SimulationPredictionService
]

instance DataAcquisitionEnabler : DTDFVocab:Enabler [
    base:desc "Data acquisition component that ingests temperature data streams from sensors."
    DTDFVocab:enables DataAcquisitionService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that performs continuous calibration of thermal model parameters using incoming temperature data."
    DTDFVocab:provides CalibrationInsight, ParameterUpdateAction
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors calibrated model outputs to detect safety violations or sub‑optimal performance."
    DTDFVocab:provides FaultDetectionInsight, AlertAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that generates optimisation recommendations such as new temperature set‑points based on model predictions."
    DTDFVocab:provides OptimizationRecommendationInsight, SetpointAdjustmentAction
]

instance SimulationPredictionService : DTDFVocab:Service [
    base:desc "Service that runs the SimpleThermalModel and DetailedThermalModel to produce temperature trajectory predictions."
    DTDFVocab:provides TemperaturePredictionInsight, ModelRunAction
]

instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Service that collects raw temperature measurements from the three sensors."
    DTDFVocab:provides RawTemperatureInsight
]

// C17: Insights
instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight that model parameters have been calibrated to match measured temperature data."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight that a safety or performance violation has been detected by the monitoring algorithm."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight that recommends a new temperature set‑point to improve incubation efficiency."
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Insight that predicts future temperature trajectory based on current operating conditions."
]

instance RawTemperatureInsight : DTDFVocab:Insight [
    base:desc "Insight providing raw temperature data streams from sensors."
]

// C17: Actions
instance ParameterUpdateAction : DTDFVocab:Action [
    base:desc "Action that automatically updates the thermal model parameters with calibrated values."
    DTDFVocab:IsAutomatic true
]

instance AlertAction : DTDFVocab:Action [
    base:desc "Action that creates an alert for operators when a violation is detected."
    DTDFVocab:IsAutomatic false
]

instance SetpointAdjustmentAction : DTDFVocab:Action [
    base:desc "Action that suggests adjusting the controller set‑point, pending operator approval."
    DTDFVocab:IsAutomatic false
]

instance ModelRunAction : DTDFVocab:Action [
    base:desc "Action that triggers execution of the thermal models for prediction."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is organized as a unified framework that ingests time‑stamped sensor data from the physical twin, applies calibration algorithms to estimate parameters and update the cyber‑physical system and environment models, then supplies the refreshed models to monitoring algorithms that evaluate safety and optimality. The loop can involve human operators or other automated algorithms to trigger actuation on the physical twin. This centralized data‑model‑algorithm pipeline is illustrated in Figure 1 of the documents."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity was evaluated experimentally by comparing the two temperature simulation models against measured temperature trajectories of the physical incubator. The four‑parameter model demonstrated higher accuracy in reproducing the thermal inertia of the heat‑bed, indicating superior fidelity for dynamic behaviour. Validation consisted of running the incubator under controlled conditions, recording temperature data, and computing prediction errors. Uncertainty sources include sensor noise and simplifications in the heat‑transfer equations. Calibration algorithms were used to reduce parameter uncertainty, and the resulting calibrated model serves as the validated representation within the digital twin."
]