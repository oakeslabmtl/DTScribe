// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "100W resistive heatbed for thermal regulation within the insulated box, constrained by power rating and controlled via bang-bang controller with MOSFET isolation for electrical safety."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "0.02 m³/s airflow fan powered by 12V or 24V DC, integrated with optocoupler isolation to prevent direct signal interference and ensure safe operation within the thermal regulation system."
]

instance BangBangTemperatureController : DTDFVocab:ActingComponent [
    base:desc "Digital bang-bang controller managing temperature adjustments by toggling the heatbed actuator based on sensor feedback, with MOSFETs providing electrical isolation for safety."
]

instance OptocouplerIsolationModule : DTDFVocab:ActingComponent [
    base:desc "Optocoupler-based signal isolation module preventing direct electrical interference between control signals and actuation components in the thermal regulation system."
]

// C3: Physical Sensing Components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer with ±0.5°C accuracy, deployed within the styrofoam box to monitor internal temperature gradients."
    DTDFVocab:producedData InternalTemperatureDataStream1
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer with ±0.5°C accuracy, deployed within the styrofoam box to monitor internal temperature gradients."
    DTDFVocab:producedData InternalTemperatureDataStream2
]

instance InternalTemperatureSensor3 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer with ±0.5°C accuracy, deployed within the styrofoam box to monitor internal temperature gradients."
    DTDFVocab:producedData InternalTemperatureDataStream3
]

// C4: Physical-to-Virtual Interaction
instance InternalTemperatureDataStream1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1
]

instance InternalTemperatureDataStream2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor2
]

instance InternalTemperatureDataStream3 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor3
]

instance TemperatureSensorDataAggregation : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureDataStream1, InternalTemperatureDataStream2, InternalTemperatureDataStream3
]

// C10: Models/Data
instance GeometricModel : DTDFVocab:Model [
    base:desc "CAD-based geometric model representing physical dimensions, shapes, and structural properties of the insulated box, heatbed, fan, and chassis components."
    DTDFVocab:inputTo RaspberryPiDataAcquisition
]

instance ThermalDynamicModel : DTDFVocab:Model [
    base:desc "Differential equation-based dynamic model simulating heat transfer, thermal distribution, and system response within the insulated box environment."
    DTDFVocab:inputTo DynamicModelCalibration, ThermalSimulationEngine
]

instance CalibrationParametersDatabase : DTDFVocab:Data [
    base:desc "Time-series database storing historical calibration parameters (e.g., thermal conductivity, heat loss coefficients) derived from sensor data and model refinement processes."
    DTDFVocab:fromData TemperatureSensorDataAggregation
    DTDFVocab:inputTo DynamicModelCalibration
]

instance RealTimeTemperatureData : DTDFVocab:Data [
    base:desc "Aggregated real-time temperature readings from all DS18S20 sensors, processed for immediate use in state estimation and control algorithms."
    DTDFVocab:fromData TemperatureSensorDataAggregation
    DTDFVocab:inputTo StateEstimationEngine, ControlAdjustmentAlgorithm
]

instance HistoricalTemperatureData : DTDFVocab:Data [
    base:desc "Archived temperature data used for long-term trend analysis, model validation, and predictive maintenance signal generation."
    DTDFVocab:fromData TemperatureSensorDataAggregation
    DTDFVocab:inputTo PredictiveAnalysisService
]

// C11: Enablers
instance RaspberryPiDataAcquisition : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B embedded system running low-level drivers to periodically read DS18S20 temperature sensors via 1-Wire protocol and forward data to RabbitMQ."
    DTDFVocab:enables TemperatureDataCollectionService, StateEstimationEngine
]

instance RabbitMQMessageBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ server acting as an asynchronous message broker facilitating decoupled communication between physical sensors, calibration algorithms, and monitoring modules."
    DTDFVocab:enables DynamicModelCalibration, FaultDetectionEngine, ControlAdjustmentAlgorithm
]

instance DynamicModelCalibration : DTDFVocab:Enabler [
    base:desc "Python-based non-linear least squares solver implemented via SciPy, adjusting thermal dynamic model parameters to minimize discrepancies between simulated and observed behavior."
    DTDFVocab:enables ModelDrivenCalibrationService
]

instance StateEstimationEngine : DTDFVocab:Enabler [
    base:desc "Supervisory controller using Kalman filter or similar algorithms to estimate current system state based on real-time sensor data and dynamic model predictions."
    DTDFVocab:enables RealTimeMonitoringService
]

instance FaultDetectionEngine : DTDFVocab:Enabler [
    base:desc "Custom Python-based monitoring tool detecting performance violations by comparing predicted vs. actual temperature states against safety thresholds."
    DTDFVocab:enables FaultDetectionService
]

instance ControlAdjustmentAlgorithm : DTDFVocab:Enabler [
    base:desc "PID-like control algorithm adjusting heatbed power and fan speed based on state estimation outputs to maintain optimal thermal conditions."
    DTDFVocab:enables OptimizationSupportService
]

instance ThermalSimulationEngine : DTDFVocab:Enabler [
    base:desc "Numerical solver (e.g., finite difference methods) implementing the thermal dynamic model to simulate system behavior under current or perturbed conditions."
    DTDFVocab:enables PredictiveAnalysisService
]

// C6: Services
instance TemperatureDataCollectionService : DTDFVocab:Service [
    base:desc "Continuous collection of high-precision temperature readings from DS18S20 sensors via 1-Wire protocol, with periodic uploads to RabbitMQ for further processing."
    DTDFVocab:provides TemperatureDataInsight
]

instance ModelDrivenCalibrationService : DTDFVocab:Service [
    base:desc "Parameter tuning service adjusting differential equation coefficients in the thermal dynamic model to achieve best-fit alignment with real-world performance data."
    DTDFVocab:provides CalibrationStatusInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "State estimation and performance monitoring service tracking current system health, detecting deviations from optimal operating conditions in real-time."
    DTDFVocab:provides SystemHealthInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Performance violation detection service triggering alerts when temperature readings exceed safe operational thresholds or deviate from predicted behavior."
    DTDFVocab:provides FaultAlertAction
]

instance OptimizationSupportService : DTDFVocab:Service [
    base:desc "Control adjustment service recommending or automatically implementing changes to heatbed power/fan speed to optimize thermal regulation efficiency."
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance PredictiveAnalysisService : DTDFVocab:Service [
    base:desc "What-if scenario simulation service predicting future system behavior under current or perturbed conditions to inform proactive decision-making."
    DTDFVocab:provides PredictiveInsight
]

// C17: Insights/Actions
instance TemperatureDataInsight : DTDFVocab:Insight [
    base:desc "Aggregated real-time temperature readings from all internal sensors, providing current thermal state of the insulated box environment."
]

instance CalibrationStatusInsight : DTDFVocab:Insight [
    base:desc "Current calibration accuracy metrics indicating how well the dynamic model parameters match observed system behavior."
]

instance SystemHealthInsight : DTDFVocab:Insight [
    base:desc "Real-time health metrics comparing predicted vs. actual temperature states, highlighting potential performance deviations."
]

instance FaultAlertAction : DTDFVocab:Action [
    base:desc "Automatic alert generation when temperature readings violate safety thresholds or performance expectations, triggering human or automated corrective actions."
    DTDFVocab:IsAutomatic true
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommended adjustments to heatbed power or fan speed to achieve optimal thermal regulation efficiency based on current system conditions."
]

instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Simulated future temperature profiles under current or perturbed operating conditions, enabling proactive decision-making."
]

// C18: Environment/Component Hierarchy
instance ThermalRegulationEnvironment : DTDFVocab:Environment [
    base:contains InsulatedBoxEnvironment, HeatbedComponent, FanComponent
]

instance InsulatedBoxEnvironment : DTDFVocab:Component [
    base:desc "Styrofoam-insulated enclosure minimizing external thermal interference while containing the heatbed and fan components for uniform temperature distribution."
    base:isContainedIn ThermalRegulationEnvironment
]

instance HeatbedComponent : DTDFVocab:Component [
    base:desc "100W resistive heating element providing thermal energy to the insulated box environment, controlled via bang-bang controller with MOSFET isolation."
    base:isContainedIn InsulatedBoxEnvironment
]

instance FanComponent : DTDFVocab:Component [
    base:desc "0.02 m³/s airflow distribution system ensuring uniform thermal conditions within the insulated box, powered by 12V/24V DC with optocoupler isolation."
    base:isContainedIn InsulatedBoxEnvironment
]

instance PhysicalTwinSystem : DTDFVocab:Environment [
    base:contains ThermalRegulationEnvironment, InternalTemperatureSensor1, InternalTemperatureSensor2, InternalTemperatureSensor3
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The **virtual-to-physical interaction** is implemented via a **bang-bang controller** that sends control commands to the physical twin. Commands are transmitted through the **RabbitMQ server**, which acts as the intermediary between the controller (digital component) and the physical system. The controller directly interacts with the physical twin, not the Digital Twin itself, as per the documented architecture. **Command types** are not specified beyond the controller’s role, but the interaction follows a **closed-loop feedback system** where the controller adjusts the physical twin’s behavior based on monitored data. No details are provided on **message formats** (e.g., binary/text), **validation/authentication mechanisms**, **conflict resolution**, or **command execution confirmation**. The system relies on the RabbitMQ server for message queuing but lacks explicit security or error-handling protocols for control commands."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system operates within a **periodic control loop** framework, where the physical twin (e.g., an incubator) is monitored and controlled through discrete time intervals. The system explicitly describes a **low-level driver** that **periodically reads temperature data** from the physical system, enabling real-time calibration of models. The **controller** component **waits after each actuation** to ensure synchronized updates between the physical and digital representations, implying a **deterministic temporal granularity** tied to the control cycle. No hierarchical time scales or continuous monitoring frequencies are specified beyond this periodic interaction, which is critical for maintaining consistency between the Digital Twin’s models and the Physical Twin’s operational state. Latency requirements are implicitly tied to the control loop’s responsiveness, though explicit latency thresholds (e.g., milliseconds or seconds) are not documented."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows an architecture pattern centered around the integration of three core components: **Data** (collected via sensors from the PT over time), **Models** (abstract representations of the PT’s cyber and physical aspects and its environment), and **Algorithms** (e.g., calibration algorithms, fault detectors, supervisory controllers, and optimizers). The system employs a modular orchestration where calibration algorithms update models dynamically using real-time data, feeding into monitoring services that assess system performance and safety. When violations are detected, the system enables human or automated interventions to modify the PT’s operational parameters. Resource management is implied to be centralized, with algorithms acting as intermediaries to bridge data, models, and decision-making processes. The overall coordination mechanism relies on iterative feedback loops between the PT and DT, ensuring alignment between the digital and physical representations."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The lifecycle of a Digital Twin (DT) spans from conceptualization to operational deployment and continuous evolution. Initially, the DT is developed during the design phase, where abstract representations (e.g., CAD models for physical dimensions or dynamic models for system behavior) are constructed to analyze specific aspects of the Physical Twin (PT). These models are refined iteratively, incorporating knowledge about cyber-physical systems (CPS) and environmental interactions. Upon deployment, the DT integrates with the PT through real-time data collection via sensors, enabling continuous monitoring and calibration. Calibration algorithms, such as non-linear least squares solvers, update models with the best parameter estimates derived from sensor data, ensuring alignment between the DT and PT. Transition management between phases involves integrating models into the DT framework post-deployment, where they are used for predictive simulations, fault detection, and performance optimization. Lifecycle governance is implicitly supported by the iterative update process, ensuring the DT remains a dynamic, evolving representation of the PT’s state and behavior over time. The document emphasizes that models should not be discarded post-deployment but instead integrated into the DT to sustain value throughout the PT’s operational lifecycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
Model fidelity is addressed through **abstraction levels**, where simplified models (e.g., lumped thermal capacitance) are prioritized for real-time simulations, while detailed models (e.g., partial differential equations for heat conduction) are used for offline validation. **Validation and verification (V&V) methods** include **calibration via non-linear least squares** to minimize parameter errors between the DT and PT. **Uncertainty sources** are implicitly acknowledged through the need for calibration, but explicit quantification (e.g., sensor noise, model bias) is not provided. **Error detection mechanisms** rely on **monitoring algorithms** that flag deviations from expected behavior (e.g., overheating). **Quality assurance processes** are inferred from the iterative calibration loop, though formal documentation of V&V procedures is not referenced in the documents.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for the Digital Twin system includes a **Raspberry Pi 4 Model B** equipped with **Wi-Fi and Bluetooth** for wireless communication. The system leverages a **RabbitMQ server** (protocol unspecified in the document) hosted on the Raspberry Pi to facilitate communication between physical sensors and digital components. **Network topology** is not explicitly described beyond the Raspberry Pi acting as a local gateway. **Bandwidth and latency requirements**, **reliability mechanisms** (e.g., persistent queues, retries), and **security protocols** (e.g., authentication, encryption) are **not in Document**. The only technical detail is the use of the Raspberry Pi’s wireless capabilities for data transmission between the DS18S20 sensor and the RabbitMQ server."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **hosting and deployment infrastructure** is **on-premise**, utilizing a **Raspberry Pi 4 Model B** running the **RabbitMQ server** as the primary computational node. The Digital Twin components (e.g., models, algorithms) are not explicitly stated to be hosted on the Raspberry Pi; instead, the RabbitMQ server serves as a **message broker** for data exchange. **Computational and storage requirements** are not detailed beyond the Raspberry Pi’s hardware specifications. **Scalability mechanisms**, **deployment models** (e.g., containerized, virtualized), and **availability/reliability assurance** (e.g., redundancy, failover) are **not in Document**. The system relies solely on the Raspberry Pi’s local resources for deployment, with no mention of cloud/edge integration or hardware redundancy."
]