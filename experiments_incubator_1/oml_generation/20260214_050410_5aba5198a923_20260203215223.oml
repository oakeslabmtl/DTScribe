// C3: Physical Sensing Components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire temperature sensor inside the incubator measuring internal temperature."
    DTDFVocab:producedData InternalTempDataTx1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire temperature sensor inside the incubator measuring internal temperature at a second point."
    DTDFVocab:producedData InternalTempDataTx2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire temperature sensor outside the incubator measuring ambient room temperature."
    DTDFVocab:producedData AmbientTempDataTx
]

// C2: Acting Components
instance HeatbedRelay : DTDFVocab:ActingComponent [
    base:desc "Relay controlling the ~100W heatbed via a MOSFET/optocoupler interface connected to the Raspberry Pi GPIO."
]

instance FanRelay : DTDFVocab:ActingComponent [
    base:desc "Relay controlling the 12/24 V fan via a MOSFET/optocoupler interface connected to the Raspberry Pi GPIO."
]

// C4: Data Transmitted
instance InternalTempDataTx1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempDataTx2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance AmbientTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

instance HeatbedStateTx : DTDFVocab:DataTransmitted [
    // no producedFrom because non‑sensing component
]

instance FanStateTx : DTDFVocab:DataTransmitted [
    // no producedFrom because non‑sensing component
]

// C10: Data
instance InternalTemperatureData1 : DTDFVocab:Data [
    base:desc "Temperature trace from InternalTempSensor1."
    DTDFVocab:inputTo PythonRuntimeEnabler
    DTDFVocab:fromData InternalTempDataTx1
]

instance InternalTemperatureData2 : DTDFVocab:Data [
    base:desc "Temperature trace from InternalTempSensor2."
    DTDFVocab:inputTo PythonRuntimeEnabler
    DTDFVocab:fromData InternalTempDataTx2
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Temperature trace from AmbientTempSensor."
    DTDFVocab:inputTo PythonRuntimeEnabler
    DTDFVocab:fromData AmbientTempDataTx
]

instance HeatbedRelayState : DTDFVocab:Data [
    base:desc "ON/OFF state log of the heatbed relay."
    DTDFVocab:inputTo PythonRuntimeEnabler
    DTDFVocab:fromData HeatbedStateTx
]

instance FanRelayState : DTDFVocab:Data [
    base:desc "ON/OFF state log of the fan relay."
    DTDFVocab:inputTo PythonRuntimeEnabler
    DTDFVocab:fromData FanStateTx
]

instance CalibrationResidualData : DTDFVocab:Data [
    base:desc "Residuals from calibration of temperature dynamics models."
    DTDFVocab:inputTo PythonRuntimeEnabler
    DTDFVocab:fromData InternalTempDataTx1, InternalTempDataTx2
]

// C10: Models
instance TemperatureModelA : DTDFVocab:Model [
    base:desc "Physics‑based temperature dynamics model with single parameters C_air and G_box."
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance TemperatureModelB : DTDFVocab:Model [
    base:desc "Physics‑based temperature dynamics model with parameters C_air, C_heater, G_box, and G_heater."
    DTDFVocab:inputTo PythonRuntimeEnabler
]

// C11: Enablers
instance PythonRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime executing controller logic, calibration scripts, simulation models and bang‑bang control."
    DTDFVocab:enables OnlineMonitoringService, TemperatureSimulationService, CalibrationService, BangBangControllerService
]

// C6: Services
instance OnlineMonitoringService : DTDFVocab:Service [
    base:desc "Monitors real‑time temperature readings and actuator statuses using data streamed over RabbitMQ."
    DTDFVocab:provides RealTimeTemperatureInsight, ActuatorStatusInsight
]

instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Performs digital simulation using TemperatureModelA and TemperatureModelB to predict temperature dynamics."
    DTDFVocab:provides TemperaturePredictionInsight, CalibratedModelCoefficientsInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibrates TemperatureModelA and TemperatureModelB parameters via non‑linear least‑squares optimization using experimental traces."
    DTDFVocab:provides CalibrationCoefficientsInsight
]

instance BangBangControllerService : DTDFVocab:Service [
    base:desc "Implements a bang‑bang temperature controller adjusting heating duration H and waiting duration C."
    DTDFVocab:provides BangBangTemperatureControlAction
]

// C17: Insights
instance RealTimeTemperatureInsight : DTDFVocab:Insight [
    base:desc "Live temperature readings from internal sensors displayed on the dashboard."
]

instance ActuatorStatusInsight : DTDFVocab:Insight [
    base:desc "Current ON/OFF states of heatbed and fan relays."
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature profiles from TemperatureModelA and TemperatureModelB."
]

instance CalibratedModelCoefficientsInsight : DTDFVocab:Insight [
    base:desc "Calibrated coefficients C_air, G_box, C_heater, G_heater obtained via least‑squares optimization."
]

instance CalibrationCoefficientsInsight : DTDFVocab:Insight [
    base:desc "Results of calibration including residuals and fitted parameters."
]

// C17: Actions
instance BangBangTemperatureControlAction : DTDFVocab:Action [
    base:desc "Bang‑bang control action adjusting heating duration H and waiting duration C."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Messages received by the Raspberry Pi over the RabbitMQ broker carry actuator commands (e.g., heater on/off, fan on/off). The low‑level driver translates these commands into GPIO pulses via the MOSFET interface to control the heatbed and fan."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time near‑real‑time operations where sensor polling and command exchanges occur on the order of seconds, consistent with the physical control loop’s heating (H) and waiting (C) durations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellation consists of a RabbitMQ communication server running on the Raspberry Pi, a low‑level driver linking the PT hardware to the broker, a controller that implements a bang‑bang temperature policy, and the simulation models (Model A/B) which consume sensor data and produce predictions; all modules run centrally on the Pi and exchange messages via the broker."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design → Build → Calibration → Operation. The Physical Twin was fabricated (PCB, heatbed, sensors), the Digital Twin’s models were developed and calibrated against experimental data, and both systems operate together in continuous operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Assumptions: uniform temperature inside the container (validated by multi‑sensor tests), negligible heat transfer to walls, constant specific heat capacity of air, and in Model A the heatbed treated as a perfect heat source (excluded in Model B). Model validation was performed via comparison of predicted temperature traces with measured sensor data, minimising residual error through optimization."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical and virtual interactions are mediated by a local RabbitMQ broker running on the same Raspberry Pi. The broker implements the AMQP 0‑9‑1 protocol and exchanges JSON messages over the loopback interface (127.0.0.1). No external network exposure or additional transport protocols are employed."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT software (controller, driver, RabbitMQ, simulation models) runs locally on the Raspberry Pi. The PT and DT share the same board, eliminating remote cloud hosting; the system is physically deployed within the incubator bench."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is enforced by a simple safe protocol within the low‑level driver: every incoming command is validated against configured limits (e.g., heater or fan enabled only for specified durations), and temperature thresholds are monitored to prevent overheating. No cyber‑security measures (authentication, encryption) are implemented, as the RabbitMQ broker and all components operate on the same device with no external network exposure."
]