// C3: Physical sensing components
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor inside incubator measuring internal temperature"
    DTDFVocab:producedData InternalTempDataTransmittedA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Second internal temperature sensor inside incubator measuring internal temperature"
    DTDFVocab:producedData InternalTempDataTransmittedB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor monitoring ambient temperature outside the incubator"
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmitted)
instance InternalTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// C10: Data (sensor readings)
instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Temperature reading from internal sensor A"
    DTDFVocab:fromData InternalTempDataTransmittedA
    DTDFVocab:inputTo DataAcquisitionEnabler, ModelCalibrationEnabler, PredictionEnabler, OptimisationEnabler, SafetyVerificationEnabler
]

instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Temperature reading from internal sensor B"
    DTDFVocab:fromData InternalTempDataTransmittedB
    DTDFVocab:inputTo DataAcquisitionEnabler, ModelCalibrationEnabler, PredictionEnabler, OptimisationEnabler, SafetyVerificationEnabler
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Ambient temperature reading from external sensor"
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo DataAcquisitionEnabler, ModelCalibrationEnabler, PredictionEnabler, OptimisationEnabler, SafetyVerificationEnabler
]

// C10: Models/Data
instance SimpleThermalModel : DTDFVocab:Model [
    base:desc "Thermal incubator model with two free parameters predicting temperature inside the insulated box"
    DTDFVocab:inputTo PredictionEnabler
]

instance DetailedThermalModel : DTDFVocab:Model [
    base:desc "Detailed thermal model with four free parameters capturing the thermal inertia of the heat‑bed"
    DTDFVocab:inputTo PredictionEnabler
]

// C11: Enablers
instance DataAcquisitionEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level driver reads the three temperature sensors periodically and publishes readings via RabbitMQ (AMQP) using a safe protocol"
    DTDFVocab:enables MonitoringService
]

instance ModelCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithms that estimate the free parameters of the two simulation models using incoming sensor data"
    DTDFVocab:enables OptimisationService, SafetyVerificationService
]

instance PredictionEnabler : DTDFVocab:Enabler [
    base:desc "Simulation component that runs the calibrated thermal models to predict future temperature evolution"
    DTDFVocab:enables PredictionService
]

instance OptimisationEnabler : DTDFVocab:Enabler [
    base:desc "Optimization engine that determines optimal heating‑bed power and fan speed based on predictions"
    DTDFVocab:enables OptimisationService
]

instance SafetyVerificationEnabler : DTDFVocab:Enabler [
    base:desc "Safety verification module that continuously checks temperature limits and detects violations"
    DTDFVocab:enables SafetyVerificationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature data from the incubator"
    DTDFVocab:provides StateEstimationInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Prediction of temperature evolution using calibrated thermal models"
    DTDFVocab:provides TemperaturePredictionInsight, ThermalInertiaEstimationInsight
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Optimisation of control actions for the heat‑bed and fan based on predictions"
    DTDFVocab:provides ConfidenceBasedRecommendationInsight, AdjustHeatingAction, AdjustFanAction
]

instance SafetyVerificationService : DTDFVocab:Service [
    base:desc "Continuous safety verification and fault detection"
    DTDFVocab:provides FaultDetectionInsight
]

instance VisualisationService : DTDFVocab:Service [
    base:desc "Advanced visualisation and reconfiguration of the incubator digital twin"
    DTDFVocab:provides VisualisationInsight
]

// C17: Insights
instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimation of the current thermal state of the incubator based on sensor data"
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Prediction of future temperature evolution inside the incubator"
]

instance ThermalInertiaEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimation of the thermal inertia of the heat‑bed derived from model calibration"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of faults such as overheating, sensor failure or control deviation"
]

instance ConfidenceBasedRecommendationInsight : DTDFVocab:Insight [
    base:desc "Confidence‑based recommendation for adjusting controller parameters to maintain safety and efficiency"
]

instance VisualisationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of incubator state, model predictions and optimisation outcomes"
]

// C17: Actions
instance AdjustHeatingAction : DTDFVocab:Action [
    base:desc "Command to increase or decrease the heat‑bed power"
    DTDFVocab:IsAutomatic true
]

instance AdjustFanAction : DTDFVocab:Action [
    base:desc "Command to modify fan speed for better heat distribution"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed that generates heat for the incubator"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan that distributes heat inside the styrofoam container"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin sends control commands (e.g., turn heat‑bed on/off, fan on/off, heating duration, waiting duration) as messages to the RabbitMQ broker. The controller, listening on RabbitMQ, receives these commands, executes a bang‑bang style control logic on the Raspberry Pi, and the low‑level driver forwards the actuation signals to the physical actuators. The low‑level driver incorporates a safety protocol that validates incoming commands before execution and uploads the resulting control state back to RabbitMQ as feedback."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT adopts a cyclic orchestration where data collected from the Physical Twin’s sensors are fed to calibration algorithms that update the parameters of cyber‑physical system and environment models; the refreshed models are then consumed by monitoring algorithms to assess safety and optimality, and when violations are detected a human operator or higher‑level controller can issue corrective actions back to the Physical Twin. This integrated flow of Data → Calibration → Updated Models → Monitoring → Decision/Control reflects the architecture outlined in Figure 1 of Document 1."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle described in the documents consists of (1) data acquisition where sensor streams from the physical twin are continuously collected; (2) model creation and integration, where abstract representations of the CPS physics and environment are built; (3) calibration, where algorithms estimate the best‑fit parameters for the models using the latest data; (4) monitoring, where the calibrated models feed runtime monitors that evaluate safety and optimality criteria; and (5) adaptation/feedback, where detected violations trigger human operators or automated algorithms to modify the physical twin or update the models. Transitions between stages are managed by the calibration and monitoring algorithms, and governance is implied by the continuous loop of data‑model‑monitor‑action."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed experimentally by comparing each model’s temperature predictions with the actual sensor measurements. The four‑parameter model showed higher accuracy in reproducing the heat‑bed’s thermal inertia and was selected for further development. Calibration algorithms update model parameters to reduce prediction error, and monitoring components detect violations of expected behaviour, prompting re‑calibration to maintain validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All components communicate through a RabbitMQ server using the AMQP protocol. The architecture follows a central broker topology: sensors → low‑level driver → RabbitMQ; controller ↔ RabbitMQ; DT components ↔ RabbitMQ. RabbitMQ provides reliable message delivery, queuing, and can be deployed on‑premise or in the cloud, offering a lightweight, mature networking layer with built‑in reliability mechanisms. Specific bandwidth or latency requirements are not stated in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The control software runs on a Raspberry Pi (edge device). The RabbitMQ broker that underpins the DT communication may be deployed either on‑premise or in a cloud environment, as indicated in the documents. No further details on storage, compute scaling, or additional availability mechanisms are provided."
]