// C2: Acting Components
instance ForceActuator : DTDFVocab:ActingComponent [
    base:desc "Physical component that applies controlled forces to the Cyber-Physical System based on Digital Twin control signals, enabling real-time adjustments to system dynamics."
]

instance EnvironmentalActuator : DTDFVocab:ActingComponent [
    base:desc "Component that modulates environmental interactions (e.g., temperature, pressure) of the Physical Twin based on Digital Twin optimization recommendations."
]

instance ControlSystemController : DTDFVocab:ActingComponent [
    base:desc "Embedded controller executing real-time decision-making logic to regulate system behavior based on Digital Twin state estimates and control signals."
]

// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Deployed sensor capturing real-time thermal data (e.g., temperature gradients) from the Physical Twin's operational environment."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring real-time pressure conditions (e.g., fluid dynamics, environmental loads) within the Cyber-Physical System."
    DTDFVocab:producedData PressureDataTransmitted
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency sensor detecting mechanical vibrations to monitor structural integrity and operational health of the Physical Twin."
    DTDFVocab:producedData VibrationDataTransmitted
]

instance ForceSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing real-time force measurements (e.g., applied loads, reaction forces) during system operation."
    DTDFVocab:producedData ForceDataTransmitted
]

instance EnvironmentalConditionSensor : DTDFVocab:SensingComponent [
    base:desc "Multi-parameter sensor monitoring external environmental factors (e.g., humidity, wind, solar radiation) affecting the Physical Twin's performance."
    DTDFVocab:producedData EnvironmentalConditionDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

instance VibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
]

instance ForceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ForceSensor
]

instance EnvironmentalConditionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalConditionSensor
]

instance EventTriggeredDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Asynchronous data transmission triggered by critical events (e.g., alarms, anomalies) from Physical Twin components."
]

// C10: Models/Data
instance GeometricModel : DTDFVocab:Model [
    base:desc "CAD-based geometric representation of Physical Twin components (e.g., structural elements, spatial configurations) used for spatial analysis and visualization."
    DTDFVocab:inputTo CADIntegrationEngine
]

instance DynamicBehaviorModel : DTDFVocab:Model [
    base:desc "Physics-based differential equation model simulating mechanical, thermal, or fluid dynamics of the Physical Twin under operating conditions."
    DTDFVocab:inputTo PhysicsSimulationEngine
]

instance MultiDomainSimulationModel : DTDFVocab:Model [
    base:desc "Co-simulation model integrating multiple domains (e.g., CAD, control, environmental) using FMI-standard tools for cross-domain behavioral analysis."
    DTDFVocab:inputTo FMIStandardEngine
]

instance StateEstimationModel : DTDFVocab:Model [
    base:desc "Kalman filter or particle filter model reconciling noisy sensor data with Physical Twin dynamics to produce consistent state estimates."
    DTDFVocab:inputTo KalmanFilterEstimator
]

instance FaultDetectionModel : DTDFVocab:Model [
    base:desc "Model-based or machine learning model detecting anomalies in Physical Twin behavior using parity space methods or neural networks."
    DTDFVocab:inputTo SVMFaultDetection
]

instance OptimizationModel : DTDFVocab:Model [
    base:desc "Constrained optimization model (e.g., CVX, Gurobi) solving resource allocation or control parameter problems for system efficiency."
    DTDFVocab:inputTo CVXOptimizer
]

instance TimeSeriesDatabaseData : DTDFVocab:Data [
    base:desc "Structured time-series dataset storing sensor-derived operational metrics (e.g., temperature, pressure, vibration) for real-time analytics."
    DTDFVocab:fromData TemperatureDataTransmitted, PressureDataTransmitted, VibrationDataTransmitted, ForceDataTransmitted
    DTDFVocab:inputTo InfluxDBSystem
]

instance KnowledgeGraphData : DTDFVocab:Data [
    base:desc "Semantic knowledge graph representing ontological relationships between Physical Twin components, models, and algorithms for semantic querying."
    DTDFVocab:fromData EnvironmentalConditionDataTransmitted, EventTriggeredDataTransmitted
    DTDFVocab:inputTo OWLKnowledgeGraphEngine
]

instance EdgeComputedData : DTDFVocab:Data [
    base:desc "Low-latency processed data from edge computing nodes, pre-filtered and calibrated before synchronization with central Digital Twin systems."
    DTDFVocab:fromData TemperatureDataTransmitted, PressureDataTransmitted
    DTDFVocab:inputTo AWSIoTGreengrass
]

// C11: Enablers
instance SiemensMindSpherePlatform : DTDFVocab:Enabler [
    base:desc "General-purpose Digital Twin framework providing cloud-based services for data management, simulation, and analytics integration."
    DTDFVocab:enables RealTimeDataAcquisitionService, PredictiveAnalysisService
]

instance PTCThingWorxPlatform : DTDFVocab:Enabler [
    base:desc "Digital Twin platform enabling modular architecture for integrating CAD models with dynamic simulations and real-time monitoring."
    DTDFVocab:enables StateEstimationService, VisualizationService
]

instance MATLABSimulationEngine : DTDFVocab:Enabler [
    base:desc "Physics-based simulation engine using Simulink for modeling mechanical, thermal, or fluid dynamics of the Physical Twin."
    DTDFVocab:enables DynamicBehaviorSimulationService
]

instance COMSOLMultiphysicsEngine : DTDFVocab:Enabler [
    base:desc "Multi-physics simulation tool for coupled domain analysis (e.g., thermal-structural interactions) in the Digital Twin."
    DTDFVocab:enables MultiDomainSimulationService
]

instance InfluxDBSystem : DTDFVocab:Enabler [
    base:desc "Time-series database storing sensor data streams for real-time analytics and historical trend analysis."
    DTDFVocab:enables TimeSeriesAnalyticsService
]

instance TimescaleDBSystem : DTDFVocab:Enabler [
    base:desc "PostgreSQL extension for time-series data management, enabling SQL-based querying of operational metrics."
    DTDFVocab:enables HistoricalDataAnalysisService
]

instance AWSIoTGreengrass : DTDFVocab:Enabler [
    base:desc "Edge computing platform processing low-latency sensor data locally before synchronization with central Digital Twin systems."
    DTDFVocab:enables EdgeProcessingService
]

instance AzureIoTEdge : DTDFVocab:Enabler [
    base:desc "Edge computing solution enabling distributed processing of sensor data with cloud synchronization capabilities."
    DTDFVocab:enables DistributedDataProcessingService
]

instance RecursiveLeastSquaresAlgorithm : DTDFVocab:Enabler [
    base:desc "Parameter estimation algorithm refining Digital Twin models using real-time sensor data to minimize prediction errors."
    DTDFVocab:enables ModelCalibrationService
]

instance BayesianUpdatingAlgorithm : DTDFVocab:Enabler [
    base:desc "Probabilistic calibration method updating model parameters with real-time data using Bayesian inference techniques."
    DTDFVocab:enables ProbabilisticModelingService
]

instance SVMFaultDetection : DTDFVocab:Enabler [
    base:desc "Support Vector Machine-based algorithm detecting anomalies in Physical Twin behavior by classifying sensor data patterns."
    DTDFVocab:enables AnomalyDetectionService
]

instance NeuralNetworkFDI : DTDFVocab:Enabler [
    base:desc "Deep learning model implementing Fault Detection and Isolation (FDI) using neural networks for complex pattern recognition."
    DTDFVocab:enables AdvancedFaultDetectionService
]

instance CVXOptimizer : DTDFVocab:Enabler [
    base:desc "Constrained optimization solver for solving control or resource allocation problems in the Digital Twin."
    DTDFVocab:enables OptimizationService
]

instance GurobiOptimizer : DTDFVocab:Enabler [
    base:desc "High-performance optimization solver for large-scale constrained optimization problems in Digital Twin applications."
    DTDFVocab:enables LargeScaleOptimizationService
]

instance KalmanFilterEstimator : DTDFVocab:Enabler [
    base:desc "State estimation algorithm reconciling noisy sensor data with Physical Twin dynamics to produce consistent state estimates."
    DTDFVocab:enables StateEstimationService
]

instance ParticleFilterEstimator : DTDFVocab:Enabler [
    base:desc "Non-linear state estimation algorithm handling complex dynamic systems with high uncertainty in sensor measurements."
    DTDFVocab:enables NonLinearStateEstimationService
]

instance OWLKnowledgeGraphEngine : DTDFVocab:Enabler [
    base:desc "Ontology modeling engine defining formal semantics for Physical Twin components, models, and algorithms using OWL/RDFS."
    DTDFVocab:enables SemanticQueryService
]

instance RESTfulAPIGateway : DTDFVocab:Enabler [
    base:desc "API gateway facilitating communication between Digital Twin services and external systems (e.g., SCADA, ERP) via RESTful protocols."
    DTDFVocab:enables ServiceIntegrationService
]

instance UnityVisualizationEngine : DTDFVocab:Enabler [
    base:desc "3D visualization platform enabling immersive visualization of Physical Twin-Digital Twin interactions via Unity engine."
    DTDFVocab:enables ImmersiveVisualizationService
]

instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering tool abstracting system behavior into reusable models for Digital Twin development."
    DTDFVocab:enables ModelDrivenDevelopmentService
]

instance ModelicaSimulationEngine : DTDFVocab:Enabler [
    base:desc "Multi-domain simulation language enabling component-based modeling of complex Cyber-Physical Systems."
    DTDFVocab:enables ComponentBasedSimulationService
]

instance MQTTProtocolStack : DTDFVocab:Enabler [
    base:desc "Lightweight IoT communication protocol enabling real-time data transmission from Physical Twin sensors to Digital Twin systems."
    DTDFVocab:enables RealTimeDataTransmissionService
]

instance OPCUAProtocolStack : DTDFVocab:Enabler [
    base:desc "Industrial communication protocol standardizing data exchange between Physical Twin components and Digital Twin systems."
    DTDFVocab:enables IndustrialDataIntegrationService
]

instance FMIStandardEngine : DTDFVocab:Enabler [
    base:desc "Functional Mock-up Interface standard enabling seamless integration of simulation models across different tools."
    DTDFVocab:enables ModelIntegrationService
]

// C6: Services
