    base:desc "Continuous collection of sensor-derived data (e.g., forces, temperatures) from the Physical Twin via time-series databases or edge computing."
    DTDFVocab:provides RealTimeDataInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Algorithm-driven reconciliation of sensor data with dynamic models to produce consistent system state estimates for the Physical Twin."
    DTDFVocab:provides StateEstimationInsight
]

instance SafetyAndPerformanceMonitoringService : DTDFVocab:Service [
    base:desc "Implementation of violation detection algorithms to flag deviations from optimal/safe operating conditions in the Physical Twin."
    DTDFVocab:provides SafetyViolationInsight
]

instance DynamicBehaviorSimulationService : DTDFVocab:Service [
    base:desc "Execution of physics-based simulations replicating the Physical Twin's behavior under current or hypothetical operating conditions."
    DTDFVocab:provides BehavioralReproductionInsight
]

instance PredictiveAnalysisService : DTDFVocab:Service [
    base:desc "Projection of future states using time-series forecasting models or physics-based simulations for proactive decision-making."
    DTDFVocab:provides PredictiveInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Parameter estimation service updating Digital Twin models with real-time data using least squares or Bayesian methods."
    DTDFVocab:provides CalibrationInsight
]

instance PerformanceOptimizationService : DTDFVocab:Service [
    base:desc "Optimization service suggesting operational adjustments (e.g., actuator settings) for efficiency or safety gains using gradient descent algorithms."
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Human-in-the-loop or automated control service providing signals to the Physical Twin based on Digital Twin-generated insights."
    DTDFVocab:provides ControlSignalAction
]

instance ClosedLoopAdaptationService : DTDFVocab:Service [
    base:desc "Real-time feedback loop service where Digital Twin outputs directly influence Physical Twin operations via control signals."
    DTDFVocab:provides AdaptiveControlAction
]

instance InteractiveDashboardService : DTDFVocab:Service [
    base:desc "Presentation of real-time and simulated data via graphical interfaces (e.g., 3D CAD overlays, time-series plots) for engineers."
    DTDFVocab:provides VisualizationInsight
]

