// Physical sensing components
instance InsideTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "Resistive temperature sensor inside the insulated styrofoam incubator, providing interior temperature readings."
    DTDFVocab:producedData InsideTempMessage1
]

instance InsideTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Resistive temperature sensor inside the insulated styrofoam incubator, complementary to InsideTemperatureSensor1."
    DTDFVocab:producedData InsideTempMessage2
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Resistive temperature sensor measuring ambient temperature outside the incubator."
    DTDFVocab:producedData AmbientTempMessage
]

// Physical-to-virtual interaction (DataTransmitted)
instance InsideTempMessage1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor1
]

instance InsideTempMessage2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor2
]

instance AmbientTempMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

// Data instances (sampled temperature data)
instance InsideTempData1 : DTDFVocab:Data [
    base:desc "Temperature sample from InsideTemperatureSensor1, transmitted via AMQP to RabbitMQ."
    DTDFVocab:fromData InsideTempMessage1
    DTDFVocab:inputTo RabbitMQBrokerEnabler, TimeSeriesDBEnabler, ModelAEnabler, ModelBEnabler, KalmanFilterEnabler, AnomalyDetectionEnabler
]

instance InsideTempData2 : DTDFVocab:Data [
    base:desc "Temperature sample from InsideTemperatureSensor2, transmitted via AMQP to RabbitMQ."
    DTDFVocab:fromData InsideTempMessage2
    DTDFVocab:inputTo RabbitMQBrokerEnabler, TimeSeriesDBEnabler, ModelAEnabler, ModelBEnabler, KalmanFilterEnabler, AnomalyDetectionEnabler
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Ambient temperature sample from AmbientTemperatureSensor, transmitted via AMQP to RabbitMQ."
    DTDFVocab:fromData AmbientTempMessage
    DTDFVocab:inputTo RabbitMQBrokerEnabler, TimeSeriesDBEnabler, ModelAEnabler, ModelBEnabler, KalmanFilterEnabler, AnomalyDetectionEnabler
]

// Enablers
instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker enabling AMQP communication between the physical sensors and the digital twin."
    DTDFVocab:enables DataIngestionService
]

instance TimeSeriesDBEnabler : DTDFVocab:Enabler [
    base:desc "Time‑series database enabler storing aggregated temperature data for visualization and historical analysis."
    DTDFVocab:enables DataStorageService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter enabler fusing ModelB predictions with dual temperature sensor data to estimate heatbed temperature."
    DTDFVocab:enables StateEstimationService
]

instance ModelAEnabler : DTDFVocab:Enabler [
    base:desc "Model A enabler executing the 2‑parameter analytical model assuming 100% electrical power conversion to air heating."
    DTDFVocab:enables ModelSimulationServiceA
]

instance ModelBEnabler : DTDFVocab:Enabler [
    base:desc "Model B enabler executing the 4‑parameter analytical model capturing heatbed thermal inertia."
    DTDFVocab:enables ModelSimulationServiceB
]

instance AnomalyDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Anomaly detection enabler using Kalman filter residuals to flag out‑of‑range temperature behavior."
    DTDFVocab:enables AnomalyDetectionService
]

instance SelfAdaptationEnabler : DTDFVocab:Enabler [
    base:desc "Self‑adaptation enabler coordinating experimentation, model recalibration, Kalman filter reconfiguration, and controller reoptimization."
    DTDFVocab:enables SelfAdaptationService
]

instance BangBangControllerEnabler : DTDFVocab:Enabler [
    base:desc "Bang‑bang controller enabler controlling heatbed and fan actuators based on LL, UL, H, and C parameters."
    DTDFVocab:enables ActuationControlService
]

instance RaspberryPiDriverEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level driver on Raspberry Pi that polls temperature sensors and publishes validated readings to RabbitMQ."
    DTDFVocab:enables DataIngestionService
]

// Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service ingesting temperature messages from RabbitMQ into the digital twin."
    DTDFVocab:provides DataAvailabilityInsight
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Service storing aggregated temperature data into the time‑series database for visualization and historical analysis."
    DTDFVocab:provides DataStoredInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service delivering real‑time temperature monitoring of the incubator’s interior."
    DTDFVocab:provides TemperatureMonitoringInsight
]

instance ModelSimulationServiceA : DTDFVocab:Service [
    base:desc "Service executing Model A to predict internal temperature assuming no heatbed inertia."
    DTDFVocab:provides ModelPredictionInsightA
]

instance ModelSimulationServiceB : DTDFVocab:Service [
    base:desc "Service executing Model B to predict internal temperature with heatbed inertia."
    DTDFVocab:provides ModelPredictionInsightB
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Service performing online calibration of Model B parameters using non‑linear least‑squares estimation."
    DTDFVocab:provides CalibrateModelAction, CalibrationStatusInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Service fusing Model B predictions with sensor data via Kalman filter to estimate the unmeasured heatbed temperature."
    DTDFVocab:provides HeatBedStateEstimationInsight, ReconfigureKalmanFilterAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Service detecting anomalies in temperature behavior based on Kalman filter residuals."
    DTDFVocab:provides AnomalyDetectionInsight, FlagAnomalousAction
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Service streaming aggregated temperature data and controller status to a time‑series database for operator dashboards."
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Service enabling what‑if co‑simulation of historical or live PT data to optimize controller parameters."
    DTDFVocab:provides WhatIfSimulationInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Service orchestrating self‑adaptation loop: experiment scheduling, recalibration, filter reconfiguration, controller reconfiguration, and optimization."
    DTDFVocab:provides SelfAdaptationInsight, ReconfigureControllerAction, OptimizeControllerAction, RetrieveRecommendationsAction
]

instance ActuationControlService : DTDFVocab:Service [
    base:desc "Service sending on/off commands to heatbed and fan actuators via RabbitMQ."
    DTDFVocab:provides ActivateHeatbedAction, ActivateFanAction
]

// Insights
instance DataAvailabilityInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful reception of temperature messages from RabbitMQ."
]

instance DataStoredInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful storage of temperature data in the time‑series database."
]

instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time visibility into current interior temperature against defined LL and UL limits."
]

instance ModelPredictionInsightA : DTDFVocab:Insight [
    base:desc "Predictive insight from Model A estimating future interior temperature assuming full power conversion."
]

instance ModelPredictionInsightB : DTDFVocab:Insight [
    base:desc "Predictive insight from Model B estimating future interior temperature accounting for heatbed inertia."
]

instance CalibrationStatusInsight : DTDFVocab:Insight [
    base:desc "Insight reflecting the current status of Model B parameter calibration."
]

instance HeatBedStateEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimate of the unmeasured heatbed temperature derived by Kalman filter fusion."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of out‑of‑range temperature behavior flagged by Kalman filter residual analysis."
]

instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of temperature trends and controller status on operator dashboards."
]

instance WhatIfSimulationInsight : DTDFVocab:Insight [
    base:desc "Outcome of co‑simulation using historical or live data for controller parameter optimization."
]

instance SelfAdaptationInsight : DTDFVocab:Insight [
    base:desc "Insight stating that self‑adaptation activities (experiment scheduling, recalibration, etc.) are underway."
]

// Actions
instance CalibrateModelAction : DTDFVocab:Action [
    base:desc "Action to recalibrate Model B parameters online using non‑linear least‑squares."
    DTDFVocab:IsAutomatic true
]

instance ReconfigureKalmanFilterAction : DTDFVocab:Action [
    base:desc "Action to reconfigure Kalman filter parameters after model recalibration."
    DTDFVocab:IsAutomatic true
]

instance ReconfigureControllerAction : DTDFVocab:Action [
    base:desc "Action to update bang‑bang controller parameters (LL, UL, H, C) during self‑adaptation."
    DTDFVocab:IsAutomatic true
]

instance OptimizeControllerAction : DTDFVocab:Action [
    base:desc "Action to re‑optimize controller settings through what‑if simulation."
    DTDFVocab:IsAutomatic true
]

instance RetrieveRecommendationsAction : DTDFVocab:Action [
    base:desc "Action to retrieve confidence‑aware recommendations from Kalman filter covariance."
    DTDFVocab:IsAutomatic true
]

instance FlagAnomalousAction : DTDFVocab:Action [
    base:desc "Action to flag anomalous temperature behavior for operator review."
    DTDFVocab:IsAutomatic false
]

instance ActivateHeatbedAction : DTDFVocab:Action [
    base:desc "Bang‑bang on/off command to the heatbed actuator."
    DTDFVocab:IsAutomatic true
]

instance ActivateFanAction : DTDFVocab:Action [
    base:desc "Bang‑bang on/off command to the fan actuator."
    DTDFVocab:IsAutomatic true
]

// Physical acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed inside the incubator controlled via on/off command sent by the bang‑bang controller."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan inside the incubator for heat distribution, controlled via on/off command."
]

instance BangBangController : DTDFVocab:ActingComponent [
    base:desc "Bang‑bang controller operating on the heatbed and fan actuators, parameterised by LL, UL, H, and C."
]

// Component definitions
instance InsulatedStyrofoamBox : DTDFVocab:Component [
    base:desc "Insulated styrofoam box forming the physical boundary of the incubator."
]

instance HeatBed : DTDFVocab:Component [
    base:desc "Heat source located inside the insulated box."
]

instance Fan : DTDFVocab:Component [
    base:desc "Mechanical fan providing mixing within the incubator."
]

instance SensorArray : DTDFVocab:Component [
    base:desc "Array of three resistive temperature sensors (two interior, one exterior)."
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 running the low‑level driver and bang‑bang controller."
]

instance CommunicationInfrastructure : DTDFVocab:Component [
    base:desc "RabbitMQ broker and AMQP communication channels between sensors, driver, and DT."
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Physical environment representing the incubator system."
    base:contains InsulatedStyrofoamBox, HeatBed, Fan, SensorArray, RaspberryPiController, CommunicationInfrastructure
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the digital twin controller running on the Raspberry Pi. The controller receives temperature measurements from RabbitMQ, executes a bang‑bang control strategy, and publishes command messages to RabbitMQ to turn the heatbed and fan on or off. Command messages are conveyed over AMQP using a simple payload that indicates actuator state (e.g., 'heatbed: ON', 'fan: OFF'). A safe protocol in the low‑level driver validates incoming commands, ensures they obey safety limits, and confirms execution by publishing status updates back to the broker. The low‑level driver then forwards the validated command to the corresponding actuator and reports execution success or failure. No authentication, encryption, or conflict resolution mechanisms beyond the safety checks are described."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin exchanges information with the physical incubator through an event‑driven message bus (RabbitMQ).  The low‑level driver on the Raspberry Pi periodically reads the two inside temperature sensors and the outside temperature sensor and publishes the readings to a RabbitMQ queue; the controller consumes these messages, drives the fan and heatbed, and publishes its control state back to the same queue.  The temporal granularity of the DT is thus defined by the polling interval of the low‑level driver and by the message round‑trip through RabbitMQ; the exact cycle time is not specified in the documents, but the system is designed to operate within a few seconds per observation cycle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is implemented on a single Raspberry Pi platform and follows a centralized CPS‑centric architecture.  Key components include: 1) the low‑level driver, which abstracts sensor/actuator I/O with a safe protocol and publishes sensor data to RabbitMQ; 2) a RabbitMQ communication server hosted on the Pi, acting as the central message broker for bi‑directional data and control flow; 3) the controller, a bang‑bang temperature regulator with parameters LL, UL, H, and C, that consumes sensor topics and publishes control commands; 4) a real‑time dashboard that subscribes to broker topics, writes telemetry to a time‑series database, and presents live visualizations; 5) an on‑demand calibration service that invokes a non‑linear least‑squares solver to tune the parameters of Model B during experimental runs; 6) a Kalman filter module that uses the calibrated Model B for anomaly detection and heat‑bed state estimation; 7) a co‑simulation module for what‑if experiments that integrates historical or live PT data with the dynamic models.  All services communicate exclusively via RabbitMQ topics, enabling modular scaling while maintaining tight coupling for rapid feedback loops and supporting the self‑adaptation loop (detection → experiment → calibration → re‑control)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The incubator Digital Twin follows a four‑phase lifecycle. 1) **Design & Model Development** – Physical and cyber subsystems are described (styrofoam box, heatbed, fan, temperaturesensors, Raspberry Pi controller) and two simulation models are built (Model A with four free parameters, Model B with two). 2) **Integration & Calibration** – The models are integrated into the DT framework (low‑level driver, RabbitMQ communication server, Kalman‑filter‑based monitor). During operation on‑demand calibration (Section 3.3) restores model parameters to the best‑fit values. 3) **Monitoring & Adaptation** – Continuous data streams from PT sensors feed the DT; monitors check safety and performance, triggering anomaly detection or controller re‑configuration. 4) **Experiment & Re‑calibration** – When a change in the plant is detected (e.g., a new bucket of water), the DT schedules experiments, gathers new data, recalibrates Model B, and re‑optimises the controller. Transition between stages is managed by the calibration loop that shifts the twin from predictive simulation to monitoring mode and back. No explicit lifecycle governance or management pattern is documented in the provided materials."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is defined by the set of assumptions underlying Model A and Model B: Assumption 1 (uniform internal temperature), Assumption 2 (negligible wall heat accumulation), Assumption 3 (constant air specific heat), and Assumption 4 (complete conversion of electrical power to air heating). Model B removes Assumption 4, adding a parameter that captures the heatbed’s thermal inertia. Calibration is performed online by estimating the free parameters via a least‑squares or similar optimisation routine whenever new data are collected. Validation and verification rely on co‑simulation between the DT and the real incubator, what‑if simulation scenarios, and Kalman‑filter‑based anomaly detection that flags deviations from expected temperature trajectories. Uncertainty quantification is implicit in the Kalman filter’s covariance; error detection is realised through monitor violations of safety bounds and drift detection. Corrective actions include re‑calibration, controller re‑configuration, and controller parameter optimisation. Quality assurance rests on periodic sensor validation, safety‑protocol enforcement by the low‑level driver, and the ability to replay historical data for model‑dataset consistency checks."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical backbone of the incubator DT comprises an AMQP‑based RabbitMQ message broker that mediates all data and control traffic between the low‑level driver, controller, and the virtual twin components. The architecture is a star topology where the Raspberry Pi (hosting the driver and controller) connects to the local network and publishes/subscribes to RabbitMQ queues. The communication relies on the AMQP protocol; no explicit bandwidth or latency requirements are specified. RabbitMQ can be configured in a clustered setup to provide redundancy and high availability, although such configuration is not shown in the documentation. The implementation does not describe additional security protocols such as TLS or access control; all messages are exchanged on the trusted local network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire Digital Twin stack is hosted on the Raspberry Pi linked to the incubator. The low‑level driver, the bang‑bang controller, the RabbitMQ server, and the digital twin services that subscribe to message feeds all run locally on the Pi (edge deployment). The system stores aggregated data and time‑series records on the Pi’s onboard storage, with the possibility to publish it to external dashboards. The deployment is managed on‑premises, aligning with the documented “on‑premises and in the cloud” capability of RabbitMQ."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the incubator in a safe operating state.  This safety‑enhancing mechanism ensures that sensor readings and actuator commands are processed only when the system is confirmed to be within safe limits, thereby preventing hazardous operating conditions.  The documents do not specify additional security or access‑control measures beyond this safe‑protocol implementation."
]