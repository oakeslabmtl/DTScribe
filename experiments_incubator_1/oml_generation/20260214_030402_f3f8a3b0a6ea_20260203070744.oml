// Acting Component
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrically heated element embedded in the insulated box that produces heat power to raise the air temperature; driven by on-board controller via power‑regulation circuit."
]

// Sensing Components
instance InternalTemperatureSensorA : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted inside the incubator box (sensor A) providing continuous temperature measurements."
    DTDFVocab:producedData InternalTemperatureDataTransmittedA
]

instance InternalTemperatureSensorB : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted inside the incubator box (sensor B) providing continuous temperature measurements."
    DTDFVocab:producedData InternalTemperatureDataTransmittedB
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted outside the incubator box to monitor ambient temperature."
    DTDFVocab:producedData ExternalTemperatureDataTransmitted
]

// DataTransmitted
instance InternalTemperatureDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensorA
]

instance InternalTemperatureDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensorB
]

instance ExternalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

// Data (processed)
instance InternalTemperatureDataA : DTDFVocab:Data [
    base:desc "Pre‑processed time‑stamped temperature series from internal sensor A, used for model calibration and monitoring."
    DTDFVocab:fromData InternalTemperatureDataTransmittedA
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

instance InternalTemperatureDataB : DTDFVocab:Data [
    base:desc "Pre‑processed time‑stamped temperature series from internal sensor B, used for model calibration and monitoring."
    DTDFVocab:fromData InternalTemperatureDataTransmittedB
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Pre‑processed time‑stamped ambient temperature series from external sensor, used for contextual information in simulation."
    DTDFVocab:fromData ExternalTemperatureDataTransmitted
    DTDFVocab:inputTo SimulationEnabler
]

// Models
instance ThermalModelTwoParam : DTDFVocab:Model [
    base:desc "Analytical thermal model predicting internal temperature using two free parameters: overall heat transfer coefficient and lumped thermal capacitance."
    DTDFVocab:inputTo SimulationEnabler, CalibrationEnabler
]

instance ThermalModelFourParam : DTDFVocab:Model [
    base:desc "Extended analytical thermal model with four free parameters, adding heat‑bed‑specific inertia to the two‑parameter model."
    DTDFVocab:inputTo SimulationEnabler, CalibrationEnabler
]

// Enablers
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Computational enabler that runs the thermal simulation models to generate temperature forecasts."
    DTDFVocab:enables PredictiveSimulationService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Algorithmic enabler that calibrates model parameters continuously using internal temperature data."
    DTDFVocab:enables CalibrationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Logical enabler that evaluates calibrated model outputs against safety and optimality thresholds."
    DTDFVocab:enables MonitoringService
]

instance ControlSupportEnabler : DTDFVocab:Enabler [
    base:desc "Decision‑making enabler that translates monitoring insights into actuation commands for the heat‑bed."
    DTDFVocab:enables ControlSupportService
]

instance CommunicationEnabler : DTDFVocab:Enabler [
    base:desc "Network enabler that exchanges state and command messages between the physical incubator and the cyber twin."
    DTDFVocab:enables CommunicationService
]

// Services
instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Provides predictive simulation of internal temperature under current operating conditions."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Continuously updates model parameters using latest temperature measurements."
    DTDFVocab:provides ModelParameterUpdateInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Checks temperature against safety limits and optimal performance thresholds."
    DTDFVocab:provides SafetyAlertInsight, PerformanceOptimizationInsight
]

instance ControlSupportService : DTDFVocab:Service [
    base:desc "Generates control actions for the heat‑bed either autonomously or by notifying the operator."
    DTDFVocab:provides AutonomousControlAction, HumanOperatorAlertAction
]

instance CommunicationService : DTDFVocab:Service [
    base:desc "Handles bidirectional communication of sensor readings, model states, and control commands."
    DTDFVocab:provides StateSyncInsight
]

// Insights
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Insight that predicts future internal temperature trajectories based on current heat input and inertia."
]

instance ModelParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that model parameters have been refined through calibration."
]

instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Insight that temperature exceeds predefined safety limits, requiring immediate mitigation."
]

instance PerformanceOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight that indicates sub‑optimal temperature regulation and suggests adjustments for efficiency."
]

instance StateSyncInsight : DTDFVocab:Insight [
    base:desc "Insight that the cyber and physical twins are synchronized regarding current state and commands."
]

// Actions
instance AutonomousControlAction : DTDFVocab:Action [
    base:desc "Automatically commands the heat‑bed actuator to adjust power to maintain target temperature."
    DTDFVocab:IsAutomatic true
]

instance HumanOperatorAlertAction : DTDFVocab:Action [
    base:desc "Notifies a human operator about safety breach or performance issue."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "When the DT’s monitoring and optimisation algorithms detect a deviation from desired thermal conditions, they generate control commands (e.g., adjust heat‑bed power or fan operation) that are sent to the physical twin to modify its behaviour, with the effect verified by subsequent sensor measurements."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "According to Document 1, the Digital Twin lifecycle starts with the creation of abstract models (e.g., CAD or dynamic differential‑equation models) during system design. After the physical twin (PT) is deployed, those models are retained and integrated with real‑time sensor data, forming the DT. During operation the DT repeatedly runs calibration algorithms that estimate the best model parameters, then feeds the updated models to monitoring components that evaluate safety and optimality. When a violation is detected, a human operator or an automated decision module may trigger a change in the PT, completing the loop. Thus the stages are: model development, integration at deployment, continuous calibration, monitoring, and corrective decision execution."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing predicted temperature trajectories against measured temperature data from the physical incubator. The study reports that the four‑parameter model reproduces the heat‑bed’s thermal inertia more accurately than the two‑parameter model, indicating higher fidelity for dynamic behaviour. Calibration algorithms are applied to update model parameters using the collected sensor data, providing a systematic validation step. Uncertainty originates from sensor noise and the simplified thermal representation; the calibration process quantifies parameter uncertainty by fitting the best‑estimate parameters. The DT also incorporates monitoring algorithms that detect violations of safety or performance thresholds, serving as an error‑detection mechanism."
]