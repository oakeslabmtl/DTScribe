// C3: Physical sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted inside the styrofoam box to monitor internal air temperature (sensor 1)."
    DTDFVocab:producedData InternalTempDataTx1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted inside the styrofoam box to monitor internal air temperature (sensor 2)."
    DTDFVocab:producedData InternalTempDataTx2
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted outside the incubator to measure ambient temperature."
    DTDFVocab:producedData ExternalTempDataTx
]

// C4: Physical-to-virtual interaction (data transmitted)
instance InternalTempDataTx1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempDataTx2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance ExternalTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// C10: Data produced from sensors
instance InternalTempData1 : DTDFVocab:Data [
    base:desc "Raw temperature reading from InternalTempSensor1 (°C)."
    DTDFVocab:fromData InternalTempDataTx1
    DTDFVocab:inputTo LowLevelDriver, CalibrationEngine, KalmanFilterEngine
]

instance InternalTempData2 : DTDFVocab:Data [
    base:desc "Raw temperature reading from InternalTempSensor2 (°C)."
    DTDFVocab:fromData InternalTempDataTx2
    DTDFVocab:inputTo LowLevelDriver, CalibrationEngine, KalmanFilterEngine
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Raw temperature reading from ExternalTempSensor (°C)."
    DTDFVocab:fromData ExternalTempDataTx
    DTDFVocab:inputTo LowLevelDriver, CalibrationEngine, KalmanFilterEngine
]

// C2: Acting components
instance ResistiveHeatBed : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed (on/off heating element) mounted inside the insulated box."
]

instance IncubatorFan : DTDFVocab:ActingComponent [
    base:desc "Small fan (on/off) mounted inside the insulated box to homogenise air temperature."
]

// C10: Models/Data
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model A based on all four modelling assumptions; two free parameters."
    DTDFVocab:inputTo CalibrationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Analytical thermal model B relaxing Assumption 4 (heat‑bed does not absorb heat); four free parameters."
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker that synchronises and forwards driver and controller messages."
    DTDFVocab:enables RealTimeVisualization, OnDemandCalibration, AnomalyDetection, WhatIfSimulation, SelfAdaptationLoop
]

instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Low‑level driver on the Raspberry Pi that reads sensors, packages measurements, and publishes them via RabbitMQ."
    DTDFVocab:enables RealTimeVisualization, OnDemandCalibration, AnomalyDetection, WhatIfSimulation, SelfAdaptationLoop
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Automated calibration algorithm that consumes temperature data to estimate free parameters of Model A and Model B."
    DTDFVocab:enables OnDemandCalibration, SelfAdaptationLoop
]

instance KalmanFilterEngine : DTDFVocab:Enabler [
    base:desc "Kalman filter implementation that fuses Model B predictions with measured temperatures for state estimation and anomaly detection."
    DTDFVocab:enables AnomalyDetection, SelfAdaptationLoop
]

instance CoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation engine that replays historical or live PT data with calibrated models for what‑if analysis."
    DTDFVocab:enables WhatIfSimulation, SelfAdaptationLoop
]

instance BangBangController : DTDFVocab:Enabler [
    base:desc "Bang‑bang controller on the Raspberry Pi with configurable lower/upper temperature limits, heating duration (H) and waiting duration (C)."
    DTDFVocab:enables SelfAdaptationLoop
]

// C6: Services
instance RealTimeVisualization : DTDFVocab:Service [
    base:desc "Real‑time dashboard that visualises sensor readings, actuator states and set‑point temperature."
    DTDFVocab:provides TemperatureSetpointInsight
]

instance OnDemandCalibration : DTDFVocab:Service [
    base:desc "Service that triggers automatic re‑estimation of model parameters whenever new temperature data are available."
    DTDFVocab:provides ModelCalibrationInsight
]

instance AnomalyDetection : DTDFVocab:Service [
    base:desc "Anomaly detection service using Kalman filter state estimation to flag deviations between predicted and measured temperatures."
    DTDFVocab:provides AnomalyDetectionInsight
]

instance WhatIfSimulation : DTDFVocab:Service [
    base:desc "What‑if simulation service that explores alternative controller settings by co‑simulating calibrated models with PT data."
    DTDFVocab:provides WhatIfSimulationInsight
]

instance SelfAdaptationLoop : DTDFVocab:Service [
    base:desc "Self‑adaptation loop that detects behavioural changes, orchestrates data‑collection experiments, re‑calibrates models, updates the Kalman filter and re‑configures the Bang‑Bang controller."
    DTDFVocab:provides AdaptiveControlInsight, ReconfigureControllerAction
]

// C17: Insights
instance TemperatureSetpointInsight : DTDFVocab:Insight [
    base:desc "Insight that supports maintaining the user‑defined temperature set‑point inside the incubator."
]

instance ModelCalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the current accuracy of the calibrated thermal model."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight that reports detected temperature anomalies and possible safety breaches."
]

instance WhatIfSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight that evaluates the impact of alternative controller parameters on temperature stability and energy consumption."
]

instance AdaptiveControlInsight : DTDFVocab:Insight [
    base:desc "Insight that recommends adaptive controller adjustments based on recent model updates and anomaly reports."
]

// C17: Action
instance ReconfigureControllerAction : DTDFVocab:Action [
    base:desc "Automatically updates Bang‑Bang controller thresholds, heating duration and waiting duration after model re‑calibration."
    DTDFVocab:IsAutomatic true
]

// C14: Environment (physical container)
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains ResistiveHeatBed, IncubatorFan, InternalTempSensor1, InternalTempSensor2, ExternalTempSensor
]

// C15: Component definition (overall digital twin)
instance IncubatorDigitalTwin : DTDFVocab:Component [
    base:desc "Digital Twin of the thermal incubator integrating sensors, actuators, models, enablers and services for real‑time monitoring, calibration, anomaly detection and self‑adaptation."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital Twin components send control commands (e.g., turn fan on/off, start heating, set heating duration H, waiting duration C, adjust lower/upper temperature limits LL/UL) as RabbitMQ messages to the controller. The controller, implemented as a bang‑bang style controller, receives these messages from the RabbitMQ server, translates them into actuator commands, and forwards them to the low‑level driver, which applies them to the physical actuators (fan and heat‑bed). The low‑level driver incorporates a safe protocol that validates commands before execution and reports the resulting control state back to RabbitMQ, providing execution confirmation and feedback to the DT."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Synchronization between the Physical Twin and Digital Twin components is realised through a RabbitMQ message broker. The low‑level driver periodically reads temperature sensors and publishes the measurements to RabbitMQ; the controller subscribes to these measurement messages and publishes command messages for the fan and heat‑bed. DT services such as the real‑time visualisation dashboard, Kalman‑filter based anomaly detector, and on‑demand calibration consume the same streams, enabling near‑real‑time operation. The documents do not provide explicit sampling rates, latency bounds, or temporal granularity, only that the driver performs periodic reads."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is orchestrated as a component‑based system where data, models and algorithms are separate services coordinated by a central RabbitMQ communication server. Sensors feed data to a low‑level driver, which forwards measurements to RabbitMQ; the controller receives the data, computes control actions and publishes its state. Calibration algorithms subscribe to the same streams to update model parameters, while monitors subscribe to detect safety or performance violations. Humans or higher‑level algorithms can trigger re‑configuration. This matches the generic CPS‑based Digital Twin pattern (Fig. 1) with a centralized message broker mediating all interactions."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The fidelity of the digital twin models is governed by four explicit modelling assumptions: (1) uniform temperature distribution inside the box, ensured by the internal fan; (2) negligible heat accumulation in the box walls; (3) constant specific heat capacity of the air; and (4) nearly all electrical power is converted to heat transferred directly to the air (Model A) – Model B relaxes assumption 4. Model validity is established experimentally by calibrating the free parameters against the sensor data; calibration experiments showed that Model B provides a more accurate prediction of the heat‑bed’s thermal inertia. Calibration algorithms update the model parameters using the collected temperature measurements, thereby maintaining consistency between the physical twin and its digital representation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All software components (low‑level driver, controller, DT modules) communicate via a centrally deployed RabbitMQ message broker. RabbitMQ provides the synchronization and message‑passing backbone; each component publishes to or subscribes from the broker. The deployment is described as lightweight and easy to install on‑premise or in the cloud, suitable for large numbers of users. The network thus consists of a Raspberry Pi hosting the controller and driver connected to the RabbitMQ server over the local network."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external components is achieved through the RabbitMQ message broker, which enables publish/subscribe exchange of sensor data and controller commands. The DT can forward these streams to a time‑series database and a dashboard for real‑time visualisation, and can supply historical or live data to co‑simulation modules for what‑if simulations, as outlined in the digital‑twinning goals. No further external systems or interoperability standards are specified."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT incorporates safety mechanisms through a low‑level driver that embeds a safe protocol to keep the physical incubator in a safe state. Communication among the controller, low‑level driver, and the DT is performed via a RabbitMQ message broker, which provides reliable, lightweight messaging deployed on‑premises or in the cloud. The documents do not describe additional cybersecurity measures such as authentication, encryption, access‑control, or threat mitigation; thus, security considerations are limited to the safe protocol in the driver and the use of RabbitMQ for dependable data exchange."
]