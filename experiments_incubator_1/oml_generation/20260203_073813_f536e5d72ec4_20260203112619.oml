{ // Return code: 1 | Stderr:
    import DTDFVocab
    instance InternalDS18S20Sensor1 : DTDFVocab:SensingComponent [
        base:desc "DS18S20 High-Precision 1-Wire Digital Thermometer sensor for internal temperature monitoring within styrofoam box",
        DTDFVocab:producedData InternalTemperatureDataTransmitted
    ]
    instance InternalDS18S20Sensor2 : DTDFVocab:SensingComponent [
        base:desc "DS18S20 High-Precision 1-Wire Digital Thermometer sensor for internal temperature monitoring within styrofoam box",
        DTDFVocab:producedData InternalTemperatureDataTransmitted
    ]
    instance ExternalDS18S20Sensor : DTDFVocab:SensingComponent [
        base:desc "DS18S20 High-Precision 1-Wire Digital Thermometer sensor for external ambient temperature monitoring",
        DTDFVocab:producedData ExternalTemperatureDataTransmitted
    ]
    instance InternalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
        base:desc "Temperature data transmitted via RabbitMQ communication server",
        DTDFVocab:producedFrom InternalDS18S20Sensor1, InternalDS18S20Sensor2
    ]
    instance ExternalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
        base:desc "Ambient temperature data transmitted via RabbitMQ communication server",
        DTDFVocab:producedFrom ExternalDS18S20Sensor
    ]
    instance SimulationInsight : DTDFVocab:Insight [
        base:desc "Simulated behavior of Physical Twin under current conditions"
    ]
    instance PredictiveInsight : DTDFVocab:Insight [
        base:desc "Forecasted behavior of Physical Twin under specified scenarios"
    ]
    instance SafetyViolationInsight : DTDFVocab:Insight [
        base:desc "Detected violation of safety criteria in system operation"
    ]
    instance OptimizationOpportunityInsight : DTDFVocab:Insight [
        base:desc "Opportunity identified for operational optimization"
    ]
    instance FaultDetectedInsight : DTDFVocab:Insight [
        base:desc "Fault detected in thermal system components"
    ]
    instance StateEstimateInsight : DTDFVocab:Insight [
        base:desc "Estimated current state of thermal system"
    ]
    instance ControlActionInsight : DTDFVocab:Insight [
        base:desc "Required control action for system regulation"
    ]
    instance OptimizationInsight : DTDFVocab:Insight [
        base:desc "Optimization recommendation for system performance"
    ]
    instance CalibrationInsight : DTDFVocab:Insight [
        base:desc "Optimal parameter estimates for model calibration"
    ]
    instance AutomatedAdjustmentAction : DTDFVocab:Action [
        base:desc "Automated adjustment of heatbed power or fan speed to maintain safety",
        DTDFVocab:IsAutomatic true
    ]
    instance HumanInterventionAction : DTDFVocab:Action [
        base:desc "Human intervention required for safety violation resolution",
        DTDFVocab:IsAutomatic false
    ]
    instance SimulationService : DTDFVocab:Service [
        base:desc "Service for replicating Physical Twin behavior via simulation",
        DTDFVocab:provides SimulationInsight
    ]
    instance PredictiveService : DTDFVocab:Service [
        base:desc "Service for forecasting Physical Twin behavior under specified scenarios",
        DTDFVocab:provides PredictiveInsight
    ]
    instance RealTimeMonitoringService : DTDFVocab:Service [
        base:desc "Service for real-time monitoring of system safety and operational optimality",
        DTDFVocab:provides SafetyViolationInsight, HumanInterventionAction
    ]
    instance FaultDetectionService : DTDFVocab:Service [
        base:desc "Service for detecting faults in the thermal system",
        DTDFVocab:provides FaultDetectedInsight
    ]
    instance StateEstimationService : DTDFVocab:Service [
        base:desc "Service for estimating current system state",
        DTDFVocab:provides StateEstimateInsight
    ]
    instance SupervisoryControlService : DTDFVocab:Service [
        base:desc "Service for generating automated control adjustments",
        DTDFVocab:provides AutomatedAdjustmentAction
    ]
    instance OptimizationService : DTDFVocab:Service [
        base:desc "Service for optimizing thermal system performance",
        DTDFVocab:provides OptimizationInsight
    ]
    instance CalibrationService : DTDFVocab:Service [
        base:desc "Service for updating model parameters with optimal estimates via calibration",
        DTDFVocab:provides CalibrationInsight
    ]
    instance SimulationEnabler : DTDFVocab:Enabler [
        base:desc "Algorithm for simulating Physical Twin behavior",
        DTDFVocab:enables SimulationService
    ]
    instance PredictiveEnabler : DTDFVocab:Enabler [
        base:desc "Algorithm for forecasting Physical Twin behavior",
        DTDFVocab:enables PredictiveService
    ]
    instance FaultDetectionEnabler : DTDFVocab:Enabler [
        base:desc "Algorithm for fault detection in thermal system",
        DTDFVocab:enables FaultDetectionService
    ]
    instance StateEstimationEnabler : DTDFVocab:Enabler [
        base:desc "Algorithm for state estimation using sensor data",
        DTDFVocab:enables StateEstimationService
    ]
    instance OptimizationEnabler : DTDFVocab:Enabler [
        base:desc "Algorithm for system optimization",
        DTDFVocab:enables OptimizationService
    ]
    instance SupervisoryControlEnabler : DTDFVocab:Enabler [
        base:desc "Supervisory control algorithm for system regulation",
        DTDFVocab:enables SupervisoryControlService
    ]
    instance CalibrationEnabler : DTDFVocab:Enabler [
        base:desc "Calibration algorithm updating model parameters with optimal estimates",
        DTDFVocab:enables CalibrationService
    ]
    instance InternalTemperatureData : DTDFVocab:Data [
        base:desc "Real-time temperature data from internal sensors processed for model input",
        DTDFVocab:fromData InternalTemperatureDataTransmitted,
        DTDFVocab:inputTo CalibrationEnabler, StateEstimationEnabler, SimulationEnabler
    ]
    instance ExternalTemperatureData : DTDFVocab:Data [
        base:desc "Real-time ambient temperature data processed for model input",
        DTDFVocab:fromData ExternalTemperatureDataTransmitted,
        DTDFVocab:inputTo CalibrationEnabler, StateEstimationEnabler, SimulationEnabler
    ]
    instance StyrofoamBoxGeometricModel : DTDFVocab:Model [
        base:desc "CAD-based geometric model representing structural attributes of styrofoam box",
        DTDFVocab:inputTo SimulationEnabler
    ]
    instance ThermalDynamicModel : DTDFVocab:Model [
        base:desc "Analytical model using differential equations for dynamic thermal behavior",
        DTDFVocab:inputTo SimulationEnabler, StateEstimationEnabler, OptimizationEnabler, PredictiveEnabler
    ]
    instance StyrofoamBox : DTDFVocab:Component [
        base:desc "Styrofoam box structure housing thermal incubator system"
    ]
    instance HeatbedActuator : DTDFVocab:ActingComponent [
        base:desc "Actuator for heating interior of styrofoam box, controlled via Raspberry Pi"
    ]
    instance FanActuator : DTDFVocab:ActingComponent [
        base:desc "Actuator for thermal distribution via fan speed control, controlled via Raspberry Pi"
    ]
    instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
        base:contains StyrofoamBox, HeatbedActuator, FanActuator, InternalDS18S20Sensor1, InternalDS18S20Sensor2, ExternalDS18S20Sensor
    ]
    instance ThermalIncubatorSystem : DTDFVocab:SystemUnderStudy [
        base:desc "Thermal incubator system",
        DTDFVocab:hasEnvironment ThermalIncubatorEnvironment
    ]
}