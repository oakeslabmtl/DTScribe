// Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Electric heating element driving the air temperature within the insulated incubator"
]
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V DC fan for air circulation, controlled via isolated MOSFET stages"
]

// Physical-to-virtual interaction – DataTransmitted (defined before sensors to avoid forward reference)
instance InsideTempDataTransmittedFront : DTDFVocab:DataTransmitted [
]
instance InsideTempDataTransmittedBack : DTDFVocab:DataTransmitted [
]
instance OutsideTempDataTransmitted : DTDFVocab:DataTransmitted [
]

// Physical sensing components
instance InsideTempSensorFront : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑wire temperature sensor monitoring the front interior of the incubator"
    DTDFVocab:producedData InsideTempDataTransmittedFront
]
instance InsideTempSensorBack : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑wire temperature sensor monitoring the rear interior of the incubator"
    DTDFVocab:producedData InsideTempDataTransmittedBack
]
instance OutsideTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑wire temperature sensor measuring ambient temperature outside the incubator"
    DTDFVocab:producedData OutsideTempDataTransmitted
]

// Insights and Actions
instance ParameterEstimatesInsight : DTDFVocab:Insight [
    base:desc "Calibrated parameter estimates (G_box, G_heater, C_air, C_heater) derived from sensor data"
]
instance ThermalInertiaDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of thermal inertia present in the incubator’s temperature response"
]
instance OperatingSetpointsRecommendationAction : DTDFVocab:Action [
    base:desc "Recommended actuator setpoints for achieving steady‑state temperature regulation"
    DTDFVocab:IsAutomatic true
]

// Services
instance SimulationModelAService : DTDFVocab:Service [
    base:desc "Simulation service running Model A to predict prospective temperature trajectories"
    DTDFVocab:provides ParameterEstimatesInsight, ThermalInertiaDetectionInsight
]
instance SimulationModelBService : DTDFVocab:Service [
    base:desc "Simulation service running Model B to refine temperature predictions"
    DTDFVocab:provides ParameterEstimatesInsight, OperatingSetpointsRecommendationAction
]
instance OnlineCalibrationService : DTDFVocab:Service [
    base:desc "Online calibration service applying SciPy least‑squares optimization to thermodynamic parameters"
    DTDFVocab:provides ParameterEstimatesInsight
]
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring and alerting service consuming RabbitMQ messages to track temperature fidelity"
    DTDFVocab:provides ThermalInertiaDetectionInsight
]
instance ParameterEstimationService : DTDFVocab:Service [
    base:desc "Service exposing calibrated model parameters back to the physical controller for setpoint adjustment"
    DTDFVocab:provides OperatingSetpointsRecommendationAction
]

// Enablers
instance EnablerPythonSimulationA : DTDFVocab:Enabler [
    base:desc "Python script executing Model A predictions and data assimilation"
    DTDFVocab:enables SimulationModelAService
]
instance EnablerPythonSimulationB : DTDFVocab:Enabler [
    base:desc "Python script executing Model B predictions and data assimilation"
    DTDFVocab:enables SimulationModelBService
]
instance EnablerScipyCalibration : DTDFVocab:Enabler [
    base:desc "SciPy nonlinear least‑squares optimizer performing online parameter calibration"
    DTDFVocab:enables OnlineCalibrationService
]
instance EnablerRabbitMQConsumer : DTDFVocab:Enabler [
    base:desc "RabbitMQ broker consumer ingesting sensor messages into the digital twin"
    DTDFVocab:enables RealTimeMonitoringService
]
instance EnablerPythonParameterEstimation : DTDFVocab:Enabler [
    base:desc "Python routine deriving calibrated parameters (G_box, G_heater, C_air, C_heater)"
    DTDFVocab:enables ParameterEstimationService
]

// Store the temperature readings – Data
instance InsideTempDataFront : DTDFVocab:Data [
    base:desc "Temperature value recorded from the front interior DS18S20 sensor"
    DTDFVocab:fromData InsideTempDataTransmittedFront
    DTDFVocab:inputTo EnablerPythonSimulationA, EnablerPythonSimulationB, EnablerScipyCalibration
]
instance InsideTempDataBack : DTDFVocab:Data [
    base:desc "Temperature value recorded from the rear interior DS18S20 sensor"
    DTDFVocab:fromData InsideTempDataTransmittedBack
    DTDFVocab:inputTo EnablerPythonSimulationA, EnablerPythonSimulationB, EnablerScipyCalibration
]
instance OutsideTempData : DTDFVocab:Data [
    base:desc "Ambient temperature value recorded from the external DS18S20 sensor"
    DTDFVocab:fromData OutsideTempDataTransmitted
    DTDFVocab:inputTo EnablerPythonSimulationA, EnablerPythonSimulationB, EnablerScipyCalibration
]

// Empirical operational data
instance FanPowerLogs : DTDFVocab:Data [
    base:desc "Historical fan power consumption logs captured from the 12/24 V DC fan"
    DTDFVocab:inputTo EnablerPythonSimulationA, EnablerPythonSimulationB
]
instance HeaterVoltageLogs : DTDFVocab:Data [
    base:desc "Voltage measurements of the heatbed current path during operation"
    DTDFVocab:inputTo EnablerPythonSimulationA, EnablerPythonSimulationB
]

// Dynamic thermal models
instance ModelA : DTDFVocab:Model [
    base:desc "Single‑parameter thermal model (G_box, C_air) for the incubator’s temperature dynamics"
    DTDFVocab:inputTo EnablerPythonSimulationA
]
instance ModelB : DTDFVocab:Model [
    base:desc "Four‑parameter thermal model (G_box, G_heater, C_air, C_heater) capturing heatbed influence"
    DTDFVocab:inputTo EnablerPythonSimulationB
]

// Physical components
instance ComponentHeatbedActuator : DTDFVocab:Component [
    base:desc "Heatbed electrical heating element controlled via isolated MOSFET staging"
]
instance ComponentFanActuator : DTDFVocab:Component [
    base:desc "12 V/24 V DC fan driven by MOSFET and optocoupler isolation"
]
instance ComponentInsideTempSensorFront : DTDFVocab:Component [
    base:desc "DS18S20 temperature sensor at the front interior location"
]
instance ComponentInsideTempSensorBack : DTDFVocab:Component [
    base:desc "DS18S20 temperature sensor at the rear interior location"
]
instance ComponentOutsideTempSensor : DTDFVocab:Component [
    base:desc "DS18S20 temperature sensor measuring external ambient temperature"
]
instance ComponentRaspberryPi : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B acting as the primary controller"
]
instance ComponentCustomPCB : DTDFVocab:Component [
    base:desc "Custom PCB housing MOSFET stages and optocouplers for actuator isolation"
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains ComponentHeatbedActuator, ComponentFanActuator, ComponentInsideTempSensorFront, ComponentInsideTempSensorBack, ComponentOutsideTempSensor, ComponentRaspberryPi, ComponentCustomPCB
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin publishes control commands (heatbed ON/OFF, fan ON/OFF, target temperature) to RabbitMQ queues that the Raspberry Pi controller subscribes to; the controller translates these into GPIO signals driving MOSFETs and the fan actuator."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near‑real‑time exchange: sensor samples and control commands are published to RabbitMQ every few seconds (fan state persistence and heatbed actuation cycles) with the Digital Twin’s simulation step sized to match the physical sampling period."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Component layout: Low‑level driver (sensor/actuator abstraction), Controller (bang‑bang control with LL, UL, H, C parameters), RabbitMQ communication server, Custom PCB linking PI to electronics, and the Digital Twin backend that subscribes to/produces messages, runs simulations and calibration."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design/Modeling → Fabrication/Implementation (open‑source hardware and software released on GitHub) → Operation/Monitoring during runtime, with the Digital Twin continuously calibrating and validating the physical system across these phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model assumptions (uniform temperature, negligible wall heat accumulation, constant specific heat, negligible fan heating) are explicitly listed; validation performed with uniform temperature experiments (Fig. 10, 11, 12) and residual error minimization via least‑squares; uncertainties due to assumptions acknowledged; no formal model verification tools reported."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "RabbitMQ (AMQP) running locally on the Raspberry Pi over IP (likely Wi‑Fi/Bluetooth) connects DT backend to the controller; communication uses per‑message queues for sensor data and control commands."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Both the control logic and the Digital Twin run on the same Raspberry Pi, i.e., an edge deployment with local storage and computation; the source code is open‑source and can be deployed on other edge devices or in the cloud."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safe protocol incorporated in the low‑level driver to keep the device in a safe state; control commands are strictly validated before GPIO output; the system uses the Raspberry Pi’s built‑in Wi‑Fi/Bluetooth with default security but no advanced cyber‑security measures are reported."
]