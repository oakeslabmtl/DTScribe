// ---------------------------
// Physical Sensing Components
// ---------------------------

instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor placed inside the insulated incubator box (internal sensor 1)."
    DTDFVocab:producedData InternalTempDataTransmitted1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor placed inside the insulated incubator box (internal sensor 2)."
    DTDFVocab:producedData InternalTempDataTransmitted2
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor positioned outside the incubator to provide ambient reference."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// ---------------------------
// Data Transmitted from Sensors
// ---------------------------

instance InternalTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// ---------------------------
// Raw Data Objects
// ---------------------------

instance InternalTempData1 : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from internal sensor 1 (resolution ±0.5 °C)."
    DTDFVocab:fromData InternalTempDataTransmitted1
    DTDFVocab:inputTo CalibrationEnabler, PredictionEnabler, MonitoringEnabler
]

instance InternalTempData2 : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from internal sensor 2 (resolution ±0.5 °C)."
    DTDFVocab:fromData InternalTempDataTransmitted2
    DTDFVocab:inputTo CalibrationEnabler, PredictionEnabler, MonitoringEnabler
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Timestamped ambient temperature reading from external sensor (resolution ±0.5 °C)."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, PredictionEnabler, MonitoringEnabler
]

// ---------------------------
// Digital Twin Models
// ---------------------------

instance SimpleIncubatorModel : DTDFVocab:Model [
    base:desc "Analytical temperature dynamics model with two free parameters (gain and time constant)."
    DTDFVocab:inputTo CalibrationEnabler, PredictionEnabler
]

instance DetailedIncubatorModel : DTDFVocab:Model [
    base:desc "Enhanced temperature dynamics model with four free parameters capturing thermal inertia of the heat‑bed."
    DTDFVocab:inputTo CalibrationEnabler, PredictionEnabler
]

// ---------------------------
// Enablers (Algorithms / Tools)
// ---------------------------

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that adjusts the parameters of SimpleIncubatorModel and DetailedIncubatorModel using the latest sensor data."
    DTDFVocab:enables CalibrationService
]

instance PredictionEnabler : DTDFVocab:Enabler [
    base:desc "Simulation/optimization engine that predicts future temperature states based on calibrated models."
    DTDFVocab:enables SimulationPredictionService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring algorithm that evaluates safety (temperature limits) and optimality, generating alerts on violations."
    DTDFVocab:enables MonitoringService
]

instance ControlEnabler : DTDFVocab:Enabler [
    base:desc "Control module that computes bang‑bang commands for the heat‑bed and fan and publishes them via RabbitMQ."
    DTDFVocab:enables ControlAdjustmentService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Visualization tool that renders temperature trends and model predictions for operators."
    DTDFVocab:enables VisualizationService
]

instance ReconfigurationEnabler : DTDFVocab:Enabler [
    base:desc "Reconfiguration component that adapts model structure or control thresholds when the environment or workload changes."
    DTDFVocab:enables ReconfigurationService
]

// ---------------------------
// Services Offered by the Digital Twin
// ---------------------------

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that continuously calibrates the incubator models using incoming sensor data."
    DTDFVocab:provides CalibrationInsight
]

instance SimulationPredictionService : DTDFVocab:Service [
    base:desc "Service that runs predictive simulations of temperature dynamics under current operating conditions."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors the incubator for safety violations and sub‑optimal operation."
    DTDFVocab:provides SafetyAlertInsight
]

instance ControlAdjustmentService : DTDFVocab:Service [
    base:desc "Service that issues control adjustments (turn‑on/turn‑off commands) to the heat‑bed and fan based on model insights."
    DTDFVocab:provides ControlAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that visualizes real‑time temperature trends and forecasted trajectories."
    DTDFVocab:provides VisualizationInsight
]

instance ReconfigurationService : DTDFVocab:Service [
    base:desc "Service that reconfigures model parameters or control thresholds in response to environmental changes."
    DTDFVocab:provides ReconfigurationInsight
]

// ---------------------------
// Insights and Actions Produced by Services
// ---------------------------

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that model parameters have been successfully updated to reflect current plant behavior."
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Insight providing forecasted temperature values for the next prediction horizon."
]

instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Insight triggered when temperature exceeds the upper safety limit or falls below the lower safety limit."
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Automatic command to turn the heat‑bed on/off or adjust fan speed based on control law."
    DTDFVocab:IsAutomatic true
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight delivering a visual representation of temperature trends and model predictions."
]

instance ReconfigurationInsight : DTDFVocab:Insight [
    base:desc "Insight confirming that the digital twin has adapted its configuration to new operating conditions."
]

// ---------------------------
// Physical Acting Components (for completeness)
// ---------------------------

instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed element that generates heat inside the incubator."
]

instance AirCirculationFan : DTDFVocab:ActingComponent [
    base:desc "Small fan that circulates air within the insulated incubator box."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "When the digital twin’s monitors detect safety or performance violations, it can trigger human operators or automated algorithms to issue corrective actions to the physical twin; the documents do not specify concrete command formats, validation, or acknowledgement mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is realized as a set of co‑located software components on the Raspberry Pi that hosts the physical incubator. A RabbitMQ server acts as the communication middleware (Communication Server) mediating messages between a low‑level driver that directly controls the heatbed and fan hardware and a high‑level controller that implements the temperature regulation logic. The DT component subscribes to the same RabbitMQ topics, receives sensor readings (two internal and one external temperature values), observes actuator commands, and updates its thermal models using calibration algorithms. It can also generate simulated actions that are sent back through the same message bus. This architecture follows a centralized, component‑based constellation where all twin services (data acquisition, model updating, simulation, and decision support) are integrated via the message broker on a single physical node."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed by comparing the predicted temperature trajectories against measured data from the incubator. Experimental results indicated that the four‑parameter model provides higher fidelity in capturing the heatbed’s thermal inertia than the simpler two‑parameter model. Validation is performed through empirical experiments, and calibration algorithms update the model parameters to minimise prediction error. Uncertainty arises from parameter estimation and sensor noise; the DT uses continuous monitoring to detect deviations and apply corrective updates, ensuring ongoing model validity."
]