// ===========================
//  C3: Physical sensing components
// ===========================

instance TemperatureSensorTop : DTDFVocab:SensingComponent [
    base:desc "Maxim Integrated DS18S20 digital temperature sensor placed at the top vertical position inside the incubator; measures -55 °C to +125 °C with ±0.5 °C accuracy and 0.5 °C resolution"
    DTDFVocab:producedData IncubatorTempDataTransmission
]

instance TemperatureSensorMiddle : DTDFVocab:SensingComponent [
    base:desc "Maxim Integrated DS18S20 digital temperature sensor placed at the middle vertical position inside the incubator; measures -55 °C to +125 °C with ±0.5 °C accuracy and 0.5 °C resolution"
    DTDFVocab:producedData IncubatorTempDataTransmission
]

instance TemperatureSensorBottom : DTDFVocab:SensingComponent [
    base:desc "Maxim Integrated DS18S20 digital temperature sensor placed at the bottom vertical position inside the incubator; measures -55 °C to +125 °C with ±0.5 °C accuracy and 0.5 °C resolution"
    DTDFVocab:producedData IncubatorTempDataTransmission
]

// ===========================
//  C4: Physical‑to‑virtual interaction (DataTransmitted)
// ===========================

instance IncubatorTempDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorTop, TemperatureSensorMiddle, TemperatureSensorBottom
]

// ===========================
//  C10: Data
// ===========================

instance IncubatorTemperatureData : DTDFVocab:Data [
    base:desc "Timestamped temperature measurements collected from the three DS18S20 sensors"
    DTDFVocab:fromData IncubatorTempDataTransmission
    DTDFVocab:inputTo CalibrationEnabler,
                MonitoringEnabler,
                SimulationEnabler,
                OptimisationEnabler,
                VisualizationEnabler,
                ReconfigurationEnabler
]

// ===========================
//  C10: Models
// ===========================

instance TwoParameterThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model of the incubator with two free parameters representing overall heat transfer"
    DTDFVocab:inputTo SimulationEnabler,
                MonitoringEnabler,
                OptimisationEnabler
]

instance FourParameterThermalModel : DTDFVocab:Model [
    base:desc "Detailed analytical thermal model capturing heat‑bed inertia using four free parameters"
    DTDFVocab:inputTo SimulationEnabler,
                MonitoringEnabler,
                OptimisationEnabler
]

// ===========================
//  C11: Enablers
// ===========================

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithms estimate the free parameters of both thermal models using the temperature data"
    DTDFVocab:enables ParameterOptimisationService,
                PredictionService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring algorithms evaluate safety and optimality constraints on model predictions and raise violations"
    DTDFVocab:enables SafetyOptimalityCheckService,
                RealTimeMonitoringService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine runs calibrated thermal models to predict internal temperature under current operating conditions"
    DTDFVocab:enables PredictionService
]

instance OptimisationEnabler : DTDFVocab:Enabler [
    base:desc "Optimisation routines adjust system parameters via calibration, keeping physical and cyber models synchronised"
    DTDFVocab:enables ParameterOptimisationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard visualisation modules render sensor data, model outputs and predictions for engineers and operators"
    DTDFVocab:enables DashboardVisualizationService
]

instance ReconfigurationEnabler : DTDFVocab:Enabler [
    base:desc "Reconfiguration mechanism adapts models when environment or operating conditions change, improving robustness"
    DTDFVocab:enables ReconfigurationSupportService
]

// ===========================
//  C6: Services
// ===========================

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of the temperature sensor streams"
    DTDFVocab:provides PredictiveInsight
]

instance SafetyOptimalityCheckService : DTDFVocab:Service [
    base:desc "Performs safety and optimality checks and raises violations"
    DTDFVocab:provides SafetyInsight,
                AlertAction
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Executes simulation‑based prediction of the incubator’s thermal behaviour under current operating conditions"
    DTDFVocab:provides PredictiveInsight
]

instance ParameterOptimisationService : DTDFVocab:Service [
    base:desc "Optimises system parameters via calibration algorithms that update the physical and cyber models"
    DTDFVocab:provides PerformanceInsight,
                CorrectiveAction
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Advanced visualisation dashboards for engineers/operators to inspect sensor data, model outputs and prediction results"
    DTDFVocab:provides PredictiveInsight
]

instance ReconfigurationSupportService : DTDFVocab:Service [
    base:desc "Supports reconfigurability of models to adapt to changing environment or operating conditions"
    DTDFVocab:provides ReconfigurationInsight,
                ReconfigureModelAction
]

// ===========================
//  C17: Insights
// ===========================

instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Anticipated temperature evolution generated by the calibrated simulation models"
]

instance SafetyInsight : DTDFVocab:Insight [
    base:desc "Detection of out‑of‑range or fault conditions indicating a safety violation"
]

instance PerformanceInsight : DTDFVocab:Insight [
    base:desc "Deviation from optimal operating points identified by the optimisation routine"
]

instance ReconfigurationInsight : DTDFVocab:Insight [
    base:desc "Recommendation to adjust model parameters because of detected environmental changes"
]

// ===========================
//  C17: Actions
// ===========================

instance AlertAction : DTDFVocab:Action [
    base:desc "Raises an alert when a constraint violation is detected"
    DTDFVocab:IsAutomatic true
]

instance CorrectiveAction : DTDFVocab:Action [
    base:desc "Suggests or triggers a corrective actuator command (e.g., heater set‑point or fan speed adjustment)"
    DTDFVocab:IsAutomatic false
]

instance ReconfigureModelAction : DTDFVocab:Action [
    base:desc "Updates model parameters to reflect new operating conditions"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Algorithms within the Digital Twin generate control actions when monitors detect violations; these actions may be executed by humans or automated components to modify the physical twin’s operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin follows a CPS‑centric orchestration pattern where sensor data from the Physical Twin are continuously streamed into the cyber side. Calibration algorithms consume this data to update the parameters of physics‑based models of the system and its environment. Updated model outputs are fed to monitoring components that assess safety and performance criteria. If a violation is detected, a decision layer—potentially involving human operators or automated supervisory controllers—triggers corrective actions that may be sent back to the Physical Twin. Thus the architecture integrates data acquisition, model calibration, monitoring, and decision/actuation loops within a unified framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity was assessed experimentally by comparing predicted temperature trajectories against measured values. The four‑parameter model demonstrated superior accuracy in reproducing the heatbed’s thermal inertia and was therefore selected for further DT development. Calibration algorithms are used to update model parameters based on incoming sensor data, providing a basic validation loop. Explicit uncertainty quantification, error detection mechanisms, or broader quality‑assurance processes are not described in the documents."
]