import DTDFVocab

// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed (electrical heating element) switched via MOSFET driver on the custom PCB under command from the Raspberry Pi controller"
]

instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal fan for air circulation switched via MOSFET driver on the custom PCB under command from the Raspberry Pi controller"
]

// C3: Physical sensing components
instance IncubatorAirTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring air temperature inside the incubator (range –55 °C to +125 °C, 0.5 °C accuracy)",
    DTDFVocab:producedData TemperatureMessageIncubator1
]

instance IncubatorAirTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring air temperature inside the incubator (range –55 °C to +125 °C, 0.5 °C accuracy)",
    DTDFVocab:producedData TemperatureMessageIncubator2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring ambient room temperature (range –55 °C to +125 °C, 0.5 °C accuracy)",
    DTDFVocab:producedData TemperatureMessageAmbient
]

// C4: Physical‑to‑virtual interaction (Data transmitted)
instance TemperatureMessageIncubator1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorAirTempSensor1
]

instance TemperatureMessageIncubator2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorAirTempSensor2
]

instance TemperatureMessageAmbient : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// C5: Data (real‑time & historical)
instance TemperatureDataIncubator1 : DTDFVocab:Data [
    base:desc "Real‑time temperature value read from IncubatorAirTempSensor1",
    DTDFVocab:fromData TemperatureMessageIncubator1,
    DTDFVocab:inputTo PredictionEngine
]

instance TemperatureDataIncubator2 : DTDFVocab:Data [
    base:desc "Real‑time temperature value read from IncubatorAirTempSensor2",
    DTDFVocab:fromData TemperatureMessageIncubator2,
    DTDFVocab:inputTo PredictionEngine
]

instance TemperatureDataAmbient : DTDFVocab:Data [
    base:desc "Real‑time temperature value read from AmbientTempSensor",
    DTDFVocab:fromData TemperatureMessageAmbient,
    DTDFVocab:inputTo PredictionEngine
]

instance HistoricalTemperatureDataIncubator : DTDFVocab:Data [
    base:desc "Historical temperature trajectory stored in the DT for calibration and model validation",
    DTDFVocab:inputTo SciPyOptimiser, PredictionEngine
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Model A – single‑parameter air‑heat model for temperature prediction",
    DTDFVocab:inputTo PredictionEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Model B – four‑parameter model including heat‑bed thermal mass for temperature prediction",
    DTDFVocab:inputTo PredictionEngine
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ (AMQP) broker on the Raspberry Pi used for publishing sensor messages and DT subscription",
    DTDFVocab:enables RealTimeMonitoringService, SafetyViolationDetectionService, TemperaturePredictionService, ParameterCalibrationService, HeatingFanControlOptimizationService
]

instance SciPyOptimiser : DTDFVocab:Enabler [
    base:desc "Python SciPy non‑linear least‑squares optimizer used for calibrating model parameters",
    DTDFVocab:enables ParameterCalibrationService
]

instance PredictionEngine : DTDFVocab:Enabler [
    base:desc "Python simulation engine that executes ThermalModelA and ThermalModelB for temperature prediction",
    DTDFVocab:enables TemperaturePredictionService, RealTimeMonitoringService, SafetyViolationDetectionService
]

instance ControlLogicEngine : DTDFVocab:Enabler [
    base:desc "Control‑logic module that computes optimal heating‑bed and fan duty cycles",
    DTDFVocab:enables HeatingFanControlOptimizationService
]

// C6: Services
instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Provides temperature prediction simulations using Model A or Model B",
    DTDFVocab:provides TemperaturePredictionInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates model parameters using non‑linear least‑squares optimisation (SciPy)",
    DTDFVocab:provides CalibrationInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Monitors real‑time temperature limits and publishes alerts",
    DTDFVocab:provides MonitoringInsight
]

instance SafetyViolationDetectionService : DTDFVocab:Service [
    base:desc "Detects safety violations when temperature exceeds defined thresholds",
    DTDFVocab:provides SafetyViolationInsight
]

instance HeatingFanControlOptimizationService : DTDFVocab:Service [
    base:desc "Optimises heating‑bed and fan control logic for stable incubation temperature",
    DTDFVocab:provides ControlOptimizationAction
]

// C17: Insights / Actions
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory generated by the selected thermal model"
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Calibrated model parameters resulting from the optimisation process"
]

instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Current temperature readings indicating compliance with operational limits"
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Alert indicating temperature breach beyond safety thresholds"
]

instance ControlOptimizationAction : DTDFVocab:Action [
    base:desc "Adjust heating‑bed power and fan speed to achieve optimal temperature regulation",
    DTDFVocab:IsAutomatic true
]

// C18: Environment and Physical Components
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedComponent, InternalFanComponent, CustomPCBComponent, RaspberryPiController, PowerSupplyComponent
]

instance HeatBedComponent : DTDFVocab:Component [
    base:desc "Electrical heating element (heat‑bed) driven by MOSFET driver"
]

instance InternalFanComponent : DTDFVocab:Component [
    base:desc "Brushless DC fan for internal air circulation, driven by MOSFET driver"
]

instance CustomPCBComponent : DTDFVocab:Component [
    base:desc "Custom PCB hosting MOSFET drivers and optocouplers for switching heat‑bed and fan"
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running low‑level driver, message broker and DT software"
]

instance PowerSupplyComponent : DTDFVocab:Component [
    base:desc "External power supply providing the required voltage and current for the incubator electronics"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (heat‑bed ON/OFF, fan ON/OFF, setpoint adjustments) to the RabbitMQ server; the Raspberry Pi controller subscribes, interprets the commands and drives the MOSFETs to actuate the heat‑bed and fan accordingly."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture comprises the Physical Twin (incubator hardware), a Raspberry Pi controller, a low‑level driver, a RabbitMQ communication server, and DT modules (models, calibrators, monitors) that subscribe to and publish on the message bus, forming a closed feedback loop between PT and virtual components."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is based on four assumptions (uniform temperature, negligible wall heat storage, constant air specific heat, negligible fan heat). Validation is performed through uniform‑temperature experiments (sensor comparison) and calibration experiments where model parameters are adjusted to minimise residual error between simulated and measured temperature trajectories."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses RabbitMQ on the Raspberry Pi, employing the AMQP protocol over the local network; messages contain sensor readings and control commands."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT components and the RabbitMQ broker are hosted directly on the Raspberry Pi 4 Model B, providing on‑device deployment without external cloud services."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the hardware in a safe state; the DT includes monitors that check temperature limits and can trigger safety actions when violations are detected."
]