// --------------------------------------------------
// Acting Components
// --------------------------------------------------
instance HeatBedResistiveActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that generates heat for reaching the target incubator temperature, driven by Raspberry Pi GPIO pins."
]

instance AirCirculationFanActuator : DTDFVocab:ActingComponent [
    base:desc "Small fan that circulates air inside the styrofoam enclosure, driven by Raspberry Pi GPIO pins."
]

// --------------------------------------------------
// Physical Sensing Components
// --------------------------------------------------
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "First internal temperature sensor placed inside the incubator, provides scalar temperature measurements."
    DTDFVocab:producedData InternalTempDataTransmittedA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Second internal temperature sensor placed inside the incubator, provides scalar temperature measurements."
    DTDFVocab:producedData InternalTempDataTransmittedB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor placed outside the incubator, provides scalar temperature measurements."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// --------------------------------------------------
// Data Transmitted (from Sensors)
// --------------------------------------------------
instance InternalTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// --------------------------------------------------
// Data (received from DataTransmitted)
// --------------------------------------------------
instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from InternalTempSensorA."
    DTDFVocab:fromData InternalTempDataTransmittedA
    DTDFVocab:inputTo IncubatorAnalyticsEnabler
]

instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from InternalTempSensorB."
    DTDFVocab:fromData InternalTempDataTransmittedB
    DTDFVocab:inputTo IncubatorAnalyticsEnabler
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from ExternalTempSensor."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo IncubatorAnalyticsEnabler
]

// --------------------------------------------------
// Models (thermal dynamics)
// --------------------------------------------------
instance ThermalModelTwoParams : DTDFVocab:Model [
    base:desc "Analytical thermal model with two free parameters used to predict internal incubator temperature."
    DTDFVocab:inputTo IncubatorAnalyticsEnabler
]

instance ThermalModelFourParams : DTDFVocab:Model [
    base:desc "Analytical thermal model with four free parameters (captures heat‑bed inertia) used to predict internal incubator temperature."
    DTDFVocab:inputTo IncubatorAnalyticsEnabler
]

// --------------------------------------------------
// Enabler (processes data and runs models)
// --------------------------------------------------
instance IncubatorAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Software stack (Raspberry Pi drivers, RabbitMQ broker, calibration and optimisation algorithms) that consumes sensor data, runs thermal models and provides higher‑level services."
    DTDFVocab:enables TemperaturePredictionService,
                      ModelCalibrationService,
                      TemperatureMonitoringService,
                      SafetyCheckingService,
                      HeatingOptimizationService
]

// --------------------------------------------------
// Services
// --------------------------------------------------
instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Simulation‑based prediction of internal incubator temperature using the analytical thermal models."
    DTDFVocab:provides FutureTemperatureInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Online calibration (parameter estimation) of the thermal models using incoming temperature data."
    DTDFVocab:provides ParameterEstimationInsight
]

instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of internal and external temperature streams."
    DTDFVocab:provides TemperatureTrendInsight
]

instance SafetyCheckingService : DTDFVocab:Service [
    base:desc "Safety checking that detects temperature violations against configured limits."
    DTDFVocab:provides TemperatureViolationInsight,
                      ShutdownHeatingAction
]

instance HeatingOptimizationService : DTDFVocab:Service [
    base:desc "Optimisation of the heating controller to keep temperature at the target set‑point."
    DTDFVocab:provides OptimizationRecommendationInsight,
                      AdjustHeatingSetpointAction
]

// --------------------------------------------------
// Insights
// --------------------------------------------------
instance FutureTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted future internal temperature derived from the thermal models."
]

instance ParameterEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated model parameters resulting from the calibration algorithm."
]

instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Detected temperature trend (e.g., rising, falling, stable) from continuous monitoring."
]

instance TemperatureViolationInsight : DTDFVocab:Insight [
    base:desc "Detected violation where temperature exceeds safety thresholds."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation to adjust heating set‑point for improved temperature regulation."
]

// --------------------------------------------------
// Actions
// --------------------------------------------------
instance ShutdownHeatingAction : DTDFVocab:Action [
    base:desc "Automatic shutdown of the heat‑bed actuator when a temperature violation is detected."
    DTDFVocab:IsAutomatic true
]

instance AdjustHeatingSetpointAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of the heat‑bed power set‑point based on optimisation recommendation."
    DTDFVocab:IsAutomatic true
]

// --------------------------------------------------
// Environment (Physical Twin)
// --------------------------------------------------
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedResistiveActuator,
                  AirCirculationFanActuator,
                  InternalTempSensorA,
                  InternalTempSensorB,
                  ExternalTempSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the digital twin are sent as AMQP messages through the RabbitMQ server to the controller running on the Raspberry Pi. The controller interprets commands (e.g., turn fan on/off, activate heat‑bed for a specified heating duration, wait for a waiting duration) and forwards actuator states to the low‑level driver, which then issues the actual signals to the physical devices. The low‑level driver includes a safety protocol that validates incoming commands before execution and acknowledges successful actuation back to the controller via RabbitMQ, providing feedback for closed‑loop operation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The incubator DT processes data in (near) real‑time: sensor readings and controller/driver messages are continuously streamed to a time‑series database, visualised on a dashboard, and used immediately by on‑demand calibration, Kalman‑filter anomaly detection and co‑simulation modules; the loop operates at the sampling rate of the temperature sensors (implicit) to keep the digital and physical twins synchronised."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized orchestration is employed: the physical twin feeds raw data to a central DT that hosts a time‑series store, a calibration engine, a Kalman‑filter based state estimator, and a co‑simulation component. These services interact internally to support real‑time visualisation, on‑demand model calibration, anomaly detection, what‑if simulations and the self‑adaptation loop."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The documents outline a three‑phase lifecycle: (1) Development – creation of abstract models of the system (e.g., CAD geometry, dynamic differential‑equation model); (2) Deployment – integration of these models with sensor data into the Digital Twin, where calibration algorithms update model parameters with the best estimates; (3) Operation – continuous acquisition of sensor data, execution of monitoring algorithms that assess safety and optimality, and possible human or automated interventions that may trigger updates to the physical twin or to the twin’s models."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing simulated temperature trajectories against measured data. Experiments showed that the four‑parameter model more accurately reproduces the thermal inertia of the heat‑bed than the simpler two‑parameter model, indicating higher validity for control tasks. Calibration algorithms continuously adjust model parameters to reduce prediction error, thereby addressing uncertainties arising from sensor noise and unmodelled environmental effects. No formal verification or quantitative uncertainty bounds are described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin and physical twin communicate over a central RabbitMQ message broker using the AMQP protocol. All components (controller, low‑level driver, DT analytics modules) connect as clients to this broker, forming a star‑topology network. RabbitMQ can be deployed on‑premise or in the cloud, offering lightweight, mature messaging with support for tens of thousands of concurrent users. Reliability is provided by RabbitMQ’s built‑in message durability and acknowledgment mechanisms; however, specific redundancy or bandwidth/latency specifications are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ server that underpins the digital‑twin communication can be hosted either on‑premise or in a cloud environment. The controller and low‑level driver run on a Raspberry Pi, providing the computational platform for real‑time control. DT analytics and model calibration components may run on any machine that can connect to the RabbitMQ broker, scaling with RabbitMQ’s ability to handle many clients. Storage requirements are not specified, but the architecture supports scalability via RabbitMQ’s clustering capabilities. Availability is ensured by RabbitMQ’s mature implementation, though explicit redundancy or SLA details are not provided."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin incorporates safety monitoring algorithms that continuously evaluate sensor data against predefined safety criteria; monitors assess whether the system is performing safely and optimally, and upon detection of a violation they can alert humans or trigger corrective actions on the physical twin. The documents do not detail any cybersecurity protocols, access control mechanisms, authentication systems, threat mitigation strategies, fail‑safe mechanisms, or risk assessment approaches."
]