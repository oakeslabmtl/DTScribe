// -------------------------------
// Physical sensing components
// -------------------------------
instance InsideBoxTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer placed inside the insulated incubator box (‑55 °C to +125 °C, 0.5 °C accuracy)"
    DTDFVocab:producedData InsideBoxTempMessage1
]

instance InsideBoxTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 1‑Wire digital thermometer placed inside the insulated incubator box (‑55 °C to +125 °C, 0.5 °C accuracy)"
    DTDFVocab:producedData InsideBoxTempMessage2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer used to measure ambient temperature outside the incubator"
    DTDFVocab:producedData AmbientTempMessage
]

// -------------------------------
// Physical‑to‑virtual data transmission
// -------------------------------
instance InsideBoxTempMessage1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideBoxTempSensor1
]

instance InsideBoxTempMessage2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideBoxTempSensor2
]

instance AmbientTempMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// -------------------------------
// Virtual data objects (time‑stamped temperature streams)
// -------------------------------
instance InsideBoxTempData1 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature stream from InsideBoxTempSensor1, published via RabbitMQ"
    DTDFVocab:fromData InsideBoxTempMessage1
    DTDFVocab:inputTo RabbitMQBroker
]

instance InsideBoxTempData2 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature stream from InsideBoxTempSensor2, published via RabbitMQ"
    DTDFVocab:fromData InsideBoxTempMessage2
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Time‑stamped ambient temperature stream, published via RabbitMQ"
    DTDFVocab:fromData AmbientTempMessage
    DTDFVocab:inputTo RabbitMQBroker
]

// -------------------------------
// Enablers (software / infrastructure)
// -------------------------------
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on the Raspberry Pi, receives sensor messages and forwards them to DT services"
    DTDFVocab:enables TemperatureSimulationService,
                     ParameterCalibrationService,
                     RealTimeMonitoringService,
                     FaultDetectionService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Python simulation engine that runs Model A and Model B to predict box temperature"
    DTDFVocab:enables TemperatureSimulationService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "SciPy non‑linear least‑squares optimiser used to calibrate model parameters from experimental temperature data"
    DTDFVocab:enables ParameterCalibrationService
]

instance MonitoringEngine : DTDFVocab:Enabler [
    base:desc "Real‑time monitoring component that checks live temperature streams against safety limits"
    DTDFVocab:enables RealTimeMonitoringService
]

instance FaultDetectionEngine : DTDFVocab:Enabler [
    base:desc "Fault detection component that raises alerts when temperature exceeds defined upper/lower thresholds"
    DTDFVocab:enables FaultDetectionService
]

// -------------------------------
// Models (physics‑based)
// -------------------------------
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single energy‑balance model with lumped heat capacity C_air and conductance G_box"
    DTDFVocab:inputTo SimulationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Extended model adding heat‑bed dynamics (C_heater, G_heater) to the box conductance G_box"
    DTDFVocab:inputTo SimulationEngine
]

// -------------------------------
// Services offered by the Digital Twin
// -------------------------------
instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Runs Model A or Model B to generate predicted temperature streams for the incubator"
    DTDFVocab:provides PredictedTemperatureInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates model parameters using SciPy least‑squares optimisation on collected temperature data"
    DTDFVocab:provides CalibrationCompletedAction,
                     UpdatedModelParametersInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuously monitors live temperature streams and checks them against configured upper/lower limits"
    DTDFVocab:provides TemperatureAlertInsight,
                     AdjustSetpointAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults by detecting violations of temperature thresholds and generates alerts"
    DTDFVocab:provides TemperatureAlertInsight
]

// -------------------------------
// Insights and actions generated by services
// -------------------------------
instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory produced by the simulation service"
]

instance UpdatedModelParametersInsight : DTDFVocab:Insight [
    base:desc "Updated calibrated values for model parameters (C_air, G_box, C_heater, G_heater) fed back to the controller"
]

instance TemperatureAlertInsight : DTDFVocab:Insight [
    base:desc "Detected temperature breach (above upper limit or below lower limit) indicating a safety issue"
]

instance CalibrationCompletedAction : DTDFVocab:Action [
    base:desc "Signals that model calibration has finished and new parameters are available for the controller"
    DTDFVocab:IsAutomatic true
]

instance AdjustSetpointAction : DTDFVocab:Action [
    base:desc "Requests human operator to adjust temperature set‑point or actuator duration in response to an alert"
    DTDFVocab:IsAutomatic false
]

// -------------------------------
// Acting components (actuators)
// -------------------------------
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heater (planar heat‑bed) switched on/off by the Raspberry Pi via MOSFET driver"
]

instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "12‑24 V internal fan that circulates air inside the incubator, controlled by the Raspberry Pi"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT components send control commands (heat‑bed ON/OFF, fan ON/OFF, waiting durations) as messages to the RabbitMQ server; the controller subscribes to these topics and actuates the heat‑bed and fan via the PCB."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A three‑layer architecture: (1) Physical Twin (incubator hardware), (2) Cyber layer comprising the RabbitMQ communication server, low‑level driver and controller on the Raspberry Pi, and (3) Digital Twin components (model simulators, calibrators, monitors) that subscribe to the same RabbitMQ topics. Figure 7 in the paper depicts this orchestration."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by (i) uniform‑temperature experiments confirming fan‑induced mixing (max 6–7 °C deviation across sensors), (ii) calibration residual minimisation using least‑squares, and (iii) comparison of simulated temperature trajectories with measured data. Assumptions such as uniform air temperature, negligible wall heat storage, constant air specific heat, and energy conversion efficiency are explicitly stated and form the validity basis."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses the AMQP protocol of RabbitMQ running locally on the Raspberry Pi; messages (sensor readings, control commands) are exchanged over TCP/IP within the same device/network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components (RabbitMQ server, low‑level driver, controller, model simulators, calibration scripts) are deployed on the Raspberry Pi 4 Model B that also hosts the physical hardware. The software is provided as open‑source code in a public GitHub repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver includes a safe protocol that keeps the hardware in a safe state (e.g., disables heaters on communication loss). The controller enforces upper and lower temperature thresholds (LL, UL) and incorporates waiting durations to avoid overshoot, providing safety supervision of the PT."
]