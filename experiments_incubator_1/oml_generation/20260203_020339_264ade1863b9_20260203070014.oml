// C3: Physical sensing components
instance InsideTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Thermistor positioned inside the insulated styrofoam box capturing internal air temperature (sensor 1)."
    DTDFVocab:producedData InsideTempDataTransmitted1
]

instance InsideTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Thermistor positioned inside the insulated styrofoam box capturing internal air temperature (sensor 2)."
    DTDFVocab:producedData InsideTempDataTransmitted2
]

instance OutsideTempSensor : DTDFVocab:SensingComponent [
    base:desc "Thermistor positioned outside the incubator monitoring ambient temperature."
    DTDFVocab:producedData OutsideTempDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmitted)
instance InsideTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensor1
]

instance InsideTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensor2
]

instance OutsideTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideTempSensor
]

// C10: Data
instance InsideTemperatureData1 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from inside sensor 1 (°C) published via RabbitMQ."
    DTDFVocab:fromData InsideTempDataTransmitted1
    DTDFVocab:inputTo TemperatureCalibrationEngine, KalmanFilterEngine, AnomalyDetectionEngine, CoSimulationEngine
]

instance InsideTemperatureData2 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from inside sensor 2 (°C) published via RabbitMQ."
    DTDFVocab:fromData InsideTempDataTransmitted2
    DTDFVocab:inputTo TemperatureCalibrationEngine, KalmanFilterEngine, AnomalyDetectionEngine, CoSimulationEngine
]

instance OutsideTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped ambient temperature reading (°C) published via RabbitMQ."
    DTDFVocab:fromData OutsideTempDataTransmitted
    DTDFVocab:inputTo TemperatureCalibrationEngine, KalmanFilterEngine, AnomalyDetectionEngine, CoSimulationEngine
]

// C10: Models/Data (analytical models)
instance IncubatorModelA : DTDFVocab:Model [
    base:desc "Analytical temperature dynamics model A with two free parameters derived from Q = c·m·ΔT."
    DTDFVocab:inputTo TemperatureCalibrationEngine
]

instance IncubatorModelB : DTDFVocab:Model [
    base:desc "Analytical temperature dynamics model B with four free parameters; relaxes the full‑power‑to‑heat assumption for higher fidelity."
    DTDFVocab:inputTo TemperatureCalibrationEngine
]

// C11: Enablers
instance TemperatureCalibrationEngine : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that updates free parameters of Model A and Model B in real time using streamed temperature data."
    DTDFVocab:enables ModelCalibrationService
]

instance KalmanFilterEngine : DTDFVocab:Enabler [
    base:desc "Kalman‑filter based estimator providing internal temperature prediction and heat‑bed state estimation."
    DTDFVocab:enables TemperaturePredictionService, AnomalyDetectionService
]

instance AnomalyDetectionEngine : DTDFVocab:Enabler [
    base:desc "Engine that analyses Kalman filter residuals to detect temperature anomalies."
    DTDFVocab:enables AnomalyDetectionService
]

instance CoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation platform that consumes calibrated models and live PT data for what‑if scenario execution."
    DTDFVocab:enables WhatIfSimulationService
]

instance OptimizationEngine : DTDFVocab:Enabler [
    base:desc "Optimization routine that searches optimal bang‑bang controller parameters based on simulation outcomes."
    DTDFVocab:enables SelfAdaptationService
]

instance SelfAdaptationEngine : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop that triggers recalibration, re‑configures Kalman filter and controller upon detected plant behavior changes."
    DTDFVocab:enables SelfAdaptationService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker mediating sensor, actuator and controller message streams."
    DTDFVocab:enables RealTimeMonitoringService, ModelCalibrationService, TemperaturePredictionService, AnomalyDetectionService, WhatIfSimulationService, SelfAdaptationService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time‑series database storing timestamped temperature and actuator data for visualization and analytics."
    DTDFVocab:enables RealTimeMonitoringService, ModelCalibrationService, TemperaturePredictionService, AnomalyDetectionService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring and visualization of temperature streams and controller state via dashboard."
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "On‑demand calibration of Model A and Model B using incoming temperature observations."
    DTDFVocab:provides ModelRecalibrationInsight
]

instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Prediction of internal temperature and heat‑bed temperature using the calibrated models and Kalman filter."
    DTDFVocab:provides TemperatureEstimationInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Detection of abnormal temperature patterns based on Kalman filter residual analysis."
    DTDFVocab:provides TemperatureAnomalyInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Co‑simulation based what‑if analysis evaluating alternative controller settings."
    DTDFVocab:provides OptimizationInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Closed‑loop self‑adaptation that re‑calibrates models, updates estimators and re‑configures controller parameters."
    DTDFVocab:provides ReconfigureControllerAction, ModelRecalibrationInsight
]

// C17: Insights/Actions
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live visual representation of temperature trends and actuator states on the web dashboard."
]

instance TemperatureAnomalyInsight : DTDFVocab:Insight [
    base:desc "Identification of temperature deviations indicative of sensor faults or unexpected plant behavior."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommended controller parameter set that minimizes temperature deviation and energy consumption."
]

instance ModelRecalibrationInsight : DTDFVocab:Insight [
    base:desc "Outcome of model recalibration indicating updated parameter values for Model A and Model B."
]

instance TemperatureEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated internal temperature and unmeasured heat‑bed temperature provided by the Kalman filter."
]

instance HeatBedControlAction : DTDFVocab:Action [
    base:desc "Bang‑bang command to turn the heat‑bed on or off."
    DTDFVocab:IsAutomatic true
]

instance FanControlAction : DTDFVocab:Action [
    base:desc "Bang‑bang command to turn the cooling fan on or off."
    DTDFVocab:IsAutomatic true
]

instance ReconfigureControllerAction : DTDFVocab:Action [
    base:desc "Automatic update of the controller's lower/upper temperature limits, heating duration, and waiting duration."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components (Physical actuators)
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that raises internal air temperature when powered."
]

instance CoolingFanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal fan that circulates air and provides cooling when activated."
]

// C1: Physical components (generic)
instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi hosting the bang‑bang controller logic and publishing actuation commands."
]

instance LowLevelDriver : DTDFVocab:Component [
    base:desc "Low‑level driver that reads sensors, publishes data to RabbitMQ, receives commands and drives hardware safely."
]

// C5: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, CoolingFanActuator, RaspberryPiController, LowLevelDriver, InsideTempSensor1, InsideTempSensor2, OutsideTempSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are sent from the DT (or other software components) to the Raspberry Pi controller via RabbitMQ messages. Command types include heat‑bed activation, fan control, and parameter settings such as lower/upper temperature limits (LL/UL), heating duration (H) and waiting duration (C). The controller validates incoming commands, executes them on the physical hardware, and publishes its current state back to RabbitMQ. The low‑level driver incorporates a safe protocol that ensures commands are applied only when the device is in a safe state, and the controller provides execution confirmation through status messages."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in near‑real‑time: it continuously listens to controller and low‑level driver messages published on the RabbitMQ broker, stores time‑stamped sensor data in a time‑series database and updates visual dashboards as data arrive. Calibration, Kalman‑filter based anomaly detection and what‑if simulations are triggered on‑demand or when new data are received, using either live or historical data. No explicit numerical latency, sampling frequency, or granularity is specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a publish‑subscribe architecture centred on a RabbitMQ message broker. Physical‑twin hardware (incubator), a low‑level driver that abstracts sensor/actuator I/O, and a bang‑bang controller exchange telemetry and commands via RabbitMQ. DT services such as monitoring, calibration, Kalman‑filter anomaly detection, and co‑simulation subscribe to the same broker to receive data and issue control actions. This centralised broker orchestrates component interaction, enabling modular addition of services and loosely‑coupled integration, as described in the provided documents."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing Model A and Model B against experimental calibration results (see Figure 13); Model B shows superior accuracy in reproducing the heat‑bed's thermal inertia. Validation is performed via on‑demand calibration that fits the models' free parameters to collected temperature data. Sources of uncertainty stem from modelling assumptions: uniform temperature distribution (enabled by the fan), negligible wall heat storage, constant specific heat capacity, and the proportion of electrical power converted to heat. These uncertainties are mitigated by periodic recalibration and by running a Kalman filter that estimates the unmeasured heat‑bed temperature and detects anomalies. Monitoring components raise violations, prompting re‑calibration or controller re‑configuration, thus constituting a continuous quality‑assurance loop."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All communication between physical and cyber components is mediated by a RabbitMQ server acting as a central message broker. The low‑level driver, controller, and DT modules act as RabbitMQ clients, sending and receiving messages through the broker. The deployment uses a client‑server topology; RabbitMQ is described as a lightweight, mature, and easy‑to‑deploy open‑source message broker that can run on‑premise or in the cloud. No explicit bandwidth, latency, reliability, redundancy, or security protocol details are provided in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The controller software runs on a Raspberry Pi embedded computer. The RabbitMQ broker can be deployed either on‑premise or in a cloud environment. DT functionalities such as real‑time visualisation, on‑demand calibration, anomaly detection, and what‑if simulation are implemented as separate software components that listen to the RabbitMQ broker; all source code and datasets are publicly available in an open‑source GitHub repository. The documents do not specify quantitative computational, storage, scalability, or availability requirements."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through RabbitMQ, an AMQP‑compatible message broker. All telemetry (temperature sensor readings) and control commands are exchanged as AMQP messages, allowing any AMQP‑capable client or external enterprise application to publish or subscribe to the same topics. This enables interoperability and integration of additional Digital Twins or enterprise systems via the standard message‑based interface. No other protocols or standards are mentioned."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol that continuously reads temperature data, checks for commands, and ensures the incubator remains in a safe state before forwarding actuator instructions, acting as a fail‑safe safety mechanism. Communication between the controller, driver and DT components is performed via a RabbitMQ message broker, which provides reliable message delivery; however, the documents do not specify authentication, encryption, or other cybersecurity measures."
]