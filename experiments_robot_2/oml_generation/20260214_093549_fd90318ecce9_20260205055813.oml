// Ingested sensor component
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Floating‑point temperature sensor providing time‑series data streamed via MQTT."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// Transmitted sensor data
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// Pre‑processed data trace stored in digital shadow
instance TemperatureTrace : DTDFVocab:Data [
    base:desc "Contextual floating‑point trace after preprocessing, stored in the digital shadow."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DataManagementLayer
]

// Common data management layer that aggregates contextual traces
instance DataManagementLayer : DTDFVocab:Enabler [
    base:desc "Common data management layer ingesting one‑way MQTT data streams and aggregating contextual traces."
    DTDFVocab:enables DataIngestionService
]

// Service that ingests sensor data streams and aggregates contextual data for the digital shadow
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service that ingests sensor data streams and aggregates contextual data for the digital shadow."
    DTDFVocab:provides ContextualTraceAggregationInsight
]

// Insight summarizing aggregated contextual traces within the digital shadow reference model
instance ContextualTraceAggregationInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing aggregated contextual traces within the digital shadow reference model."
]

// Requirements model built as part of the multi‑level MBSE approach
instance RequirementsModel : DTDFVocab:Model [
    base:desc "Requirements model built as part of the multi‑level MBSE approach."
    DTDFVocab:inputTo MBSEToolchain
]

// Functional model capturing system functional requirements
instance FunctionalModel : DTDFVocab:Model [
    base:desc "Functional model capturing system functional requirements."
    DTDFVocab:inputTo MBSEToolchain
]

// Logical model integrating SysML state machine (v1.7) and MontiArc Automaton behaviors
instance LogicalSysMLStateMachineModel : DTDFVocab:Model [
    base:desc "Logical model integrating SysML state machine (v1.7) and MontiArc Automaton behaviors."
    DTDFVocab:inputTo MBSEToolchain
]

// Product/technical model describing component‑connector relationships via ACME, AADL, and MontiArc
instance ProductTechnicalModel : DTDFVocab:Model [
    base:desc "Product/technical model describing component‑connector relationships via ACME, AADL, and MontiArc."
    DTDFVocab:inputTo MBSEToolchain
]

// Simulation model linked to MathWorks Simulink for dynamic behavior testing
instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model linked to MathWorks Simulink for dynamic behavior testing."
    DTDFVocab:inputTo MathWorksSimulinkEnabler
]

// MBSE toolchain providing model integration across abstraction layers
instance MBSEToolchain : DTDFVocab:Enabler [
    base:desc "MBSE toolchain providing model integration across abstraction layers."
    DTDFVocab:enables ModelDefinitionService
]

// Service that defines and validates model relationships across hierarchy
instance ModelDefinitionService : DTDFVocab:Service [
    base:desc "Service that defines and validates model relationships across hierarchy."
    DTDFVocab:provides ModelDefinitionInsight
]

// Insight providing mapping of model relationships
instance ModelDefinitionInsight : DTDFVocab:Insight [
    base:desc "Insight providing mapping of model relationships across abstraction layers."
]

// Interpreter for ACME architecture descriptions
instance ACMEInterpreter : DTDFVocab:Enabler [
    base:desc "Interpreter for ACME architecture descriptions."
    DTDFVocab:enables ArchitectureRelationshipService
]

// Interpreter for AADL architecture descriptions
instance AADLInterpreter : DTDFVocab:Enabler [
    base:desc "Interpreter for AADL architecture descriptions."
    DTDFVocab:enables ArchitectureRelationshipService
]

// Interpreter for MontiArc component‑connector relationships
instance MontiArcInterpreter : DTDFVocab:Enabler [
    base:desc "Interpreter for MontiArc component‑connector relationships."
    DTDFVocab:enables ArchitectureRelationshipService
]

// Service that manages architecture‑relationship insights across the model hierarchy
instance ArchitectureRelationshipService : DTDFVocab:Service [
    base:desc "Service that manages architecture‑relationship insights across the model hierarchy."
    DTDFVocab:provides ArchitectureRelationshipInsight
]

// Insight detailing component‑connector relationships across models
instance ArchitectureRelationshipInsight : DTDFVocab:Insight [
    base:desc "Insight detailing component‑connector relationships across models."
]

// Enabler enabling MathWorks Simulink for simulation execution
instance MathWorksSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "Enabler enabling MathWorks Simulink for simulation execution."
    DTDFVocab:enables SimulationExecutionService
]

// Service that executes simulations and generates simulation results
instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service that executes simulations and generates simulation results."
    DTDFVocab:provides SimulationResultInsight
    DTDFVocab:provides GenerateExecutableArtifactAction
]

// Insight summarizing simulation results and supporting decision making
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing simulation results and supporting decision making."
]

// Action to generate executable artifacts (C++ or Java) from simulation models, automated
instance GenerateExecutableArtifactAction : DTDFVocab:Action [
    base:desc "Automated action to generate executable artifacts (C++ or Java) from simulation models."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is architected through Model‑Based Systems Engineering (MBSE). Functional and logical layers are captured with SysML, using block definition diagrams to specify component interfaces and internal block diagrams to detail connector relationships. Executable behaviour is modeled in MathWorks Simulink, which can be translated into C++ or Java code for runtime execution. Integration between modelling layers is facilitated by SysML’s extension mechanisms and Simulink’s execution flow, ensuring that component interactions, data flow, and control logic are coordinated across the entire twin. Resource management is handled by the Simulink simulation engine and the generated code, while coordination across subsystems is achieved through the explicit SysML artifact links that define the system’s architecture."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin development lifecycle follows a sequential abstraction hierarchy—requirements, functional architecture, logical architecture, and product/technical layer—each represented with model‑based systems engineering (MBSE) notations. SysML is typically used at the requirements and functional levels, while architectural description languages such as ACME, AADL, or MontiArc describe component‑connector structures at the logical and product layers. Transition between stages is facilitated by reuse of model artifacts, simulation in MathWorks Simulink or MontiArc Automaton to validate behavior prior to hardware integration, and active components that convert one‑way digital shadow data streams into bidirectional interfaces, thereby enabling governance of design change and stakeholder integration."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the physical system and the digital twin uses MQTT as the transport protocol. No specific MQTT version, QoS level, or additional network topology details are provided.
"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The digital twin interfaces with external industrial control systems via MQTT broker for real‑time data exchange. Machine data is encapsulated using the Asset Administration Shell (AAS) standard, facilitating interoperability with enterprise systems. The system connects to a Siemens SINUMERIK 840D-SL machine controller as a data source."
]