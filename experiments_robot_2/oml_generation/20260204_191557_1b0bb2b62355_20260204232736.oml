// C17: Insights
instance MotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Insight into motion‑accuracy deviations caused by joint friction and mechanical wear."
]

instance FrictionEffectInsight : DTDFVocab:Insight [
    base:desc "Insight into nonlinear friction effects derived from the black‑box model."
]

// C17: Action
instance AdjustControlAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of controller parameters to compensate for identified friction.",
    DTDFVocab:IsAutomatic true
]

// C6: Services – Monitoring
instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitors robot‑axis state by interpreting encoder data and simulation outputs.",
    DTDFVocab:provides MotionAccuracyInsight
]

// C6: Services – Analysis
instance AnalysisService : DTDFVocab:Service [
    base:desc "Analyzes friction and wear by comparing simulation baseline with ML‑model residuals.",
    DTDFVocab:provides FrictionEffectInsight, AdjustControlAction
]

// C11: Enablers – Simulation engine
instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "Executes the white‑box physics‑based Simulink dynamic simulation of the robot axis.",
    DTDFVocab:enables MonitoringService
]

// C11: Enablers – Machine‑learning inference engine
instance MLInferenceEngine : DTDFVocab:Enabler [
    base:desc "Executes the black‑box machine‑learning regression model that captures nonlinear friction effects.",
    DTDFVocab:enables AnalysisService
]

// C2: Physical components (motor, gearbox, controller)
instance RobotAxisMotor : DTDFVocab:Component [
    base:desc "Electric motor driving the first robot axis."
]

instance RobotAxisGearbox : DTDFVocab:Component [
    base:desc "Gearbox transmitting motor torque to the robot axis."
]

instance SiemensSinumerik840DController : DTDFVocab:Component [
    base:desc "SINUMERIK 840D sl CNC controller managing robot motion."
]

// C3: Physical sensing component
instance RobotAxisEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder attached to the first (vertical) robot axis at the base, providing position feedback for the motor and gearbox.",
    DTDFVocab:producedData EncoderTrace
]

// C4: Physical-to-virtual interaction (data transmission)
instance EncoderTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotAxisEncoder
]

// C10: Data (contextual data trace)
instance EncoderStateData : DTDFVocab:Data [
    base:desc "Contextual data trace of encoder position values collected during robot operation.",
    DTDFVocab:fromData EncoderTrace,
    DTDFVocab:inputTo SimulinkSimulationEngine, MLInferenceEngine
]

// C10: Models/Data – White‑box simulation model
instance WhiteBoxPhysicsSimulinkModel : DTDFVocab:Model [
    base:desc "White‑box physics‑based model of the robot axis implemented in Simulink.",
    DTDFVocab:inputTo SimulinkSimulationEngine
]

// C10: Models/Data – Black‑box friction model
instance BlackBoxFrictionMLModel : DTDFVocab:Model [
    base:desc "Black‑box data‑driven regression model (e.g., machine‑learning) capturing nonlinear friction effects.",
    DTDFVocab:inputTo MLInferenceEngine
]

// C16: Environment
instance RobotCellEnvironment : DTDFVocab:Environment [
    base:contains RobotAxisMotor, RobotAxisGearbox, RobotAxisEncoder, SiemensSinumerik840DController
]

// C12: Processing component (traceability)
instance ProcessingComponent : DTDFVocab:Component [
    base:desc "Processing component that consumes input data traces and, using simulation or data‑calculation models, generates output traces for the digital shadow."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "According to the documents, the digital shadow does not push data back to the physical system and therefore lacks a virtual‑to‑physical control flow. While a Digital Twin can provide active components to interpret incoming data, the source material does not describe any command types, control message formats, validation, authentication, feedback, conflict resolution, or execution confirmation mechanisms."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by combining analytically interpretable Simulink simulations with statistically learned machine‑learning models, allowing validation against measured robot behavior. The approach emphasises traceability of transformations (e.g., SysML → simulation) and verification of model correctness. Reliability depends on the correctness of underlying models and data transformations; therefore, verification methods and quality‑assurance processes are applied to detect and correct errors, and uncertainties are implicitly managed by the hybrid model structure."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The digital twin is integrated with an external Siemens SINUMERIK 840D sl CNC controller; data is streamed using the MQTT protocol and the twin implements the Asset Administration Shell (AAS) standard, facilitating interoperability with other enterprise systems and digital twins."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin implementation follows the Asset Administration Shell (AAS) specification for standardized asset representation, uses SysML as the modelling language for exchanging engineering models, and adopts MQTT as the communication protocol for real‑time data streaming, aligning with Industry 4.0 interoperability standards."
]