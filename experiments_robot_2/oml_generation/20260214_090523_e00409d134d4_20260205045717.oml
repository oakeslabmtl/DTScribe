// C3: Physical sensing components
instance TelemetryReceiverSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensing component that ingests data via standard telemetry protocols such as OPC UA and MQTT as required by the active twin component."
    DTDFVocab:producedData SensorDerivedTracesStream
]

instance SimulatedOutputsSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensing component representing simulation outputs generated by the MathWorks Simulink engine."
    DTDFVocab:producedData SimulatedOutputsStream
]

// C4: Physical-to-virtual interaction
instance SensorDerivedTracesStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TelemetryReceiverSensor
]

instance SimulatedOutputsStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulatedOutputsSensor
]

// C10: Models/Data
instance SensorDerivedTracesData : DTDFVocab:Data [
    base:desc "Aggregated sensor-derived traces as per the Digital Shadow reference model."
    DTDFVocab:fromData SensorDerivedTracesStream
]

instance SimulatedOutputsData : DTDFVocab:Data [
    base:desc "Simulation outputs from the MathWorks Simulink engine."
    DTDFVocab:fromData SimulatedOutputsStream
]

instance SysMLArchitecturalModel : DTDFVocab:Model [
    base:desc "SysML is used to capture requirements, functional, logical, and product/technical abstractions."
    DTDFVocab:inputTo CodeGenerationTool
]

instance SimulinkOperationalModel : DTDFVocab:Model [
    base:desc "Operational dynamics are simulated in MathWorks Simulink, allowing numerical analysis of continuous-time subsystems."
    DTDFVocab:inputTo SimulinkEngine
]

instance CPlusPlusCodeGenerationModel : DTDFVocab:Model [
    base:desc "Code generation targets general-purpose languages like C++ or Java."
    DTDFVocab:inputTo CodeGenerationTool
]

// C11: Enablers
instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink engine employed to simulate dynamics and validate models."
    DTDFVocab:enables SimulationService
]

instance CodeGenerationTool : DTDFVocab:Enabler [
    base:desc "Code generators that produce deployment-ready C++ or Java code."
    DTDFVocab:enables CodeDeploymentService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Database back-end for time-series storage and retrieval."
    DTDFVocab:enables DataStorageService
]

instance OPCUAIngestion : DTDFVocab:Enabler [
    base:desc "Supports real-time data ingestion through the OPC UA telemetry protocol."
    DTDFVocab:enables TelemetryIngestionService
]

instance MQTTIngestion : DTDFVocab:Enabler [
    base:desc "Supports real-time data ingestion through the MQTT telemetry protocol."
    DTDFVocab:enables TelemetryIngestionService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates operational dynamics using MathWorks Simulink engine."
    DTDFVocab:provides DigitalShadowMappingInsight
]

instance CodeDeploymentService : DTDFVocab:Service [
    base:desc "Deploys code generated targeting C++ or Java."
    DTDFVocab:provides DeployGeneratedCodeAction
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Stores and retrieves time-series data in the database back-end."
    DTDFVocab:provides DataStorageInsight
]

instance TelemetryIngestionService : DTDFVocab:Service [
    base:desc "Ingests real-time telemetry data via OPC UA and MQTT."
    DTDFVocab:provides TelemetryIngestionInsight
]

// C17: Insights/Actions
instance DigitalShadowMappingInsight : DTDFVocab:Insight [
    base:desc "Unifies sensor-derived traces and simulation outputs under a common ontological mapping that distinguishes geometric, behavioural, and analytical representations."
]

instance DeployGeneratedCodeAction : DTDFVocab:Action [
    base:desc "Deploys generated C++ or Java code to runtime components."
    DTDFVocab:IsAutomatic true
]

instance DataStorageInsight : DTDFVocab:Insight [
    base:desc "Stores time-series data in the database for retrieval."
]

instance TelemetryIngestionInsight : DTDFVocab:Insight [
    base:desc "Real-time ingestion of telemetry data via OPC UA and MQTT."
]