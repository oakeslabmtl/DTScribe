// C3: Physical sensing components
instance IndustrialAssetSensor : DTDFVocab:SensingComponent [
    base:desc "Heterogeneous data collection device capturing contextual traces from physical industrial assets (e.g., machinery, equipment) via automated one-way data flows as per Digital Shadow Reference Model. Compatible with standard industrial protocols like OPC UA or MQTT."
    DTDFVocab:producedData IndustrialAssetTelemetryData
]

instance OperationalLogCollector : DTDFVocab:SensingComponent [
    base:desc "Component aggregating operational logs and event traces from PLCs or edge devices in manufacturing systems, supporting passive data collection for Digital Shadow implementation."
    DTDFVocab:producedData OperationalLogData
]

instance IoTTelemetryDevice : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled device collecting real-time telemetry from physical assets, supporting event-triggered or periodic data transmission to Digital Twin infrastructure."
    DTDFVocab:producedData IoTTelemetryData
]

// C4: Physical-to-virtual interaction
instance IndustrialAssetTelemetryData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndustrialAssetSensor
    base:desc "Aggregated sensor telemetry from industrial assets, including vibration, temperature, and operational parameters, transmitted via industrial protocols."
]

instance OperationalLogData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalLogCollector
    base:desc "Structured operational logs and event traces collected from PLCs and edge devices, supporting Digital Shadow's passive data aggregation."
]

instance IoTTelemetryData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IoTTelemetryDevice
    base:desc "Real-time IoT telemetry data from physical assets, supporting event-driven or periodic synchronization with Digital Twin models."
]

// C10: Models/Data
instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based functional architecture model using Internal Block Diagrams (IBDs) to define component-connector perspectives across requirements, functional, and logical layers."
    DTDFVocab:inputTo SysMLEnabler, MontiArcEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7+ state machine model capturing dynamic behavior of industrial assets and processes, integrated with simulation tools for validation."
    DTDFVocab:inputTo SysMLEnabler
]

instance SimulinkDynamicBehaviorModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for high-fidelity dynamic system simulation, supporting continuous-time, discrete-event, or hybrid simulation scenarios."
    DTDFVocab:inputTo SimulinkEnabler
]

instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces derived from physical-to-virtual data flows, supporting Digital Shadow and Digital Twin synchronization."
    DTDFVocab:fromData IndustrialAssetTelemetryData, OperationalLogData, IoTTelemetryData
    DTDFVocab:inputTo DataAggregationEnabler
]

instance HeterogeneousDataSource : DTDFVocab:Data [
    base:desc "Integration layer for diverse data sources including sensor feeds, operational logs, and external APIs, enabling multi-notation modeling consistency."
    DTDFVocab:fromData IndustrialAssetTelemetryData, OperationalLogData, IoTTelemetryData
    DTDFVocab:inputTo DataIntegrationEnabler
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based enabler for multi-layered system modeling (requirements, functional/logical architectures) using IBDs and state machines, supporting MBSE methodologies."
    DTDFVocab:enables DigitalTwinMonitoringService, DigitalTwinVisualizationService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc framework for component-based architecture modeling, including MontiArc Automaton for behavioral descriptions, integrated with SysML."
    DTDFVocab:enables DigitalTwinPredictionService, DigitalTwinOptimizationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink enabler for dynamic system simulation, behavioral validation, and control system design, supporting hybrid modeling with SysML."
    DTDFVocab:enables DigitalTwinPredictionService, DigitalTwinControlService
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "Data aggregation and abstraction mechanism for contextual data traces, supporting Digital Shadow's passive data flow and Digital Twin's active processing."
    DTDFVocab:enables DigitalTwinMonitoringService, DigitalTwinPredictionService
]

instance DataIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Heterogeneous data integration layer bridging SysML, ADLs, simulation tools, and code to ensure consistent data flow across abstraction layers."
    DTDFVocab:enables DigitalTwinOptimizationService, DigitalTwinVisualizationService
]

instance CppJavaImplementationEnabler : DTDFVocab:Enabler [
    base:desc "General-purpose implementation enabler using C++/Java for custom algorithms, active components, and data processing pipelines within the Digital Twin."
    DTDFVocab:enables DigitalTwinControlService, DigitalTwinOptimizationService
]

// C6: Services
instance DigitalTwinMonitoringService : DTDFVocab:Service [
    base:desc "Real-time or periodic state synchronization service between physical system and digital counterpart, enabling contextual data trace aggregation for monitoring."
    DTDFVocab:provides PhysicalStateInsight, AnomalyDetectionInsight
]

instance DigitalTwinPredictionService : DTDFVocab:Service [
    base:desc "Simulation-based prediction service using Simulink and aggregated data traces to model system behavior, validate designs, and forecast failures."
    DTDFVocab:provides FailurePredictionInsight, ProcessOptimizationInsight
]

instance DigitalTwinOptimizationService : DTDFVocab:Service [
    base:desc "Data-driven decision support service for process improvements, resource allocation, and energy efficiency using active components and algorithms."
    DTDFVocab:provides OptimizationRecommendationInsight, ResourceAllocationInsight
]

instance DigitalTwinControlService : DTDFVocab:Service [
    base:desc "Autonomous or semi-autonomous intervention service enabling feedback loops to adjust physical system parameters or trigger actions based on Digital Twin processing."
    DTDFVocab:provides ParameterAdjustmentAction, ProcessControlAction
]

instance DigitalTwinVisualizationService : DTDFVocab:Service [
    base:desc "Multi-perspective dashboard service providing 3D/2D representations of system state, anomalies, and optimization opportunities for stakeholders."
    DTDFVocab:provides SystemStateVisualizationInsight, AnomalyVisualizationInsight
]

// C17: Insights/Actions
instance PhysicalStateInsight : DTDFVocab:Insight [
    base:desc "Real-time or near-real-time insight into the physical system's state, derived from synchronized data traces and monitoring services."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of deviations or anomalies in system behavior, enabling proactive maintenance or intervention."
]

instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive insight into potential system failures or degradation, based on simulation and aggregated operational data."
]

instance ProcessOptimizationInsight : DTDFVocab:Insight [
    base:desc "Data-driven recommendations for process improvements, resource allocation, or energy efficiency in manufacturing systems."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Actionable recommendations for optimizing system performance, derived from active data processing and simulation."
]

instance ResourceAllocationInsight : DTDFVocab:Insight [
    base:desc "Insight into optimal resource allocation strategies, supporting decision-making for manufacturing operations."
]

instance SystemStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Multi-perspective visualization of system state, including 3D/2D representations for engineers and operators."
]

instance AnomalyVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of detected anomalies or deviations in system behavior for stakeholder analysis."
]

instance ParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Autonomous adjustment of physical system parameters based on Digital Twin processing and feedback loops."
    DTDFVocab:IsAutomatic true
]

instance ProcessControlAction : DTDFVocab:Action [
    base:desc "Semi-autonomous control actions triggered by the Digital Twin to intervene in physical processes (e.g., process adjustments, safety measures)."
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin constellation** is orchestrated through **architecture patterns** rooted in **Model-Based Systems Engineering (MBSE)**, leveraging **multi-notation modeling** (e.g., SysML for structural/logical views, ADLs like MontiArc or AADL for component-connector perspectives, and simulation tools like Simulink for behavioral dynamics). The system integrates **heterogeneous stakeholders and perspectives**, requiring **coordination mechanisms** to unify disparate models (e.g., requirements, functional, logical, and physical layers). **Resource management** is implied via **modular decomposition** (e.g., RFLP methodology) and **compositional architectures** (e.g., SysML IBDs or MontiArc Automaton for stateful behavior). While the document does not specify **exact orchestration protocols**, the use of **ADLs** (e.g., ACME, AADL) suggests **component-based integration** with well-defined **interfaces** and **interconnections**. The **system-wide coordination** may involve **centralized controllers** (e.g., for Digital Twin constellations) or **distributed consensus** (e.g., for decentralized instances), though no specific **middleware** (e.g., OPC UA, MQTT) or **service-oriented patterns** are mentioned. The **Digital Shadow Reference Model** (Fig. 1) implies a **UML-class-driven** approach to define relationships between physical and digital entities, but lacks details on **real-time synchronization** or **event-driven coordination**."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **fidelity requirements** aligned with MBSE methodologies, ensuring models accurately reflect the physical system’s behavior across abstraction layers. **Validation and verification (V&V) methods** are implied through the use of **SysML-based state machines** and **simulation tools (e.g., Simulink)**, which enable dynamic behavior testing and error detection. Uncertainty quantification is addressed via **data aggregation and abstraction mechanisms** (as per the Digital Shadow reference model), though specific uncertainty sources or error correction protocols are not detailed. **Quality assurance processes** are inferred to include cross-layer consistency checks (e.g., via ADLs like AADL or MontiArc) and integration of **heterogeneous stakeholder perspectives** to mitigate discrepancies between modeled and physical system states. No explicit mention of **safety constraints, calibration methods, or formal verification frameworks** (e.g., model checking) is provided in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system supports **horizontal integration** with **external systems** through **interoperability standards** and **data exchange protocols**, though no specific technologies (e.g., OPC UA, REST APIs, ROS) are named. The document emphasizes **heterogeneous stakeholder integration**, suggesting dependencies on **enterprise systems** (e.g., ERP, MES) or **other Digital Twins** via **model-based interfaces** (e.g., SysML, ADLs). Integration patterns are implied by **MBSE methodologies** (e.g., OOSEM, SPES), which advocate for **modular, reusable components** with **well-defined interfaces** (e.g., component-connector views in ADLs). The **Digital Shadow Reference Model** (Fig. 1) highlights **one-way data flow** (e.g., from physical assets to digital models), but **bidirectional integration** (e.g., for Digital Twins) would require **active processing components** (e.g., simulation tools like Simulink or general-purpose code in C++/Java). No **standardized protocols** or **semantic interoperability frameworks** (e.g., ontologies, OWL) are mentioned, though the use of **UML class diagrams** in the reference model suggests **structured data modeling** for cross-system communication. The document does not specify **dependencies** on external systems beyond the need to **aggregate and abstract data** for specific purposes."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system, as described in the context documents, integrates **cybersecurity protocols** and **access control mechanisms** through the **Asset Administration Shell (AAS)** framework (referenced in [46], [47], and [50]). The AAS provides a standardized structure for embedding **authentication systems** and **threat mitigation strategies** by encapsulating security policies within its **submodels**, such as the **Security submodel** (as per [50]). This aligns with **RAMI4.0** (Reference Architecture Model Industrie 4.0, [49]), which mandates hierarchical security integration across the **Automation Pyramid** ([42]). The **Digital Shadow** concept ([42]) further emphasizes **fail-safe mechanisms** by maintaining synchronized, real-time replicas of physical assets, ensuring operational continuity even under partial system failures. **Risk assessment approaches** are implicitly supported via the **Asset Administration Shell’s** modular design, allowing integration with external **cybersecurity frameworks** (e.g., IEC 62443) for compliance. **Safety-critical system considerations** are addressed through **Functional Mockup Interface (FMI)** ([51]), enabling interoperable simulation models with validated safety constraints, while **MQTT-based communication** ([52]) ensures lightweight, secure data exchange for IoT-driven Digital Twin components. The **Thingsboard IoT platform** ([53]) provides additional **access control** via role-based permissions and **encryption protocols** for data integrity."
]