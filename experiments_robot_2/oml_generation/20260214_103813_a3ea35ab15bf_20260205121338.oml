// C2: Acting Components
instance Motor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor (input: motor current I_M, output: torque τ_M)"
]

instance Gearbox : DTDFVocab:ActingComponent [
    base:desc "Multi-stage gear transmission system with cycloidal gearbox (first stage: torque τ_G, second stage: output torque τ_out)"
]

instance SafetyCell : DTDFVocab:ActingComponent [
    base:desc "Restricts working range to -90° to 90° and monitors operational limits for collision prevention"
]

// C3: Physical sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor position encoder measuring angular position and reducing backlash uncertainty"
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind gearbox measuring output angle and enabling friction detection via encoder comparison"
]

instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures input current I_M via MQTT protocol for motor control monitoring"
]

instance FrictionAnalysisSensor : DTDFVocab:SensingComponent [
    base:desc "Analyzes elasticity and backlash differences between motor and gearbox encoders for real-time friction detection"
]

// C4: Physical-to-virtual interaction
instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder, CurrentSensor
]

instance OutputAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance TorqueData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder, GearboxEncoder
]

instance AngularVelocityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder, GearboxEncoder
]

instance FrictionAnalysisData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder, GearboxEncoder
]

// C10: Models/Data
instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "White-box friction model in MATLAB Simulink simulating Coulomb-Viscous friction effects"
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "White-box friction model in MATLAB Simulink simulating Stribeck friction behavior"
]

instance IdealFrictionlessModel : DTDFVocab:Model [
    base:desc "Simulated frictionless dynamics model for motor, gearbox, and system comparison"
]

instance FrictionIncludedModel : DTDFVocab:Model [
    base:desc "Simulated model including friction effects for real-time comparison with measured data"
]

instance MeasuredData : DTDFVocab:Data [
    base:desc "Real-time measured data streamed via MQTT (input current I_M, output angle, torque, angular velocity)"
]

instance SimulatedData : DTDFVocab:Data [
    base:desc "Derived simulated data comparing frictionless and friction-included outputs from dynamics models"
]

instance MetadataData : DTDFVocab:Data [
    base:desc "Data provenance metadata including source origin (sensor channel), timestamps, and computational provenance"
]

instance StructuralModel : DTDFVocab:Data [
    base:desc "SysML Block Definition Diagram (BDD) and Internal Block Diagram (IBD) describing Motor → Gearbox → Cycloidal Gearbox system flows"
]

// C11: Enablers
instance MQTTProtocol : DTDFVocab:Enabler [
    base:desc "Real-time data streaming protocol for sensor data transmission (motor current I_M, output angle, torque, angular velocity)"
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "Executable simulation environment for friction models (Coulomb-Viscous, Stribeck) and dynamics modeling"
]

instance SysMLTool : DTDFVocab:Enabler [
    base:desc "Structural modeling tool for SysML Block Definition and Internal Block Diagrams"
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Digital integration framework enabling seamless data exchange between physical and virtual components"
]

instance UnifiedDashboard : DTDFVocab:Enabler [
    base:desc "Visualization platform for real-time friction analysis and control optimization"
]

// C6: Services
instance FrictionAnalysisDashboard : DTDFVocab:Service [
    base:desc "Unified visualization platform displaying real-time friction loss (static, kinetic, viscous) with semantic data relationships"
]

instance ModelBasedControlOptimization : DTDFVocab:Service [
    base:desc "Dynamic adjustment of control parameters (torque, angular velocity) using white-box and black-box friction models"
]

instance LiveDataAggregation : DTDFVocab:Service [
    base:desc "Aggregates sensor data, simulation outputs, and model predictions for contextual friction behavior insights"
]

instance MultiPhysicsAwareness : DTDFVocab:Service [
    base:desc "Combines structural (SysML) and behavioral (MATLAB Simulink) models to simulate and validate friction effects in real-time"
]

// C17: Insights/Actions
instance FrictionDeviationInsight : DTDFVocab:Insight [
    base:desc "Real-time detection of friction deviations between measured and simulated dynamics, enabling motion accuracy improvements"
]

instance MotionAccuracyImprovement : DTDFVocab:Action [
    base:desc "Dynamic parameter updates to friction models based on real-time data comparison, reducing up to 30% positioning inaccuracies"
]

instance ControlTrajectoryOptimization : DTDFVocab:Action [
    base:desc "Optimized motion trajectories for machining tasks using friction models, improving positioning accuracy"
]

instance MaintenanceAlert : DTDFVocab:Action [
    base:desc "Automatic notifications for high friction anomalies requiring maintenance or tooling adjustments"
]

instance ParameterUpdateAction : DTDFVocab:Action [
    base:desc "Automatic dynamic adjustment of friction model parameters during operation via real-time data comparison"
]

instance DiagnosticAlert : DTDFVocab:Action [
    base:desc "Real-time alerts for operational anomalies (e.g., high friction) detected through system monitoring"
]

// C12: Environment
instance RobotFirstAxisEnvironment : DTDFVocab:Environment [
    base:contains Motor, Gearbox, SafetyCell
]

instance IndustrialRobotEnvironment : DTDFVocab:Environment [
    base:contains RobotFirstAxisEnvironment
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin operates on a **real-time, event-driven time scale**:
  - **Data Acquisition Rate**: Sensor data (e.g., motor current, encoders) is streamed at **high-frequency intervals** (implied by live operational data requirements).
  - **Model Update Frequency**: Friction models are **continuously refined** during operation, with updates triggered by deviations between measured and simulated data.
  - **Dashboard Synchronization**: Visualization and processing occur in **sub-second latency** to support real-time decision-making in robot control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellation consists of:
  - **Physical Twin (PT)**: The **MABI MAX 100 industrial robot** (first axis: motor, gearbox, cycloidal gearbox).
  - **Digital Shadow (DS)**: A **real-time, passive data aggregation layer** that links physical sensor data with simulation models to analyze friction.
  - **Processing Layer**: Active components (e.g., MATLAB Simulink simulations, MQTT data processing) that generate derived data traces (e.g., simulated torque/velocity) and enable **traceability** of data origins.
  - **Control Interface**: Integration with the **Siemens SINUMERIK 840D sl CNC controller** for dynamic friction compensation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin spans the following lifecycle stages:
  - **As Designed**: Structural and behavioral models (SysML, MATLAB Simulink) are developed to simulate ideal robot dynamics without friction.
  - **As Manufactured**: Physical robot is instrumented with sensors (encoders, current measurement) to capture operational data.
  - **As Operated**: The Digital Shadow continuously updates friction models and provides real-time corrections to the **Siemens SINUMERIK 840D sl CNC controller** for improved motion accuracy during machining tasks."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
  - **Verification/Validation**:
    - **Model Validation**: Simulated friction models (Coulomb-Viscous, Stribeck) are validated against live sensor data to quantify accuracy.
    - **Uncertainty Analysis**: Differences between measured and simulated data (e.g., encoder-based friction detection) are used to assess model fidelity.
  - **Traceability**: Each data point is linked to its source (sensor, model) and computational provenance, ensuring reproducibility.
  - **Parameter Calibration**: Robot-specific parameters (e.g., gearbox ratios, motor constants) from the manufacturer are used to align simulation with physical behavior."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin is technically connected via:
  - **Data Protocol**: **MQTT** for real-time sensor data streaming (input current *I_M*, output angle, torque, angular velocity).
  - **Model Integration**: **MathWorks MATLAB Simulink** for executable friction simulations, interfaced with the Digital Shadow via data traces.
  - **Control Interface**: Direct integration with the **Siemens SINUMERIK 840D sl CNC controller** for dynamic friction compensation in robot motion."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin integrates horizontally with:
  - **CNC Controller (SINUMERIK 840D sl)**: Direct feedback loop for real-time friction compensation.
  - **Manufacturing Data Systems**: Sensor data and friction models are linked to machining operations for context-aware adjustments."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin adheres to:
  - **Modeling Standards**: **SysML** for structural/behavioral modeling, **MathWorks MATLAB Simulink** for simulation.
  - **Digital Shadow Reference Model**: Follows the **Digital Shadow Reference Model (DSRM)** (UML class diagram) for traceability and data provenance.
  - **Asset Administration Shell (AAS)**: Enables interoperability with Industry 4.0 standards for digital twin integration."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin includes safety considerations:
  - **Safety Cell**: Restricts the robot’s working range to **-90° to 90°** to prevent collisions.
  - **Real-Time Data Validation**: Sensor data is validated against physical constraints (e.g., maximum speed *|q̇_max| = 75°/s) before processing.
  - **Remote Operation Risk Mitigation**: The Digital Shadow does not autonomously act on the physical system; all adjustments are controlled via the **SINUMERIK 840D sl CNC controller**, ensuring safe operation."
]