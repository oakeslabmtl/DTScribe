// --------------------------------------------------------
// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring input current I_M from the robot axis"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor shaft providing motor angle r_M"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder located behind the gearbox providing gear output angle r_G"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// C10: Data (raw sensor streams)
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor current I_M streamed via MQTT"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance MotorEncoderData : DTDFVocab:Data [
    base:desc "Time‑series of motor shaft angle r_M streamed via MQTT"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance GearboxEncoderData : DTDFVocab:Data [
    base:desc "Time‑series of gearbox output angle r_G streamed via MQTT"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker for live data streaming from the robot to the digital shadow"
    DTDFVocab:enables RealTimeFrictionIdentificationService,
                   ContinuousModelUpdatingService,
                   IntegratedVisualizationService,
                   DataTraceabilityService
]

instance MATLABSimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink runtime executing motor, gearbox and friction simulation models"
    DTDFVocab:enables RealTimeFrictionIdentificationService,
                   ContinuousModelUpdatingService
]

instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML tool used for structural engineering models of the robot axis"
    DTDFVocab:enables IntegratedVisualizationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "AAS providing standardized asset description for the robot axis"
    DTDFVocab:enables DataTraceabilityService
]

instance DashboardVisualization : DTDFVocab:Enabler [
    base:desc "Unified dashboard visualizing live measurements, simulated traces and derived friction parameters"
    DTDFVocab:enables IntegratedVisualizationService
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction parameters from live data"
    DTDFVocab:provides FrictionParameterDerivationInsight
]

instance ContinuousModelUpdatingService : DTDFVocab:Service [
    base:desc "Continuous updating of white‑box and black‑box friction models during operation"
    DTDFVocab:provides ModelUpdateAction
]

instance IntegratedVisualizationService : DTDFVocab:Service [
    base:desc "Integrated visualization of sensor data, simulated traces and derived friction parameters in a unified dashboard"
    DTDFVocab:provides VisualizationInsight
]

instance DataTraceabilityService : DTDFVocab:Service [
    base:desc "Traceability of each data point to its originating sensor or model"
    DTDFVocab:provides TraceabilityInsight
]

// C17: Insights / Actions
instance FrictionParameterDerivationInsight : DTDFVocab:Insight [
    base:desc "Derivation of static, kinetic and viscous friction parameters for the gearbox"
]

instance ModelUpdateAction : DTDFVocab:Action [
    base:desc "Automatic update of white‑box and black‑box friction model parameters"
    DTDFVocab:IsAutomatic true
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Combined view of live measurements, simulated data and friction parameters"
]

instance TraceabilityInsight : DTDFVocab:Insight [
    base:desc "Ability to trace each data point back to its source sensor or model"
]

// C10: Models (Simulation & Calculation)
instance SimulinkFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model of motor dynamics, gear wheel and cycloidal gearbox friction (Coulomb‑Viscous, Stribeck, Dahl, LuGre)"
    DTDFVocab:inputTo MATLABSimulinkEngine
]

instance FrictionIdentificationModel : DTDFVocab:Model [
    base:desc "Data calculation model that identifies friction parameters from current and encoder position streams"
    DTDFVocab:inputTo MATLABSimulinkEngine
]

// C4: ProducedData for model outputs (replaces DataTransmitted)
instance SimulatedTorqueDataTransmitted : DTDFVocab:ProducedData [
]

instance FrictionParametersDataTransmitted : DTDFVocab:ProducedData [
]

// C10: Data (model outputs)
instance SimulatedTorqueData : DTDFVocab:Data [
    base:desc "Simulated torque time series generated by the Simulink friction model"
    DTDFVocab:fromData SimulatedTorqueDataTransmitted
    DTDFVocab:inputTo DashboardVisualization
]

instance FrictionParametersData : DTDFVocab:Data [
    base:desc "Derived friction parameters (static, kinetic, viscous) fed back to the robot control algorithm"
    DTDFVocab:fromData FrictionParametersDataTransmitted
    DTDFVocab:inputTo DashboardVisualization,
                   AssetAdministrationShell
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow does not send commands or data back to the physical robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time / continuous during robot operation; data traces are updated as the robot moves."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow combines the asset (first axis), data traces, processing components (simulation and calculation models), and a dashboard service to provide friction analysis and model verification."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated (runtime) stage – the digital shadow is created and used while the robot is running to improve motion control accuracy."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous identification of friction parameters using both white‑box (analytical) and black‑box (data‑driven) models, traceability of each data point to its source and processing model, and validation by comparing simulated friction‑free data with measured data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Live data transferred via MQTT from the robot controller to the digital shadow; Asset Administration Shells provide metadata and model linkage."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Industry 4.0 Asset Administration Shell (AAS) standard and SysML modeling language for model exchange."
]