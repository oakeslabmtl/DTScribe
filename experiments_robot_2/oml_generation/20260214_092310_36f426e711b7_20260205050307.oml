// C2: Acting Component
instance PermanentMagnetSynchronousMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor driving the first rotary joint axis, transmitting torque through a gearwheel and cycloidal gearbox to the shaft."
]

// C3: Physical sensing components
instance MotorPositionEncoderSensing : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder providing joint angle of motor shaft."
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxPositionEncoderSensing : DTDFVocab:SensingComponent [
    base:desc "Gearbox‑mounted position encoder providing angle after gearbox."
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

instance MotorCurrentSensorSensing : DTDFVocab:SensingComponent [
    base:desc "Electrical current sensor measuring motor excitation current."
    DTDFVocab:producedData CurrentMeasurementDataTransmitted
]

// C4: Physical‑to‑virtual interaction
instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoderSensing
    base:desc "MQTT message stream containing motor encoder angle data."
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoderSensing
    base:desc "MQTT message stream containing gearbox encoder angle data."
]

instance CurrentMeasurementDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensorSensing
    base:desc "MQTT message stream containing motor current measurement."
]

// C10: Models/Data
instance ToolingAndEnablersData : DTDFVocab:Data [
    base:desc "SysML system architecture models, MATLAB Simulink executable simulation, MQTT protocol stack, AAS asset description, and web‑based dashboard data."
    DTDFVocab:inputTo SysMLModelingEnabler, MATLABSimulinkEnabler, MQTTEnabler, AssetAdministrationShellEnabler, DashboardEnabler
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML toolchain enabling creation and versioning of system architecture models."
    DTDFVocab:enables DataAggregationService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink framework executing dynamic simulation models of motor, gearbox, and friction."
    DTDFVocab:enables FrictionParameterIdentificationService, RealTimeDashboardService
]

instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol stack enabling real‑time transport of sensor streams to the digital shadow."
    DTDFVocab:enables DataAggregationService, RealTimeDashboardService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "AAS representation providing standardized asset metadata and configuration."
    DTDFVocab:enables DataAggregationService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard platform visualizing measured versus simulated joint states in real‑time."
    DTDFVocab:enables RealTimeDashboardService
]

// Data instances derived from sensor streams
instance MotorAngleData : DTDFVocab:Data [
    base:desc "Measured motor angle derived from motor encoder data."
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler, MQTTEnabler
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Measured gearbox angle derived from gearbox encoder data."
    DTDFVocab:fromData GearboxAngleDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler, MQTTEnabler
]

instance CurrentMeasurementData : DTDFVocab:Data [
    base:desc "Measured motor current."
    DTDFVocab:fromData CurrentMeasurementDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler, MQTTEnabler
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Derived torque calculated from motor current and torque constant."
    DTDFVocab:fromData CurrentMeasurementDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance DerivedVelocityData : DTDFVocab:Data [
    base:desc "Derived rotational velocity derived from angle difference over time."
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance DerivedAccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration derived from velocity difference over time."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

// C4 continued: includes simulation output as data for comparison
instance SimulationOutputJointStateData : DTDFVocab:Data [
    base:desc "Simulated joint states (angle, velocity, torque) from white‑box friction models."
    DTDFVocab:fromData CurrentMeasurementDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

// C6: Services
instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Provides live comparison of measured joint states against simulated outputs for monitoring."
    DTDFVocab:provides JointStateComparisonInsight, MotionAccuracyImprovementAction
]

instance FrictionParameterIdentificationService : DTDFVocab:Service [
    base:desc "Continuously identifies static, kinetic, and viscous friction parameters from trace data."
    DTDFVocab:provides FrictionParameterEstimationInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Aggregates data traces with metadata to enable traceability throughout the twin lifecycle."
    DTDFVocab:provides DataTraceabilityInsight
]

// C17: Insights/Actions
instance JointStateComparisonInsight : DTDFVocab:Insight [
    base:desc "Insight into deviation between real joint state measurements and simulation predictions."
]

instance FrictionParameterEstimationInsight : DTDFVocab:Insight [
    base:desc "Insight on updated friction parameter values for drivetrain modeling."
]

instance DataTraceabilityInsight : DTDFVocab:Insight [
    base:desc "Insight confirming traceability of data provenance from sensors to models."
]

instance MaintenanceSchedulingAction : DTDFVocab:Action [
    base:desc "Automated maintenance scheduling based on friction trends and wear indicators."
    DTDFVocab:IsAutomatic true
]

instance ThresholdTuningAction : DTDFVocab:Action [
    base:desc "Manual action to adjust friction threshold settings for improved control accuracy."
    DTDFVocab:IsAutomatic false
]

instance MotionAccuracyImprovementAction : DTDFVocab:Action [
    base:desc "Automatic update of control law with new friction parameters to enhance motion accuracy."
    DTDFVocab:IsAutomatic true
]

// C18: Environment
instance MABI100RobotEnvironment : DTDFVocab:Environment [
    base:contains SerialIndustrialRobot, FirstRotaryJointAxis
]

// C19: Components
instance SerialIndustrialRobot : DTDFVocab:Component [
    base:desc "Serial industrial robot MABI 100 comprising six axes."
]

instance FirstRotaryJointAxis : DTDFVocab:Component [
    base:desc "First rotary joint at robot base driven by permanent‑magnet synchronous motor."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "No outbound control signals are sent from the DT back to the robot; the digital shadow is a passive one‑way data consumer, serving only as a visualization and diagnostic tool."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sensor data is streamed at the robot’s operational sampling frequency (typically a few hundred Hz to kHz as dictated by the CNC controller); the DT processes data in near‑real‑time and updates dashboards with each new data point."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized orchestration where sensor data is ingested via MQTT, processed by simulation components (Simulations M, GW, GB), aggregated into data traces, and displayed in a unified dashboard; the DT uses the AAS to bind model and data."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is constructed during the operational life stage; its engineering model covers the manufactured robot operating on the factory floor, with continuous updates reflective of wear, load, and temperature changes."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity depends on the chosen friction model; validation is performed by comparing simulated outputs against measured sensor data; continuous identification compensates for wear and temperature‑induced discrepancies; uncertainties are mitigated by traceable data calculations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data flows from the robot to the DT using MQTT; the DT listens on defined topics for current and encoder data; no outbound control traffic is defined."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "References the Asset Administration Shell (AAS) standard for asset description and SysML for system modeling; simulation models are implemented in MATLAB/Simulink."
]