instance PhysicalSystemStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensing component capturing physical system states from the physical environment"
    DTDFVocab:producedData PhysicalSystemStateDataTransmitted
]

instance PhysicalSystemStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemStateSensor
]

instance PhysicalSystemStateData : DTDFVocab:Data [
    base:desc "Raw physical system state data collected from sensors"
    DTDFVocab:fromData PhysicalSystemStateDataTransmitted
    DTDFVocab:inputTo Simulink, Cpp, Java
]

instance ContextualDataTracesDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemStateSensor
]

instance ContextualDataTracesData : DTDFVocab:Data [
    base:desc "Contextual data traces aggregated and abstracted from physical system states"
    DTDFVocab:fromData ContextualDataTracesDataTransmitted
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT, ACME, AADL, MontiArc, SysMLIBDs, Simulink, Cpp, Java
]

instance SysMLModel : DTDFVocab:Model [
    base:desc "SysML model for multi-level abstraction (requirements, functional, logical, technical layers)"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT, SysMLIBDs
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME architecture description language model for component interfaces and interconnections"
    DTDFVocab:inputTo ACME
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL architecture description language model for component interfaces"
    DTDFVocab:inputTo AADL
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description language model for component interconnections"
    DTDFVocab:inputTo MontiArc
]

instance SysMLIBDsModel : DTDFVocab:Model [
    base:desc "SysML Interface Block Diagrams model for component interconnections"
    DTDFVocab:inputTo SysMLIBDs
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton behavioral model"
    DTDFVocab:inputTo MontiArc, Simulink
]

instance SysMLStateMachinesModel : DTDFVocab:Model [
    base:desc "SysML state machine behavioral model"
    DTDFVocab:inputTo SysMLIBDs, Simulink
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink simulation model"
    DTDFVocab:inputTo Simulink
]

instance CppModel : DTDFVocab:Model [
    base:desc "C++ code implementation model"
    DTDFVocab:inputTo Cpp
]

instance JavaModel : DTDFVocab:Model [
    base:desc "Java code implementation model"
    DTDFVocab:inputTo Java
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "RFLP methodology (Requirements, Functions, Logics, Physics) for system abstraction levels"
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for system modeling"
]

instance SPES : DTDFVocab:Enabler [
    base:desc "SPES methodology for system engineering"
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for system abstraction"
]

instance ACME : DTDFVocab:Enabler [
    base:desc "ACME architecture description language for component modeling"
]

instance AADL : DTDFVocab:Enabler [
    base:desc "AADL architecture description language for component interfaces"
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "MontiArc architecture description language for component interconnections"
]

instance SysMLIBDs : DTDFVocab:Enabler [
    base:desc "SysML Interface Block Diagrams for component interconnections"
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation tool"
]

instance Cpp : DTDFVocab:Enabler [
    base:desc "C++ programming language for implementation"
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java programming language for implementation"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to industry standards including SysML for model-based systems engineering, and architecture description languages such as ACME, AADL, MontiArc, and SysML IBDs for component & connector perspectives. These standards enable integration of heterogeneous stakeholders and perspectives within the Model-Based Systems Engineering (MBSE) framework."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security measures include X.509 certificate-based mutual TLS authentication for Asset Administration Shell (AAS) components, role-based access control (RBAC) through AAS access control lists, TLS encryption for data in transit using MQTT (Mosquitto) and Thingsboard platforms, and JWT-based authentication for secure access management in Thingsboard."
]