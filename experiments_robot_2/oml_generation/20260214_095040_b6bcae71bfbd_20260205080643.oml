// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring applied current I_m to the motor."
    DTDFVocab:producedData MotorCurrentMQTT
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted directly on the motor shaft to capture motor position."
    DTDFVocab:producedData MotorAngleMQTT
]

instance GearboxSecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder installed on the gearbox housing to monitor gear position."
    DTDFVocab:producedData GearboxAngleMQTT
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Output angle sensor capturing the joint/output angle q of the rotary axis."
    DTDFVocab:producedData OutputAngleMQTT
]

// C4: Data transmitted via MQTT
instance MotorCurrentMQTT : DTDFVocab:DataTransmitted [
    base:desc "MQTT stream transmitting measured motor current I_m in real‑time."
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorAngleMQTT : DTDFVocab:DataTransmitted [
    base:desc "MQTT stream transmitting measured motor angle q_motor in real‑time."
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxAngleMQTT : DTDFVocab:DataTransmitted [
    base:desc "MQTT stream transmitting measured gear angle q_gear in real‑time."
    DTDFVocab:producedFrom GearboxSecondaryEncoder
]

instance OutputAngleMQTT : DTDFVocab:DataTransmitted [
    base:desc "MQTT stream transmitting measured output angle q_output in real‑time."
    DTDFVocab:producedFrom OutputAngleSensor
]

// C5: Data traces derived from transmissions
instance MeasuredMotorCurrentData : DTDFVocab:Data [
    base:desc "Data trace of measured motor current I_m."
    DTDFVocab:fromData MotorCurrentMQTT
    DTDFVocab:inputTo DataAggregatorEnabler
]

instance MeasuredMotorAngleData : DTDFVocab:Data [
    base:desc "Data trace of measured motor angle q_motor."
    DTDFVocab:fromData MotorAngleMQTT
    DTDFVocab:inputTo DataAggregatorEnabler
]

instance MeasuredGearboxAngleData : DTDFVocab:Data [
    base:desc "Data trace of measured gear angle q_gear."
    DTDFVocab:fromData GearboxAngleMQTT
    DTDFVocab:inputTo DataAggregatorEnabler
]

instance MeasuredOutputAngleData : DTDFVocab:Data [
    base:desc "Data trace of measured output angle q_output."
    DTDFVocab:fromData OutputAngleMQTT
    DTDFVocab:inputTo DataAggregatorEnabler
]

instance SimulatedMotorOutputData : DTDFVocab:Data [
    base:desc "Simulated trace of motor output based on Simulink model (ṙ_M)."
    DTDFVocab:inputTo DataAggregatorEnabler
]

instance SimulatedGearboxOutputData : DTDFVocab:Data [
    base:desc "Simulated trace of gearbox output based on Simulink model (ṙ_G)."
    DTDFVocab:inputTo DataAggregatorEnabler
]

instance SimulatedCombinedOutputData : DTDFVocab:Data [
    base:desc "Simulated trace of combined motor+gearbox output (ṙ_out)."
    DTDFVocab:inputTo DataAggregatorEnabler
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Derived torque τ data computed from measured currents and mechanical model."
    DTDFVocab:inputTo DataAggregatorEnabler
]

instance DerivedAngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω data computed from measured angular changes."
    DTDFVocab:inputTo DataAggregatorEnabler
]

instance DerivedAccelerationData : DTDFVocab:Data [
    base:desc "Derived acceleration data computed from angular velocity changes."
    DTDFVocab:inputTo DataAggregatorEnabler
]

// C10: Models/Data
instance MotorStructuralModel : DTDFVocab:Model [
    base:desc "Structural engineering model of the motor detailing mechanical properties."
    DTDFVocab:inputTo DataAggregatorEnabler
]

instance GearboxStructuralModel : DTDFVocab:Model [
    base:desc "Structural engineering model of the gearbox detailing mechanical properties."
    DTDFVocab:inputTo DataAggregatorEnabler
]

instance SimulinkMotorSimulationModel : DTDFVocab:Model [
    base:desc "Executable Simulink simulation of motor dynamics."
    DTDFVocab:inputTo DataAggregatorEnabler
]

instance SimulinkGearboxSimulationModel : DTDFVocab:Model [
    base:desc "Executable Simulink simulation of gearbox dynamics."
    DTDFVocab:inputTo DataAggregatorEnabler
]

// C17: Components (representing processing units of the twin)
instance SimulationMotorComponent : DTDFVocab:Component [
    base:desc "Simulation component for the motor."
]

instance SimulationGearwheelComponent : DTDFVocab:Component [
    base:desc "Simulation component for the gearwheel."
]

instance SimulationGearboxComponent : DTDFVocab:Component [
    base:desc "Simulation component for the gearbox."
]

// C11: Enablers
instance DataAggregatorEnabler : DTDFVocab:Enabler [
    base:desc "Aggregates measured and simulated data traces into a digital shadow for the first rotary axis."
    DTDFVocab:enables VisualDashboardService, FrictionIdentificationService, MotionAccuracyService
]

// C6: Services
instance VisualDashboardService : DTDFVocab:Service [
    base:desc "Service providing a web‑based dashboard that displays real‑time comparison between measured and simulated data traces."
    DTDFVocab:provides RealTimeComparisonInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service performing continuous friction identification using multi‑physics models."
    DTDFVocab:provides FrictionIdentificationInsight
]

instance MotionAccuracyService : DTDFVocab:Service [
    base:desc "Service applying calibrated friction model updates to improve robot motion accuracy."
    DTDFVocab:provides FrictionModelUpdateInsight, ApplyFrictionModelUpdatesAction
]

// C17: Insights/Actions
instance RealTimeComparisonInsight : DTDFVocab:Insight [
    base:desc "Insight comparing real‑time measured versus simulated data traces."
]

instance FrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Insight identifying current friction parameters from twin data."
]

instance FrictionModelUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight that friction model parameters have been updated by the twin."
]

instance ApplyFrictionModelUpdatesAction : DTDFVocab:Action [
    base:desc "Action applying updated friction model parameters to the robot control loop."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data acquisition and processing with each sensor sample (e.g., sampled at the controller rate); the DT continually evaluates simulation models concurrently with live data."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration of sensors feeding MQTT topics, a Processing component executing the Simulink models, generating data traces, and a dashboard consuming these traces; the digital shadow remains passive and is tied to the Asset via its AAS."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Designed in MBSE with SysML, simulated in Simulink, instantiated during operation as a digital shadow, refined continuously via live data identification; covers as operated lifecycle stage."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "White‑box friction models (Coulomb‑viscous, Stribeck, Dahl, LuGre) and black‑box data‑driven models are validated by comparing simulated torque and velocity traces against measured data; traceability of data points to their generation path is maintained; uncertainties arise from load, temperature, wear, and are managed through continuous re‑identification."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor and control data are transmitted over MQTT from the robot controller to the digital shadow processing component. The AAS provides a semantically enriched interface for asset description but the transport protocol remains MQTT. No explicit mention of additional protocols such as OPC UA or TCP/IP in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with SysML for system architecture, UML (class diagrams), AAS standards for asset representation, MQTT protocol for messaging, Simulink for model‑based simulation."
]