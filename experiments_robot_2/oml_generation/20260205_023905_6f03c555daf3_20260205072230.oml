// Sensing Components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor for the first joint motor of MABI MAX 100 robot."
    DTDFVocab:producedData CurrentData
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted on the motor of the first joint."
    DTDFVocab:producedData MotorAngleData
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Gearbox encoder positioned behind the gearbox of the first joint."
    DTDFVocab:producedData GearboxAngleData
]

// Data Transmitted
instance CurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
    base:desc "Motor current signal transmitted via MQTT."
]

instance MotorAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
    base:desc "Motor encoder output (joint angle) transmitted via MQTT."
]

instance GearboxAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
    base:desc "Gearbox encoder output (joint angle) transmitted via MQTT."
]

// Raw Data
instance MeasuredCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current trace from current sensor."
    DTDFVocab:fromData CurrentData
    DTDFVocab:inputTo SimulinkEnabler
]

instance MeasuredMotorAngleData : DTDFVocab:Data [
    base:desc "Measured motor joint angle from motor encoder."
    DTDFVocab:fromData MotorAngleData
    DTDFVocab:inputTo SimulinkEnabler
]

instance MeasuredGearboxAngleData : DTDFVocab:Data [
    base:desc "Measured gearbox joint angle from gearbox encoder."
    DTDFVocab:fromData GearboxAngleData
    DTDFVocab:inputTo SimulinkEnabler
]

// Derived Data
instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque of first joint calculated from current and motor model."
    DTDFVocab:fromData MeasuredCurrentData
    DTDFVocab:inputTo SimulinkEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity of first joint calculated from motor angle."
    DTDFVocab:fromData MeasuredMotorAngleData
    DTDFVocab:inputTo SimulinkEnabler
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived acceleration of first joint computed from angular velocity."
    DTDFVocab:fromData AngularVelocityData
    DTDFVocab:inputTo SimulinkEnabler
]

instance FrictionData : DTDFVocab:Data [
    base:desc "Actionable friction data derived from torque and velocity."
    DTDFVocab:fromData TorqueData
    DTDFVocab:inputTo AASEnabler
]

// Data Traces
instance CurrentTrace : DTDFVocab:Data [
    base:desc "Data trace of measured current for modeling."
    DTDFVocab:fromData MeasuredCurrentData
    DTDFVocab:inputTo AASEnabler
]

instance PositionTrace : DTDFVocab:Data [
    base:desc "Data trace of measured motor angle for modeling."
    DTDFVocab:fromData MeasuredMotorAngleData
    DTDFVocab:inputTo AASEnabler
]

// Models
instance AxisEngineeringModel : DTDFVocab:Model [
    base:desc "Engineering model of first joint motor and gearbox."
    DTDFVocab:inputTo SimulinkEnabler
]

instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of motor for first joint."
    DTDFVocab:inputTo SimulinkEnabler
]

instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of gearbox for first joint."
    DTDFVocab:inputTo SimulinkEnabler
]

instance FrictionSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink friction model for joint frictions."
    DTDFVocab:inputTo SimulinkEnabler
]

// Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker for live telemetry streaming from sensors."
    DTDFVocab:enables RealTimeMonitoringService, FrictionModelIdentificationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "Simulink runtime enabler for executing simulation models."
    DTDFVocab:enables RealTimeMonitoringService, FrictionModelIdentificationService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell enabler for data integration and traceability."
    DTDFVocab:enables FrictionParameterProvisionService
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling enabler for structural modeling."
    DTDFVocab:enables RealTimeMonitoringService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard enabler for real‑time visualization of joint behavior."
    DTDFVocab:enables RealTimeMonitoringService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring and visualization of joint behavior."
    DTDFVocab:provides WearConditionInsight
]

instance FrictionModelIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of friction models (white‑box and black‑box)."
    DTDFVocab:provides JointFrictionCharacteristicIdentification, FrictionModelParameterUpdate
]

instance FrictionParameterProvisionService : DTDFVocab:Service [
    base:desc "Provision of friction parameters for improved motion control."
    DTDFVocab:provides ProvideFrictionParameters, MotionControlAccuracyImprovement
]

// Insights
instance JointFrictionCharacteristicIdentification : DTDFVocab:Insight [
    base:desc "Identification of joint friction characteristics."
]

instance FrictionModelParameterUpdate : DTDFVocab:Insight [
    base:desc "Update of friction model parameters."
]

instance WearConditionInsight : DTDFVocab:Insight [
    base:desc "Insights into wear or operating conditions."
]

instance MotionControlAccuracyImprovement : DTDFVocab:Insight [
    base:desc "Improved motion control accuracy."
]

// Action
instance ProvideFrictionParameters : DTDFVocab:Action [
    base:desc "Provision of identified friction parameters to motion control system."
    DTDFVocab:IsAutomatic true
]

// Components
instance MABIMAX100FirstJointMotor : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor of the first joint of MABI MAX 100 robot."
]

instance MABIMAX100FirstJointGearbox : DTDFVocab:Component [
    base:desc "Dual‑stage gearbox of the first joint of MABI MAX 100 robot."
]

// Environment
instance RobotJointEnvironment : DTDFVocab:Environment [
    base:contains MotorCurrentSensor, MotorEncoderSensor, GearboxEncoderSensor, MABIMAX100FirstJointMotor, MABIMAX100FirstJointGearbox
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Not in Document – the current implementation only visualizes and identifies friction models; no actuation commands are sent back to the robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time continuous data acquisition and simulation; the digital shadow processes live data streams and updates models continuously as operations of the physical robot occur; no fixed sampling interval is specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central digital shadow consisting of (1) asset description (engineering model), (2) simulation and data‑calculation models, (3) processing components that compute traces, (4) live data sources via MQTT, and (5) a dashboard UI."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow operates at the operated phase, using real‑time sensor data; it builds on manufactured engineering models and updates during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Not in Document – the paper does not detail specific V&V procedures or uncertainty quantification beyond noting continuous model refinement."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol for streaming sensor telemetry between the physical robot and the digital shadow; data traces are stored with provenance and traceability."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Not in Document – hosting details of the digital shadow (local server, cloud, etc.) are not specified."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not in Document – no exchange with external information systems is described."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not in Document – ownership and privacy aspects are not addressed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for modeling, Asset Administration Shell (AAS) as a standard for data representation, and MQTT as a communication protocol."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Not in Document – no cybersecurity or safety analysis is presented."
]