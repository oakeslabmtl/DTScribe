// Sensing Components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors the current at the motor input of the first axis."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor shaft encoder feeding motor angle data."
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Gearbox shaft encoder feeding gearbox angle data."
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

// Transmitted Data
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

// Derived Transmitted Data (produced by simulation/enabling components)
instance DerivedTorqueDataTransmitted : DTDFVocab:DataTransmitted [
]

instance DerivedAngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
]

instance DerivedAccelerationDataTransmitted : DTDFVocab:DataTransmitted [
]

// Data Traces
instance MotorCurrentTrace : DTDFVocab:Data [
    base:desc "Historical trace of the motor input current."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulationEnabler, FrictionIdentificationEnabler, DashboardEnabler
]

instance MotorAngleTrace : DTDFVocab:Data [
    base:desc "Historical trace of the motor shaft angle."
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo SimulationEnabler, FrictionIdentificationEnabler, DashboardEnabler
]

instance GearboxAngleTrace : DTDFVocab:Data [
    base:desc "Historical trace of the gearbox shaft angle."
    DTDFVocab:fromData GearboxAngleDataTransmitted
    DTDFVocab:inputTo SimulationEnabler, FrictionIdentificationEnabler, DashboardEnabler
]

instance DerivedTorqueTrace : DTDFVocab:Data [
    base:desc "Derived trace of motor torque from simulation."
    DTDFVocab:fromData DerivedTorqueDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

instance DerivedAngularVelocityTrace : DTDFVocab:Data [
    base:desc "Derived trace of motor angular velocity from simulation."
    DTDFVocab:fromData DerivedAngularVelocityDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

instance DerivedAccelerationTrace : DTDFVocab:Data [
    base:desc "Derived trace of motor angular acceleration from simulation."
    DTDFVocab:fromData DerivedAccelerationDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

// Enablers
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulink simulation enabler that processes sensor data to simulate motor and gearbox behavior."
    DTDFVocab:enables SimulationService
]

instance FrictionIdentificationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that performs real‑time friction identification using MATLAB Simulink."
    DTDFVocab:enables FrictionIdentificationService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that aggregates data traces and visualizes them on a unified dashboard."
    DTDFVocab:enables DashboardService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell enabler describing the digital twin of the first axis."
    DTDFVocab:enables AASService
]

instance AASService : DTDFVocab:Service [
    base:desc "Service providing Asset Administration Shell for the digital twin of the first axis."
]

// Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time friction identification service covering Coulomb‑Viscous, Stribeck, Dahl, LuGre models."
    DTDFVocab:provides FrictionParameterEstimateInsight, LossEstimateInsight, ControllerParameterAdjustmentRecommendationAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service that runs motor and gearbox behavior models in MATLAB Simulink."
    DTDFVocab:provides SimulationVsMeasuredComparisonInsight
]

instance DashboardService : DTDFVocab:Service [
    base:desc "Data aggregation and visualization service for unified dashboard."
    DTDFVocab:provides SimulationVsMeasuredComparisonInsight
]

instance MotionControllerFeedService : DTDFVocab:Service [
    base:desc "Service that provides updated friction parameters to the plant controller."
    DTDFVocab:provides ControllerParameterAdjustmentRecommendationAction, UpdateFrictionModelAction
]

// Insights
instance FrictionParameterEstimateInsight : DTDFVocab:Insight [
    base:desc "Insight derived from friction model identification providing estimated friction parameters."
]

instance LossEstimateInsight : DTDFVocab:Insight [
    base:desc "Insight estimating friction‑related energy loss in the first axis."
]

instance SimulationVsMeasuredComparisonInsight : DTDFVocab:Insight [
    base:desc "Insight comparing simulated motor behavior with measured data for real‑time visualization."
]

// Actions
instance ControllerParameterAdjustmentRecommendationAction : DTDFVocab:Action [
    base:desc "Recommendation to adjust controller parameters based on identified friction."
    DTDFVocab:IsAutomatic false
]

instance UpdateFrictionModelAction : DTDFVocab:Action [
    base:desc "Automatic update of the friction model in the motion controller."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time, continuous identification; the digital shadow updates friction models continuously as the robot operates, without any intentional lag."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Digital shadow comprising a schematic engineering model (SysML), simulation models (Simulink), a processing component that executes those models, sensor data streams (MQTT), and an Asset Administration Shell representing the robot; all orchestrated to deliver diagnostics and visualization."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Lifecycle covers the design phase where engineering models (SysML structural model, Simulink simulation models) are created, a manufacturing phase where the physical robot already exists, and an operation phase where the digital shadow runs continuously during robot operation, continuously updating friction models."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of each data point back to its generating processing component; use of analytical (white‑box) and data‑driven (black‑box) friction models; continuous real‑time identification compensates for wear and temperature changes; explicit coupling of simulation and measured data ensures model validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data transmitted over MQTT; asset administration shell may use other protocols but not specified; thus the only documented protocol is MQTT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The study follows SysML, Asset Administration Shell (AAS) standards, and uses MathWorks MATLAB/Simulink as the modeling/simulation environment."
]