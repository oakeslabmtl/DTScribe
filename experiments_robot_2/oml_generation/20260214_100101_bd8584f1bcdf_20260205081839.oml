// C3: Physical sensing components
instance PhysicalSystemTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Collects raw temperature data traces from physical system components for Digital Shadow aggregation"
    DTDFVocab:producedData PhysicalSystemTemperatureDataTransmitted
]

instance PhysicalSystemPressureSensor : DTDFVocab:SensingComponent [
    base:desc "Collects raw pressure data traces from physical system components for Digital Shadow aggregation"
    DTDFVocab:producedData PhysicalSystemPressureDataTransmitted
]

instance PhysicalSystemVibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Collects raw vibration data traces from physical system components for Digital Shadow aggregation"
    DTDFVocab:producedData PhysicalSystemVibrationDataTransmitted
]

instance PhysicalSystemPerformanceIndicatorSensor : DTDFVocab:SensingComponent [
    base:desc "Collects derived performance metrics from physical system components for Digital Shadow aggregation"
    DTDFVocab:producedData PhysicalSystemPerformanceIndicatorDataTransmitted
]

instance PhysicalSystemOperationalStateSensor : DTDFVocab:SensingComponent [
    base:desc "Collects operational state data traces from physical system components for Digital Shadow aggregation"
    DTDFVocab:producedData PhysicalSystemOperationalStateDataTransmitted
]

// C4: Physical-to-virtual interaction
instance PhysicalSystemTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemTemperatureSensor
    base:desc "Transmits raw temperature data via one-way flow to Digital Shadow, potentially triggered by time intervals or threshold crossings"
]

instance PhysicalSystemPressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemPressureSensor
    base:desc "Transmits raw pressure data via one-way flow to Digital Shadow, potentially triggered by time intervals or threshold crossings"
]

instance PhysicalSystemVibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemVibrationSensor
    base:desc "Transmits raw vibration data via one-way flow to Digital Shadow, potentially triggered by time intervals or threshold crossings"
]

instance PhysicalSystemPerformanceIndicatorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemPerformanceIndicatorSensor
    base:desc "Transmits derived performance metrics via one-way flow to Digital Shadow, potentially triggered by state changes"
]

instance PhysicalSystemOperationalStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemOperationalStateSensor
    base:desc "Transmits operational state data via one-way flow to Digital Shadow, potentially triggered by state changes"
]

// C10: Models/Data
instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML-based requirements model covering functional, logical, and technical layers using RFLP/OOSEM methodologies"
    DTDFVocab:inputTo SysMLToolchainEnabler
]

instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) defining component-connector architecture for functional layer"
    DTDFVocab:inputTo SysMLToolchainEnabler
]

instance SysMLLogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) defining component-connector architecture for logical layer"
    DTDFVocab:inputTo SysMLToolchainEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model for behavioral description of system components"
    DTDFVocab:inputTo SysMLToolchainEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model for enhanced behavioral modeling with state transitions"
    DTDFVocab:inputTo MontiArcToolchainEnabler
]

instance SimulinkDynamicBehaviorModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for detailed dynamic behavior simulation and analysis"
    DTDFVocab:inputTo SimulinkToolchainEnabler
]

instance CppImplementationModel : DTDFVocab:Model [
    base:desc "C++ implementation model for low-level system logic and custom behavior descriptions"
    DTDFVocab:inputTo CppToolchainEnabler
]

instance JavaImplementationModel : DTDFVocab:Model [
    base:desc "Java implementation model for general-purpose system logic and integration layers"
    DTDFVocab:inputTo JavaToolchainEnabler
]

instance DigitalShadowAggregatedData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted data from Digital Shadow Reference Model (Fig. 1) for specific analytical purposes"
    DTDFVocab:fromData PhysicalSystemTemperatureDataTransmitted, PhysicalSystemPressureDataTransmitted,
                   PhysicalSystemVibrationDataTransmitted, PhysicalSystemPerformanceIndicatorDataTransmitted,
                   PhysicalSystemOperationalStateDataTransmitted
    DTDFVocab:inputTo DigitalShadowIntegrationEnabler
]

instance HeterogeneousModelConsolidationData : DTDFVocab:Data [
    base:desc "Consolidated data from multiple modeling notations (SysML, ADLs, simulation) for multi-stakeholder visualization"
    DTDFVocab:fromData DigitalShadowAggregatedData
    DTDFVocab:inputTo ModelIntegrationEnabler
]

// C11: Enablers
instance SysMLToolchainEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based toolchain supporting MBSE across requirements, functional, and logical architecture layers"
    DTDFVocab:enables SysMLMonitoringService, SysMLBehavioralAnalysisService
]

instance MontiArcToolchainEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc toolchain supporting component-connector architecture and automaton-based behavioral modeling"
    DTDFVocab:enables MontiArcBehavioralAnalysisService, MontiArcSimulationIntegrationService
]

instance SimulinkToolchainEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink toolchain for detailed dynamic behavior simulation and analysis"
    DTDFVocab:enables SimulinkDynamicAnalysisService, SimulinkValidationService
]

instance CppToolchainEnabler : DTDFVocab:Enabler [
    base:desc "C++ toolchain for low-level system implementation and custom logic execution"
    DTDFVocab:enables CppImplementationService
]

instance JavaToolchainEnabler : DTDFVocab:Enabler [
    base:desc "Java toolchain for general-purpose system logic and integration layers"
    DTDFVocab:enables JavaImplementationService
]

instance DigitalShadowIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Digital Shadow integration layer implementing one-way data flow from physical system to digital representation"
    DTDFVocab:enables DigitalShadowDataAggregationService
]

instance ModelIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Integration mechanism consolidating heterogeneous models from SysML, ADLs, and simulation tools"
    DTDFVocab:enables MultiPerspectiveVisualizationService
]

// C6: Services
instance SysMLMonitoringService : DTDFVocab:Service [
    base:desc "Real-time or periodic data aggregation and abstraction from physical system via SysML models"
    DTDFVocab:provides SysMLMonitoringInsight
]

instance SysMLBehavioralAnalysisService : DTDFVocab:Service [
    base:desc "Behavioral analysis using SysML state machines to model and analyze system behavior dynamically"
    DTDFVocab:provides SysMLBehavioralAnalysisInsight
]

instance MontiArcBehavioralAnalysisService : DTDFVocab:Service [
    base:desc "Behavioral analysis using MontiArc Automaton to model and analyze system behavior dynamically"
    DTDFVocab:provides MontiArcBehavioralAnalysisInsight
]

instance MontiArcSimulationIntegrationService : DTDFVocab:Service [
    base:desc "Integration of MontiArc automata with simulation tools for comprehensive behavioral modeling"
    DTDFVocab:provides MontiArcSimulationInsight
]

instance SimulinkDynamicAnalysisService : DTDFVocab:Service [
    base:desc "Dynamic behavior analysis using MathWorks Simulink for detailed system simulation"
    DTDFVocab:provides SimulinkDynamicAnalysisInsight
]

instance SimulinkValidationService : DTDFVocab:Service [
    base:desc "System validation through Simulink-based simulation and analysis"
    DTDFVocab:provides SimulinkValidationInsight
]

instance CppImplementationService : DTDFVocab:Service [
    base:desc "Low-level system implementation using C++ for custom logic execution"
    DTDFVocab:provides CppImplementationInsight
]

instance JavaImplementationService : DTDFVocab:Service [
    base:desc "General-purpose system logic implementation using Java"
    DTDFVocab:provides JavaImplementationInsight
]

instance DigitalShadowDataAggregationService : DTDFVocab:Service [
    base:desc "Data aggregation and abstraction from Digital Shadow Reference Model for specific analytical purposes"
    DTDFVocab:provides DigitalShadowDataInsight
]

instance MultiPerspectiveVisualizationService : DTDFVocab:Service [
    base:desc "Multi-perspective visualization consolidating models from SysML, ADLs, and simulation tools"
    DTDFVocab:provides MultiPerspectiveVisualizationInsight
]

