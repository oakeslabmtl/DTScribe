    base:desc "Dynamic behavior analysis insights from Simulink-based system simulation"
]

instance SimulinkValidationInsight : DTDFVocab:Insight [
    base:desc "System validation insights from Simulink-based simulation and analysis"
]

instance CppImplementationInsight : DTDFVocab:Insight [
    base:desc "Implementation insights from C++-based low-level system logic execution"
]

instance JavaImplementationInsight : DTDFVocab:Insight [
    base:desc "Implementation insights from Java-based general-purpose system logic"
]

