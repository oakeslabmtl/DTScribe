    base:desc "Real-time monitoring insights derived from SysML-based data aggregation and abstraction"
]

instance SysMLBehavioralAnalysisInsight : DTDFVocab:Insight [
    base:desc "Behavioral analysis insights from SysML state machine modeling of system components"
]

