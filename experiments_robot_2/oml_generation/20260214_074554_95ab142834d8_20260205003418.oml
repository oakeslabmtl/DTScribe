// C3: Physical sensing components
instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder on the permanent‑magnet synchronous motor, provides motor shaft angle r_M."
    DTDFVocab:producedData MotorEncoderAngleTransmitted
]

instance GearboxSecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder located behind the gearbox, provides output shaft angle r_out."
    DTDFVocab:producedData GearboxEncoderAngleTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor reading motor phase current I_M from the Siemens SINUMERIK 840D controller."
    DTDFVocab:producedData MotorCurrentTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorEncoderAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder
]

instance GearboxEncoderAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxSecondaryEncoder
]

instance MotorCurrentTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Data
instance MotorEncoderAngleData : DTDFVocab:Data [
    base:desc "Angle trace r_M measured by MotorMountedEncoder."
    DTDFVocab:fromData MotorEncoderAngleTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance GearboxEncoderAngleData : DTDFVocab:Data [
    base:desc "Angle trace r_out measured by GearboxSecondaryEncoder."
    DTDFVocab:fromData GearboxEncoderAngleTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Current trace I_M measured by MotorCurrentSensor."
    DTDFVocab:fromData MotorCurrentTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance SimulatedTorqueData : DTDFVocab:Data [
    base:desc "Torque trace τ simulated by Simulink friction models."
    DTDFVocab:inputTo DashboardEnabler
]

instance SimulatedAngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity trace ω simulated by Simulink models."
    DTDFVocab:inputTo DashboardEnabler
]

instance DerivedFrictionParametersData : DTDFVocab:Data [
    base:desc "Derived static, kinetic, and viscous friction parameters identified from measured and simulated data."
    DTDFVocab:inputTo DashboardEnabler
]

// C10: Models/Data (simulation and calculation models)
instance FrictionFreeSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink simulation of the motor‑gearbox system without friction."
    DTDFVocab:inputTo MatlabSimulinkEnabler
]

instance CoulombViscousSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink simulation including Coulomb and viscous friction models."
    DTDFVocab:inputTo MatlabSimulinkEnabler
]

instance TorqueCalculationModel : DTDFVocab:Model [
    base:desc "Executable model calculating torque from measured currents and speeds."
    DTDFVocab:inputTo MatlabSimulinkEnabler
]

instance FrictionParameterIdentificationModel : DTDFVocab:Model [
    base:desc "Data‑driven identification model that computes static, kinetic, and viscous friction parameters."
    DTDFVocab:inputTo MatlabSimulinkEnabler
]

// C11: Enablers
instance MatlabSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment used to run friction and torque models."
    DTDFVocab:enables FrictionIdentificationService, MotionControlUpdateService, ModelComparisonService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker providing low‑latency streaming of sensor traces to the digital shadow."
    DTDFVocab:enables RealTimeVisualizationService, ModelComparisonService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard for real‑time visualization of measured and simulated data."
    DTDFVocab:enables RealTimeVisualizationService, MotionControlUpdateService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of measured and simulated data traces on the dashboard."
    DTDFVocab:provides PositionalAccuracyImprovementInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Identification and quantification of static, kinetic and viscous friction in the gearbox."
    DTDFVocab:provides PositionalAccuracyImprovementInsight
]

instance ModelComparisonService : DTDFVocab:Service [
    base:desc "Comparison of simulated friction‑free models with measured data."
    DTDFVocab:provides PositionalAccuracyImprovementInsight
]

instance MotionControlUpdateService : DTDFVocab:Service [
    base:desc "Generation of friction parameters and automatic update of the robot motion‑control algorithm."
    DTDFVocab:provides UpdateMotionControlAlgorithmAction, PositionalAccuracyImprovementInsight
]

// C17: Insights
instance PositionalAccuracyImprovementInsight : DTDFVocab:Insight [
    base:desc "Improved positional accuracy achieved by adjusting the motion‑control algorithm with derived friction parameters."
]

// C17: Actions
instance UpdateMotionControlAlgorithmAction : DTDFVocab:Action [
    base:desc "Automatically updates the robot’s motion‑control algorithm based on identified friction parameters."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The shadow operates in real‑time, ingesting sensor streams as they arrive (continuous, live data) and updating friction model parameters continuously during robot operation. The processing chain (MQTT ingestion → processing → Simulink simulation) runs at the same rate as the incoming data, enabling on‑line identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow consisting of the asset (first axis), a purpose (FrictionDerivation), multiple DataTraces sourced from sensors, Processing components that execute simulation models, and a dashboard that presents both measured and simulated traces for friction analysis."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the operated phase of the robot, i.e., runtime operation where live data are collected and used for continuous friction model identification."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability from DataPoints to their generating Processing component and underlying simulation or calculation model; comparison of simulated friction‑free behavior with measured data to validate friction models; ability to continuously update white‑box and black‑box friction parameters as wear occurs."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted to the digital shadow over MQTT; the connection is one‑way (physical‑to‑virtual)."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation employs the Asset Administration Shell (AAS) as a standardized digital representation of the asset, SysML as a standardized modeling language, and MQTT as a widely adopted messaging protocol for industrial IoT data exchange."
]