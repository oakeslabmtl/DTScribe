// Sensing components
instance DataTraceSensor : DTDFVocab:SensingComponent [
    base:desc "Captures real‑time contextual data traces via the digital shadow mechanism"
]
instance SimulationOutputSensor : DTDFVocab:SensingComponent [
    base:desc "Captures simulation outputs from MathWorks Simulink models during simulation runs"
]
instance BuildMetricsSensor : DTDFVocab:SensingComponent [
    base:desc "Collects compiled code metrics (size, complexity) from C++ and Java implementations"
]

// Data transmitted
instance ContextualDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DataTraceSensor
]
instance SimulationOutputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationOutputSensor
]
instance BuildMetricsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildMetricsSensor
]

// Data
instance ContextualData : DTDFVocab:Data [
    base:desc "Real‑time contextual data captured by the digital shadow mechanism"
    DTDFVocab:fromData ContextualDataTransmitted
    DTDFVocab:inputTo ContextualAnalysisEnabler
]
instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Simulation outputs generated by Simulink models"
    DTDFVocab:fromData SimulationOutputDataTransmitted
    DTDFVocab:inputTo SimulationAnalysisEnabler
]
instance BuildMetricsData : DTDFVocab:Data [
    base:desc "Compiled code metrics extracted from C++ and Java source code"
    DTDFVocab:fromData BuildMetricsDataTransmitted
    DTDFVocab:inputTo BuildMetricsAnalysisEnabler
]

// Models
instance RequirementsModel : DTDFVocab:Model [
    base:desc "Requirements layer of the multilevel Model‑Based Systems Engineering (MBSE) model"
    DTDFVocab:inputTo ModelAlignmentEnabler
]
instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "Functional architecture layer represented using ACME and AADL"
    DTDFVocab:inputTo ModelAlignmentEnabler
]
instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Logical architecture layer represented using MontiArc and SysML interaction block diagrams (IBDs)"
    DTDFVocab:inputTo ModelAlignmentEnabler
]
instance ProductTechnicalModel : DTDFVocab:Model [
    base:desc "Product/technical layer represented using SysML components and connectors"
    DTDFVocab:inputTo ModelAlignmentEnabler
]
instance SystemStructureModel : DTDFVocab:Model [
    base:desc "System structure represented with architecture description languages (ADLs)"
    DTDFVocab:inputTo ModelAlignmentEnabler
]
instance BehaviorStateMachineModel : DTDFVocab:Model [
    base:desc "Behavioral dynamics encoded through state machines (SysML v1.7 and MontiArc Automaton models)"
    DTDFVocab:inputTo ModelAlignmentEnabler
]
instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulink-based simulation model for analytical and predictive capabilities"
    DTDFVocab:inputTo SimulationExecutionEnabler
]
instance AlgorithmicImplementationModel : DTDFVocab:Model [
    base:desc "Algorithmic implementations in C++ and Java for execution"
    DTDFVocab:inputTo AlgorithmExecutionEnabler
]

// Enablers
instance ContextualAnalysisEnabler : DTDFVocab:Enabler [
    base:desc "Analyzes contextual data streams via real‑time processing pipelines"
    DTDFVocab:enables ContextualInsightService
]
instance SimulationAnalysisEnabler : DTDFVocab:Enabler [
    base:desc "Ingests simulation outputs for validation and statistical analysis"
    DTDFVocab:enables SimulationInsightService
]
instance BuildMetricsAnalysisEnabler : DTDFVocab:Enabler [
    base:desc "Analyzes compiled code metrics to assess quality and maintenance risks"
    DTDFVocab:enables BuildMetricsInsightService
]
instance ModelAlignmentEnabler : DTDFVocab:Enabler [
    base:desc "Aligns and maps heterogeneous multilevel models across ACME, AADL, MontiArc, and SysML notations"
    DTDFVocab:enables ModelReviewService
]
instance SimulationExecutionEnabler : DTDFVocab:Enabler [
    base:desc "Executes Simulink simulation models and streams outputs to analytic components"
    DTDFVocab:enables SimulationExecutionService
]
instance AlgorithmExecutionEnabler : DTDFVocab:Enabler [
    base:desc "Deploys and executes C++ and Java algorithmic implementations in real‑time contexts"
    DTDFVocab:enables AlgorithmExecutionService
]

// Services
instance ContextualInsightService : DTDFVocab:Service [
    base:desc "Provides real‑time situational awareness insights derived from contextual data streams"
    DTDFVocab:provides ContextualInsight
]
instance SimulationInsightService : DTDFVocab:Service [
    base:desc "Delivers simulation validation insights and performance metrics"
    DTDFVocab:provides SimulationValidationInsight
]
instance BuildMetricsInsightService : DTDFVocab:Service [
    base:desc "Generates insights on code quality and maintainability from compiled metrics"
    DTDFVocab:provides BuildMetricsQualityInsight
]
instance ModelReviewService : DTDFVocab:Service [
    base:desc "Reviews model alignment across heterogeneous notations and provides alignment health insights"
    DTDFVocab:provides ModelAlignmentHealthInsight
]
instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Executes simulation models and publishes results for downstream analysis"
    DTDFVocab:provides SimulationExecutionResultInsight
]
instance AlgorithmExecutionService : DTDFVocab:Service [
    base:desc "Executes algorithmic implementations and monitors runtime behavior"
    DTDFVocab:provides AlgorithmRuntimeInsight
]

// Insights
instance ContextualInsight : DTDFVocab:Insight [
    base:desc "Real‑time situational awareness derived from contextual data streams"
]
instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Validation metrics comparing simulated outputs against nominal behavior"
]
instance BuildMetricsQualityInsight : DTDFVocab:Insight [
    base:desc "Assessment of code quality and maintainability based on compiled metrics"
]
instance ModelAlignmentHealthInsight : DTDFVocab:Insight [
    base:desc "Health status of model alignment across multiple notations"
]
instance SimulationExecutionResultInsight : DTDFVocab:Insight [
    base:desc "Results and performance metrics of simulation execution"
]
instance AlgorithmRuntimeInsight : DTDFVocab:Insight [
    base:desc "Runtime performance and diagnostic insights from algorithmic executions"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "During the development of a Digital Twin the system is modeled in a multi‑level MBSE hierarchy: a requirements level described with SysML; a functional architecture level also captured using SysML; a logical architecture level defined with Architecture Description Languages such as ACME, AADL or MontiArc; and a product (technical) level where detailed component interfaces and composition are specified by SysML Interaction Block Diagrams (IBDs). Transition between these abstraction levels is typically mediated by MBSE practices such as RFLP, OOSEM, SPES, or SMArDT, and the evolution of the models is maintained in a version‑controlled repository. Governance is implicit in the MBSE workflow, requiring integration of heterogeneous stakeholder perspectives."
]