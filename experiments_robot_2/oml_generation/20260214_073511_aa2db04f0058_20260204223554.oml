// C3: Physical sensing components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor position encoder measuring shaft rotation of the first axis motor"
    DTDFVocab:producedData MotorPositionEncoderDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary gearbox encoder measuring output rotation of the cycloidal gearbox"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor providing phase current I_M of the first axis motor"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorPositionEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Data instances
instance MotorAngleData : DTDFVocab:Data [
    base:desc "Angular position of motor shaft derived from encoder ticks"
    DTDFVocab:fromData MotorPositionEncoderDataTransmitted
    DTDFVocab:inputTo EnablerSimulink
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Angular position of gearbox output derived from secondary encoder"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo EnablerSimulink
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor phase current I_M"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo EnablerSimulink
]

instance TorqueTraceData : DTDFVocab:Data [
    base:desc "Torque trace τ computed from current and motor geometry"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo EnablerSimulink
]

instance AngularVelocityTraceData : DTDFVocab:Data [
    base:desc "Angular velocity ω derived from successive angle measurements"
    DTDFVocab:fromData MotorPositionEncoderDataTransmitted
    DTDFVocab:inputTo EnablerSimulink
]

instance AccelerationTraceData : DTDFVocab:Data [
    base:desc "Angular acceleration α derived from angular velocity"
    DTDFVocab:fromData MotorPositionEncoderDataTransmitted
    DTDFVocab:inputTo EnablerSimulink
]

// C11: Enablers (tooling and enablers)
instance EnablerMqtt : DTDFVocab:Enabler [
    base:desc "MQTT broker used for streaming live sensor data from the robot to the digital shadow"
    DTDFVocab:enables ServiceLiveDataStreaming
]

instance EnablerSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink engine executing friction and motion simulation models"
    DTDFVocab:enables ServiceFrictionIdentification, ServiceModelParameterUpdate, ServiceLiveDataStreaming
]

instance EnablerDashboard : DTDFVocab:Enabler [
    base:desc "Dashboard visualisation tool presenting measured and simulated data"
    DTDFVocab:enables ServiceDataVisualization
]

instance EnablerAAS : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for integrating SysML and Simulink models into the digital twin"
    DTDFVocab:enables ServiceModelParameterUpdate
]

// C6: Digital Twin Services
instance ServiceLiveDataStreaming : DTDFVocab:Service [
    base:desc "Real‑time streaming of sensor measurements (current I_M, encoder angles) via MQTT"
    DTDFVocab:provides InsightLiveDataAvailability
]

instance ServiceFrictionIdentification : DTDFVocab:Service [
    base:desc "Real‑time friction identification (static, kinetic, viscous) based on streamed data"
    DTDFVocab:provides InsightFrictionParameterExtraction, InsightFrictionLossDetection
]

instance ServiceModelParameterUpdate : DTDFVocab:Service [
    base:desc "Automatic update of control parameters and model coefficients to improve positioning accuracy"
    DTDFVocab:provides ActionAutomaticControlUpdate, InsightPositioningAccuracyImprovement
]

instance ServiceDataVisualization : DTDFVocab:Service [
    base:desc "Visualization of measured and simulated torque, velocity and position on a dashboard"
    DTDFVocab:provides InsightFrictionParameterExtraction, InsightFrictionLossDetection
]

// C17: Insights and Actions
instance InsightLiveDataAvailability : DTDFVocab:Insight [
    base:desc "Availability of live sensor data in the digital shadow"
]

instance InsightFrictionParameterExtraction : DTDFVocab:Insight [
    base:desc "Extraction of friction parameters (static, kinetic, viscous) from streamed data"
]

instance InsightFrictionLossDetection : DTDFVocab:Insight [
    base:desc "Detection of friction loss events during robot motion"
]

instance InsightPositioningAccuracyImprovement : DTDFVocab:Insight [
    base:desc "Enhanced positioning accuracy of the robot after model parameter updates"
]

instance ActionAutomaticControlUpdate : DTDFVocab:Action [
    base:desc "Automatic update of control parameters to compensate identified friction and improve positioning"
    DTDFVocab:IsAutomatic true
]

// C10: Models/Data (engineering and simulation models)
instance ModelSysMLBlockDefinition : DTDFVocab:Model [
    base:desc "SysML block definition diagram of the first axis motor, gearwheel and cycloidal gearbox"
    DTDFVocab:inputTo EnablerAAS
]

instance ModelSysMLInternalBlockDiagram : DTDFVocab:Model [
    base:desc "SysML internal block diagram detailing connections between motor, gearwheel and gearbox"
    DTDFVocab:inputTo EnablerAAS
]

instance ModelSimulinkFrictionless : DTDFVocab:Model [
    base:desc "MATLAB/Simulink frictionless model used as baseline for comparison"
    DTDFVocab:inputTo EnablerSimulink
]

instance ModelSimulinkCoulombViscous : DTDFVocab:Model [
    base:desc "Simulink model implementing Coulomb‑Viscous friction"
    DTDFVocab:inputTo EnablerSimulink
]

instance ModelSimulinkStribeck : DTDFVocab:Model [
    base:desc "Simulink model implementing Stribeck friction characteristics"
    DTDFVocab:inputTo EnablerSimulink
]

instance ModelSimulinkDahl : DTDFVocab:Model [
    base:desc "Simulink model implementing Dahl friction model"
    DTDFVocab:inputTo EnablerSimulink
]

instance ModelSimulinkLuGre : DTDFVocab:Model [
    base:desc "Simulink model implementing LuGre friction model"
    DTDFVocab:inputTo EnablerSimulink
]

instance ModelDataCalculation : DTDFVocab:Model [
    base:desc "Data calculation model converting current and angle data to torque, ω and α"
    DTDFVocab:inputTo EnablerSimulink
]

// C13: Physical components of the asset
instance ComponentMotor : DTDFVocab:Component [
    base:desc "Electric motor of the first axis of MABI MAX 100 robot"
]

instance ComponentGearwheel : DTDFVocab:Component [
    base:desc "Gearwheel directly coupled to the motor shaft"
]

instance ComponentCycloidalGearbox : DTDFVocab:Component [
    base:desc "Cycloidal gearbox reducing speed and increasing torque for the first axis"
]

instance ComponentFrictionShadow : DTDFVocab:Component [
    base:desc "Passive digital shadow representing friction behavior of the first axis"
]

// C14: Environment containing the components
instance RobotAxisEnvironment : DTDFVocab:Environment [
    base:contains ComponentMotor, ComponentGearwheel, ComponentCycloidalGearbox, ComponentFrictionShadow
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow does not send commands back to the robot"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time operation synchronized with the robot’s sensor update rate (up to the maximum axis speed of 75°/s)"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow consisting of Purpose (FrictionDerivation), Asset (MABI first axis), Sources (sensors, MQTT channels), Processing components (Simulation M, GW, GB), Models (engineering and simulation), and DataTraces (I_M, r_M, r_G, r_out, \u0302r_M, \u0302r_G, \u0302r_out)"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Engineering (SysML structural model), implementation (Simulink simulation and friction models), operational (continuous identification during robot runtime)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Combination of white‑box analytical friction models and black‑box data‑driven models; continuous re‑identification to capture wear, temperature and load effects; validation by comparing simulated outputs with measured data traces; full traceability via processing component provenance"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data transmitted over MQTT (TCP/IP) from the robot controller to the digital shadow; integration with AAS for asset description"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of Asset Administration Shell (AAS) as an Industry 4.0 standard, SysML modeling, and the Digital Shadow Reference Model (UML class diagram)"
]