// C3: Physical sensing components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution rotary encoder mounted directly on the motor shaft of the first vertical axis of the MABI100 industrial robot."
    DTDFVocab:producedData MotorAngleTransmitted
]

instance GearboxOutputEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution rotary encoder mounted on the gearbox output of the first vertical axis."
    DTDFVocab:producedData GearboxAngleTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring the electrical input current of the permanent‑magnet synchronous motor."
    DTDFVocab:producedData MotorCurrentTransmitted
]

// C4: Data transmitted via MQTT
instance MotorAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxOutputEncoder
]

instance MotorCurrentTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// New DataTransmitted instances for derived signals
instance MotorTorqueTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance GearboxVelocityTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxOutputEncoder
]

// C10: Models
instance SysMLMotorGearboxModel : DTDFVocab:Model [
    base:desc "SysML component‑connector diagram representing the motor, gearwheel, and cycloidal gearbox."
    DTDFVocab:inputTo SysMLModeler
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "Executable Simulink block for the motor, incorporating Coulomb, Viscous, and Stribeck friction models."
    DTDFVocab:inputTo SimulinkSimEngine
]

instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "Executable Simulink block for the gearwheel and cycloidal gearbox, incorporating Dahl and LuGre friction models."
    DTDFVocab:inputTo SimulinkSimEngine
]

// C4: Data (measured and derived)
instance MotorAngleData : DTDFVocab:Data [
    base:desc "Measured joint angle from the motor shaft encoder."
    DTDFVocab:inputTo MQTTIngestor
    DTDFVocab:fromData MotorAngleTransmitted
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Measured joint angle from the gearbox output encoder."
    DTDFVocab:inputTo MQTTIngestor
    DTDFVocab:fromData GearboxAngleTransmitted
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured electrical current of the motor."
    DTDFVocab:inputTo MQTTIngestor
    DTDFVocab:fromData MotorCurrentTransmitted
]

instance MotorTorqueData : DTDFVocab:Data [
    base:desc "Derived motor torque calculated from current and motor electrical parameters."
    DTDFVocab:inputTo SimulinkSimEngine
    DTDFVocab:fromData MotorCurrentTransmitted
]

instance MotorVelocityData : DTDFVocab:Data [
    base:desc "Derived motor angular velocity calculated from encoder angle derivatives."
    DTDFVocab:inputTo SimulinkSimEngine
    DTDFVocab:fromData MotorAngleTransmitted
]

instance GearboxVelocityData : DTDFVocab:Data [
    base:desc "Derived gearbox angular velocity calculated from encoder angle derivatives."
    DTDFVocab:inputTo SimulinkSimEngine
    DTDFVocab:fromData GearboxAngleTransmitted
]

instance AxisTorqueData : DTDFVocab:Data [
    base:desc "Derived overall axis torque derived from motor and gearbox dynamics."
    DTDFVocab:inputTo SimulinkSimEngine
    DTDFVocab:fromData MotorTorqueTransmitted
]

instance AxisVelocityData : DTDFVocab:Data [
    base:desc "Derived overall axis angular velocity."
    DTDFVocab:inputTo SimulinkSimEngine
    DTDFVocab:fromData GearboxVelocityTransmitted
]

instance SimulatedMotorAngleData : DTDFVocab:Data [
    base:desc "Simulated motor shaft angle from the Simulink motor model."
    DTDFVocab:inputTo SimulinkSimEngine
]

instance SimulatedGearboxAngleData : DTDFVocab:Data [
    base:desc "Simulated gearbox output angle from the Simulink gearbox model."
    DTDFVocab:inputTo SimulinkSimEngine
]

// C5: Enablers
instance MQTTIngestor : DTDFVocab:Enabler [
    base:desc "Ingests real‑time telemetry from the robot via MQTT."
    DTDFVocab:enables RealTimeDashboardService
]

instance SimulinkSimEngine : DTDFVocab:Enabler [
    base:desc "Executes Simulink blocks for motor and gearbox simulation."
    DTDFVocab:enables FrictionParameterUpdateService
]

instance SysMLModeler : DTDFVocab:Enabler [
    base:desc "Creates and manages SysML component-connector diagrams."
]

instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Provides a custom dashboard for visualisation of friction estimation and model comparison."
    DTDFVocab:enables RealTimeDashboardService
]

instance MBSEMethodEnabler : DTDFVocab:Enabler [
    base:desc "Implements RFLP and SMArDT MBSE methods for twin development."
    DTDFVocab:enables FrictionParameterUpdateService
]

// C6: Services
instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Real‑time dashboard that visualises friction estimation and model comparison."
    DTDFVocab:provides FrictionParameterInsight, WearForecastInsight
]

instance FrictionParameterUpdateService : DTDFVocab:Service [
    base:desc "Service performing continuous, multi‑physics‑aware identification of friction models."
    DTDFVocab:provides UpdateControllerParametersAction
]

// C17: Insights/Actions
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Updated friction parameters for white‑box and black‑box models derived during operation."
]

instance WearForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of wear and maintenance requirements based on friction parameter trends."
]

instance UpdateControllerParametersAction : DTDFVocab:Action [
    base:desc "Automatically updates the robot controller with new friction parameters."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time streaming of sensor data; the DT processes data at the same granularity as the robot controller updates, with no fixed period specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT consists of: an engineering model (SysML), processing component that consumes sensor traces, simulation and data‑calculation models, and outputs data traces that feed a real‑time dashboard. All components are orchestrated through the AAS and MQTT bus."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT is engineered during operation; it captures the as‑operated behaviour of the physical robot. Design and manufacturing phases are not directly represented, although the structural model is derived from the robot’s engineering data."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "White‑box models incorporate parameters dependent on load, temperature, and time; black‑box models are updated online using live data. Model validity is assessed by comparing simulated traces against measured sensor data, with a focus on low‑frequency drift and high‑frequency noise. Traceability of data generation ensures verifiable updates."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data is transmitted over MQTT (publish/subscribe) to the DT. The DT may expose data via Asset Administration Shells (AAS) for interoperability."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of ISO/IEC 30141 AAS, SysML (ISO/IEC 15288 for MBSE), and MBSE methods such as RFLP, SMArDT. The digital shadow conforms to the AAS reference model and MBSE guidelines."
]