// C3: Physical sensing components
instance JointCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Joint sensor measuring input current, sampled at high frequency for torque estimation"
    DTDFVocab:producedData CleanCurrentDataTransmitted
]

instance JointAngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Joint sensor measuring motor angular velocity, sampled at high frequency"
    DTDFVocab:producedData CleanAngularVelocityDataTransmitted
]

instance JointPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Joint sensor measuring first‑axis position, used for closed‑loop positioning"
    DTDFVocab:producedData CleanPositionDataTransmitted
]

instance JointTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Joint sensor measuring torque/force related to friction"
    DTDFVocab:producedData MeasuredTorqueDataTransmitted
]

instance JointLoadSensor : DTDFVocab:SensingComponent [
    base:desc "Joint sensor measuring operational load on the robot"
    DTDFVocab:producedData MeasuredLoadDataTransmitted
]

instance JointTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Joint sensor measuring temperature influencing friction"
    DTDFVocab:producedData MeasuredTemperatureDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance CleanCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointCurrentSensor
]

instance CleanAngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointAngularVelocitySensor
]

instance CleanPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointPositionSensor
]

instance MeasuredTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointTorqueSensor
]

instance MeasuredLoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointLoadSensor
]

instance MeasuredTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointTemperatureSensor
]

// C10: Data instances
instance CleanCurrentData : DTDFVocab:Data [
    base:desc "Low‑pass filtered current signal sent as JSON via MQTT"
    DTDFVocab:fromData CleanCurrentDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, ModelExecutionEnabler
]

instance CleanAngularVelocityData : DTDFVocab:Data [
    base:desc "Filtered angular velocity data transmitted through MQTT"
    DTDFVocab:fromData CleanAngularVelocityDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance CleanPositionData : DTDFVocab:Data [
    base:desc "Filtered axis position data transmitted through MQTT"
    DTDFVocab:fromData CleanPositionDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance MeasuredTorqueData : DTDFVocab:Data [
    base:desc "Measured torque values from joint torque sensor"
    DTDFVocab:fromData MeasuredTorqueDataTransmitted
    DTDFVocab:inputTo ModelExecutionEnabler
]

instance MeasuredLoadData : DTDFVocab:Data [
    base:desc "Measured load values from joint load sensor"
    DTDFVocab:fromData MeasuredLoadDataTransmitted
    DTDFVocab:inputTo ModelExecutionEnabler
]

instance MeasuredTemperatureData : DTDFVocab:Data [
    base:desc "Measured temperature values from joint temperature sensor"
    DTDFVocab:fromData MeasuredTemperatureDataTransmitted
    DTDFVocab:inputTo ModelExecutionEnabler
]

instance SimulatedFrictionData : DTDFVocab:Data [
    base:desc "Friction torque generated by the white‑box Simulink model"
    DTDFVocab:inputTo CompensationControlEnabler, StorageEnabler
]

instance PredictedFrictionData : DTDFVocab:Data [
    base:desc "Friction torque predicted by the neural‑network black‑box model"
    DTDFVocab:inputTo CompensationControlEnabler, StorageEnabler
]

// C10: Models
instance WhiteBoxFrictionModel : DTDFVocab:Model [
    base:desc "Simulink white‑box dynamic simulation of joint friction varying with load, temperature and payload"
    DTDFVocab:inputTo ModelExecutionEnabler
]

instance BlackBoxNeuralFrictionModel : DTDFVocab:Model [
    base:desc "Online‑trained neural network predicting joint friction from torque, load and temperature"
    DTDFVocab:inputTo ModelExecutionEnabler
]

// C11: Enablers
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Pre‑processing component applying low‑pass filter and routing data via MQTT to the AAS Executor"
    DTDFVocab:enables RealTimeFrictionMonitoringService
]

instance ModelExecutionEnabler : DTDFVocab:Enabler [
    base:desc "Execution environment for white‑box Simulink and black‑box neural models (FMU/NN runtime)"
    DTDFVocab:enables PredictiveMaintenanceService, SimulationResultStorageService
]

instance CompensationControlEnabler : DTDFVocab:Enabler [
    base:desc "Real‑time compensation controller that converts model friction predictions into actuator set‑points"
    DTDFVocab:enables ClosedLoopCompensationService
]

instance StorageEnabler : DTDFVocab:Enabler [
    base:desc "ThingsBoard digital shadow storage handling measured, simulated and reference traces"
    DTDFVocab:enables ParameterOptimizationService
]

// C6: Services
instance RealTimeFrictionMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of joint friction behavior for operator awareness"
    DTDFVocab:provides FrictionMonitoringInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance based on early fault detection from friction trends"
    DTDFVocab:provides FaultDetectionInsight
]

instance ClosedLoopCompensationService : DTDFVocab:Service [
    base:desc "Closed‑loop control service that issues compensation commands to joint actuators"
    DTDFVocab:provides CompensationAction
]

instance ParameterOptimizationService : DTDFVocab:Service [
    base:desc "Optimization service for machining parameters, e.g., CO₂ reduction via simulation experiments"
    DTDFVocab:provides CO2ReductionInsight
]

instance SimulationResultStorageService : DTDFVocab:Service [
    base:desc "Service that stores simulation outputs for later analysis and replay"
    DTDFVocab:provides SimulationResultInsight
]

// C17: Insights
instance FrictionMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight into current friction levels enabling operator decision making"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Early fault detection insight derived from abnormal friction patterns"
]

instance CO2ReductionInsight : DTDFVocab:Insight [
    base:desc "Insight on potential CO₂ emission reduction through optimized machining parameters"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight about simulation result quality and model validation status"
]

// C17: Actions
instance CompensationAction : DTDFVocab:Action [
    base:desc "Automatically send compensation torque set‑points to joint motor drives"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance JointMotorDriveActuator : DTDFVocab:ActingComponent [
    base:desc "Motor drive of each robot joint that receives real‑time compensation commands from the twin"
]

// C5: System under study (as a component)
instance IndustrialMachiningRobot : DTDFVocab:Component [
    base:desc "Industrial robot used for machining where joint friction varies with load, temperature and payload"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin operates under real‑time constraints: friction identification calculations must be performed within the control loop’s dead‑time, and continuous data streams from the physical robot are transmitted via MQTT to ThingsBoard, implying sub‑second latency and a granularity sufficient for online joint‑friction compensation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a model‑driven orchestration: a SysML structural model of the robot and executable Simulink simulation models (integrated via FMI) are combined in an Asset Administration Shell (AAS). An AAS Executor consumes live robot data (published over MQTT), runs the simulation models to compute friction estimates, stores the resulting data in the digital shadow on ThingsBoard, and pushes updates to a visualization dashboard, forming an automated pipeline that links data acquisition, model execution, and result dissemination."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "According to the MBSE discussion in Document 1, the Digital Twin lifecycle is organized into successive abstraction layers that mirror traditional system development phases: (1) requirements modeling, (2) functional‑architecture modeling, (3) logical‑architecture modeling, and (4) product/technical‑layer modeling. At each stage the twin is represented by appropriate artifacts – SysML requirement diagrams, SysML/internal‑block diagrams or ADL component‑connector diagrams for functional and logical structures, and concrete simulation models (e.g., Simulink) or executable code for the technical layer. Transitions between stages are managed by the MBSE process, which refines and refactors higher‑level models into lower‑level ones while preserving traceability links (the “originates‑from” association described in Document 2). Governance is achieved through integration of heterogeneous stakeholder views and consistent use of the reference model, ensuring that each phase conforms to the same underlying ontology."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by combining verified white‑box Simulink models with calibrated black‑box neural networks, while traceability of each data trace to its generating processing component and underlying model is maintained via the ‘originates‑from’ relation; validation includes runtime comparison of simulated and measured values, uncertainty quantification is addressed through continuous model updating, and quality assurance relies on verification of SysML‑to‑simulation transformations and real‑time dead‑time analysis."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The data‑transport layer is built on the MQTT protocol (implemented with Mosquitto) using a publish‑subscribe topology. Sensor data are encapsulated as JSON messages and published on hierarchical topics, allowing clients to subscribe to the needed streams. The MQTT broker mediates communication between the preprocessing component, the AAS Executor, and the ThingsBoard IoT platform, which consumes the same MQTT streams for storage and visualization. No explicit bandwidth, latency, redundancy or security specifications are provided in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration relies on standardized IIoT protocols and standards: MQTT is used for sensor data acquisition, ThingsBoard serves as the IoT platform for data storage and visualization, the Asset Administration Shell provides semantic interoperability, and FMI enables coupling of SysML structural models with Simulink behavioral models. This stack allows the digital twin to interoperate with other enterprise systems and to be extended by additional applications via the central data memory."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Documents 4 and 1 reference several established industry modelling standards that are adopted in the described Digital Twin approach: the Systems Modeling Language (SysML) for requirements and internal‑block diagrams, the Architecture Analysis & Design Language (AADL) for component‑level architecture, the ACME ADL for component‑connector specifications, and MontiArc/ MontiArcAutomaton for combined structural and behavioral models. The SMArDT framework (Document 4) is also cited as a modelling approach for automotive software testing, indicating compliance with domain‑specific standards. The use of a reference model with an explicit conformance relation (Document 2) enforces adherence to these standards across concrete realizations, but no specific certification schemes or interoperability protocols (e.g., OPC UA, MQTT) are mentioned for the twin itself."
]