// C1: Physical sensing components - Motor Encoder
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder providing real-time angular position measurements for the robot's first axis motor drive (two per drive axis to reduce positional uncertainty)"
]

// C2: Physical sensing components - Secondary Encoder
instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder providing secondary angular position measurements for the robot's first axis drive train to detect elasticity and reduce backlash"
]

// C3: Physical-to-virtual interaction - Motor Current Data Transmission
instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder,
    DTDFVocab:producedFrom SiemensSinumerik840DCNCController
]

// C4: Physical-to-virtual interaction - Angular Position Data Transmission
instance AngularPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder,
    DTDFVocab:producedFrom SecondaryEncoder
]

// C5: Physical-to-virtual interaction - Torque Data Transmission
instance TorqueData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SiemensSinumerik840DCNCController
]

// C6: Physical-to-virtual interaction - Angular Velocity Data Transmission
instance AngularVelocityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SiemensSinumerik840DCNCController
]

// C7: Physical-to-virtual interaction - Acceleration Data Transmission
instance AccelerationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SiemensSinumerik840DCNCController
]

// C8: Data Traces - Motor Current Trace
instance MotorCurrentTrace : DTDFVocab:Data [
    base:desc "Real-time motor current trace (I_M) streamed from MABI MAX 100 robot's first axis via MQTT protocol"
    DTDFVocab:fromData MotorCurrentData
    DTDFVocab:inputTo SimulationProcessingComponent
]

// C9: Data Traces - Angular Position Trace
instance AngularPositionTrace : DTDFVocab:Data [
    base:desc "Real-time angular position trace (θ_M) from encoders for the robot's first axis"
    DTDFVocab:fromData AngularPositionData
    DTDFVocab:inputTo SimulationProcessingComponent
]

// C10: Data Traces - Torque Trace
instance TorqueTrace : DTDFVocab:Data [
    base:desc "Real-time torque trace (τ_M) derived from motor current via known motor constants"
    DTDFVocab:fromData TorqueData
    DTDFVocab:inputTo SimulationProcessingComponent
    DTDFVocab:inputTo FrictionAnalysisDashboard
]

// C11: Data Traces - Angular Velocity Trace
instance AngularVelocityTrace : DTDFVocab:Data [
    base:desc "Real-time angular velocity trace (ω) from CNC controller for the robot's first axis"
    DTDFVocab:fromData AngularVelocityData
    DTDFVocab:inputTo SimulationProcessingComponent
    DTDFVocab:inputTo FrictionAnalysisDashboard
]

// C12: Data Traces - Acceleration Trace
instance AccelerationTrace : DTDFVocab:Data [
    base:desc "Real-time acceleration trace derived from velocity data for the robot's first axis"
    DTDFVocab:fromData AccelerationData
    DTDFVocab:inputTo SimulationProcessingComponent
]

// C13: Data Traces - Simulated Torque Trace (r̂_M)
instance SimulatedTorqueTrace : DTDFVocab:Data [
    base:desc "Simulated torque trace (τ̂_M) generated by friction models for comparison with measured data"
    DTDFVocab:fromData SimulationOutputTrace
    DTDFVocab:inputTo FrictionAnalysisDashboard
]

// C14: Data Traces - Simulated Angular Velocity Trace (ω̂)
instance SimulatedAngularVelocityTrace : DTDFVocab:Data [
    base:desc "Simulated angular velocity trace (ω̂) generated by friction models for comparison with measured data"
    DTDFVocab:fromData SimulationOutputTrace
    DTDFVocab:inputTo FrictionAnalysisDashboard
]

// C15: Data Traces - Simulated Angular Position Trace (θ̂)
instance SimulatedAngularPositionTrace : DTDFVocab:Data [
    base:desc "Simulated angular position trace (θ̂) generated by friction models for comparison with measured data"
    DTDFVocab:fromData SimulationOutputTrace
    DTDFVocab:inputTo FrictionAnalysisDashboard
]

// C16: Engineering Models - SysML BDD for First Axis
instance FirstAxisBDD : DTDFVocab:Model [
    base:desc "SysML Block Definition Diagram modeling the structural components of the robot's first axis (motor, gearbox, cycloidal gear) and their interconnections"
    DTDFVocab:inputTo SimulationProcessingComponent
]

// C17: Engineering Models - SysML IBD for First Axis
instance FirstAxisIBD : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram defining rotational torque/velocity and electrical current flow definitions for the robot's first axis components"
    DTDFVocab:inputTo SimulationProcessingComponent
]

// C18: Simulation Models - Coulomb-Viscous Friction Model
instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model implementing Coulomb-Viscous friction behavior for the robot's first axis drive train"
    DTDFVocab:inputTo SimulationProcessingComponent
]

// C19: Simulation Models - Stribeck Friction Model
instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model implementing Stribeck friction behavior for the robot's first axis"
    DTDFVocab:inputTo SimulationProcessingComponent
]

// C20: Simulation Models - Dahl Friction Model
instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model implementing Dahl friction behavior for the robot's first axis"
    DTDFVocab:inputTo SimulationProcessingComponent
]

// C21: Simulation Models - LuGre Friction Model
instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model implementing LuGre friction behavior for the robot's first axis"
    DTDFVocab:inputTo SimulationProcessingComponent
]

// C22: Simulation Models - Ideal System Behavior Model
instance IdealSystemBehaviorModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model representing ideal torque/velocity behavior without friction for the robot's first axis"
    DTDFVocab:inputTo SimulationProcessingComponent
]

// C23: Simulation Processing Components - Motor Simulation Class
instance MotorSimulationComponent : DTDFVocab:Model [
    base:desc "Simulation class in digital shadow's UML model processing motor current input and producing simulated torque/velocity outputs"
    DTDFVocab:inputTo SimulationProcessingComponent
]

// C24: Simulation Processing Components - Gearbox Simulation Class
instance GearboxSimulationComponent : DTDFVocab:Model [
    base:desc "Simulation class in digital shadow's UML model processing gearbox input and producing simulated torque/velocity outputs"
    DTDFVocab:inputTo SimulationProcessingComponent
]

// C25: Simulation Processing Components - Cycloidal Gear Simulation Class
instance CycloidalGearSimulationComponent : DTDFVocab:Model [
    base:desc "Simulation class in digital shadow's UML model processing cycloidal gear input and producing simulated torque/velocity outputs"
    DTDFVocab:inputTo SimulationProcessingComponent
]

// C26: Processing Components - Simulation Processing Component
instance SimulationProcessingComponent : DTDFVocab:Enabler [
    base:desc "Digital shadow processing component that consumes input data traces (I_M, torque, angular velocity) and produces simulated torque/velocity outputs for friction analysis"
    DTDFVocab:enables FrictionAnalysisService
    DTDFVocab:enables ModelRefinementService
]

// C27: Enablers - MQTT Protocol
instance MQTTProtocol : DTDFVocab:Enabler [
    base:desc "MQTT protocol used for streaming real-time sensor data (motor current, angular position) from MABI MAX 100 robot's first axis to digital shadow"
    DTDFVocab:enables DataStreamingService
]

// C28: Enablers - Siemens Sinumerik 840D CNC Controller
instance Sinumerik840DCNCController : DTDFVocab:Enabler [
    base:desc "Siemens SINUMERIK 840D CNC controller providing access to motor current (I_M) and derived torque (τ_M) for the robot's first axis"
    DTDFVocab:enables DataAcquisitionService
]

// C29: Enablers - MATLAB Simulink Simulation Environment
instance MATLABSimulinkEnvironment : DTDFVocab:Enabler [
    base:desc "MathWorks MATLAB Simulink environment hosting friction behavior models (Coulomb-Viscous, Stribeck, Dahl, LuGre) and ideal system simulations"
    DTDFVocab:enables SimulationProcessingComponent
]

// C30: Enablers - Asset Administration Shell (AAS)
instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Digital twin's Asset Administration Shell integrating structural and behavioral models with data traces for semantic understanding"
    DTDFVocab:enables ModelIntegrationService
]

// C31: Services - Friction Analysis Service
instance FrictionAnalysisService : DTDFVocab:Service [
    base:desc "Real-time friction analysis service providing continuous identification and refinement of friction models (white-box/black-box) using live operational data"
    DTDFVocab:provides FrictionCharacteristicsInsight
    DTDFVocab:provides ModelAccuracyInsight
]

// C32: Services - Model Refinement Service
instance ModelRefinementService : DTDFVocab:Service [
    base:desc "Service enabling continuous identification and refinement of friction models through iterative comparison of measured vs. simulated data traces"
    DTDFVocab:provides ModelParameterAdjustmentAction
    DTDFVocab:provides ModelValidationAction
]

// C33: Services - Data Streaming Service
instance DataStreamingService : DTDFVocab:Service [
    base:desc "Service aggregating real-time sensor data (motor current, torque, angular velocity) from MABI MAX 100 robot's first axis via MQTT protocol"
    DTDFVocab:provides DataTraceAggregationAction
]

// C34: Services - Model Integration Service
instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Service linking structural models (SysML BDD/IBD) with behavioral models and data traces for semantic understanding of friction behavior"
    DTDFVocab:provides ModelTraceabilityAction
]

// C35: Services - Visualization Dashboard Service
instance FrictionAnalysisDashboard : DTDFVocab:Service [
    base:desc "Unified dashboard visualizing live data traces (measured vs. simulated) and friction analysis results for robot motion optimization"
    DTDFVocab:provides VisualizationInsight
    DTDFVocab:provides ControlParameterAdjustmentAction
]

// C36: Insights - Friction Characteristics Insight
instance FrictionCharacteristicsInsight : DTDFVocab:Insight [
    base:desc "Real-time detection of static, kinetic, and viscous friction characteristics in the robot's first axis drive train"
]

// C37: Insights - Model Accuracy Insight
instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Continuous identification of friction model accuracy through comparison of measured vs. simulated data traces"
]

// C38: Actions - ModelParameterAdjustmentAction
instance ModelParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of friction model parameters based on real-time data comparison"
    DTDFVocab:IsAutomatic true
]

// C39: Actions - ModelValidationAction
instance ModelValidationAction : DTDFVocab:Action [
    base:desc "Validation of friction models through iterative comparison of measured vs. simulated data traces"
    DTDFVocab:IsAutomatic true
]

// C40: Actions - ControlParameterAdjustmentAction
instance ControlParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Dynamic adjustment of robot control parameters based on friction analysis insights"
    DTDFVocab:IsAutomatic true
]

// C41: Actions - DataTraceAggregationAction
instance DataTraceAggregationAction : DTDFVocab:Action [
    base:desc "Aggregation of real-time sensor data traces (I_M, torque, angular velocity) from the robot's first axis"
    DTDFVocab:IsAutomatic true
]

// C42: Actions - VisualizationInsight
instance VisualizationInsight : DTDFVocab:Action [
    base:desc "Real-time visualization of friction losses and model accuracy on the dashboard"
    DTDFVocab:IsAutomatic true
]

// C43: Data Transmitted - Simulation Output Trace
instance SimulationOutputTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationProcessingComponent
]

// C44: Environment - Robot First Axis System
instance RobotFirstAxisSystem : DTDFVocab:Environment [
    base:contains MotorEncoder,
    base:contains SecondaryEncoder,
    base:contains FirstAxisBDD,
    base:contains FirstAxisIBD,
    base:contains SimulationProcessingComponent,
    base:contains CoulombViscousFrictionModel,
    base:contains StribeckFrictionModel,
    base:contains DahlFrictionModel,
    base:contains LuGreFrictionModel,
    base:contains IdealSystemBehaviorModel,
    base:contains MotorSimulationComponent,
    base:contains GearboxSimulationComponent,
    base:contains CycloidalGearSimulationComponent,
    base:contains MotorCurrentTrace,
    base:contains AngularPositionTrace,
    base:contains TorqueTrace,
    base:contains AngularVelocityTrace,
    base:contains AccelerationTrace,
    base:contains SimulatedTorqueTrace,
    base:contains SimulatedAngularVelocityTrace,
    base:contains SimulatedAngularPositionTrace
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twinning time scale is real-time, with data acquisition and processing occurring at the frequency of sensor streams (e.g., motor current and angle updates). The digital shadow dynamically exchanges friction models during operation, ensuring real-time synchronization between physical and virtual representations. The primary focus is on operational-time-scale analysis, with no explicit mention of offline or batch processing phases."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation consists of a **single digital shadow** focused on the first axis of the MABI MAX 100 robot. It integrates:
  - The physical system (first axis: motor, gearbox, cycloidal gear).
  - A set of engineering, simulation, and data calculation models (SysML BDD/IBD, Simulink models).
  - A processing component (Simulation_M, Simulation_GW, Simulation_GB) that dynamically exchanges friction models.
  - A dashboard for visualization and analysis.
  The constellation is centralized and purpose-driven, with no mention of external DTs or horizontal integration with other systems."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow operates during the **operated** stage of the system’s lifecycle, specifically targeting the **as-operated** representation of the robot’s first axis. It does not cover the **as-designed** or **as-manufactured** stages, as these would require structural and manufacturing-specific models. The primary purpose is to analyze friction behavior in real-time during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The fidelity and validity considerations include:
  - **Data Traceability**: All data traces (measured/simulated) are linked to their sources (e.g., sensor channels, model inputs) via metadata, ensuring transparency in friction model derivation.
  - **Model Validation**: Simulation models (Simulink) are validated against live operational data to identify discrepancies (e.g., friction losses) between measured and simulated torque/velocity traces.
  - **Uncertainty Handling**: The use of two encoders per drive axis (motor and secondary) reduces positional uncertainty and backlash, improving the accuracy of friction measurements.
  - **Verification/Validation**: No explicit mention of formal verification or validation frameworks (e.g., ISO/IEC standards), but the methodology relies on iterative comparison between measured and simulated data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin’s technical connection to the physical system relies on:
  - **Data Acquisition**: MQTT protocol for streaming sensor data (motor current I_M, output angle) from the Siemens SINUMERIK 840D CNC controller.
  - **Model Integration**: Asset Administration Shells (AAS) for linking digital shadow components (models, data traces) to the physical system’s structure (SysML BDD/IBD).
  - **Real-Time Processing**: Live data is processed in real-time by simulation models (Simulink) to generate friction analysis outputs, ensuring synchronization with the physical system."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin incorporates:
  - **SysML** for structural modeling (BDD/IBD).
  - **MathWorks MATLAB Simulink** for simulation models.
  - **MQTT** for data acquisition.
  - **Asset Administration Shells (AAS)** for digital shadow integration.
  No explicit mention of broader standards (e.g., ISO 4180 for digital twins, IEC 62264 for industrial automation), but the methodology aligns with MBSE and digital shadow reference models (e.g., [15])."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The digital twin’s security and safety considerations include:
  - **Data Security**: MQTT protocol for streaming sensor data, though no explicit mention of encryption or access controls.
  - **Safety**: The robot’s safety cell restricts the working range to [-90°, 90°], and the maximum speed is 75°/s. The digital shadow does not enable remote operation or autonomous intervention in the physical system, mitigating safety risks.
  - **Operational Safety**: The focus is on improving motion accuracy via friction modeling, with no mention of autonomous decision-making or emergency interventions."
]