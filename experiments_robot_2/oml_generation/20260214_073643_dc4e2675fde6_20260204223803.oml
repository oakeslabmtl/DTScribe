// C3: Physical sensing components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the permanent‑magnet synchronous motor (measures motor shaft angle r_M)"
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder located behind the gearwheel gearbox (measures gearbox output angle r_G)"
    DTDFVocab:producedData GearboxPositionDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring the input current I_M of the motor"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Data objects
instance MotorAngleData : DTDFVocab:Data [
    base:desc "Measured motor shaft angle r_M from motor position encoder"
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Measured gearbox output angle r_G from secondary encoder"
    DTDFVocab:fromData GearboxPositionDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured input current I_M from motor current sensor"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque τ calculated from measured current I_M and motor angle"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo DataCalculationEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω calculated from motor angle r_M time derivative"
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo DataCalculationEnabler
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration α calculated from motor angle r_M second derivative"
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo DataCalculationEnabler
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker for live streaming of sensor data"
    DTDFVocab:enables DashboardVisualizationService, DataStorageService
]

instance DataCalculationEnabler : DTDFVocab:Enabler [
    base:desc "Computation environment (e.g., MATLAB functions) that processes raw sensor data to produce derived torque, velocity, and acceleration"
    DTDFVocab:enables FrictionIdentificationService, DataComparisonService, FrictionParameterGenerationService
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for executable simulation models of motor, gearwheel and gearbox"
    DTDFVocab:enables SimulationExecutionService
]

instance WebDashboard : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard for operator visualization of measured and simulated data"
    DTDFVocab:enables DashboardVisualizationService, FrictionInsightService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for integration of models and data within the digital twin ecosystem"
    DTDFVocab:enables EngineeringModelIntegrationService
]

// C6: Services
instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of measured and simulated torque/velocity traces on the web dashboard"
    DTDFVocab:provides InsightFrictionTrends, InsightModelMeasurementDeviation
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of static, kinetic and viscous friction parameters within the gearbox"
    DTDFVocab:provides InsightFrictionParameters
]

instance DataComparisonService : DTDFVocab:Service [
    base:desc "Comparison of simulated versus measured torque and velocity traces"
    DTDFVocab:provides InsightModelMeasurementDeviation
]

instance FrictionParameterGenerationService : DTDFVocab:Service [
    base:desc "Generation of friction parameters used to adjust the robot controller for improved motion accuracy"
    DTDFVocab:provides ActionAdjustRobotController, ActionGenerateFrictionParameters
]

// C17: Insights
instance InsightFrictionTrends : DTDFVocab:Insight [
    base:desc "Operators receive insight into trends of static, kinetic and viscous friction over time"
]

instance InsightModelMeasurementDeviation : DTDFVocab:Insight [
    base:desc "Insight into deviations between simulated and measured torque/velocity data"
]

instance InsightFrictionParameters : DTDFVocab:Insight [
    base:desc "Derived friction parameters (static, kinetic, viscous) identified from data"
]

// C17: Actions
instance ActionAdjustRobotController : DTDFVocab:Action [
    base:desc "Adjust the robot controller using the identified friction parameters to improve motion accuracy"
    DTDFVocab:IsAutomatic true
]

instance ActionGenerateFrictionParameters : DTDFVocab:Action [
    base:desc "Generate new friction parameter values for the gearbox model"
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance EngineeringModelSysML : DTDFVocab:Model [
    base:desc "SysML Block Definition Diagram and Internal Block Diagram describing the structural composition of the first axis"
    DTDFVocab:inputTo AssetAdministrationShell
]

instance SimulationModelMotor : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the permanent‑magnet synchronous motor"
    DTDFVocab:inputTo MATLABSimulink
]

instance SimulationModelGearboxFrictionless : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the gearbox without friction"
    DTDFVocab:inputTo MATLABSimulink
]

instance SimulationModelGearboxCoulombViscous : DTDFVocab:Model [
    base:desc "MATLAB/Simulink gearbox model with Coulomb‑Viscous friction"
    DTDFVocab:inputTo MATLABSimulink
]

instance SimulationModelGearboxStribeck : DTDFVocab:Model [
    base:desc "MATLAB/Simulink gearbox model with Stribeck friction"
    DTDFVocab:inputTo MATLABSimulink
]

instance DataCalculationModelTorque : DTDFVocab:Model [
    base:desc "Processing component that derives torque τ from measured current I_M and motor angle"
    DTDFVocab:inputTo DataCalculationEnabler
]

instance DataCalculationModelVelocity : DTDFVocab:Model [
    base:desc "Processing component that derives angular velocity ω from motor angle r_M"
    DTDFVocab:inputTo DataCalculationEnabler
]

instance DataCalculationModelAcceleration : DTDFVocab:Model [
    base:desc "Processing component that derives angular acceleration α from motor angle r_M"
    DTDFVocab:inputTo DataCalculationEnabler
]

// Additional placeholder services for completeness
instance DataStorageService : DTDFVocab:Service [
    base:desc "Stores streamed sensor data in the digital shadow"
    DTDFVocab:provides InsightDataArchiving
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Executes MATLAB/Simulink simulation models"
    DTDFVocab:provides InsightSimulationResults
]

instance FrictionInsightService : DTDFVocab:Service [
    base:desc "Provides friction‑related insights to the dashboard"
    DTDFVocab:provides InsightFrictionParameters
]

instance EngineeringModelIntegrationService : DTDFVocab:Service [
    base:desc "Integrates engineering models into the Asset Administration Shell"
    DTDFVocab:provides InsightModelIntegration
]

// Additional insights for placeholders
instance InsightDataArchiving : DTDFVocab:Insight [
    base:desc "Insight that sensor data have been archived in the digital twin"
]

instance InsightSimulationResults : DTDFVocab:Insight [
    base:desc "Insight into results generated by simulation models"
]

instance InsightModelIntegration : DTDFVocab:Insight [
    base:desc "Insight that engineering models are integrated and available in the AAS"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is passive; no data or commands are sent from the virtual model back to the robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time operation synchronized with the robot’s motion; data are acquired and processed at the robot’s sampling rate (implicitly tied to the live MQTT feed) to enable on‑line friction identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A digital shadow composed of (1) the physical asset (first robot axis), (2) engineering models (SysML), (3) simulation models (Simulink), (4) processing components that consume measured data traces and produce simulated traces, (5) data storage for DataTraces, and (6) a visualization dashboard, all linked through the Digital Shadow Reference Model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each DataTrace back to its source and processing component ensures model fidelity; validation is performed by comparing simulated friction‑compensated outputs with measured reference data to assess accuracy of white‑box and black‑box friction models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Live data are transmitted from the robot to the digital shadow over MQTT; the Asset Administration Shell (AAS) provides semantic linking of data and models."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) as a standard for digital twin integration and SysML as a modeling standard; reference to IEC‑62304 is not made, but AAS and SysML are explicitly employed."
]