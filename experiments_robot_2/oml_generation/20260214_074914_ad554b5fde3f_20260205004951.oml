instance PhysicalSystemStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors capturing physical system states for data aggregation"
    DTDFVocab:producedData PhysicalSystemStateDataTransmitted
]

instance PhysicalSystemStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemStateSensor
]

instance PhysicalSystemStateData : DTDFVocab:Data [
    base:desc "Physical system states with contextual data traces aggregated and abstracted for specific purposes"
    DTDFVocab:fromData PhysicalSystemStateDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler, JavaEnabler, RFLPMethodology, OOSEMMethodology, SPESMethodology, SMArDTMethodology, MBSEMethodology, ACMEEnabler, AADLEnabler, MontiArcEnabler, SysMLIBDSEnabler
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation tool for analytical models"
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for system implementation"
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for system implementation"
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP methodology for managing system complexity"
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for integrating heterogeneous stakeholders"
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for system engineering"
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for system complexity management"
]

instance MBSEMethodology : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering (MBSE) methodology"
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME architecture description language for component & connector perspectives"
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL architecture description language for component & connector perspectives"
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc architecture description language for component & connector perspectives"
]

instance SysMLIBDSEnabler : DTDFVocab:Enabler [
    base:desc "SysML IBDs for component & connector architectures"
]

instance SysMLModel : DTDFVocab:Model [
    base:desc "SysML for multi-level abstraction modeling (requirements, functional, logical, product/technical layers)"
    DTDFVocab:inputTo MBSEMethodology
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME architecture description for component & connector perspectives"
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL architecture description for component & connector perspectives"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description for component & connector perspectives"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLIBDsModel : DTDFVocab:Model [
    base:desc "SysML IBDs for component & connector architectures"
    DTDFVocab:inputTo SysMLIBDSEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavioral modeling"
    DTDFVocab:inputTo MBSEMethodology
]

instance SimulationAnalyticalModel : DTDFVocab:Model [
    base:desc "Simulation-based analytical models using MathWorks Simulink"
    DTDFVocab:inputTo SimulinkEnabler
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adheres to industry standards including SysML for Model-Based Systems Engineering (MBSE), ACME, AADL, MontiArc, and SysML Internal Block Diagrams (IBDs) as architecture description languages (ADLs) for component & connector modeling, ensuring interoperability and structured system representation across development phases."
]