// Component instances

instance MABIMAX100Robot : DTDFVocab:Component [
    base:desc "Six‑axis serial industrial robot with high‑precision, high‑speed performance, driven by Siemens SINUMERIK 840D SL controller."
]

instance FirstAxisPMSMMotor : DTDFVocab:ActingComponent [
    base:desc "High‑speed permanent‑magnet synchronous motor driving the first axis, controlled by Siemens SINUMERIK 840D SL, nominal speed limit |q̇max| = 75°/s."
]

// Sensing components

instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑shaft encoder mounted on the PMSM shaft, providing 0.1 mm positional accuracy and 0.06 mm repeatability."
    DTDFVocab:producedData MotorShaftPositionTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located after the reduction gearbox, providing 0.1 mm positional accuracy and 0.06 mm repeatability."
    DTDFVocab:producedData GearboxPositionTransmitted
]

// Data transmitted instances

instance MotorShaftPositionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxPositionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// Data instances

instance Joint1MotorShaftPositionData : DTDFVocab:Data [
    base:desc "Joint 1 motor shaft positional data stream received by the PLC and forwarded to the Digital Twin."
    DTDFVocab:fromData MotorShaftPositionTransmitted
    DTDFVocab:inputTo SimulinkEngine
    DTDFVocab:inputTo SysMLModeler
]

instance Joint1GearboxPositionData : DTDFVocab:Data [
    base:desc "Joint 1 gearbox positional data stream received by the PLC and forwarded to the Digital Twin."
    DTDFVocab:fromData GearboxPositionTransmitted
    DTDFVocab:inputTo SimulinkEngine
    DTDFVocab:inputTo MontiArcModeler
]

// Models

instance KinematicDynamicsModel : DTDFVocab:Model [
    base:desc "Analytical kinematic and dynamic model of the MABI MAX 100 implemented in Simulink."
    DTDFVocab:inputTo SimulinkEngine
]

instance FrictionModel : DTDFVocab:Model [
    base:desc "White‑box friction formulation incorporating motor and gearbox characteristics."
    DTDFVocab:inputTo SimulinkEngine
]

instance SurrogateModel : DTDFVocab:Model [
    base:desc "Black‑box surrogate model trained on live sensor streams to emulate joint behaviour."
    DTDFVocab:inputTo SimulinkEngine
]

// Enablers

instance SysMLModeler : DTDFVocab:Enabler [
    base:desc "SysML model‑based systems engineering tool capturing requirements and architecture."
    DTDFVocab:enables RealTimeMonitoringService
]

instance MontiArcModeler : DTDFVocab:Enabler [
    base:desc "MontiArc tool for component‑connector structure and behavioral automata modeling."
    DTDFVocab:enables RealTimeMonitoringService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment that simulates the hybrid model stack of the Digital Twin."
    DTDFVocab:enables RealTimeMonitoringService
]

instance CppCodeGenerator : DTDFVocab:Enabler [
    base:desc "C++ code generation tool for deploying simulation models."
    DTDFVocab:enables RealTimeMonitoringService
]

instance JavaCodeGenerator : DTDFVocab:Enabler [
    base:desc "Java code generation tool for deploying simulation models."
    DTDFVocab:enables RealTimeMonitoringService
]

// Service

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service that aggregates joint states and provides real‑time monitoring to supervisory software."
    DTDFVocab:provides JointPositionInsight, TorqueControlAction
]

// Insights

instance JointPositionInsight : DTDFVocab:Insight [
    base:desc "Insight into joint 1 position accuracy, repeatability, and deviation from commanded path."
]

// Actions

instance TorqueControlAction : DTDFVocab:Action [
    base:desc "Action to adjust motor torque via SINUMERIK controller based on feedback from the Digital Twin."
    DTDFVocab:IsAutomatic true
]

// Environment

instance MABIMAX100Environment : DTDFVocab:Environment [
    base:contains MABIMAX100Robot, FirstAxisPMSMMotor, MotorShaftEncoder, GearboxEncoder
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Digital Twin orchestration follows a multi‑level MBSE approach. The physical system is modeled at requirements, functional, logical and product/technical layers using SysML, with the logical architecture expressed via ADLs such as AADL and MontiArc. Behavior is captured in dynamic models, for example using MATLAB/Simulink, Simulink‑Automaton or state machines from SysML v1.7. Code generation in C++ or Java is performed to drive the digital twin, and the various modeling artefacts are integrated through model‑interchange and code‑generation tools supplied by MathWorks and system‑integrators."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital Twin lifecycle as described in the document comprises four core modeling phases conducted within Model‑Based Systems Engineering (MBSE). 1) **Requirements modeling** captured with SysML, 2) **Functional architecture** defined in SysML and refined through advanced Architecture Description Languages such as ACME or AADL, 3) **Logical architecture** mapped via methodologies like RFLP (Requirements‑Functions‑Logics‑Physics), OOSEM, SPES or SMArDT, and 4) **Product/technical implementation** produced by simulation and code generation tools (e.g., MathWorks Simulink, C++/Java code). Transition between phases is achieved by hierarchical model refinement and composition, and governance of the lifecycle is implied by the multi‑layered abstraction and stakeholder integration required for the manufacturing focus of the reference model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is validated through a continuous comparison of simulated joint trajectories—generated by the integrated engineering, data‑calculation, and simulation models—with real‑time encoder measurements. The root‑mean‑square deviation between simulation and measurement serves as an error indicator for backlash, elasticity, and friction in the drive train. The dual‑encoder arrangement reduces positional uncertainty by providing redundant position feedback, enabling the system to bound the residual error. Whenever the residual exceeds a tolerance inferred from empirical calibration, the friction model is updated; this loop ensures that the Digital Twin remains an accurate, data‑driven representation of the physical system."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adopts standardized modeling languages: SysML (requirements, functional, logical, behavioral modeling) and UML (for behavior such as state‑machine diagrams). No additional compliance, certification, or interoperability standards are mentioned in the provided document."
]