// C3: Physical sensing components
instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing real‑time torque (τ) data from the first vertical axis of the MABI MAX 100 robot."
    DTDFVocab:producedData JointTorqueDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing real‑time angular velocity (ω) data from the first vertical axis of the MABI MAX 100 robot."
    DTDFVocab:producedData JointAngularVelocityDataTransmitted
]

// C4: DataTransmitted
instance JointTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
]

instance JointAngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

// C10: Data
instance JointTorqueData : DTDFVocab:Data [
    base:desc "Aggregated torque data from the first vertical axis, received via MQTT."
    DTDFVocab:fromData JointTorqueDataTransmitted
    DTDFVocab:inputTo DataIngestionEnabler
]

instance JointAngularVelocityData : DTDFVocab:Data [
    base:desc "Aggregated angular velocity data from the first vertical axis, received via MQTT."
    DTDFVocab:fromData JointAngularVelocityDataTransmitted
    DTDFVocab:inputTo DataIngestionEnabler
]

// C11: Enablers
instance DataIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Automated one‑way data ingestion middleware following the Digital Shadow reference model."
    DTDFVocab:enables PassiveMonitoringDiagnosticsService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulink (MathWorks) simulation environment for validating the behavioral models."
    DTDFVocab:enables PassiveMonitoringDiagnosticsService
]

instance CodeGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Code generation infrastructure producing C++ or Java real‑time components from behavioral models."
    DTDFVocab:enables PassiveMonitoringDiagnosticsService
]

instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 modeling and IBD support for functional and logical architecture representation."
    DTDFVocab:enables PassiveMonitoringDiagnosticsService
]

instance MontiArcStateMachineEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for component‑and‑connector oriented behavioral modeling."
    DTDFVocab:enables PassiveMonitoringDiagnosticsService
]

instance DatabasePersistenceEnabler : DTDFVocab:Enabler [
    base:desc "Database layers for state persistence and historical data storage."
    DTDFVocab:enables PassiveMonitoringDiagnosticsService
]

// C6: Services
instance PassiveMonitoringDiagnosticsService : DTDFVocab:Service [
    base:desc "Passive monitoring and diagnostics service that ingests joint kinematic and dynamic data, applies a multi‑physics identification algorithm, and visualizes results on a real‑time dashboard."
    DTDFVocab:provides MotorFrictionInsight, MotorWearInsight, RootCauseAnalysisAction
]

// C17: Insights/Actions
instance MotorFrictionInsight : DTDFVocab:Insight [
    base:desc "Insight that detects motor friction on the first vertical axis."
]

instance MotorWearInsight : DTDFVocab:Insight [
    base:desc "Insight that detects motor wear on the first vertical axis."
]

instance RootCauseAnalysisAction : DTDFVocab:Action [
    base:desc "Action enabling operators and maintenance engineers to perform root‑cause analysis of performance degradations."
    DTDFVocab:IsAutomatic false
]

// C10: Models
instance RotationalJointBehaviorModel : DTDFVocab:Model [
    base:desc "SysML model of the rotational joint behavior of the first vertical axis, encoded using state machines."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance MultiPhysicsIdentificationModel : DTDFVocab:Model [
    base:desc "Multi‑physics aware identification model used to detect motor friction and wear."
    DTDFVocab:inputTo DataIngestionEnabler
]

// C4: Component representing the studied system
instance MabiMax100VerticalAxis : DTDFVocab:Component [
    base:desc "First vertical axis of the six‑axis Serial robotic arm MABI MAX 100, featuring a permanent‑magnet synchronous motor and a cycloidal gearbox."
]

instance ProductionPlant : DTDFVocab:Environment [
    base:contains MabiMax100VerticalAxis
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical to digital data are transmitted using the MQTT protocol. The source does not specify protocol versions, QoS levels, authentication mechanisms, or network topology details."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system conforms to established modelling and architecture standards, including the Unified Modeling Language (UML) for high‑level conceptual modelling and SysML for system architecture and behavior. Architecture Description Languages employed—ACME, AADL, and MontiArc—adhere to their respective specifications, enabling standardized component‑and‑connector descriptions and interface definitions that support interoperability across toolchains."
]