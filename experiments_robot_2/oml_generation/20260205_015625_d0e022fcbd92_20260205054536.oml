// C11: Enablers
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML is used to structurally model the system components and interfaces, including IBDs and state machines"
    DTDFVocab:enables ModelIntegrationService
]

instance ACMEModelingTool : DTDFVocab:Enabler [
    base:desc "ACME expresses the component and connector architecture of the system"
    DTDFVocab:enables ModelIntegrationService
]

instance AADLModelingTool : DTDFVocab:Enabler [
    base:desc "AADL captures platform‑specific properties of system components"
    DTDFVocab:enables ModelIntegrationService
]

instance MontiArcAutomatonTool : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton state machines model the discrete behaviour of components"
    DTDFVocab:enables ModelIntegrationService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink models continuous‑time dynamics, later converted to executable code"
    DTDFVocab:enables ModelIntegrationService
]

instance CodeGenTool : DTDFVocab:Enabler [
    base:desc "C++/Java executable code is generated from Simulink models for simulation and integration"
    DTDFVocab:enables ModelIntegrationService
]

instance SMArDTFramework : DTDFVocab:Enabler [
    base:desc "SMArDT framework integrates multiple modeling notations and manages the lifecycle of hybrid artifacts"
    DTDFVocab:enables ModelIntegrationService
]

// C10: Models/Data (models are models, not data)
instance RequirementModel : DTDFVocab:Model [
    base:desc "Requirements level model representing system needs and constraints"
    DTDFVocab:inputTo SMArDTFramework, SysMLTool
]

instance FunctionalModel : DTDFVocab:Model [
    base:desc "Functional architecture expressed in SysML, ACME, and AADL"
    DTDFVocab:inputTo SMArDTFramework, ACMEModelingTool, AADLModelingTool, SysMLTool
]

instance LogicalModel : DTDFVocab:Model [
    base:desc "Logical architecture mapped from functional models, expressed in SysML and MontiArc"
    DTDFVocab:inputTo SMArDTFramework, MontiArcAutomatonTool, SysMLTool
]

instance ProductTechnicalModel : DTDFVocab:Model [
    base:desc "Product/technical architecture expressed in ACME and AADL"
    DTDFVocab:inputTo SMArDTFramework, ACMEModelingTool, AADLModelingTool
]

// C6: Services
instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Service that compiles and validates the integrated models across notations"
    DTDFVocab:provides ModelIntegrationInsight
]

// C17: Insights/Actions
instance ModelIntegrationInsight : DTDFVocab:Insight [
    base:desc "Insight that the SMArDT framework successfully integrated models, enabling lifecycle management of hybrid artifacts"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration follows the Digital Shadow Reference Model depicted in Fig. 1, expressed as a UML class diagram. The constellation comprises the core concepts of Purpose, DataTrace, Source, Asset, and Processing. Each Purpose defines a specific application intent of a digital shadow instance. DataTraces aggregate raw data records collected from Sources (e.g., sensors or control units) and link them to underlying Assets (the physical reference). Processing elements apply transformation, aggregation, and abstraction logic to produce context‑aware model updates. The system is structured into hierarchical layers where the Physical domain feeds raw data into the Digital domain, which is then exposed through standardized interfaces for downstream services. MBSE practices are employed to link the UML artefacts with SysML behavior descriptions and simulation models (e.g., Simulink) to enable end‑to‑end validation of the digital shadow."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin lifecycle follows an MBSE‑aligned sequence of abstraction layers: (1) requirements capture that establishes stakeholder needs; (2) functional architecture expressed through SysML diagrams and architecture description languages (ADLs) such as ACME or AADL; (3) logical architecture described with component‑connector models such as MontiArc signal flow or state machines; (4) product/technical layer realised via code generation to C++ or Java and simulation models in MathWorks Simulink. Transition management between layers is achieved through model transformations supported by the same tooling ecosystem, while governance of the entire lifecycle is guided by established MDSE methods including RFLP, OOSEM, SPES and SMArDT."
]