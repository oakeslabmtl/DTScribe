// C3: Physical sensing components
instance MqttEnabledIndustrialSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that generates data traces and publishes them via MQTT protocol using a Mosquitto broker; each update triggers an event‑driven publish."
    DTDFVocab:producedData MqttSensorDataMessage
]

// C4: Physical‑to‑virtual interaction                                           
instance MqttSensorDataMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MqttEnabledIndustrialSensor
]

// C10: Data (contextual trace stored in ThingsBoard)                          
instance ThingsBoardContextualDataTrace : DTDFVocab:Data [
    base:desc "Contextual data trace stored in the ThingsBoard IoT platform after MQTT ingestion, available for processing components."
    DTDFVocab:fromData MqttSensorDataMessage
    DTDFVocab:inputTo ThingsBoardIoTPlatform
]

// C11: Enabler (IoT platform)                                                 
instance ThingsBoardIoTPlatform : DTDFVocab:Enabler [
    base:desc "ThingsBoard IoT platform that ingests MQTT messages, stores contextual traces and makes them available to downstream processing."
    DTDFVocab:enables SimulationProcessingService
]

// C6: Service (executes models)                                               
instance SimulationProcessingService : DTDFVocab:Service [
    base:desc "Service that executes engineering, Simulink‑based simulation and data‑calculation models to produce higher‑level abstractions."
    DTDFVocab:provides SystemBehaviorInsight, OperatorAlertAction
]

// C17: Insight                                                                
instance SystemBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight derived from model outputs describing system behavior and performance trends."
]

// C17: Action                                                                
instance OperatorAlertAction : DTDFVocab:Action [
    base:desc "Action to alert operators for potential corrective measures based on the insight."
    DTDFVocab:IsAutomatic false
]

// C10: Models                                                                
instance EngineeringStructureModel : DTDFVocab:Model [
    base:desc "Engineering model describing system structure and properties."
    DTDFVocab:inputTo ThingsBoardIoTPlatform
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Simulink‑based dynamic simulation model used to compute higher‑level abstractions."
    DTDFVocab:inputTo ThingsBoardIoTPlatform
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Data‑calculation model performing computational steps on input traces."
    DTDFVocab:inputTo ThingsBoardIoTPlatform
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated through a model‑driven reference model that captures components and connectors. Processing components, instantiated from this reference model, consume input data traces and produce derived traces using either data‑calculation or simulation models. The flow of traces is recorded by the ‘originates‑from’ association, enabling transitive traceability from generated traces back to the responsible processing component, its input traces and the underlying models. Concretization of the reference model is achieved by mapping abstract concepts (e.g., DataTrace, ProcessingComponent) to concrete classes and relations, thereby defining the system’s architecture. This architecture follows the component‑and‑connector style used in ADLs such as ACME, AADL, MontiArc, and SysML internal block diagrams, allowing integration of heterogeneous models (SysML, Simulink, source code) and supporting resource management through explicit model composition."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by selecting appropriate model types: white‑box physics‑based models (e.g., Simulink simulations) for interpretability and predictability, complemented by black‑box data‑driven models (e.g., machine‑learning regressors) for capturing nonlinear effects. Validation and verification are performed on the model‑based development chain, including verification of transformations such as SysML to simulation models. The reliability of the Digital Twin depends on the correctness of underlying models and data transformations; traceability mechanisms (originates‑from links) support uncertainty quantification, error detection, and correction by allowing provenance checks throughout the computational pipeline."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical network connection is based on the MQTT messaging protocol, implemented by the Mosquitto client/server over a TCP/IP IP backbone. Devices acting as data sources (sensors, machines) act as MQTT clients that publish to a central broker; the broker may be hosted locally or in the cloud (e.g., as part of a ThingsBoard deployment). The documents do not provide further details on topology, bandwidth, latency, redundancy, or security mechanisms."
]