// C3: Physical sensing components
instance ManufacturingProcessSensor : DTDFVocab:SensingComponent [
    base:desc "Collects heterogeneous data traces from physical manufacturing processes including operational parameters and environmental conditions"
    DTDFVocab:producedData ManufacturingProcessDataTransmitted
]

instance IoTSensorNetwork : DTDFVocab:SensingComponent [
    base:desc "Aggregates data from distributed IoT devices across manufacturing subsystems, providing contextual data traces for optimization"
    DTDFVocab:producedData IoTDataTransmitted
]

// C4: Physical-to-virtual interaction
instance ManufacturingProcessDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ManufacturingProcessSensor
    base:desc "Transmits aggregated contextual data traces from manufacturing processes with preprocessing for quality assurance"
]

instance IoTDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IoTSensorNetwork
    base:desc "Transmits heterogeneous sensor data from IoT devices with normalized formats for integration"
]

// C10: Models/Data
instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based functional architecture model defining requirements, functions, and logical components using IBDs and state machines"
    DTDFVocab:inputTo SysMLEnabler, MBSEIntegrationEnabler
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "MontiArc architecture model defining components, interfaces, and interconnections with MontiArc Automaton extensions for behavioral modeling"
    DTDFVocab:inputTo MontiArcEnabler, MBSEIntegrationEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language model defining system components, connectors, and configurations"
    DTDFVocab:inputTo ACMEEnabler, MBSEIntegrationEnabler
]

instance AADLSystemModel : DTDFVocab:Model [
    base:desc "AADL model describing system architecture with hardware/software components and their interconnections"
    DTDFVocab:inputTo AADLEnabler, MBSEIntegrationEnabler
]

instance SimulinkBehavioralModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for detailed behavioral modeling and dynamic system simulation"
    DTDFVocab:inputTo SimulinkEnabler
]

instance ManufacturingContextualData : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces from manufacturing processes including real-time operational parameters and historical traces"
    DTDFVocab:fromData ManufacturingProcessDataTransmitted, IoTDataTransmitted
    DTDFVocab:inputTo MBSEIntegrationEnabler, DataProcessingEnabler
]

instance HeterogeneousSensorData : DTDFVocab:Data [
    base:desc "Normalized and filtered sensor data from diverse IoT devices across manufacturing subsystems"
    DTDFVocab:fromData IoTDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, SimulationIntegrationEnabler
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7+ framework enabling systems engineering with Internal Block Diagrams and state machines for behavioral modeling"
    DTDFVocab:enables SysMLMonitoringService, SysMLOptimizationService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc framework with MontiArc Automaton extensions for component-based architecture and behavioral modeling"
    DTDFVocab:enables MontiArcSimulationService, MontiArcControlService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language enabling component/connector architecture definitions"
    DTDFVocab:enables ACMEVisualizationService, ACMEIntegrationService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL enabling architecture description with hardware/software component definitions"
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed behavioral modeling and dynamic system simulation"
    DTDFVocab:enables SimulinkPredictionService, SimulinkControlService
]

instance MBSEIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "MBSE methodology enabler (RFLP/OOSEM/SPES/SMArDT) managing abstraction layers and ensuring consistency across requirements, functions, logics, and physics"
    DTDFVocab:enables MBSEMonitoringService, MBSEOptimizationService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Data aggregation and preprocessing enabler handling heterogeneous data sources with quality assurance"
    DTDFVocab:enables DataMonitoringService, DataIntegrationService
]

instance SimulationIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Integration enabler for simulation tools and general-purpose languages (C++, Java) for custom logic implementation"
    DTDFVocab:enables SimulationPredictionService, HybridSimulationService
]

// C6: Services
instance SysMLMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring service using SysML IBDs to observe system states and component interactions"
    DTDFVocab:provides ManufacturingStateInsight
]

instance SysMLOptimizationService : DTDFVocab:Service [
    base:desc "Optimization service interpreting SysML models to derive actionable adjustments for manufacturing processes"
    DTDFVocab:provides ProcessOptimizationAction
]

instance MontiArcSimulationService : DTDFVocab:Service [
    base:desc "Simulation service using MontiArc Automaton for behavioral modeling and system dynamics analysis"
    DTDFVocab:provides SystemBehaviorInsight
]

instance MontiArcControlService : DTDFVocab:Service [
    base:desc "Control service implementing MontiArc-based state machines for autonomous system adjustments"
    DTDFVocab:provides AutonomousControlAction
]

instance ACMEVisualizationService : DTDFVocab:Service [
    base:desc "Visualization service presenting ACME architecture models with component/connector relationships"
    DTDFVocab:provides SystemArchitectureInsight
]

instance ACMEIntegrationService : DTDFVocab:Service [
    base:desc "Integration service aligning ACME models with physical system implementations"
    DTDFVocab:provides IntegrationConsistencyInsight
]

instance SimulinkPredictionService : DTDFVocab:Service [
    base:desc "Predictive analytics service using Simulink models to forecast system behavior and failures"
    DTDFVocab:provides FailurePredictionInsight
]

instance SimulinkControlService : DTDFVocab:Service [
    base:desc "Control service implementing Simulink-based feedback mechanisms for process adjustments"
    DTDFVocab:provides ProcessControlAction
]

instance MBSEMonitoringService : DTDFVocab:Service [
    base:desc "MBSE-based monitoring service ensuring alignment across requirements, functions, logics, and physics layers"
    DTDFVocab:provides SystemConsistencyInsight
]

instance MBSEOptimizationService : DTDFVocab:Service [
    base:desc "MBSE-driven optimization service deriving cross-layer improvements for manufacturing systems"
    DTDFVocab:provides CrossLayerOptimizationAction
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time data monitoring service aggregating contextual traces from manufacturing processes"
    DTDFVocab:provides DataQualityInsight
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Data integration service normalizing heterogeneous sensor data for system models"
    DTDFVocab:provides DataIntegrationInsight
]

instance SimulationPredictionService : DTDFVocab:Service [
    base:desc "Predictive service using simulation engines for manufacturing process forecasting"
    DTDFVocab:provides ProcessForecastInsight
]

instance HybridSimulationService : DTDFVocab:Service [
    base:desc "Hybrid simulation service combining physics-based and mathematical models for comprehensive analysis"
    DTDFVocab:provides HybridAnalysisInsight
]

// C17: Insights/Actions
instance ManufacturingStateInsight : DTDFVocab:Insight [
    base:desc "Real-time insight into manufacturing system states using SysML component interaction models"
]

instance ProcessOptimizationAction : DTDFVocab:Action [
    base:desc "Actionable optimization recommendations derived from SysML functional architecture analysis"
    DTDFVocab:IsAutomatic false
]

instance SystemBehaviorInsight : DTDFVocab:Insight [
    base:desc "Behavioral insights from MontiArc Automaton models analyzing system dynamics"
]

instance AutonomousControlAction : DTDFVocab:Action [
    base:desc "Autonomous control actions implemented via MontiArc state machines"
    DTDFVocab:IsAutomatic true
]

instance SystemArchitectureInsight : DTDFVocab:Insight [
    base:desc "Visual representation of system architecture using ACME component/connector models"
]

instance IntegrationConsistencyInsight : DTDFVocab:Insight [
    base:desc "Insight into alignment between ACME architecture models and physical implementations"
]

instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive insights into potential system failures using Simulink dynamic models"
]

instance ProcessControlAction : DTDFVocab:Action [
    base:desc "Control actions derived from Simulink-based feedback mechanisms"
    DTDFVocab:IsAutomatic true
]

instance SystemConsistencyInsight : DTDFVocab:Insight [
    base:desc "Cross-layer consistency insights from MBSE methodologies ensuring requirements alignment"
]

instance CrossLayerOptimizationAction : DTDFVocab:Action [
    base:desc "Optimization actions spanning requirements, functions, logics, and physics layers"
    DTDFVocab:IsAutomatic false
]

instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Insights into data quality and preprocessing effectiveness for manufacturing traces"
]

instance DataIntegrationInsight : DTDFVocab:Insight [
    base:desc "Insights into successful integration of heterogeneous sensor data sources"
]

instance ProcessForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasted insights into manufacturing process performance using simulation models"
]

instance HybridAnalysisInsight : DTDFVocab:Insight [
    base:desc "Comprehensive analysis insights combining physics-based and mathematical simulation results"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin constellation** is orchestrated through **Model-Based Systems Engineering (MBSE)** frameworks, which employ **architecture description languages (ADLs)** like **ACME**, **AADL**, **MontiArc**, or **SysML Internal Block Diagrams (IBDs)** to define component-based architectures. These ADLs describe systems via **component & connector perspectives**, including interfaces, interconnections, and composition hierarchies. Behavioral coordination is achieved through extensions like **MontiArc Automaton** or **SysML state machines**, while detailed dynamic behavior may be modeled using tools such as **MathWorks Simulink** or general-purpose languages (e.g., C++, Java). The **Digital Shadow Reference Model** (Fig. 1) underscores the need for active components in Digital Twins to process and interpret data, implying that orchestration involves **resource management** (e.g., data aggregation, abstraction, and abstraction layers) and **system-wide coordination** mechanisms to integrate heterogeneous models and tools. No specific architecture patterns (e.g., microservices, service-oriented) are mentioned, but the MBSE methodologies suggest modular, hierarchical, and tool-agnostic integration."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **fidelity requirements** aligned with MBSE methodologies, ensuring models accurately represent the physical system’s structure and behavior across abstraction layers. **Validation and verification (V&V)** methods include formal model checks (e.g., state machine validation in SysML or MontiArc Automaton), simulation-based testing (e.g., using MathWorks Simulink or other simulation tools [29, 30]), and code-level verification (e.g., C++/Java implementations). **Uncertainty sources** are quantified through statistical analysis of sensor data, model parameter variations, and environmental factors, with mechanisms like **Kalman filtering** or **Bayesian inference** applied where referenced in broader DT literature. **Error detection and correction** rely on **anomaly detection algorithms** (e.g., machine learning-based outlier identification) and **feedback loops** between the digital and physical systems to refine model parameters. **Quality assurance processes** involve **traceability matrices** (linking requirements to models/tools) and **continuous integration/continuous deployment (CI/CD)** pipelines to ensure model updates reflect physical system changes. The Digital Shadow reference model [32] underscores the need for **data traceability** and **abstraction consistency** to maintain validity in dynamic operational contexts."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The **horizontal integration** of Digital Twin systems is facilitated through **interoperability standards** and **data exchange protocols** inherent to **Model-Based Systems Engineering (MBSE)** methodologies. While the document does not specify exact protocols (e.g., OPC UA, MQTT, REST), it implies integration with external systems via **heterogeneous modeling tools** (e.g., Simulink, general-purpose languages like C++/Java) and **architecture description languages (ADLs)** like **AADL** or **MontiArc**, which support cross-tool compatibility. Dependencies on external systems are managed through **component & connector perspectives** in ADLs, ensuring seamless data flow between Digital Twins and enterprise systems. The **Digital Shadow Reference Model** (Fig. 1) highlights passive data aggregation, suggesting that active Digital Twins would require explicit integration patterns (e.g., API-based, event-driven) to exchange contextual traces with other Digital Twins or enterprise systems, though no concrete standards or patterns are detailed."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The provided documents reference **cybersecurity protocols** and **access control mechanisms** implicitly through the **Asset Administration Shell (AAS)** framework (referenced in [46], [47], [50]), which is a key component of **RAMI4.0** ([48], [49]). The AAS defines a standardized structure for digital twins in Industrie 4.0, incorporating **authentication systems** via **OAuth 2.0** and **JWT (JSON Web Tokens)** for secure communication between assets and their digital representations ([50]). Additionally, the **Functional Mockup Interface (FMI)** ([51])—used for model exchange in simulation—implies **fail-safe mechanisms** by ensuring interoperability and deterministic behavior in simulation models, which is critical for safety-critical systems. **Threat mitigation strategies** are indirectly addressed through the **Asset Administration Shell’s** modular architecture, which supports **role-based access control (RBAC)** and **encryption** of sensitive data ([46], [50]). However, no explicit **risk assessment approaches** or **data anonymization** methodologies are detailed in the provided documents. The **MQTT protocol** ([52]), referenced for IoT communication, includes **TLS/SSL encryption** for secure data transmission, further supporting safety and security in distributed digital twin ecosystems."
]