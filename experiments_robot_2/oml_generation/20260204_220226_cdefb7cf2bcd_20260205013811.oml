import "DTDFVocab"

instance StructuralModelingService : DTDFVocab:Service [
    base:desc "Service for structural modeling using MBSE methodologies and ADLs"
]

instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Service for behavior modeling using MontiArc Automaton and SysML state machines"
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted directly on the permanent magnet synchronous motor of the first vertical axis"
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance PostGearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder positioned behind the gearbox of the first vertical axis"
    DTDFVocab:producedData PostGearboxPositionDataTransmitted
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Real-time motor position data transmitted via MQTT protocol"
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance PostGearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Real-time gearbox position data transmitted via MQTT protocol"
    DTDFVocab:producedFrom PostGearboxPositionEncoder
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for multi-level abstraction modeling (requirements, functional, logical, technical layers)"
    DTDFVocab:enables StructuralModelingService
]

instance RFLPEnabler : DTDFVocab:Enabler [
    base:desc "RFLP methodology for complexity management in MBSE"
    DTDFVocab:enables StructuralModelingService
]

instance OOSEMEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for complexity management in MBSE"
    DTDFVocab:enables StructuralModelingService
]

instance SPESEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for complexity management in MBSE"
    DTDFVocab:enables StructuralModelingService
]

instance SMArDTEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for complexity management in MBSE"
    DTDFVocab:enables StructuralModelingService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component interfaces and interconnections"
    DTDFVocab:enables StructuralModelingService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component interfaces and interconnections"
    DTDFVocab:enables StructuralModelingService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavior modeling"
    DTDFVocab:enables BehavioralModelingService
]

instance SysMLStateMachinesEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 state machines for behavior modeling"
    DTDFVocab:enables BehavioralModelingService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for analytical modeling and simulation"
    DTDFVocab:enables MotionControlService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed system behavior implementation"
    DTDFVocab:enables MotionControlService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed system behavior implementation"
    DTDFVocab:enables MotionControlService
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "High-frequency position data from motor encoder with real-time transmission for precise state monitoring"
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler
]

instance PostGearboxPositionData : DTDFVocab:Data [
    base:desc "High-frequency position data from secondary gearbox encoder with real-time transmission for precise state monitoring"
    DTDFVocab:fromData PostGearboxPositionDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler
]

instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving the first vertical axis of MABI MAX 100 robot"
]

instance GearTransmission : DTDFVocab:ActingComponent [
    base:desc "Gear transmission component for the first axis drive with low gear ratios"
]

instance CycloidalGear : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear for achieving low gear ratios in the first axis drive"
]

instance SiemensSINUMERIKController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl controller enabling precise actuation with safety constraints and remote interfaces"
]

instance MABIMAX100Robot : DTDFVocab:Environment [
    base:desc "Serial robot MABI MAX 100 with six axes operating in precision motion control environment"
    base:contains PermanentMagnetSynchronousMotor, GearTransmission, CycloidalGear, SiemensSINUMERIKController, MotorPositionEncoder, PostGearboxPositionEncoder
]

instance StructuralModelSysMLIBD : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram for structural component modeling"
    DTDFVocab:inputTo SysMLEnabler, ACMEEnabler, AADLEnabler
]

instance StructuralModelACME : DTDFVocab:Model [
    base:desc "ACME model for component interfaces and interconnections"
    DTDFVocab:inputTo ACMEEnabler
]

instance StructuralModelAADL : DTDFVocab:Model [
    base:desc "AADL model for component interfaces and interconnections"
    DTDFVocab:inputTo AADLEnabler
]

instance BehavioralModelMontiArc : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavior modeling"
    DTDFVocab:inputTo MontiArcEnabler
]

instance BehavioralModelSysMLStateMachines : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines for behavior modeling"
    DTDFVocab:inputTo SysMLStateMachinesEnabler
]

instance AnalyticalModelSimulink : DTDFVocab:Model [
    base:desc "Simulink model for analytical simulation"
    DTDFVocab:inputTo SimulinkEnabler
]

instance AnalyticalModelCpp : DTDFVocab:Model [
    base:desc "C++ implementation for detailed system behavior"
    DTDFVocab:inputTo CppEnabler
]

instance AnalyticalModelJava : DTDFVocab:Model [
    base:desc "Java implementation for detailed system behavior"
    DTDFVocab:inputTo JavaEnabler
]

instance StructuralInsight : DTDFVocab:Insight [
    base:desc "Insight into structural component relationships and interfaces"
]

instance BehavioralInsight : DTDFVocab:Insight [
    base:desc "Insight into system dynamics and behavior"
]

instance MotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Enhanced motion accuracy through digital twin analysis"
]

instance OperationalEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Improved operational efficiency via real-time monitoring"
]

instance AdjustMotionParametersAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of motion parameters based on digital twin feedback"
    DTDFVocab:IsAutomatic true
]

instance MotionControlService : DTDFVocab:Service [
    base:desc "Motion control service for precision motion accuracy enhancement"
    DTDFVocab:provides MotionAccuracyInsight, AdjustMotionParametersAction
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system maintains real-time synchronization through automated one-way data flow from physical assets to the digital representation, with active components processing live data streams for immediate state updates."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is validated through quantitative comparison of simulated data against measured data to assess deviations. Uncertainty sources such as mechanical backlash and positional inaccuracies are quantified using sensor data, with error correction mechanisms integrated into the control loop to maintain data consistency and model accuracy."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved via Asset Administration Shells (AAS) for standardization, sensor data streaming using MQTT protocol, and connection to Siemens SINUMERIK 840D sl industrial controllers."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system utilizes industry-standard modeling languages and architecture description languages (ADLs) such as SysML [17], AADL [24], ACME [23], and MontiArc [25], [26] for structured representation across multiple abstraction levels (requirements, functional architecture, logical architecture, and product/technical layers). These standards support component & connector modeling, including interfaces and interconnections, and integrate with simulation tools like MathWorks Simulink [28], general-purpose languages (C++, Java), and address heterogeneous stakeholder integration [31]."
]