// C3: Physical sensing component
instance PhysicalObjectSensor : DTDFVocab:SensingComponent [
    base:desc "Automated one-way sensor transmitting physical object data via MQTT to a broker (Mosquitto) and ThingsBoard IoT platform."
    DTDFVocab:producedData MqttDataMessage
]

// C4: Physical-to-virtual interaction – data transmitted
instance MqttDataMessage : DTDFVocab:DataTransmitted [
    base:desc "MQTT message containing sensor or log data that flows passively to the digital shadow."
    DTDFVocab:producedFrom PhysicalObjectSensor
]

// C10: Data trace stored in the twin
instance InputDataTrace : DTDFVocab:Data [
    base:desc "Stored data trace generated by the cyber‑physical system, associated with fine‑grained metadata."
    DTDFVocab:fromData MqttDataMessage
    DTDFVocab:inputTo ProcessingComponent
]

// C10: Engineering/Simulation/Calculation models
instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "SysML model (internal block diagram, state machines) describing system structure and properties."
    DTDFVocab:inputTo ProcessingComponent
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink dynamic simulation model used for runtime behavior prediction."
    DTDFVocab:inputTo ProcessingComponent
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Data‑calculation model that derives higher‑level abstractions from raw data traces."
    DTDFVocab:inputTo ProcessingComponent
]

// C11: Enabler – processing component
instance ProcessingComponent : DTDFVocab:Enabler [
    base:desc "Processing component that consumes input data traces, executes selected simulation or data‑calculation model, and produces output traces with provenance tracked via ‘originates‑from’."
    DTDFVocab:enables TwinSimulationService
]

// C6: Service provided by the enabler
instance TwinSimulationService : DTDFVocab:Service [
    base:desc "Service that orchestrates simulation execution and integrates output traces into the digital twin."
    DTDFVocab:provides DerivedAbstractionInsight, TwinUpdateAction
]

// C17: Insight derived from the service
instance DerivedAbstractionInsight : DTDFVocab:Insight [
    base:desc "Higher‑level abstraction derived from simulation or calculation results, offering insight into system behavior."
]

// C17: Action triggered by the service
instance TwinUpdateAction : DTDFVocab:Action [
    base:desc "Automatic update of the digital twin with new output traces."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle described follows the MBSE development flow: initial requirements modeling, followed by functional‑architecture modeling, then logical‑architecture modeling, and finally product/technical‑layer modeling. Representations evolve from textual requirement specifications to SysML internal block diagrams, then to component‑connector ADL models (e.g., ACME, AADL, MontiArc) and finally to executable artifacts such as MathWorks Simulink models or source code in C++/Java. Transition between these stages is governed by conformance relations defined in the reference model, although explicit governance mechanisms are not detailed in the documents."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and validity are ensured through traceability and verification of model transformations. The reference model mandates that each data trace retain an “originates‑from” link to the processing component, input traces, and the applied model, preserving transitive provenance. Correctness of transformations (e.g., from SysML specifications to simulation models such as Simulink) is verified to guarantee that the computational behavior matches the engineered design. Reliability of the digital shadow (and thus the twin) depends on the correctness of the underlying models and the applied data transformations; any deviation is detected via the traceability links. Quality assurance includes verification of model consistency, validation against physical measurements where available, and documentation of uncertainty sources through metadata attached to data traces."
]