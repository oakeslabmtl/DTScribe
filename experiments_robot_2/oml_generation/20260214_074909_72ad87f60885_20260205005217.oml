instance PhysicalSystemStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensing component for physical system states"
    DTDFVocab:producedData PhysicalSystemDataTransmitted
]

instance PhysicalSystemDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Automated one-way data flows from physical system states"
    DTDFVocab:producedFrom PhysicalSystemStateSensor
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Contextual data traces aggregated for specific purposes"
    DTDFVocab:fromData PhysicalSystemDataTransmitted
    DTDFVocab:inputTo RFLPMethodology, OOSEMMethodology, SPESMethodology, SMArDTMethodology, ACMEADL, AADLADL, MontiArcADL, SysMLIBDs, MontiArcAutomatonTool, SysMLStateMachineTool, SimulinkTool, CppProgrammingLanguage, JavaProgrammingLanguage
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML for structural modeling including component & connector perspectives via IBDs"
    DTDFVocab:inputTo SysMLIBDs
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME architecture description language for architectural descriptions"
    DTDFVocab:inputTo ACMEADL
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL architecture description language for architectural descriptions"
    DTDFVocab:inputTo AADLADL
]

instance MontiArcArchitectureModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description language for architectural descriptions"
    DTDFVocab:inputTo MontiArcADL
]

instance MontiArcAutomatonBehavioralModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcAutomatonTool
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines for behavioral modeling"
    DTDFVocab:inputTo SysMLStateMachineTool
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink for simulation"
    DTDFVocab:inputTo SimulinkTool
]

instance CppCodeModel : DTDFVocab:Model [
    base:desc "C++ code for detailed behavior implementation"
    DTDFVocab:inputTo CppProgrammingLanguage
]

instance JavaCodeModel : DTDFVocab:Model [
    base:desc "Java code for detailed behavior implementation"
    DTDFVocab:inputTo JavaProgrammingLanguage
]

