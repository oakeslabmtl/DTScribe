// Sensing Components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "measurement of input current"
    DTDFVocab:producedData InputCurrentTelemetry
]

instance OutputPositionSensor : DTDFVocab:SensingComponent [
    base:desc "measurement of output position"
    DTDFVocab:producedData OutputPositionTelemetry
]

// Physical-to-virtual telemetry
instance InputCurrentTelemetry : DTDFVocab:DataTransmitted [
    base:desc "raw telemetry of input current transmitted via MQTT"
    DTDFVocab:producedFrom InputCurrentSensor
]

instance OutputPositionTelemetry : DTDFVocab:DataTransmitted [
    base:desc "raw telemetry of output position transmitted via MQTT"
    DTDFVocab:producedFrom OutputPositionSensor
]

// Processed Data
instance TorqueData : DTDFVocab:Data [
    base:desc "torque computed from input current telemetry"
    DTDFVocab:fromData InputCurrentTelemetry
    DTDFVocab:inputTo SimulinkSimulatorEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "angular velocity computed from output position telemetry"
    DTDFVocab:fromData OutputPositionTelemetry
    DTDFVocab:inputTo SimulinkSimulatorEnabler
]

instance JointFrictionEstimateData : DTDFVocab:Data [
    base:desc "joint friction estimate derived from torque and velocity data"
    DTDFVocab:fromData InputCurrentTelemetry
    DTDFVocab:inputTo DashboardVisualizationEnabler
]

// Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT messaging broker for real‑time data exchange"
    DTDFVocab:enables DataIngestionService
]

instance SysMLModellingToolEnabler : DTDFVocab:Enabler [
    base:desc "SysML tool implementing IBDs and state machines for functional architecture"
    DTDFVocab:enables ModelingService
]

instance SimulinkSimulatorEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for quantitative dynamics simulation"
    DTDFVocab:enables SimulationService
]

instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard tool for visualising joint friction and operational metrics"
    DTDFVocab:enables InsightDeliveryService
]

// Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Ingests MQTT telemetry streams into digital twin"
]

instance ModelingService : DTDFVocab:Service [
    base:desc "Executes SysML-based modeling for joint friction analysis"
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs Simulink simulation to compute torque and angular velocity from telemetry"
]

instance InsightDeliveryService : DTDFVocab:Service [
    base:desc "Delivers real‑time insights on joint friction to operators"
    DTDFVocab:provides JointFrictionInsight
]

// Models
instance JointFrictionIdentificationModel : DTDFVocab:Model [
    base:desc "SysML model for detecting joint friction in manufacturing context"
    DTDFVocab:inputTo SysMLModellingToolEnabler
]

instance JointFrictionSimulationModel : DTDFVocab:Model [
    base:desc "Simulink model for dynamic behavior simulation of joint system"
    DTDFVocab:inputTo SimulinkSimulatorEnabler
]

// Insight
instance JointFrictionInsight : DTDFVocab:Insight [
    base:desc "Identifies joint friction variations based on processed torque and velocity data"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital Twin lifecycle follows a Model‑Based Systems Engineering (MBSE) process comprising four abstraction levels: a requirements stage that captures stakeholder needs and constraints; a functional architecture stage where SysML IBD diagrams describe component–connector relationships; a logical architecture stage where behavior is modeled using SysML state‑machines or MontiArc automata; and a product/technical layer stage that translates models into Simulink models or C++ code. Transition between stages is governed through model‑driven engineering, generating abstractions from one level to the next, while lifecycle governance is supported by MBSE methodologies such as RFLP, OOSEM, SPES, and SMArDT."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Telemetry from the physical components is streamed to the digital twin via the MQTT messaging protocol. The documents do not provide further detail on the network topology, bandwidth, latency, redundancy, or security mechanisms beyond the use of MQTT itself. The interface is therefore a simple client‑to‑broker one‑way data channel."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin architecture adheres to widely recognised MBSE and modelling standards. SysML (v1.7) is employed for structural and behavioural diagramming; ACME and AADL provide component‑connector formalism for functional and logical layers; MontiArc specifies automaton‑based behavioural models; and Simulink is used for hybrid system simulation and code generation. The integration of these ADLs supports interoperability across industry toolchains and facilitates traceability between requirements and implementation artefacts. No additional ISO or IEEE standard numbers are cited in the document, so compliance is limited to the utilisation of SysML, ACME, AADL, MontiArc, and Simulink as the foundational modelling languages."
]