instance SysmlInternalBlockDiagram : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram for structural modeling of components and connections"
    DTDFVocab:inputTo SysmlTool
]

instance SysmlStateMachine : DTDFVocab:Model [
    base:desc "SysML State Machine for behavioral modeling of system states and transitions"
    DTDFVocab:inputTo SysmlTool
]

instance AcmeArchitectureModel : DTDFVocab:Model [
    base:desc "ACME architecture description language model for component and interface specifications"
    DTDFVocab:inputTo SysmlTool
]

instance AadlArchitectureModel : DTDFVocab:Model [
    base:desc "AADL architecture description language model for embedded systems design"
    DTDFVocab:inputTo SysmlTool
]

instance MontiArcArchitectureModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description language model for component-based architectures"
    DTDFVocab:inputTo SysmlTool
]

instance SimulinkAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model generated using MathWorks Simulink for dynamic system simulation"
    DTDFVocab:inputTo SimulinkTool
]

instance CppProgramModel : DTDFVocab:Model [
    base:desc "Analytical model developed using C++ programming language"
    DTDFVocab:inputTo CppLanguage
]

instance JavaProgramModel : DTDFVocab:Model [
    base:desc "Analytical model developed using Java programming language"
    DTDFVocab:inputTo JavaLanguage
]

instance SysmlTool : DTDFVocab:Enabler [
    base:desc "SysML tool for system modeling across abstraction levels (requirements, functional, logical, technical)"
    DTDFVocab:enables SysmlModelingService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink tool for behavior modeling and simulation"
    DTDFVocab:enables SimulationService
]

instance CppLanguage : DTDFVocab:Enabler [
    base:desc "C++ programming language for analytical model development"
    DTDFVocab:enables AnalyticalModelingService
]

instance JavaLanguage : DTDFVocab:Enabler [
    base:desc "Java programming language for analytical model development"
    DTDFVocab:enables AnalyticalModelingService
]

instance RflpMethodology : DTDFVocab:Enabler [
    base:desc "RFLP methodology (Requirements, Functions, Logics, Physics) for hierarchical abstraction"
    DTDFVocab:enables HeterogeneousToolIntegrationService
]

instance OosemMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for managing system complexity through hierarchical abstraction"
    DTDFVocab:enables HeterogeneousToolIntegrationService
]

instance SpesMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for system engineering and management"
    DTDFVocab:enables HeterogeneousToolIntegrationService
]

instance SmardtMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for system complexity management"
    DTDFVocab:enables HeterogeneousToolIntegrationService
]

instance SysmlModelingService : DTDFVocab:Service [
    base:desc "Service for structural and behavioral system modeling using SysML"
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for simulating system behavior using MathWorks Simulink"
]

instance HeterogeneousToolIntegrationService : DTDFVocab:Service [
    base:desc "Service for integrating data from physical systems via heterogeneous tool integration across diverse modeling notations and stakeholder perspectives"
]

instance AnalyticalModelingService : DTDFVocab:Service [
    base:desc "Service for generating analytical models using general-purpose programming languages"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to standards such as SysML [17] for Model-Based Systems Engineering (MBSE), ACME [23], AADL [24], MontiArc [25, 26], and SysML IBDs [17, 27] as Architecture Description Languages (ADLs) for component-based modeling. It integrates tools like MathWorks Simulink [28], simulation methods [29, 30], and general-purpose programming languages (C++, Java), while addressing heterogeneous stakeholder integration [31] through interoperability frameworks."
]