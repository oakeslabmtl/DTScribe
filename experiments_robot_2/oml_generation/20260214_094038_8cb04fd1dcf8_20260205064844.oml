// Sensing Components – Individual absolute encoders and motor sensors
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Absolute optical encoder mounted on the permanent‑magnet synchronous motor shaft provides high‑resolution angular position data."
    DTDFVocab:producedData ShaftEncoderDataMQTT
]
instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Absolute optical encoder mounted behind the gearbox provides redundant angular position data."
    DTDFVocab:producedData GearboxEncoderDataMQTT
]
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor attached to the motor winding streams instantaneous motor current."
    DTDFVocab:producedData CurrentSensorDataMQTT
]
instance MotorTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Torque sensor measuring motor output torque via strain gauge."
    DTDFVocab:producedData TorqueSensorDataMQTT
]
instance MotorVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Velocity sensor derived from encoder tick rate reports angular velocity."
    DTDFVocab:producedData VelocitySensorDataMQTT
]

// Data‑Transmitted instances – MQTT traffic from physical sensors to the twin
instance ShaftEncoderDataMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]
instance GearboxEncoderDataMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]
instance CurrentSensorDataMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]
instance TorqueSensorDataMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorTorqueSensor
]
instance VelocitySensorDataMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorVelocitySensor
]

// Virtual Data – processed data stored in the twin
instance ShaftEncoderData : DTDFVocab:Data [
    base:desc "Processed encoder position data for the motor shaft used in friction‑loss modelling."
    DTDFVocab:fromData ShaftEncoderDataMQTT
    DTDFVocab:inputTo MQTTBroker, SimulinkRuntime
]
instance GearboxEncoderData : DTDFVocab:Data [
    base:desc "Processed encoder position data for the gearbox used for redundancy checks."
    DTDFVocab:fromData GearboxEncoderDataMQTT
    DTDFVocab:inputTo MQTTBroker, SimulinkRuntime
]
instance CurrentSensorData : DTDFVocab:Data [
    base:desc "Processed current measurement data used to estimate motor torque."
    DTDFVocab:fromData CurrentSensorDataMQTT
    DTDFVocab:inputTo MQTTBroker, SimulinkRuntime
]
instance TorqueSensorData : DTDFVocab:Data [
    base:desc "Processed torque data used in real‑time friction‑loss calculation."
    DTDFVocab:fromData TorqueSensorDataMQTT
    DTDFVocab:inputTo MQTTBroker, SimulinkRuntime
]
instance VelocitySensorData : DTDFVocab:Data [
    base:desc "Processed velocity data used for trajectory optimization."
    DTDFVocab:fromData VelocitySensorDataMQTT
    DTDFVocab:inputTo MQTTBroker, SimulinkRuntime
]

// Acting Components – Physical actuation chain
instance PermanentMagnetSynchronousMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor driving the first rotary axis controlled by the SINUMERIK 840D servo‑drive."
]
instance ServoDriveActuator : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D servo‑drive regulating motor position and velocity using dual‑encoder feedback."
]
instance FieldbusControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Fieldbus controller addressing the servo‑drive remotely via the SINUMERIK control interface."
]
instance SafetyCellActuator : DTDFVocab:ActingComponent [
    base:desc "Safety cell limiting joint travel to ±90° with mechanical limit switches providing hard stops."
]

// Enablers – Technological infrastructure supporting the twin
instance SimulinkRuntime : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment executing real‑time simulation, behavior models, and control synthesis."
    DTDFVocab:enables MonitoringDashboardService, FrictionLossModelService, TrajectoryOptimizationService
]
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating one‑way data flow of sensor streams from the plant to the twin."
    DTDFVocab:enables DataIngestionService
]
instance OPCUAInterface : DTDFVocab:Enabler [
    base:desc "OPC UA server hosting the Asset Administration Shell maps twin data to HMI and SCADA for bidirectional exchange."
    DTDFVocab:enables TwinDataAccessService
]
instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Standardized interface exposing the digital twin’s data and capabilities to external systems."
    DTDFVocab:enables AssetDataAccessService
]
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service that ingests sensor data from MQTT broker into the twin."
]
instance AssetDataAccessService : DTDFVocab:Service [
    base:desc "Service that exposes asset data over the Asset Administration Shell."
    DTDFVocab:provides AssetDataAccessInsight
]

// Services – Functional capabilities provided by the twin
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard visualizing first‑axis kinematics and encoder signals detects friction‑induced deviations."
    DTDFVocab:provides FrictionDeviationInsight, TrajectoryOptimizationInsight
]
instance FrictionLossModelService : DTDFVocab:Service [
    base:desc "Computation of friction‑loss model from raw sensor streams supplies corrective feedback to the robot controller."
    DTDFVocab:provides CorrectiveFeedbackAction
]
instance TrajectoryOptimizationService : DTDFVocab:Service [
    base:desc "Performance‑insight service analyzing motion accuracy to optimize the robot’s trajectory."
    DTDFVocab:provides TrajectoryOptimizationInsight
]
instance TwinDataAccessService : DTDFVocab:Service [
    base:desc "Access service for external HMI/SCADA applications via the Asset Administration Shell."
    DTDFVocab:provides AssetDataAccessInsight
]

// Insights – Observations derived by the services
instance FrictionDeviationInsight : DTDFVocab:Insight [
    base:desc "Insight identifying friction‑induced deviations in the first rotary axis motion."
]
instance TrajectoryOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight highlighting trajectory execution inefficiencies and suggesting path improvements."
]
instance CorrectiveFeedbackAction : DTDFVocab:Action [
    base:desc "Automatic corrective action transmitting feedback commands to the SINUMERIK control interface."
    DTDFVocab:IsAutomatic true
]
instance AssetDataAccessInsight : DTDFVocab:Insight [
    base:desc "Insight exposing twin data via the Asset Administration Shell for external consumption."
]

// Models – Architectural and behavioral representations
instance SysMLProductModel : DTDFVocab:Model [
    base:desc "SysML product/technical layer model describing component‑connector relationships of the robot arm."
    DTDFVocab:inputTo SimulinkRuntime
]
instance ACMELogicalModel : DTDFVocab:Model [
    base:desc "ACME logical architecture model capturing high‑level functional decomposition."
    DTDFVocab:inputTo SimulinkRuntime
]
instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc automaton model representing stateful dynamics of the movable joint."
    DTDFVocab:inputTo SimulinkRuntime
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The development of a Digital Twin follows the Model‑Based Systems Engineering (MBSE) abstraction hierarchy: it begins at the requirements level where system intent is captured, progresses to the functional architecture level that delineates high‑level behaviours, moves to the logical architecture level where component connectivity is defined, and proceeds to the product/technical layer where detailed component models, interface specifications and implementation artefacts (e.g., C++/Java code, Simulink blocks) are produced. Each level is represented by the appropriate notation – for example, SysML v1.7 is used for functional and logical IBDs, while MontiArc, ACME, or AADL capture component‑connector relationships. Transitions between these levels are enabled through model transformation techniques that preserve abstraction mapping and ensure that decisions made earlier are reflected in the lower‑level artefacts."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed by comparing the simulated trajectory to the measured machine trajectory; deviations are quantified in terms of repeatability (0.06 mm) and absolute positional error (0.1 mm). Verification is performed by cross‑checking the encoder signals against ground‑truth readings, and uncertainty stemming from encoder resolution and mechanical backlash is encapsulated within the stated repeatability specification. Errors beyond the tolerance are flagged by a watchdog that monitors deviation from the expected encoder values and logs fault events for further analysis."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Active data ingestion is performed via MQTT messages over an IP network. The document does not specify the network topology, bandwidth, latency, reliability or security measures beyond the use of MQTT."
]