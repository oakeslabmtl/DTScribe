import DTDFVocab from "http://example.com/DTDFVocab"
instance RequirementsSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for SysML requirements data",
    DTDFVocab:producedData SysML_RequirementsDataTransmitted
]
instance FunctionalSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for SysML functional data",
    DTDFVocab:producedData SysML_FunctionalDataTransmitted
]
instance LogicalSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for SysML logical data",
    DTDFVocab:producedData SysML_LogicalDataTransmitted
]
instance TechnicalSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for SysML technical data",
    DTDFVocab:producedData SysML_TechnicalDataTransmitted
]
instance ACMEArchitectureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for ACME architecture data",
    DTDFVocab:producedData ACME_ArchitectureDataTransmitted
]
instance AADLArchitectureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for AADL architecture data",
    DTDFVocab:producedData AADL_ArchitectureDataTransmitted
]
instance MontiArcArchitectureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for MontiArc architecture data",
    DTDFVocab:producedData MontiArc_ArchitectureDataTransmitted
]
instance SysMLIBDSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for SysML IBD data",
    DTDFVocab:producedData SysML_IBD_DataTransmitted
]
instance MontiArcAutomatonSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for MontiArc Automaton data",
    DTDFVocab:producedData MontiArc_AutomatonDataTransmitted
]
instance SysMLStateMachineSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for SysML state machine data",
    DTDFVocab:producedData SysML_StateMachineDataTransmitted
]
instance SimulinkSimulationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for Simulink simulation data",
    DTDFVocab:producedData Simulink_SimulationDataTransmitted
]
instance CppBehaviorSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for C++ behavior data",
    DTDFVocab:producedData Cpp_BehaviorDataTransmitted
]
instance JavaBehaviorSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for Java behavior data",
    DTDFVocab:producedData Java_BehaviorDataTransmitted
]
instance Simulink_Enabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation of detailed dynamics",
    DTDFVocab:enables DataIntegrationService
]
instance Cpp_Enabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior implementation",
    DTDFVocab:enables DataIntegrationService
]
instance Java_Enabler : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior implementation",
    DTDFVocab:enables DataIntegrationService
]
instance ACME_Enabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component and interface modeling",
    DTDFVocab:enables DataIntegrationService
]
instance AADL_Enabler : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component and interface modeling",
    DTDFVocab:enables DataIntegrationService
]
instance MontiArc_Enabler : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component and interface modeling",
    DTDFVocab:enables DataIntegrationService
]
instance SysML_Enabler : DTDFVocab:Enabler [
    base:desc "SysML for system architecture modeling across requirements, functional, logical, and technical layers",
    DTDFVocab:enables DataIntegrationService
]
instance IntegratedToolchains_Enabler : DTDFVocab:Enabler [
    base:desc "Integrated toolchains addressing heterogeneous stakeholder perspectives",
    DTDFVocab:enables DataIntegrationService
]
instance SysML_RequirementsModel : DTDFVocab:Model [
    base:desc "SysML model for requirements layer in MBSE methodology",
    DTDFVocab:inputTo SysML_Enabler
]
instance SysML_FunctionalModel : DTDFVocab:Model [
    base:desc "SysML model for functional layer in MBSE methodology",
    DTDFVocab:inputTo SysML_Enabler
]
instance SysML_LogicalModel : DTDFVocab:Model [
    base:desc "SysML model for logical layer in MBSE methodology",
    DTDFVocab:inputTo SysML_Enabler
]
instance SysML_TechnicalModel : DTDFVocab:Model [
    base:desc "SysML model for technical layer in MBSE methodology",
    DTDFVocab:inputTo SysML_Enabler
]
instance ACME_ArchitectureModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language model for components and interfaces",
    DTDFVocab:inputTo ACME_Enabler
]
instance AADL_ArchitectureModel : DTDFVocab:Model [
    base:desc "AADL Architecture Description Language model for components and interfaces",
    DTDFVocab:inputTo AADL_Enabler
]
instance MontiArc_ArchitectureModel : DTDFVocab:Model [
    base:desc "MontiArc Architecture Description Language model for components and interfaces",
    DTDFVocab:inputTo MontiArc_Enabler
]
instance SysML_IBD_Model : DTDFVocab:Model [
    base:desc "SysML Integrated Block Diagram (IBD) model for component interconnections",
    DTDFVocab:inputTo SysML_Enabler
]
instance MontiArc_AutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model for behavioral aspects",
    DTDFVocab:inputTo MontiArc_Enabler
]
instance SysML_StateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machine model for behavioral aspects",
    DTDFVocab:inputTo SysML_Enabler
]
instance Simulink_SimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for detailed dynamics simulation",
    DTDFVocab:inputTo Simulink_Enabler
]
instance Cpp_BehaviorModel : DTDFVocab:Model [
    base:desc "C++ programming language for detailed behavior implementation",
    DTDFVocab:inputTo Cpp_Enabler
]
instance Java_BehaviorModel : DTDFVocab:Model [
    base:desc "Java programming language for detailed behavior implementation",
    DTDFVocab:inputTo Java_Enabler
]
instance SysML_RequirementsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RequirementsSensor
]
instance SysML_FunctionalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FunctionalSensor
]
instance SysML_LogicalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LogicalSensor
]
instance SysML_TechnicalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TechnicalSensor
]
instance ACME_ArchitectureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ACMEArchitectureSensor
]
instance AADL_ArchitectureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AADLArchitectureSensor
]
instance MontiArc_ArchitectureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MontiArcArchitectureSensor
]
instance SysML_IBD_DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLIBDSensor
]
instance MontiArc_AutomatonDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MontiArcAutomatonSensor
]
instance SysML_StateMachineDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SysMLStateMachineSensor
]
instance Simulink_SimulationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkSimulationSensor
]
instance Cpp_BehaviorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CppBehaviorSensor
]
instance Java_BehaviorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JavaBehaviorSensor
]
instance SysML_RequirementsData : DTDFVocab:Data [
    base:desc "Requirements data from SysML model",
    DTDFVocab:fromData SysML_RequirementsDataTransmitted,
    DTDFVocab:inputTo SysML_Enabler
]
instance SysML_FunctionalData : DTDFVocab:Data [
    base:desc "Functional data from SysML model",
    DTDFVocab:fromData SysML_FunctionalDataTransmitted,
    DTDFVocab:inputTo SysML_Enabler
]
instance SysML_LogicalData : DTDFVocab:Data [
    base:desc "Logical data from SysML model",
    DTDFVocab:fromData SysML_LogicalDataTransmitted,
    DTDFVocab:inputTo SysML_Enabler
]
instance SysML_TechnicalData : DTDFVocab:Data [
    base:desc "Technical data from SysML model",
    DTDFVocab:fromData SysML_TechnicalDataTransmitted,
    DTDFVocab:inputTo SysML_Enabler
]
instance ACME_ArchitectureData : DTDFVocab:Data [
    base:desc "ACME architecture data",
    DTDFVocab:fromData ACME_ArchitectureDataTransmitted,
    DTDFVocab:inputTo ACME_Enabler
]
instance AADL_ArchitectureData : DTDFVocab:Data [
    base:desc "AADL architecture data",
    DTDFVocab:fromData AADL_ArchitectureDataTransmitted,
    DTDFVocab:inputTo AADL_Enabler
]
instance MontiArc_ArchitectureData : DTDFVocab:Data [
    base:desc "MontiArc architecture data",
    DTDFVocab:fromData MontiArc_ArchitectureDataTransmitted,
    DTDFVocab:inputTo MontiArc_Enabler
]
instance SysML_IBD_Data : DTDFVocab:Data [
    base:desc "SysML Integrated Block Diagram data",
    DTDFVocab:fromData SysML_IBD_DataTransmitted,
    DTDFVocab:inputTo SysML_Enabler
]
instance MontiArc_AutomatonData : DTDFVocab:Data [
    base:desc "MontiArc Automaton behavioral data",
    DTDFVocab:fromData MontiArc_AutomatonDataTransmitted,
    DTDFVocab:inputTo MontiArc_Enabler
]
instance SysML_StateMachineData : DTDFVocab:Data [
    base:desc "SysML state machine behavioral data",
    DTDFVocab:fromData SysML_StateMachineDataTransmitted,
    DTDFVocab:inputTo SysML_Enabler
]
instance Simulink_SimulationData : DTDFVocab:Data [
    base:desc "Simulink simulation data",
    DTDFVocab:fromData Simulink_SimulationDataTransmitted,
    DTDFVocab:inputTo Simulink_Enabler
]
instance Cpp_BehaviorData : DTDFVocab:Data [
    base:desc "C++ behavior implementation data",
    DTDFVocab:fromData Cpp_BehaviorDataTransmitted,
    DTDFVocab:inputTo Cpp_Enabler
]
instance Java_BehaviorData : DTDFVocab:Data [
    base:desc "Java behavior implementation data",
    DTDFVocab:fromData Java_BehaviorDataTransmitted,
    DTDFVocab:inputTo Java_Enabler
]
instance DataIntegrationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from integrated heterogeneous models for stakeholder perspectives"
]
instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Service for integrating heterogeneous models across different notations and tools to accommodate multiple stakeholder perspectives",
    DTDFVocab:provides DataIntegrationInsight
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with industry standards including SysML [17], AADL [24], ACME [23], and MontiArc [25], [26] for architecture description and system modeling within Model-Based Systems Engineering (MBSE) frameworks."
]