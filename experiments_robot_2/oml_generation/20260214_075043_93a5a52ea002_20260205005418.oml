instance SysML : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for system modeling across abstraction levels (requirements, functional, logical, product/technical layers)"
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "Architecture Description Language and behavior modeling tool for component & connector structures and state machines"
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for analytical simulations"
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "RFLP methodology for complexity management in MBSE"
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for complexity management in MBSE"
]

instance SPES : DTDFVocab:Enabler [
    base:desc "SPES methodology for complexity management in MBSE"
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for complexity management in MBSE"
]

instance ACME : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component & connector structures"
]

instance AADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component & connector structures"
]

instance CPlusPlus : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior execution"
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior execution"
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML component & connector diagrams via IBDs for structural modeling"
    DTDFVocab:inputTo SysML
]

instance MontiArcBehavioralModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArc
]

instance SysMLStateMachine : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines for behavioral modeling"
    DTDFVocab:inputTo SysML
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink for analytical simulations"
    DTDFVocab:inputTo Simulink
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to industry standards including SysML [17] for model-based systems engineering, AADL [24] for architecture description, ACME [23] for component-based modeling, and MontiArc [25], [26] for architectural descriptions, ensuring interoperability and integration of heterogeneous stakeholder perspectives as required in MBSE practices."
]