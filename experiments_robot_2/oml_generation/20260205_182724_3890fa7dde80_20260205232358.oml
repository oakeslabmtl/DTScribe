// C2: Acting Components (Passive Data Transmission)
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor component in the MABI MAX 100 first axis that generates torque (τ_M) and angular velocity (ω) outputs, but does not receive actuation commands from the digital twin. Operates within the physical twin system for high-precision manufacturing tasks."
]

instance GearboxTransmission : DTDFVocab:ActingComponent [
    base:desc "Combination of gearwheel and cycloidal gearbox in the MABI MAX 100 first axis that processes motor torque (τ_M) and angular velocity (ω) to produce output torque (τ_G, τ_out) and angular velocity (ω_out). No direct actuation from digital twin operates in passive data transmission mode."
]

// C3: Physical Sensing Components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Primary position encoder mounted directly on the permanent magnet synchronous motor shaft, providing real-time angular displacement data for backlash and positional uncertainty analysis in the MABI MAX 100 first axis."
    DTDFVocab:producedData MotorEncoderData
]

instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder mounted behind the cycloidal gearbox in the MABI MAX 100 first axis, providing real-time output angle data for friction analysis and positional accuracy verification."
    DTDFVocab:producedData SecondaryEncoderData
]

instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Siemens SINUMERIK 840D sl. CNC controller integrated current sensor measuring input current (I_M) to the motor for torque derivation and dynamics analysis."
    DTDFVocab:producedData CurrentSensorData
]

// C4: Physical-to-Virtual Interaction
instance MotorEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
    base:desc "Real-time angular displacement data streamed from the motor encoder to the digital shadow via MQTT protocol for friction analysis and positional accuracy verification."
]

instance SecondaryEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoder
    base:desc "Real-time output angle data streamed from the secondary encoder to the digital shadow via MQTT protocol for backlash and positional uncertainty analysis."
]

instance CurrentSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
    base:desc "Input current (I_M) data streamed from the Siemens SINUMERIK 840D sl. CNC controller to the digital shadow via MQTT protocol for torque derivation and dynamics modeling."
]

// C10: Models/Data
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML Block Definition Diagram (BDD) and Internal Block Diagram (IBD) describing the structural composition of the MABI MAX 100 first axis including motor, gearwheel, and cycloidal gearbox components with rotational/current flow definitions."
    DTDFVocab:inputTo SysMLTool
]

instance IdealGearboxModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model representing ideal gearbox behavior without friction, used as baseline for friction analysis in the MABI MAX 100 first axis."
    DTDFVocab:inputTo SimulinkTool
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink implementation of Coulomb-Viscous friction model for the cycloidal gearbox in the MABI MAX 100 first axis, used to analyze static and kinetic friction components."
    DTDFVocab:inputTo SimulinkTool
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink implementation of Stribeck friction model for the MABI MAX 100 first axis, capturing stiction and breakaway effects in gearbox dynamics."
    DTDFVocab:inputTo SimulinkTool
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink implementation of Dahl friction model for the cycloidal gearbox, used to analyze dynamic friction behavior under varying loads."
    DTDFVocab:inputTo SimulinkTool
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink implementation of LuGre friction model for the MABI MAX 100 first axis, providing detailed characterization of friction dynamics including micro-sliding effects."
    DTDFVocab:inputTo SimulinkTool
]

instance MotorDynamicsModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model representing motor dynamics (τ_M, ω_M) calculations using manufacturer-provided dynamics models for the permanent magnet synchronous motor in the MABI MAX 100 first axis."
    DTDFVocab:inputTo SimulinkTool
]

instance GearboxDynamicsModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model representing gearbox dynamics (τ_G, ω_G) calculations incorporating gear ratios and friction effects for the cycloidal gearbox in the MABI MAX 100 first axis."
    DTDFVocab:inputTo SimulinkTool
]

instance TorqueDerivationAlgorithm : DTDFVocab:Model [
    base:desc "Data calculation algorithm deriving torque (τ) values from measured inputs (I_M, encoder data) using manufacturer-specific dynamics models for the MABI MAX 100 first axis."
    DTDFVocab:inputTo DataProcessingEnabler
]

instance AngularVelocityDerivationAlgorithm : DTDFVocab:Model [
    base:desc "Data calculation algorithm deriving angular velocity (ω) values from encoder data for the MABI MAX 100 first axis, used in friction analysis and motion accuracy assessment."
    DTDFVocab:inputTo DataProcessingEnabler
]

instance MeasuredCurrentData : DTDFVocab:Data [
    base:desc "Time-series data stream of input current (I_M) measured by the Siemens SINUMERIK 840D sl. CNC controller, used as input for torque derivation and dynamics modeling."
    DTDFVocab:fromData CurrentSensorData
    DTDFVocab:inputTo TorqueDerivationAlgorithm
]

instance MeasuredMotorAngleData : DTDFVocab:Data [
    base:desc "Time-series data stream of motor shaft angle (ω_M) from the primary encoder, used as input for angular velocity derivation and friction analysis."
    DTDFVocab:fromData MotorEncoderData
    DTDFVocab:inputTo AngularVelocityDerivationAlgorithm
]

instance MeasuredOutputAngleData : DTDFVocab:Data [
    base:desc "Time-series data stream of output angle (ω_out) from the secondary encoder, used as reference for backlash and positional uncertainty analysis."
    DTDFVocab:fromData SecondaryEncoderData
    DTDFVocab:inputTo GearboxDynamicsModel
]

instance DerivedMotorTorqueData : DTDFVocab:Data [
    base:desc "Time-series data of derived motor torque (τ_M) calculated from current measurements using manufacturer dynamics models for the MABI MAX 100 first axis."
    DTDFVocab:fromData MeasuredCurrentData
    DTDFVocab:inputTo MotorDynamicsModel
]

instance DerivedMotorVelocityData : DTDFVocab:Data [
    base:desc "Time-series data of derived motor angular velocity (ω_M) calculated from encoder data for the MABI MAX 100 first axis."
    DTDFVocab:fromData MeasuredMotorAngleData
    DTDFVocab:inputTo MotorDynamicsModel
]

instance SimulatedIdealTorqueData : DTDFVocab:Data [
    base:desc "Time-series data of simulated ideal gearbox torque (τ_G_ideal) without friction, used as baseline for friction analysis in the MABI MAX 100 first axis."
    DTDFVocab:fromData IdealGearboxModel
    DTDFVocab:inputTo FrictionAnalysisService
]

instance SimulatedCoulombViscousTorqueData : DTDFVocab:Data [
    base:desc "Time-series data of simulated gearbox torque (τ_G_CV) incorporating Coulomb-Viscous friction effects for the MABI MAX 100 first axis."
    DTDFVocab:fromData CoulombViscousFrictionModel
    DTDFVocab:inputTo FrictionAnalysisService
]

instance SimulatedStribeckTorqueData : DTDFVocab:Data [
    base:desc "Time-series data of simulated gearbox torque (τ_G_Stribeck) incorporating Stribeck friction effects for the MABI MAX 100 first axis."
    DTDFVocab:fromData StribeckFrictionModel
    DTDFVocab:inputTo FrictionAnalysisService
]

instance SimulatedDahlTorqueData : DTDFVocab:Data [
    base:desc "Time-series data of simulated gearbox torque (τ_G_Dahl) incorporating Dahl friction effects for the MABI MAX 100 first axis."
    DTDFVocab:fromData DahlFrictionModel
    DTDFVocab:inputTo FrictionAnalysisService
]

instance SimulatedLuGreTorqueData : DTDFVocab:Data [
    base:desc "Time-series data of simulated gearbox torque (τ_G_LuGre) incorporating LuGre friction effects for the MABI MAX 100 first axis."
    DTDFVocab:fromData LuGreFrictionModel
    DTDFVocab:inputTo FrictionAnalysisService
]

instance SimulatedOutputTorqueData : DTDFVocab:Data [
    base:desc "Time-series data of simulated output torque (τ_out) incorporating all friction models for the MABI MAX 100 first axis, used for motion accuracy assessment."
    DTDFVocab:fromData GearboxDynamicsModel
    DTDFVocab:inputTo MotionAccuracyService
]

// C11: Enablers
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML modeling tool used to create Block Definition Diagrams (BDDs) and Internal Block Diagrams (IBDs) for structural modeling of the MABI MAX 100 first axis components."
    DTDFVocab:enables StructuralModelingService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink tool used to implement executable friction models (Coulomb-Viscous, Stribeck, Dahl, LuGre) and dynamics simulations for the MABI MAX 100 first axis."
    DTDFVocab:enables FrictionAnalysisService
    DTDFVocab:enables DynamicsSimulationService
]

instance MQTTProtocol : DTDFVocab:Enabler [
    base:desc "MQTT protocol implementation enabling real-time data streaming from Siemens SINUMERIK 840D sl. CNC controller to the digital shadow for the MABI MAX 100 first axis."
    DTDFVocab:enables DataAcquisitionService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Data processing engine implementing algorithms to derive torque (τ) and angular velocity (ω) from measured inputs (I_M, encoder data) for the MABI MAX 100 first axis."
    DTDFVocab:enables TorqueDerivationService
    DTDFVocab:enables VelocityDerivationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) implementation providing semantic interoperability for the MABI MAX 100 first axis digital shadow, enabling standardized data exchange and model integration."
    DTDFVocab:enables SemanticInteroperabilityService
]

instance VisualizationDashboard : DTDFVocab:Enabler [
    base:desc "Unified visualization dashboard integrating measured vs. simulated data (torque, angular velocity) for the MABI MAX 100 first axis to identify friction-induced deviations."
    DTDFVocab:enables DataVisualizationService
]

// C6: Services
instance StructuralModelingService : DTDFVocab:Service [
    base:desc "Service providing SysML structural modeling of the MABI MAX 100 first axis components (motor, gearwheel, cycloidal gearbox) with rotational/current flow definitions."
    DTDFVocab:provides AxisCompositionInsight
]

instance FrictionAnalysisService : DTDFVocab:Service [
    base:desc "Service combining white-box (analytical) and black-box (data-driven) models to derive joint friction characteristics (static, kinetic, viscous) in real-time for the MABI MAX 100 first axis."
    DTDFVocab:provides FrictionCharacterizationInsight
    DTDFVocab:provides ModelRefinementRecommendation
]

instance DynamicsSimulationService : DTDFVocab:Service [
    base:desc "Service executing MATLAB Simulink models for motor and gearbox dynamics (τ, ω calculations) incorporating friction effects for the MABI MAX 100 first axis."
    DTDFVocab:provides MotionAccuracyAssessmentInsight
]

instance TorqueDerivationService : DTDFVocab:Service [
    base:desc "Service deriving torque (τ) values from measured inputs (I_M, encoder data) using manufacturer-specific dynamics models for the MABI MAX 100 first axis."
    DTDFVocab:provides DerivedTorqueData
]

instance VelocityDerivationService : DTDFVocab:Service [
    base:desc "Service deriving angular velocity (ω) values from encoder data for the MABI MAX 100 first axis, used in friction analysis and motion accuracy assessment."
    DTDFVocab:provides DerivedVelocityData
]

instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Service streaming real-time sensor data (I_M, encoder outputs) from Siemens SINUMERIK 840D sl. CNC controller to the digital shadow via MQTT protocol for the MABI MAX 100 first axis."
    DTDFVocab:provides MeasuredDataTraces
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service providing unified dashboard visualization of measured vs. simulated data (torque, angular velocity) to identify deviations caused by friction in the MABI MAX 100 first axis."
    DTDFVocab:provides VisualizationInsight
]

instance SemanticInteroperabilityService : DTDFVocab:Service [
    base:desc "Service enabling standardized data exchange and model integration through Asset Administration Shell (AAS) for the MABI MAX 100 first axis digital shadow."
    DTDFVocab:provides InteroperabilityInsight
]

instance MotionAccuracyService : DTDFVocab:Service [
    base:desc "Service analyzing motion accuracy by comparing simulated and measured data to quantify friction-induced inaccuracies in the MABI MAX 100 first axis."
    DTDFVocab:provides MotionAccuracyAssessmentInsight
]

// C17: Insights/Actions
instance AxisCompositionInsight : DTDFVocab:Insight [
    base:desc "Structural composition insight of the MABI MAX 100 first axis including motor, gearwheel, and cycloidal gearbox components with rotational/current flow definitions derived from SysML models."
]

instance FrictionCharacterizationInsight : DTDFVocab:Insight [
    base:desc "Real-time identification of static, kinetic, and viscous friction components in the cycloidal gearbox of the MABI MAX 100 first axis based on combined white-box and black-box modeling."
]

instance ModelRefinementRecommendation : DTDFVocab:Insight [
    base:desc "Suggested parameter updates for friction models based on operational data deviations to account for wear, temperature, and load variations in the MABI MAX 100 first axis."
]

instance MotionAccuracyAssessmentInsight : DTDFVocab:Insight [
    base:desc "Quantification of friction-induced inaccuracies (up to 30% of total error) in the MABI MAX 100 first axis, providing correction strategies for robot control algorithms."
]

instance DerivedTorqueData : DTDFVocab:Insight [
    base:desc "Time-series data of derived motor torque (τ_M) and gearbox torque (τ_G) values calculated from measured inputs for the MABI MAX 100 first axis."
]

instance DerivedVelocityData : DTDFVocab:Insight [
    base:desc "Time-series data of derived angular velocity (ω_M, ω_G) values calculated from encoder data for the MABI MAX 100 first axis."
]

instance MeasuredDataTraces : DTDFVocab:Insight [
    base:desc "Time-series data traces including measured I_M, output angle, and derived torque/velocity values streamed from the Siemens SINUMERIK 840D sl. CNC controller for the MABI MAX 100 first axis."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Unified dashboard visualization comparing measured vs. simulated torque and angular velocity data to identify friction-induced deviations in the MABI MAX 100 first axis."
]

instance InteroperabilityInsight : DTDFVocab:Insight [
    base:desc "Standardized data exchange and model integration capabilities enabled through Asset Administration Shell (AAS) for the MABI MAX 100 first axis digital shadow."
]

instance FrictionDiagnosticAlert : DTDFVocab:Action [
    base:desc "Automatic alert system flagging anomalies in friction behavior (e.g., sudden wear) for maintenance planning in the MABI MAX 100 first axis."
    DTDFVocab:IsAutomatic true
]

instance MotionAccuracyCorrection : DTDFVocab:Action [
    base:desc "Recommended correction strategies for robot control algorithms based on quantified friction-induced inaccuracies in the MABI MAX 100 first axis."
    DTDFVocab:IsAutomatic false
]

// C18: Environment
instance MabiMax100FirstAxisEnvironment : DTDFVocab:Environment [
    base:desc "Environment containing the physical and digital components of the MABI MAX 100 first axis (base axis) including motor, gearbox, sensors, and digital shadow for friction analysis."
    base:contains MotorActuator
    base:contains GearboxTransmission
    base:contains MotorEncoder
    base:contains SecondaryEncoder
    base:contains CurrentSensor
]

// C19: Component
instance FirstAxisDigitalShadow : DTDFVocab:Component [
    base:desc "Purpose-specific digital shadow of the MABI MAX 100 first axis designed for friction analysis, incorporating SysML structural models, Simulink behavioral models, and real-time data assimilation from MQTT streams."
    base:isContainedIn MabiMax100FirstAxisEnvironment
    base:contains SysMLStructuralModel
    base:contains SimulinkTool
    base:contains MQTTProtocol
    base:contains DataProcessingEnabler
    base:contains AssetAdministrationShell
    base:contains VisualizationDashboard
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin operates on a **real-time, continuous time scale**, synchronizing with the physical system’s operational frequency. Data is processed at **high temporal resolution** (millisecond-level granularity) to enable real-time friction identification. The digital shadow updates dynamically with **live sensor data streams** (e.g., MQTT) and **simulation models** (e.g., Simulink), ensuring low-latency analysis for motion accuracy improvements."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation is structured as follows:
  - **Core Components**:
    - **Digital Shadow (FrictionShadow)**: Purpose-specific abstraction for friction analysis, incorporating **Purpose (FrictionDerivation)**, **Asset (Mabi)**, and **Processing components** (Simulation M, GW, GB).
    - **Data Sources**: Physical sensors (encoders) and derived data (e.g., torque from dynamics models).
    - **Models**: Linked engineering (SysML), simulation (Simulink), and data calculation models.
  - **Data Flow**:
    1. Physical system → **MQTT streams** → Digital Shadow (data ingestion).
    2. Digital Shadow → **Processing components** (Simulink) → Simulated friction outputs.
    3. Unified dashboard → **Visualization** of deviations between measured and simulated data.
  - **Orchestration**: Centralized pipeline with **traceable data provenance**, enabling end-to-end analysis of friction effects on motion accuracy."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin operates during the **operational phase** of the physical system’s life cycle, focusing on **as-operated** representations of the first axis. It does not model the **as-designed** (ideal) or **as-manufactured** phases but instead **continuously refines its models** based on real-time operational data to improve motion accuracy. The digital shadow is **dynamic and adaptive**, evolving alongside the physical system’s wear and usage patterns."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The digital twin’s fidelity and validity are ensured through:
  - **Model Validation**: Comparison of **measured vs. simulated data** (e.g., torque, angular velocity) to validate friction models (Coulomb-Viscous, Stribeck, etc.).
  - **Uncertainty Quantification**: Analysis of deviations between **reference data (measured)** and **simulated outputs** (e.g., ˆτ_M, ˆω_G) to assess model accuracy.
  - **Parameter Identification**: Continuous **adjustment of friction model parameters** during operation to account for **wear, temperature, and load variations**.
  - **Verification Mechanisms**: **Traceability** of data origins (e.g., MQTT channels) and processing steps (Simulink models) to ensure reproducibility.
  - **Error Sources**: Addressed through **dual encoder systems** (motor + secondary encoder) to mitigate backlash and positional uncertainty."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection between the physical twin (PT) and digital twin (DT) is established via:
  - **Protocol**: **MQTT (Message Queuing Telemetry Transport)** for **real-time, low-latency data streaming** of sensor data (I_M, encoder outputs).
  - **Data Format**: Time-series data with **floating-point values** for torque (τ) and angular velocity (ω), structured as **DataTraces** in the digital shadow.
  - **Network Architecture**: **Unified dashboard** aggregates and visualizes data from the digital shadow, enabling **cross-model correlation** (e.g., SysML + Simulink). No explicit mention of cloud/edge deployment is provided; the system appears **locally integrated** with the CNC controller."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is **locally deployed** alongside the Siemens SINUMERIK 840D sl. CNC controller, leveraging **on-premise infrastructure** for real-time processing. The **dashboard visualization** is likely hosted on the same local network or integrated into the CNC system’s interface. No cloud-based deployment or distributed hosting is mentioned; the system relies on **local computation resources** (e.g., MATLAB Simulink runtime) for processing."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin adheres to the following standards:
  - **Modeling**: SysML (OMG standard) for **engineering models** (BDDs, IBDs).
  - **Asset Representation**: **Asset Administration Shell (AAS)** (IEC 62424) for semantic interoperability and data traceability.
  - **Simulation**: MATLAB Simulink (industry-standard tool) for **executable behavioral models**.
  - **Data Protocols**: MQTT (IETF standard) for **real-time data streaming**.
  The methodology also references **Digital Shadow Reference Model (DSRM)** for structured digital shadow construction."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The digital twin’s security and safety considerations include:
  - **No Remote Actuation**: The digital shadow is **passive**; it does not execute operations remotely on the physical system, mitigating risks of unintended control interventions.
  - **Data Isolation**: Sensor data (e.g., MQTT streams) is **locally processed** without explicit mention of cybersecurity protocols (e.g., encryption, authentication). The system relies on the **Siemens SINUMERIK 840D sl.** controller’s inherent security for data integrity.
  - **Safety Constraints**: The robot’s **safety cell** restricts the working range to [-90°, 90°], ensuring operational limits are respected. However, **no explicit safety protocols** (e.g., fail-safes, emergency stops) are linked to the digital twin’s outputs.
  - **Human Safety**: The digital twin’s purpose is **analytical** (friction modeling), with no direct interaction with human operators during operation."
]