// Acting components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor driving the robot’s first rotary joint"
]

instance SINUMERIKServoDrive : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D servo‑drive controlling motor position and velocity via dual encoders"
]

// Physical sensing components
instance MotorShankAbsoluteEncoder : DTDFVocab:SensingComponent [
    base:desc "Absolute optical encoder mounted on the motor shaft for high‑precision angular position measurement"
    DTDFVocab:producedData MotorShankEncoderMQTT
]

instance GearboxAbsoluteEncoder : DTDFVocab:SensingComponent [
    base:desc "Absolute optical encoder mounted behind the gearbox for additional position feedback"
    DTDFVocab:producedData GearboxEncoderMQTT
]

// Physical-to-virtual data transmission (MQTT)
instance MotorShankEncoderMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShankAbsoluteEncoder
]

instance GearboxEncoderMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxAbsoluteEncoder
]

// Aggregated data traces
instance MotorShankEncoderTrace : DTDFVocab:Data [
    base:desc "Stream of motor shaft encoder angle values collected over time"
    DTDFVocab:fromData MotorShankEncoderMQTT
    DTDFVocab:inputTo MQTT_MessagingBroker, MATLABSimulink_CoSimulation
]

instance GearboxEncoderTrace : DTDFVocab:Data [
    base:desc "Stream of gearbox encoder angle values collected over time"
    DTDFVocab:fromData GearboxEncoderMQTT
    DTDFVocab:inputTo MQTT_MessagingBroker, MATLABSimulink_CoSimulation
]

// Model instances
instance SystemArchitectureSysMLModel : DTDFVocab:Model [
    base:desc "SysML model capturing the robot’s structural and functional architecture across abstraction layers"
    DTDFVocab:inputTo SysML_SystemModelingTool
]

instance FunctionalArchitectureACMEModel : DTDFVocab:Model [
    base:desc "ACME model of the robot’s functional hierarchy and component relationships"
    DTDFVocab:inputTo SysML_SystemModelingTool
]

instance LogicalArchitectureAADLModel : DTDFVocab:Model [
    base:desc "AADL model representing the logical architecture of the robot’s control system"
    DTDFVocab:inputTo SysML_SystemModelingTool
]

instance BehaviorStateMachineMontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton capturing the robot’s behavioral dynamics and state transitions"
    DTDFVocab:inputTo SysML_SystemModelingTool
]

instance SimulationSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model used for real‑time simulation of the robot’s kinematic and dynamic behavior"
    DTDFVocab:inputTo MATLABSimulink_CoSimulation
]

// Enablers
instance SysML_SystemModelingTool : DTDFVocab:Enabler [
    base:desc "SysML tool for designing the robot’s system architecture"
    DTDFVocab:enables RealTimeMonitoringDashboardService
]

instance AAS_AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell exposing the digital twin’s data and services via a standardized interface"
    DTDFVocab:enables RealTimeMonitoringDashboardService
]

instance MQTT_MessagingBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating one‑way telemetry from physical sensors to the digital twin"
    DTDFVocab:enables RealTimeMonitoringDashboardService
]

instance MATLABSimulink_CoSimulation : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink co‑simulation environment generating and consuming model data"
    DTDFVocab:enables RealTimeMonitoringDashboardService
]

instance OPCUA_Server : DTDFVocab:Enabler [
    base:desc "OPC UA server hosting the AAS model and mapping twin data to HMI/SCADA systems"
    DTDFVocab:enables RealTimeMonitoringDashboardService
]

// Service
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Dashboard visualizing the first axis kinematics and encoder signals for plant operators, maintenance engineers, and commissioning personnel"
    DTDFVocab:provides FrictionDeviationDetectionInsight, TrajectoryOptimizationAction, RepeatabilityImprovementAction, CorrectiveFeedbackAction
]

// Insights
instance FrictionDeviationDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects friction‑induced deviations in axis motion based on encoder telemetry"
]

// Actions
instance TrajectoryOptimizationAction : DTDFVocab:Action [
    base:desc "Calculates and applies trajectory adjustments to improve repeatability"
    DTDFVocab:IsAutomatic true
]

instance RepeatabilityImprovementAction : DTDFVocab:Action [
    base:desc "Adjusts control loops to enhance positional repeatability of the robot"
    DTDFVocab:IsAutomatic true
]

instance CorrectiveFeedbackAction : DTDFVocab:Action [
    base:desc "Computes corrective feedback signals for the SINUMERIK servo drive to mitigate friction losses"
    DTDFVocab:IsAutomatic true
]

// Environment
instance IndustrialPlantEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotor, SINUMERIKServoDrive, MotorShankAbsoluteEncoder, GearboxAbsoluteEncoder
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The development of a Digital Twin follows the Model‑Based Systems Engineering (MBSE) abstraction hierarchy: it begins at the requirements level where system intent is captured, progresses to the functional architecture level that delineates high‑level behaviours, moves to the logical architecture level where component connectivity is defined, and proceeds to the product/technical layer where detailed component models, interface specifications and implementation artefacts (e.g., C++/Java code, Simulink blocks) are produced. Each level is represented by the appropriate notation – for example, SysML v1.7 is used for functional and logical IBDs, while MontiArc, ACME, or AADL capture component‑connector relationships. Transitions between these levels are enabled through model transformation techniques that preserve abstraction mapping and ensure that decisions made earlier are reflected in the lower‑level artefacts."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed by comparing the simulated trajectory to the measured machine trajectory; deviations are quantified in terms of repeatability (0.06 mm) and absolute positional error (0.1 mm). Verification is performed by cross‑checking the encoder signals against ground‑truth readings, and uncertainty stemming from encoder resolution and mechanical backlash is encapsulated within the stated repeatability specification. Errors beyond the tolerance are flagged by a watchdog that monitors deviation from the expected encoder values and logs fault events for further analysis."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Active data ingestion is performed via MQTT messages over an IP network. The document does not specify the network topology, bandwidth, latency, reliability or security measures beyond the use of MQTT."
]