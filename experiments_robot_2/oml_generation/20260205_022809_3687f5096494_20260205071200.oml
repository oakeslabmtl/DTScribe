// C3: Physical sensing components
instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder provides absolute angle of the permanent‑magnet synchronous motor."
    DTDFVocab:producedData MotorEncoderTopic
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Gearbox encoder provides absolute angle of the torque‑transmission gearbox."
    DTDFVocab:producedData GearboxEncoderTopic
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measures electrical current (I_M) supplied to the motor."
    DTDFVocab:producedData MotorCurrentTopic
]

instance MotorTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Back‑emf derived torque sensor provides measured output torque of the motor."
    DTDFVocab:producedData MotorTorqueTopic
]

// C4: Physical-to-virtual interaction (Data transmitted over MQTT)
instance MotorEncoderTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

instance MotorCurrentTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorTorqueTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorTorqueSensor
]

// Simulation data transmitted from Simulink model
instance SimulinkDynamicsComponent : DTDFVocab:Component [
    base:desc "MATLAB/Simulink model replicating motor, gearbox, and cycloidal dynamics."
]

instance SimulinkMotorTorqueTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkDynamicsComponent
]

instance SimulinkGearboxTorqueTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkDynamicsComponent
]

instance SimulinkAxisTorqueTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkDynamicsComponent
]

// C10: Model/Data
// Measured data from sensors
instance MotorAngleData : DTDFVocab:Data [
    base:desc "Measured motor angle from motor encoder."
    DTDFVocab:fromData MotorEncoderTopic
    DTDFVocab:inputTo DataProcessingEnabler
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Measured gearbox angle from gearbox encoder."
    DTDFVocab:fromData GearboxEncoderTopic
    DTDFVocab:inputTo DataProcessingEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current (I_M)."
    DTDFVocab:fromData MotorCurrentTopic
    DTDFVocab:inputTo DataProcessingEnabler
]

instance MeasuredMotorTorqueData : DTDFVocab:Data [
    base:desc "Measured motor torque derived from back‑emf."
    DTDFVocab:fromData MotorTorqueTopic
    DTDFVocab:inputTo DataProcessingEnabler
]

// Simulated data from models
instance SimulatedMotorTorqueData : DTDFVocab:Data [
    base:desc "Simulated motor torque from Simulink model."
    DTDFVocab:fromData SimulinkMotorTorqueTopic
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SimulatedGearboxTorqueData : DTDFVocab:Data [
    base:desc "Simulated gearbox torque from Simulink model."
    DTDFVocab:fromData SimulinkGearboxTorqueTopic
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SimulatedAxisTorqueData : DTDFVocab:Data [
    base:desc "Simulated overall axis torque from Simulink model."
    DTDFVocab:fromData SimulinkAxisTorqueTopic
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

// Output data from services
instance FrictionEstimatesTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FrictionEstimationService
]

instance FrictionEstimatesData : DTDFVocab:Data [
    base:desc "Aggregated static, kinetic, and viscous friction estimates derived from real‑time identification."
    DTDFVocab:fromData FrictionEstimatesTopic
    DTDFVocab:inputTo DataProcessingEnabler
]

instance TorqueComparisonTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueComparisonService
]

instance TorqueComparisonData : DTDFVocab:Data [
    base:desc "Comparison of simulated torque versus measured torque for validation."
    DTDFVocab:fromData TorqueComparisonTopic
    DTDFVocab:inputTo DataProcessingEnabler
]

instance DashboardTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RealTimeDashboardService
]

instance DashboardData : DTDFVocab:Data [
    base:desc "Live dashboard data visualization of friction and torque trends."
    DTDFVocab:fromData DashboardTopic
    DTDFVocab:inputTo DataProcessingEnabler
]

instance BaselineDataTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BaselineProvisioningService
]

instance BaselineData : DTDFVocab:Data [
    base:desc "Baseline information for future digital twin evolution."
    DTDFVocab:fromData BaselineDataTopic
    DTDFVocab:inputTo DataProcessingEnabler
]

// C11: Enablers
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processes incoming telemetry for friction estimation and torque comparison."
    DTDFVocab:enables FrictionEstimationService, TorqueComparisonService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Executes Simulink models for online estimation of motor, gearbox, and axis torques."
    DTDFVocab:enables FrictionEstimationService, TorqueComparisonService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker that receives telemetry from physical sensors and publishes to digital twin services."
    DTDFVocab:enables RealTimeDashboardService, BaselineProvisioningService
]

// C6: Services
instance FrictionEstimationService : DTDFVocab:Service [
    base:desc "Real‑time estimation of joint friction using white‑box and data‑driven models."
    DTDFVocab:provides FrictionEstimatesInsight
]

instance TorqueComparisonService : DTDFVocab:Service [
    base:desc "Online comparison of simulated and measured torques to validate model accuracy."
    DTDFVocab:provides TorqueComparisonInsight
]

instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Real‑time visualization dashboard built on Chart.js for monitoring friction and torque trends."
    DTDFVocab:provides DashboardInsight
]

instance BaselineProvisioningService : DTDFVocab:Service [
    base:desc "Baseline provisioning for future digital twin expansions."
    DTDFVocab:provides BaselineInsight
]

// C17: Insights/Actions
instance FrictionEstimatesInsight : DTDFVocab:Insight [
    base:desc "Real‑time friction estimates for static, kinetic, and viscous components."
]

instance TorqueComparisonInsight : DTDFVocab:Insight [
    base:desc "Comparison of simulated torque versus measured torque for validation."
]

instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Live dashboard visualization of friction and torque trends."
]

instance BaselineInsight : DTDFVocab:Insight [
    base:desc "Baseline information for future digital twin development."
]

instance AdjustControlParameterAction : DTDFVocab:Action [
    base:desc "Operator adjustment of controller parameters based on friction insights."
    DTDFVocab:IsAutomatic false
]

instance UpdateMaintenanceScheduleAction : DTDFVocab:Action [
    base:desc "Operator update of maintenance schedule informed by friction trend analysis."
    DTDFVocab:IsAutomatic false
]

instance UpdateControlParameterAutomaticAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of control parameters using friction insights."
    DTDFVocab:IsAutomatic true
]

// Components representing physical and logical parts
instance MotorComponent : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor driving the first vertical axis."
]

instance TorqueTransmissionGearboxComponent : DTDFVocab:Component [
    base:desc "Torque‑transmission gearbox in the first axis."
]

instance CycloidalGearboxComponent : DTDFVocab:Component [
    base:desc "Cycloidal gearbox providing precise high‑torque output."
]

instance SiemensControllerComponent : DTDFVocab:Component [
    base:desc "Siemens SINUMERIK 840D SL CNC controller governing the robot axis."
]

instance MABIMAX100RobotComponent : DTDFVocab:Component [
    base:desc "MABI MAX 100 industrial robot focusing on first axis."
]

instance MQTTBrokerComponent : DTDFVocab:Component [
    base:desc "MQTT broker used for live telemetry."
]

instance DigitalShadowReferenceModelComponent : DTDFVocab:Component [
    base:desc "Digital Shadow Reference Model (DSRM) ensuring semantic conformance."
]

instance AASComponent : DTDFVocab:Component [
    base:desc "Asset Administration Shell (AAS) describing asset metadata and connectivity."
]

instance DashboardComponent : DTDFVocab:Component [
    base:desc "Web dashboard UI using Chart.js for real‑time visualization."
]

// C14: Environment containing all components
instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains MotorEncoderSensor, GearboxEncoderSensor, MotorCurrentSensor, MotorTorqueSensor,
    SimulinkDynamicsComponent, MQTTBrokerComponent, SimulinkSimulationEnabler, MQTTBrokerEnabler,
    DataProcessingEnabler, FrictionEstimationService, TorqueComparisonService,
    RealTimeDashboardService, BaselineProvisioningService,
    MotorComponent, TorqueTransmissionGearboxComponent, CycloidalGearboxComponent,
    SiemensControllerComponent, MABIMAX100RobotComponent, AASComponent, DigitalShadowReferenceModelComponent,
    DashboardComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Not in Document. The digital shadow does not send commands or data back to the physical robot; it operates as a purely passive observation layer."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization at the sample rate of the sensor data (typically hundreds of Hz for motor current and encoder signals). The DT updates friction models in real‑time as new data arrive."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized digital shadow comprising: physical robot axis (motor, gearboxes), MQTT data sources (encoders, current), a Processing component that consumes sensor traces, executes Simulink simulation models (motor, gearwheel, gearbox, friction), generates derived data traces, and exposes results through an AAS‑backed interface and a visualization dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the ‘as designed’ stage (ideal frictionless simulation models), the ‘as manufactured’ stage (parametric models calibrated with manufacturer data), and the ‘as operated’ stage (online friction identification from live measurements)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fine‑grained traceability links each data trace to its originating source and processing component, enabling verification of the simulation against measured data and identification of deviations. Continuous comparison between simulated and measured torques quantifies model validity and informs online parameter updates. Uncertainty not quantified explicitly but can be inferred from residuals between measured and simulated values."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual data flows over MQTT (publish/subscribe). The DT subscribes to encoder and current topics and publishes processed friction estimates on separate topics consumed by the dashboard. No explicit OPC UA or Ethernet‑Industrial links are mentioned."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Not in Document. The implementation details of the host environment, cloud versus on‑premise, and scaling considerations are not specified."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not in Document. No mention of integration with external systems or other digital twins."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not in Document. Data ownership, privacy policies, and rights are not discussed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to MBSE standards: SysML for modeling, Asset Administration Shell (AAS) for asset description, and the Digital Shadow Reference Model (DSRM). The simulation environment uses MATLAB/Simulink, an industry‑accepted modeling tool."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Not in Document. No explicit cybersecurity or safety‑critical considerations are mentioned."
]