// C2: Acting Components
instance PMSMActuator : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor (PMSM) rated 5 kW, 5,000 rpm, 20 Nm, coupled to Siemens SINUMERIK 840D PLC exposing a TCP/IP‑based OPC‑UA interface and Modbus TCP for remote configuration."
]

// C3: Physical sensing components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution incremental encoder on motor shaft delivering 0.1° absolute resolution, 5 V quadrature signal sampled at 10 kHz, transmitted over fiber‑optic RS‑485 link to the PLC."
    DTDFVocab:producedData MotorShaftEncoderData
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Gearbox‑mounted incremental encoder providing 0.01° absolute resolution, 5 V quadrature signal sampled at 10 kHz, transmitted over fiber‑optic RS‑485 link to the PLC."
    DTDFVocab:producedData GearboxEncoderData
]

instance HallEffectCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Hall‑effect current sensor (0–30 A range) providing instantaneous current data, sampled synchronously at 10 kHz, transmitted over fiber‑optic RS‑485 link to the PLC."
    DTDFVocab:producedData HallEffectCurrentSensorData
]

// C4: Physical‑to‑Virtual interaction
instance MotorShaftEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance HallEffectCurrentSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HallEffectCurrentSensor
]

// C10: Models/Data
instance MotorDynamicsSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of the PMSM dynamics and gearbox kinematics, used for real‑time simulation and validation."
    DTDFVocab:inputTo TwinAnalyticsEnabler
]

instance FrictionCoefficientModel : DTDFVocab:Model [
    base:desc "Model estimating joint friction coefficients from live encoder and current data."
    DTDFVocab:inputTo TwinAnalyticsEnabler
]

instance TemperatureMaterialPropertyModel : DTDFVocab:Model [
    base:desc "Model inferring temperature‑dependent material properties from sensor streams."
    DTDFVocab:inputTo TwinAnalyticsEnabler
]

// C4: Data instances
instance MotorAngleData : DTDFVocab:Data [
    base:desc "Instantaneous motor shaft angle derived from MotorShaftEncoderData, stored with 16‑bit timestamp resolution."
    DTDFVocab:fromData MotorShaftEncoderData
    DTDFVocab:inputTo TwinAnalyticsEnabler
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Instantaneous gearbox output angle derived from GearboxEncoderData, stored with 16‑bit timestamp resolution."
    DTDFVocab:fromData GearboxEncoderData
    DTDFVocab:inputTo TwinAnalyticsEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Instantaneous motor current from HallEffectCurrentSensorData, stored with 16‑bit timestamp resolution."
    DTDFVocab:fromData HallEffectCurrentSensorData
    DTDFVocab:inputTo TwinAnalyticsEnabler
]

// C11: Enablers
instance TwinAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Enabler executing simulation models (Simulink, MontiArc) and data assimilation for real‑time analytics."
    DTDFVocab:enables TwinAnalyticsService
]

// C6: Services
instance TwinAnalyticsService : DTDFVocab:Service [
    base:desc "Analytics service providing insights into joint friction, material properties, and optimization of control parameters."
    DTDFVocab:provides JointFrictionInsight, TemperatureMaterialPropertyInsight, TorqueVarianceInsight, ControlParameterAdjustmentAction
]

// C17: Insights/Actions
instance JointFrictionInsight : DTDFVocab:Insight [
    base:desc "Real‑time estimated joint friction coefficients inferred from encoder and current data, with a 5 % variance threshold for alert."
]

instance TemperatureMaterialPropertyInsight : DTDFVocab:Insight [
    base:desc "Estimated temperature‑dependent material properties derived from continuous sensor streams."
]

instance TorqueVarianceInsight : DTDFVocab:Insight [
    base:desc "Detection of a 5 % torque variance from predicted torque, triggering a decision support alert."
]

instance ControlParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Recommended adjustment to control parameters for a robot controller based on friction data, improving execution accuracy by up to 3 %."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle is organized according to classical MBSE abstraction layers: (1) **Requirements** – traceable stakeholder needs expressed in natural‑language or SysML requirements blocks; (2) **Functional architecture** – SysML activity or sequence diagrams that decompose high‑level functions into observable interactions; (3) **Logical architecture** – a component‑connector model built with SysML IBDs, ACME or AADL that specifies interfaces and data flows; (4) **Product/Technical layer** – a concrete Instantiation of the logical model in a target platform (e.g., a Simulink block‑set, C++/Java classes, or a MontiArc simulation model). Transitions between layers are governed by traceability links that map requirements to functional activities, functional blocks to logical components, and logical interfaces to concrete implementation objects. Governance is achieved through a MBSE “Requirements‑Functions‑Logics‑Physics” (RFLP) workflow, ensuring that any change at the requirement level propagates automatically downwards via version‑controlled SysML models and that any prototype‑level behaviour is validated before promotion to the next abstraction tier.*"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The only technical connection described in the source is the MQTT transport of sensor data from the physical machines to the digital shadow. No additional details on network topology, QoS, security protocols, or bandwidth requirements are provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin complies with several industry standards: it implements **Asset Administration Shells (AAS)** – the ISO‑based reference model for digital product representation; it uses **SysML** (ISO 19464) and **ACME** for component–connector abstraction; and it streams telemetry via the lightweight **MQTT** protocol, conforming to IEC 61499 event‑driven architectures. All exchanged data types follow the AAS information model, ensuring interoperability across Industrial IoT platforms.*"
]