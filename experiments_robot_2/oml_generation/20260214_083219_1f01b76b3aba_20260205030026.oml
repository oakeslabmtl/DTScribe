instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted directly on the permanent magnet synchronous motor of the first axis"
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder positioned behind the gearbox of the first axis"
    DTDFVocab:producedData GearboxPositionDataTransmitted
]

instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor collecting input current data from the permanent magnet synchronous motor"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Position data from motor encoder"
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo Simulink, MontiArcAutomaton
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Position data from gearbox encoder"
    DTDFVocab:fromData GearboxPositionDataTransmitted
    DTDFVocab:inputTo Simulink, MontiArcAutomaton
]

instance CurrentData : DTDFVocab:Data [
    base:desc "Input current data from motor"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo Simulink, Cpp
]

instance Motor1 : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor for the first axis of MABI MAX 100 robot"
]

instance SiemensController : DTDFVocab:Component [
    base:desc "Siemens SINUMERIK 840D sl controller managing servo control loops"
]

instance GearTransmission : DTDFVocab:Component [
    base:desc "Gear transmission for mechanical reduction in the first axis"
]

instance CycloidalGear : DTDFVocab:Component [
    base:desc "Cycloidal gear for mechanical reduction in the first axis"
]

instance IndustrialRoboticsEnvironment : DTDFVocab:Environment [
    base:desc "Industrial robotics operational domain for MABI MAX 100 first axis"
    base:contains Motor1, GearTransmission, CycloidalGear, SiemensController
]

instance SysML : DTDFVocab:Enabler [
    base:desc "SysML-based MBSE methodology for structural modeling"
    DTDFVocab:enables FrictionModelingService, RealTimeMonitoringService
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "RFLP methodology for Requirements, Functions, Logics, Physics modeling"
    DTDFVocab:enables FrictionModelingService
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for object-oriented system engineering"
    DTDFVocab:enables RealTimeMonitoringService
]

instance SPES : DTDFVocab:Enabler [
    base:desc "SPES methodology for system engineering processes"
    DTDFVocab:enables FrictionModelingService
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for handling complexity across abstraction levels"
    DTDFVocab:enables VisualizationService
]

instance ACME : DTDFVocab:Enabler [
    base:desc "ACME architecture description language for component and connector perspectives"
    DTDFVocab:enables FrictionModelingService
]

instance AADL : DTDFVocab:Enabler [
    base:desc "AADL architecture description language for real-time systems"
    DTDFVocab:enables RealTimeMonitoringService
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "MontiArc architecture description language for component composition"
    DTDFVocab:enables FrictionModelingService
]

instance SysMLIBDs : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component and interface modeling"
    DTDFVocab:enables FrictionModelingService
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavior modeling"
    DTDFVocab:enables FrictionModelingService
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed simulation and behavior modeling"
    DTDFVocab:enables FrictionModelingService
]

instance Cpp : DTDFVocab:Enabler [
    base:desc "C++ programming language for simulation code implementation"
    DTDFVocab:enables FrictionModelingService
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java programming language for digital twin components"
    DTDFVocab:enables VisualizationService
]

instance ProblemIdentification : DTDFVocab:Enabler [
    base:desc "Step to identify problem and define objectives for digital twin"
    DTDFVocab:enables FrictionModelingService
]

instance AssetAnalysis : DTDFVocab:Enabler [
    base:desc "Step to assess physical assets and existing models"
    DTDFVocab:enables FrictionModelingService
]

instance SimulationModelCreation : DTDFVocab:Enabler [
    base:desc "Step to use or create calculations or models for simulation"
    DTDFVocab:enables FrictionModelingService
]

instance DataIdentification : DTDFVocab:Enabler [
    base:desc "Step to determine required data streams for digital twin"
    DTDFVocab:enables FrictionModelingService
]

instance SysMLModel : DTDFVocab:Model [
    base:desc "SysML model for structural representation of MABI MAX 100 first axis"
    DTDFVocab:inputTo SysML, SysMLIBDs
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME model for component and connector perspectives"
    DTDFVocab:inputTo ACME
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL model for real-time system architecture"
    DTDFVocab:inputTo AADL
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc model for component composition"
    DTDFVocab:inputTo MontiArc
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model for behavior simulation"
    DTDFVocab:inputTo MontiArcAutomaton
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model for detailed motion dynamics simulation"
    DTDFVocab:inputTo Simulink
]

instance CppCodeModel : DTDFVocab:Model [
    base:desc "C++ implementation of simulation models"
    DTDFVocab:inputTo Cpp
]

instance JavaCodeModel : DTDFVocab:Model [
    base:desc "Java implementation of digital twin components"
    DTDFVocab:inputTo Java
]

instance FrictionModelingService : DTDFVocab:Service [
    base:desc "Service for modeling joint friction to optimize robot motion accuracy"
    DTDFVocab:provides JointFrictionInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service for real-time monitoring of mechanical component behavior"
    DTDFVocab:provides MechanicalComponentStatusInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Unified dashboard for operators and engineers to assess system performance and control"
    DTDFVocab:provides UserInterfaceInsight
]

instance JointFrictionInsight : DTDFVocab:Insight [
    base:desc "Insight into joint friction characteristics for motion accuracy improvement"
]

instance MechanicalComponentStatusInsight : DTDFVocab:Insight [
    base:desc "Real-time status of mechanical components including wear and tear"
]

instance UserInterfaceInsight : DTDFVocab:Insight [
    base:desc "Visualized system performance data for operator interaction"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is validated by comparing simulated data against measured physical system data, where deviation serves as the primary validation metric. The system addresses inaccuracies in robot motion through continuous calibration, as specified in the solution scope to improve overall motion accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for sensor data transmission; no details on network topology, bandwidth, latency, reliability, redundancy, or security protocols are specified in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with industry standards including SysML [17] for systems engineering modeling, ACME [23], AADL [24], MontiArc [25,26] for architecture description languages, and SysML Internal Block Diagrams (IBDs) [17,27], facilitating interoperability among heterogeneous stakeholders and systems [31]."
]