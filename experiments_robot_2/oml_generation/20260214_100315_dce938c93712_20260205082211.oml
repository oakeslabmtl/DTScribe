    base:desc "Insight into the validation status of SysML models against system requirements."
]

instance ComponentInteractionInsight : DTDFVocab:Insight [
    base:desc "Insight into component interactions and interface definitions in ACME/AADL models."
]

instance ArchitectureValidationInsight : DTDFVocab:Insight [
    base:desc "Insight into the validation of component/connector architectures against system specifications."
]

instance BehavioralPatternInsight : DTDFVocab:Insight [
    base:desc "Insight into behavioral patterns modeled using MontiArc Automaton and SysML state machines."
]

instance StateTransitionInsight : DTDFVocab:Insight [
    base:desc "Insight into state transitions and behavioral dynamics of manufacturing components."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight into simulation results from MathWorks Simulink behavioral models."
]

instance DynamicBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight into dynamic system behavior derived from simulation analysis."
]

instance ControlAlgorithmInsight : DTDFVocab:Insight [
    base:desc "Insight into the performance and effectiveness of custom C++ control algorithms."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for system optimization derived from control algorithm analysis."
]

instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Insight into the quality and reliability of processed manufacturing data."
]

instance ProcessingPatternInsight : DTDFVocab:Insight [
    base:desc "Insight into data processing patterns and transformation workflows."
]

instance ModelConsistencyInsight : DTDFVocab:Insight [
    base:desc "Insight into the consistency between SysML, ADL, and simulation models."
]

instance CrossToolValidationInsight : DTDFVocab:Insight [
    base:desc "Insight into cross-tool validation results across heterogeneous modeling environments."
]

instance DataAbstractionInsight : DTDFVocab:Insight [
    base:desc "Insight into the abstraction process from raw sensor data to structured Digital Shadow representations."
]

instance ContextualDataInsight : DTDFVocab:Insight [
    base:desc "Insight into contextual data derived from manufacturing system operations."
]

instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Real-time insight into the operational state of manufacturing systems."
]

instance OperationalStatusInsight : DTDFVocab:Insight [
    base:desc "Insight into the operational status and health of manufacturing equipment."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight into detected anomalies in manufacturing system behavior."
]

instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Insight into predicted failures and degradation patterns in manufacturing systems."
