// C3: Physical Sensing Components
instance RobotCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Collects input current data from the MABI MAX 100 robot's motor drives via MQTT protocol for real-time monitoring"
    DTDFVocab:producedData RobotCurrentDataTransmitted
]

instance RobotTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Collects torque measurements from the robot's gear transmission systems via MQTT protocol for dynamic behavior analysis"
    DTDFVocab:producedData RobotTorqueDataTransmitted
]

instance RobotAngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Collects angular velocity data from robot axes via MQTT protocol for motion control validation"
    DTDFVocab:producedData RobotAngularVelocityDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance RobotCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotCurrentSensor
]

instance RobotTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotTorqueSensor
]

instance RobotAngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotAngularVelocitySensor
]

// C10: Models/Data
instance SysMLMultiLayeredSystemModel : DTDFVocab:Model [
    base:desc "SysML v1.7+ model capturing multi-layered system architecture (requirements, functional/logical layers, product models) for MABI MAX 100"
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machines describing behavioral patterns of robot axes and gearbox interactions"
    DTDFVocab:inputTo SysMLEnabler
]

instance MontiArcComponentConnectorModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model defining component-connector architecture for robot axes, gearboxes, and motor interfaces"
    DTDFVocab:inputTo MontiArcEnabler
]

instance AADLComponentConnectorModel : DTDFVocab:Model [
    base:desc "AADL model for component-connector-based architecture of robot mechanical subsystems"
    DTDFVocab:inputTo AADLEnabler
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for detailed dynamic simulation of motor-gearbox interactions with C++/Java integration"
    DTDFVocab:inputTo SimulinkEnabler
]

instance UMLClassDiagramDataModel : DTDFVocab:Model [
    base:desc "UML-based class diagrams defining data trace aggregation and abstraction layers for contextual manufacturing data"
    DTDFVocab:inputTo UMLEnabler
]

instance RobotStateData : DTDFVocab:Data [
    base:desc "Aggregated contextual traces of robot operational states (sensor readings, joint positions, load variations) for analysis"
    DTDFVocab:fromData RobotCurrentDataTransmitted, RobotTorqueDataTransmitted, RobotAngularVelocityDataTransmitted
    DTDFVocab:inputTo MQTTDataAggregatorEnabler, SysMLEnabler
]

instance HistoricalDataTraces : DTDFVocab:Data [
    base:desc "Long-term storage of historical sensor data traces for trend analysis and system evolution tracking"
    DTDFVocab:fromData RobotCurrentDataTransmitted, RobotTorqueDataTransmitted, RobotAngularVelocityDataTransmitted
    DTDFVocab:inputTo DatabaseBackendEnabler
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7+ implementation enabling multi-layered system modeling and state machine behavioral descriptions"
    DTDFVocab:enables DataAbstractionService, SystemVisualizationService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton implementation for component-connector architecture modeling of robot mechanical systems"
    DTDFVocab:enables SystemIntegrationService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL implementation for defining robot component interfaces and interconnections"
    DTDFVocab:enables SystemIntegrationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for detailed dynamic simulation with C++/Java integration for control logic"
    DTDFVocab:enables SimulationValidationService
]

instance UMLEnabler : DTDFVocab:Enabler [
    base:desc "UML-based modeling enabling data trace aggregation and abstraction layers for manufacturing context"
    DTDFVocab:enables DataAbstractionService
]

instance MQTTDataAggregatorEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol implementation for lightweight, event-driven data streaming from physical robot to digital representation"
    DTDFVocab:enables DataAcquisitionService
]

instance DatabaseBackendEnabler : DTDFVocab:Enabler [
    base:desc "Database backend for storing historical data traces with implicit support for long-term analysis"
    DTDFVocab:enables DataStorageService
]

instance SiemensSINUMERIK840DEnabler : DTDFVocab:Enabler [
    base:desc "Siemens SINUMERIK 840D sl real-time motion control system interfacing with PMSM drives and gear transmission"
    DTDFVocab:enables MotionControlService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell implementation enabling standardized data exchange and interoperability with PLM/MES systems"
    DTDFVocab:enables SystemInteroperabilityService
]

// C6: Services
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Automated one-way ingestion of state data from physical robot via MQTT protocol for contextual trace collection"
    DTDFVocab:provides RobotStateInsight
]

instance DataAbstractionService : DTDFVocab:Service [
    base:desc "Aggregation and abstraction of raw sensor data into structured digital representations for analysis"
    DTDFVocab:provides DataAbstractionInsight
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Long-term storage and retrieval of historical data traces for trend analysis"
    DTDFVocab:provides HistoricalDataInsight
]

instance SystemVisualizationService : DTDFVocab:Service [
    base:desc "Presentation of aggregated system data for monitoring and diagnostic purposes"
    DTDFVocab:provides SystemBehaviorInsight
]

instance SystemIntegrationService : DTDFVocab:Service [
    base:desc "Integration of heterogeneous modeling tools (SysML, ADLs) for component-connector architecture validation"
    DTDFVocab:provides SystemIntegrationInsight
]

instance SimulationValidationService : DTDFVocab:Service [
    base:desc "Validation of robot behavior under real-world conditions using co-simulation frameworks"
    DTDFVocab:provides SimulationValidationInsight
]

instance MotionControlService : DTDFVocab:Service [
    base:desc "Real-time motion control of robot axes via SINUMERIK 840D sl with PMSM drive integration"
    DTDFVocab:provides MotionControlInsight
]

instance SystemInteroperabilityService : DTDFVocab:Service [
    base:desc "Standardized data exchange between digital twin and manufacturing ecosystem tools (PLM/MES systems)"
    DTDFVocab:provides InteroperabilityInsight
]

// C17: Insights/Actions
instance RobotStateInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of robot operational states through aggregated sensor data traces"
]

instance DataAbstractionInsight : DTDFVocab:Insight [
    base:desc "Structured digital representations of robot behavior enabling contextual analysis"
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Trend analysis of long-term operational data for system evolution tracking"
]

instance SystemBehaviorInsight : DTDFVocab:Insight [
    base:desc "Visual representation of robot system behavior for diagnostic purposes"
]

instance SystemIntegrationInsight : DTDFVocab:Insight [
    base:desc "Validation of component-connector architecture across heterogeneous modeling tools"
]

instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Verification of robot behavior under real-world conditions (joint friction, load variations)"
]

instance MotionControlInsight : DTDFVocab:Insight [
    base:desc "Real-time performance monitoring of motion control system with PMSM drives"
]

instance InteroperabilityInsight : DTDFVocab:Insight [
    base:desc "Status of standardized data exchange between digital twin and manufacturing ecosystem"
]

// C2: Acting Components (implicit from characteristics)
instance PMSMDriveActuator : DTDFVocab:ActingComponent [
    base:desc "Permanent Magnet Synchronous Motor (PMSM) drive system controlled by Siemens SINUMERIK 840D sl for robot axis actuation"
]

instance GearTransmissionSystem : DTDFVocab:ActingComponent [
    base:desc "Mechanical gear transmission system interfacing with PMSM drives to enable precise robot motion control"
]

instance RobotAxisController : DTDFVocab:ActingComponent [
    base:desc "Component implementing motion control logic for individual robot axes via SINUMERIK 840D sl interface"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system’s orchestration and coordination are underpinned by **Model-Based Systems Engineering (MBSE)** frameworks, which employ **architecture description languages (ADLs)** (e.g., ACME, AADL, MontiArc, SysML IBDs) to define **component & connector perspectives**, including interfaces, interconnections, and composition. These ADLs enable **system-wide coordination** by modeling the structural and behavioral relationships between components. For dynamic behavior, MBSE integrates with tools like **MathWorks Simulink**, other simulation tools, or general-purpose languages (C++, Java) to implement **resource management** and **real-time coordination mechanisms**. The document does not specify exact architecture patterns (e.g., microservices, service-oriented) but implies a **modular, tool-agnostic orchestration** to handle heterogeneity across stakeholders and modeling notations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system validates model fidelity by comparing **simulated data against measured data** from the physical system, ensuring alignment between digital and physical states. Validation is supported by **Simulink-based simulations** and **friction models** to refine behavioral accuracy. The system adheres to **Digital Shadow principles**, where data traces are passively collected and aggregated for contextual abstraction, but no explicit **uncertainty quantification, error correction mechanisms, or quality assurance processes** are detailed in the provided documents. No specific **validation/verification methods** (e.g., statistical metrics, anomaly detection) or **adaptive control tuning** (e.g., PID parameters) are mentioned."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Shadow system leverages **MQTT** for streaming sensor data from the physical system (e.g., a robot controlled by a Siemens SINUMERIK 840D sl) to the digital representation. The communication infrastructure is not explicitly detailed beyond this protocol, and no information is provided regarding **network topology, bandwidth/latency requirements, redundancy mechanisms, or security protocols** for the connection. The system does not describe a control network or bidirectional communication architecture (e.g., OPC UA or proprietary industrial protocols)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **hosting and deployment infrastructure** for the Digital Shadow system is not explicitly detailed beyond the implementation of an **Asset Administration Shell (AAS)** and a **dashboard** for visualization. No information is provided regarding **hosting platforms** (cloud, edge, or on-premise), **computational/storage requirements**, **scalability mechanisms**, or **deployment models** (e.g., containerization via Docker/Kubernetes). The document focuses on the **digital shadow’s passive data collection role** rather than infrastructure specifics, leaving deployment details unspecified."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with external systems through **Model-Based Systems Engineering (MBSE)** frameworks, which facilitate **heterogeneous data aggregation and abstraction** via **architecture description languages (ADLs)**. While the document does not explicitly enumerate data exchange protocols or interoperability standards, it implies support for **contextual data traces** (e.g., sensor streams) and **active processing components** to interpret incoming data. The **Digital Shadow Reference Model** (Fig. 1) suggests a foundational role for **data aggregation and abstraction**, though no specific protocols (e.g., MQTT, OPC UA) or integration patterns (e.g., API gateways, enterprise service buses) are detailed. The system’s active components (e.g., those enabling real-time identification) may rely on **simulation tools (Simulink)** or **general-purpose code (C++, Java)** for cross-system interoperability."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE)** standards, including **SysML** (Systems Modeling Language) for system modeling and **architecture description languages (ADLs)** such as **ACME**, **AADL**, and **MontiArc**, which are standardized or widely adopted in systems engineering. **SysML v1.7** introduces state machines for behavioral modeling, aligning with broader **OMG (Object Management Group)** standards. The system may also leverage **interoperability standards** implied by the integration of heterogeneous tools (e.g., **MathWorks Simulink**, simulation tools, and general-purpose languages like **C++/Java**), though specific interoperability protocols (e.g., **OPC UA**, **FIXML**) are not mentioned. **Certification requirements** or **compliance frameworks** are not explicitly detailed, but adherence to **MBSE best practices** (e.g., [18]–[22]) suggests alignment with industry standards for system modeling and engineering."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system incorporates **safety cells** to restrict operational ranges, specifically limiting the **MAX-100-2-25-P robotic arm** to a **safety cell range of [−90°, 90°]** as per its functional specifications ([44]). Data from the physical asset is **streamed via MQTT** ([52]), a lightweight publish-subscribe protocol, though the documents do not specify encryption mechanisms (e.g., TLS/SSL) or granular cybersecurity controls like OAuth 2.0 or IEC 62443 compliance. The system leverages **Functional Mockup Interface (FMI)** ([51]) for simulation model exchange, which inherently supports interoperability but lacks explicit mention of security hardening for communication channels. No evidence of **access control mechanisms**, **authentication systems**, or **risk assessment methodologies** (e.g., ISO 27001, NIST SP 800-53) is provided in the referenced documents."
]