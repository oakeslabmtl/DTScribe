instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements, Function, Logic, Physical) MBSE methodology"
]

instance OOSEMMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM (Object-Oriented Systems Engineering Method) MBSE methodology"
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES (Software Product Line Engineering and Systems Engineering) MBSE methodology"
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT (System Model-based Architecture and Design Tool) MBSE methodology"
]

instance ACMEADL : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component and connector architecture"
]

instance AADLADL : DTDFVocab:Enabler [
    base:desc "AADL (Architecture Analysis & Design Language) for embedded systems architecture"
]

instance MontiArcADL : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component and connector architecture"
]

instance SysMLIBD : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for structural modeling"
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavior modeling"
]

instance SysMLStateMachine : DTDFVocab:Enabler [
    base:desc "SysML v1.7 state machines for behavior modeling"
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and model-based design"
]

instance CppProgrammingLanguage : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior specification"
]

instance JavaProgrammingLanguage : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior specification"
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML model for structural modeling using Internal Block Diagrams",
    inputTo SysMLIBD, SimulinkTool
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME architecture description model for component and connector architecture",
    inputTo ACMEADL
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL (Architecture Analysis & Design Language) for embedded systems architecture",
    inputTo AADLADL
]

instance MontiArcArchitectureModel : DTDFVocab:Model [
    base:desc "MontiArc Architecture Description Language for component and connector architecture",
    inputTo MontiArcADL
]

instance MontiArcAutomatonBehaviorModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton behavior modeling for dynamic system behavior",
    inputTo MontiArcAutomaton
]

instance SysMLStateMachineBehaviorModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines for behavior modeling",
    inputTo SysMLStateMachine
]

instance RequirementsModel : DTDFVocab:Model [
    base:desc "Requirements layer model in MBSE process",
    inputTo RFLPMethodology
]

instance FunctionalModel : DTDFVocab:Model [
    base:desc "Functional layer model in MBSE process",
    inputTo OOSEMMMethodology
]

instance LogicalModel : DTDFVocab:Model [
    base:desc "Logical layer model in MBSE process",
    inputTo SPESMethodology
]

instance ProductModel : DTDFVocab:Model [
    base:desc "Product/technical layer model in MBSE process",
    inputTo SMArDTMethodology
]

instance SysMLStructuralModelDataTransmitted : DTDFVocab:DataTransmitted [
    producedFrom SysMLStructuralModel
]

instance ACMEArchitectureModelDataTransmitted : DTDFVocab:DataTransmitted [
    producedFrom ACMEArchitectureModel
]

instance AADLArchitectureModelDataTransmitted : DTDFVocab:DataTransmitted [
    producedFrom AADLArchitectureModel
]

instance MontiArcArchitectureModelDataTransmitted : DTDFVocab:DataTransmitted [
    producedFrom MontiArcArchitectureModel
]

instance MontiArcAutomatonBehaviorModelDataTransmitted : DTDFVocab:DataTransmitted [
    producedFrom MontiArcAutomatonBehaviorModel
]

instance SysMLStateMachineBehaviorModelDataTransmitted : DTDFVocab:DataTransmitted [
    producedFrom SysMLStateMachineBehaviorModel
]

instance RequirementsModelDataTransmitted : DTDFVocab:DataTransmitted [
    producedFrom RequirementsModel
]

instance FunctionalModelDataTransmitted : DTDFVocab:DataTransmitted [
    producedFrom FunctionalModel
]

instance LogicalModelDataTransmitted : DTDFVocab:DataTransmitted [
    producedFrom LogicalModel
]

instance ProductModelDataTransmitted : DTDFVocab:DataTransmitted [
    producedFrom ProductModel
]

instance SysMLStructuralModelData : DTDFVocab:Data [
    base:desc "Structural model data for simulation",
    fromData SysMLStructuralModelDataTransmitted,
    inputTo SimulinkTool
]

instance ACMEArchitectureModelData : DTDFVocab:Data [
    base:desc "ACME architecture model data",
    fromData ACMEArchitectureModelDataTransmitted,
    inputTo ACMEADL
]

instance AADLArchitectureModelData : DTDFVocab:Data [
    base:desc "AADL architecture model data",
    fromData AADLArchitectureModelDataTransmitted,
    inputTo AADLADL
]

instance MontiArcArchitectureModelData : DTDFVocab:Data [
    base:desc "MontiArc architecture model data",
    fromData MontiArcArchitectureModelDataTransmitted,
    inputTo MontiArcADL
]

instance MontiArcAutomatonBehaviorModelData : DTDFVocab:Data [
    base:desc "MontiArc Automaton behavior model data",
    fromData MontiArcAutomatonBehaviorModelDataTransmitted,
    inputTo MontiArcAutomaton, CppProgrammingLanguage, JavaProgrammingLanguage
]

instance SysMLStateMachineBehaviorModelData : DTDFVocab:Data [
    base:desc "SysML state machine behavior model data",
    fromData SysMLStateMachineBehaviorModelDataTransmitted,
    inputTo SysMLStateMachine, CppProgrammingLanguage, JavaProgrammingLanguage
]

instance RequirementsModelData : DTDFVocab:Data [
    base:desc "Requirements layer model data",
    fromData RequirementsModelDataTransmitted,
    inputTo RFLPMethodology
]

instance FunctionalModelData : DTDFVocab:Data [
    base:desc "Functional layer model data",
    fromData FunctionalModelDataTransmitted,
    inputTo OOSEMMMethodology
]

instance LogicalModelData : DTDFVocab:Data [
    base:desc "Logical layer model data",
    fromData LogicalModelDataTransmitted,
    inputTo SPESMethodology
]

instance ProductModelData : DTDFVocab:Data [
    base:desc "Product/technical layer model data",
    fromData ProductModelDataTransmitted,
    inputTo SMArDTMethodology
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system utilizes SysML for Model-Based Systems Engineering (MBSE), AADL, ACME, and MontiArc as architecture description languages for component & connector perspectives, along with MathWorks Simulink for behavior simulation and general-purpose programming languages like C++ or Java for detailed implementation, as referenced in the MBSE context."
]