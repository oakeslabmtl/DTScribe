// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor electrical current of permanent‑magnet synchronous motor"
    DTDFVocab:producedData CurrentMQTT
]

instance MotorShankEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor shaft measuring angular position"
    DTDFVocab:producedData MotorPositionMQTT
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder after the gearbox measuring output shaft position"
    DTDFVocab:producedData GearboxPositionMQTT
]

// C4: Physical‑to‑virtual interaction
instance CurrentMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorPositionMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShankEncoder
]

instance GearboxPositionMQTT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// C10: Models/Data (raw data)
instance CurrentData : DTDFVocab:Data [
    base:desc "Time series of motor current streamed via MQTT"
    DTDFVocab:inputTo DataProcessingEngine
    DTDFVocab:fromData CurrentMQTT
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Time series of motor shaft angular position streamed via MQTT"
    DTDFVocab:inputTo DataProcessingEngine
    DTDFVocab:fromData MotorPositionMQTT
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Time series of gearbox output shaft angular position streamed via MQTT"
    DTDFVocab:inputTo DataProcessingEngine
    DTDFVocab:fromData GearboxPositionMQTT
]

// C10: Models/Data (derived data)
instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque time series computed from current data and motor parameters"
    DTDFVocab:inputTo SimulationExecutor
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity time series computed from gearbox position data"
    DTDFVocab:inputTo SimulationExecutor
]

// C10: Models
instance MotorSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model of the permanent‑magnet synchronous motor"
    DTDFVocab:inputTo SimulationExecutor
]

instance GearwheelSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model of the gearwheel gearbox"
    DTDFVocab:inputTo SimulationExecutor
]

instance CycloidalGearboxSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model of the cycloidal gearbox"
    DTDFVocab:inputTo SimulationExecutor
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Coulomb‑Viscous friction model used in simulation"
    DTDFVocab:inputTo SimulationExecutor
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Stribeck friction model used in simulation"
    DTDFVocab:inputTo SimulationExecutor
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Dahl friction model used in simulation"
    DTDFVocab:inputTo SimulationExecutor
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "LuGre friction model used in simulation"
    DTDFVocab:inputTo SimulationExecutor
]

// C10: Data calculation model
instance DataProcessingService : DTDFVocab:Service [
    base:desc "Service that processes raw sensor data and computes derived torque and angular velocity"
    DTDFVocab:provides ComputedTorqueInfoInsight
]

// C11: Enablers
instance DataProcessingEngine : DTDFVocab:Enabler [
    base:desc "Python/C++ engine that processes MQTT sensor streams and computes derived torque and angular velocity"
    DTDFVocab:enables DataProcessingService
]

instance SimulationExecutor : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink simulation executor that runs motor, gearwheel, and gearbox models"
    DTDFVocab:enables RealTimeFrictionIdentificationService, ComparativeDataAnalysisService, SimulationUpdateService
]

instance DashboardVisualizationEngine : DTDFVocab:Enabler [
    base:desc "Dashboard engine for unified visualization of data traces and insights"
    DTDFVocab:enables DashboardVisualizationService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell integration enabler that aggregates data for further processing"
    DTDFVocab:enables NotificationService
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service that identifies real‑time friction parameters by comparing measured and simulated data"
    DTDFVocab:provides FrictionParameterUpdateInsight
]

instance ComparativeDataAnalysisService : DTDFVocab:Service [
    base:desc "Service that performs comparative analysis between measured and simulated data traces to detect wear and motion profile issues"
    DTDFVocab:provides WearDetectionInsight, MotionProfileAdjustmentInsight
]

instance SimulationUpdateService : DTDFVocab:Service [
    base:desc "Service that updates simulation model parameters, such as friction coefficients, based on identification results"
    DTDFVocab:provides UpdateFrictionParametersAction
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Service that visualizes data traces and insights on a unified dashboard"
    DTDFVocab:provides MachiningAccuracyImprovementInsight
]

instance NotificationService : DTDFVocab:Service [
    base:desc "Service that raises alerts to operators when diagnostics indicate potential wear or process deviation"
    DTDFVocab:provides NotifyOperatorAction
]

// C17: Insights/Actions
instance FrictionParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight identifying friction parameter updates needed in the simulation"
]

instance WearDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting wear indicators based on comparative data analysis"
]

instance MotionProfileAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Insight recommending motion profile adjustments to improve machining accuracy"
]

instance MachiningAccuracyImprovementInsight : DTDFVocab:Insight [
    base:desc "Insight visualizing improvements in machining accuracy through dashboard"
]

instance ComputedTorqueInfoInsight : DTDFVocab:Insight [
    base:desc "Insight reporting computed torque and angular velocity derived from sensor data"
]

instance UpdateFrictionParametersAction : DTDFVocab:Action [
    base:desc "Automatic action to update friction coefficients in simulation models"
    DTDFVocab:IsAutomatic true
]

instance AdjustMotionProfileAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust motion profiles in the robot controller"
    DTDFVocab:IsAutomatic true
]

instance NotifyOperatorAction : DTDFVocab:Action [
    base:desc "Automatic notification sent to operators to indicate diagnostics or desired adjustments"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time, continuous operation; sensor data is streamed in real time, and simulation models are executed synchronously to match the data rate, enabling immediate feedback and model update."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated architecture where the asset (robot), its engineering model, processing component, simulation models, and sensor data streams are integrated via the AAS; the digital shadow processes incoming data traces, performs simulation and model updating, and exposes a dashboard for monitoring."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (SysML structural and behavioral modeling), Development (implementation of Simulink simulation models and MQTT data ingestion), and Operational (continuous real‑time identification of friction during robot use). Manufacturing and validation phases are not explicitly covered in the document."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "White‑box analytical friction models combined with data‑driven black‑box models allow continuous parameter identification; simulation fidelity depends on accurate motor constants, gear ratios, and encoder precision; traceability of data generation ensures validation; uncertainties in friction due to wear, load, and temperature are addressed by real‑time data linking."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT communication between robot sensors and the digital shadow; data channels include motor current, encoder signals; optional Asset Administration Shell for semantic integration; processing component consumes these streams on a defined topic."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with SysML for system modeling, Asset Administration Shell (AAS) standard for data integration, and usage of established MBSE practices."
]