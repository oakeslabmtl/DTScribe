// C3: Physical sensing component (Digital Shadow Collector)
instance DigitalShadowCollector : DTDFVocab:SensingComponent [
    base:desc "Automated collection of contextual data traces from the physical asset, forming the Digital Shadow"
    DTDFVocab:producedData DigitalShadowTransmission
]

// C4: Data Transmitted
instance DigitalShadowTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DigitalShadowCollector
]

// C10: Data
instance DigitalShadowData : DTDFVocab:Data [
    base:desc "Structured repository of contextual data traces ingested by the Digital Twin"
    DTDFVocab:fromData DigitalShadowTransmission
    DTDFVocab:inputTo SimulinkDataRepository
]

// C11: Enabler
instance SimulinkDataRepository : DTDFVocab:Enabler [
    base:desc "Simulink-engineered repository that stores ingested data for simulation-based testing"
    DTDFVocab:enables SimulationEngagementService
]

// C6: Service
instance SimulationEngagementService : DTDFVocab:Service [
    base:desc "Service that integrates simulated dynamics within the Digital Twin using Simulink"
    DTDFVocab:provides SimulationInsight
]

// C17: Insight
instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Dynamic insight derived from Simulink simulation of the twin model"
]

// C10: Models
instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "Functional and logical structures drafted in SysML"
    DTDFVocab:inputTo SysMLRepositoryEnabler
]

instance MontiArcBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioural dynamics represented via state‑machine/automaton in MontiArc"
    DTDFVocab:inputTo MontiArcRepositoryEnabler
]

instance SimulinkSimModel : DTDFVocab:Model [
    base:desc "Simulink model for simulation‑based testing of dynamic aspects"
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance AnalyticalCPlusPlusModel : DTDFVocab:Model [
    base:desc "Analytical model implemented in C++ for code‑level simulation"
    DTDFVocab:inputTo AnalyticalEngineEnabler
]

// C11: Enablers for models
instance SysMLRepositoryEnabler : DTDFVocab:Enabler [
    base:desc "Repository enabler that manages SysML model artefacts"
    DTDFVocab:enables SysMLValidationService
]

instance MontiArcRepositoryEnabler : DTDFVocab:Enabler [
    base:desc "Repository enabler that manages MontiArc model artefacts"
    DTDFVocab:enables MontiArcValidationService
]

instance SimulinkEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine enabler that runs Simulink models"
    DTDFVocab:enables SimulinkSimulationService
]

instance AnalyticalEngineEnabler : DTDFVocab:Enabler [
    base:desc "Runtime enabler for executing analytical C++ models"
    DTDFVocab:enables AnalyticalValidationService
]

// C6: Services for validation/simulation
instance SysMLValidationService : DTDFVocab:Service [
    base:desc "Service that validates SysML models against requirements"
    DTDFVocab:provides SysMLValidationInsight
]

instance MontiArcValidationService : DTDFVocab:Service [
    base:desc "Service that validates MontiArc behavioural models against simulation results"
    DTDFVocab:provides MontiArcValidationInsight
]

instance SimulinkSimulationService : DTDFVocab:Service [
    base:desc "Service that runs Simulink simulations to test dynamic behaviours"
    DTDFVocab:provides DynamicSimulationInsight
]

instance AnalyticalValidationService : DTDFVocab:Service [
    base:desc "Service that validates analytical C++ models via code‑generation and simulation"
    DTDFVocab:provides CodeLevelSimulationInsight
]

// C17: Validation Insights
instance SysMLValidationInsight : DTDFVocab:Insight [
    base:desc "Insight into compliance of SysML model with specified requirements"
]

instance MontiArcValidationInsight : DTDFVocab:Insight [
    base:desc "Insight into consistency of MontiArc state‑machine behaviours with simulation data"
]

instance DynamicSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight into dynamic performance of the twin during Simulink simulation"
]

instance CodeLevelSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight into code‑level simulation accuracy of analytical C++ models"
]

// C17: Automated Action
instance DeployCodeAction : DTDFVocab:Action [
    base:desc "Automated action to deploy generated C++ code into operational environment"
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle follows the MBSE multi‑level abstraction model described in Section II.B.1. Initial requirements are captured in the requirement layer using SysML requirement diagrams. Functional behaviour is expressed in the functional architecture layer through SysML activity and sequence diagrams, potentially enriched by MontiArc automaton or SysML state machines. The logical architecture is then articulated with ADLs (ACME, AADL, MontiArc) which provide component‑connector views and detailed interface definitions. Finally, at the product/technical layer the DT is instantiated as executable code – typically generated from SysML or MontiArc models and implemented in C++ or Java – and integrated with simulation environments such as MathWorks Simulink for dynamic validation. Transition between stages is managed by traceability links inherent in the MBSE toolchain (e.g., SysML requirement to function, to component, to code). Governance of the lifecycle relies on MBSE best practices, including version control of models, change management, and model‑to‑code consistency checks. This staged, traceable approach ensures that each abstraction level receives a dedicated representation, and that evolution from conception to deployment is orchestrated through rigorous documentation and tool support."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT specification in the document adheres to several widely accepted industry modeling standards. System representation is performed with SysML, a standardized systems modeling language that supports requirement, activity, sequence, and state machine diagrams. Component‑connector views are expressed using architecture description languages such as ACME, AADL, and MontiArc, each of which provides formal semantic descriptions of interfaces and interconnections. The integration of state‐machine based behavior is supported by SysML activity/state machine diagrams and MontiArc Automaton, enabling formal verification. Additionally, the document references SMArDT, an MBSE methodology that incorporates best‑practice artefacts aligned with functional safety and industrial safety standards, thus facilitating interoperability with existing engineering environments and compliance with established model‑based development guidelines."
]