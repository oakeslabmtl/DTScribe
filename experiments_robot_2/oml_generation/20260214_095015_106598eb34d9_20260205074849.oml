// Component representing the first vertical axis of the MABI MAX 100 industrial robot
instance MABIMAX100FirstAxis : DTDFVocab:Component [
    base:desc "Serial industrial robot MABI MAX 100 first vertical axis comprising a permanent‑magnet synchronous motor, gear shaft, and cycloidal gearbox"
]

// Sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring I_M at the motor of the MABI MAX 100 first vertical axis"
    DTDFVocab:producedData MotorCurrentMQTTData
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder positioned directly on the motor shaft of the first vertical axis"
    DTDFVocab:producedData MotorEncoderAngleMQTTData
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the gearbox of the first vertical axis"
    DTDFVocab:producedData GearboxEncoderAngleMQTTData
]

// Data transmitted via MQTT
instance MotorCurrentMQTTData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderAngleMQTTData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderAngleMQTTData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// In‑stream data derived from sensors
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Streamed motor current values (I_M) obtained via MQTT from Siemens SINUMERIK 840D controller"
    DTDFVocab:fromData MotorCurrentMQTTData
    DTDFVocab:inputTo MATLABSimulinkTools, AASLinker
]

instance MotorEncoderAngleData : DTDFVocab:Data [
    base:desc "Motor encoder angle values streamed via MQTT"
    DTDFVocab:fromData MotorEncoderAngleMQTTData
    DTDFVocab:inputTo MATLABSimulinkTools, AASLinker
]

instance GearboxEncoderAngleData : DTDFVocab:Data [
    base:desc "Secondary gearbox encoder angle values streamed via MQTT"
    DTDFVocab:fromData GearboxEncoderAngleMQTTData
    DTDFVocab:inputTo MATLABSimulinkTools, AASLinker
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Derived torque calculated from motor current measurements"
    DTDFVocab:fromData MotorCurrentMQTTData
    DTDFVocab:inputTo MATLABSimulinkTools, AASLinker
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity derived from motor encoder readings"
    DTDFVocab:fromData MotorEncoderAngleMQTTData
    DTDFVocab:inputTo MATLABSimulinkTools, AASLinker
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration derived from motor encoder readings"
    DTDFVocab:fromData MotorEncoderAngleMQTTData
    DTDFVocab:inputTo MATLABSimulinkTools, AASLinker
]

// Services to resolve references
instance EngineeringModelService : DTDFVocab:Service [
    base:desc "Service providing engineering model information for the first axis"
]

instance DataStreamService : DTDFVocab:Service [
    base:desc "Service managing MQTT data streaming for the first axis"
]

instance AssetLinkingService : DTDFVocab:Service [
    base:desc "Service linking data series to the asset model for the first axis"
]

// Enablers (tooling and enablers)
instance SysMLTools : DTDFVocab:Enabler [
    base:desc "SysML used for structural modeling of the first vertical axis of the MABI MAX 100 robot"
    DTDFVocab:enables EngineeringModelService
]

instance MATLABSimulinkTools : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink used for executable simulation and friction modeling of motor, gearbox, and axis dynamics"
    DTDFVocab:enables FrictionIdentificationService, MotorControlAdjustmentService, MultiPhysicsComparisonService, RealTimeDashboardService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker handling real‑time data streaming from the Siemens SINUMERIK 840D controller"
    DTDFVocab:enables DataStreamService
]

instance AASLinker : DTDFVocab:Enabler [
    base:desc "Asset Administration Shells linking data series to the asset model for the first vertical axis"
    DTDFVocab:enables AssetLinkingService
]

instance VisualizationDashboard : DTDFVocab:Enabler [
    base:desc "Custom visualization dashboard for real‑time monitoring of the digital twin"
    DTDFVocab:enables RealTimeDashboardService
]

// Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service performing continuous friction identification using white‑box and black‑box models"
    DTDFVocab:provides UpdatedFrictionModelParametersInsight, AdjustedControlStrategyInsight, WearTemperatureEffectInsight
]

instance MotorControlAdjustmentService : DTDFVocab:Service [
    base:desc "Service enabling adjustment of motor current setpoints based on friction analysis"
    DTDFVocab:provides MotorCurrentSetpointReTuningInsight, ReTuneMotorCurrentSetpointAction
]

instance MultiPhysicsComparisonService : DTDFVocab:Service [
    base:desc "Service executing multi‑physics comparison between simulated and measured data"
    DTDFVocab:provides MultiPhysicsComparisonInsight
]

instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Service delivering real‑time visualization of twin data streams on the custom dashboard"
    DTDFVocab:provides RealTimeDashboardInsight
]

// Insights
instance UpdatedFrictionModelParametersInsight : DTDFVocab:Insight [
    base:desc "Updated friction model parameters derived from continuous identification"
]

instance AdjustedControlStrategyInsight : DTDFVocab:Insight [
    base:desc "Adjusted control strategies suggested for the robot based on shadow analysis"
]

instance MotorCurrentSetpointReTuningInsight : DTDFVocab:Insight [
    base:desc "Potential re‑tuning of motor current setpoints to compensate for measured friction"
]

instance WearTemperatureEffectInsight : DTDFVocab:Insight [
    base:desc "Insights into wear and temperature effects on friction"
]

instance MultiPhysicsComparisonInsight : DTDFVocab:Insight [
    base:desc "Multi‑physics-aware comparison between simulated and measured data"
]

instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization dashboard insight for the digital twin"
]

// Actions
instance AdjustControlStrategyAction : DTDFVocab:Action [
    base:desc "Action to adjust the control strategy based on identified friction characteristics"
    DTDFVocab:IsAutomatic true
]

instance ReTuneMotorCurrentSetpointAction : DTDFVocab:Action [
    base:desc "Action to re‑tune motor current setpoints for optimal performance"
    DTDFVocab:IsAutomatic true
]

// Models
instance FirstAxisEngineeringModel : DTDFVocab:Model [
    base:desc "Engineering model of the first vertical axis realized in SysML"
    DTDFVocab:inputTo SysMLTools
]

instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of the permanent‑magnet synchronous motor for the first axis"
    DTDFVocab:inputTo MATLABSimulinkTools
]

instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of the cycloidal gearbox for the first axis"
    DTDFVocab:inputTo MATLABSimulinkTools
]

instance AxisSimulinkModel : DTDFVocab:Model [
    base:desc "Overall Simulink model of the axis combining motor and gearbox dynamics"
    DTDFVocab:inputTo MATLABSimulinkTools
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Coulomb‑Viscous friction model used within motor simulations"
    DTDFVocab:inputTo MATLABSimulinkTools
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Stribeck friction model used within motor simulations"
    DTDFVocab:inputTo MATLABSimulinkTools
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Dahl friction model used within motor simulations"
    DTDFVocab:inputTo MATLABSimulinkTools
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "LuGre friction model used within motor simulations"
    DTDFVocab:inputTo MATLABSimulinkTools
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data streaming at each sampling cycle of the robot controller; data and simulation updates occur synchronously with the control loop (typical sampling rates of the SINUMERIK 840D controller)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Asset (first axis) → Engineering model (SysML) → Processing component (consumes sensor data and runs simulation) → Simulation models (Simulink) → Data traces (current, angles, torque, velocity) → Dashboard. All components are orchestrated centrally within the digital shadow, with data automatically linked via the AAS and streamed through MQTT."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated phase – the digital shadow represents the robot during normal operation, providing real‑time monitoring and model updating based on live sensor data."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity ensured by using executable Simulink models and analytical friction models calibrated to sensor data; traceability maintained by linking each data point to its originating source and processing chain; validation performed by comparing simulated torques/angular velocities to measured values; uncertainties in friction parameters are reduced through continuous online identification."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchanged over MQTT protocol between the robot controller (Siemens SINUMERIK 840D sl) and the digital shadow; Asset Administration Shells (AAS) used in the data linkage; no direct network details beyond standard MQTT communication are specified."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Industry 4.0 Asset Administration Shells (AAS) standard; SysML modeling language (ISO/IEC 19510); MATLAB Simulink for simulation; integration of white‑box and black‑box friction models adheres to standard multi‑physics modeling practices."
]