// C3: Physical Sensing Components
instance ForceTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "High-resolution sensor deployed on robotic joints to measure nonlinear friction and dynamic interactions with sub-millimeter positional precision for scalable identification methods (Sorrentino et al., [14])"
    DTDFVocab:producedData ForceTorqueDataTransmitted
]

instance EncoderSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency angular position sensor (=1kHz) for robotic arm joints, synchronized with simulation tools for low-latency validation of kinematic models"
    DTDFVocab:producedData AngularPositionDataTransmitted
]

instance AccelerometerSensor : DTDFVocab:SensingComponent [
    base:desc "Multi-axis accelerometer measuring dynamic effects in robotic cells with sub-degree precision for behavioral forecasting of manufacturing cells (Huang et al., 2021)"
    DTDFVocab:producedData AccelerationDataTransmitted
]

instance InjectionMoldingPressureSensor : DTDFVocab:SensingComponent [
    base:desc "High-precision pressure sensor for continuous monitoring of injection molding process parameters with real-time data transmission for process optimization"
    DTDFVocab:producedData InjectionMoldingPressureDataTransmitted
]

instance EnvironmentalConditionSensor : DTDFVocab:SensingComponent [
    base:desc "Multi-parameter sensor measuring temperature, humidity, and atmospheric pressure for contextual data traces in manufacturing environments"
    DTDFVocab:producedData EnvironmentalConditionDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance ForceTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ForceTorqueSensor
]

instance AngularPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderSensor
]

instance AccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AccelerometerSensor
]

instance InjectionMoldingPressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InjectionMoldingPressureSensor
]

instance EnvironmentalConditionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalConditionSensor
]

// C10: Models/Data
instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) representing functional/logical architecture of manufacturing systems with state machines for behavioral modeling (v1.7)"
    DTDFVocab:inputTo SysMLSimulationEnabler
]

instance AADLComponentModel : DTDFVocab:Model [
    base:desc "AADL model defining component-interaction architecture for safety-critical manufacturing systems with explicit interfaces and connectors"
    DTDFVocab:inputTo AADLSimulationEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc automaton-based behavioral model for robotic system dynamics with probabilistic latent variable integration for nonlinear phenomena"
    DTDFVocab:inputTo MontiArcSimulationEnabler
]

instance SimulinkInjectionMoldingModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink dynamic simulation model for injection molding process with real-time control logic prototyping"
    DTDFVocab:inputTo SimulinkExecutionEngine
]

instance MachineLearningFaultDetectionModel : DTDFVocab:Model [
    base:desc "Data-driven machine learning model for fault prediction in manufacturing systems using historical and real-time sensor data (Muctadir et al., 2024)"
    DTDFVocab:inputTo MLAnalyticsPlatform
]

instance ProcessOptimizationModel : DTDFVocab:Model [
    base:desc "Mathematical programming model for continuous manufacturing process optimization using digital shadow-derived insights (Idzik et al., 2023)"
    DTDFVocab:inputTo OptimizationEngine
]

instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated and abstracted sensor data traces including telemetry, operational logs, and environmental parameters for purpose-specific analysis"
    DTDFVocab:fromData ForceTorqueDataTransmitted, AngularPositionDataTransmitted, AccelerationDataTransmitted, InjectionMoldingPressureDataTransmitted, EnvironmentalConditionDataTransmitted
    DTDFVocab:inputTo DataAggregationPipeline
]

instance DigitalShadowData : DTDFVocab:Data [
    base:desc "Passive digital representation of physical system state derived from contextual data traces with traceability to source processing components"
    DTDFVocab:fromData ContextualDataTrace
    DTDFVocab:inputTo ShadowProcessingComponent
]

instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Dynamic simulation outputs from Simulink and other tools used for validation against real-time manufacturing data"
    DTDFVocab:fromData InjectionMoldingPressureDataTransmitted
    DTDFVocab:inputTo ValidationEngine
]

// C11: Enablers
instance SysMLSimulationEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based simulation environment for functional/logical architecture validation and behavioral modeling using state machines"
    DTDFVocab:enables MonitoringService, VisualizationService
]

instance AADLSimulationEnabler : DTDFVocab:Enabler [
    base:desc "AADL simulation toolchain for component-interaction modeling and safety-critical system validation"
    DTDFVocab:enables ControlService, OptimizationService
]

instance MontiArcSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc automaton-based simulation platform for robotic system behavioral modeling with probabilistic extensions"
    DTDFVocab:enables PredictionService, DecisionSupportService
]

instance SimulinkExecutionEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink real-time execution engine for dynamic system simulation and control logic prototyping"
    DTDFVocab:enables ControlService, VisualizationService
]

instance MLAnalyticsPlatform : DTDFVocab:Enabler [
    base:desc "AI/ML platform integrating machine learning models for fault detection, predictive maintenance, and behavioral forecasting"
    DTDFVocab:enables PredictionService, MaintenanceService
]

instance OptimizationEngine : DTDFVocab:Enabler [
    base:desc "Mathematical programming engine for production planning and continuous manufacturing process optimization"
    DTDFVocab:enables OptimizationService, DecisionSupportService
]

instance DataAggregationPipeline : DTDFVocab:Enabler [
    base:desc "Kafka-based data aggregation pipeline for real-time contextual data trace collection and abstraction"
    DTDFVocab:enables MonitoringService, ShadowProcessingComponent
]

instance ShadowProcessingComponent : DTDFVocab:Enabler [
    base:desc "Software agent component interpreting digital shadow data for state estimation and anomaly detection"
    DTDFVocab:enables MonitoringService, ControlService
]

instance ValidationEngine : DTDFVocab:Enabler [
    base:desc "Engine for validating simulation outputs against real-time manufacturing data"
    DTDFVocab:enables MonitoringService
]

instance RESTfulAPIMiddleware : DTDFVocab:Enabler [
    base:desc "RESTful API middleware for real-time data exchange between physical systems and digital twin components"
    DTDFVocab:enables MonitoringService, ControlService, VisualizationService, PredictionService, OptimizationService, DecisionSupportService, MaintenanceService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time telemetry aggregation and anomaly detection service using contextual data traces and model-based state estimation"
    DTDFVocab:provides RealTimeMonitoringInsight, AnomalyDetectionInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Process optimization service for continuous manufacturing using digital shadow-derived insights and mathematical programming"
    DTDFVocab:provides ProcessOptimizationInsight, ResourceAllocationInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Fault prediction and maintenance scheduling service using historical and real-time data with machine learning models"
    DTDFVocab:provides FaultPredictionInsight, MaintenanceRecommendationAction
]

instance ControlService : DTDFVocab:Service [
    base:desc "Closed-loop control service interpreting digital shadow data to adjust physical system parameters in real-time"
    DTDFVocab:provides ControlParameterAdjustmentAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D/4D simulation and dashboard-based analytics service for stakeholder-specific insights"
    DTDFVocab:provides InteractiveSimulationInsight, DashboardAnalyticsInsight
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Production planning and control decision support system using digital twin insights"
    DTDFVocab:provides StrategicOptimizationInsight, ProductionPlanningAction
]

instance MaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance service for fault diagnosis and equipment health monitoring"
    DTDFVocab:provides EquipmentHealthInsight, MaintenanceScheduleAction
]

// C17: Insights/Actions
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time operational status of manufacturing systems with contextual data trace visualization"
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Identified anomalies in sensor data patterns indicating potential system deviations"
]

instance ProcessOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized process parameters for continuous manufacturing derived from digital shadow analysis"
]

instance ResourceAllocationInsight : DTDFVocab:Insight [
    base:desc "Recommended resource allocation strategies based on production capacity analysis"
]

instance FaultPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted fault occurrences with confidence intervals for maintenance planning"
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Automated maintenance scheduling recommendations based on predictive analytics"
    DTDFVocab:IsAutomatic true
]

instance ControlParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Real-time adjustment of physical system parameters based on digital twin analysis"
    DTDFVocab:IsAutomatic true
]

instance InteractiveSimulationInsight : DTDFVocab:Insight [
    base:desc "3D/4D interactive simulation environment for operator training and process validation"
]

instance DashboardAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Stakeholder-specific dashboard analytics with real-time KPI visualization"
]

