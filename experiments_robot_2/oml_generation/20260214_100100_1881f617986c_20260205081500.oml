// C10: Models/Data
instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based functional architecture model covering system requirements, functional decomposition, and logical architecture components as part of MBSE methodology"
    DTDFVocab:inputTo SysMLModelingEnabler, MontiArcComponentConnectorEnabler
]

instance SysMLLogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based logical architecture model defining system components, interfaces, and interconnections using Internal Block Diagrams (IBDs) for component-connector views"
    DTDFVocab:inputTo SysMLModelingEnabler, MontiArcAutomatonEnabler
]

instance SysMLProductLayerModel : DTDFVocab:Model [
    base:desc "SysML product layer model representing physical system components and their technical specifications for digital twin alignment"
    DTDFVocab:inputTo SysMLModelingEnabler, AADLArchitectureEnabler
]

instance MontiArcComponentConnectorModel : DTDFVocab:Model [
    base:desc "MontiArc-based component-connector architecture model defining system components, interfaces, and composition relationships"
    DTDFVocab:inputTo MontiArcComponentConnectorEnabler, MontiArcAutomatonEnabler
]

instance MontiArcAutomatonBehaviorModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton behavioral model for dynamic system behavior simulation using state machines and automata"
    DTDFVocab:inputTo MontiArcAutomatonEnabler, SimulinkSimulationEnabler
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink-based dynamic simulation model for detailed behavioral analysis and system optimization"
    DTDFVocab:inputTo SimulinkSimulationEnabler, CppJavaImplementationEnabler
]

instance ContextualDataTraceAggregationModel : DTDFVocab:Model [
    base:desc "Model for aggregating and abstracting contextual data traces (sensor data, operational logs) from physical system for digital representation"
    DTDFVocab:inputTo DataIntegrationEnabler, DataPreprocessingEnabler
]

instance UMLClassDiagramDataModel : DTDFVocab:Model [
    base:desc "UML-based class diagram model formalizing data aggregation and abstraction workflows as per Digital Shadow Reference Model"
    DTDFVocab:inputTo DataIntegrationEnabler, SysMLModelingEnabler
]

instance StructuredSensorData : DTDFVocab:Data [
    base:desc "Structured time-series sensor data collected from physical system components (e.g., temperature, pressure, vibration)"
    DTDFVocab:fromData SensorDataTransmitted
    DTDFVocab:inputTo DataPreprocessingEnabler, DataIntegrationEnabler
]

instance UnstructuredOperationalLogs : DTDFVocab:Data [
    base:desc "Unstructured operational logs including images, audio, and text-based operational records from physical system"
    DTDFVocab:fromData SensorDataTransmitted
    DTDFVocab:inputTo DataPreprocessingEnabler, DataIntegrationEnabler
]

instance HistoricalSystemRecords : DTDFVocab:Data [
    base:desc "Historical system records including past operational states, maintenance logs, and performance metrics"
    DTDFVocab:fromData ExternalSystemDataTransmitted
    DTDFVocab:inputTo DataIntegrationEnabler, DataPreprocessingEnabler
]

instance ExternalSystemApiData : DTDFVocab:Data [
    base:desc "Data from external system APIs providing supplementary information for digital twin context"
    DTDFVocab:fromData ExternalSystemDataTransmitted
    DTDFVocab:inputTo DataIntegrationEnabler, DataPreprocessingEnabler
]

instance ProcessedFeatureData : DTDFVocab:Data [
    base:desc "Processed feature data after dimensionality reduction, anomaly detection, and normalization from raw sensor inputs"
    DTDFVocab:fromData SensorDataTransmitted
    DTDFVocab:inputTo DataPreprocessingEnabler, DataIntegrationEnabler
]

instance SimulationInputData : DTDFVocab:Data [
    base:desc "Prepared simulation input data including validated and normalized datasets for dynamic system analysis"
    DTDFVocab:fromData ProcessedFeatureData, HistoricalSystemRecords
    DTDFVocab:inputTo SimulinkSimulationEnabler, PredictiveAnalyticsService
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based modeling enabler supporting MBSE methodologies (RFLP, OOSEM) for multi-layer system architecture modeling"
    DTDFVocab:enables SysMLModelingService, DataIntegrationService
]

instance MontiArcComponentConnectorEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc component-connector architecture enabler for defining system components, interfaces, and composition relationships"
    DTDFVocab:enables ArchitectureDefinitionService, ComponentInteractionService
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton enabler for behavioral modeling using state machines and automata for dynamic system simulation"
    DTDFVocab:enables BehavioralModelingService, StateTransitionService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation enabler for detailed dynamic system analysis and optimization"
    DTDFVocab:enables SimulationService, PredictiveAnalyticsService
]

instance CppJavaImplementationEnabler : DTDFVocab:Enabler [
    base:desc "C++/Java implementation enabler for custom logic execution and physical system integration"
    DTDFVocab:enables CustomLogicService
]

instance AADLArchitectureEnabler : DTDFVocab:Enabler [
    base:desc "AADL (Architecture Analysis & Design Language) enabler for architecture description and system deployment modeling"
    DTDFVocab:enables ArchitectureDefinitionService, DeploymentService
]

instance DataIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Data integration enabler handling ETL pipelines and middleware solutions for heterogeneous data source unification"
    DTDFVocab:enables DataAggregationService, DataConsistencyService
]

instance DataPreprocessingEnabler : DTDFVocab:Enabler [
    base:desc "Data preprocessing enabler performing feature extraction, dimensionality reduction, and anomaly detection on raw sensor data"
    DTDFVocab:enables DataPreprocessingService, FeatureExtractionService
]

instance BehavioralModelingEnabler : DTDFVocab:Enabler [
    base:desc "Behavioral modeling enabler integrating state machines and automata for dynamic system behavior simulation"
    DTDFVocab:enables BehavioralModelingService, PredictiveBehaviorService
]

// C6: Services
instance SysMLModelingService : DTDFVocab:Service [
    base:desc "Service providing SysML-based multi-layer system modeling (requirements, functional, logical, product layers) for digital twin alignment"
    DTDFVocab:provides SystemArchitectureInsight, ModelConsistencyInsight
]

instance ArchitectureDefinitionService : DTDFVocab:Service [
    base:desc "Service defining system architecture using ADLs (ACME, AADL, MontiArc) for component-connector relationships"
    DTDFVocab:provides ComponentInteractionInsight, SystemCompositionInsight
]

instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Service enabling behavioral modeling through state machines and automata for dynamic system simulation"
    DTDFVocab:provides StateTransitionInsight, PredictiveBehaviorInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service providing detailed dynamic system simulation using MathWorks Simulink for performance analysis"
    DTDFVocab:provides SimulationResultsInsight, OptimizationRecommendationInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Service aggregating and abstracting contextual data traces from physical system for digital representation"
    DTDFVocab:provides DataConsistencyInsight, ContextualDataInsight
]

instance DataPreprocessingService : DTDFVocab:Service [
    base:desc "Service performing feature extraction, dimensionality reduction, and anomaly detection on raw sensor data"
    DTDFVocab:provides ProcessedDataInsight, DataQualityInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service providing predictive analytics for failure prevention and process optimization based on simulation data"
    DTDFVocab:provides FailurePredictionInsight, ProcessOptimizationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service generating multi-perspective views (functional, logical, technical) for stakeholder decision support"
    DTDFVocab:provides VisualDecisionSupportInsight, StakeholderSpecificViewInsight
]

instance CustomLogicService : DTDFVocab:Service [
    base:desc "Service implementing custom logic using C++/Java for specialized system behaviors and integrations"
    DTDFVocab:provides CustomLogicExecutionInsight, SystemIntegrationInsight
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Service managing ETL pipelines and middleware for heterogeneous data source integration"
    DTDFVocab:provides DataIntegrationInsight, SystemConsistencyInsight
]

instance ComponentInteractionService : DTDFVocab:Service [
    base:desc "Service providing insights into component interactions and interface definitions"
    DTDFVocab:provides ComponentInteractionInsight
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Service managing system deployment and architecture configuration"
    DTDFVocab:provides DeploymentInsight
]

instance DataConsistencyService : DTDFVocab:Service [
    base:desc "Service ensuring data consistency across heterogeneous sources"
    DTDFVocab:provides DataConsistencyInsight
]

instance DataValidationService : DTDFVocab:Service [
    base:desc "Service validating data quality and consistency"
    DTDFVocab:provides DataQualityInsight
]

instance FeatureExtractionService : DTDFVocab:Service [
    base:desc "Service performing feature extraction from raw sensor data"
    DTDFVocab:provides ProcessedDataInsight
]

instance PredictiveBehaviorService : DTDFVocab:Service [
    base:desc "Service providing predictive behavior insights based on simulation"
    DTDFVocab:provides PredictiveBehaviorInsight
]

instance StateTransitionService : DTDFVocab:Service [
    base:desc "Service managing state transitions and behavioral dynamics"
    DTDFVocab:provides StateTransitionInsight
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Service providing decision support through visualization and analysis"
    DTDFVocab:provides VisualDecisionSupportInsight
]

