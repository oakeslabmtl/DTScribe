// C3: Physical sensing component (one-way data collector for digital shadow)
instance PhysicalObjectDigitalShadowSensor : DTDFVocab:SensingComponent [
    base:desc "Automated one-way data collector that continuously gathers contextual data traces from the cyber‑physical system for the digital shadow (passive flow)."
    DTDFVocab:producedData PhysicalToDigitalTrace
]

// C4: Physical-to-virtual interaction – data transmitted
instance PhysicalToDigitalTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalObjectDigitalShadowSensor
]

// C5: Data (output traces stored centrally)
instance DigitalTwinTraceData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted output traces generated by processing components and stored in the central Thingsboard memory."
    DTDFVocab:fromData PhysicalToDigitalTrace
    DTDFVocab:inputTo MBSEStackEnabler, SimulationEngineEnabler, ProgrammingLanguageEnabler, SMArDTModelingEnabler
]

// C10: Models – physics‑based and data‑driven
instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "White‑box physics‑based dynamic simulation model created in MathWorks Simulink."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance NeuralNetworkFrictionModel : DTDFVocab:Model [
    base:desc "Black‑box data‑driven neural‑network model for friction, trained on sensor data."
    DTDFVocab:inputTo ProgrammingLanguageEnabler
]

// C11: Enablers (tooling and methodologies)
instance MBSEStackEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Based Systems Engineering stack leveraging SysML diagrams, ACME, AADL, MontiArc, and MontiArcAutomaton specifications."
    DTDFVocab:enables DataProcessingService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engines such as MathWorks Simulink and DEVS discrete‑event frameworks."
    DTDFVocab:enables DataProcessingService
]

instance ProgrammingLanguageEnabler : DTDFVocab:Enabler [
    base:desc "General‑purpose programming languages C++ and Java used for executable code generation of processing components."
    DTDFVocab:enables DataProcessingService
]

instance SMArDTModelingEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT modeling approach for automotive software testing integrated into the DT development workflow."
    DTDFVocab:enables DataProcessingService
]

// C6: Service (processing and storage)
instance DataProcessingService : DTDFVocab:Service [
    base:desc "Service that processes input data traces through models and stores resulting traces in Thingsboard."
    DTDFVocab:provides TraceabilityInsight, DataVisualizationAction
]

// C17: Insight
instance TraceabilityInsight : DTDFVocab:Insight [
    base:desc "Fine‑grained traceability linking each output data trace to its originating processing component, input traces, and model used."
]

// C17: Action
instance DataVisualizationAction : DTDFVocab:Action [
    base:desc "Visualization of processed simulation results and data traces for engineers."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin extends the digital shadow by adding active components that can interpret incoming data and push control information back to the physical system. These active components enable the twin to send commands or configuration updates to the physical object, though the documents do not detail command formats, authentication, or confirmation mechanisms."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The approach requires high model fidelity by continuously updating physics‑based (white‑box) and data‑driven (black‑box) friction models with the live data stream, ensuring the models stay accurate over the robot’s life (Document 4). Verification and traceability are achieved by linking each data trace back to the processing component, input traces and the model that produced it, thereby supporting detection of errors and model correctness (Document 3). The correctness of transformations between modeling artifacts (e.g., from SysML to simulation models) is emphasized as a prerequisite for reliable digital shadows (Document 2). Real‑time constraints such as control system dead time are considered to guarantee that model updates meet the timing requirements of the robot control loop (Document 4)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The documents reference the MQTT protocol (implemented by the Mosquitto broker) and the ThingsBoard IoT platform as examples of communication infrastructure that can be used for connecting physical devices to digital models. These technologies provide the underlying network communication for transmitting data traces, but the specific network topology, bandwidth, latency, or redundancy provisions are not described."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "A cloud‑based deployment is suggested for digital shadow and twin services, as exemplified by the study on using cloud technologies for a CNC machine digital shadow at the machine shop floor level. The documents do not specify the exact hosting platform, scaling strategies, storage sizes, or availability guarantees."
]