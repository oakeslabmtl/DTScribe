// Acting Components – mechanical actuation
instance PMSMActuator : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor (PMSM) on the first axis, rated for closed‑loop torque and position control."
]
instance SINUMERIKController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D CNC controller providing closed‑loop torque and position regulators exposes Profinet and OPC UA APIs."
]

// Acting Component – reference trajectory generation
instance TrajectoryPlanner : DTDFVocab:ActingComponent [
    base:desc "Planner that generates high‑level reference signals defining the desired motion trajectory provides command payloads over Profinet."
]

// Sensing Components – position encoders
instance Drive1PositionEncoderA : DTDFVocab:SensingComponent [
    base:desc "High‑resolution incremental encoder on Drive 1, delivering angular position with sub‑millidegree precision using a 12‑bit ADC."
    DTDFVocab:producedData EncoderAngleDataTransmitted
]
instance Drive1PositionEncoderB : DTDFVocab:SensingComponent [
    base:desc "Redundant high‑resolution incremental encoder on Drive 1, delivering angular position with sub‑millidegree precision using a 12‑bit ADC."
    DTDFVocab:producedData EncoderAngleDataTransmitted
]

// Sensing Component – torque sensor
instance Drive1TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Torque sensor on Drive 1, recording load data 12‑bit ADC, sampling up to 1 kHz."
    DTDFVocab:producedData TorqueDataTransmitted
]

// DataTransmitted – physical data streams
instance EncoderAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Drive1PositionEncoderA, Drive1PositionEncoderB
]
instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Drive1TorqueSensor
]
instance ReferenceTrajectoryDataTransmitted : DTDFVocab:DataTransmitted [
]
instance SimulatedFrictionDataTransmitted : DTDFVocab:DataTransmitted [
]

// Data – physical measurement data
instance EncoderAngleData : DTDFVocab:Data [
    base:desc "Measured raw angular position from the drive encoders."
    DTDFVocab:fromData EncoderAngleDataTransmitted
    DTDFVocab:inputTo MQTTMiddleware, DataStoragePlatform
]
instance TorqueData : DTDFVocab:Data [
    base:desc "Measured raw torque from the drive torque sensor."
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo MQTTMiddleware, DataStoragePlatform
]
instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Computed angular velocity derived from encoder position data, sampled at 1 kHz."
    DTDFVocab:fromData EncoderAngleDataTransmitted
    DTDFVocab:inputTo MQTTMiddleware, DataStoragePlatform
]

// Data – reference and simulation data
instance ReferenceTrajectoryData : DTDFVocab:Data [
    base:desc "Reference motion trajectory signal generated by the trajectory planner."
    DTDFVocab:fromData ReferenceTrajectoryDataTransmitted
    DTDFVocab:inputTo MQTTMiddleware, DataStoragePlatform
]
instance SimulatedFrictionData : DTDFVocab:Data [
    base:desc "Simulated friction output from the MATLAB Simulink model."
    DTDFVocab:fromData SimulatedFrictionDataTransmitted
    DTDFVocab:inputTo MQTTMiddleware, DataStoragePlatform
]

// Enablers – middleware and storage
instance MQTTMiddleware : DTDFVocab:Enabler [
    base:desc "MQTT broker handling real‑time sensor feeds at up to 50 kB/s synchronizes timestamps via NTP."
    DTDFVocab:enables MonitoringService, VisualizationService
]
instance DataStoragePlatform : DTDFVocab:Enabler [
    base:desc "Relational/NoSQL database aggregating sensor, reference, and model‑output traces for long‑term storage."
    DTDFVocab:enables MonitoringService
]
instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink runtime executing executable simulation models of friction characteristics."
    DTDFVocab:enables SimulationService
]
instance VisualizationPlatform : DTDFVocab:Enabler [
    base:desc "Visualization stack rendering live plots, trend overlays, and anomaly dashboards."
    DTDFVocab:enables VisualizationService
]
instance AnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Lightweight analytics engine normalising sensor streams, applying threshold checks, and computing KPIs."
    DTDFVocab:enables MonitoringService
]

// Services – monitoring, visualization, and simulation
instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that aggregates normalized sensor data, computes vibration‑to‑angle ratios, and triggers alerts."
    DTDFVocab:provides VibrationToAngleRatioInsight, AnomalyDetectionInsight
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Service exposing real‑time dashboards with live plots, trend overlays, and anomaly alerts."
    DTDFVocab:provides VibrationToAngleRatioInsight, AnomalyDetectionInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs the friction model simulation and injects simulated data into the twin."
    DTDFVocab:provides SimulatedFrictionInsight
]

// Insights – KPI computation and anomaly detection
instance VibrationToAngleRatioInsight : DTDFVocab:Insight [
    base:desc "Insight that computes the vibration‑to‑angle ratio KPI from angular velocity and encoder data."
]
instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight that identifies deviations beyond confidence bounds and signals anomaly events."
]
instance SimulatedFrictionInsight : DTDFVocab:Insight [
    base:desc "Insight that evaluates friction simulation outputs against real‑time measurements."
]

// Action – automated maintenance
instance TriggerMaintenanceAction : DTDFVocab:Action [
    base:desc "Action that initiates an automated maintenance workflow when anomaly thresholds are exceeded."
    DTDFVocab:IsAutomatic true
]

// Environment – Asset Administration Shell
instance AASEnvironment : DTDFVocab:Environment [
    base:contains PMSMActuator, SINUMERIKController, TrajectoryPlanner,
          Drive1PositionEncoderA, Drive1PositionEncoderB, Drive1TorqueSensor,
          MQTTMiddleware, DataStoragePlatform, SimulinkEngine,
          VisualizationPlatform, AnalyticsEngine, MonitoringService,
          VisualizationService, SimulationService
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle is organized into hierarchical abstraction levels: (1) Requirements, where high‑level specifications are captured; (2) Functional Architecture, modelled with SysML to specify system components and interfaces; (3) Logical Architecture, represented through architecture description languages (ACME, AADL, MontiArc), often enriched with state‑machine constructs; (4) Product/Technical Layer, producing executable artifacts (C++/Java code, Simulink models). Transition between phases is managed through MBSE model refinement, with each lower‑level model concretizing the preceding one, and traceability maintained via SysML‑based artifacts. Governance is typically achieved by applying MBSE practices—traceability, versioned model artifacts—though the document does not detail a formal framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed by quantitative comparison of simulated outputs against measured sensor data, with deviations used to define acceptable error margins. Validation employs statistical residual analysis, uncertainty quantification via Monte Carlo simulation, and runtime consistency checks that flag out‑of‑spec data. Corrections are applied by iteratively tuning Simulink model parameters. Quality assurance follows structured processes similar to IEC 61400‑6, guaranteeing that both data integrity and model accuracy meet documented specifications."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin relies on MQTT for transmitting real‑time sensor streams from the physical system. Data is aggregated within an Asset Administration Shell for integration. No further specifications on bandwidth, latency, redundancy or security are provided in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system conforms to several interoperability and architecture standards: the data model is encapsulated within an Asset Administration Shell (AAS) following the ISO 23249‑2/IEC 61560 framework for industrial systems; MQTT 3.1.1 is employed for real‑time bi‑directional messaging, while JSON payloads are wrapped in OPC UA data types for gateway integration; behavioural models are authored in SysML v1.7, ensuring compatibility with standard modelling tools. The combination supports certified data exchange and facilitates linkage to broader industry‑wide digital‑twin ecosystems."
]