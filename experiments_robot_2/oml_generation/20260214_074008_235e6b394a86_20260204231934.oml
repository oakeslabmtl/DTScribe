// ==============================
// Physical Sensing Components
// ==============================

// C3: Position encoder sensor
instance PositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder providing joint angle time‑series values for the six‑axis MABI MAX 100 robot."
    DTDFVocab:producedData PositionEncoderMQTTPayload
]

// C3: Motor current sensor
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor‑current measurement sensor delivering current draw time‑series for each servo motor."
    DTDFVocab:producedData MotorCurrentMQTTPayload
]

// =============================
// Physical‑to‑Virtual Interaction (Data Transmission)
// =============================

// C4: MQTT payload for position encoder
instance PositionEncoderMQTTPayload : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionEncoder
]

// C4: MQTT payload for motor current
instance MotorCurrentMQTTPayload : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// =============================
// Data (Contextual Traces)
// =============================

// C10: Position encoder trace data
instance PositionEncoderTrace : DTDFVocab:Data [
    base:desc "Contextual data trace of joint positions streamed continuously via MQTT."
    DTDFVocab:fromData PositionEncoderMQTTPayload
    DTDFVocab:inputTo SimulinkEngineEnabler, MachineLearningEngineEnabler
]

// C10: Motor current trace data
instance MotorCurrentTrace : DTDFVocab:Data [
    base:desc "Contextual data trace of motor currents streamed continuously via MQTT."
    DTDFVocab:fromData MotorCurrentMQTTPayload
    DTDFVocab:inputTo SimulinkEngineEnabler, MachineLearningEngineEnabler
]

// =============================
// Models / Data (Computational Artifacts)
// =============================

// Functional architecture model (SysML)
instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML block diagram capturing functional architecture of the MABI MAX 100 digital twin."
    DTDFVocab:inputTo AssetAdministrationShellEnabler
]

// Logical architecture model (SysML)
instance SysMLLogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram describing logical component decomposition."
    DTDFVocab:inputTo AssetAdministrationShellEnabler
]

// Component‑connector model (ACME ADL)
instance ACMEComponentConnectorModel : DTDFVocab:Model [
    base:desc "ACME architecture description language model specifying component‑connector structure."
    DTDFVocab:inputTo AssetAdministrationShellEnabler
]

// Physics‑based simulation model (Simulink)
instance SimulinkPhysicsSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink white‑box model used for physics‑based simulation of robot dynamics."
    DTDFVocab:inputTo SimulinkEngineEnabler
]

// Data‑driven ML model (black‑box)
instance MachineLearningInferenceModel : DTDFVocab:Model [
    base:desc "Trained machine‑learning model (e.g., neural network) for data‑driven prediction of robot state."
    DTDFVocab:inputTo MachineLearningEngineEnabler
]

// =============================
// Enablers (Tooling & Execution Platforms)
// =============================

// Asset Administration Shell as enabler
instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) serving as the standard information container for the twin."
    DTDFVocab:enables InsightGenerationService
]

// Simulink execution engine
instance SimulinkEngineEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink runtime engine that executes the physics‑based simulation model."
    DTDFVocab:enables InsightGenerationService
]

// Machine‑learning inference engine
instance MachineLearningEngineEnabler : DTDFVocab:Enabler [
    base:desc "Java/C++ runtime that hosts the black‑box machine‑learning inference model."
    DTDFVocab:enables AutomatedAdjustmentService
]

// =============================
// Services
// =============================

// Service that generates higher‑level insights
instance InsightGenerationService : DTDFVocab:Service [
    base:desc "Service interpreting incoming data streams and producing higher‑level data traces."
    DTDFVocab:provides HigherLevelDataInsight, ProvenanceTraceabilityInsight
]

// Service that triggers automated actions
instance AutomatedAdjustmentService : DTDFVocab:Service [
    base:desc "Service that decides on automatic adjustments based on processed insights."
    DTDFVocab:provides AutomatedDecisionAction
]

// =============================
// Insights / Actions
// =============================

// Insight: aggregated higher‑level data
instance HigherLevelDataInsight : DTDFVocab:Insight [
    base:desc "Aggregated and abstracted data trace derived from raw sensor traces."
]

// Insight: fine‑grained provenance
instance ProvenanceTraceabilityInsight : DTDFVocab:Insight [
    base:desc "Provenance information linking each insight back to originating sensor trace and processing model."
]

// Action: automated decision making
instance AutomatedDecisionAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of robot parameters based on generated insights."
    DTDFVocab:IsAutomatic true
]

// =============================
// Physical System Component
// =============================

instance MABIMAX100Robot : DTDFVocab:Component [
    base:desc "Serial six‑axis industrial manipulator MABI MAX 100 equipped with six servo motors and gearboxes."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is defined as a passive entity that neither operates autonomously nor pushes data back to the physical system; consequently no virtual‑to‑physical control commands, feedback, or validation mechanisms are described."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated according to the Digital Shadow Reference Model (Fig. 1). The model defines a class diagram that connects DataTrace objects with their originating Source, the associated Model (engineering, simulation, or data‑calculation), and a Processing component that consumes input traces and produces output traces. Concrete realization of the reference model involves mapping each reference concept to concrete elements, thereby incarnating the abstract architecture. The Processing component encodes the execution logic of the linked models and provides fine‑grained traceability via the ‘originates‑from’ association, which enables transitive tracing of data lineage throughout the twin. This arrangement constitutes the overall coordination and resource management pattern for the Digital Twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The lifecycle is expressed through successive MBSE abstraction layers: a requirements model, a functional‑architecture model, a logical‑architecture model and a product/technical model. At each stage the Digital Twin is represented by a set of formal models (e.g., SysML requirement diagrams, SysML internal block diagrams, ADL component‑connector diagrams, simulation models such as Simulink). Transition between stages is performed by a concretization step that maps abstract reference‑model concepts to concrete class‑diagram incarnations, ensuring a conformance relation that governs the evolution of the Twin through development."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The approach stresses traceability of every model element and data trace back to its origin, which is presented as a key quality‑assurance mechanism. Reliability of the Twin is said to depend on the correctness of the underlying models and on the transformations applied to the data; the authors cite the need for verification of model transformations (e.g., from SysML to simulation models) to guarantee semantic consistency. Uncertainty is addressed by combining white‑box and black‑box models, thereby reducing model error. The literature calls for explicit traceability and verification methods to ensure that data‑model mappings are correct, but no quantitative validation procedures are described in the documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange between the physical asset and the digital shadow relies on the MQTT messaging protocol, employed in a publish‑subscribe fashion. The documents identify MQTT as the transport mechanism but do not provide further details on network topology, bandwidth, latency, QoS settings, redundancy, or security (e.g., TLS) used for the connection."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The documents specify that the Digital Twin integrates with external systems using the Asset Administration Shell (AAS) as the interoperability standard defined by the Industry 4.0 framework. Sensor data and other real‑time DataTraces are streamed to the twin via the MQTT publish‑subscribe protocol, enabling lightweight, asynchronous data exchange with MES, ERP, or other enterprise systems. The AAS provides a standardized information model for exposing the twin’s services and data, while MQTT handles the message transport, thus supporting bidirectional communication and seamless integration with other Digital Twins or external IT infrastructures."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on established modelling standards: SysML is used for requirements and functional/structural diagrams; architecture description languages such as ACME, AADL and MontiArc provide component‑connector specifications; behavioural models employ SysML state machines and MontiArc Automaton. Conformance to the digital‑shadow reference model is enforced through an explicit conformance relation that maps concrete class‑diagram elements to the abstract concepts defined in the reference model, ensuring interoperability and adherence to the specified modeling standards."
]