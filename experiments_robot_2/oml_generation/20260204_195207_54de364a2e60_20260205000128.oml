// C3: Physical sensing component (digital shadow trace producer)
instance PhysicalContextTraceProducer : DTDFVocab:SensingComponent [
    base:desc "Automated one‑way data flow from the physical object to a digital object, producing contextual data traces as described in the digital‑shadow reference model."
    DTDFVocab:producedData ContextualTraceDataTransmitted
]

// C4: Physical‑to‑virtual interaction (data transmitted)
instance ContextualTraceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalContextTraceProducer
]

// C10: Data (aggregated contextual trace)
instance AggregatedContextualData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual traces organized as a trace collection for a specific purpose."
    DTDFVocab:fromData ContextualTraceDataTransmitted
    DTDFVocab:inputTo MBSEFrameworkEnabler
]

// C10: Models/Data (MBSE and ADL models)
instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "System structure captured with SysML internal block diagrams (IBDs) as part of the MBSE engineering process."
    DTDFVocab:inputTo MBSEFrameworkEnabler
]

instance SysMLBehaviorModel : DTDFVocab:Model [
    base:desc "Behavior described with SysML state machines and v1.7 extensions."
    DTDFVocab:inputTo MBSEFrameworkEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "Logical architecture expressed in the ACME architecture description language."
    DTDFVocab:inputTo ArchitectureToolEnabler
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "Logical architecture expressed in the AADL architecture description language."
    DTDFVocab:inputTo ArchitectureToolEnabler
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "Logical architecture modeled with MontiArc."
    DTDFVocab:inputTo ArchitectureToolEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "Behavioral refinement of MontiArc models using MontiArc Automaton extensions."
    DTDFVocab:inputTo ArchitectureToolEnabler
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model linked to MathWorks Simulink for executing behavior specifications."
    DTDFVocab:inputTo SimulationToolEnabler
]

instance CppImplementationModel : DTDFVocab:Model [
    base:desc "Implementation‑level model expressed in C++ as part of the active component realizing inbound data."
    DTDFVocab:inputTo ProgrammingRuntimeEnabler
]

// C11: Enablers (tooling & integration)
instance MBSEFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Based Systems Engineering (MBSE) framework integrating SysML, ADLs, and trace management."
    DTDFVocab:enables ModelIntegrationService, DataAggregationService
]

instance ArchitectureToolEnabler : DTDFVocab:Enabler [
    base:desc "Toolchain supporting ACME, AADL, MontiArc, and related architecture description languages."
    DTDFVocab:enables ModelIntegrationService
]

instance SimulationToolEnabler : DTDFVocab:Enabler [
    base:desc "Simulation environment such as MathWorks Simulink used for executing behavioral models."
    DTDFVocab:enables SimulationExecutionService
]

instance ProgrammingRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "General‑purpose runtime for C++/Java components that interpret inbound data."
    DTDFVocab:enables ModelUpdateAction
]

// C6: Services
instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Service that integrates heterogeneous models across requirements, functional, logical, and physical abstraction levels."
    DTDFVocab:provides AggregatedInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service that executes simulations in the Simulink environment."
    DTDFVocab:provides ModelUpdateAction
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Service that aggregates contextual trace data and abstracts it for specific analysis purposes."
    DTDFVocab:provides AggregatedInsight
]

// C17: Insights/Actions
instance AggregatedInsight : DTDFVocab:Insight [
    base:desc "Insight derived from aggregated and abstracted contextual traces, supporting purpose‑specific decision contexts."
]

instance ModelUpdateAction : DTDFVocab:Action [
    base:desc "Action that triggers an update of digital‑twin models based on newly received contextual data."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "A digital twin extends the digital shadow by providing active components capable of sending control information back to the physical system. According to the paper, the twin can generate commands or control messages that are interpreted by the physical asset, but the documents do not detail command formats, validation, authentication, feedback loops, conflict resolution or execution acknowledgements."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin operates on a real‑time, data‑driven basis, continuously linking live sensor data from the physical system to its digital counterpart. Incoming measurements are captured as time‑series traces at the native sampling rate of each sensor, enabling live‑data linking and near‑zero latency updates. Synchronization between physical and digital components is therefore performed continuously, with temporal granularity determined by the sensor sampling interval and without explicit fixed frequency values provided in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system architecture follows the Digital Shadow Reference Model (DSRM), which defines four core elements—Asset, Source, Model, and Processing. A concrete realization (concretization) maps these abstract concepts to concrete classes and associations, establishing a layered pipeline where the Asset provides raw data traces, the Source records and aggregates them, the Model encapsulates engineering, simulation, or data‑calculation models, and the Processing component consumes input traces, executes the models, and produces derived output traces. Traceability is maintained through 'originates‑from' associations, enabling transitive provenance tracking. This composition orchestrates the overall Digital Twin, integrating heterogeneous modelling notations (e.g., SysML, simulation tools) and managing resources via the processing pipeline."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the Model‑Based Systems‑Engineering (MBSE) abstraction hierarchy described in the document: (1) Requirements stage – capture and formalise stakeholder requirements; (2) Functional architecture stage – model functional decomposition using SysML internal block diagrams (IBDs) and architecture description languages (ADLs); (3) Logical architecture stage – specify component‑connector structures with ADLs such as ACME, AADL or MontiArc, including interface definitions; (4) Product/technical stage – map logical components to concrete implementation artifacts such as Simulink simulation models or source code in C++/Java. Transitions between these stages are managed by MBSE traceability mechanisms, ensuring that each representation (requirements, functional, logical, technical) is linked and governed throughout the Twin’s life‑cycle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical sensor data is streamed to the digital shadow via the MQTT protocol, using a Mosquitto server as the broker. The documents do not provide further details on network topology, bandwidth, latency, redundancy, or additional security mechanisms."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on the SysML modelling language (an OMG standard) and on UML class diagrams for the digital‑shadow reference model. Architecture description languages (ACME, AADL, MontiArc) are employed to capture component‑connector structures, following industry‑accepted ADL conventions. No additional certification, compliance frameworks, or interoperability standards are explicitly mentioned in the provided text."
]