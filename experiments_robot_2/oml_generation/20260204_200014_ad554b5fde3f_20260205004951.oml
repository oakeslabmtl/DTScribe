instance MBSE : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for managing system complexity and integrating heterogeneous stakeholders"
]

instance SysML : DTDFVocab:Enabler [
    base:desc "SysML for multi-level abstraction modeling (requirements, functional, logical, product/technical layers)"
]

instance ACME : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component & connector perspectives"
]

instance AADL : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component & connector perspectives"
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component & connector perspectives"
]

instance SysMLIBD : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component & connector architectures defining interfaces and interconnections"
]

instance MathWorksSimulink : DTDFVocab:Enabler [
    base:desc "Simulation tool for simulation-based analytical models"
]

instance CPlusPlus : DTDFVocab:Enabler [
    base:desc "General-purpose programming language for system implementation"
]

instance Java : DTDFVocab:Enabler [
    base:desc "General-purpose programming language for system implementation"
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "Methodology for managing system complexity and integrating heterogeneous stakeholders"
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "Methodology for managing system complexity and integrating heterogeneous stakeholders"
]

instance SPES : DTDFVocab:Enabler [
    base:desc "Methodology for managing system complexity and integrating heterogeneous stakeholders"
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "Methodology for managing system complexity and integrating heterogeneous stakeholders"
]

instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML model for requirements layer abstraction"
    DTDFVocab:inputTo MBSE, SysML
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML model for functional layer abstraction"
    DTDFVocab:inputTo MBSE, SysML
]

instance SysMLLogicalModel : DTDFVocab:Model [
    base:desc "SysML model for logical layer abstraction"
    DTDFVocab:inputTo MBSE, SysML
]

instance SysMLProductModel : DTDFVocab:Model [
    base:desc "SysML model for product/technical layer abstraction"
    DTDFVocab:inputTo MBSE, SysML
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME architecture description for component & connector perspectives"
    DTDFVocab:inputTo ACME
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL architecture description for component & connector perspectives"
    DTDFVocab:inputTo AADL
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description for component & connector perspectives"
    DTDFVocab:inputTo MontiArc
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams for component & connector architectures"
    DTDFVocab:inputTo SysMLIBD
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArc
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavioral modeling"
    DTDFVocab:inputTo SysML
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink simulation-based analytical models"
    DTDFVocab:inputTo MathWorksSimulink
]

instance PhysicalSystemStateDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Aggregated physical system states data traces"
]

instance PhysicalSystemStateData : DTDFVocab:Data [
    base:desc "Physical system states with contextual data traces aggregated and abstracted for specific purposes"
    DTDFVocab:fromData PhysicalSystemStateDataTransmitted
    DTDFVocab:inputTo MBSE, SysML, ACME, AADL, MontiArc, SysMLIBD, MathWorksSimulink, CPlusPlus, Java, RFLP, OOSEM, SPES, SMArDT
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adheres to industry standards including SysML for Model-Based Systems Engineering (MBSE), ACME, AADL, MontiArc, and SysML Internal Block Diagrams (IBDs) as architecture description languages (ADLs) for component & connector modeling, ensuring interoperability and structured system representation across development phases."
]