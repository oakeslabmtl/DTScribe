    base:desc "Processed joint state data for Axis 1, derived from raw encoder and current traces.",
    DTDFVocab:fromData Axis1DataTransmitted,
    DTDFVocab:inputTo SimulinkDynamicsEnabler, DatabaseEnabler
]

