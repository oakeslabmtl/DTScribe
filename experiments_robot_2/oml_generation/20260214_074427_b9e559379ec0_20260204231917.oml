instance SimulinkDynamicsModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink multi‑physics simulation of robot dynamics used for joint‑friction identification and wear prediction.",
    DTDFVocab:inputTo SimulinkDynamicsEnabler
]

instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "UML class diagram that defines the schema for contextual data traces constituting the digital shadow.",
    DTDFVocab:inputTo MiddlewareEnabler
]

instance SysMLLogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram describing functional and logical components of the robot.",
    DTDFVocab:inputTo SysMLModelEnabler
]

