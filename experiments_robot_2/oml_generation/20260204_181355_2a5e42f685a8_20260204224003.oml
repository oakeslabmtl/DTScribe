// C3: Physical sensing components
instance FirstAxisPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the position of the first axis (motor and gearbox) on the MABI MAX 100 industrial robot."
    DTDFVocab:producedData PositionDataTransmitted
]

instance FirstAxisTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the torque of the first axis (motor and gearbox) on the MABI MAX 100 industrial robot."
    DTDFVocab:producedData TorqueDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FirstAxisPositionSensor
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FirstAxisTorqueSensor
]

// C10: Data
instance PositionData : DTDFVocab:Data [
    base:desc "Time‑stamped position trace of the first axis, used for real‑time monitoring and simulation."
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo SimulinkProcessingEngine
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Time‑stamped torque trace of the first axis, used for diagnostic analysis and optimisation."
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo SimulinkProcessingEngine
]

// C10: Models
instance FirstAxisPhysicsModel : DTDFVocab:Model [
    base:desc "Physics‑based white‑box model of the motor‑gearbox dynamics for the first axis, implemented in Simulink."
    DTDFVocab:inputTo SimulinkProcessingEngine
]

instance FrictionDetectionModel : DTDFVocab:Model [
    base:desc "Data‑driven black‑box model for detecting joint friction using historical torque traces."
    DTDFVocab:inputTo SimulinkProcessingEngine
]

instance AccuracyPredictionModel : DTDFVocab:Model [
    base:desc "Predictive model that estimates motion‑accuracy errors and recommends corrective actions."
    DTDFVocab:inputTo SimulinkProcessingEngine
]

// C11: Enablers
instance SimulinkProcessingEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink execution environment that consumes input data traces and runs physics‑based and data‑driven models for the robot's first axis."
    DTDFVocab:enables RealTimeVisualizationDashboard,
                     DiagnosticAnalysisService,
                     MotionAccuracyOptimizationService
]

// C6: Services
instance RealTimeVisualizationDashboard : DTDFVocab:Service [
    base:desc "Real‑time visualization dashboard displaying first‑axis position and torque data to operators."
    DTDFVocab:provides FirstAxisStateInsight
]

instance DiagnosticAnalysisService : DTDFVocab:Service [
    base:desc "Diagnostic analysis that identifies joint friction in the first axis using simulation models."
    DTDFVocab:provides JointFrictionInsight
]

instance MotionAccuracyOptimizationService : DTDFVocab:Service [
    base:desc "Performance optimisation that predicts and suggests corrective actions to improve motion accuracy of the first axis."
    DTDFVocab:provides CorrectiveActionSuggestion
]

// C17: Insights / Actions
instance FirstAxisStateInsight : DTDFVocab:Insight [
    base:desc "Insight into the current state of the first axis derived from live position and torque data."
]

instance JointFrictionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting increased friction in the joint of the first axis based on diagnostic model outputs."
]

instance CorrectiveActionSuggestion : DTDFVocab:Action [
    base:desc "Suggested corrective actions (e.g., lubrication, parameter adjustment) to improve motion accuracy."
    DTDFVocab:IsAutomatic false
]

// C5: Physical components
instance MabiMax100Robot : DTDFVocab:Component [
    base:desc "MABI MAX 100 industrial robot, the physical twin of the digital twin."
]

instance FirstAxisMotor : DTDFVocab:Component [
    base:desc "Motor of the first axis of the MABI MAX 100 robot."
]

instance FirstAxisGearbox : DTDFVocab:Component [
    base:desc "Gearbox of the first axis of the MABI MAX 100 robot."
]

instance SiemensSinumerik840DController : DTDFVocab:Component [
    base:desc "Siemens SINUMERIK 840D sl controller governing the robot's motion."
]

// C16: Environment
instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:contains MabiMax100Robot,
                     FirstAxisMotor,
                     FirstAxisGearbox,
                     SiemensSinumerik840DController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is defined as a passive entity with an automated one‑way data flow from the physical object to the digital object; it neither operates autonomously nor pushes data back to the physical system. Therefore, no command types, control message formats, validation, authentication, feedback, or execution confirmation mechanisms are present."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by integrating both white‑box Simulink simulations (providing clear interpretability and predictability) and black‑box learning models (capturing complex non‑linear relationships). Validation and verification focus on ensuring the correctness of model transformations, such as from SysML specifications to simulation models, with traceability mechanisms highlighted to track changes. Reliability is linked to the correctness of underlying models and data transformations, prompting systematic verification of transformation steps and verification of model outputs against physical measurements. While explicit uncertainty quantification methods are not detailed, the emphasis on traceability and verification implies a quality‑assurance process aimed at detecting and correcting model errors."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin implementation adheres to multiple established modeling standards. System structure and behavior are captured using Model‑Based Systems‑Engineering (MBSE) with SysML (Systems Modeling Language) for requirements, functional, and logical architectures. Component‑connector specifications rely on architecture description languages (ADLs) such as ACME, AADL, and MontiArc, as well as SysML internal block diagrams (IBDs). The Digital Shadow reference model is expressed as a UML (Unified Modeling Language) class diagram, providing a formal metamodel that can be concretized through a defined conformance relation. These standards ensure interoperability with simulation tools (e.g., MathWorks Simulink) and code generators for languages like C++ and Java."
]