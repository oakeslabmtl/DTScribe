instance RealTimeDataInsight : DTDFVocab:Insight [
    base:desc "Real-time data insights for operational status of MABI MAX 100 robot"
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual dashboard for monitoring MABI MAX 100 robot performance"
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Insights enabling predictive maintenance to reduce downtime for MABI MAX 100 robot"
]

instance PerformanceOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insights for optimizing performance and efficiency of MABI MAX 100 robot"
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring through live-data linking of MABI MAX 100 robot",
    DTDFVocab:provides RealTimeDataInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualization via dashboard interface for MABI MAX 100 robot operations",
    DTDFVocab:provides DashboardVisualizationInsight
]

instance JointFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous multi-physics-aware identification of joint friction for predictive maintenance",
    DTDFVocab:provides PredictiveMaintenanceInsight, PerformanceOptimizationInsight
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP methodology for multi-level abstraction across requirements, functional, logical, and physics layers",
    DTDFVocab:enables RealTimeMonitoringService, VisualizationService, JointFrictionIdentificationService
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for system complexity management",
    DTDFVocab:enables RealTimeMonitoringService, VisualizationService, JointFrictionIdentificationService
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for system complexity management",
    DTDFVocab:enables RealTimeMonitoringService, VisualizationService, JointFrictionIdentificationService
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for system complexity management",
    DTDFVocab:enables RealTimeMonitoringService, VisualizationService, JointFrictionIdentificationService
]

instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML modeling tool for requirements, functional, logical, and technical layers",
    DTDFVocab:enables RealTimeMonitoringService, VisualizationService, JointFrictionIdentificationService
]

instance ACMEADLTool : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language tool for component interfaces and composition",
    DTDFVocab:enables RealTimeMonitoringService, VisualizationService, JointFrictionIdentificationService
]

instance AADLTool : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language tool for component interfaces and composition",
    DTDFVocab:enables RealTimeMonitoringService, VisualizationService, JointFrictionIdentificationService
]

instance MontiArcADLTool : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language tool for component interfaces and composition",
    DTDFVocab:enables RealTimeMonitoringService, VisualizationService, JointFrictionIdentificationService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for analytical simulations and multi-physics modeling",
    DTDFVocab:enables RealTimeMonitoringService, VisualizationService, JointFrictionIdentificationService
]

instance CppTool : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior specification",
    DTDFVocab:enables RealTimeMonitoringService, VisualizationService, JointFrictionIdentificationService
]

instance JavaTool : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior specification",
    DTDFVocab:enables RealTimeMonitoringService, VisualizationService, JointFrictionIdentificationService
]

instance MABIMAX100SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram for structural representation of MABI MAX 100 industrial robot",
    DTDFVocab:inputTo SysMLTool, RFLPMethodology
]

instance MABIMAX100ACMEModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language model for component interfaces of MABI MAX 100 robot",
    DTDFVocab:inputTo ACMEADLTool, RFLPMethodology
]

instance MABIMAX100AADLModel : DTDFVocab:Model [
    base:desc "AADL Architecture Description Language model for component composition of MABI MAX 100 robot",
    DTDFVocab:inputTo AADLTool, RFLPMethodology
]

instance MABIMAX100MontiArcADLModel : DTDFVocab:Model [
    base:desc "MontiArc Architecture Description Language model for component interfaces of MABI MAX 100 robot",
    DTDFVocab:inputTo MontiArcADLTool, RFLPMethodology
]

instance MABIMAX100MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton behavioral model for MABI MAX 100 robot",
    DTDFVocab:inputTo MontiArcADLTool, RFLPMethodology
]

instance MABIMAX100SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML State Machine behavioral model for MABI MAX 100 robot",
    DTDFVocab:inputTo SysMLTool, RFLPMethodology
]

instance MABIMAX100SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink analytical simulation model for MABI MAX 100 robot",
    DTDFVocab:inputTo SimulinkTool
]

instance MABIMAX100CppModel : DTDFVocab:Model [
    base:desc "C++ detailed behavior specification model for MABI MAX 100 robot",
    DTDFVocab:inputTo CppTool
]

instance MABIMAX100JavaModel : DTDFVocab:Model [
    base:desc "Java detailed behavior specification model for MABI MAX 100 robot",
    DTDFVocab:inputTo JavaTool
]

instance FirstVerticalAxisDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FirstVerticalAxisPositionSensor,
    base:desc "Time series data streamed via MQTT protocol from first vertical axis of MABI MAX 100 robot"
]

instance FirstVerticalAxisPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Position sensors for the first vertical axis of MABI MAX 100 industrial robot",
    DTDFVocab:producedData FirstVerticalAxisDataTransmission
]

instance FirstVerticalAxisSensorData : DTDFVocab:Data [
    base:desc "Raw position data from first vertical axis sensor of MABI MAX 100 robot",
    DTDFVocab:fromData FirstVerticalAxisDataTransmission,
    DTDFVocab:inputTo SimulinkTool, CppTool, JavaTool
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is structured using the Digital Shadow Reference Model (Fig. 1), a UML class diagram defining components including Asset (physical entity), Model (mathematical representation), Processing (data transformation logic), and DataTrace (sensor data streams). The Concrete Digital Shadow Model (Fig. 5) implements these elements with real-time data streaming via MQTT and Asset Administration Shells (AAS) for standardized data exchange within the manufacturing context."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for sensor data transmission. Network topology, bandwidth requirements, latency specifications, reliability and redundancy mechanisms, and security protocols are not specified in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system complies with industry standards including SysML [17] for system modeling, ACME [23], AADL [24], MontiArc [25,26], and SysML IBDs [17,27] as architecture description languages (ADLs) for component and connector perspectives. Additionally, methodologies such as RFLP [18,19], OOSEM [20], SPES [21], and SMArDT [22] are applied to manage complexity across abstraction levels (requirements, functional architecture, logical architecture, product/technical layer)."
]