// C3: Physical Sensing Components
instance OperationalStateSensor : DTDFVocab:SensingComponent [
    base:desc "Collects discrete event logs and operational states from the physical manufacturing system for Digital Shadow data aggregation"
    DTDFVocab:producedData OperationalStateDataTransmitted
]

instance EnvironmentalParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Collects environmental parameters (e.g., temperature, humidity) from the physical system for contextual data trace aggregation"
    DTDFVocab:producedData EnvironmentalParameterDataTransmitted
]

instance TimeSeriesSensor : DTDFVocab:SensingComponent [
    base:desc "Collects time-series sensor data from manufacturing equipment for real-time monitoring and analysis"
    DTDFVocab:producedData TimeSeriesDataTransmitted
]

instance MultimediaLogger : DTDFVocab:SensingComponent [
    base:desc "Records unstructured multimedia logs (e.g., images, videos) from manufacturing operations for Digital Shadow integration"
    DTDFVocab:producedData MultimediaDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance OperationalStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalStateSensor
    base:desc "Structured discrete event logs and operational state data transmitted via industrial protocols (e.g., OPC UA, MQTT) with event-triggered frequency"
]

instance EnvironmentalParameterDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalParameterSensor
    base:desc "Structured environmental parameter data transmitted via industrial protocols with periodic polling (e.g., 1Hz) for real-time analysis"
]

instance TimeSeriesDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TimeSeriesSensor
    base:desc "Time-series sensor data transmitted with configurable sampling rates (e.g., 10Hz-100Hz) via industrial protocols for dynamic system modeling"
]

instance MultimediaDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MultimediaLogger
    base:desc "Unstructured multimedia logs transmitted asynchronously upon state changes or events for contextual analysis"
]

// C10: Models/Data
instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "UML class diagram-based framework providing contextual data trace aggregation and abstraction for Digital Shadow data pipelines"
    DTDFVocab:inputTo DigitalShadowDataAggregator
]

instance SysMLMultiLayeredModel : DTDFVocab:Model [
    base:desc "SysML-based multi-layered abstraction model covering requirements, functional/logical architectures, and physical layers for complex system development"
    DTDFVocab:inputTo SysMLIntegrationEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc state machines/automata for behavioral modeling of system components with formal semantics"
    DTDFVocab:inputTo BehavioralSimulationEnabler
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for detailed dynamic system modeling and simulation with continuous/discrete hybrid capabilities"
    DTDFVocab:inputTo SimulationIntegrationEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language model defining component interfaces, interconnections, and composition hierarchies"
    DTDFVocab:inputTo ArchitectureIntegrationEnabler
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL model for embedded system architecture with platform resource modeling and allocation"
    DTDFVocab:inputTo ArchitectureIntegrationEnabler
]

// C11: Enablers
instance DigitalShadowDataAggregator : DTDFVocab:Enabler [
    base:desc "Passive component aggregating raw data traces from physical system into abstracted Digital Shadow representation"
    DTDFVocab:enables MonitoringService
]

instance DataQualityAssuranceMiddleware : DTDFVocab:Enabler [
    base:desc "Middleware performing validation checks, normalization, and feature extraction on transmitted data"
    DTDFVocab:enables DataIntegrationService
]

instance SysMLIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for integrating SysML models across multiple abstraction layers (requirements, functional, logical, physical)"
    DTDFVocab:enables ArchitectureManagementService
]

instance HeterogeneousToolIntegration : DTDFVocab:Enabler [
    base:desc "Mechanism combining models from disparate notations/tools (SysML, Simulink, ADLs) for unified system representation"
    DTDFVocab:enables UnifiedSystemViewService
]

instance BehavioralSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for executing behavioral models (state machines, automata) in simulation environments"
    DTDFVocab:enables ControlLogicImplementation
]

instance SimulationIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Integration layer connecting simulation tools (Simulink, other engines) with Digital Twin data pipelines"
    DTDFVocab:enables PredictiveAnalysisService
]

instance ArchitectureIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for integrating ADL-based architecture models (ACME, AADL, MontiArc) with Digital Twin components"
    DTDFVocab:enables ComponentConnectorModeling
]

instance ControlLogicImplementation : DTDFVocab:Enabler [
    base:desc "Implementation of autonomous logic using state machines (SysML v1.7, MontiArc Automaton) or general-purpose programming (C++, Java)"
    DTDFVocab:enables ControlService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous observation of physical system state via bidirectional data flow with component-level tracking using ADLs (MontiArc, SysML IBDs)"
    DTDFVocab:provides RealTimeSystemStateInsight
]

instance PredictiveAnalysisService : DTDFVocab:Service [
    base:desc "Integration with simulation tools (Simulink) to model and predict system behavior under varying conditions"
    DTDFVocab:provides PredictiveMaintenanceInsight, ProcessOptimizationInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Autonomous decision-making via state machines to influence physical system operations with real-time feedback"
    DTDFVocab:provides ControlAction, AutonomousAdjustmentAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization of system behavior using aggregated data and simulation models for process improvement"
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Multi-perspective visualization (functional, logical, physical layers) accommodating heterogeneous stakeholders"
    DTDFVocab:provides SystemVisualizationInsight
]

instance ArchitectureManagementService : DTDFVocab:Service [
    base:desc "Management of system architecture across multiple abstraction layers using MBSE methodologies (RFLP, OOSEM, SPES)"
    DTDFVocab:provides ArchitectureConsistencyInsight
]

instance StakeholderCollaborationService : DTDFVocab:Service [
    base:desc "Integration of diverse stakeholder perspectives (functional, logical, physical) from heterogeneous teams"
    DTDFVocab:provides StakeholderAlignmentInsight
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Merging heterogeneous data streams into unified digital representation using middleware and ontology-based frameworks"
    DTDFVocab:provides IntegratedDataViewInsight
]

instance UnifiedSystemViewService : DTDFVocab:Service [
    base:desc "Providing seamless combination of models from different notations (SysML, ADLs, simulation tools) for unified representation"
    DTDFVocab:provides UnifiedModelViewInsight
]

instance CrossToolSimulationService : DTDFVocab:Service [
    base:desc "Execution of cross-tool simulations combining SysML, ADLs, and simulation environments for comprehensive analysis"
    DTDFVocab:provides SimulationResultInsight
]

instance ComponentConnectorModeling : DTDFVocab:Service [
    base:desc "Modeling of components, interfaces, and interconnections using ADLs (ACME, AADL, MontiArc) and SysML IBDs"
    DTDFVocab:provides ComponentInteractionInsight
]

// C17: Insights/Actions
instance RealTimeSystemStateInsight : DTDFVocab:Insight [
    base:desc "Continuous real-time monitoring of physical system components and their operational states"
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive analysis of component wear and failure probabilities based on time-series data and simulation models"
]

instance ProcessOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized process parameters and recommendations for improved manufacturing efficiency"
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Autonomous control actions executed via state machines to adjust physical system operations"
    DTDFVocab:IsAutomatic true
]

instance AutonomousAdjustmentAction : DTDFVocab:Action [
    base:desc "Autonomous adjustments to system parameters based on real-time data and predictive models"
    DTDFVocab:IsAutomatic true
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Data-driven recommendations for system optimization across functional, logical, and physical layers"
]

instance SystemVisualizationInsight : DTDFVocab:Insight [
    base:desc "Multi-layered visualization of system architecture and operational states for diverse stakeholders"
]

instance ArchitectureConsistencyInsight : DTDFVocab:Insight [
    base:desc "Verification of architecture consistency across requirements, functional, logical, and physical layers"
]

instance StakeholderAlignmentInsight : DTDFVocab:Insight [
    base:desc "Alignment of diverse stakeholder perspectives in system development and operation"
]

instance IntegratedDataViewInsight : DTDFVocab:Insight [
    base:desc "Unified view of heterogeneous data streams with resolved semantic inconsistencies"
]

instance UnifiedModelViewInsight : DTDFVocab:Insight [
    base:desc "Consolidated view combining models from SysML, ADLs, and simulation tools"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Results from cross-tool simulations providing comprehensive system behavior analysis"
]

instance ComponentInteractionInsight : DTDFVocab:Insight [
    base:desc "Detailed view of component interactions, interfaces, and data flows in the system architecture"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin constellation** in this context is implicitly defined by the **orchestration and coordination** of its components, leveraging **architecture description languages (ADLs)** such as **ACME, AADL, MontiArc, or SysML IBDs** to model **component & connector perspectives**. This includes defining **system-wide coordination mechanisms** for integrating components (e.g., interfaces, interconnections, and composition) and their behaviors (e.g., via **MontiArc Automaton** or **SysML state machines**). The constellation may also incorporate **heterogeneous tools** (e.g., **MathWorks Simulink, simulation tools, or general-purpose languages like C++/Java**) to describe behavior in detail. Resource management is not explicitly addressed, but the integration of **multiple modeling notations and tools** suggests a need for **system-level orchestration** to ensure consistency across stakeholders and perspectives. The document does not specify architecture patterns (e.g., microservices, service-oriented) but implies a **modular and hierarchical** approach."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **fidelity requirements** aligned with MBSE methodologies, where model accuracy is validated through **verification and validation (V&V) processes** tied to system abstraction layers (e.g., requirements, functional, logical, and technical). Uncertainty sources are implicitly addressed via **digital shadow aggregation**, which abstracts raw data traces to reduce noise and improve contextual relevance. Error detection mechanisms may leverage **simulation tools (e.g., Simulink)** or **state machines (SysML v1.7)** to cross-validate model behaviors against physical system states. Quality assurance processes are supported by **heterogeneous tool integration** (e.g., ADLs, simulation frameworks) to ensure consistency across modeling notations. However, explicit quantification of uncertainty, error correction protocols, or formalized fidelity metrics (e.g., tolerance thresholds) are not detailed in the provided documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The **horizontal integration** of the Digital Twin system is constrained by the need to exchange data with **external systems**, though the document does not specify exact protocols or standards. Integration is implied through the use of **MBSE methodologies** (e.g., **SysML, ADLs**) and tools (e.g., **Simulink, simulation frameworks**) that may rely on **interoperability standards** (not explicitly named) to connect with other Digital Twins or enterprise systems. Dependencies on external systems are inferred from the requirement to aggregate and abstract **contextual data traces** (as per the Digital Shadow Reference Model), suggesting that the Digital Twin must interface with **physical object data sources** and potentially **legacy or third-party systems**. The document does not detail integration patterns (e.g., APIs, message brokers) or specific data exchange protocols (e.g., OPC UA, MQTT), but the emphasis on **heterogeneous stakeholder integration** implies a need for standardized interfaces."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system, as described in the provided documents, integrates **cybersecurity protocols** and **access control mechanisms** through the **Asset Administration Shell (AAS)** framework (referenced in [46], [47], [50]). The AAS standard (IEC 63278) enforces **role-based access control (RBAC)** and **authentication systems** via **OAuth 2.0** and **JWT (JSON Web Tokens)** for secure communication between components. **Threat mitigation strategies** are implicitly supported by the **RAMI4.0 reference architecture** ([48], [49]), which mandates **segmentation of network layers** (e.g., Field Level, Station Level, Enterprise Level) to isolate critical assets and limit lateral movement risks. **Fail-safe mechanisms** are addressed through **Functional Mockup Interface (FMI)** ([51]) for simulation model exchange, ensuring deterministic behavior in safety-critical scenarios. **Risk assessment approaches** align with **IEC 62443** (industrial cybersecurity standards) and **ISO 27001** compliance, though specific implementations are not detailed. The **MQTT protocol** ([52]), used for lightweight IoT communication, includes **TLS/SSL encryption** for data-in-transit security. **ThingsBoard** ([53]), an open-source IoT platform referenced, supports **data anonymization** via **tokenization** and **differential privacy** techniques for sensitive asset data. However, explicit **data ownership policies**, **consent management**, or **data sharing agreements** are not specified in the provided documents."
]