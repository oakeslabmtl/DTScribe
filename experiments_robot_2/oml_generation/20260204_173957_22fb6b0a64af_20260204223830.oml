// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) measuring the electrical current of the permanent‑magnet synchronous motor"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted on the motor shaft providing angular position of the motor"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxSecondaryEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder placed behind the gearwheel gearbox delivering gear output shaft position"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance TorqueSignalFromController : DTDFVocab:SensingComponent [
    base:desc "Derived torque signal calculated from motor current and controller parameters"
    DTDFVocab:producedData TorqueSignalDataTransmitted
]

instance VelocitySignalFromController : DTDFVocab:SensingComponent [
    base:desc "Derived angular velocity signal obtained from encoder rates and controller estimation"
    DTDFVocab:producedData VelocitySignalDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxSecondaryEncoderSensor
]

instance TorqueSignalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSignalFromController
]

instance VelocitySignalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocitySignalFromController
]

// C10: Data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current I_M streaming in real time"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkFrictionEngine
]

instance MotorEncoderData : DTDFVocab:Data [
    base:desc "Measured motor shaft angle from the motor encoder"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkFrictionEngine
]

instance GearboxEncoderData : DTDFVocab:Data [
    base:desc "Measured gearwheel output angle from the secondary encoder"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkFrictionEngine
]

instance TorqueSignalData : DTDFVocab:Data [
    base:desc "Computed torque trace derived from current and motor parameters"
    DTDFVocab:fromData TorqueSignalDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkFrictionEngine
]

instance VelocitySignalData : DTDFVocab:Data [
    base:desc "Computed angular velocity trace derived from encoder rates"
    DTDFVocab:fromData VelocitySignalDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkFrictionEngine
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker used for streaming live sensor data to the digital shadow"
    DTDFVocab:enables RealTimeFrictionIdentificationService, DataTraceGenerationService
]

instance SimulinkFrictionEngine : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink environment executing friction models (Coulomb‑Viscous, Stribeck, Dahl, LuGre) and data‑calculation models"
    DTDFVocab:enables AutomaticParameterEstimationService, DataVisualizationService
]

instance VisualizationDashboard : DTDFVocab:Enabler [
    base:desc "Custom web dashboard visualizing measured versus simulated traces in a unified view"
    DTDFVocab:enables DataVisualizationService
]

// C10: Models
instance SysMLMotorGearboxModel : DTDFVocab:Model [
    base:desc "SysML block definition & internal block diagram describing the motor, gearwheel gearbox and cycloidal gearbox"
    DTDFVocab:inputTo MQTTBroker
]

instance SimulinkCoulombViscousModel : DTDFVocab:Model [
    base:desc "Simulink friction model implementing Coulomb and viscous friction components"
    DTDFVocab:inputTo SimulinkFrictionEngine
]

instance SimulinkLuGreModel : DTDFVocab:Model [
    base:desc "Simulink implementation of the LuGre friction model for high‑fidelity identification"
    DTDFVocab:inputTo SimulinkFrictionEngine
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Computation model converting measured current and angles into torque, angular velocity and acceleration"
    DTDFVocab:inputTo SimulinkFrictionEngine
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction parameters"
    DTDFVocab:provides FrictionParameterEstimationInsight
]

instance AutomaticParameterEstimationService : DTDFVocab:Service [
    base:desc "Automatic estimation of parameters for white‑box and black‑box friction models"
    DTDFVocab:provides FeedBackFrictionParametersAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Visualization of measured and simulated data in a unified dashboard"
    DTDFVocab:provides DeviationDetectionInsight
]

instance DataTraceGenerationService : DTDFVocab:Service [
    base:desc "Generation of data traces (I_M, r_M, r_G, r_out and simulated ^r_M, ^r_G, ^r_out) for offline analysis"
    DTDFVocab:provides MaintenanceDecisionAction
]

// C17: Insights
instance FrictionParameterEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated friction parameters are obtained, enabling controller tuning for improved motion accuracy"
]

instance DeviationDetectionInsight : DTDFVocab:Insight [
    base:desc "Detected deviations between simulated and measured behavior highlight potential maintenance needs"
]

// C17: Actions
instance FeedBackFrictionParametersAction : DTDFVocab:Action [
    base:desc "Feed back the identified friction parameters to the robot controller to improve motion accuracy"
    DTDFVocab:IsAutomatic true
]

instance MaintenanceDecisionAction : DTDFVocab:Action [
    base:desc "Trigger maintenance decision process based on detected deviations"
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow consisting of an Asset (first axis), Sources (sensors and derived signals), Processing components (simulation models executing friction calculations), DataTraces (measured and simulated), and a dashboard that aggregates and visualizes the results. The Processing component consumes input traces, applies simulation models, and produces output traces for analysis."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow is applied during the operated phase of the robot, using engineering models (structure) and runtime sensor data to create a live representation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of every data point to its origin and processing component ensures model fidelity. Both white‑box (analytical) and black‑box (data‑driven) friction models are validated by comparing simulated torque/velocity against measured traces. Multi‑physics awareness and continuous re‑identification address wear and temperature effects."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow over MQTT; the communication is one‑way (physical‑to‑virtual) as defined for digital shadows."
]