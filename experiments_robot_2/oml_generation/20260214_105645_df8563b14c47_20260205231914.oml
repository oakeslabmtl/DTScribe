]

instance InjectionMoldingProcess : DTDFVocab:Component [
    base:desc "Continuous manufacturing process for injection molding with integrated digital twin for real-time optimization"
    base:contains InjectionMoldingMachine, TemperatureSensorArray, PressureTransducerNetwork
