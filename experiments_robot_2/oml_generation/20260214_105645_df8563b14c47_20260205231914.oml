    base:desc "Decision support system integrating AI-driven analytics for strategic production planning and resource allocation in Industry 4.0 environments"
    DTDFVocab:enables ProductionPlanningService
]

// C3: Physical Sensing Components
instance TemperatureSensorArray : DTDFVocab:SensingComponent [
    base:desc "Array of temperature sensors collecting real-time thermal data from injection molding machines and production environments"
    DTDFVocab:producedData ThermalDataTransmitted
]

instance PressureTransducerNetwork : DTDFVocab:SensingComponent [
    base:desc "Network of pressure transducers monitoring injection pressures and system hydraulics in continuous manufacturing processes"
    DTDFVocab:producedData PressureDataTransmitted
]

instance RobotStateMonitoringSystem : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled system tracking robot state parameters including position, velocity, and operational status for performance analysis"
    DTDFVocab:producedData RobotStateDataTransmitted
]

instance OperationalLogCollector : DTDFVocab:SensingComponent [
    base:desc "System aggregating operational logs from manufacturing equipment including activation events, process anomalies, and maintenance records"
    DTDFVocab:producedData OperationalLogDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance ThermalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorArray
    DTDFVocab:fromData ThermalData
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureTransducerNetwork
    DTDFVocab:fromData PressureData
]

instance RobotStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotStateMonitoringSystem
    DTDFVocab:fromData RobotStateData
]

instance OperationalLogDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalLogCollector
    DTDFVocab:fromData OperationalLogData
]

// C10: Models/Data
instance PhysicsBasedInjectionModel : DTDFVocab:Model [
    base:desc "White-box simulation model of injection molding processes using differential equations to predict material flow and cooling patterns"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance MachineLearningFrictionModel : DTDFVocab:Model [
    base:desc "Black-box probabilistic model trained on historical robot data to predict and compensate for friction variations in industrial applications"
    DTDFVocab:inputTo TensorFlowMLEnabler
]

instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "Conforming model derived from Digital Shadow Reference Model enabling hierarchical instantiation of Digital Twin components with traceability to physical data traces"
    DTDFVocab:inputTo SysMLModelingEnabler
]

