    DTDFVocab:inputTo RoboticsPerformanceOptimizationEnabler
]

instance OperationalLogData : DTDFVocab:Data [
    base:desc "Processed operational logs containing activation events, anomalies, and maintenance records for predictive maintenance analysis"
