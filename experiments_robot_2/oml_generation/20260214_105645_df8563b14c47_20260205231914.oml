    base:desc "Aggregated and abstracted temperature data traces from manufacturing processes, contextualized for specific optimization purposes"
    DTDFVocab:fromData ThermalDataTransmitted
    DTDFVocab:inputTo InjectionMoldingOptimizationEnabler
]

instance PressureData : DTDFVocab:Data [
    base:desc "Processed pressure data representing injection molding system hydraulics, filtered for quality control applications"
    DTDFVocab:fromData PressureDataTransmitted
    DTDFVocab:inputTo QualityControlSimulationEnabler
]

instance RobotStateData : DTDFVocab:Data [
    base:desc "Contextualized robot state data including position, velocity, and operational metrics for performance analysis and optimization"
