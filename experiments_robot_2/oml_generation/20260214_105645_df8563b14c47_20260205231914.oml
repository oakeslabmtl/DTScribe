// C2: Acting Components
instance InjectionMoldingProcessController : DTDFVocab:ActingComponent [
    base:desc "Active component for closed-loop control of injection molding processes, enabling real-time adjustments to cycle times, temperatures, and pressures based on DT-generated insights"
    DTDFVocab:enables InjectionMoldingOptimizationService
]

instance RoboticsFrictionCompensationSystem : DTDFVocab:ActingComponent [
    base:desc "AI-driven system for adaptive friction compensation in industrial robots using black-box machine learning models to optimize movement precision"
