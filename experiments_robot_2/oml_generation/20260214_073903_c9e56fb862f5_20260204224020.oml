// C3: Physical sensing component
instance PhysicalObjectStateCollector : DTDFVocab:SensingComponent [
    base:desc "Collects contextual state data traces from the existing physical object for the digital shadow (one‑way data flow)."
    DTDFVocab:producedData StateDataTransmitted
]

// C4: Physical-to-virtual interaction
instance StateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalObjectStateCollector
]

// C10: Data
instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data trace used as input for simulation and data‑calculation models."
    DTDFVocab:fromData StateDataTransmitted
    DTDFVocab:inputTo ProcessingEngine
]

// C10: Models
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML model capturing structural architecture (components, interfaces, connectors) of the physical system."
    DTDFVocab:inputTo ProcessingEngine
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "Executable simulation model in MathWorks Simulink derived from SysML for behavior evaluation."
    DTDFVocab:inputTo ProcessingEngine
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Data‑driven calculation model (e.g., C++/Java) used to compute derived outputs from input traces."
    DTDFVocab:inputTo ProcessingEngine
]

// C11: Enablers (Processing component)
instance ProcessingEngine : DTDFVocab:Enabler [
    base:desc "Software processing component that consumes data traces and model outputs to produce derived information."
    DTDFVocab:enables DerivationService
]

// C6: Service
instance DerivationService : DTDFVocab:Service [
    base:desc "Transforms raw input data traces into higher‑level output data (e.g., performance indicators) while preserving provenance."
    DTDFVocab:provides PerformanceIndicatorInsight
]

// C17: Insight
instance PerformanceIndicatorInsight : DTDFVocab:Insight [
    base:desc "Derived performance indicator computed from contextual data using simulation or data‑calculation models, with full lineage to inputs."
]

// Additional Enablers reflecting tooling and enablers
instance SysMLTooling : DTDFVocab:Enabler [
    base:desc "SysML MBSE tooling used for requirements, functional, logical, and product layer modeling."
    DTDFVocab:enables ModelTransformationService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink engine executing executable simulation models."
    DTDFVocab:enables ModelTransformationService
]

instance MontiArcEngine : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton engine for state‑machine based behavior specifications."
    DTDFVocab:enables ModelTransformationService
]

// Service for model transformation
instance ModelTransformationService : DTDFVocab:Service [
    base:desc "Transforms SysML models into simulation models and orchestrates model execution."
    DTDFVocab:provides ModelTransformationInsight
]

// Insight about model transformation
instance ModelTransformationInsight : DTDFVocab:Insight [
    base:desc "Provides status and conformance insight of model transformations (RFLP, OOSEM, SPES, SMArDT methodologies)."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The document states that a Digital Twin can provide active components that may generate control commands back to the physical system, but it does not specify command types, message formats, validation, authentication, or feedback mechanisms."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the MBSE development hierarchy described in the documents: it starts with a requirements model, proceeds to functional‑architecture models, then logical‑architecture models, and finally to the product/technical layer. At each stage the Twin is represented with appropriate artifacts – SysML requirement diagrams, SysML internal‑block diagrams or IBDs for functional and logical structures, and concrete component‑connector models in ADLs (e.g., ACME, AADL, MontiArc) for the technical layer. Transition between stages is managed by concretizing the Digital Shadow Reference Model into a concrete realization (a mapping of reference concepts to concrete classes and associations) and by extending the model with simulation or calculation models (e.g., Simulink) that generate data traces. Governance is achieved through the reference‑model conformance relation that defines which concrete models are admissible at each lifecycle phase."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The approach stresses traceability of every model element back to its source data and verification of model transformations (e.g., from SysML architectural models to simulation models) to preserve semantics. Fidelity is addressed by combining physics‑based (white‑box) models with data‑driven (black‑box) components, thereby leveraging the predictability of analytical models and the expressive power of machine‑learning models. Validation relies on the correctness of the underlying models and on systematic verification methods proposed in the literature, which aim to ensure that the digital representation accurately reflects the physical system."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on a reference‑model based standardisation strategy: a Digital Shadow Reference Model defines domain concepts and a formal conformance relation that identifies all admissible concrete models. Modelling is performed with standard languages and standards – SysML for system modelling, ADLs such as ACME, AADL and MontiArc for component‑connector architecture, and simulation tools like Simulink for behavior. The concrete realization of the reference model follows a mapping (conformance) to these standard artefacts, ensuring interoperability and compliance with the established modelling standards."
]