instance MQTTDataFlow : DTDFVocab:DataTransmitted [
    base:desc "Automated one-way data flow via MQTT protocol for passive aggregation of sensor traces in the digital shadow"
    DTDFVocab:producedFrom JointFrictionData, MachiningForceTrace, TemperatureTrace, LoadVariationTrace
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Service for aggregating and processing sensor data traces from robot and machining systems for digital shadow monitoring"
    DTDFVocab:provides WearProgressionInsight, LoadDistributionInsight
]

instance MQTTProtocol : DTDFVocab:Enabler [
    base:desc "MQTT protocol implementation for real-time bidirectional data exchange between physical sensors and digital shadow components"
    DTDFVocab:enables DataAggregationService
]

instance SimulinkSimulation : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for detailed behavior modeling and dynamic simulation of robot and machining processes"
    DTDFVocab:inputTo FrictionModel, MachiningProcessModel
]

instance NeuralNetworkProcessing : DTDFVocab:Enabler [
    base:desc "Machine learning framework for black-box model training and real-time adaptation of friction compensation parameters"
    DTDFVocab:inputTo AdaptiveFrictionModel
]

instance FrictionModelProcessing : DTDFVocab:Enabler [
    base:desc "Data processing pipeline for friction data aggregation and model parameter updates via MontiArc Automaton behavior modeling"
    DTDFVocab:inputTo FrictionCompensationService
]

instance MachiningOptimizationModel : DTDFVocab:Enabler [
    base:desc "Simulation-based optimization model for machining parameter adjustments using discrete-event simulation frameworks"
    DTDFVocab:inputTo MachiningParameterService
]

instance AdaptiveControlProcessing : DTDFVocab:Enabler [
    base:desc "Real-time control processing component for adaptive friction compensation based on environmental condition traces"
    DTDFVocab:inputTo DynamicFrictionService
]

