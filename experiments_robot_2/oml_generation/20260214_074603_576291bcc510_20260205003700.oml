// C3: Physical sensing components
instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder providing angle data for elasticity and friction derivation"
    DTDFVocab:producedData MotorEncoderAngleDataTransmitted
]

instance GearboxSecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the gearbox providing angle data for elasticity and friction derivation"
    DTDFVocab:producedData GearboxEncoderAngleDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) used to derive torque and friction information"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical‑to‑virtual interaction
instance MotorEncoderAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder
]

instance GearboxEncoderAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxSecondaryEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Data
instance MeasuredMotorAngleData : DTDFVocab:Data [
    base:desc "Measured motor‑axis angle trace streamed via MQTT"
    DTDFVocab:fromData MotorEncoderAngleDataTransmitted
    DTDFVocab:inputTo MqttStreamingEnabler
]

instance MeasuredGearboxAngleData : DTDFVocab:Data [
    base:desc "Measured gearbox‑axis angle trace streamed via MQTT"
    DTDFVocab:fromData GearboxEncoderAngleDataTransmitted
    DTDFVocab:inputTo MqttStreamingEnabler
]

instance MeasuredMotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current (I_M) trace streamed via MQTT"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MqttStreamingEnabler
]

// C10: Engineering & Simulation Models
instance EngineeringSysMLModel : DTDFVocab:Model [
    base:desc "SysML component & internal block diagrams describing the first vertical axis of the MABI MAX 100 robot"
    DTDFVocab:inputTo SysmlModelingEnabler
]

instance SimulinkFrictionFreeModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink friction‑free model of the vertical axis"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance SimulinkCoulombViscousModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink Coulomb‑Viscous friction model"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance SimulinkStribeckModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink Stribeck friction model"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance SimulinkDahlModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink Dahl friction model"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance SimulinkLuGreModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink LuGre friction model"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

// C11: Enablers (tooling & integration)
instance MqttStreamingEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker streaming live measurement time‑series data"
    DTDFVocab:enables FrictionIdentificationService, ParameterUpdateService, DashboardVisualizationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) providing model integration and data exchange"
    DTDFVocab:enables ParameterUpdateService, DashboardVisualizationService
]

instance SimulinkExecutionEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink execution environment for running friction models"
    DTDFVocab:enables ParameterUpdateService
]

instance SysmlModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling toolchain used for engineering model creation"
    DTDFVocab:enables ParameterUpdateService
]

instance WebDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard visualizing measured vs. simulated data"
    DTDFVocab:enables DashboardVisualizationService
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of static, kinetic and viscous friction parameters"
    DTDFVocab:provides FrictionParametersInsight, UpdateControlAlgorithmAction
]

instance ParameterUpdateService : DTDFVocab:Service [
    base:desc "Model‑based parameter updating for improved motion control accuracy"
    DTDFVocab:provides ModelDeviationInsight, ModelUpdateDecisionAction
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Unified dashboard for visualization of measured vs. simulated data"
    DTDFVocab:provides VisualizationInsight
]

// C17: Insights
instance FrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Quantitative friction parameters (static, kinetic, viscous) extracted from live data"
]

instance ModelDeviationInsight : DTDFVocab:Insight [
    base:desc "Insight into deviations between measured data and simulated model predictions"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of measured versus simulated traces for engineer analysis"
]

// C17: Actions
instance UpdateControlAlgorithmAction : DTDFVocab:Action [
    base:desc "Automatic update of the motion control algorithm with newly identified friction parameters"
    DTDFVocab:IsAutomatic true
]

instance ModelUpdateDecisionAction : DTDFVocab:Action [
    base:desc "Engineer decision to update model parameters or tune control based on deviation insight"
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time, continuous during robot operation; data are captured and processed on‑line to enable immediate model updates and friction estimation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow comprising a Purpose (FrictionDerivation), Asset (MABI robot first axis), Sources (sensors and derived data), Processing components (Simulation M, GW, GB), Models (engineering, simulation, data‑calculation), and DataTraces, all instantiated from the Digital Shadow Reference Model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of each data point to its source and processing component is maintained; simulated outputs are compared against measured reference traces to validate friction models; both white‑box (analytical) and black‑box (data‑driven) models are continuously re‑identified to account for wear, tool changes, and temperature effects."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Measurement data are transmitted from the physical robot to the digital shadow via the MQTT protocol; Asset Administration Shells are used to encapsulate model metadata and support integration."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The work adheres to the SysML standard (OMG) for engineering models and utilizes the Asset Administration Shell (AAS) specification (defined by the Industrie 4.0 platform) for standardized asset representation and data exchange. These standards ensure interoperability of models and communication across the digital twin ecosystem."
]