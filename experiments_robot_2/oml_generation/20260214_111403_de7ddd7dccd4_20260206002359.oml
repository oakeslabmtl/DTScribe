// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor integrated with Siemens SINUMERIK 840D sl control system, constrained within [-90, 90] degree operational range with safety cell enforcement for boundary protection."
    base:isContainedIn ManufacturingEnvironment
]

instance SafetyCell : DTDFVocab:ActingComponent [
    base:desc "Safety cell component restricting operational boundaries of the robotic system to prevent unauthorized or hazardous movements."
    base:isContainedIn ManufacturingEnvironment
]

// C3: Physical Sensing Components
instance PositionEncoderAxis1 : DTDFVocab:SensingComponent [
    base:desc "High-precision position encoder for kinematic tracking with 0.06mm path repeatability and 0.1mm positional accuracy, optimized for the robotic system's operational envelope."
    DTDFVocab:producedData PositionDataAxis1
    base:isContainedIn ManufacturingEnvironment
]

instance PositionEncoderAxis2 : DTDFVocab:SensingComponent [
    base:desc "High-precision position encoder for kinematic tracking with 0.06mm path repeatability and 0.1mm positional accuracy, optimized for the robotic system's operational envelope."
    DTDFVocab:producedData PositionDataAxis2
    base:isContainedIn ManufacturingEnvironment
]

instance PositionEncoderAxis3 : DTDFVocab:SensingComponent [
    base:desc "High-precision position encoder for kinematic tracking with 0.06mm path repeatability and 0.1mm positional accuracy, optimized for the robotic system's operational envelope."
    DTDFVocab:producedData PositionDataAxis3
    base:isContainedIn ManufacturingEnvironment
]

instance PositionEncoderAxis4 : DTDFVocab:SensingComponent [
    base:desc "High-precision position encoder for kinematic tracking with 0.06mm path repeatability and 0.1mm positional accuracy, optimized for the robotic system's operational envelope."
    DTDFVocab:producedData PositionDataAxis4
    base:isContainedIn ManufacturingEnvironment
]

instance PositionEncoderAxis5 : DTDFVocab:SensingComponent [
    base:desc "High-precision position encoder for kinematic tracking with 0.06mm path repeatability and 0.1mm positional accuracy, optimized for the robotic system's operational envelope."
    DTDFVocab:producedData PositionDataAxis5
    base:isContainedIn ManufacturingEnvironment
