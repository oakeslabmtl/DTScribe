instance PhysicalSystemStateSensor : DTDFVocab:SensingComponent [
    base:desc "Physical system state data sources via one-way data flow as described in digital shadows"
    DTDFVocab:producedData PhysicalSystemStateDataTransmitted
]

instance PhysicalSystemStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemStateSensor
]

instance PhysicalSystemStateData : DTDFVocab:Data [
    base:desc "Data originating from physical system states"
    DTDFVocab:fromData PhysicalSystemStateDataTransmitted
    DTDFVocab:inputTo SimulationTool_Simulink, ProgrammingLanguage_Cpp, ProgrammingLanguage_Java
]

instance StructuralModel_SysML_IBD : DTDFVocab:Model [
    base:desc "Structural model using SysML IBDs for component & connector modeling"
    DTDFVocab:inputTo ADL_SysML_IBD
]

instance StructuralModel_ACME : DTDFVocab:Model [
    base:desc "Structural model using ACME architecture description language"
    DTDFVocab:inputTo ADL_ACME
]

instance StructuralModel_AADL : DTDFVocab:Model [
    base:desc "Structural model using AADL architecture description language"
    DTDFVocab:inputTo ADL_AADL
]

instance BehavioralModel_MontiArc_Automaton : DTDFVocab:Model [
    base:desc "Behavioral model using MontiArc Automaton"
    DTDFVocab:inputTo ADL_MontiArc
]

instance BehavioralModel_SysML_StateMachines : DTDFVocab:Model [
    base:desc "Behavioral model using SysML v1.7 state machines"
    DTDFVocab:inputTo ADL_SysML_IBD
]

instance AnalyticalModel_Simulink : DTDFVocab:Model [
    base:desc "Analytical model using MathWorks Simulink"
    DTDFVocab:inputTo SimulationTool_Simulink
]

instance AnalyticalModel_Cpp : DTDFVocab:Model [
    base:desc "Analytical model using C++ code"
    DTDFVocab:inputTo ProgrammingLanguage_Cpp
]

instance AnalyticalModel_Java : DTDFVocab:Model [
    base:desc "Analytical model using Java code"
    DTDFVocab:inputTo ProgrammingLanguage_Java
]

instance MBSE_RFLP : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology RFLP for multi-level abstraction modeling"
    DTDFVocab:enables AnalysisService
]

instance MBSE_OOSEM : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology OOSEM for multi-level abstraction modeling"
    DTDFVocab:enables AnalysisService
]

instance MBSE_SPES : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology SPES for multi-level abstraction modeling"
    DTDFVocab:enables AnalysisService
]

instance MBSE_SMArDT : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology SMArDT for multi-level abstraction modeling"
    DTDFVocab:enables AnalysisService
]

instance ADL_ACME : DTDFVocab:Enabler [
    base:desc "Architecture Description Language ACME for defining components, interfaces, and connections"
    DTDFVocab:enables AnalysisService
]

instance ADL_AADL : DTDFVocab:Enabler [
    base:desc "Architecture Description Language AADL for defining components, interfaces, and connections"
    DTDFVocab:enables AnalysisService
]

instance ADL_MontiArc : DTDFVocab:Enabler [
    base:desc "Architecture Description Language MontiArc for defining components, interfaces, and connections"
    DTDFVocab:enables SimulationService
]

instance ADL_SysML_IBD : DTDFVocab:Enabler [
    base:desc "Architecture Description Language SysML IBDs for component & connector modeling"
    DTDFVocab:enables SimulationService
]

instance SimulationTool_Simulink : DTDFVocab:Enabler [
    base:desc "Simulation tool MathWorks Simulink for handling simulation"
    DTDFVocab:enables SimulationService
]

instance ProgrammingLanguage_Cpp : DTDFVocab:Enabler [
    base:desc "General-purpose programming language C++ for code integration"
    DTDFVocab:enables AnalysisService
]

instance ProgrammingLanguage_Java : DTDFVocab:Enabler [
    base:desc "General-purpose programming language Java for code integration"
    DTDFVocab:enables AnalysisService
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for simulating the physical system using models and data"
    DTDFVocab:provides SimulationInsight
]

instance AnalysisService : DTDFVocab:Service [
    base:desc "Service for analyzing the physical system using models and data"
    DTDFVocab:provides AnalysisInsight
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight generated from simulation of physical system"
]

instance AnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight generated from analysis of physical system"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adheres to industry standards including SysML [17], ACME [23], AADL [24], MontiArc [25], [26], and MathWorks Simulink [28] for modeling, architecture description, and simulation, ensuring interoperability and compliance with specified protocols."
]