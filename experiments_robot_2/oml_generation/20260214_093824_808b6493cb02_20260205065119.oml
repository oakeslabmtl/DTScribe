// Acting Components
instance PermanentMagnetSynchronousMotor1 : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor (PMSM) with continuous current rating of 10 A, mounted on joint 1 and coupled to a 20 Nm gearbox."
]
instance Gearbox1 : DTDFVocab:ActingComponent [
    base:desc "24‑speed reduction gearbox delivering a 20 Nm torque rating, positioned between the PMSM and the joint shaft."
]
instance JointDriveController1 : DTDFVocab:ActingComponent [
    base:desc "Microcontroller driving the motor driver with 48 V DC bus, providing position, velocity, or acceleration command modulation."
]
instance CANFDSafetyNet1 : DTDFVocab:ActingComponent [
    base:desc "CAN‑FD safety net that clamps actuator commands to ±90° joint limits and forwards them to microcontrollers."
]
instance Watchdog1 : DTDFVocab:ActingComponent [
    base:desc "Watchdog triggering an emergency stop when overshoot or acceleration exceeds 10 °/s², ensuring mechanical safety."
]

// Sensing Components
instance PrimaryJointEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution rotary encoder mounted on motor shaft, providing 0.0001°/tick resolution at 10 kHz sampling."
    DTDFVocab:producedData PrimaryJointEncoderData
]
instance SecondaryJointEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary rotary encoder positioned after gearbox, reducing backlash and providing 0.0001°/tick resolution at 10 kHz sampling."
    DTDFVocab:producedData SecondaryJointEncoderData
]

// Data Transmitted
instance PrimaryJointEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PrimaryJointEncoder
]
instance SecondaryJointEncoderData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryJointEncoder
]

// Aggregated Data
instance JointEncoderDataAggregated : DTDFVocab:Data [
    base:desc "Aggregated JSON payload of primary and secondary encoder data streamed over MQTT at 250 kB/s."
    DTDFVocab:fromData PrimaryJointEncoderData, SecondaryJointEncoderData
    DTDFVocab:inputTo MQTTBrokerEnabler, HealthMonitoringEnabler
]

// Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "UART‑based MQTT broker enabling real‑time ingestion of encoder data."
    DTDFVocab:enables EncoderDataMonitoringService
]
instance HealthMonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Health monitoring enabler processing encoder data for fault detection."
    DTDFVocab:enables HealthMonitoringService
]
instance AcmeModelDescription : DTDFVocab:Enabler [
    base:desc "ACME architecture descriptor for component sequencing."
]
instance AADLModelDescription : DTDFVocab:Enabler [
    base:desc "AADL model describing real‑time scheduling and resource allocation."
]
instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc tool enabling automaton synthesis from SysML state machines."
]
instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink engine executing dynamic simulation of joint behavior."
]

// Services
instance EncoderDataMonitoringService : DTDFVocab:Service [
    base:desc "Service ingesting encoder data and evaluating data quality metrics."
    DTDFVocab:provides DataQualityInsight
]
instance HealthMonitoringService : DTDFVocab:Service [
    base:desc "Service performing health checks on encoder telemetry and triggering safety actions."
    DTDFVocab:provides FaultDetectionInsight, TriggerEmergencyStopAction
]

// Insights
instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Insight indicating RMS encoder position accuracy within 0.01° and velocity accuracy within 0.1 °/s."
]
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight flagging missing tick anomalies or over‑current faults detected by encoder tags."
]

// Actions
instance TriggerEmergencyStopAction : DTDFVocab:Action [
    base:desc "Automatic action initiating watchdog emergency stop upon fault detection."
    DTDFVocab:IsAutomatic true
]

// Models
instance SysMLComponentDiagramModel : DTDFVocab:Model [
    base:desc "SysML component diagram depicting the system’s physical and logical structure."
    DTDFVocab:inputTo AcmeModelDescription, AADLModelDescription
]
instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine modeling joint motion control logic."
    DTDFVocab:inputTo MontiArcTool
]
instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "Simulink simulation model of joint dynamics for controller tuning."
    DTDFVocab:inputTo SimulinkEngine
]
instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc automaton capturing behavior execution of the digital twin."
    DTDFVocab:inputTo MontiArcTool
]

// Environment containing system components
instance RobotPlatformEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotor1, Gearbox1, JointDriveController1, CANFDSafetyNet1, Watchdog1, PrimaryJointEncoder, SecondaryJointEncoder
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is orchestrated using a Model‑Based Systems Engineering (MBSE) approach. The component and connector structure is described in SysML via an Architecture Design Block Diagram (Fig. 3). Behavioural dynamics are captured in executable MATLAB/Simulink models which are linked to the SysML model. The twin’s architecture follows a hierarchical multi‑level abstraction (requirements, functional, logical, product) with a centralised model repository. Coordination between the structural and behavioural models is achieved through model integration within the MBSE toolchain, enabling automatic generation of simulation and code artifacts."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin lifecycle is built on four stacked abstraction layers: a requirements layer that captures system constraints, a functional architecture layer that defines high‑level capabilities, a logical architecture layer that describes component interactions, and a product/technical layer that specifies concrete implementation details."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A robust fidelity and validity protocol balances analytical simplicity with realistic dynamics. The twin employs a multi‑resolution modeling hierarchy: lower‑order kinematics models for rapid controller tuning, and higher‑order dynamic models that incorporate detailed motor electrical characteristics, gearbox backlash, and nonlinear friction. Validation is performed by systematic comparison of simulated joint trajectories against measured data collected during a calibration routine. The deviation metric employs the mean absolute deviation over a five‑second test step, with a threshold of <0.05 degrees for position and <0.3 degrees per second for velocity. Exceedances trigger a re‑parameterization loop where parameters are adjusted via a gradient‑based optimizer. Uncertainty quantification is performed through Monte‑Carlo simulation of sensor noise and component tolerances, yielding confidence intervals for predicted states. Error detection is integrated at both data and model levels: outlier filtering removes transient spikes, while residual analysis flags model mismatch when the difference between predicted and measured signals exceeds three sigma. Quality assurance is maintained through automated regression tests that run on every code and model revision, generating a signed “fit report” that documents validation status, test coverage, and any identified regressions."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Shadow is a passive one‑way data consumer; it receives data streams from the physical object without pushing data back. The integration is limited to a single data flow channel; no bidirectional communication or external enterprise system integration (e.g., MES/ERP) is described. Inter‑system protocols are not specified beyond the generic one‑way data ingestion."
]