// C3: Physical sensing components (represented by digital shadow collector)
instance RobotContextCollector : DTDFVocab:SensingComponent [
    base:desc "Automated collector in the digital shadow that continuously gathers contextual data traces from the MABI MAX 100 robot and forwards them to the digital twin."
    DTDFVocab:producedData RobotDataTransmission
]

// C4: Data transmitted from physical to virtual
instance RobotDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotContextCollector
]

// C10: Data produced by the transmission
instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data collected from the robot, used for model synchronization and decision support."
    DTDFVocab:fromData RobotDataTransmission
    DTDFVocab:inputTo JavaRuntime
]

// C10: Models
instance StructuralModel : DTDFVocab:Model [
    base:desc "Structural/geometric model of the MABI MAX 100 captured in SysML block diagrams and internal block diagrams."
    DTDFVocab:inputTo SysMLTool
]

instance BehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model expressed as SysML state machines describing robot axis motions and controller logic."
    DTDFVocab:inputTo SysMLTool
]

instance AnalyticalSimulinkModel : DTDFVocab:Model [
    base:desc "Physics‑based dynamic simulation model of the robot implemented in MathWorks Simulink."
    DTDFVocab:inputTo SimulinkTool
]

instance MachineLearningRegressorModel : DTDFVocab:Model [
    base:desc "Data‑driven black‑box regression model (machine‑learning) used for predicting robot performance metrics."
    DTDFVocab:inputTo JavaRuntime
]

// C11: Enablers (tooling and execution environments)
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML modeling environment used to author structural and behavioral models and generate traceability artifacts."
    DTDFVocab:enables ContextProcessingService
]

instance ACMEArchitectureDescription : DTDFVocab:Enabler [
    base:desc "ACME architecture description language used for component‑connector mappings and system composition."
    DTDFVocab:enables ContextProcessingService
]

instance AADLArchitectureDescription : DTDFVocab:Enabler [
    base:desc "AADL used to describe hardware/software components and their interactions."
    DTDFVocab:enables ContextProcessingService
]

instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc language for architecture modeling, supporting component connectivity."
    DTDFVocab:enables ContextProcessingService
]

instance MontiArcAutomatonBehavior : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton extension for specifying component behavior models."
    DTDFVocab:enables ContextProcessingService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for analytical and dynamic simulation models."
    DTDFVocab:enables ContextProcessingService
]

instance CppRuntime : DTDFVocab:Enabler [
    base:desc "C++ runtime used to integrate generated code and provide low‑level execution of twin services."
    DTDFVocab:enables ContextProcessingService
]

instance JavaRuntime : DTDFVocab:Enabler [
    base:desc "Java runtime environment that hosts data processing and decision‑support services."
    DTDFVocab:enables ContextProcessingService
]

// C6: Services
instance ContextProcessingService : DTDFVocab:Service [
    base:desc "Active software component that interprets the one‑way data flow, processes contextual data traces, and provides decision support and optimization capabilities."
    DTDFVocab:provides DecisionSupportInsight, OptimizationAction
]

// C17: Insights
instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Insight derived from processed data that supports operational decisions for the robot."
]

// C17: Actions
instance OptimizationAction : DTDFVocab:Action [
    base:desc "Automatic optimization action that adjusts robot parameters based on insight, enabling closed‑loop performance improvement."
    DTDFVocab:IsAutomatic true
]

// Components of the physical system
instance MabiMax100Robot : DTDFVocab:Component [
    base:desc "Serial industrial robot MABI MAX 100, a six‑axis robot with permanent‑magnet synchronous motors and a Siemens SINUMERIK 840D controller."
]

instance Axis1Motor : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor driving the first axis of the MABI MAX 100 robot."
]

instance Sinumerik840DController : DTDFVocab:Component [
    base:desc "Siemens SINUMERIK 840D sl controller managing robot motion and I/O."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "A Digital Twin can provide active components that enable bidirectional communication, allowing the digital model to push data or commands back to the physical system. The documents mention that a digital twin may contain active components for control, but they do not describe command types, control message formats, validation/authentication mechanisms, feedback systems, conflict resolution, or command execution confirmation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows the Digital Shadow Reference Model, consisting of Asset, Model, DataTrace, Processing, and Source entities. A Processing component consumes input DataTraces, applies engineering or simulation models, and emits output DataTraces that become part of the shadow. Associations such as 'originates from' provide transitive traceability from output traces back to source components and models. This component‑&‑connector style orchestration integrates heterogeneous models (e.g., SysML, simulation tools) and manages resources through explicit data‑flow links, embodying a model‑driven integration pattern."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by combining white‑box (physics‑based Simulink) and black‑box (data‑driven) models, as recommended for accurate friction identification. The approach stresses traceability of data to model elements and verification of model transformations (e.g., from SysML to simulation models) to guarantee correctness. Uncertainty arising from model approximations and data preprocessing is acknowledged, and quality assurance relies on explicit traceability links and verification steps described in the literature."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between physical devices and the digital twin relies on the MQTT protocol, with sensors acting as MQTT clients publishing time‑series data to an MQTT broker (e.g., Mosquitto). The network follows a client‑broker topology over IP networks. The documents reference the use of an IoT platform (ThingsBoard) that can ingest MQTT streams, implying a layered architecture where MQTT feeds into the platform’s data processing modules. No explicit bandwidth, latency, reliability, redundancy, or security (e.g., TLS) specifications are provided in the sources."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The deployment environment for the digital shadow/Digital Twin includes cloud‑based IoT platforms such as ThingsBoard and may incorporate Asset Administration Shells (AAS) for standardized representation, as mentioned in the literature. Visualization is performed through a dashboard (e.g., Angular‑based front‑end). While the texts refer to cloud‑based technologies at the machine shop‑floor level, concrete details on compute/storage sizing, scalability mechanisms, deployment models (cloud, edge, on‑premise), or availability assurances are not provided."
]