// C2: Acting Components (none specified in the document)

// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring electrical current of the motor."
    DTDFVocab:producedData MotorCurrentData
]
instance MotorEncoderPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Motor shaft encoder providing position data of the motor shaft."
    DTDFVocab:producedData MotorEncoderPositionData
]
instance GearboxEncoderPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Gearwheel encoder providing position data of the gearbox output."
    DTDFVocab:producedData GearboxEncoderPositionData
]
instance MotionSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor providing instantaneous velocity of the first axis transmitted via MQTT."
    DTDFVocab:producedData MotionSpeedData
]
instance MotionAccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor providing instantaneous acceleration of the first axis transmitted via MQTT."
    DTDFVocab:producedData MotionAccelerationData
]

// C4: Physical-to-virtual interaction
instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]
instance MotorEncoderPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderPositionSensor
]
instance GearboxEncoderPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderPositionSensor
]
instance MotionSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionSpeedSensor
]
instance MotionAccelerationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionAccelerationSensor
]
instance SimulationOutputData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderPositionSensor, GearboxEncoderPositionSensor
]

// C10: Models/Data
instance StructuralSysMLModel : DTDFVocab:Model [
    base:desc "Engineering structural SysML model of the first axis."
    DTDFVocab:inputTo SimulinkEnabler
]
instance MotorSimulationModel : DTDFVocab:Model [
    base:desc "Simulink executable simulation model of the motor."
    DTDFVocab:inputTo SimulinkEnabler
]
instance GearboxSimulationModel : DTDFVocab:Model [
    base:desc "Simulink model of the gearbox dynamics."
    DTDFVocab:inputTo SimulinkEnabler
]
instance SystemSimulationModel : DTDFVocab:Model [
    base:desc "Integrated Simulink model of the overall first axis system."
    DTDFVocab:inputTo SimulinkEnabler
]
instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Coulomb‑Viscous friction model implemented in Simulink."
    DTDFVocab:inputTo SimulinkEnabler
]
instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Stribeck friction model implemented in Simulink."
    DTDFVocab:inputTo SimulinkEnabler
]
instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Dahl friction model implemented in Simulink."
    DTDFVocab:inputTo SimulinkEnabler
]
instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "LuGre friction model implemented in Simulink."
    DTDFVocab:inputTo SimulinkEnabler
]

// C10: Data instances
instance CurrentDataTrace : DTDFVocab:Data [
    base:desc "Live sensor data trace of motor current captured at control loop frequency."
    DTDFVocab:fromData MotorCurrentData
    DTDFVocab:inputTo MQTTEnabler
]
instance MotorEncoderPositionDataTrace : DTDFVocab:Data [
    base:desc "Live sensor data trace of motor encoder position captured at control loop frequency."
    DTDFVocab:fromData MotorEncoderPositionData
    DTDFVocab:inputTo MQTTEnabler
]
instance GearboxEncoderPositionDataTrace : DTDFVocab:Data [
    base:desc "Live sensor data trace of gearbox encoder position captured at control loop frequency."
    DTDFVocab:fromData GearboxEncoderPositionData
    DTDFVocab:inputTo MQTTEnabler
]
instance SpeedDataTrace : DTDFVocab:Data [
    base:desc "Live sensor data trace of instantaneous speed of the first axis."
    DTDFVocab:fromData MotionSpeedData
    DTDFVocab:inputTo MQTTEnabler
]
instance AccelerationDataTrace : DTDFVocab:Data [
    base:desc "Live sensor data trace of instantaneous acceleration of the first axis."
    DTDFVocab:fromData MotionAccelerationData
    DTDFVocab:inputTo MQTTEnabler
]
instance DerivedFrictionDataTrace : DTDFVocab:Data [
    base:desc "Derived data trace of friction state generated from simulation output."
    DTDFVocab:fromData SimulationOutputData
    DTDFVocab:inputTo SimulinkEnabler
]

// C11: Enablers
instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker used for real‑time transmission of sensor data to the digital shadow."
    DTDFVocab:enables RealTimeVisualizationService, FrictionMonitoringService
]
instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "Simulink/MATLAB simulation environment for executing mechanical and friction models."
    DTDFVocab:enables FrictionModelUpdateService
]
instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Web dashboard providing real‑time visualization of joint motion and friction states."
    DTDFVocab:enables RealTimeVisualizationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of joint motion and friction states in a dashboard."
    DTDFVocab:provides DiscrepancyVisualizationInsight
]
instance FrictionMonitoringService : DTDFVocab:Service [
    base:desc "Continuous identification and alerting of abnormal friction behavior for maintenance."
    DTDFVocab:provides AbnormalFrictionAlertInsight, TriggerMaintenanceProcedure
]
instance FrictionModelUpdateService : DTDFVocab:Service [
    base:desc "Continuous identification and updating of white‑box and black‑box friction models for the first axis."
    DTDFVocab:provides FrictionParameterInsight
]

// C17: Insights / Actions
instance DiscrepancyVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of discrepancies between simulated and measured signals to guide operator decisions."
]
instance AbnormalFrictionAlertInsight : DTDFVocab:Insight [
    base:desc "Alert for abnormal friction behavior indicating maintenance needs."
]
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived friction model parameters for controller tuning."
]
instance TriggerMaintenanceProcedure : DTDFVocab:Action [
    base:desc "Action to trigger preventive maintenance procedure based on abnormal friction alerts."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time, continuous synchronization with the physical robot’s sensor sampling (sub‑second or faster), enabling live monitoring and online model identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow architecture consists of a data ingestion layer (MQTT), a processing component that consumes sensor traces, runs simulation models, and outputs processed traces, and a visualization dashboard; all components conform to the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational phase (as‑built/operating) where the digital shadow monitors the robot during machining tasks."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured through traceability: each data trace can be linked back to its originating sensor or simulation component. Validation occurs by comparing simulated outputs against measured data traces (e.g., deviation of ˆrM versus rM). The combination of white‑box analytical friction models and black‑box data‑driven models allows for continuous re‑calibration to maintain accuracy over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT broker facilitates communication between the robot’s sensors and the digital shadow; Asset Administration Shells expose data interfaces; data traces include metadata such as timestamp and source."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Conformance to Asset Administration Shell (AAS) standards, SysML modeling language, MBSE practices, and reference modeling approach (DSRM)."
]