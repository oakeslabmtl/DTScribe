// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the input electric current of the robot axes, publishing values via MQTT."
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Torque sensor on Axis 1 that reports mechanical torque, streamed via MQTT."
    DTDFVocab:producedData TorqueDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Encoder‑derived angular‑velocity sensor for each robot joint, sent as MQTT time‑series."
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

// C4: Physical‑to‑virtual interaction (data transmission)
instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

// C10: Data
instance InputCurrentTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of input‑current measurements streamed from InputCurrentSensor."
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo ProcessingEnabler
]

instance TorqueTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of torque values generated by TorqueSensor."
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo ProcessingEnabler
]

instance AngularVelocityTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of angular‑velocity readings supplied by AngularVelocitySensor."
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo ProcessingEnabler
]

instance DigitalShadowData : DTDFVocab:Data [
    base:desc "Aggregated digital‑shadow repository containing contextual traces from all sensors."
    DTDFVocab:inputTo ProcessingEnabler
]

// C10: Models/Data
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML block diagram describing the hierarchical structure of the MABI MAX 100 robot."
    DTDFVocab:inputTo ProcessingEnabler
]

instance SysMLBehaviorModel : DTDFVocab:Model [
    base:desc "SysML state‑machine specifications capturing functional behavior of the robot controller."
    DTDFVocab:inputTo ProcessingEnabler
]

instance SimulinkPhysicsModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink white‑box simulation of the robot’s kinematics and dynamics."
    DTDFVocab:inputTo ProcessingEnabler
]

instance DataDrivenBlackBoxModel : DTDFVocab:Model [
    base:desc "Black‑box data‑driven calculation model complementing the physics simulation."
    DTDFVocab:inputTo ProcessingEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME architecture description linking software components of the digital twin."
    DTDFVocab:inputTo ProcessingEnabler
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL model describing the execution platform and timing characteristics."
    DTDFVocab:inputTo ProcessingEnabler
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc component‑and‑connector model used for cross‑domain integration."
    DTDFVocab:inputTo ProcessingEnabler
]

// C11: Enablers
instance ProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that consumes sensor data traces and engineering models, applies simulation or calculation models, and emits derived output insights with provenance."
    DTDFVocab:enables RealTimeMonitoringService, DecisionSupportService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Active service providing real‑time monitoring of the robot’s physical state."
    DTDFVocab:provides PerformanceMetricsInsight, FeedbackControlAction
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Decision‑support service delivering anomaly detection and optimization recommendations."
    DTDFVocab:provides AnomalyIndicatorInsight, OptimizationRecommendationInsight
]

// C17: Insights
instance PerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Derived performance metrics (e.g., speed, load factor) computed from processed sensor traces."
]

instance AnomalyIndicatorInsight : DTDFVocab:Insight [
    base:desc "Anomaly indicators generated when sensor data deviate from model‑predicted behavior."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendations (e.g., trajectory adjustments) based on simulation outcomes."
]

// C17: Action
instance FeedbackControlAction : DTDFVocab:Action [
    base:desc "Automatic feedback control action applied to the robot controller to correct deviations."
    DTDFVocab:IsAutomatic true
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through traceability and verification of model transformations, notably from SysML specifications to executable Simulink simulations. The reliability of the Digital Twin depends on the correctness of both the underlying models and the data integration steps. Verification activities include checking consistency of model abstractions across abstraction layers and confirming that transformations preserve intended semantics. The approach emphasizes the need to combine complementary white‑box and black‑box models to improve overall accuracy, while maintaining documentation of model provenance to support validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on MQTT (Message Queuing Telemetry Transport) over standard IP networks. Physical sensors act as MQTT publishers, sending time‑series sensor data to an MQTT broker (Mosquitto) that serves as the communication hub. The network topology follows a typical star arrangement where edge devices connect directly to the broker. MQTT provides lightweight messaging suitable for low‑bandwidth, low‑latency transmission; however, explicit bandwidth, latency or redundancy specifications are not detailed in the documents. Security mechanisms such as TLS for MQTT are not described in the source material."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin is modelled with SysML, the OMG‑defined systems‑engineering modelling language, and its structure follows the Digital Shadow Reference Model, which enforces a formal conformance relation between a concrete class diagram and the reference diagram as described in [41]. Architectural descriptions may also employ standardized ADLs such as ACME, AADL or MontiArc, providing a component‑connector view that is consistent with established industry modelling standards."
]