instance IntrinsicRobotEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution encoder capturing joint-level positional data for kinematic analysis in industrial robots, supporting sub-millimeter positional accuracy requirements for friction modeling."
    DTDFVocab:producedData JointPositionDataTransmitted
]

instance ForceTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Precision force/torque sensor (±0.1% FS) distributed across robot joints to capture dynamic friction phenomena and nonlinear kinetic behavior, with high-frequency sampling capabilities (≥1kHz)."
    DTDFVocab:producedData ForceTorqueDataTransmitted
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency vibration sensor for monitoring dynamic system behavior, particularly useful for detecting anomalies in manufacturing processes and robotic systems."
    DTDFVocab:producedData VibrationDataTransmitted
]

instance EnvironmentalParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor network capturing contextual environmental parameters (humidity, pressure) relevant to manufacturing process stability and equipment performance."
    DTDFVocab:producedData EnvironmentalParameterDataTransmitted
]

