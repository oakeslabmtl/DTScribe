    DTDFVocab:inputTo DataAggregationEnabler
]

instance ForceTorqueData : DTDFVocab:Data [
    base:desc "Processed force/torque data traces with noise reduction and calibration applied, suitable for friction coefficient estimation and dynamic behavior analysis."
