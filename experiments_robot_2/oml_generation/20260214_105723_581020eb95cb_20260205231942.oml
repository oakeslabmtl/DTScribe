]

// C10: Models/Data
instance PhysicsBasedFrictionModel : DTDFVocab:Model [
    base:desc "White-box analytical model for nonlinear friction phenomena in industrial robots, implemented in Simulink with probabilistic latent variable components for uncertainty handling."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance DataDrivenFrictionModel : DTDFVocab:Model [
    base:desc "Black-box machine learning model trained on intrinsic robot state data to capture complex nonlinear relationships not representable analytically, avoiding dedicated experimental setups."
    DTDFVocab:inputTo MachineLearningEnabler
]

instance SysMLFunctionalArchitecture : DTDFVocab:Model [
    base:desc "SysML v1.7 functional architecture model describing system dynamics at logical/functional level using state machines for behavior specification."
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc automaton-based behavioral model for describing system dynamics in industrial robotics applications."
    DTDFVocab:inputTo MontiArcEnabler
]

