// Sensing Components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring electrical current drawn by the drive motor"
    DTDFVocab:producedData MotorCurrentRawDataTransmitted
]

instance MotorJointEncoder : DTDFVocab:SensingComponent [
    base:desc "Primary joint encoder measuring motor shaft angle"
    DTDFVocab:producedData MotorJointAngleRawDataTransmitted
]

instance GearboxJointEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder measuring gearbox output angle"
    DTDFVocab:producedData GearboxJointAngleRawDataTransmitted
]

// Data Transmitted via MQTT
instance MotorCurrentRawDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorJointAngleRawDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorJointEncoder
]

instance GearboxJointAngleRawDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxJointEncoder
]

// Derived Data Streams (torque, velocity, acceleration)
instance DerivedTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorJointEncoder, GearboxJointEncoder
]

instance DerivedVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorJointEncoder, GearboxJointEncoder
]

instance DerivedAccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorJointEncoder, GearboxJointEncoder
]

// Simulated Data Streams from MATLAB/Simulink
instance SimulatedTorqueDataTransmitted : DTDFVocab:DataTransmitted [
]

instance SimulatedVelocityDataTransmitted : DTDFVocab:DataTransmitted [
]

instance SimulatedAccelerationDataTransmitted : DTDFVocab:DataTransmitted [
]

// Data Instances
instance MotorCurrentRawData : DTDFVocab:Data [
    base:desc "Raw motor current measurement data stream"
    DTDFVocab:fromData MotorCurrentRawDataTransmitted
    DTDFVocab:inputTo EnablerMQTT
]

instance MotorJointAngleRawData : DTDFVocab:Data [
    base:desc "Raw motor shaft angle measurement data stream"
    DTDFVocab:fromData MotorJointAngleRawDataTransmitted
    DTDFVocab:inputTo EnablerMQTT
]

instance GearboxJointAngleRawData : DTDFVocab:Data [
    base:desc "Raw gearbox output angle measurement data stream"
    DTDFVocab:fromData GearboxJointAngleRawDataTransmitted
    DTDFVocab:inputTo EnablerMQTT
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Torque calculated from dual joint encoder data"
    DTDFVocab:fromData DerivedTorqueDataTransmitted
    DTDFVocab:inputTo EnablerMATLABSim
]

instance DerivedVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity calculated from joint encoder data"
    DTDFVocab:fromData DerivedVelocityDataTransmitted
    DTDFVocab:inputTo EnablerMATLABSim
]

instance DerivedAccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration calculated from joint encoder data"
    DTDFVocab:fromData DerivedAccelerationDataTransmitted
    DTDFVocab:inputTo EnablerMATLABSim
]

instance SimulatedTorqueData : DTDFVocab:Data [
    base:desc "Simulated torque from MATLAB/Simulink friction model"
    DTDFVocab:fromData SimulatedTorqueDataTransmitted
    DTDFVocab:inputTo EnablerMATLABSim
]

instance SimulatedVelocityData : DTDFVocab:Data [
    base:desc "Simulated angular velocity from MATLAB/Simulink friction model"
    DTDFVocab:fromData SimulatedVelocityDataTransmitted
    DTDFVocab:inputTo EnablerMATLABSim
]

instance SimulatedAccelerationData : DTDFVocab:Data [
    base:desc "Simulated angular acceleration from MATLAB/Simulink friction model"
    DTDFVocab:fromData SimulatedAccelerationDataTransmitted
    DTDFVocab:inputTo EnablerMATLABSim
]

// Models
instance SysMLBlockDiagramModel : DTDFVocab:Model [
    base:desc "SysML block and interaction diagram of motor, gearbox, and joint hardware"
    DTDFVocab:inputTo EnablerAAS
]

instance MATLABSimFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model implementing friction laws (Coulomb-Viscous, Stribeck, Dahl, LuGre)"
    DTDFVocab:inputTo EnablerMATLABSim
]

// Enablers
instance EnablerMQTT : DTDFVocab:Enabler [
    base:desc "MQTT broker handling live data streams of motor current and joint encoder angles"
    DTDFVocab:enables ServiceRealTimeFrictionID
]

instance EnablerMATLABSim : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for real‑time friction identification and model updating"
    DTDFVocab:enables ServiceRealTimeFrictionID, ServiceFrictionModelUpdate
]

instance EnablerDashboard : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard for visual comparison of measured and simulated data"
    DTDFVocab:enables ServiceDashboardVisualization
]

instance EnablerAAS : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell governing asset metadata and interoperability"
    DTDFVocab:enables ServiceFrictionModelUpdate
]

// Services
instance ServiceRealTimeFrictionID : DTDFVocab:Service [
    base:desc "Real‑time joint friction identification service updating white‑box and black‑box models"
    DTDFVocab:provides InsightFrictionParameterUpdate, InsightWearIdentification, InsightTaskPlanningAdjustment
]

instance ServiceFrictionModelUpdate : DTDFVocab:Service [
    base:desc "Service providing friction model updates to the CNC controller (SINUMERIK 840D SL)"
    DTDFVocab:provides InsightFrictionParameterUpdate, ActionGenerateFrictionParameterUpdate
]

instance ServiceDashboardVisualization : DTDFVocab:Service [
    base:desc "Unified dashboard service for visualizing measured versus simulated torque, velocity, and acceleration"
    DTDFVocab:provides InsightFrictionParameterUpdate, InsightWearIdentification, InsightTaskPlanningAdjustment
]

// Insights
instance InsightFrictionParameterUpdate : DTDFVocab:Insight [
    base:desc "Notification of updated friction parameters for controller tuning"
]

instance InsightWearIdentification : DTDFVocab:Insight [
    base:desc "Identification of wear or tool changes based on friction behavior"
]

instance InsightTaskPlanningAdjustment : DTDFVocab:Insight [
    base:desc "Suggestion of task planning adjustments based on friction‑derived insights"
]

// Actions
instance ActionGenerateFrictionParameterUpdate : DTDFVocab:Action [
    base:desc "Automated generation of friction parameter updates for CNC controller tuning"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time continuous synchronization at the robot’s native sampling rate (typically several hundred samples per second), with simulation runs performed synchronously to match instantaneous friction estimates"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Digital Shadow comprising: asset description via AAS, engineering model (SysML), simulation component (Simulink), data‑linking mechanism, processing component generating computed traces, and a visual dashboard—consolidated through MQTT and AAS interfaces"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated phase twin providing online friction identification; engineering stages include design of the digital shadow, implementation of models and data, deployment to the control environment, and operational use"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of every data point to its source and processing chain; comparison of simulated vs. measured data; use of white‑box and black‑box models combined for higher fidelity; continuous model updating to reduce deviation; validation through measurement‑derived torque calculations"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT transport protocol for sensor data ingestion; Asset Administration Shell interfaces for structure and metadata; optional REST endpoints for dashboard communication"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "SysML (v1.7), MBSE methodologies (RFLP, SMArDT), Digital Shadow Reference Model, Asset Administration Shells, and compliance with the digital‑shadow concept of one‑way data flow"
]