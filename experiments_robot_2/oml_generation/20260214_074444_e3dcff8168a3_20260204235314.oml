// -----------------------------------------------------------------------------
// C3: Physical-to-Virtual Interaction – Sensors and Data Transmission
// -----------------------------------------------------------------------------
instance MqttDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor, OutputAngleSensor
]

instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input current of the MABIMAX100 robot first axis",
    DTDFVocab:producedData MqttDataStream
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring output angle of the MABIMAX100 robot first axis",
    DTDFVocab:producedData MqttDataStream
]

// -----------------------------------------------------------------------------
// C10: Data Artifacts (raw and derived)
// -----------------------------------------------------------------------------
instance RawCurrentData : DTDFVocab:Data [
    base:desc "Raw time‑stamped current measurements from InputCurrentSensor",
    DTDFVocab:fromData MqttDataStream,
    DTDFVocab:inputTo DataProcessor
]

instance RawAngleData : DTDFVocab:Data [
    base:desc "Raw time‑stamped angle measurements from OutputAngleSensor",
    DTDFVocab:fromData MqttDataStream,
    DTDFVocab:inputTo DataProcessor
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Derived torque calculated from current and angle measurements",
    DTDFVocab:fromData MqttDataStream,
    DTDFVocab:inputTo MonitoringEngine
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity calculated from successive angle samples",
    DTDFVocab:fromData MqttDataStream,
    DTDFVocab:inputTo MonitoringEngine
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration calculated from velocity data",
    DTDFVocab:fromData MqttDataStream,
    DTDFVocab:inputTo MonitoringEngine
]

// -----------------------------------------------------------------------------
// C10: Services needed for processing
// -----------------------------------------------------------------------------
instance DataProcessingInsight : DTDFVocab:Insight [
    base:desc "Result of processing raw sensor streams into derived data"
]

instance DataProcessingService : DTDFVocab:Service [
    base:desc "Service that processes raw data streams into derived data",
    DTDFVocab:provides DataProcessingInsight
]

// -----------------------------------------------------------------------------
// C11: Enablers (processing and simulation engines)
// -----------------------------------------------------------------------------
instance DataProcessor : DTDFVocab:Enabler [
    base:desc "Pre‑processes raw sensor streams and derives torque, velocity, and acceleration",
    DTDFVocab:enables DataProcessingService
]

instance MonitoringEngine : DTDFVocab:Enabler [
    base:desc "Consumes derived kinematic data to provide real‑time joint monitoring",
    DTDFVocab:enables RealTimeJointMonitoringService
]

instance FrictionAnalysisEngine : DTDFVocab:Enabler [
    base:desc "Uses multi‑physics models to quantify joint friction losses",
    DTDFVocab:enables JointFrictionIdentificationService
]

instance WearPredictionEngine : DTDFVocab:Enabler [
    base:desc "Predicts wear and degradation using physics‑aware and ML models",
    DTDFVocab:enables WearPredictionService
]

instance OptimizationEngine : DTDFVocab:Enabler [
    base:desc "Optimizes control parameters based on model predictions",
    DTDFVocab:enables ControlParameterOptimizationService
]

instance AssistanceEngine : DTDFVocab:Enabler [
    base:desc "Provides closed‑loop trajectory assistance and fault detection",
    DTDFVocab:enables ClosedLoopTrajectoryAssistanceService,
    DTDFVocab:enables FaultDetectionService
]

// -----------------------------------------------------------------------------
// C6: Services
// -----------------------------------------------------------------------------
instance RealTimeJointMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of joint positions, velocities and forces",
    DTDFVocab:provides JointPositionInsight,
    DTDFVocab:provides JointVelocityInsight,
    DTDFVocab:provides JointForceInsight
]

instance JointFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuously identifies and quantifies joint friction losses using multi‑physics models",
    DTDFVocab:provides FrictionLossInsight
]

instance WearPredictionService : DTDFVocab:Service [
    base:desc "Predicts wear and degradation of the first axis",
    DTDFVocab:provides WearTrendInsight
]

instance ControlParameterOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes control parameters to improve accuracy",
    DTDFVocab:provides OptimizeControlParametersAction
]

instance ClosedLoopTrajectoryAssistanceService : DTDFVocab:Service [
    base:desc "Offers closed‑loop assistance for trajectory planning",
    DTDFVocab:provides AssistTrajectoryPlanningAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults in the axis based on sensor data and model anomalies",
    DTDFVocab:provides FaultAlertInsight
]

// -----------------------------------------------------------------------------
// C17: Insights
// -----------------------------------------------------------------------------
instance JointPositionInsight : DTDFVocab:Insight [
    base:desc "Current joint position derived from angle sensor data"
]

instance JointVelocityInsight : DTDFVocab:Insight [
    base:desc "Current joint velocity derived from angular‑velocity data"
]

instance JointForceInsight : DTDFVocab:Insight [
    base:desc "Estimated joint torque derived from derived torque data"
]

instance FrictionLossInsight : DTDFVocab:Insight [
    base:desc "Quantified joint friction loss obtained from physics‑aware analysis"
]

instance WearTrendInsight : DTDFVocab:Insight [
    base:desc "Projected wear trend for the axis based on historical and model data"
]

instance FaultAlertInsight : DTDFVocab:Insight [
    base:desc "Detected fault condition with severity level for operator awareness"
]

// -----------------------------------------------------------------------------
// C17: Actions
// -----------------------------------------------------------------------------
instance OptimizeControlParametersAction : DTDFVocab:Action [
    base:desc "Automatically adjusts controller gains to improve repeatability",
    DTDFVocab:IsAutomatic true
]

instance AssistTrajectoryPlanningAction : DTDFVocab:Action [
    base:desc "Provides operator with suggested trajectory corrections in real time",
    DTDFVocab:IsAutomatic true
]

// -----------------------------------------------------------------------------
// C10: Models (MBSE artefacts)
// -----------------------------------------------------------------------------
instance SysMLArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model capturing structural and functional architecture of the robot axis",
    DTDFVocab:inputTo SysMLTool
]

instance ADLComponentConnectorModel : DTDFVocab:Model [
    base:desc "ACME/AADL/MontiArc model describing components and connectors of the axis",
    DTDFVocab:inputTo ADLTool
]

instance StateMachineBehaviorModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state‑machine model of axis behavior",
    DTDFVocab:inputTo BehaviorEngine
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink white‑box dynamic model of motor‑gearbox‑joint system",
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance MachineLearningPredictorModel : DTDFVocab:Model [
    base:desc "Data‑driven ML predictor for wear and friction based on historical data",
    DTDFVocab:inputTo MachineLearningInferenceEngine
]

// -----------------------------------------------------------------------------
// C11: Enablers for Model Execution / Transformation
// -----------------------------------------------------------------------------
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "Tool supporting SysML modeling and transformations to Simulink",
    DTDFVocab:enables ModelingTransformationService
]

instance ADLTool : DTDFVocab:Enabler [
    base:desc "Tool for authoring ACME/AADL/MontiArc architecture models",
    DTDFVocab:enables ArchitectureCompositionService
]

instance BehaviorEngine : DTDFVocab:Enabler [
    base:desc "Engine executing state‑machine behavior models",
    DTDFVocab:enables JointFrictionIdentificationService
]

instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulink runtime executing the white‑box dynamic model",
    DTDFVocab:enables WearPredictionService
]

instance MachineLearningInferenceEngine : DTDFVocab:Enabler [
    base:desc "Framework (e.g., TensorFlow) running ML predictor models",
    DTDFVocab:enables WearPredictionService
]

// -----------------------------------------------------------------------------
// Additional Services for Model Management
// -----------------------------------------------------------------------------
instance ModelingTransformationService : DTDFVocab:Service [
    base:desc "Transforms SysML models to Simulink models",
    DTDFVocab:provides ModelTransformationInsight
]

instance ArchitectureCompositionService : DTDFVocab:Service [
    base:desc "Composes component models using ADLs",
    DTDFVocab:provides ArchitectureCompositionInsight
]

// -----------------------------------------------------------------------------
// Insights for Model Management
// -----------------------------------------------------------------------------
instance ModelTransformationInsight : DTDFVocab:Insight [
    base:desc "Verified transformation from SysML to Simulink"
]

instance ArchitectureCompositionInsight : DTDFVocab:Insight [
    base:desc "Validated composition of physics‑based and data‑driven components"
]

// -----------------------------------------------------------------------------
// Physical Components (system under study)
// -----------------------------------------------------------------------------
instance AxisMotor : DTDFVocab:Component [
    base:desc "High‑torque motor of the first axis"
]

instance MultiStageGearbox : DTDFVocab:Component [
    base:desc "Multi‑stage gearbox transmitting motor torque"
]

instance RotaryJoint : DTDFVocab:Component [
    base:desc "Flexible rotary joint delivering high repeatability"
]

instance Sinumerik840DController : DTDFVocab:Component [
    base:desc "Siemens SINUMERIK 840D SL controller driving the axis"
]

instance FirstAxisAssembly : DTDFVocab:Component [
    base:desc "Assembly comprising motor, gearbox and rotary joint"
]

// -----------------------------------------------------------------------------
// Environment containing the physical components
// -----------------------------------------------------------------------------
instance RobotEnvironment : DTDFVocab:Environment [
    base:contains AxisMotor, MultiStageGearbox, RotaryJoint, Sinumerik840DController, FirstAxisAssembly
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained through rigorous traceability of data artifacts and verification of model transformations. Each digital shadow data trace is linked to its generation process and to the corresponding model element, supporting impact analysis. Transformations from high‑level MBSE artifacts (e.g., SysML diagrams) to executable simulation models (e.g., Simulink) are subject to verification methods that check structural and semantic consistency. Validation is performed by comparing model outputs with the measured data traces provided by the digital shadow; observed deviations are used to assess accuracy and trigger model refinement. Sources of uncertainty such as sensor noise or modeling simplifications are acknowledged, and their impact is documented as part of the traceability information."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the physical sensors and the digital shadow uses the MQTT protocol (as referenced by the Mosquitto client/server implementation). The documents do not provide details on network topology, bandwidth or latency requirements, redundancy mechanisms, or security protocols (e.g., TLS) for this connection."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach conforms to the SysML modeling language for system architecture and to UML class diagrams for the Digital Shadow Reference Model. The reference model defines a conformance relation that must be satisfied by any concrete realization, providing a standardised way to map domain concepts to concrete elements. ADLs such as ACME, AADL and MontiArc are employed as standard component‑connector description languages, and the processing step leverages standard simulation and data‑calculation model formats as defined by the reference model."
]