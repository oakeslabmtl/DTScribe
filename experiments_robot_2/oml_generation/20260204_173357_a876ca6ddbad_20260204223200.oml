// C4: Physical-to-virtual interaction
instance EquipmentMqttClient : DTDFVocab:SensingComponent [
    base:desc "Embedded MQTT client in the equipment that streams sensor data via MQTT (Mosquitto broker) to the digital counterpart."
    DTDFVocab:producedData MqttSensorDataStream
]

instance MqttSensorDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EquipmentMqttClient
]

instance TimeStampedSensorReading : DTDFVocab:Data [
    base:desc "Time‑stamped sensor reading collected from the physical CPS, potentially filtered and transformed before storage."
    DTDFVocab:fromData MqttSensorDataStream
    DTDFVocab:inputTo ProcessingEngine
]

// C11: Enablers
instance ProcessingEngine : DTDFVocab:Enabler [
    base:desc "Processing component that aggregates, filters, transforms, and runs simulation or calculation models on incoming sensor traces before storing them in the digital shadow."
    DTDFVocab:enables DigitalShadowUpdateService
]

// C6: Services
instance DigitalShadowUpdateService : DTDFVocab:Service [
    base:desc "Service that stores processed data traces in the digital shadow and makes them available for downstream insights."
    DTDFVocab:provides TwinStateInsight, DataQualityValidation
]

// C17: Insights/Actions
instance TwinStateInsight : DTDFVocab:Insight [
    base:desc "Provides a real‑time view of the system state within the digital shadow."
]

instance DataQualityValidation : DTDFVocab:Action [
    base:desc "Automatically validates incoming sensor traces against model specifications to ensure quality assurance."
    DTDFVocab:IsAutomatic true
]

// C10: Models/Data
instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Simulink dynamic simulation model that represents system behavior and is executed by the processing engine."
    DTDFVocab:inputTo ProcessingEngine
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Data‑calculation model that derives higher‑level abstractions from pre‑processed sensor data."
    DTDFVocab:inputTo ProcessingEngine
]

instance EngineeringStructureModel : DTDFVocab:Model [
    base:desc "Engineering model describing system structure and properties, linked to both input data and generated output traces."
    DTDFVocab:inputTo ProcessingEngine
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through verification of model transformations (e.g., from SysML to simulation models) and by maintaining fine‑grained traceability of data traces to the processing components and underlying models. The reliability of the Digital Twin depends on the correctness of the engineering, simulation and data‑calculation models, with explicit traceability used to detect and correct errors. Quality‑assurance processes include model‑based verification, traceability checks, and conformance to the Digital Shadow Reference Model; uncertainty sources are addressed by ensuring correct transformations and model correctness, although quantitative uncertainty quantification is not detailed in the documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between physical devices and the digital shadow relies on the MQTT protocol over a client‑server topology; physical nodes act as MQTT clients publishing to topics on a Mosquitto broker, while the digital‑twin side (e.g., Thingsboard platform) subscribes to these topics. No explicit bandwidth, latency, or redundancy specifications are given in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital shadow and twin are hosted on cloud‑based IoT platforms such as Thingsboard (version 4.0.0) and can also be deployed at the shop‑floor level using cloud‑enabled services, as described for a CNC‑machine digital shadow (Document 57). The deployment relies on standard cloud infrastructure providing compute and storage for the processing components and model execution; scalability is achieved through the cloud platform’s elastic resources. No on‑premise or edge‑specific deployment details are provided."
]