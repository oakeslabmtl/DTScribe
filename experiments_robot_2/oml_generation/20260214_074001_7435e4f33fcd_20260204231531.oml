// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input electric current of the physical object, providing time‑series data."
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring output mechanical angle of the physical object, providing time‑series data."
    DTDFVocab:producedData OutputAngleDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

// C10: Data
instance InputCurrentData : DTDFVocab:Data [
    base:desc "Aggregated input‑current time‑series after MQTT transport and preprocessing."
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo MosquittoBrokerEnabler, DataPreprocessorEnabler
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Aggregated output‑angle time‑series after MQTT transport and preprocessing."
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo MosquittoBrokerEnabler, DataPreprocessorEnabler
]

// C11: Enablers (data flow)
instance MosquittoBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker (Mosquitto) used for one‑way streaming of sensor samples with QoS guarantees."
    DTDFVocab:enables DataIngestionService
]

instance DataPreprocessorEnabler : DTDFVocab:Enabler [
    base:desc "Pre‑processing engine that filters, aligns and abstracts raw sensor traces before integration."
    DTDFVocab:enables DataAnalysisService
]

// C6: Services (data flow)
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service ingesting pre‑processed sensor data into the digital‑shadow platform."
    DTDFVocab:provides CurrentDataInsight
]

instance DataAnalysisService : DTDFVocab:Service [
    base:desc "Service performing quality checks and analytical processing on ingested data."
    DTDFVocab:provides AngleDataInsight
]

// C17: Insights (data flow)
instance CurrentDataInsight : DTDFVocab:Insight [
    base:desc "Insight derived from input‑current trends, supporting monitoring of electrical behavior."
]

instance AngleDataInsight : DTDFVocab:Insight [
    base:desc "Insight derived from output‑angle trends, supporting mechanical performance evaluation."
]

// C10: Models
instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML v1.7 model capturing stakeholder requirements for the digital twin."
    DTDFVocab:inputTo ModelTransformationEnabler
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML functional specification model linking requirements to system functions."
    DTDFVocab:inputTo ModelTransformationEnabler
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Logical component‑connector architecture expressed in ACME/AADL/MontiArc."
    DTDFVocab:inputTo ModelTransformationEnabler
]

instance PhysicalArchitectureModel : DTDFVocab:Model [
    base:desc "Physical layer model detailing concrete components and interfaces."
    DTDFVocab:inputTo ModelTransformationEnabler
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "White‑box analytical simulation model built in MathWorks Simulink."
    DTDFVocab:inputTo SimulationEnabler
]

instance CppRuntimeModel : DTDFVocab:Model [
    base:desc "Generated C++ runtime artifact implementing the digital twin behavior."
    DTDFVocab:inputTo CodeGenerationEnabler
]

// C11: Enablers (model processing)
instance ModelTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Transformation engine converting SysML models to simulation and code artifacts."
    DTDFVocab:enables ModelTransformationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulink execution environment running the simulation model."
    DTDFVocab:enables SimulationService
]

instance CodeGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Code generator producing C++ and Java implementations from transformed models."
    DTDFVocab:enables CodeExecutionService
]

// C6: Services (model processing)
instance ModelTransformationService : DTDFVocab:Service [
    base:desc "Service orchestrating model-to-model transformations across abstraction levels."
    DTDFVocab:provides ModelTransformationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service executing Simulink simulations for dynamic behavior analysis."
    DTDFVocab:provides SimulationResultInsight
]

instance CodeExecutionService : DTDFVocab:Service [
    base:desc "Service managing execution of generated C++/Java runtime artifacts."
    DTDFVocab:provides RuntimeExecutionAction
]

// C17: Insights/Actions (model processing)
instance ModelTransformationInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful propagation of requirements to logical and physical models."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight revealing simulation outcomes for validation of the digital twin."
]

instance RuntimeExecutionAction : DTDFVocab:Action [
    base:desc "Action triggering the live execution of the digital twin runtime."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin processes live measurement data in real‑time, receiving continuous data traces from the physical robot axis and updating its internal models continuously. Synchronisation is performed on a real‑time basis, with latency kept low enough to support near‑instantaneous feedback, although the documents do not specify exact update frequencies or quantitative latency limits."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows the Digital Shadow Reference Model, instantiated as a concrete Digital Shadow model that comprises the core entities Asset, Source, Model, Processing, and Data Trace. Data traces are generated by Processing components that consume input traces and apply engineering, simulation, or data‑calculation models to produce new traces. Traceability is maintained through the ‘originates‑from’ association, enabling transitive linking of traces to the responsible processing component and underlying models. A pipeline architecture dynamically exchanges friction models, orchestrating the flow of data from the physical asset through the processing chain to the twin’s digital representation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and validity are addressed through traceability and verification of model transformations, as emphasized in the documents. Reliability of the digital shadow (and thus the Digital Twin) depends on the correctness of underlying models and the data processing pipeline. The approach mandates verification of transformations (e.g., from SysML specifications to Simulink simulations) to ensure semantic consistency. Traceability mechanisms are required to link model elements to source data, supporting quality assurance and detection of modeling errors. While specific uncertainty quantification methods are not detailed, the emphasis on verification and correct data aggregation reflects a commitment to maintaining high model fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the physical layer and the digital twin relies on the MQTT protocol (implemented with Mosquitto as server/client). MQTT operates over TCP/IP, providing a publish/subscribe network topology where the physical device publishes sensor topics and the digital twin subscribes to them. The required bandwidth is low‑to‑moderate, matching typical IoT sensor streams, and the protocol’s built‑in QoS levels address reliability. Security is handled by MQTT’s optional TLS encryption, as described in the referenced MQTT implementation details."
]