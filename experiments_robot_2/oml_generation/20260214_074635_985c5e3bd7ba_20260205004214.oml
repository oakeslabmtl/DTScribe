// C3: Physical sensing components
instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder of the vertical axis (provides raw motor angle r_M)"
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the gearbox (provides gearbox output angle r_out)"
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor phase current I_M"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance DerivedTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorMountedEncoder
]

instance DerivedAngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder
]

// C10: Data instances
instance MotorAngleData : DTDFVocab:Data [
    base:desc "Measured motor angle r_M streamed via MQTT"
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Measured gearbox output angle r_out streamed via MQTT"
    DTDFVocab:fromData GearboxAngleDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current I_M streamed via MQTT"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance MotorTorqueData : DTDFVocab:Data [
    base:desc "Derived motor torque τ_M calculated from I_M and motor parameters"
    DTDFVocab:fromData DerivedTorqueDataTransmitted
    DTDFVocab:inputTo FrictionIdentificationEngine
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω calculated from successive angle measurements"
    DTDFVocab:fromData DerivedAngularVelocityDataTransmitted
    DTDFVocab:inputTo FrictionIdentificationEngine
]

// C10: Models / Data
instance SysMLAxisBlockModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagram of the vertical axis"
    DTDFVocab:inputTo AssetAdministrationShell
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the permanent‑magnet synchronous motor"
    DTDFVocab:inputTo MATLABSimulinkEngine
]

instance SimulinkGearwheelModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the gearwheel gearbox"
    DTDFVocab:inputTo MATLABSimulinkEngine
]

instance SimulinkCycloidalGearboxModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the cycloidal gearbox"
    DTDFVocab:inputTo MATLABSimulinkEngine
]

instance FrictionModelCoulombViscous : DTDFVocab:Model [
    base:desc "Friction model combining Coulomb and viscous friction components"
    DTDFVocab:inputTo FrictionIdentificationEngine
]

instance FrictionModelStribeck : DTDFVocab:Model [
    base:desc "Stribeck friction model for low‑speed behavior"
    DTDFVocab:inputTo FrictionIdentificationEngine
]

instance FrictionModelDahl : DTDFVocab:Model [
    base:desc "Dahl friction model capturing pre‑slip dynamics"
    DTDFVocab:inputTo FrictionIdentificationEngine
]

instance FrictionModelLuGre : DTDFVocab:Model [
    base:desc "LuGre friction model for dynamic friction identification"
    DTDFVocab:inputTo FrictionIdentificationEngine
]

instance FrictionParametersData : DTDFVocab:Data [
    base:desc "Identified static, kinetic and viscous friction parameters"
    DTDFVocab:inputTo SiemensSinumerikController
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker that streams live sensor measurements to the digital twin"
    DTDFVocab:enables RealTimeVisualizationService , FrictionIdentificationService
]

instance MATLABSimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution engine running motor and gearbox simulation models"
    DTDFVocab:enables SimulationExecutionService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for integrating engineering models with the digital twin"
    DTDFVocab:enables ModelManagementService
]

instance SiemensSinumerikController : DTDFVocab:Enabler [
    base:desc "Siemens SINUMERIK 840D controller that receives updated friction parameters"
    DTDFVocab:enables ParameterUpdateService
]

instance DashboardVisualizationTool : DTDFVocab:Enabler [
    base:desc "Custom dashboard that visualizes measured and simulated data in real time"
    DTDFVocab:enables RealTimeVisualizationService
]

instance FrictionIdentificationEngine : DTDFVocab:Enabler [
    base:desc "Algorithmic engine that continuously identifies friction parameters from sensor data"
    DTDFVocab:enables FrictionIdentificationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of measured and simulated data in a unified dashboard"
    DTDFVocab:provides InsightLiveDataVisualization
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of static, kinetic and viscous friction parameters"
    DTDFVocab:provides InsightFrictionParametersIdentified
]

instance ParameterUpdateService : DTDFVocab:Service [
    base:desc "Generation and transmission of updated friction parameters to improve motion control accuracy"
    DTDFVocab:provides ActionUpdateControllerParameters
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Execution of MATLAB/Simulink motor and gearbox simulation models"
    DTDFVocab:provides InsightSimulationResults
]

instance ModelManagementService : DTDFVocab:Service [
    base:desc "Management and versioning of engineering models via the Asset Administration Shell"
    DTDFVocab:provides InsightModelConsistency
]

// C17: Insights / Actions
instance InsightLiveDataVisualization : DTDFVocab:Insight [
    base:desc "Operators can monitor live sensor data and simulation results simultaneously"
]

instance InsightFrictionParametersIdentified : DTDFVocab:Insight [
    base:desc "Friction parameters (static, kinetic, viscous) are identified from live data"
]

instance ActionUpdateControllerParameters : DTDFVocab:Action [
    base:desc "Automatic update of controller friction parameters to refine motion control algorithms"
    DTDFVocab:IsAutomatic true
]

instance InsightSimulationResults : DTDFVocab:Insight [
    base:desc "Simulation outputs provide predictive behavior of motor and gearboxes"
]

instance InsightModelConsistency : DTDFVocab:Insight [
    base:desc "Ensures that SysML and Simulink models remain consistent within the digital twin"
]

// C17: Environment and Components (optional, for completeness)
instance VerticalAxisEnvironment : DTDFVocab:Environment [
    base:contains MotorMountedEncoder , GearboxEncoder , MotorCurrentSensor
]

instance VerticalAxisComponent : DTDFVocab:Component [
    base:desc "First vertical axis of the MABI MAX 100 robot, equipped with a permanent‑magnet synchronous motor, gearwheel gearbox, cycloidal gearbox, and safety cell limiting motion to ±90° at max 75 °/s"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time operation; data are acquired and processed as they are produced, enabling on‑line identification of friction during robot operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow consisting of a Purpose (FrictionDerivation), Asset (MABI first axis), Processing components (Simulation_M, Simulation_GW, Simulation_GB), Models (engineering, simulation, data‑calculation), Sources (sensor channels), and DataTraces that are linked to support friction identification."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow targets the operated phase of the robot, using live operational data to model the as‑built and as‑operated behavior."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability is maintained by linking each DataTrace to its originating Source and Processing component; both white‑box (analytical) and black‑box (data‑driven) friction models are continuously updated using live data, providing multi‑physics‑aware identification and validation of model accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted to the digital shadow via the MQTT protocol."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Asset Administration Shells (AAS) are used as the standardized information model for representing the robot asset and its associated data within the digital shadow."
]