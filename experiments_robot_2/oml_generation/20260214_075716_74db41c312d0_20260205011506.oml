instance PhysicalObjectStateSensor : DTDFVocab:SensingComponent [
    base:desc "Senses physical object state traces from the digital shadow's one-way data flow"
    DTDFVocab:producedData PhysicalObjectStateTraces
]

instance PhysicalObjectStateTraces : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalObjectStateSensor
]

instance RequirementsData : DTDFVocab:Data [
    base:desc "Data representing requirements abstraction level"
    DTDFVocab:fromData PhysicalObjectStateTraces
    DTDFVocab:inputTo SysML, RFLP, OOSEM, SPES, SMArDT
]

instance FunctionalArchitectureData : DTDFVocab:Data [
    base:desc "Data representing functional architecture abstraction level"
    DTDFVocab:fromData PhysicalObjectStateTraces
    DTDFVocab:inputTo SysML, RFLP, OOSEM, SPES, SMArDT
]

instance LogicalArchitectureData : DTDFVocab:Data [
    base:desc "Data representing logical architecture abstraction level"
    DTDFVocab:fromData PhysicalObjectStateTraces
    DTDFVocab:inputTo SysML, RFLP, OOSEM, SPES, SMArDT
]

instance ProductTechnicalLayerData : DTDFVocab:Data [
    base:desc "Data representing product/technical layer abstraction level"
    DTDFVocab:fromData PhysicalObjectStateTraces
    DTDFVocab:inputTo SysML, RFLP, OOSEM, SPES, SMArDT
]

instance SysML_StructuralModel : DTDFVocab:Model [
    base:desc "SysML model for structural modeling using Internal Block Diagrams (IBDs) for component & connector perspectives"
    DTDFVocab:inputTo SysML
]

instance MontiArcBehavioralModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArc
]

instance SysML_StateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavioral modeling"
    DTDFVocab:inputTo SysML
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink simulation model for dynamic behavior"
    DTDFVocab:inputTo Simulink
]

instance ACME : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component & connector architecture descriptions"
]

instance AADL : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component & connector architecture descriptions"
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component & connector architecture descriptions"
]

instance SysML : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering (MBSE) structural modeling language"
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "Methodology for abstraction level management"
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "Methodology for abstraction level management"
]

instance SPES : DTDFVocab:Enabler [
    base:desc "Methodology for abstraction level management"
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "Methodology for abstraction level management"
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "Tool for dynamic behavior simulation"
]

instance Cpp : DTDFVocab:Enabler [
    base:desc "General-purpose programming language for detailed implementation"
]

instance Java : DTDFVocab:Enabler [
    base:desc "General-purpose programming language for detailed implementation"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system utilizes Model-Based Systems Engineering (MBSE) with SysML [17] for system modeling across abstraction levels (requirements, functional architecture, logical architecture, product/technical layer). Architecture Description Languages (ADLs) such as ACME [23], AADL [24], MontiArc [25], [26], and SysML IBDs [17], [27] are employed for component-based descriptions, including interfaces and interconnections. Behavior modeling is handled via MontiArc Automaton and SysML state machines, enhanced by tools like MathWorks Simulink [28], simulation methods [29], [30], and general-purpose languages (C++, Java). Methodologies including RFLP [18], [19], OOSEM [20], SPES [21], and SMArDT [22] manage complexity."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security measures include X.509 certificate-based authentication and role-based access control (RBAC) for Asset Administration Shell (AAS) components per Plattform Industrie 4.0 standards, TLS encryption for MQTT communication using Mosquitto server, JWT token authentication and RBAC in Thingsboard IoT platform, and RAMI4.0 security dimension integration for cross-layer cybersecurity protocols."
]