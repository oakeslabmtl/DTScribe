// C3: Physical sensing components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted directly on the motor shaft, providing high‑resolution angular position data for closed‑loop control."
    DTDFVocab:producedData MotorShaftEncoderDataTransmitted
]

instance JointAxisEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder distributed on each robot axis for monitoring joint positions."
    DTDFVocab:producedData JointAxisEncoderDataTransmitted
]

// C4: Physical‑to‑virtual data transmission
instance MotorShaftEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance JointAxisEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointAxisEncoder
]

// C10: Raw data instances
instance MotorShaftPositionData : DTDFVocab:Data [
    base:desc "Raw angular position data received from the motor‑shaft encoder."
    DTDFVocab:fromData MotorShaftEncoderDataTransmitted
    DTDFVocab:inputTo HybridInferenceEngine, DigitalShadowAggregator
]

instance JointAxisPositionData : DTDFVocab:Data [
    base:desc "Raw joint‑axis position data received from the axis encoder."
    DTDFVocab:fromData JointAxisEncoderDataTransmitted
    DTDFVocab:inputTo HybridInferenceEngine, DigitalShadowAggregator
]

// C10: Models (white‑box and black‑box)
instance SimulinkMechanicalDynamicsModel : DTDFVocab:Model [
    base:desc "White‑box Simulink dynamic simulation of the underlying mechanical system."
    DTDFVocab:inputTo HybridInferenceEngine
]

instance FrictionRegressorMLModel : DTDFVocab:Model [
    base:desc "Black‑box machine‑learning regressor that captures nonlinear friction characteristics."
    DTDFVocab:inputTo HybridInferenceEngine
]

// C11: Enablers (processing components)
instance HybridInferenceEngine : DTDFVocab:Enabler [
    base:desc "Processing component that couples the white‑box simulation with the black‑box predictor to perform hybrid inference on incoming sensor traces."
    DTDFVocab:enables InsightGenerationService
]

instance DigitalShadowAggregator : DTDFVocab:Enabler [
    base:desc "Automated component that aggregates and abstracts incoming sensor traces into contextual data traces for the digital shadow (one‑way passive flow)."
    DTDFVocab:enables DigitalShadowService
]

// C6: Services
instance InsightGenerationService : DTDFVocab:Service [
    base:desc "Service that consumes hybrid inference results and produces analytical insights for decision support."
    DTDFVocab:provides FrictionCompensationInsight, JointPositionStatusInsight, AdjustControlParametersAction
]

instance DigitalShadowService : DTDFVocab:Service [
    base:desc "Service that provides insights derived from the aggregated contextual data traces of the digital shadow."
    DTDFVocab:provides ContextualDataTraceInsight
]

// C17: Insights
instance FrictionCompensationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending friction‑compensation parameters based on the ML regressor output."
]

instance JointPositionStatusInsight : DTDFVocab:Insight [
    base:desc "Insight indicating joint position status and detecting possible anomalies from sensor data."
]

instance ContextualDataTraceInsight : DTDFVocab:Insight [
    base:desc "Insight representing aggregated contextual data traces used for higher‑level analysis."
]

// C17: Action
instance AdjustControlParametersAction : DTDFVocab:Action [
    base:desc "Action to adjust closed‑loop control parameters based on the friction‑compensation insight."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the Model‑Based Systems‑Engineering (MBSE) progression described in the documents: starting with a requirements model, proceeding to functional‑architecture models, then logical‑architecture models, and finally to the product/technical layer models that represent the concrete implementation. Each stage is represented with appropriate modeling notations (e.g., SysML requirement diagrams, SysML internal block diagrams, architecture description languages such as ACME, AADL or MontiArc) and transformations between stages are performed by model‑to‑model mappings. Governance of the lifecycle is addressed through the MBSE framework, which coordinates the multiple abstraction levels and ensures traceability across stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through full traceability of each model element to its originating data and to the physical phenomenon it represents. The methodology emphasises verification of model transformations, e.g., confirming the correctness of conversions from SysML specifications to Simulink simulation models. Reliability of the Digital Twin depends on the correctness of underlying models and the data processing chain; therefore, uncertainty sources such as model approximation errors are acknowledged and mitigated by maintaining traceable data traces in the Digital Shadow. Validation is performed by comparing simulated outputs against measured data to detect deviations, supporting corrective actions and quality assurance."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The available documentation mentions the use of the MQTT protocol for streaming sensor data, with Mosquitto cited as a server and client implementation of MQTT. An IoT platform (ThingsBoard) is listed, suggesting that MQTT‑published data may be ingested and visualised via this platform. No further information on network topology, bandwidth, latency, reliability, redundancy, or security mechanisms (e.g., TLS, authentication) is provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The documents align the Digital Twin with established modeling standards: SysML (including internal block diagrams and state machines), UML class diagrams for the reference model, and architecture description languages such as ACME, AADL and MontiArc. Conformance to the Digital‑Shadow Reference Model is expressed as a mapping relation that guarantees that any concrete realization adheres to the reference concepts. No explicit industry certification standards or interoperability protocols are mentioned."
]