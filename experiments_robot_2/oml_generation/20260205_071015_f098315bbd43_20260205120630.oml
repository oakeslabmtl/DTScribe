    base:desc "Derived from aggregated contextual data traces and state machine processing"
]

instance FailurePrediction : DTDFVocab:Insight [
    base:desc "Predictive insights generated through simulation-based analytics"
]

instance AutonomousAction : DTDFVocab:Action [
    base:desc "Autonomous decision-making actions enabled by active DT components"
    DTDFVocab:IsAutomatic "true"
]

instance MBSEFramework : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering (MBSE) methodologies including RFLP, OOSEM, SMArDT for DT alignment"
    DTDFVocab:enables "DigitalShadowDefinition", "StateMachineModel", "SimulationModel"
    base:methodologies "Requirements→Functions→Logics→Physics (RFLP), OOSEM, SMArDT"
]

