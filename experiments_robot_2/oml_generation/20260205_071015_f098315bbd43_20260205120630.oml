instance DigitalShadowDefinition : DTDFVocab:Data [
    base:desc "A set of contextual data traces and their aggregation and abstraction for a specific purpose (e.g., manufacturing monitoring)"
    DTDFVocab:producedData "contextual data traces"
    DTDFVocab:fromData "DigitalShadowDefinition"
]

instance DataInterpreter : DTDFVocab:ActingComponent [
    base:desc "Active software components that interpret and process data from passive digital shadows"
    DTDFVocab:inputTo "DigitalShadowDefinition"
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation tools (MathWorks Simulink) for dynamic analysis of system interactions"
    DTDFVocab:enables "SimulationEngine"
]

instance ContextualDataTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom "DigitalShadowDefinition"
    DTDFVocab:dataType "contextual data traces"
]

instance DigitalShadowModel : DTDFVocab:Model [
    base:desc "Structured UML class diagrams representing heterogeneous data sources for manufacturing contexts"
    DTDFVocab:inputTo "DigitalShadowDefinition"
]

instance StateMachineModel : DTDFVocab:Model [
    base:desc "Behavioral models defined via SysML v1.7 state machines or MontiArc Automata"
    DTDFVocab:inputTo "SimulationEngine"
    DTDFVocab:purpose "critical behavior validation via model checking"
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Dynamic analysis models integrated with MathWorks Simulink for system interaction validation"
    DTDFVocab:inputTo "SimulationEngine"
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring capabilities derived from aggregated data traces"
    DTDFVocab:provides "OperationalInsight"
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics enabled by simulation-driven processing of contextual data"
    DTDFVocab:provides "FailurePrediction"
]

instance AutonomousControlService : DTDFVocab:Service [
    base:desc "Autonomous bidirectional data processing for real-time decision-making"
    DTDFVocab:provides "AutonomousAction"
]

