// C1: Acting Components
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "The motor component of the MABI MAX 100 robot's first vertical axis, providing torque output for motion control"
]

instance GearboxActuator : DTDFVocab:ActingComponent [
    base:desc "The cycloidal gearbox component of the MABI MAX 100 robot's first axis, transmitting mechanical power with friction characteristics"
]

// C2: Physical Sensing Components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted directly on the motor to measure motor position and angular velocity"
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder mounted behind the gearbox to measure gearwheel rotational position and reduce positional uncertainty"
]

instance SiemensCNCController : DTDFVocab:SensingComponent [
    base:desc "Siemens SINUMERIK 840D CNC controller providing access to motor current (I_M) and derived torque (τ_M) via motor constants"
]

// C3: Physical Sensing Component Data Outputs
instance MotorPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearwheelPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SiemensCNCController
]

instance DerivedTorqueData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SiemensCNCController
]

// C4: Physical Data Traces
instance MeasuredMotorPosition : DTDFVocab:Data [
    base:desc "Measured motor position data from the motor encoder, representing the first axis's rotational state"
    DTDFVocab:fromData MotorPositionData
]

instance MeasuredGearwheelPosition : DTDFVocab:Data [
    base:desc "Measured gearwheel position data from the secondary encoder, providing cycloidal gearbox output position"
    DTDFVocab:fromData GearwheelPositionData
]

instance MeasuredMotorCurrent : DTDFVocab:Data [
    base:desc "Measured input current (I_M) from the motor, used for torque calculation via motor constants"
    DTDFVocab:fromData MotorCurrentData
]

instance MeasuredTorque : DTDFVocab:Data [
    base:desc "Derived torque (τ_M) from motor current measurements using known motor constants"
    DTDFVocab:fromData DerivedTorqueData
]

instance MeasuredAngularVelocity : DTDFVocab:Data [
    base:desc "Angular velocity (ω_M) derived from motor encoder readings, representing motor rotational speed"
    DTDFVocab:fromData MotorPositionData
]

// C5: Virtual Data Traces (Simulated)
instance SimulatedMotorTorque : DTDFVocab:Data [
    base:desc "Simulated torque (τ_G) for the motor component in the digital twin model, representing ideal system behavior without friction"
]

instance SimulatedGearwheelTorque : DTDFVocab:Data [
    base:desc "Simulated torque for the gearwheel output in the digital twin model, derived via cycloidal gearbox dynamics"
]

instance SimulatedMotorVelocity : DTDFVocab:Data [
    base:desc "Simulated angular velocity (ω_G) for the motor component in the digital twin model"
]

instance SimulatedGearwheelVelocity : DTDFVocab:Data [
    base:desc "Simulated angular velocity for the gearwheel output in the digital twin model"
]

// C6: Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML modeling tool used for creating structural (Block Definition Diagrams) and behavioral (Internal Block Diagrams) models of the robot's first axis"
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MathWorks MATLAB Simulink used for executable simulation models of friction and system dynamics"
]

instance CustomDashboard : DTDFVocab:Enabler [
    base:desc "Custom visualization dashboard integrating and visualizing data traces (measured vs. simulated) for friction analysis"
]

// C7: Models
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "Structural SysML model describing the first axis as a composition of Motor and Gearbox components (cycloidal gearbox)"
]

instance SysMLBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral SysML model representing the dynamic behavior of the robot's first axis components"
]

instance SimulinkFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model implementing friction models (Coulomb-Viscous, Stribeck, Dahl, LuGre) to simulate friction effects in the gearbox"
]

instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model representing the cycloidal gearbox dynamics and ideal system behavior without friction"
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model for overall system dynamics including friction compensation and motion control"
]

// C8: Services
instance RealTimeFrictionIdentification : DTDFVocab:Service [
    base:desc "Real-time friction identification service combining white-box (analytical) and black-box (data-driven) friction models for dynamic adjustment"
]

instance DynamicModelExchange : DTDFVocab:Service [
    base:desc "Continuous refinement service for exchanging friction models during operation to enable adaptive control algorithms"
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Visualization service integrating and analyzing data traces (measured vs. simulated torque/velocity) for friction analysis"
]

// C9: Insights/Actions
instance FrictionDetectionInsight : DTDFVocab:Insight [
    base:desc "Real-time detection of static, kinetic, and viscous friction in the gearbox to identify friction characteristics and potential wear"
]

instance ModelRefinementAction : DTDFVocab:Action [
    base:desc "Automatic refinement of friction models based on continuous data-driven learning to improve motion accuracy"
    DTDFVocab:IsAutomatic true
]

instance ModelUpdateAction : DTDFVocab:Action [
    base:desc "Dynamic exchange of friction models during operation to continuously improve simulation accuracy"
    DTDFVocab:IsAutomatic true
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Visualization of deviations between measured and simulated data to flag anomalies such as tool changes or wear patterns"
]

// C12: Environment
instance RobotFirstAxisEnvironment : DTDFVocab:Environment [
    base:contains MotorActuator, GearboxActuator, MotorEncoder, GearboxEncoder, SiemensCNCController
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains SysMLStructuralModel, SysMLBehavioralModel,
              SimulinkFrictionModel, SimulinkGearboxModel,
              SimulinkDynamicModel,
              MeasuredMotorPosition, MeasuredGearwheelPosition,
              MeasuredMotorCurrent, MeasuredTorque, MeasuredAngularVelocity,
              SimulatedMotorTorque, SimulatedGearwheelTorque,
              SimulatedMotorVelocity, SimulatedGearwheelVelocity
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twinning time scale operates in **real-time** with:
  - **Operational synchronization** tied to robot control loops, ensuring data consistency with physical system dynamics.
  - **Sub-second latency** for live data processing and friction model updates, though exact frequencies (e.g., ~1 kHz) are not specified. The focus is on **continuous, adaptive friction modeling** during robot operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation consists of:
  - A **centralized digital shadow** for the first axis of the MABI MAX 100 robot, incorporating:
    - **Physical system**: Motor, gearbox, and encoders.
    - **Virtual models**: SysML structural models, Simulink friction models, and AAS for traceability.
    - **Data processing**: Processing components (Simulation M, Simulation GW, Simulation GB) that link measured data to simulated outputs.
  The constellation does not include external DTs or horizontal integrations with other systems."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin operates primarily during the **operational phase** of the robot, specifically for:
  - **As-operated** representation, where friction models are continuously refined based on real-time data.
  The digital shadow is not explicitly tied to design or manufacturing stages, though it supports **continuous improvement** of control algorithms during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
  - **Traceability**: Data traces are linked to their sources (e.g., encoders, simulation models) via **Asset Administration Shells (AAS)** and SysML models, ensuring transparency.
  - **Model validation**: Friction models (Coulomb-Viscous, Stribeck, Dahl, LuGre) are validated against real-time sensor data to account for wear, load, and environmental factors.
  - **Uncertainty handling**: Differences between measured and simulated data are analyzed to infer friction losses, with no explicit mention of formal uncertainty quantification methods in the document."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection between the physical and virtual systems uses:
  - **MQTT protocol** for real-time data streaming from sensors (motor current, angle, torque/velocity).
  - **SysML models** for structural and behavioral representation of the first axis.
  - **MathWorks MATLAB Simulink** for executable simulation models of friction and system dynamics."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin is not explicitly hosted on the robot’s CNC controller. Instead, data is **streamed via MQTT** from the Siemens SINUMERIK 840D sl controller to an external system for processing, simulation, and visualization. The DT infrastructure is separate from the CNC hardware."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin adheres to:
   - **SysML** for structural modeling,
   - **Asset Administration Shells (AAS)** for data linking,
   - **MQTT** for data communication,
   - No explicit mention of ISO/IEC 42010, IIoT-IS, or OASIS standards in the provided documents."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety considerations include:
   - **Safety Cell Constraints**: The robot’s working range is restricted to [-90°, 90°] by the safety cell,
   - **Operational Safety**: The digital shadow is passive (one-way data flow), ensuring no autonomous actions or remote control risks,
   - **No Encrypted MQTT**: Not explicitly mentioned; the focus is on real-time data streaming without specific security protocols."
]