// C2: Acting Components
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "The physical motor actuator component of the MABI MAX 100 industrial robot's first vertical axis, responsible for rotational motion generation"
]

// C3: Physical sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted directly on the motor for measuring motor rotational position"
    DTDFVocab:producedData MotorPositionData
]

instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearbox to measure gearbox output angle, reducing backlash and positional uncertainty"
    DTDFVocab:producedData GearboxOutputAngleData
]

instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor streaming input current (I_M) measurements via MQTT protocol"
    DTDFVocab:producedData InputCurrentData
]

// C4: Physical-to-virtual interaction
instance MotorPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxOutputAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoder
]

instance InputCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
]

instance DerivedTorqueData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionData, GearboxOutputAngleData
]

instance DerivedAngularVelocityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionData
]

// C10: Models/Data
instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "SysML Block Definition Diagram describing the robot's structural components (motor, gearboxes) and architecture"
]

instance SysMLBehaviorModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram describing the robot's behavior and flow definitions for rotational and current energy"
]

instance IdealBehaviorSimulation : DTDFVocab:Model [
    base:desc "MathWorks MATLAB Simulink model simulating ideal behavior of the robot's first axis without friction"
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "MathWorks MATLAB Simulink model simulating Coulomb and viscous friction behaviors in the gearbox"
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "MathWorks MATLAB Simulink model simulating Stribeck friction behavior in the gearbox"
]

instance SimulationM : DTDFVocab:Model [
    base:desc "Simulation model processing input data traces to generate virtual outputs for motor behavior analysis"
]

instance SimulationGW : DTDFVocab:Model [
    base:desc "Simulation model processing gearbox-specific data traces to generate virtual outputs"
]

instance SimulationGB : DTDFVocab:Model [
    base:desc "Simulation model processing combined data traces for gearbox behavior analysis"
]

instance MeasuredInputCurrentData : DTDFVocab:Data [
    base:desc "Measured input current (I_M) data stream from physical sensors"
    DTDFVocab:fromData InputCurrentData
]

instance MeasuredOutputAngleData : DTDFVocab:Data [
    base:desc "Measured output angle data from secondary encoder, reducing positional uncertainty"
    DTDFVocab:fromData GearboxOutputAngleData
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering (MBSE) using SysML for structural and behavioral modeling of the robot's first axis components"
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks MATLAB Simulink platform for executable simulation models of friction behaviors in the gearbox"
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Data processing simulation models (Simulation M, Simulation GW, Simulation GB) for generating virtual outputs from input data traces"
]

instance MQTTExtension : DTDFVocab:Enabler [
    base:desc "MQTT protocol extension for live sensor data streaming (motor current I_M, output angle measurements)"
]

// C6: Services
instance StructuralModelingService : DTDFVocab:Service [
    base:desc "Service providing SysML structural modeling of the robot's motor, gearboxes, and cycloidal gear components"
]

instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Service providing SysML behavioral modeling of rotational and current energy flow definitions"
]

instance FrictionSimulationService : DTDFVocab:Service [
    base:desc "Service providing executable simulation models (Coulomb-Viscous, Stribeck) for friction behavior analysis"
]

instance DataStreamingService : DTDFVocab:Service [
    base:desc "Service handling live sensor data streaming via MQTT protocol (input current I_M, output angle)"
]

instance DataProcessingService : DTDFVocab:Service [
    base:desc "Service processing simulation models (Simulation M, Simulation GW, Simulation GB) to generate virtual outputs"
]

// C17: Insights/Actions
instance FrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Understanding static, kinetic, and viscous friction in the gearbox to improve motion control accuracy"
]

instance ControlAccuracyImprovementInsight : DTDFVocab:Insight [
    base:desc "Dynamic adjustment of white-box and black-box models to reduce motion inaccuracies in the robot's first axis"
]

instance RealTimeFrictionIdentification : DTDFVocab:Action [
    base:desc "Real-time identification of friction characteristics using both white-box (analytical) and black-box (data-driven) models"
    DTDFVocab:IsAutomatic true
]

instance MotionControlImprovementAction : DTDFVocab:Action [
    base:desc "Continuous refinement of friction models during operation to adapt to changes in wear, tools, or applications"
    DTDFVocab:IsAutomatic true
]

instance FrictionModelValidation : DTDFVocab:Action [
    base:desc "Validation of friction models against real-world measurements to ensure accuracy"
    DTDFVocab:IsAutomatic true
]

instance MotionAccuracyAdjustment : DTDFVocab:Action [
    base:desc "Dynamic adjustment of control parameters to maintain motion accuracy despite friction variations"
    DTDFVocab:IsAutomatic true
]

instance WearMonitoring : DTDFVocab:Action [
    base:desc "Continuous monitoring of gearbox wear through friction model adaptation and data analysis"
    DTDFVocab:IsAutomatic true
]

instance DataConsistencyValidation : DTDFVocab:Action [
    base:desc "Validation of sensor data consistency to ensure reliable digital twin operation"
    DTDFVocab:IsAutomatic true
]

instance DerivedParameterGeneration : DTDFVocab:Action [
    base:desc "Generation of derived parameters (torque, angular velocity) from raw sensor data for analysis"
    DTDFVocab:IsAutomatic true
]

instance OutputValidation : DTDFVocab:Action [
    base:desc "Validation of simulation model outputs against physical measurements for accuracy verification"
    DTDFVocab:IsAutomatic true
]

instance LiveDataAvailability : DTDFVocab:Action [
    base:desc "Ensuring continuous availability of live sensor data streams for digital twin operation"
    DTDFVocab:IsAutomatic true
]

instance StructuralUnderstandingInsight : DTDFVocab:Insight [
    base:desc "Comprehensive understanding of the robot's structural components (motor, gearboxes) through SysML modeling"
]

instance ComprehensiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of all physical relationships and data flows in the robot's first axis digital twin"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Not explicitly detailed in the documents, but inferred to be conceptualized as:
  - **Data-driven friction models** (white-box and black-box) dynamically updated with live data to improve robot control accuracy.
  - **Simulation models** (Simulink) generating virtual outputs (torque, angular velocity) for comparison with measured data."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital shadow operates in **real-time** with:
  - **Live data streaming** (e.g., sensor data via MQTT) for immediate processing and comparison with simulated data.
  - **Continuous identification and refinement** of friction models during operation, enabling adaptive control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin constellation is **focused on the first axis** of the MABI MAX 100 industrial robot, with:
  - A **centralized digital shadow** integrating structural and behavioral models, live data, and visualization.
  - **Asset Administration Shell (AAS)** for linking data and models to ensure traceability and semantic support."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow operates primarily during the **operated phase** of the robot’s lifecycle, focusing on:
  - **As-operated** representation (real-time data and live measurements).
  - **Continuous improvement** of motion control accuracy during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The fidelity and validity considerations include:
  - **Uncertainty in friction modeling**: Friction depends on load, temperature, and wear, which may not be fully captured in analytical models.
  - **Data-driven validation**: Continuous comparison of measured vs. simulated data to validate model accuracy.
  - **Verification/Validation**: Real-time processing and dashboard visualization for operational insights."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection uses:
  - **MQTT protocol** for live sensor data streaming.
  - **SysML and Simulink integration** for model-based simulation and data processing."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Not explicitly detailed; the digital shadow is deployed on the robot’s local network (implied by MQTT streaming and dashboard integration). Hosting details (e.g., server infrastructure, cloud deployment) are not specified in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not explicitly detailed; the digital twin is focused on the robot’s first axis and its controller (SINUMERIK 840D sl). Potential future integration with external systems (e.g., other DTs, ERP systems) is not addressed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The documents reference:
  - **SysML** for modeling (standardized for MBSE).
  - **MQTT** for data communication (standardized IoT protocol).
  - **Asset Administration Shell (AAS)** for linking digital and physical assets (industry-standard for Industry 4.0)."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Not explicitly addressed in the digital twin; however, the physical safety cell of the robot (restricting ±90° angular range) is a physical safety feature. The digital twin itself does not handle remote operations or safety-critical commands (e.g., emergency stops)."
]