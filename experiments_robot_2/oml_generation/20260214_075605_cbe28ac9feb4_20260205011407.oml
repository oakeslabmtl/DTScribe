instance SysMLIBDs : DTDFVocab:Model [
    base:desc "Structural model using SysML Internal Block Diagrams"
    DTDFVocab:inputTo SysMLEnabler
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "Structural model using ACME architecture description language"
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "Structural model using Architecture Analysis & Design Language"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "Behavioral model using MontiArc Automaton"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLStateMachinesModel : DTDFVocab:Model [
    base:desc "Behavioral model using SysML v1.7 state machines"
    DTDFVocab:inputTo SysMLStateMachineEnabler
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "Analytical model using MathWorks Simulink"
    DTDFVocab:inputTo SimulinkEnabler
]

instance CppCodeModel : DTDFVocab:Model [
    base:desc "Analytical model using C++ code"
    DTDFVocab:inputTo CppEnabler
]

instance JavaCodeModel : DTDFVocab:Model [
    base:desc "Analytical model using Java code"
    DTDFVocab:inputTo JavaEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based tool for component & connector modeling"
    DTDFVocab:enables ModelingService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME architecture description language tool"
    DTDFVocab:enables ModelingService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL tool for component modeling"
    DTDFVocab:enables ModelingService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton tool for behavior modeling"
    DTDFVocab:enables BehaviorService
]

instance SysMLStateMachineEnabler : DTDFVocab:Enabler [
    base:desc "SysML state machine tool for behavior modeling"
    DTDFVocab:enables BehaviorService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation tool"
    DTDFVocab:enables SimulationService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for code integration"
    DTDFVocab:enables CodeExecutionService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for code integration"
    DTDFVocab:enables CodeExecutionService
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements, Functions, Logics, Physics) MBSE methodology"
    DTDFVocab:enables SystemDesignService
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for system modeling"
    DTDFVocab:enables SystemDesignService
]

instance SPES : DTDFVocab:Enabler [
    base:desc "SPES methodology for system engineering"
    DTDFVocab:enables SystemDesignService
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for multi-level abstraction modeling"
    DTDFVocab:enables SystemDesignService
]

instance ModelingService : DTDFVocab:Service [
    base:desc "Service for system architecture modeling using ADLs"
    DTDFVocab:provides SystemAnalysisInsight
]

instance SystemDesignService : DTDFVocab:Service [
    base:desc "Service for system design using MBSE methodologies"
    DTDFVocab:provides DesignInsight
]

instance BehaviorService : DTDFVocab:Service [
    base:desc "Service for behavior modeling and simulation"
    DTDFVocab:provides BehaviorInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for executing simulation models"
    DTDFVocab:provides SimulationInsight
]

instance CodeExecutionService : DTDFVocab:Service [
    base:desc "Service for executing code-based analytical models"
    DTDFVocab:provides CodeInsight
]

instance SystemAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight derived from system architecture model analysis"
]

instance DesignInsight : DTDFVocab:Insight [
    base:desc "Insight derived from system design processes"
]

instance BehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight from behavioral model analysis"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from simulation results"
]

instance CodeInsight : DTDFVocab:Insight [
    base:desc "Insight derived from code execution"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adheres to industry standards including SysML [17], ACME [23], AADL [24], MontiArc [25], [26], and MathWorks Simulink [28] for modeling, architecture description, and simulation, ensuring interoperability and compliance with specified protocols."
]