// C3: Physical sensing components
instance MotorSideEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on motor-side measuring joint angle"
    DTDFVocab:producedData JointAngleDataMotorSide
]

instance GearwheelSideEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on gearwheel-side measuring joint angle"
    DTDFVocab:producedData JointAngleDataGearwheel
]

instance MotorInputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring input current I_M for motor torque estimation"
    DTDFVocab:producedData CurrentSensorData
]

instance MotorTorqueEstimator : DTDFVocab:SensingComponent [
    base:desc "Estimator converting input current and motor constants to motor torque, data streamed via MQTT"
    DTDFVocab:producedData CurrentDerivedTorqueData
]

// C4: Data transmitted
instance JointAngleDataMotorSide : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSideEncoder
]

instance JointAngleDataGearwheel : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearwheelSideEncoder
]

instance CurrentSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorInputCurrentSensor
]

instance CurrentDerivedTorqueData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorTorqueEstimator
]

// C4: Data (from transmitted)
instance MotorSideJointAngleData : DTDFVocab:Data [
    base:desc "Joint angle measurement from motor-side encoder, streamed via MQTT"
    DTDFVocab:fromData JointAngleDataMotorSide
    DTDFVocab:inputTo ComparisonProcessingEnabler
]

instance GearwheelJointAngleData : DTDFVocab:Data [
    base:desc "Joint angle measurement from gearwheel-side encoder, streamed via MQTT"
    DTDFVocab:fromData JointAngleDataGearwheel
    DTDFVocab:inputTo ComparisonProcessingEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Input current I_M measurement from current sensor, streamed via MQTT"
    DTDFVocab:fromData CurrentSensorData
    DTDFVocab:inputTo ComparisonProcessingEnabler
]

instance MotorTorqueData : DTDFVocab:Data [
    base:desc "Estimated motor torque derived from current sensor, streamed via MQTT"
    DTDFVocab:fromData CurrentDerivedTorqueData
    DTDFVocab:inputTo ComparisonProcessingEnabler
]

// C10: Models
instance AxisStructuralSysMLModel : DTDFVocab:Model [
    base:desc "SysML structural model of serial industrial robot MABI MAX 100 first axis"
    DTDFVocab:inputTo SimulationProcessorEnabler
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "White‑box Coulomb‑viscous friction model for motor‑gearbox dynamics"
    DTDFVocab:inputTo SimulationProcessorEnabler
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "White‑box Stribeck friction model for smoother torque estimation"
    DTDFVocab:inputTo SimulationProcessorEnabler
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "White‑box Dahl friction model for dynamic friction effects"
    DTDFVocab:inputTo SimulationProcessorEnabler
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "White‑box LuGre friction model capturing micro‑slip"
    DTDFVocab:inputTo SimulationProcessorEnabler
]

instance FrictionDataDrivenModel : DTDFVocab:Model [
    base:desc "Black‑box data‑driven friction model trained on measured signals"
    DTDFVocab:inputTo SimulationProcessorEnabler
]

instance SimulinkSystemModel : DTDFVocab:Model [
    base:desc "MATLAB‑Simulink executable model integrating motor, gearbox, and friction models"
    DTDFVocab:inputTo SimulationProcessorEnabler
]

// C4: Data for simulation outputs
instance SimulatedTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    // simulated data produced by simulation processor
]

instance SimulatedTorqueData : DTDFVocab:Data [
    base:desc "Simulated motor torque from Simulink model"
    DTDFVocab:fromData SimulatedTorqueDataTransmitted
    DTDFVocab:inputTo ComparisonProcessingEnabler
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker for realtime sensor data streaming"
    DTDFVocab:enables MQTTDataAcquisitionService
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling platform for structural and behavioral models"
    DTDFVocab:enables StructuralModelService
]

instance SimulationProcessorEnabler : DTDFVocab:Enabler [
    base:desc "Enabler coordinating simulation models to produce simulated outputs"
    DTDFVocab:enables SimulationExecutionService
]

instance ComparisonProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Allows comparison of simulated and measured signals"
    DTDFVocab:enables SimulationComparisonService, FrictionIdentificationService, JointWearDiagnosticsService, MotionAccuracyService
]

// C11: Service instances
instance MQTTDataAcquisitionService : DTDFVocab:Service [
    base:desc "Service for acquiring data from sensors via MQTT"
]

instance StructuralModelService : DTDFVocab:Service [
    base:desc "Service exposing SysML structural models"
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service performing Simulink simulation of the system"
]

instance SimulationComparisonService : DTDFVocab:Service [
    base:desc "Service comparing simulated and measured signals for analysis"
    DTDFVocab:provides SignalComparisonInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service identifying friction parameters from continuous data"
    DTDFVocab:provides FrictionParameterUpdateInsight
]

instance JointWearDiagnosticsService : DTDFVocab:Service [
    base:desc "Service diagnosing joint wear based on sensor data"
    DTDFVocab:provides JointWearDiagnosticsInsight
]

instance MotionAccuracyService : DTDFVocab:Service [
    base:desc "Service improving motion accuracy for machining tasks"
    DTDFVocab:provides MotionAccuracyImprovementInsight
]

// C6: Insights
instance FrictionParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Updated friction parameters derived from continuous identification"
]

instance MotorTorqueAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Recommendations for motor torque adjustments"
]

instance JointWearDiagnosticsInsight : DTDFVocab:Insight [
    base:desc "Diagnostics on joint wear"
]

instance MotionAccuracyImprovementInsight : DTDFVocab:Insight [
    base:desc "Improved motion accuracy for machining tasks"
]

instance SignalComparisonInsight : DTDFVocab:Insight [
    base:desc "Comparison of simulated and measured signals"
]

// C6: Actions
instance UpdateMotorTorqueAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of motor torque based on friction parameter updates"
    DTDFVocab:IsAutomatic true
]

instance DynamicModelSwitchAction : DTDFVocab:Action [
    base:desc "Dynamic switching of friction models during operation"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time, continuous data exchange with sampling rates sufficient to capture robot dynamics (up to the actuator bandwidth of ~75°/s); simulation models run in parallel and are synchronized with measurement data"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central Digital Shadow consisting of a processing component that consumes sensor traces, applies engineering, simulation, and data‑driven models to generate simulated outputs; a set of data traces (reference and simulated) linked via AAS; a visualization dashboard; and the physical robot as the source."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Shadow is instantiated during operation (operated stage), built upon design‑time engineering models (as designed), and enriched with measurement data from the manufactured robot; it thus spans the design → manufacture → operation lifecycle phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "White‑box analytical models capture physical friction physics; black‑box data‑driven models bypass parameter identification; both are validated against live measurement data in real time; traceability ensures each data point’s provenance; uncertainty from wear, temperature, load is mitigated by continuous reidentification; simulation fidelity is limited by simplifications of gear geometry but sufficient for comparative analysis."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "One‑way data flow from PT to DT via MQTT broker; the Digital Shadow receives serialized sensor data (current, position) and sends processed data to the dashboard; no direct bidirectional control channel is described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for modeling (ISO/IEC 15929), Asset Administration Shells (IEC 62832/IEC 62196) as part of Industry 4.0 standards; reference to Digital Shadow Reference Model; adherence to MBSE practices (RFLP, SPES)."
]