// Physical sensing component
instance TelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Software components that interpret incoming telemetry."
    DTDFVocab:producedData TelemetryDataTransmitted
]

// Physical-to-virtual interaction
instance TelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TelemetrySensor
]

// Data entity
instance TelemetryData : DTDFVocab:Data [
    base:desc "Data gathered from incoming telemetry, processed for simulation and analysis."
    DTDFVocab:fromData TelemetryDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, MontiArcEnabler
]

// Models
instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulink model for real‑time simulation of the system."
    DTDFVocab:inputTo SimulinkEnabler
]
instance MontiArcBehaviorModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model defining the system behavior."
    DTDFVocab:inputTo MontiArcEnabler
]
instance SysMLArchitectureModel : DTDFVocab:Model [
    base:desc "SysML v1.7 component diagram capturing functional and logical architecture."
    DTDFVocab:inputTo SysMLv1_7Enabler
]
instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram for interface specification."
    DTDFVocab:inputTo SysMLIBDEnabler
]
instance CodeGenModel : DTDFVocab:Model [
    base:desc "Model configuration for generating C++ and Java code."
    DTDFVocab:inputTo CodeGenerationEnabler
]
instance VersionControlModel : DTDFVocab:Model [
    base:desc "Metadata model for Git‑based MBSE version control."
    DTDFVocab:inputTo VersionControlEnabler
]

// Enablers
instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for executing Simulink models."
    DTDFVocab:enables SimulationService
]
instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavior definition."
    DTDFVocab:enables BehaviorExecutionService
]
instance SysMLv1_7Enabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 for architectural modeling."
    DTDFVocab:enables ModelCheckingService
]
instance SysMLIBDEnabler : DTDFVocab:Enabler [
    base:desc "SysML IBDs for interface specification."
    DTDFVocab:enables InterfaceDefinitionService
]
instance CodeGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Code generation to C++ and Java from models."
    DTDFVocab:enables CodeGenerationService
]
instance VersionControlEnabler : DTDFVocab:Enabler [
    base:desc "Git for MBSE version control."
    DTDFVocab:enables VersioningService
]

// Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates models using MathWorks Simulink."
    DTDFVocab:provides SimulationOutcomeInsight, RunSimulationAction
]
instance BehaviorExecutionService : DTDFVocab:Service [
    base:desc "Executes MontiArc automata."
    DTDFVocab:provides BehaviorExecutionResultInsight, ExecuteBehaviorAction
]
instance ModelCheckingService : DTDFVocab:Service [
    base:desc "Performs model checking of SysML models."
    DTDFVocab:provides ModelValidityInsight, RunModelCheckAction
]
instance InterfaceDefinitionService : DTDFVocab:Service [
    base:desc "Provides interface specifications from SysML IBDs."
    DTDFVocab:provides InterfaceDefinitionInsight, GenerateInterfaceDefinitionAction
]
instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Generates C++ and Java code from models."
    DTDFVocab:provides GeneratedCodeInsight, GenerateCodeAction
]
instance VersioningService : DTDFVocab:Service [
    base:desc "Manages model versioning via Git."
    DTDFVocab:provides VersioningStatusInsight, VersionUpdateAction
]

// Insights
instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Results of the simulation run, including performance metrics."
]
instance BehaviorExecutionResultInsight : DTDFVocab:Insight [
    base:desc "Outcome of behavior execution from MontiArc automata."
]
instance ModelValidityInsight : DTDFVocab:Insight [
    base:desc "Validity assessment of SysML models after model checking."
]
instance InterfaceDefinitionInsight : DTDFVocab:Insight [
    base:desc "Interface specifications derived from SysML IBDs."
]
instance GeneratedCodeInsight : DTDFVocab:Insight [
    base:desc "Generated C++ and Java code artifacts."
]
instance VersioningStatusInsight : DTDFVocab:Insight [
    base:desc "Current repository status and version lineage."
]

// Actions
instance RunSimulationAction : DTDFVocab:Action [
    base:desc "Command to run the simulation with current model parameters."
    DTDFVocab:IsAutomatic true
]
instance ExecuteBehaviorAction : DTDFVocab:Action [
    base:desc "Trigger execution of behavior model."
    DTDFVocab:IsAutomatic false
]
instance RunModelCheckAction : DTDFVocab:Action [
    base:desc "Initiate model checking of SysML architecture."
    DTDFVocab:IsAutomatic false
]
instance GenerateInterfaceDefinitionAction : DTDFVocab:Action [
    base:desc "Generate interface definition files."
    DTDFVocab:IsAutomatic true
]
instance GenerateCodeAction : DTDFVocab:Action [
    base:desc "Generate code from model configuration."
    DTDFVocab:IsAutomatic true
]
instance VersionUpdateAction : DTDFVocab:Action [
    base:desc "Commit and push changes to Git repository."
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellation orchestrates the system’s architectural description across multiple modeling languages and simulation tools within a central MBSE framework.  Component and connector aspects are encoded using architecture description languages such as ACME or AADL, while SysML Interaction Block Diagrams (IBDs) capture functional and logical interactions.  Behavioral detail is embodied either in MontiArc Automata or in SysML v1.7 state machines, and simulation models are integrated via MathWorks Simulink or equivalent tools, allowing the tight coupling of discrete‑time heterogeneous models.  This multi‑notation, component‑centric orchestration provides coordinated resource management by linking the static structural model with its dynamic simulation counterpart, thereby sustaining a coherent end‑to‑end Digital Twin representation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle is delineated by successive abstraction levels: 1) Requirements capturing the functional intent and performance criteria; 2) Functional architecture that defines capabilities and interfaces; 3) Logical architecture that specifies component behaviours and interaction patterns; 4) Product or technical layer that models concrete implementation details and material properties. Transitions between stages are managed via model transformations and conformance checks in SysML specification diagrams (e.g., internal block diagrams, state machine diagrams). Lifecycle governance is achieved through Model‑Based Systems Engineering (MBSE) practices that enforce traceability and versioning across these layers."
]