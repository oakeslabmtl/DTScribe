// ************************************
//  Enablers
// ************************************
instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "Simulink (MATLAB) simulation platform used for component dynamics, gearboxes, and friction modeling."
    DTDFVocab:enables SimulationService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker used to transmit real‑time sensor data streams from PLC to the digital twin."
    DTDFVocab:enables DataTransmissionService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Enables ontology‑based linking and traceability of data traces via the Asset Administration Shell."
    DTDFVocab:enables DataLinkingService
]

instance WebDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard application used to visualise measured and simulated data traces in real‑time."
    DTDFVocab:enables DataVisualizationService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that consumes sensor data streams and produces friction model predictions."
    DTDFVocab:enables SimulationService
]

// ************************************
//  Services
// ************************************
instance SimulationService : DTDFVocab:Service [
    base:desc "Runs continuous simulation of motor, gearboxes, and friction models to refine parameters and provide insights."
    DTDFVocab:provides FrictionLossDetectionInsight, FrictionModelParameterUpdateInsight, MotionControlAccuracyInsight, DataExportAction
]

instance DataTransmissionService : DTDFVocab:Service [
    base:desc "Publishes real‑time sensor data streams from PLC to the digital shadow via MQTT."
    DTDFVocab:provides DataLinkingAction
]

instance DataLinkingService : DTDFVocab:Service [
    base:desc "Enables linkage and traceability between virtual and physical data via Asset Administration Shell."
    DTDFVocab:provides DataLinkingInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Visualises measured and simulated data traces on a web‑based dashboard."
    DTDFVocab:provides VisualizedDataInsight
]

// ************************************
//  Insights
// ************************************
instance FrictionLossDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight on friction loss in the first axis derived from comparison of measured and simulated data."
]

instance FrictionModelParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight indicating needed updates to friction model parameters for improved accuracy."
]

instance MotionControlAccuracyInsight : DTDFVocab:Insight [
    base:desc "Insight on motion control accuracy after model refinement."
]

instance MaintenanceSchedulingInsight : DTDFVocab:Insight [
    base:desc "Insight for maintenance scheduling based on wear and friction analysis."
]

instance ToolWearMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight facilitating monitoring of tool wear during operation."
]

instance DataLinkingInsight : DTDFVocab:Insight [
    base:desc "Insight confirming data traces have been linked to corresponding Asset Administration Shell entities."
]

instance VisualizedDataInsight : DTDFVocab:Insight [
    base:desc "Insight ensuring data traces are visualised correctly on the dashboard."
]

// ************************************
//  Actions
// ************************************
instance MaintenanceSchedulingAction : DTDFVocab:Action [
    base:desc "Automated action to schedule maintenance based on friction and wear analysis."
    DTDFVocab:IsAutomatic true
]

instance ToolWearMonitoringAction : DTDFVocab:Action [
    base:desc "Automated action to monitor tool wear in real‑time."
    DTDFVocab:IsAutomatic true
]

instance DataExportAction : DTDFVocab:Action [
    base:desc "Action to export processed data traces for further offline analysis."
    DTDFVocab:IsAutomatic false
]

instance UpdateFrictionModelAction : DTDFVocab:Action [
    base:desc "Action to update friction model parameters within the simulation."
    DTDFVocab:IsAutomatic false
]

instance DataLinkingAction : DTDFVocab:Action [
    base:desc "Automated action to link transmitted data streams to Asset Administration Shell entities."
    DTDFVocab:IsAutomatic true
]

// ************************************
//  Components
// ************************************
instance MABI100FirstAxis : DTDFVocab:Component [
    base:desc "First axis of the MABI 100 industrial robot."
]

instance PermanentMagnetSynchronousMotor : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor powering the first axis."
]

instance GearwheelGearbox : DTDFVocab:Component [
    base:desc "Gearwheel gearbox used to transmit motor torque to the cycloidal gearbox."
]

instance CycloidalGearbox : DTDFVocab:Component [
    base:desc "Cycloidal gearbox providing the final drive to the output shaft."
]

instance DualPositionEncoders : DTDFVocab:Component [
    base:desc "Dual position encoders located on the motor and gearbox for precise angle measurement."
]

// ************************************
//  Sensors (Sensing Components)
// ************************************
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor mounted on the permanent‑magnet synchronous motor measuring I_M."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder measuring rotor angle."
    DTDFVocab:producedData RotorAngleDataTransmitted
]

instance GearboxSecondaryEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearbox capturing gearbox rotation."
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Output angle sensor transmitting shaft angle via MQTT."
    DTDFVocab:producedData OutputAngleDataTransmitted
]

instance TorqueDataProcessingSensor : DTDFVocab:SensingComponent [
    base:desc "Processing component that derives torque from measured current and encoder data."
    DTDFVocab:producedData TorqueDataTransmitted
]

instance AngularVelocityDataProcessingSensor : DTDFVocab:SensingComponent [
    base:desc "Processing component that derives angular velocity from encoder data."
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

instance AccelerationDataProcessingSensor : DTDFVocab:SensingComponent [
    base:desc "Processing component that derives angular acceleration from encoder data."
    DTDFVocab:producedData AccelerationDataTransmitted
]

// ************************************
//  Data Transmitted
// ************************************
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance RotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxSecondaryEncoderSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueDataProcessingSensor
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocityDataProcessingSensor
]

instance AccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AccelerationDataProcessingSensor
]

// ************************************
//  Data (Processed Traces)
// ************************************
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured current of the motor (I_M)."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance RotorAngleData : DTDFVocab:Data [
    base:desc "Measured rotor angle from the motor encoder."
    DTDFVocab:fromData RotorAngleDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Measured gearbox angle from the secondary encoder."
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Measured output shaft angle from the output encoder."
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque calculated from motor current and encoder data."
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity calculated from encoder data."
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration calculated from encoder data."
    DTDFVocab:fromData AccelerationDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

// ************************************
//  Models
// ************************************
instance EngineeringStructuralModel : DTDFVocab:Model [
    base:desc "Engineering structural model of the first axis, comprising motor, gearboxes, and encoders."
    DTDFVocab:inputTo SimulinkTool
]

instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model representing the permanent‑magnet synchronous motor dynamics."
    DTDFVocab:inputTo SimulinkTool
]

instance GearwheelSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model representing the gearwheel gearbox dynamics."
    DTDFVocab:inputTo SimulinkTool
]

instance CycloidalGearboxSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model representing the cycloidal gearbox dynamics."
    DTDFVocab:inputTo SimulinkTool
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Stribeck friction model used for white‑box friction representation."
    DTDFVocab:inputTo SimulinkTool
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Coulomb‑viscous friction model used for basic friction representation."
    DTDFVocab:inputTo SimulinkTool
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Dahl friction model used for dynamic friction representation."
    DTDFVocab:inputTo SimulinkTool
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "LuGre friction model used for advanced dynamic friction representation."
    DTDFVocab:inputTo SimulinkTool
]

// ************************************
//  Environment
// ************************************
instance RobotFirstAxisEnvironment : DTDFVocab:Environment [
    base:contains MABI100FirstAxis, PermanentMagnetSynchronousMotor, GearwheelGearbox, CycloidalGearbox, DualPositionEncoders
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous data acquisition and processing at every control cycle (real‑time); dynamic substitution of friction models during operation, enabling near‑instantaneous updates to the robot controller."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central digital shadow comprising an engineering model of the axis, a processing component executing simulation and data‑calculation models, multiple data traces (measured and simulated), and an AAS for seamless integration; all orchestrated to provide real‑time insight into friction behavior of the first axis."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design stage: engineering structural model of the axis in SysML; manufacturing stage: physical asset data captured by sensors; operational stage: live data streams and dynamic friction model updates during normal robot operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation by comparing simulated outputs against measured data traces; traceability of every data point to its originating processing component and model; uncertainty handled via continuous parameter identification of white‑box and black‑box friction models; model fidelity increased by including temperature, load, and time dependencies."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "One‑way data flow from the physical robot to the digital shadow via MQTT messages; Asset Administration Shells providing semantic metadata; no direct output from the shadow to the robot (passive)."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML (UML) for modeling; AAS (ISO/IEC 42042) for digital asset representation; UML class diagram for reference model; adherence to MBSE methodologies (RFLP, SPES, SMArDT) implied."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Digital shadow is passive, eliminating risk of unsafe remote actuation; data transmission over MQTT may be secured via TLS if configured; no safety controls required on physical system; compliance with industrial safety standards assumed but not specified."
]