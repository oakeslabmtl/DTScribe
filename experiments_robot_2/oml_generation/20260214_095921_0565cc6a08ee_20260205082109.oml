// C3: Physical Sensing Components
instance ContextualDataCollector : DTDFVocab:SensingComponent [
    base:desc "Collects contextual data traces from physical systems including sensor readings, operational logs, and environmental metrics. Supports both structured (time-series sensor data, discrete event logs) and unstructured (multimedia logs) data formats."
    DTDFVocab:producedData PhysicalContextualDataStream
]

instance PhysicalSystemSensor : DTDFVocab:SensingComponent [
    base:desc "Automated sensor system capturing real-time operational parameters from the physical system for digital twin synchronization."
    DTDFVocab:producedData PhysicalSystemDataStream
]

// C4: Physical-to-Virtual Interaction
instance PhysicalContextualDataStream : DTDFVocab:DataTransmitted [
    base:desc "One-way automated data flow from physical object to digital representation containing aggregated contextual traces. Includes preprocessing steps like filtering and normalization."
    DTDFVocab:producedFrom ContextualDataCollector
]

instance PhysicalSystemDataStream : DTDFVocab:DataTransmitted [
    base:desc "Real-time or near-real-time data transmission from physical system sensors to digital twin framework. Passive flow without autonomous feedback to physical system."
    DTDFVocab:producedFrom PhysicalSystemSensor
]

// C10: Models/Data
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML-based structural model describing system components, interfaces, and composition hierarchies using Internal Block Diagrams (IBDs). Supports multi-layer abstraction from requirements to product/technical layers."
    DTDFVocab:inputTo SysMLModelingTool
]

instance SysMLBehavioralModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model for behavioral description and MontiArc Automaton extensions for complex system dynamics."
    DTDFVocab:inputTo SysMLModelingTool, MontiArcFramework
]

instance SimulationBehaviorModel : DTDFVocab:Model [
    base:desc "Detailed simulation model using MathWorks Simulink or equivalent tools for system behavior analysis and validation."
    DTDFVocab:inputTo SimulationTool
]

instance AggregatedContextualData : DTDFVocab:Data [
    base:desc "Processed contextual data traces collected from physical system, abstracted and stored for analytical purposes. Includes filtered and normalized sensor data."
    DTDFVocab:fromData PhysicalContextualDataStream
    DTDFVocab:inputTo DataIntegrationMiddleware
]

instance PhysicalSystemStateData : DTDFVocab:Data [
    base:desc "Real-time operational state data from physical system sensors, synchronized with digital twin representation."
    DTDFVocab:fromData PhysicalSystemDataStream
    DTDFVocab:inputTo DataIntegrationMiddleware
]

// C11: Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML implementation tool supporting Internal Block Diagrams (IBDs) and state machines for structural and behavioral modeling across multiple abstraction layers."
    DTDFVocab:enables SystemArchitectureService, BehavioralAnalysisService
]

instance MontiArcFramework : DTDFVocab:Enabler [
    base:desc "Architecture Description Language (ADL) framework supporting component-connector modeling with integrated automaton-based behavior description."
    DTDFVocab:enables SystemArchitectureService, ControlLogicService
]

instance SimulationTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink or equivalent simulation platform for detailed system behavior modeling and validation."
    DTDFVocab:enables SimulationValidationService, ControlLogicService
]

instance DataIntegrationMiddleware : DTDFVocab:Enabler [
    base:desc "Middleware solution for aggregating and aligning heterogeneous data sources from physical system with digital twin modeling framework."
    DTDFVocab:enables DataMonitoringService, SystemStateSynchronizationService
]

instance GeneralPurposeProgramming : DTDFVocab:Enabler [
    base:desc "C++/Java implementation environment for custom logic, control algorithms, and system-specific extensions."
    DTDFVocab:enables ControlLogicService, CustomAlgorithmService
]

// C6: Services
instance SystemArchitectureService : DTDFVocab:Service [
    base:desc "Service managing system architecture description using SysML IBDs and ADLs, ensuring component interface consistency across stakeholders."
    DTDFVocab:provides SystemArchitectureInsight
]

instance BehavioralAnalysisService : DTDFVocab:Service [
    base:desc "Service analyzing system behavior through state machines and simulation models to identify dynamic patterns."
    DTDFVocab:provides BehavioralPatternInsight
]

instance SimulationValidationService : DTDFVocab:Service [
    base:desc "Service validating system behavior through simulation models against physical system performance metrics."
    DTDFVocab:provides SimulationValidationInsight
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring real-time data streams from physical system and contextual data traces for anomaly detection."
    DTDFVocab:provides DataAnomalyInsight
]

instance SystemStateSynchronizationService : DTDFVocab:Service [
    base:desc "Service maintaining synchronization between physical system state and digital twin representation through data integration."
    DTDFVocab:provides SynchronizationStatusInsight
]

instance ControlLogicService : DTDFVocab:Service [
    base:desc "Service implementing control logic through simulation tools and general-purpose programming for system optimization."
    DTDFVocab:provides ControlOptimizationAction
]

instance CustomAlgorithmService : DTDFVocab:Service [
    base:desc "Service implementing domain-specific algorithms and custom logic extensions for specialized system requirements."
    DTDFVocab:provides CustomAlgorithmInsight
]

// C17: Insights/Actions
instance SystemArchitectureInsight : DTDFVocab:Insight [
    base:desc "Structural and compositional insights about system architecture derived from SysML IBDs and ADL descriptions."
]

instance BehavioralPatternInsight : DTDFVocab:Insight [
    base:desc "Identified behavioral patterns and state transitions from simulation and state machine analysis."
]

instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results comparing simulated behavior against physical system performance metrics."
]

instance DataAnomalyInsight : DTDFVocab:Insight [
    base:desc "Detected anomalies in real-time data streams and contextual traces from physical system monitoring."
]

instance SynchronizationStatusInsight : DTDFVocab:Insight [
    base:desc "Current synchronization status between physical system state and digital twin representation."
]

instance ControlOptimizationAction : DTDFVocab:Action [
    base:desc "Automated control optimization actions derived from simulation and behavioral analysis."
    DTDFVocab:IsAutomatic true
]

instance CustomAlgorithmInsight : DTDFVocab:Insight [
    base:desc "Results and performance metrics from domain-specific custom algorithms implemented in the digital twin."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin (DT) constellation** is not explicitly detailed in the provided document, but the **orchestration and coordination** are implicitly addressed through **Model-Based Systems Engineering (MBSE)** frameworks and **architecture description languages (ADLs)**. The document emphasizes the need for **integrating heterogeneous stakeholders and perspectives**, suggesting a **system-wide coordination mechanism** via **multi-notation modeling tools** (e.g., SysML for functional/logical architecture, MontiArc Automaton for behavior, or Simulink for simulation). The **resource management** aspect is implied through the use of **component & connector perspectives** (e.g., ACME, AADL) to define interfaces, interconnections, and composition, while **system-wide coordination** may rely on **shared middleware** (e.g., simulation tools, code in C++/Java) to ensure consistency across layers (requirements, functions, logics, physics)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **fidelity considerations** through structured **validation and verification (V&V) methods** applied to models and data. While the document does not specify exact fidelity metrics, it implies adherence to **MBSE methodologies** (e.g., RFLP, OOSEM, SPES) that enforce traceability from requirements to implementation, ensuring model accuracy. **Uncertainty sources** may arise from **data abstraction** in Digital Shadows (as per [32]), where contextual traces are aggregated and simplified, potentially introducing discrepancies between the digital and physical states. Error detection mechanisms are not explicitly detailed, but the system’s reliance on **automated data flows** and **active components** (e.g., simulation tools like Simulink) suggests real-time monitoring and correction capabilities. **Quality assurance** is implied through the use of **standardized modeling languages (SysML, ADLs)** and tools, which enforce consistency and reduce ambiguity. However, no quantitative specifications (e.g., error thresholds, precision requirements) or formal **uncertainty quantification** techniques (e.g., probabilistic modeling) are provided in the document."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for a Digital Twin (DT) system is not explicitly detailed in the provided document. However, the **one-way data flow** from physical to digital (as described for digital shadows [32]) implies underlying **communication protocols** must support reliable transmission of contextual data traces. While no specific protocols (e.g., **OPC UA, MQTT, HTTP/REST, or industrial Ethernet**) are mentioned, the integration of heterogeneous tools (e.g., **Simulink [28]**, **SysML [17]**, or **MontiArc [25]**) suggests interoperability requirements. The **network topology** may involve distributed architectures (e.g., edge-cloud hybrid) to handle data aggregation and abstraction, but no topology (e.g., star, mesh, or hierarchical) is specified. **Bandwidth and latency requirements** are not quantified, though real-time or near-real-time constraints are implied for dynamic systems. **Reliability and redundancy mechanisms** are not addressed, nor are **security protocols** (e.g., encryption, authentication, or access control) for network communication. The document does not provide details on infrastructure deployment (e.g., 5G, industrial IoT gateways, or private networks)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **hosting and deployment infrastructure** for a Digital Twin (DT) system is not explicitly described in the provided document. However, the integration of **heterogeneous tools** (e.g., **Simulink [28]**, **SysML [17]**, **MontiArc [25]**, or general-purpose languages like **C++/Java**) implies a **scalable, multi-platform deployment model**. The document does not specify whether the DT is hosted in **cloud, edge, or on-premise** environments, nor does it detail **computational/storage requirements** (e.g., CPU/GPU resources, memory, or storage tiers). **Scalability mechanisms** (e.g., containerization via Docker/Kubernetes, auto-scaling, or microservices) are not mentioned, though the use of **MBSE methodologies** (e.g., **RFLP, OOSEM, SPES**) suggests modular design principles that could support scalability. **Availability/reliability assurance** mechanisms (e.g., failover, backup systems, or SLAs) are not addressed. The document also does not clarify **deployment models** (e.g., hybrid cloud, multi-cloud, or air-gapped systems) or whether the DT leverages **edge computing** for localized processing."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The document does not provide explicit details on **horizontal integration** with external systems, but it implies **interoperability standards** and **data exchange protocols** through the use of **MBSE methodologies** and **ADLs** (e.g., SysML, AADL, MontiArc). Integration with **external systems** (e.g., other Digital Twins or enterprise systems) is suggested via **shared modeling frameworks** (e.g., SysML IBDs for component interconnections) and **simulation tools** (e.g., Simulink, MathWorks). The document does not specify **dependencies on external systems** or **integration patterns**, but it highlights the need for **heterogeneous stakeholder integration**, which may involve **standardized interfaces** (e.g., component connectors in ADLs) or **middleware** (e.g., code in C++/Java) to ensure seamless data exchange across boundaries. The **Digital Shadow Reference Model** (Fig. 1) further implies a **one-way data flow** (passive aggregation), but this does not directly address DT-to-DT or DT-to-enterprise integration."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system, as described in the provided documents, integrates **cybersecurity protocols** aligned with **Industrie 4.0** standards, particularly through the **Asset Administration Shell (AAS)** framework (referenced in [46], [47], [50]). The AAS enables **access control mechanisms** via role-based permissions and **authentication systems** leveraging **OAuth 2.0** and **JWT (JSON Web Tokens)** for secure API interactions (as implied by [50], which outlines AAS as a standardized shell for asset data exchange). **Threat mitigation strategies** are implicitly supported by the **RAMI4.0 reference architecture** ([48], [49]), which mandates **cybersecurity layers** across the **automation pyramid** (e.g., OT/IT segmentation, encryption for data in transit/rest). **Fail-safe mechanisms** are addressed through **model-driven engineering (MDE)** approaches ([43]), where Digital Twin models include **safety-critical system considerations** via **functional mockup interfaces (FMI)** ([51]) for simulation model exchange, ensuring deterministic behavior under fault conditions. **Risk assessment** is tied to **conformance relations** in reference models ([41]), validating structural integrity and compliance with **IEC 62443** (industrial cybersecurity) and **ISO 27001** (information security management) principles, though explicit details on implementation are not provided. The **MQTT protocol** ([52]) is referenced for lightweight, secure IoT communication, while **ThingsBoard** ([53]) offers built-in **data encryption (TLS 1.2+)** and **audit logging** for compliance tracking. No explicit mention of **data anonymization** or **consent management** is found."
]