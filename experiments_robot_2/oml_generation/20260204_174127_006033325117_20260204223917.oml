// ==================== C3: Physical sensing components ==================== // Return code: 1 | Stderr:
// Motor current sensor
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring phase current I_M for the first axis motor"
    DTDFVocab:producedData MotorCurrentStream
]

// Motor position encoder
instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor position encoder providing motor shaft angle for the first axis"
    DTDFVocab:producedData MotorEncoderStream
]

// Gearbox secondary encoder
instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary gearbox encoder providing gearbox output angle for the first axis"
    DTDFVocab:producedData GearboxEncoderStream
]

// ==================== C4: Physical‑to‑virtual interaction ====================
// Data streams transmitted via MQTT
instance MotorCurrentStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// ==================== C10: Models/Data ====================
// Measured data objects
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor phase current I_M (A) streamed via MQTT"
    DTDFVocab:fromData MotorCurrentStream
    DTDFVocab:inputTo MatlabSimulinkEngine, MqttBroker
]

instance MotorAngleData : DTDFVocab:Data [
    base:desc "Measured motor shaft angle (rad) from motor encoder"
    DTDFVocab:fromData MotorEncoderStream
    DTDFVocab:inputTo MatlabSimulinkEngine, MqttBroker
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Measured gearbox output angle (rad) from secondary encoder"
    DTDFVocab:fromData GearboxEncoderStream
    DTDFVocab:inputTo MatlabSimulinkEngine, MqttBroker
]

// Derived data objects (computed inside Simulink)
instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Torque derived analytically from motor current and system parameters"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity computed from angle time series"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration computed from velocity time series"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

// ==================== C11: Enablers ====================
// MQTT broker for live data streaming
instance MqttBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker used for real‑time sensor data streaming to the digital twin"
    DTDFVocab:enables RealTimeFrictionIdentification, DataVisualization
]

// MATLAB/Simulink execution environment
instance MatlabSimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink models of motor, gearwheel, gearbox and friction (Coulomb‑Viscous, Stribeck, Dahl, LuGre)"
    DTDFVocab:enables RealTimeFrictionIdentification, FrictionParameterGeneration
]

// Custom dashboard for visualization
instance CustomDashboard : DTDFVocab:Enabler [
    base:desc "Custom dashboard visualizing measured and simulated data"
    DTDFVocab:enables DataVisualization
]

// SysML modeling tool
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML tool for Block Definition and Internal Block Diagrams of the first axis"
    DTDFVocab:enables StructuralModeling
]

// Asset Administration Shell for model integration
instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "AAS used to integrate SysML and Simulink models into the digital twin"
    DTDFVocab:enables ModelIntegration
]

// ==================== C6: Services ====================
instance RealTimeFrictionIdentification : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction using combined white‑box and black‑box models"
    DTDFVocab:provides ReducedPositioningErrors, UpdateMotionControlAlgorithm
]

instance DataVisualization : DTDFVocab:Service [
    base:desc "Visualization of measured and simulated data in a custom dashboard"
    DTDFVocab:provides ImprovedMachiningPrecision
]

instance FrictionParameterGeneration : DTDFVocab:Service [
    base:desc "Generation of updated friction parameters to improve motion‑control accuracy"
    DTDFVocab:provides ReducedPositioningErrors
]

instance StructuralModeling : DTDFVocab:Service [
    base:desc "Structural modeling of the first axis using SysML block diagrams"
    DTDFVocab:provides StructuralModelAvailable
]

instance ModelIntegration : DTDFVocab:Service [
    base:desc "Integration of SysML and Simulink models via Asset Administration Shell"
    DTDFVocab:provides ModelIntegrationCompleted
]

// ==================== C17: Insights/Actions ====================
// Insights
instance ReducedPositioningErrors : DTDFVocab:Insight [
    base:desc "Derived friction parameters reduce positioning errors in the robot controller"
]

instance ImprovedMachiningPrecision : DTDFVocab:Insight [
    base:desc "Accurate friction compensation improves overall machining precision"
]

instance StructuralModelAvailable : DTDFVocab:Insight [
    base:desc "SysML structural model of the first axis is available for analysis"
]

instance ModelIntegrationCompleted : DTDFVocab:Insight [
    base:desc "SysML and Simulink models have been successfully integrated via AAS"
]

// Actions
instance UpdateMotionControlAlgorithm : DTDFVocab:Action [
    base:desc "Update motion‑control algorithm with newly identified friction parameters"
    DTDFVocab:IsAutomatic true
]

// ==================== C5: Component definitions ====================
// Physical component under study
instance FirstAxis : DTDFVocab:Component [
    base:desc "First vertical axis of the MABI MAX 100 robot, including motor, gearwheel and cycloidal gearbox"
]

// Digital twin shadow
instance FrictionShadow : DTDFVocab:Component [
    base:desc "Digital shadow instance representing the first axis (single instance, no hierarchical twins)"
    base:contains FirstAxis
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "No virtual‑to‑physical interaction; the digital shadow follows a one‑way data flow and does not send commands back to the robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time operation during robot run‑time; data are captured and processed on‑the‑fly to update friction models."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow consisting of the purpose class FrictionDerivation, the asset class Mabi, processing components (Simulation_M, Simulation_GW, Simulation_GB), engineering and simulation models, and associated DataTraces, all instantiated in the FrictionShadow object."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated stage – the digital shadow is created and used while the robot is in service to monitor and improve its behaviour."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of each DataTrace to its source and processing component ensures provenance; combination of analytical (white‑box) and data‑driven (black‑box) friction models permits validation against measured data; continuous re‑identification addresses model drift due to wear, temperature, or load changes."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow over MQTT; the digital shadow consumes these MQTT topics to populate DataTraces."
]