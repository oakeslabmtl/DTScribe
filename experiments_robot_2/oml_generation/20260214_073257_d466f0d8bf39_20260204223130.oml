// C3: Physical sensing component (derived from data trace collection description)
instance CPSDataTraceCollector : DTDFVocab:SensingComponent [
    base:desc "Collects contextual data traces from the cyber‑physical system as described in the digital twin framework."
    DTDFVocab:producedData CPSDataTraceTransmitted
]

// C4: Physical-to-virtual interaction
instance CPSDataTraceTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CPSDataTraceCollector
]

// C10: Data
instance CPSContextualData : DTDFVocab:Data [
    base:desc "Contextual data trace representing raw observations collected from the cyber‑physical system."
    DTDFVocab:fromData CPSDataTraceTransmitted
    DTDFVocab:inputTo EngineeringModelProcessor, SimulationModelProcessor, DataCalculationProcessor
]

// C10: Models/Data
instance SysMLBlockDiagramModel : DTDFVocab:Model [
    base:desc "SysML block diagram engineering model describing system structure, properties and behavior."
    DTDFVocab:inputTo EngineeringModelProcessor
]

instance ACMEAADLModel : DTDFVocab:Model [
    base:desc "Component‑connector ADL model (ACME/AADL/MontiArc) capturing system architecture."
    DTDFVocab:inputTo EngineeringModelProcessor
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink simulation model implementing dynamic physical behavior."
    DTDFVocab:inputTo SimulationModelProcessor
]

instance MontiArcAutomatonStateMachineModel : DTDFVocab:Model [
    base:desc "MontiArcAutomaton state‑machine model representing behavioral logic."
    DTDFVocab:inputTo SimulationModelProcessor
]

instance StatisticalMLModel : DTDFVocab:Model [
    base:desc "Statistical/machine‑learning model generating higher‑level abstractions from raw traces."
    DTDFVocab:inputTo DataCalculationProcessor
]

// C11: Enablers (Processing components)
instance EngineeringModelProcessor : DTDFVocab:Enabler [
    base:desc "Processing component that consumes data traces and executes engineering models (SysML, ADLs)."
    DTDFVocab:enables EngineeringModelService
]

instance SimulationModelProcessor : DTDFVocab:Enabler [
    base:desc "Processing component that runs simulation models such as Simulink and MontiArcAutomaton state machines."
    DTDFVocab:enables SimulationService
]

instance DataCalculationProcessor : DTDFVocab:Enabler [
    base:desc "Processing component applying statistical or machine‑learning calculations to produce analytics."
    DTDFVocab:enables DataAnalyticsService
]

// C6: Services
instance EngineeringModelService : DTDFVocab:Service [
    base:desc "Service providing structural and behavioral insights derived from engineering models."
    DTDFVocab:provides StructuralInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service delivering simulation‑based predictions of system state."
    DTDFVocab:provides PredictionInsight, StatePredictionAction
]

instance DataAnalyticsService : DTDFVocab:Service [
    base:desc "Service delivering analytical insights and automated actions from data‑calculation models."
    DTDFVocab:provides AnomalyDetectionInsight, AnomalyMitigationAction
]

// C17: Insights
instance StructuralInsight : DTDFVocab:Insight [
    base:desc "Insight into system architecture and component relationships obtained from engineering models."
]

instance PredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive insight forecasting future system behavior based on simulation outputs."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight identifying abnormal patterns detected by statistical/ML models."
]

// C17: Actions
instance StatePredictionAction : DTDFVocab:Action [
    base:desc "Automatic action to update the digital twin state with predicted values."
    DTDFVocab:IsAutomatic true
]

instance AnomalyMitigationAction : DTDFVocab:Action [
    base:desc "Automatic corrective action triggered upon detection of anomalies."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows a Model‑Based Systems‑Engineering (MBSE) approach that is split into several abstraction levels: (1) requirements modeling, (2) functional architecture, (3) logical architecture, and (4) product/technical (physical) layer. During development the twin is first represented by high‑level SysML requirement and block diagrams, then refined into functional and logical models using architecture description languages such as ACME, AADL, MontiArc or SysML internal block diagrams, and finally instantiated with concrete engineering, simulation or data‑calculation models (e.g., Simulink). Transition between stages is governed by explicit traceability links (the “originates‑from” association) that connect data traces to the processing components and the models that generated them, ensuring that each refinement step can be audited and that governance of the lifecycle is based on conformance to the Digital Shadow Reference Model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and validity are addressed through traceability and verification of model transformations. The reliability of a digital shadow (and by extension a Digital Twin) is directly linked to the correctness of its underlying models and the data‑processing steps; therefore, verification methods such as systematic checks of transformations from SysML to simulation models are employed. Uncertainty sources include errors in the original data traces and inaccuracies in the physics‑based (white‑box) or data‑driven (black‑box) models; these are quantified by maintaining fine‑grained traceability, which allows the origin of any computed trace to be identified and inspected. Error detection is supported by the “originates‑from” association that enables back‑propagation of inconsistencies, and correction mechanisms rely on re‑executing processing components with validated input. Quality assurance is ensured by conforming concrete realizations to the Digital Shadow Reference Model, guaranteeing that all modeling concepts and their relationships satisfy the defined conformance relation."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin framework adopts several industry modelling standards: SysML (OMG) for requirements and behavior models, AADL (SAE) for architecture description, ACME for component‑connector specifications, MontiArcAutomaton for combined architecture and automaton behavior, and Simulink (MathWorks) for simulation models. Conformance to the Digital Shadow Reference Model is achieved through a defined conformance relation that maps concrete class diagrams to the reference concepts, ensuring interoperability across tools and adherence to the referenced standards."
]