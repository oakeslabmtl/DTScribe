// C2: Acting Components
instance InjectionMoldingMachineActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator component for injection molding machines enabling closed-loop control of process parameters like pressure, temperature, and cycle time."
]

instance RoboticsJointActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator component for robotic joints enabling adaptive control of movement parameters including friction compensation and dynamic positioning."
]

// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "High-precision temperature sensor capturing real-time thermal data from manufacturing processes for quality control and process optimization."
    DTDFVocab:producedData TemperatureDataTrace
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Accelerometer-based vibration sensor monitoring dynamic mechanical states in robotic systems and injection molding machines."
    DTDFVocab:producedData VibrationDataTrace
]

instance ForceTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Force/torque sensor distributed across robotic joints capturing nonlinear friction and kinematic parameters for adaptive control."
    DTDFVocab:producedData ForceTorqueDataTrace
]

instance PositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-resolution encoder providing real-time positional data for robotic systems and CNC machines."
    DTDFVocab:producedData PositionDataTrace
]

instance OperationalLogSensor : DTDFVocab:SensingComponent [
    base:desc "System log sensor capturing timestamps, event records, and process execution traces for manufacturing operations."
    DTDFVocab:producedData OperationalLogTrace
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTrace : DTDFVocab:DataTransmitted [
    base:desc "Real-time temperature data transmitted via MQTT protocol from temperature sensors to digital shadow framework."
    DTDFVocab:producedFrom TemperatureSensor
]

instance VibrationDataTrace : DTDFVocab:DataTransmitted [
    base:desc "Vibration data transmitted periodically (millisecond-level) from accelerometers via MQTT for dynamic state analysis."
    DTDFVocab:producedFrom VibrationSensor
]

instance ForceTorqueDataTrace : DTDFVocab:DataTransmitted [
    base:desc "High-frequency force/torque data transmitted event-triggered from robotic joints for friction compensation modeling."
    DTDFVocab:producedFrom ForceTorqueSensor
]

instance PositionDataTrace : DTDFVocab:DataTransmitted [
    base:desc "Positional data transmitted via MQTT from encoders for real-time kinematic analysis in robotic systems."
    DTDFVocab:producedFrom PositionEncoder
]

instance OperationalLogTrace : DTDFVocab:DataTransmitted [
    base:desc "Operational log data transmitted periodically from system logs containing process execution records and event timestamps."
    DTDFVocab:producedFrom OperationalLogSensor
]

// C10: Models/Data
instance PhysicsBasedRobotDynamicsModel : DTDFVocab:Model [
    base:desc "White-box Simulink-based model representing robot dynamics with analytical formulations for interpretable behavior modeling."
    DTDFVocab:inputTo SimulinkEnabler
]

instance MachineLearningFrictionModel : DTDFVocab:Model [
    base:desc "Black-box machine learning model capturing nonlinear friction phenomena in robotic joints using historical sensor data."
    DTDFVocab:inputTo AIMLEnabler
]

instance InjectionMoldingProcessModel : DTDFVocab:Model [
    base:desc "Physics-based model simulating injection molding processes including thermal, pressure, and cycle time dynamics."
    DTDFVocab:inputTo InjectionMoldingSimulationEnabler
]

instance ProcessStateData : DTDFVocab:Data [
    base:desc "Aggregated state data derived from raw sensor traces representing current operational state of manufacturing systems."
    DTDFVocab:fromData TemperatureDataTrace, VibrationDataTrace, ForceTorqueDataTrace, PositionDataTrace
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance OperationalTraceData : DTDFVocab:Data [
    base:desc "Structured operational data traces containing timestamps, event logs, and process execution records for analysis."
    DTDFVocab:fromData OperationalLogTrace
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance DerivedKPIData : DTDFVocab:Data [
    base:desc "Derived key performance indicators (KPIs) calculated from raw sensor data including yield rates, energy consumption metrics."
    DTDFVocab:fromData ProcessStateData
    DTDFVocab:inputTo VisualizationEnabler
]

// C11: Enablers
instance MQTTProtocolEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol implementation via Mosquitto enabling lightweight, low-latency data transmission from sensors to digital twin."
    DTDFVocab:enables DataAggregationService
]

instance ThingsBoardPlatformEnabler : DTDFVocab:Enabler [
    base:desc "ThingsBoard IoT platform (v4.0.0) supporting MQTT integration, rule engine for contextual analysis, and data aggregation."
    DTDFVocab:enables StateTrackingService, PredictiveMaintenanceService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink enabling detailed behavioral modeling, dynamic system simulation, and control logic implementation."
    DTDFVocab:enables ProcessOptimizationService, ScenarioSimulationService
]

instance AIMLEnabler : DTDFVocab:Enabler [
    base:desc "AI/ML framework enabling predictive analytics, failure forecasting, and adaptive decision-making using historical data."
    DTDFVocab:enables FailurePredictionService, PerformanceForecastingService
]

instance ProcessingComponentEnabler : DTDFVocab:Enabler [
    base:desc "Processing component implementing simulation models and data calculation logic for transforming input traces into output insights."
    DTDFVocab:enables QualityControlService, ResourceAllocationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Interactive dashboard framework enabling 3D/4D visualizations of system states and scenario simulations."
    DTDFVocab:enables InteractiveDashboardService, StakeholderIntegrationService
]

instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling tool enabling functional and logical architecture modeling including internal block diagrams for component-connector perspectives."
    DTDFVocab:enables ModelIntegrationService, ArchitectureValidationService
]

instance InjectionMoldingSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Specialized CAE software for injection molding process simulation including thermal, pressure, and cycle time dynamics."
    DTDFVocab:enables QualityControlService, ProcessOptimizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of physical system states detecting deviations or anomalies in manufacturing processes."
    DTDFVocab:provides StateTrackingInsight, AnomalyDetectionAction
]

