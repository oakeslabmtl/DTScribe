]

instance InteractiveDashboardService : DTDFVocab:Service [
    base:desc "Interactive 3D/4D visualization service enabling real-time monitoring and scenario simulation of system states."
    DTDFVocab:provides VisualizationInsight
]

instance StakeholderIntegrationService : DTDFVocab:Service [
    base:desc "Customized interfaces for engineers, operators, and planners enabling heterogeneous stakeholder integration."
    DTDFVocab:provides UserInterfaceInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Service aggregating raw sensor data into structured, purpose-specific models for digital shadow framework."
    DTDFVocab:provides AggregatedDataInsight
]

instance ResourceAllocationService : DTDFVocab:Service [
    base:desc "AI-driven service recommending machine scheduling, material flow, and maintenance intervals for optimized resource use."
    DTDFVocab:provides AllocationRecommendationAction
]

instance ScenarioSimulationService : DTDFVocab:Service [
    base:desc "Virtual testing service enabling what-if scenario simulations for process optimization and contingency planning."
