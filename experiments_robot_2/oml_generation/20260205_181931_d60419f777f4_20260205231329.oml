]

instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Service integrating heterogeneous models (SysML, Simulink, custom code) into cohesive digital twin architecture."
    DTDFVocab:provides IntegratedModelInsight
]

instance ArchitectureValidationService : DTDFVocab:Service [
    base:desc "Service validating digital twin architecture against requirements and functional specifications."
    DTDFVocab:provides ValidationResultInsight
]

