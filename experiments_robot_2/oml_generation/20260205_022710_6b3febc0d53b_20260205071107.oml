// Sensing components // Return code: 1 | Stderr:
instance MotorControllerOutputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor controller output current sensor"
    DTDFVocab:producedData MQTTCurrentData
]

instance MotorEncoderSignalSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder signal sensor"
    DTDFVocab:producedData MQTTMotorAngleData
]

instance GearboxEncoderSignalSensor : DTDFVocab:SensingComponent [
    base:desc "Gearbox encoder signal sensor"
    DTDFVocab:producedData MQTGGearboxAngleData
]

// Data transmitted over MQTT
instance MQTTCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorControllerOutputCurrentSensor
]

instance MQTTMotorAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSignalSensor
]

instance MQTGGearboxAngleData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSignalSensor
]

// Recorded sensor data
instance CurrentData : DTDFVocab:Data [
    base:desc "Current sensor data received via MQTT"
    DTDFVocab:fromData MQTTCurrentData
    DTDFVocab:inputTo MATLABSimulinkSimulator, GrafanaDashboardFramework
]

instance MotorAngleData : DTDFVocab:Data [
    base:desc "Motor angle sensor data received via MQTT"
    DTDFVocab:fromData MQTTMotorAngleData
    DTDFVocab:inputTo MATLABSimulinkSimulator, GrafanaDashboardFramework
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Gearbox angle sensor data received via MQTT"
    DTDFVocab:fromData MQTGGearboxAngleData
    DTDFVocab:inputTo MATLABSimulinkSimulator, GrafanaDashboardFramework
]

// Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML for modeling"
    DTDFVocab:enables ContinuousFrictionModelIdentificationService, MotorGearDynamicsSimulationService
]

instance MATLABSimulinkSimulator : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink for simulation"
    DTDFVocab:enables MotorGearDynamicsSimulationService
]

instance AssetAdministrationShellDataPackaging : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for data packaging"
    DTDFVocab:enables MeasurementSimulationComparisonService
]

instance MQTTBrokerLiveDataTransfer : DTDFVocab:Enabler [
    base:desc "MQTT broker for live data transfer"
    DTDFVocab:enables RealTimeMonitoringDashboardService, ContinuousFrictionModelIdentificationService
]

instance GrafanaDashboardFramework : DTDFVocab:Enabler [
    base:desc "Dashboard framework for visualization (e.g., Grafana)"
    DTDFVocab:enables OperatorDecisionSupportDashboardService
]

// Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard"
    DTDFVocab:provides FrictionBehaviorChangeInsight, MachiningAccuracyImprovementInsight
]

instance ContinuousFrictionModelIdentificationService : DTDFVocab:Service [
    base:desc "Continuous white‑and black‑box friction model identification"
    DTDFVocab:provides FrictionModelUpgradeInsight, UpgradeFrictionModelAction
]

instance MotorGearDynamicsSimulationService : DTDFVocab:Service [
    base:desc "Simulation of motor and gear dynamics"
    DTDFVocab:provides MotorTorqueProfileUpdateInsight, UpdateMotorTorqueProfileAction
]

instance OperatorDecisionSupportDashboardService : DTDFVocab:Service [
    base:desc "Visualization for operator decision support"
    DTDFVocab:provides ControllerTuningRecommendationAction, MaintenanceRecommendationAction, ModelSelectionRecommendationAction
]

instance MeasurementSimulationComparisonService : DTDFVocab:Service [
    base:desc "Service for comparing measured and simulated data"
    DTDFVocab:provides MeasurementSimulationComparisonInsight, DataPackagingAction
]

// Insights
instance FrictionBehaviorChangeInsight : DTDFVocab:Insight [
    base:desc "Identification of friction behavior changes"
]

instance MachiningAccuracyImprovementInsight : DTDFVocab:Insight [
    base:desc "Improved machining accuracy"
]

instance MotorTorqueProfileUpdateInsight : DTDFVocab:Insight [
    base:desc "Updates to motor torque profiles for improved machining accuracy"
]

instance FrictionModelUpgradeInsight : DTDFVocab:Insight [
    base:desc "Continuous improvement of friction models during operation"
]

instance MeasurementSimulationComparisonInsight : DTDFVocab:Insight [
    base:desc "Comparison between measured and simulated data"
]

// Actions
instance ControllerTuningRecommendationAction : DTDFVocab:Action [
    base:desc "Recommendation for controller tuning"
    DTDFVocab:IsAutomatic false
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Recommendation for maintenance actions"
    DTDFVocab:IsAutomatic false
]

instance ModelSelectionRecommendationAction : DTDFVocab:Action [
    base:desc "Decisions on model selection"
    DTDFVocab:IsAutomatic false
]

instance UpdateMotorTorqueProfileAction : DTDFVocab:Action [
    base:desc "Update motor torque profiles"
    DTDFVocab:IsAutomatic false
]

instance UpgradeFrictionModelAction : DTDFVocab:Action [
    base:desc "Continuous improvement of friction models during operation"
    DTDFVocab:IsAutomatic false
]

instance DataPackagingAction : DTDFVocab:Action [
    base:desc "Action for packaging data in Asset Administration Shell"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital shadow consumes live data streams and updates its models in real time at the native sensor sampling rates; simulation runs synchronized with the data stream, providing near‑real‑time friction estimates. Exact sampling frequencies are not specified in the document but the system operates continuously during robot operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated set of components: the asset (robot first axis), engineering model, data‑calculation models, processing unit that consumes sensor traces and produces simulated outputs, and a visualization dashboard presenting the data trace and model results."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT includes design/ideal models (engineering models of motor and gearbox), manufacturing representations (physical sensor data), and operative models (real‑time data during machining); it spans the operational stage of the robot."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Strict traceability of each data point back to its source, comparison of measured and simulated data, continuous validation by real‑time mismatch monitoring, and inclusion of both analytical (white‑box) and data‑driven (black‑box) models to balance fidelity and adaptability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Live sensor data are transmitted to the digital shadow via the MQTT protocol. Asset metadata and model metadata are managed within the Asset Administration Shell (AAS). No bidirectional network communication from the twin to the robot is specified."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for modeling, Asset Administration Shells for data interchange, and reference to digital shadow reference model per Kritzinger et al. as a standard architecture."
]