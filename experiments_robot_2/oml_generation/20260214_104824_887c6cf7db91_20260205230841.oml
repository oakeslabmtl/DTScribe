// C2: Acting Components
instance InjectionMoldingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator component for dynamic adjustment of injection molding parameters (e.g., melt temperature, injection speed) to minimize defects via closed-loop feedback from Digital Twin simulations"
]

