]

instance DigitalShadowAggregator : DTDFVocab:Enabler [
    base:desc "IoT gateway service aggregating and abstracting heterogeneous sensor data into purpose-driven digital shadow traces using Kritzinger et al. [32] reference model"
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "TimescaleDB-based time-series database storing sensor data streams and historical process logs with optimized query performance for analytics"
]

instance MQTTGateway : DTDFVocab:Enabler [
    base:desc "MQTT-based IoT gateway (Mosquitto implementation) enabling low-latency transmission of real-time telemetry data to digital twin components"
]

instance OntologyKnowledgeGraph : DTDFVocab:Enabler [
