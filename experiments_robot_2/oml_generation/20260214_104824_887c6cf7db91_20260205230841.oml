    base:desc "Actuator for robotic systems enabling real-time adjustments in dynamic environments through adaptive control algorithms derived from Digital Twin predictions"
]

instance ProcessReactorActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator system for continuous process reactors enabling temperature/pressure control based on real-time yield prediction and energy optimization insights from the Digital Twin"
]

// C3: Physical sensing components
instance RobotJointForceSensor : DTDFVocab:SensingComponent [
    base:desc "High-resolution force/torque sensor embedded in robotic joints to measure nonlinear friction phenomena with kHz-range sampling for scalable identification methods"
    DTDFVocab:producedData RobotJointForceDataTransmitted
]

instance InjectionMoldingTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Precision temperature sensor monitoring melt temperature and mold surface conditions with event-triggered data collection for process optimization"
    DTDFVocab:producedData InjectionMoldingTemperatureDataTransmitted
]

instance ChemicalProcessFlowSensor : DTDFVocab:SensingComponent [
    base:desc "Flow rate sensor for chemical process reactors capturing real-time process dynamics with low-latency transmission for yield prediction analytics"
    DTDFVocab:producedData ChemicalProcessFlowDataTransmitted
]

instance RoboticPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-precision encoder measuring robotic joint angles and end-effector positions with millisecond-level sampling for motion planning simulations"
    DTDFVocab:producedData RoboticPositionDataTransmitted
]

instance VibrationMonitoringSensor : DTDFVocab:SensingComponent [
    base:desc "Accelerometer-based vibration sensor deployed on machinery for anomaly detection and predictive maintenance analysis of equipment wear"
    DTDFVocab:producedData VibrationDataTransmitted
]

// C4: Physical-to-virtual interaction
instance RobotJointForceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotJointForceSensor
]

instance InjectionMoldingTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InjectionMoldingTemperatureSensor
]

instance ChemicalProcessFlowDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChemicalProcessFlowSensor
]

instance RoboticPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoboticPositionEncoder
]

instance VibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationMonitoringSensor
]

instance ContextualEnvironmentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InjectionMoldingTemperatureSensor, ChemicalProcessFlowSensor, VibrationMonitoringSensor
]

// C10: Models/Data
instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based functional architecture model describing component-connector relationships for injection molding machines using state machines (v1.7) for behavioral description"
    DTDFVocab:inputTo SysMLModelingTool
]

instance SimulinkInjectionMoldingModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink dynamic simulation model for injection molding processes including nonlinear friction phenomena and state machine-based control logic"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance MachineLearningFrictionModel : DTDFVocab:Model [
    base:desc "Data-driven probabilistic latent variable model capturing nonlinear robot friction relationships using methods from Sorrentino et al. [14] integrated with white-box models"
    DTDFVocab:inputTo TensorFlowFramework
]

instance AADLHardwareSoftwareModel : DTDFVocab:Model [
    base:desc "AADL architecture model formally specifying hardware/software components and interfaces for robotic control systems with real-time constraints"
    DTDFVocab:inputTo AADLToolchain
]

instance DigitalShadowTraceData : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces from physical systems including raw sensor data, operational logs, and purpose-driven abstractions for manufacturing analytics"
    DTDFVocab:fromData InjectionMoldingTemperatureDataTransmitted, RobotJointForceDataTransmitted, VibrationDataTransmitted
    DTDFVocab:inputTo DigitalShadowAggregator
]

instance HistoricalProcessData : DTDFVocab:Data [
    base:desc "Time-series historical data including production metrics, equipment logs, and performance indicators for retrospective trend analysis and root-cause analysis"
    DTDFVocab:fromData ContextualEnvironmentDataTransmitted
    DTDFVocab:inputTo TimeSeriesDatabase
]

instance RealTimeTelemetryData : DTDFVocab:Data [
    base:desc "Low-latency sensor data stream including temperature, pressure, and vibration metrics transmitted via MQTT protocols for real-time monitoring and control"
    DTDFVocab:fromData InjectionMoldingTemperatureDataTransmitted, ChemicalProcessFlowDataTransmitted
    DTDFVocab:inputTo MQTTGateway
]

