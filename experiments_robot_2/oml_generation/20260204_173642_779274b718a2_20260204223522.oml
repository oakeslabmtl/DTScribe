// --------------------------------------------------------------
// C3: Physical Sensing Components
// --------------------------------------------------------------
instance MotorEncoderSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted on the motor shaft"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoderSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the gearbox"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance MotorCurrentSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Electric current sensor for motor current I_M"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance PositionAngleSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Position sensor providing output angle of the axis"
    DTDFVocab:producedData PositionAngleDataTransmitted
]

instance TorqueEstimatorSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Derived torque τ measurement obtained from the controller"
    DTDFVocab:producedData TorqueDataTransmitted
]

instance AngularVelocityEstimatorSensingComponent : DTDFVocab:SensingComponent [
    base:desc "Derived angular velocity ω measurement obtained from the controller"
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

// --------------------------------------------------------------
// C4: Physical-to-Virtual Interaction (Data Transmitted)
// --------------------------------------------------------------
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensingComponent
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensingComponent
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensingComponent
]

instance PositionAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionAngleSensingComponent
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueEstimatorSensingComponent
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocityEstimatorSensingComponent
]

// --------------------------------------------------------------
// C10: Data (Sensor Traces)
// --------------------------------------------------------------
instance MotorEncoderAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped motor shaft angle from the motor encoder"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance GearboxEncoderAngleData : DTDFVocab:Data [
    base:desc "Time‑stamped gearbox shaft angle from the secondary encoder"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Live motor current I_M trace"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance PositionAngleData : DTDFVocab:Data [
    base:desc "Output angle of the vertical axis (reference r_out)"
    DTDFVocab:fromData PositionAngleDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque τ trace from controller calculations"
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω trace from controller calculations"
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

// --------------------------------------------------------------
// C10: Engineering & Simulation Models
// --------------------------------------------------------------
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams describing the axis structure of MABI MAX 100"
    DTDFVocab:inputTo AssetAdministrationShellEnabler
]

instance SimulinkFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of motor‑gearwheel‑gearbox including Coulomb‑Viscous, Stribeck, Dahl, LuGre friction models"
    DTDFVocab:inputTo SimulinkEngine
]

// --------------------------------------------------------------
// C11: Enablers (Tooling & Infrastructure)
// --------------------------------------------------------------
instance MqttBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker for streaming live sensor data to the digital shadow"
    DTDFVocab:enables RealTimeFrictionIdentificationService,
                    DashboardVisualizationService,
                    SimulationComparisonService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for data encapsulation and linking to SysML elements"
    DTDFVocab:enables SimulationComparisonService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution engine for running friction and drivetrain simulation models"
    DTDFVocab:enables SimulationComparisonService
]

instance DashboardApp : DTDFVocab:Enabler [
    base:desc "Integrated dashboard for visualizing data traces and model comparison"
    DTDFVocab:enables DashboardVisualizationService
]

// --------------------------------------------------------------
// C6: Services
// --------------------------------------------------------------
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction using combined white‑box and black‑box models"
    DTDFVocab:provides FrictionParameterDerivationInsight,
                    UpdateRobotControllerAction
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Visualization of live data traces and model outputs in an integrated dashboard"
    DTDFVocab:provides DataTraceVisualizationInsight
]

instance SimulationComparisonService : DTDFVocab:Service [
    base:desc "Comparison of simulated vs. measured data to improve robot motion accuracy"
    DTDFVocab:provides SimulationMeasurementComparisonInsight,
                    AdjustSimulationParametersAction
]

// --------------------------------------------------------------
// C17: Insights
// --------------------------------------------------------------
instance FrictionParameterDerivationInsight : DTDFVocab:Insight [
    base:desc "Derivation of friction parameters that can be fed back to the robot controller to improve motion accuracy"
]

instance DataTraceVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of sensor data traces in the dashboard for operator awareness"
]

instance SimulationMeasurementComparisonInsight : DTDFVocab:Insight [
    base:desc "Detection of wear or temperature‑induced changes enabling maintenance decisions via simulated‑measured data comparison"
]

// --------------------------------------------------------------
// C17: Actions
// --------------------------------------------------------------
instance UpdateRobotControllerAction : DTDFVocab:Action [
    base:desc "Feed derived friction parameters back to the robot controller"
    DTDFVocab:IsAutomatic true
]

instance AdjustSimulationParametersAction : DTDFVocab:Action [
    base:desc "Modify simulation model parameters based on comparison results"
    DTDFVocab:IsAutomatic false
]

// --------------------------------------------------------------
// C2: System Under Study (Asset)
// --------------------------------------------------------------
instance MabiMax100Robot : DTDFVocab:Component [
    base:desc "Industrial robot MABI MAX 100 (six‑axis robot) focusing on its first vertical axis"
]

// --------------------------------------------------------------
// C5: Environment (optional)
// --------------------------------------------------------------
instance RobotWorkspace : DTDFVocab:Environment [
    base:contains MabiMax100Robot
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Not in Document (digital shadow is a one‑way, passive entity and does not send commands back to the robot)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow consisting of a singleton purpose (FrictionDerivation), the asset (MABI robot first axis), multiple DataTrace objects (measured and simulated), Processing components (Simulation_M, Simulation_GW, Simulation_GB) that consume input traces and produce output traces using the simulation models, all linked according to the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational stage – the digital shadow is created and used during robot run‑time to continuously identify friction and refine control; it builds on models defined during design."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each data point to its source and processing component; comparison of simulated friction‑free model versus measured data to validate friction models; continuous online identification to capture wear and temperature effects, ensuring high fidelity of the digital shadow."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow over MQTT; data are encapsulated in AAS structures for linking with the SysML model."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Uses the Industry 4.0 Asset Administration Shell (AAS) standard, SysML (OMG standard) for modeling, and MQTT (OASIS standard) for data transport."
]