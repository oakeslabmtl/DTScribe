prefix base: http://www.w3.org/2004/02/skos/core#
prefix DTDFVocab: http://example.org/DTDFVocab#

instance MQTTStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MABIMAX100Encoder, MABIMAX100CurrentSensor
]

instance MABIMAX100Motor : DTDFVocab:ActingComponent [
    base:desc "Actuating motor for precise motion control in MABI MAX 100 robot"
]

instance MABIMAX100Gearbox : DTDFVocab:Component [
    base:desc "Gearbox component transmitting torque in MABI MAX 100 robot"
]

instance MABIMAX100Encoder : DTDFVocab:SensingComponent [
    base:desc "Encoder sensor for measuring output angle in MABI MAX 100 robot",
    DTDFVocab:producedData MQTTStream
]

instance MABIMAX100CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor for measuring input current to robot motors",
    DTDFVocab:producedData MQTTStream
]

instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:contains MABIMAX100Motor, MABIMAX100Gearbox, MABIMAX100Encoder, MABIMAX100CurrentSensor
]

instance PositionAngleData : DTDFVocab:Data [
    base:desc "Time series data of output angles from MABI MAX 100 robot encoders",
    DTDFVocab:fromData MQTTStream
]

instance CurrentData : DTDFVocab:Data [
    base:desc "Time series data of input current to robot motors",
    DTDFVocab:fromData MQTTStream
]

instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML for requirements, functional, logical, and technical modeling",
    DTDFVocab:enables SysMLModelingService
]

instance ACMETool : DTDFVocab:Enabler [
    base:desc "ACME architecture description language tooling",
    DTDFVocab:enables ArchitectureModelingService
]

instance AADLTool : DTDFVocab:Enabler [
    base:desc "AADL architecture description language tooling",
    DTDFVocab:enables ArchitectureModelingService
]

instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc for architecture description and behavioral modeling",
    DTDFVocab:enables ArchitectureModelingService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and analytical modeling",
    DTDFVocab:enables SimulationService
]

instance CppTool : DTDFVocab:Enabler [
    base:desc "C++ programming language for code-based analytical models",
    DTDFVocab:enables CodeAnalysisService
]

instance JavaTool : DTDFVocab:Enabler [
    base:desc "Java programming language for code-based analytical models",
    DTDFVocab:enables CodeAnalysisService
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for layered abstraction in MBSE",
    DTDFVocab:enables MBSEProcessService
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for layered abstraction in MBSE",
    DTDFVocab:enables MBSEProcessService
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for layered abstraction in MBSE",
    DTDFVocab:enables MBSEProcessService
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP methodology for layered abstraction in MBSE",
    DTDFVocab:enables MBSEProcessService
]

instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML model for requirements layer in MBSE",
    DTDFVocab:inputTo SysMLTool
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML model for functional layer in MBSE",
    DTDFVocab:inputTo SysMLTool
]

instance SysMLLogicalModel : DTDFVocab:Model [
    base:desc "SysML model for logical layer in MBSE",
    DTDFVocab:inputTo SysMLTool
]

instance SysMLTechnicalModel : DTDFVocab:Model [
    base:desc "SysML model for product/technical layer in MBSE",
    DTDFVocab:inputTo SysMLTool
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME architecture description for component & connector structures",
    DTDFVocab:inputTo ACMETool
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL architecture description for component & connector structures",
    DTDFVocab:inputTo AADLTool
]

instance MontiArcArchitectureModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description for component & connector structures",
    DTDFVocab:inputTo MontiArcTool
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML IBD model for component & connector structures",
    DTDFVocab:inputTo SysMLTool
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton behavioral model",
    DTDFVocab:inputTo MontiArcTool
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine behavioral model",
    DTDFVocab:inputTo SysMLTool
]

instance SimulinkAnalyticalModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink analytical model for simulation",
    DTDFVocab:inputTo SimulinkEnabler
]

instance CppCodeModel : DTDFVocab:Model [
    base:desc "C++ code model for analytical purposes",
    DTDFVocab:inputTo CppTool
]

instance JavaCodeModel : DTDFVocab:Model [
    base:desc "Java code model for analytical purposes",
    DTDFVocab:inputTo JavaTool
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for simulating robot behavior using analytical models",
    DTDFVocab:provides SimulationInsight
]

instance CodeAnalysisService : DTDFVocab:Service [
    base:desc "Service for analyzing C++ and Java code models",
    DTDFVocab:provides CodeInsight
]

instance ArchitectureModelingService : DTDFVocab:Service [
    base:desc "Service for modeling architecture using ADLs",
    DTDFVocab:provides ArchitectureInsight
]

instance SysMLModelingService : DTDFVocab:Service [
    base:desc "Service for SysML-based modeling",
    DTDFVocab:provides SysMLInsight
]

instance MBSEProcessService : DTDFVocab:Service [
    base:desc "Service for MBSE methodology processes",
    DTDFVocab:provides MBSEInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service for real-time monitoring of robot sensor data",
    DTDFVocab:provides RobotPositionInsight, MotorCurrentInsight
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Predictive simulation insights for robot operations"
]

instance CodeInsight : DTDFVocab:Insight [
    base:desc "Code analysis insights from C++ and Java models"
]

instance ArchitectureInsight : DTDFVocab:Insight [
    base:desc "Architecture modeling insights from ADLs"
]

instance SysMLInsight : DTDFVocab:Insight [
    base:desc "SysML modeling insights for requirements and functional layers"
]

instance MBSEInsight : DTDFVocab:Insight [
    base:desc "MBSE process insights for layered abstraction"
]

instance RobotPositionInsight : DTDFVocab:Insight [
    base:desc "Real-time position data from robot encoders"
]

instance MotorCurrentInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of motor input current"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization of live measurements from the physical system to the digital shadow via one-way data flow, ensuring continuous state representation without feedback to the physical system, as defined by Kritzinger et al. [32]."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Shadow Reference Model (DSRM) defines a concrete architecture with Processing (consuming and producing data traces), Model (digital representation), and Asset (physical system interface) components, where data flows from Asset to Processing for aggregation and abstraction before being processed by the Model component."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for sensor data transmission between physical and digital components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with industry standards such as SysML [17], AADL [24], ACME [23], and MontiArc [25], [26] for architecture description and systems modeling. These standards enable interoperability through component & connector perspectives and support integration of diverse stakeholders [31]."
]