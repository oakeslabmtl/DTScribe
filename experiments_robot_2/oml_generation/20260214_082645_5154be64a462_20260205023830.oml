instance MABIMAX100Robot : DTDFVocab:Component [
    base:desc "Serial robot MABI MAX 100 with six axes"
]

instance MotorComponent : DTDFVocab:Component [
    base:desc "Motor component of MABI MAX 100 robot"
]

instance GearboxComponent : DTDFVocab:Component [
    base:desc "Gearbox component of MABI MAX 100 robot"
]

instance ControllerComponent : DTDFVocab:Component [
    base:desc "Controller component of MABI MAX 100 robot"
]

instance EncoderComponent : DTDFVocab:Component [
    base:desc "Encoder component of MABI MAX 100 robot"
]

instance RobotEnvironment : DTDFVocab:Environment [
    base:desc "Physical environment of the MABI MAX 100 robot system"
    base:contains MABIMAX100Robot, MotorComponent, GearboxComponent, ControllerComponent, EncoderComponent
]

instance MABIMAX100Encoder : DTDFVocab:SensingComponent [
    base:desc "Encoder sensor for the MABI MAX 100 robot axes"
    DTDFVocab:producedData MQTTDataStream
]

instance MQTTDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MABIMAX100Encoder
    base:desc "Time-series sensor data streamed via MQTT protocol from physical robot components to digital shadow"
]

instance TimeSeriesData : DTDFVocab:Data [
    base:desc "Time-series data from robot encoders"
    DTDFVocab:fromData MQTTDataStream
    DTDFVocab:inputTo FrictionEnabler, VisualizationEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML tool for systems engineering modeling across requirements, functional architecture, logical architecture, and product/technical layer"
    DTDFVocab:enables SystemModelingService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME architecture description language for component & connector relationships"
    DTDFVocab:enables SystemArchitectureService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL architecture description language for component & connector perspectives"
    DTDFVocab:enables SystemArchitectureService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc architecture description language and Automaton for behavior modeling"
    DTDFVocab:enables BehaviorModelingService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for analytical simulations"
    DTDFVocab:enables SimulationService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for high-performance simulations"
    DTDFVocab:enables SimulationService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for general-purpose application development"
    DTDFVocab:enables VisualizationService
]

instance RFLPMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "RFLP methodology for handling complexity in system design"
    DTDFVocab:enables SystemDesignService
]

instance OOSEMMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for object-oriented system engineering"
    DTDFVocab:enables SystemDesignService
]

instance SPESMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for system engineering processes"
    DTDFVocab:enables SystemDesignService
]

instance SMArDTMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for managing complexity in digital twins"
    DTDFVocab:enables SystemDesignService
]

instance FrictionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for friction analysis using Simulink and C++"
    DTDFVocab:enables FrictionAnalysisService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for unified dashboard visualization using Java and Simulink"
    DTDFVocab:enables VisualizationService
]

instance SystemModelingService : DTDFVocab:Service [
    base:desc "Service for system modeling using SysML across abstraction levels"
    DTDFVocab:provides SystemArchitectureInsight
]

instance SystemArchitectureService : DTDFVocab:Service [
    base:desc "Service for system architecture description using ADLs"
    DTDFVocab:provides ArchitectureInsight
]

instance BehaviorModelingService : DTDFVocab:Service [
    base:desc "Service for behavior modeling using MontiArc Automaton"
    DTDFVocab:provides BehaviorInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for analytical simulations using Simulink and C++"
    DTDFVocab:provides SimulationResultInsight
]

instance SystemDesignService : DTDFVocab:Service [
    base:desc "Service for system design using methodologies RFLP, OOSEM, SPES, SMArDT"
    DTDFVocab:provides DesignInsight
]

instance FrictionAnalysisService : DTDFVocab:Service [
    base:desc "Service for friction analysis to improve robot control accuracy"
    DTDFVocab:provides FrictionIdentificationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Integrated visualization service for unified dashboard"
    DTDFVocab:provides VisualizationInsight
]

instance SystemArchitectureInsight : DTDFVocab:Insight [
    base:desc "System architecture model insights from SysML and ADLs"
]

instance ArchitectureInsight : DTDFVocab:Insight [
    base:desc "Component and connector relationships insights from ADLs"
]

instance BehaviorInsight : DTDFVocab:Insight [
    base:desc "Behavior modeling insights from MontiArc Automaton"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation results for robot motion and control"
]

instance DesignInsight : DTDFVocab:Insight [
    base:desc "System design insights from methodologies RFLP, OOSEM, SPES, SMArDT"
]

instance FrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Identifying friction to improve robot control accuracy"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Unified dashboard for user interaction with digital twin"
]

instance SysMLModel : DTDFVocab:Model [
    base:desc "SysML model for structural and functional architecture across requirements, functional, logical, and product/technical abstraction levels"
    DTDFVocab:inputTo SysMLEnabler
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME architecture description for component & connector relationships"
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL architecture description for component & connector relationships"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description for component & connector perspectives"
    DTDFVocab:inputTo MontiArcEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model for behavior modeling via state machines"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for analytical simulations"
    DTDFVocab:inputTo SimulinkEnabler
]

instance CppModel : DTDFVocab:Model [
    base:desc "C++ program for high-performance simulations"
    DTDFVocab:inputTo CppEnabler
]

instance JavaModel : DTDFVocab:Model [
    base:desc "Java application for general-purpose development"
    DTDFVocab:inputTo JavaEnabler
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication protocol: MQTT for sensor data streaming; no details on network topology, bandwidth, latency, reliability, redundancy, or security protocols provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to industry standards such as SysML [17] for model-based systems engineering, ACME [23], AADL [24], and MontiArc [25], [26] for architecture description languages (ADLs) to define component interfaces and interconnections. Methodologies including RFLP, OOSEM, SPES, and SMArDT are applied across abstraction levels (requirements, functional, logical, product/technical). Behavior modeling integrates Simulink [28], simulation tools [29], [30], and general-purpose languages (C++, Java), with interoperability ensured through heterogeneous stakeholder integration [31]."
]