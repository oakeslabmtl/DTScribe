// C3: Physical sensing component (collects state of physical object)
instance PhysicalStateSensor : DTDFVocab:SensingComponent [
    base:desc "Collects state information of a physical object to be mirrored in the digital twin."
    DTDFVocab:producedData PhysicalStateDataMessage
]

// C4: Data transmitted from sensor to digital twin
instance PhysicalStateDataMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalStateSensor
]

// C10: Data instance (continuous one‑way data flow into the twin)
instance DigitalShadowData : DTDFVocab:Data [
    base:desc "Continuous one‑way data flow into the twin for monitoring and analysis."
    DTDFVocab:fromData PhysicalStateDataMessage
    DTDFVocab:inputTo SimulinkEngine, CPlusPlusCodeGenerator, JavaCodeGenerator
]

// C11: Enablers that enable the modeling and simulation service
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML tool for documenting functional and logical architecture across abstraction layers."
    DTDFVocab:enables ModelingAndSimulationService
]

instance ACME_ADLTool : DTDFVocab:Enabler [
    base:desc "ADL tool to capture component‑connector relationships using ACME specifications."
    DTDFVocab:enables ModelingAndSimulationService
]

instance AADLTool : DTDFVocab:Enabler [
    base:desc "Architecture Description Language (AADL) tool for system analysis and architecture modeling."
    DTDFVocab:enables ModelingAndSimulationService
]

instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc tool for modeling component hierarchies and interfaces."
    DTDFVocab:enables ModelingAndSimulationService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink engine executing simulation models."
    DTDFVocab:enables ModelingAndSimulationService
]

instance CPlusPlusCodeGenerator : DTDFVocab:Enabler [
    base:desc "Code generator producing C++ code for deployment."
    DTDFVocab:enables ModelingAndSimulationService
]

instance JavaCodeGenerator : DTDFVocab:Enabler [
    base:desc "Code generator producing Java code for deployment."
    DTDFVocab:enables ModelingAndSimulationService
]

// C6: Service that performs modeling and simulation
instance ModelingAndSimulationService : DTDFVocab:Service [
    base:desc "Service that performs modeling and simulation of digital twin system."
    DTDFVocab:provides SimulationResultInsight
]

// C17: Insight derived from simulation
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulation results of digital twin."
]

// C10: Models used in the twin
instance SysMLIntegratedBlockDiagramModel : DTDFVocab:Model [
    base:desc "SysML Integrated Block Diagram model describing system components, interfaces, and interconnections."
    DTDFVocab:inputTo SysMLTool, SimulinkEngine, CPlusPlusCodeGenerator, JavaCodeGenerator
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc model with Automaton extension describing component behaviors via state machines."
    DTDFVocab:inputTo MontiArcTool, CPlusPlusCodeGenerator, JavaCodeGenerator
]

// C11: Additional enabler and service for monitoring digital twin state
instance DigitalTwinMonitoringService : DTDFVocab:Service [
    base:desc "Service facilitating monitoring of the digital twin state using the digital shadow reference model."
    DTDFVocab:provides DigitalTwinStateInsight, TwinStateAction
]

instance DigitalTwinStateInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing current state of digital twin derived from simulation data."
]

instance TwinStateAction : DTDFVocab:Action [
    base:desc "Action to adjust simulation parameters based on twin state."
    DTDFVocab:IsAutomatic true
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin’s communication stack is built on Mosquitto, the open‑source MQTT broker described in document 52, which implements the MQTT 3.1.1 protocol with explicit support for TLS encryption (currently TLS 1.2/1.3) and username/password authentication; optional client‑side certificates can be used for mutual TLS to guarantee that only authenticated controllers exchange telemetry.  At the application level, the platform employs Thingsboard (document 53) as an IoT back‑end, providing a multi‑tenant architecture with fine‑grained role‑based access control, JWT‑based device authentication, and mandatory TLS for all MQTT, HTTP and WebSocket traffic, with integrated audit logging for device, tenant and subscription events.  In the overall architecture, the RAMI 4.0 reference model (document 48) offers a dedicated cybersecurity layer that mandates risk assessment procedures, fail‑safe safeguards and a comprehensive resource‑based access control system, ensuring that safety‑critical data flows are isolated, encrypted, and monitored.  The Asset Administration Shell (document 50) encapsulates security metadata at the asset level—security categories, access rules, and cryptographic keys—allowing automated enforcement of ownership and authentication policies when the twin interfaces with the physical robot.  Finally, the functional mockup interface (FMI, document 51) can be employed to exchange simulation models in a version‑controlled, signed‑file format, further protecting model integrity and preventing unauthorized modification."
]