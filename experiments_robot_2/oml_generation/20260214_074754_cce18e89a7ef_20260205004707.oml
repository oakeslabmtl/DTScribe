instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "Model-Based Systems Engineering (MBSE) with SysML for structural modeling across requirements, functional, logical, and product/technical layers"
    DTDFVocab:inputTo SysMLEnabler
]

instance AADLComponentConnectorModel : DTDFVocab:Model [
    base:desc "Architecture Description Language (ADL) AADL for component-connector architecture descriptions"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcComponentConnectorModel : DTDFVocab:Model [
    base:desc "Architecture Description Language (ADL) MontiArc for component-connector architecture descriptions"
    DTDFVocab:inputTo MontiArcEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "Behavioral modeling using MontiArc Automaton"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "Behavioral modeling using SysML state machines"
    DTDFVocab:inputTo SysMLEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "Architecture Description Language (ADL) ACME for component-connector architecture descriptions"
    DTDFVocab:inputTo ACMEEnabler
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagrams for component & connector structure"
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering (MBSE) with SysML for system modeling across abstraction levels"
    DTDFVocab:enables ModelingService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Language (ADL) AADL for component-connector architecture descriptions"
    DTDFVocab:enables ArchitectureDescriptionService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Language (ADL) MontiArc for component-connector architecture descriptions"
    DTDFVocab:enables ArchitectureDescriptionService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Language (ADL) ACME for component-connector architecture descriptions"
    DTDFVocab:enables ArchitectureDescriptionService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "Analytical simulations leveraging MathWorks Simulink"
    DTDFVocab:enables SimulationService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "General-purpose programming language C++ for detailed behavior implementation"
    DTDFVocab:enables BehaviorImplementationService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "General-purpose programming language Java for detailed behavior implementation"
    DTDFVocab:enables BehaviorImplementationService
]

instance RFLPMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "Methodology RFLP for managing complexity"
    DTDFVocab:enables ModelingService
]

instance OOSEMMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "Methodology OOSEM for managing complexity"
    DTDFVocab:enables ModelingService
]

instance SPESMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "Methodology SPES for managing complexity"
    DTDFVocab:enables ModelingService
]

instance SMArDTMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "Methodology SMArDT for managing complexity"
    DTDFVocab:enables StakeholderIntegrationService
]

instance ModelingService : DTDFVocab:Service [
    base:desc "Modeling across abstraction levels using MBSE and SysML"
    DTDFVocab:provides ModelValidationInsight
]

instance ArchitectureDescriptionService : DTDFVocab:Service [
    base:desc "Architecture description using ADLs such as AADL, MontiArc, and ACME"
    DTDFVocab:provides ArchitectureDescriptionInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Analytical simulations using MathWorks Simulink"
    DTDFVocab:provides SimulationResultInsight
]

instance BehaviorImplementationService : DTDFVocab:Service [
    base:desc "Detailed behavior implementation using C++ and Java"
    DTDFVocab:provides BehaviorImplementationInsight
]

instance StakeholderIntegrationService : DTDFVocab:Service [
    base:desc "Management integrating heterogeneous stakeholder perspectives through multi-tool and multi-notation modeling environments"
    DTDFVocab:provides StakeholderIntegrationInsight
]

instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Validation of system models across abstraction levels"
]

instance ArchitectureDescriptionInsight : DTDFVocab:Insight [
    base:desc "Comprehensive architecture description and analysis"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation results and analysis"
]

instance BehaviorImplementationInsight : DTDFVocab:Insight [
    base:desc "Implementation details and behavior verification"
]

instance StakeholderIntegrationInsight : DTDFVocab:Insight [
    base:desc "Integration of stakeholder perspectives into the digital twin"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The document references industry standards such as SysML for Model-Based Systems Engineering, ACME, AADL, MontiArc as architecture description languages for component & connector perspectives, and methodologies like RFLP, OOSEM, SPES, SMArDT for system complexity handling. These standards are applicable to Digital Twin development processes."
]