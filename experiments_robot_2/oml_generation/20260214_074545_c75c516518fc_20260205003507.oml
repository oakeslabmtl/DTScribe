// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring the motor input current I_M, publishing via MQTT"
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder providing angular position of the motor shaft"
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Gearbox encoder providing angular position after the cycloidal gearbox"
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

// C10: Data
instance InputCurrentData : DTDFVocab:Data [
    base:desc "Live input current I_M trace streamed from the robot"
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkFrictionEngine
]

instance MotorAngleData : DTDFVocab:Data [
    base:desc "Live motor shaft angle trace from the motor encoder"
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkFrictionEngine
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Live gearbox output angle trace from the gearbox encoder"
    DTDFVocab:fromData GearboxAngleDataTransmitted
    DTDFVocab:inputTo MQTTBroker, SimulinkFrictionEngine
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker used for real‑time publishing of sensor streams"
    DTDFVocab:enables RealTimeFrictionIdentificationService
]

instance SimulinkFrictionEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution engine running motor, gearbox and friction models"
    DTDFVocab:enables RealTimeFrictionIdentificationService, DataComparisonService
]

instance DashboardApp : DTDFVocab:Enabler [
    base:desc "Custom web dashboard visualising measured vs. simulated data and friction parameters"
    DTDFVocab:enables DashboardVisualizationService
]

// C10: Models/Data (Models)
instance SysMLAxisModel : DTDFVocab:Model [
    base:desc "SysML block‑definition and internal‑block diagram of the MABI MAX 100 first axis"
    DTDFVocab:inputTo SimulinkFrictionEngine
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the permanent‑magnet synchronous motor"
    DTDFVocab:inputTo SimulinkFrictionEngine
]

instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the cycloidal gearbox"
    DTDFVocab:inputTo SimulinkFrictionEngine
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "LuGre friction model (including Coulomb, viscous, Stribeck and Dahl effects) applied to the axis"
    DTDFVocab:inputTo SimulinkFrictionEngine
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of friction parameters (static, kinetic, viscous) from live sensor data"
    DTDFVocab:provides FrictionParameterInsight, UpdateControllerParametersAction
]

instance DataComparisonService : DTDFVocab:Service [
    base:desc "Comparison of measured torque/velocity traces with simulated results"
    DTDFVocab:provides DataFitInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Dashboard visualisation of measured vs. simulated data and identified friction parameters"
    DTDFVocab:provides MotionAccuracyInsight
]

// C17: Insights
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Identified friction parameters that can be fed back to improve motion accuracy"
]

instance DataFitInsight : DTDFVocab:Insight [
    base:desc "Quantitative fit metric between measured and simulated torque/velocity data"
]

instance MotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Assessment of motion accuracy improvement after friction compensation"
]

// C17: Actions
instance UpdateControllerParametersAction : DTDFVocab:Action [
    base:desc "Action to update the SINUMERIK 840D controller with new friction compensation parameters"
    DTDFVocab:IsAutomatic false
]

// C18: Environment and physical components
instance AxisPhysicalEnvironment : DTDFVocab:Environment [
    base:contains PMSynchronousMotor, CycloidalGearbox, MotorEncoderComponent, GearboxEncoderComponent, SiemensCNCController
]

instance PMSynchronousMotor : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor driving the first axis"
]

instance CycloidalGearbox : DTDFVocab:Component [
    base:desc "Cycloidal gearbox providing speed reduction and torque transmission"
]

instance MotorEncoderComponent : DTDFVocab:Component [
    base:desc "Encoder mounted on the motor shaft for angular position feedback"
]

instance GearboxEncoderComponent : DTDFVocab:Component [
    base:desc "Encoder mounted on the gearbox output for angular position feedback"
]

instance SiemensCNCController : DTDFVocab:Component [
    base:desc "Siemens SINUMERIK 840D CNC controller managing the axis motion"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "No data or commands are sent from the digital shadow back to the robot; the digital shadow functions as a one‑way passive entity."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time acquisition and processing during robot operation; the digital shadow updates friction estimates continuously as new sensor data arrive."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow follows the Digital Shadow Reference Model: it comprises a Purpose (FrictionDerivation), an Asset (MABI axis), multiple DataTraces, Sources, Processing components (simulation models), and Models (engineering, simulation, data‑calculation) linked together to form the FrictionShadow instance."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the design stage (engineering SysML model, simulation models) and the operational stage (run‑time data collection and friction monitoring) of the robot."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability is maintained by linking each data point to its source and processing model. Friction estimates are validated by comparing simulated friction‑less behavior with measured data; continuous multi‑physics‑aware identification ensures model fidelity over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow using the MQTT messaging protocol."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach leverages the Asset Administration Shell (AAS) standard and uses SysML as a standardized modelling language; the Digital Shadow Reference Model provides a standardized conceptual framework."
]