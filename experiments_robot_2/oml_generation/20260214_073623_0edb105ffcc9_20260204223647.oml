// ------------------------------------------------------------
// C3: Physical sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder providing motor shaft angle r_M"
    DTDFVocab:producedData MQTT_r_M_Trace
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind the gearbox providing gearbox angle r_G"
    DTDFVocab:producedData MQTT_r_G_Trace
]

instance OutputEncoder : DTDFVocab:SensingComponent [
    base:desc "Output encoder delivering output shaft angle r_out"
    DTDFVocab:producedData MQTT_r_out_Trace
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring phase current I_M"
    DTDFVocab:producedData MQTT_I_M_Trace
]

// ------------------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance MQTT_I_M_Trace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MQTT_r_M_Trace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance MQTT_r_G_Trace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MQTT_r_out_Trace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputEncoder
]

instance Simulink_r_M_Trace : DTDFVocab:DataTransmitted [
]

instance Simulink_r_G_Trace : DTDFVocab:DataTransmitted [
]

instance Simulink_r_out_Trace : DTDFVocab:DataTransmitted [
]

// ------------------------------------------------------------
// C10: Data instances
instance I_M_Data : DTDFVocab:Data [
    base:desc "Motor current time‑series I_M captured from MotorCurrentSensor"
    DTDFVocab:fromData MQTT_I_M_Trace
    DTDFVocab:inputTo MQTTBroker
]

instance r_M_Data : DTDFVocab:Data [
    base:desc "Motor encoder angle time‑series r_M"
    DTDFVocab:fromData MQTT_r_M_Trace
    DTDFVocab:inputTo MQTTBroker
]

instance r_G_Data : DTDFVocab:Data [
    base:desc "Gearbox encoder angle time‑series r_G"
    DTDFVocab:fromData MQTT_r_G_Trace
    DTDFVocab:inputTo MQTTBroker
]

instance r_out_Data : DTDFVocab:Data [
    base:desc "Output shaft angle time‑series r_out"
    DTDFVocab:fromData MQTT_r_out_Trace
    DTDFVocab:inputTo MQTTBroker
]

instance Simulated_r_M_Data : DTDFVocab:Data [
    base:desc "Simulated motor angle ^r_M produced by friction models"
    DTDFVocab:fromData Simulink_r_M_Trace
    DTDFVocab:inputTo WebDashboard
]

instance Simulated_r_G_Data : DTDFVocab:Data [
    base:desc "Simulated gearbox angle ^r_G produced by friction models"
    DTDFVocab:fromData Simulink_r_G_Trace
    DTDFVocab:inputTo WebDashboard
]

instance Simulated_r_out_Data : DTDFVocab:Data [
    base:desc "Simulated output angle ^r_out produced by friction models"
    DTDFVocab:fromData Simulink_r_out_Trace
    DTDFVocab:inputTo WebDashboard
]

// ------------------------------------------------------------
// C10: Models
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML block and internal block diagrams describing the structure and flow ports of the robot axis"
    DTDFVocab:inputTo SysMLTool
]

instance SimulinkFrictionSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink executable models of Coulomb‑Viscous, Stribeck, Dahl, and LuGre for friction identification"
    DTDFVocab:inputTo SimulinkTool
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Processing component that consumes sensor traces and produces simulated friction traces"
    DTDFVocab:inputTo SimulinkTool
]

instance CoulombViscousModel : DTDFVocab:Model [
    base:desc "Coulomb‑Viscous friction model used within the Simulink simulation"
    DTDFVocab:inputTo SimulinkTool
]

instance StribeckModel : DTDFVocab:Model [
    base:desc "Stribeck friction model used within the Simulink simulation"
    DTDFVocab:inputTo SimulinkTool
]

instance DahlModel : DTDFVocab:Model [
    base:desc "Dahl friction model used within the Simulink simulation"
    DTDFVocab:inputTo SimulinkTool
]

instance LuGreModel : DTDFVocab:Model [
    base:desc "LuGre friction model used within the Simulink simulation"
    DTDFVocab:inputTo SimulinkTool
]

// ------------------------------------------------------------
// C11: Enablers (tooling & integration)
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML modeling tool for structural model creation"
    DTDFVocab:enables ControlOptimizationService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink environment executing friction simulation models"
    DTDFVocab:enables FrictionIdentificationService,
                     ControlOptimizationService,
                     SimulationComparisonService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker for real‑time streaming of sensor traces I_M, r_M, r_G, r_out"
    DTDFVocab:enables RealTimeVisualizationService,
                     FrictionIdentificationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for integrating engineering and simulation models into the twin"
    DTDFVocab:enables ControlOptimizationService,
                     SimulationComparisonService
]

instance WebDashboard : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard visualizing real‑time and simulated data"
    DTDFVocab:enables RealTimeVisualizationService,
                     SimulationComparisonService
]

// ------------------------------------------------------------
// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization dashboard for live sensor and simulated data"
    DTDFVocab:provides ModelPerformanceInsight,
                     DashboardNotificationAction
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous friction identification (static, kinetic, viscous) using white‑box and black‑box models"
    DTDFVocab:provides FrictionParameterInsight
]

instance ControlOptimizationService : DTDFVocab:Service [
    base:desc "Model‑based control optimisation using derived friction parameters"
    DTDFVocab:provides UpdateControlAlgorithmAction
]

instance SimulationComparisonService : DTDFVocab:Service [
    base:desc "Comparison of simulated versus measured data to assess friction loss and model quality"
    DTDFVocab:provides FrictionLossInsight,
                     ModelPerformanceInsight
]

// ------------------------------------------------------------
// C17: Insights
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived static, kinetic and viscous friction parameters"
]

instance MotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Improved motion accuracy resulting from updated control algorithm"
]

instance FrictionLossInsight : DTDFVocab:Insight [
    base:desc "Quantified friction loss obtained from simulated‑measured data comparison"
]

instance ModelPerformanceInsight : DTDFVocab:Insight [
    base:desc "Assessment of model performance shown on the dashboard"
]

// ------------------------------------------------------------
// C17: Actions
instance UpdateControlAlgorithmAction : DTDFVocab:Action [
    base:desc "Feed derived friction parameters back to the robot control algorithm to improve motion accuracy"
    DTDFVocab:IsAutomatic true
]

instance DashboardNotificationAction : DTDFVocab:Action [
    base:desc "Notify engineers via the dashboard about friction loss and model performance"
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time operation; data are captured and processed as they are generated, enabling online identification of friction parameters during robot motion."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A one‑way digital shadow architecture composed of a Purpose (FrictionDerivation), Asset (MABI robot first axis), Processing components (Simulation M, GW, GB), Models (engineering, simulation, data‑calculation), and DataTraces linked via the Digital Shadow Reference Model; data flow is from PT to DT only."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow covers the operated stage of the robot, using live operational data to refine models and improve control during runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each data point to its generating model and source; continuous multi‑physics‑aware identification allows validation by comparing simulated friction‑free behaviour with measured data; model parameters are updated online to maintain accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Live data transmission from the robot controller to the digital shadow uses the MQTT protocol; models are accessed via Asset Administration Shell interfaces."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation follows the Asset Administration Shell (AAS) specification, a standard for Industry 4.0 digital representations, and uses SysML which is an ISO/IEC standard for system modelling."
]