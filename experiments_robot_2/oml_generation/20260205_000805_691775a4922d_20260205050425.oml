// C2: Acting Components
instance PermanentMagnetMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor of the MABI MAX 100 first axis, driven by current I_M."
]
instance GearwheelGearbox : DTDFVocab:ActingComponent [
    base:desc "Gearwheel gearbox of the MABI MAX 100 first axis."
]
instance CycloidalGearbox : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gearbox of the MABI MAX 100 first axis."
]

// C3: Physical sensing components
instance IMCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor feeding motor current I_M."
    DTDFVocab:producedData MQTT_IMCurrentSensor
]
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder measuring angular position of the motor shaft."
    DTDFVocab:producedData MQTT_MotorEncoder
]
instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary gearbox encoder measuring output shaft angular position."
    DTDFVocab:producedData MQTT_GearboxEncoder
]

// C4: Physical-to-virtual interaction
instance MQTT_IMCurrentSensor : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IMCurrentSensor
]
instance MQTT_MotorEncoder : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]
instance MQTT_GearboxEncoder : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// C10: Models/Data
instance Data_IMCurrentSensor : DTDFVocab:Data [
    base:desc "Measured current I_M from the current sensor."
    DTDFVocab:fromData MQTT_IMCurrentSensor
    DTDFVocab:inputTo MQTTDataIngressEnabler
]
instance Data_MotorEncoder : DTDFVocab:Data [
    base:desc "Measured motor angular position from the motor encoder."
    DTDFVocab:fromData MQTT_MotorEncoder
    DTDFVocab:inputTo MQTTDataIngressEnabler
]
instance Data_GearboxEncoder : DTDFVocab:Data [
    base:desc "Measured gearbox angular position from the secondary gearbox encoder."
    DTDFVocab:fromData MQTT_GearboxEncoder
    DTDFVocab:inputTo MQTTDataIngressEnabler
]
instance Data_MeasuredTorque : DTDFVocab:Data [
    base:desc "Derived torque τ from current I_M."
    DTDFVocab:fromData Data_IMCurrentSensor
    DTDFVocab:inputTo FrictionIdentificationEnabler
]
instance Data_MeasuredAngularVelocity : DTDFVocab:Data [
    base:desc "Derived angular velocity ω from gearbox encoder."
    DTDFVocab:fromData Data_GearboxEncoder
    DTDFVocab:inputTo FrictionIdentificationEnabler
]
instance Data_SimulatedTorque : DTDFVocab:Data [
    base:desc "Simulated torque τ from Simulink motor and gearbox models."
    DTDFVocab:fromData Data_IMCurrentSensor
    DTDFVocab:inputTo SimulationExecutionEnabler
]
instance Data_SimulatedAngularVelocity : DTDFVocab:Data [
    base:desc "Simulated angular velocity ω from Simulink gear models."
    DTDFVocab:fromData Data_IMCurrentSensor
    DTDFVocab:inputTo SimulationExecutionEnabler
]
instance Data_FrictionCoefficients : DTDFVocab:Data [
    base:desc "Identified friction coefficients from real‑time friction identification."
    DTDFVocab:fromData Data_MeasuredTorque
    DTDFVocab:inputTo FrictionIdentificationEnabler
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the permanent magnet synchronous motor."
    DTDFVocab:inputTo SimulationExecutionEnabler
]
instance SimulinkGearwheelModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the gearwheel gearbox."
    DTDFVocab:inputTo SimulationExecutionEnabler
]
instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the cycloidal gearbox."
    DTDFVocab:inputTo SimulationExecutionEnabler
]
instance CoulombViscousFrictionLawModel : DTDFVocab:Model [
    base:desc "Coulomb–viscous friction law model for joint friction."
    DTDFVocab:inputTo FrictionIdentificationEnabler
]
instance StribeckFrictionLawModel : DTDFVocab:Model [
    base:desc "Stribeck friction law model for joint friction."
    DTDFVocab:inputTo FrictionIdentificationEnabler
]
instance DahlFrictionLawModel : DTDFVocab:Model [
    base:desc "Dahl friction law model for joint friction."
    DTDFVocab:inputTo FrictionIdentificationEnabler
]
instance LuGreFrictionLawModel : DTDFVocab:Model [
    base:desc "LuGre friction law model for joint friction."
    DTDFVocab:inputTo FrictionIdentificationEnabler
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service that performs continuous real‑time identification of joint friction using combined white‑box and black‑box models."
    DTDFVocab:provides FrictionCoefficientInsight, UpdateControlAlgorithmAction
]
instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service that executes Simulink simulation models for motor and gearbox."
    DTDFVocab:provides SimulationResultsInsight
]
instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service that visualizes measured and simulated signals in a dashboard."
    DTDFVocab:provides SignalComparisonInsight
]
instance RealTimeDataIngestionService : DTDFVocab:Service [
    base:desc "Service that ingests real‑time sensor data via MQTT."
]

// C7: Enablers
instance MQTTDataIngressEnabler : DTDFVocab:Enabler [
    base:desc "MQTT data ingestion enabler for real‑time collection of sensor data."
    DTDFVocab:enables RealTimeDataIngestionService
]
instance SimulationExecutionEnabler : DTDFVocab:Enabler [
    base:desc "Simulation execution enabler for running Simulink models."
    DTDFVocab:enables SimulationExecutionService
]
instance FrictionIdentificationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for continuous real‑time identification of joint friction."
    DTDFVocab:enables RealTimeFrictionIdentificationService
]
instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard visualization enabler for displaying measured vs simulated signals."
    DTDFVocab:enables DataVisualizationService
]

// C11: Insights
instance FrictionCoefficientInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time identified friction coefficients."
]
instance SimulationResultsInsight : DTDFVocab:Insight [
    base:desc "Insight presenting simulation results for torque and angular velocity."
]
instance SignalComparisonInsight : DTDFVocab:Insight [
    base:desc "Insight comparing measured and simulated signals in a dashboard."
]

// C11: Actions
instance UpdateControlAlgorithmAction : DTDFVocab:Action [
    base:desc "Automatic update of the robot control algorithm based on identified friction coefficients."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Not in Document."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time updates synchronized with the sensor sampling interval (typically in the order of milliseconds); the Digital Shadow processes data with near‑real‑time latency to support online friction identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Pipeline: sensor data (I_M, encoder) streamed via MQTT → Asset Administration Shell exposing data points → Processing component consumes data traces and executes similarity models in Simulink → Digital Shadow aggregates example Data Traces (referenced and simulated) → Dashboard visualizes results; the constellation follows the Digital Shadow Reference Model with Engineering, Data‑Calculation, and Simulation models linked through the Processing component."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated (run‑time) phase of the robot; the Digital Shadow is instantiated during operation to monitor and update friction models; it does not cover design or manufacturing phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity depends on the physics‑based simulation of motor and gearboxes and the chosen friction law; validity is ensured by continuous comparison of simulated outputs (τ, ω) with measured data; parameter identification is updated online; traceability ensures errors can be isolated; model uncertainty arises from measurement noise and unmodelled dynamics."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "One‑way MQTT broker delivering time‑series data from physical sensors to the Digital Shadow; Asset Administration Shells define metadata and data structure; no two‑way communication described."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Not in Document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not in Document."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not in Document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML (ISO/IEC 19448) as MBSE standard, Asset Administration Shells adhering to the Industrie 4.0 AAS standard, RFLP, SMArDT methodologies; adherence to ISO/IEC 30141 for digital twin architecture."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Not in Document."
]