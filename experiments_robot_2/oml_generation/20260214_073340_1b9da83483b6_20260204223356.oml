// C3: Physical sensing components (derived from characteristics)
instance RobotStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing intrinsic robot state data, providing raw sensor streams."
    DTDFVocab:producedData RobotStateDataTransmitted
]

instance ContextualDataSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor aggregating contextual data traces from the physical object for digital shadow."
    DTDFVocab:producedData ContextualDataTransmitted
]

// C4: Physical-to-virtual interaction
instance RobotStateDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Automated one‑way data flow from the RobotStateSensor to the digital twin (digital shadow)."
    DTDFVocab:producedFrom RobotStateSensor
]

instance ContextualDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Automated one‑way data flow from the ContextualDataSensor to the digital twin (digital shadow)."
    DTDFVocab:producedFrom ContextualDataSensor
]

// C10: Data instances
instance RobotStateDataTrace : DTDFVocab:Data [
    base:desc "Raw sensor stream representing intrinsic robot state, used as input for processing components."
    DTDFVocab:fromData RobotStateDataTransmitted
    DTDFVocab:inputTo ProcessingEnabler
]

instance ContextDataTrace : DTDFVocab:Data [
    base:desc "Aggregated contextual trace, used as input for processing components."
    DTDFVocab:fromData ContextualDataTransmitted
    DTDFVocab:inputTo ProcessingEnabler
]

// C10: Model instances
instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "White‑box dynamic simulation model realized in Simulink representing physical behavior."
    DTDFVocab:inputTo SimulinkEnabler
]

instance MachineLearningStateModel : DTDFVocab:Model [
    base:desc "Black‑box data‑driven model ingesting robot state data for prediction."
    DTDFVocab:inputTo MLInferenceEnabler
]

// C11: Enablers
instance ProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that consumes input data traces and executes calculation or simulation models to generate derived insights."
    DTDFVocab:enables InsightGenerationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment executing white‑box simulation models."
    DTDFVocab:enables SimulationExecutionService
]

instance MLInferenceEnabler : DTDFVocab:Enabler [
    base:desc "Machine‑learning execution environment performing inference on black‑box models using robot state data."
    DTDFVocab:enables MLInferenceService
]

// C6: Services
instance InsightGenerationService : DTDFVocab:Service [
    base:desc "Service that generates higher‑level abstractions (insights) from processed data traces."
    DTDFVocab:provides DerivedInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service that runs simulation models to produce simulation‑based insights."
    DTDFVocab:provides SimulationInsight
]

instance MLInferenceService : DTDFVocab:Service [
    base:desc "Service providing inference results and recommended actions based on machine‑learning models."
    DTDFVocab:provides RecommendationAction
]

// C17: Insights / Actions
instance DerivedInsight : DTDFVocab:Insight [
    base:desc "Higher‑level abstraction derived from raw sensor data, used for decision support."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight reflecting predicted system behavior generated by simulation execution."
]

instance RecommendationAction : DTDFVocab:Action [
    base:desc "Recommended action produced by ML inference, marked as automatic."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the Model‑Based Systems‑Engineering (MBSE) approach that separates models into successive abstraction levels: (1) requirements model, (2) functional architecture model, (3) logical architecture model, and (4) product/technical layer model. Early phases use SysML requirement diagrams; functional architecture is represented with SysML internal‑block diagrams; logical architecture is captured with component‑connector ADLs such as ACME, AADL, and MontiArc (including MontiArc Automaton for behavior); and the product layer is realized by executable code (C++, Java) or simulation models (e.g., MathWorks Simulink). Transitions between phases are governed by traceability links defined by the “originates‑from” association in the Digital Shadow reference model, which allow each lower‑level element to be traced back to its higher‑level source. Lifecycle governance is achieved by mapping concrete class diagrams to the reference model and enforcing conformance relations during each development step."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by combining white‑box (Simulink) and black‑box (ML) models and by verifying transformations such as SysML‑to‑simulation code to guarantee correctness. Reliability of the digital shadow depends on traceability of model artefacts and verification of data transformations. Sources of uncertainty (e.g., measurement noise, model approximation) are to be quantified, and error detection/correction mechanisms are implied through systematic model‑based verification and validation processes."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The documents mention the MQTT protocol as a communication mechanism, with Mosquitto providing a server and client implementation. IoT platforms such as ThingsBoard (v4.0.0) can be used to manage MQTT‑based data exchange, offering a lightweight publish/subscribe network layer for connecting physical devices to the digital twin."
]