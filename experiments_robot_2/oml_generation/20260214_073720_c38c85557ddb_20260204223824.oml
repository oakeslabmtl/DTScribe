// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring input current I_M of the permanent‑magnet synchronous motor"
    DTDFVocab:producedData MotorCurrentTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder measuring motor shaft angle"
    DTDFVocab:producedData MotorAngleTransmitted
]

instance SecondaryEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder measuring gearbox output angle"
    DTDFVocab:producedData OutputAngleTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorCurrentTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance OutputAngleTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoderSensor
]

instance TorqueTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorEncoderSensor
]

instance AngularVelocityTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance AccelerationTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

// C10: Data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor current I_M received via MQTT"
    DTDFVocab:fromData MotorCurrentTransmitted
    DTDFVocab:inputTo EnablerSimulink
]

instance MotorAngleData : DTDFVocab:Data [
    base:desc "Time‑series of motor angle"
    DTDFVocab:fromData MotorAngleTransmitted
    DTDFVocab:inputTo EnablerSimulink
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Time‑series of gearbox output angle"
    DTDFVocab:fromData OutputAngleTransmitted
    DTDFVocab:inputTo EnablerSimulink
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque calculated from current and motor angle"
    DTDFVocab:fromData TorqueTransmitted
    DTDFVocab:inputTo EnablerSimulink
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity of the motor shaft"
    DTDFVocab:fromData AngularVelocityTransmitted
    DTDFVocab:inputTo EnablerSimulink
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration of the motor shaft"
    DTDFVocab:fromData AccelerationTransmitted
    DTDFVocab:inputTo EnablerSimulink
]

// C10: Models
instance EngineeringSysMLModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams representing the first‑axis assembly"
    DTDFVocab:inputTo EnablerSysML
]

instance SimulationSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of motor, gearwheel, cycloidal gearbox and friction (Coulomb‑Viscous, Stribeck, Dahl, LuGre)"
    DTDFVocab:inputTo EnablerSimulink
]

instance FrictionSimulinkModel : DTDFVocab:Model [
    base:desc "Friction sub‑model (Coulomb‑Viscous, Stribeck, Dahl, LuGre) used within the Simulink simulation"
    DTDFVocab:inputTo EnablerSimulink
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Model for calculating torque, angular velocity and acceleration from raw sensor traces"
    DTDFVocab:inputTo EnablerSimulink
]

// C11: Enablers (tooling and enablers)
instance EnablerMQTT : DTDFVocab:Enabler [
    base:desc "MQTT broker enabling live transmission of sensor time‑series data to the digital shadow"
    DTDFVocab:enables ServiceRealTimeFrictionIdentification, ServiceVisualizationDashboard
]

instance EnablerSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment executing the dynamic simulation and friction identification"
    DTDFVocab:enables ServiceRealTimeFrictionIdentification, ServiceParameterUpdate
]

instance EnablerSysML : DTDFVocab:Enabler [
    base:desc "SysML tooling for structural and behavioral modeling of the robot axis"
    DTDFVocab:enables ServiceVisualizationDashboard, ServiceTwinningProcess
]

instance EnablerAAS : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell representing the physical robot asset in the digital twin ecosystem"
    DTDFVocab:enables ServiceParameterUpdate
]

instance EnablerCustomDashboard : DTDFVocab:Enabler [
    base:desc "Custom visualization dashboard for operator interaction with measured vs simulated data"
    DTDFVocab:enables ServiceVisualizationDashboard
]

// C6: Services
instance ServiceRealTimeFrictionIdentification : DTDFVocab:Service [
    base:desc "Provides real‑time identification of gearbox friction parameters (static, kinetic, viscous) using incoming sensor data"
    DTDFVocab:provides InsightFrictionParameterExtraction
]

instance ServiceVisualizationDashboard : DTDFVocab:Service [
    base:desc "Displays measured vs simulated data on a custom dashboard for operator interaction"
    DTDFVocab:provides InsightVisualization
]

instance ServiceParameterUpdate : DTDFVocab:Service [
    base:desc "Updates robot controller parameters based on identified friction values to improve motion control accuracy"
    DTDFVocab:provides InsightMotionControlImprovement, ActionAdjustMotionControl
]

instance ServiceTwinningProcess : DTDFVocab:Service [
    base:desc "Manages the four‑step purpose‑driven digital shadow development methodology"
    DTDFVocab:provides InsightTwinningMethodology, ActionRefineDigitalShadow
]

// C17: Insights
instance InsightFrictionParameterExtraction : DTDFVocab:Insight [
    base:desc "Extracted friction parameters (static, kinetic, viscous) from live sensor data"
]

instance InsightVisualization : DTDFVocab:Insight [
    base:desc "Comparison of measured and simulated data for operator evaluation"
]

instance InsightMotionControlImprovement : DTDFVocab:Insight [
    base:desc "Improved positional accuracy and reduced machining errors after parameter update"
]

instance InsightTwinningMethodology : DTDFVocab:Insight [
    base:desc "Four‑step purpose‑driven methodology: problem identification, asset/model analysis, simulation & friction modeling, data identification"
]

// C17: Actions
instance ActionAdjustMotionControl : DTDFVocab:Action [
    base:desc "Automatically adjusts robot controller motion‑control algorithm with new friction parameters"
    DTDFVocab:IsAutomatic true
]

instance ActionRefineDigitalShadow : DTDFVocab:Action [
    base:desc "Iteratively refines the digital shadow as new sensor data become available"
    DTDFVocab:IsAutomatic false
]

// C2: Components (system under study)
instance ComponentPMSMotor : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor of the first axis"
]

instance ComponentGearwheelGearbox : DTDFVocab:Component [
    base:desc "Gearwheel gearbox in the first axis"
]

instance ComponentCycloidalGearbox : DTDFVocab:Component [
    base:desc "Cycloidal gearbox in the first axis"
]

instance ComponentMotorEncoder : DTDFVocab:Component [
    base:desc "Encoder mounted on the motor shaft"
]

instance ComponentSecondaryEncoder : DTDFVocab:Component [
    base:desc "Encoder mounted behind the gearbox measuring output angle"
]

instance ComponentSafetyCell : DTDFVocab:Component [
    base:desc "Safety cell limiting robot motion to ±90° and maximum speed 75°/s"
]

// C16: Environment (grouping of components)
instance EnvironmentFirstAxis : DTDFVocab:Environment [
    base:contains ComponentPMSMotor, ComponentGearwheelGearbox, ComponentCycloidalGearbox,
                ComponentMotorEncoder, ComponentSecondaryEncoder, ComponentSafetyCell
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital shadow operates in a continuous, real‑time mode, ingesting sensor data as it is generated and updating friction estimates on‑line during robot operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow is realized as a purpose‑driven constellation comprising a Purpose (FrictionDerivation), an Asset (Mabi first axis), Sources (sensor streams via MQTT), Processing components (simulation and friction‑identification models), Models (engineering, simulation, data‑calculation), and Data Traces (measured and simulated torque/velocity series) that are linked and visualized in a unified dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow incorporates engineering models (SysML structural model) representing the designed system and operates on live operational data, thus covering both the design (as‑built) and operated stages of the physical system."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability is ensured by linking each data point to its source and processing model. Friction models are validated by comparing simulated torque/velocity outputs against measured reference traces, enabling multi‑physics‑aware identification and continuous validation during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted to the digital shadow using the MQTT protocol. The Asset Administration Shell (AAS) is employed to encapsulate asset metadata and interface definitions."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation follows Industry 4.0 standards such as Asset Administration Shells (AAS) for asset representation, uses the MQTT communication standard for data exchange, and employs SysML and MATLAB/Simulink, which are established engineering standards."
]