instance MotorEncoderPositionData : DTDFVocab:DataTransmitted [
    base:desc "Position data from motor encoder streamed via MQTT protocol",
    DTDFVocab:producedFrom MotorEncoder
]

instance SecondaryEncoderPositionData : DTDFVocab:DataTransmitted [
    base:desc "Position data from secondary encoder behind gearbox streamed via MQTT protocol",
    DTDFVocab:producedFrom SecondaryEncoder
]

instance MotorEncoderPositionDataRaw : DTDFVocab:Data [
    base:desc "Raw position data from motor encoder",
    DTDFVocab:fromData MotorEncoderPositionData
]

instance SecondaryEncoderPositionDataRaw : DTDFVocab:Data [
    base:desc "Raw position data from secondary encoder",
    DTDFVocab:fromData SecondaryEncoderPositionData
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted directly on the motor"
]

instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder positioned behind the gearbox"
]

instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving the first axis"
]

instance GearTransmission : DTDFVocab:ActingComponent [
    base:desc "Gear transmission for the robot"
]

instance CycloidalGear : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear for precision motion"
]

instance SiemensSINUMERIK840DController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl controller for robot control"
]

instance ProcessingComponent : DTDFVocab:Component [
    base:desc "Dedicated processing component for interpreting and analyzing incoming data streams"
]

instance Insight_CurrentState : DTDFVocab:Insight [
    base:desc "Current state of the robot for real-time monitoring"
]

instance Insight_FrictionLossDetection : DTDFVocab:Insight [
    base:desc "Friction loss detection as defined in Section IV.A"
]

instance Action_CorrectiveAction : DTDFVocab:Action [
    base:desc "Corrective actions for enhancing motion accuracy",
    DTDFVocab:IsAutomatic true
]

instance Service_RealTimeMonitoringAndVisualization : DTDFVocab:Service [
    base:desc "Real-time monitoring and visualization via dashboard interfaces for manufacturing engineers and maintenance personnel",
    DTDFVocab:provides Insight_CurrentState
]

instance Service_FrictionIdentification : DTDFVocab:Service [
    base:desc "Friction identification for dynamic adjustment of robot dynamics",
    DTDFVocab:provides Insight_FrictionLossDetection
]

instance Service_Optimization : DTDFVocab:Service [
    base:desc "Optimization for enhancing motion accuracy through sensor data analysis and simulation-based corrective actions",
    DTDFVocab:provides Action_CorrectiveAction
]

instance Enabler_SysML : DTDFVocab:Enabler [
    base:desc "SysML for system structure and behavior modeling",
    DTDFVocab:enables Service_RealTimeMonitoringAndVisualization, Service_FrictionIdentification, Service_Optimization
]

instance Enabler_RFLP : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements, Functions, Logics, Physics) for handling complexity across abstraction levels",
    DTDFVocab:enables Service_RealTimeMonitoringAndVisualization, Service_FrictionIdentification, Service_Optimization
]

instance Enabler_OOSEM : DTDFVocab:Enabler [
    base:desc "OOSEM for handling complexity across abstraction levels",
    DTDFVocab:enables Service_RealTimeMonitoringAndVisualization, Service_FrictionIdentification, Service_Optimization
]

instance Enabler_SPES : DTDFVocab:Enabler [
    base:desc "SPES for handling complexity across abstraction levels",
    DTDFVocab:enables Service_RealTimeMonitoringAndVisualization, Service_FrictionIdentification, Service_Optimization
]

instance Enabler_SMArDT : DTDFVocab:Enabler [
    base:desc "SMArDT for handling complexity across abstraction levels",
    DTDFVocab:enables Service_RealTimeMonitoringAndVisualization, Service_FrictionIdentification, Service_Optimization
]

instance Enabler_ACME : DTDFVocab:Enabler [
    base:desc "ACME for component & connector perspectives",
    DTDFVocab:enables Service_RealTimeMonitoringAndVisualization, Service_FrictionIdentification, Service_Optimization
]

instance Enabler_AADL : DTDFVocab:Enabler [
    base:desc "AADL for component & connector perspectives",
    DTDFVocab:enables Service_RealTimeMonitoringAndVisualization, Service_FrictionIdentification, Service_Optimization
]

instance Enabler_MontiArc : DTDFVocab:Enabler [
    base:desc "MontiArc for component & connector perspectives and behavior modeling",
    DTDFVocab:enables Service_RealTimeMonitoringAndVisualization, Service_FrictionIdentification, Service_Optimization
]

instance Enabler_Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and behavior modeling",
    DTDFVocab:enables Service_FrictionIdentification, Service_Optimization
]

instance Enabler_Cpp : DTDFVocab:Enabler [
    base:desc "C++ for general-purpose code in behavior modeling and processing",
    DTDFVocab:enables Service_RealTimeMonitoringAndVisualization, Service_FrictionIdentification, Service_Optimization
]

instance Enabler_Java : DTDFVocab:Enabler [
    base:desc "Java for general-purpose code in behavior modeling and processing",
    DTDFVocab:enables Service_RealTimeMonitoringAndVisualization, Service_FrictionIdentification, Service_Optimization
]

instance StructuralModel_SysML : DTDFVocab:Model [
    base:desc "Structural model using SysML for system structure",
    DTDFVocab:inputTo Enabler_SysML
]

instance StructuralModel_ACME : DTDFVocab:Model [
