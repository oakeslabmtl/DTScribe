    DTDFVocab:inputTo Enabler_MontiArc
]

instance StructuralModel_SysMLIBDs : DTDFVocab:Model [
    base:desc "Structural model using SysML IBDs",
    DTDFVocab:inputTo Enabler_SysML
]

