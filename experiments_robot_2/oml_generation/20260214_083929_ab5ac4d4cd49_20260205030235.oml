    DTDFVocab:inputTo Enabler_SysML
]

instance BehavioralModel_MontiArcAutomaton : DTDFVocab:Model [
    base:desc "Behavioral model using MontiArc Automaton",
    DTDFVocab:inputTo Enabler_MontiArc
]

instance BehavioralModel_Simulink : DTDFVocab:Model [
    base:desc "Behavioral model using MathWorks Simulink simulations",
    DTDFVocab:inputTo Enabler_Simulink
]

instance BehavioralModel_Cpp : DTDFVocab:Model [
