// C3: Physical sensing components
instance PhysicalAssetDataCollector : DTDFVocab:SensingComponent [
    base:desc "Automated collection of contextual data traces from the physical asset via the one‑way Digital Shadow."
    DTDFVocab:producedData DigitalShadowData
]

// C4: Physical‑to‑virtual interaction
instance DigitalShadowData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalAssetDataCollector
]

// C10: Models/Data
instance IngestedAssetData : DTDFVocab:Data [
    base:desc "Ingested contextual data from the physical asset, aligned with the model hierarchy."
    DTDFVocab:fromData DigitalShadowData
    DTDFVocab:inputTo DataIngestionEnabler
]

// C11: Enablers
instance DataIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Repository-based enabler that harvests ingested data and triggers ingestion services."
    DTDFVocab:enables DataIngestionService
]

instance ModelRepositoryEnabler : DTDFVocab:Enabler [
    base:desc "Version‑controlled model repository that stores SysML, MontiArc, and analytical models."
    DTDFVocab:enables ValidationAnalysisService
]

instance SimulationEnvironmentEnabler : DTDFVocab:Enabler [
    base:desc "Simulation environment that hosts Simulink and MontiArc automaton models for dynamic validation."
    DTDFVocab:enables SimulationService
]

instance CodeGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Toolchain enabler that transforms SysML and UML models into C++ and Java code."
    DTDFVocab:enables CodeGenerationService
]

// C6: Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service that processes ingested data and aligns it with the model hierarchy for validation."
    DTDFVocab:provides AssetDataInsight
]

instance ValidationAnalysisService : DTDFVocab:Service [
    base:desc "Service that verifies model fidelity against ingested data across multiple abstraction levels."
    DTDFVocab:provides ValidationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that executes Simulink and MontiArc automaton simulations for behavior verification."
    DTDFVocab:provides SimulationInsight
]

instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Service that generates executable C++ or Java code from SysML/UML specifications."
    DTDFVocab:provides CodeGenerationInsight
]

// C17: Insights
instance AssetDataInsight : DTDFVocab:Insight [
    base:desc "Insight on recovered contextual data from the physical asset."
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from continuous validation of model fidelity across abstraction levels."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight showing behavioral alignment of the twin with physical asset dynamics."
]

instance CodeGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating consistency of generated code with SysML/UML models."
]

// C10: Models
instance SysMLDesignModel : DTDFVocab:Model [
    base:desc "SysML model capturing functional and logical structures of the system."
    DTDFVocab:inputTo ModelRepositoryEnabler
]

instance MontiArcConnectorModel : DTDFVocab:Model [
    base:desc "MontiArc component‑connector view representing component interactions."
    DTDFVocab:inputTo ModelRepositoryEnabler
]

instance SimulinkBehaviorModel : DTDFVocab:Model [
    base:desc "Simulink model used to simulate the dynamic behavior of the twin."
    DTDFVocab:inputTo SimulationEnvironmentEnabler
]

instance AnalyticalCppModel : DTDFVocab:Model [
    base:desc "Analytical model implemented in C++ for code‑level simulation."
    DTDFVocab:inputTo SimulationEnvironmentEnabler
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle follows the MBSE multi‑level abstraction model described in Section II.B.1. Initial requirements are captured in the requirement layer using SysML requirement diagrams. Functional behaviour is expressed in the functional architecture layer through SysML activity and sequence diagrams, potentially enriched by MontiArc automaton or SysML state machines. The logical architecture is then articulated with ADLs (ACME, AADL, MontiArc) which provide component‑connector views and detailed interface definitions. Finally, at the product/technical layer the DT is instantiated as executable code – typically generated from SysML or MontiArc models and implemented in C++ or Java – and integrated with simulation environments such as MathWorks Simulink for dynamic validation. Transition between stages is managed by traceability links inherent in the MBSE toolchain (e.g., SysML requirement to function, to component, to code). Governance of the lifecycle relies on MBSE best practices, including version control of models, change management, and model‑to‑code consistency checks. This staged, traceable approach ensures that each abstraction level receives a dedicated representation, and that evolution from conception to deployment is orchestrated through rigorous documentation and tool support."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT specification in the document adheres to several widely accepted industry modeling standards. System representation is performed with SysML, a standardized systems modeling language that supports requirement, activity, sequence, and state machine diagrams. Component‑connector views are expressed using architecture description languages such as ACME, AADL, and MontiArc, each of which provides formal semantic descriptions of interfaces and interconnections. The integration of state‐machine based behavior is supported by SysML activity/state machine diagrams and MontiArc Automaton, enabling formal verification. Additionally, the document references SMArDT, an MBSE methodology that incorporates best‑practice artefacts aligned with functional safety and industrial safety standards, thus facilitating interoperability with existing engineering environments and compliance with established model‑based development guidelines."
]