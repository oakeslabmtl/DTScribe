// Enablers
instance SysMLToolEnabler : DTDFVocab:Enabler [
    base:desc "\"SysML for modeling\""
    DTDFVocab:enables StructuralModelingService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "\"MATLAB/Simulink for simulation\""
    DTDFVocab:enables SimulationService, FrictionEstimationService, IdentificationOptimizationService
]

instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "\"MQTT for live data streaming\""
    DTDFVocab:enables LiveDataStreamingService, AggregationVisualizationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "\"Asset Administration Shells (AAS) for asset description and semantic linking\""
    DTDFVocab:enables DataLinkingSemanticService
]

instance DashboardFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "\"Dashboard framework for visualization\""
    DTDFVocab:enables AggregationVisualizationService
]

// Services
instance StructuralModelingService : DTDFVocab:Service [
    base:desc "\"Service providing structural modeling insights using SysML\""
    DTDFVocab:provides StructuralModelInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "\"Service executing simulation of motor and gearbox dynamics in MATLAB Simulink\""
    DTDFVocab:provides SimulationResultInsight
]

instance FrictionEstimationService : DTDFVocab:Service [
    base:desc "\"Real‑time friction estimation combining white‑box and black‑box models\""
    DTDFVocab:provides FrictionParameterEstimationInsight, WearPatternIdentificationInsight
]

instance AggregationVisualizationService : DTDFVocab:Service [
    base:desc "\"Aggregation and visualization of measured and simulated data through a unified dashboard\""
    DTDFVocab:provides VisualizationInsight
]

instance IdentificationOptimizationService : DTDFVocab:Service [
    base:desc "\"Continuous identification and update of friction parameters for controller optimization\""
    DTDFVocab:provides ControllerTuningFeedbackAction, MaintenanceSchedulingRecommendationAction, ControllerPerformancePredictionInsight
]

instance DataLinkingSemanticService : DTDFVocab:Service [
    base:desc "\"Data linking and semantic support via Asset Administration Shells\""
    DTDFVocab:provides AssetLinkingInsight
]

instance LiveDataStreamingService : DTDFVocab:Service [
    base:desc "\"Live one‑way data flow from the physical robot to the digital shadow via MQTT\""
    DTDFVocab:provides LiveDataStreamingInsight
]

// Insights
instance StructuralModelInsight : DTDFVocab:Insight [
    base:desc "\"Structural insight derived from SysML-based model of the motor and gearboxes\""
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "\"Result insight from MATLAB Simulink simulation of the system\""
]

instance FrictionParameterEstimationInsight : DTDFVocab:Insight [
    base:desc "\"Estimation of friction parameters\""
]

instance WearPatternIdentificationInsight : DTDFVocab:Insight [
    base:desc "\"Identification of wear patterns\""
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "\"Visualization of measured and simulated data\""
]

instance AssetLinkingInsight : DTDFVocab:Insight [
    base:desc "\"Semantic linking of asset data via AAS\""
]

instance LiveDataStreamingInsight : DTDFVocab:Insight [
    base:desc "\"Live data streaming insight\""
]

instance ControllerPerformancePredictionInsight : DTDFVocab:Insight [
    base:desc "\"Data‑driven prediction of controller performance improvements\""
]

// Actions
instance ControllerTuningFeedbackAction : DTDFVocab:Action [
    base:desc "\"Updated feedback for controller tuning\""
    DTDFVocab:IsAutomatic true
]

instance MaintenanceSchedulingRecommendationAction : DTDFVocab:Action [
    base:desc "\"Maintenance scheduling recommendations\""
    DTDFVocab:IsAutomatic true
]

// Sensing Components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "\"Motor encoder mounted on the permanent‑magnet synchronous motor\""
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearwheelEncoder : DTDFVocab:SensingComponent [
    base:desc "\"Secondary encoder mounted behind the gearwheel gearbox\""
    DTDFVocab:producedData GearwheelPositionDataTransmitted
]

instance CurrentSensorIM : DTDFVocab:SensingComponent [
    base:desc "\"Current sensor measuring the motor current IM\""
    DTDFVocab:producedData IMDataTransmitted
]

// Data Transmitted
instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearwheelPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearwheelEncoder
]

instance IMDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensorIM
]

// Data (Measured)
instance IMData : DTDFVocab:Data [
    base:desc "\"Measured motor current IM\""
    DTDFVocab:fromData IMDataTransmitted
    DTDFVocab:inputTo MQTTEnabler
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "\"Measured motor encoder position\""
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo MQTTEnabler
]

instance GearwheelPositionData : DTDFVocab:Data [
    base:desc "\"Measured gearwheel encoder position\""
    DTDFVocab:fromData GearwheelPositionDataTransmitted
    DTDFVocab:inputTo MQTTEnabler
]

// Data Transmitted (Simulated)
instance SimulatedIMDataTransmitted : DTDFVocab:DataTransmitted [
    /* produced by simulation model - not attached to sensor */
]

instance SimulatedMotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    /* produced by simulation model */
]

instance SimulatedGearwheelPositionDataTransmitted : DTDFVocab:DataTransmitted [
    /* produced by simulation model */
]

instance SimulatedTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    /* produced by simulation model */
]

instance SimulatedAngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    /* produced by simulation model */
]

// Data (Simulated)
instance SimulatedIMData : DTDFVocab:Data [
    base:desc "\"Simulated motor current IM\""
    DTDFVocab:fromData SimulatedIMDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance SimulatedMotorPositionData : DTDFVocab:Data [
    base:desc "\"Simulated motor encoder position\""
    DTDFVocab:fromData SimulatedMotorPositionDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance SimulatedGearwheelPositionData : DTDFVocab:Data [
    base:desc "\"Simulated gearwheel encoder position\""
    DTDFVocab:fromData SimulatedGearwheelPositionDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance SimulatedTorqueData : DTDFVocab:Data [
    base:desc "\"Simulated torque τ of the motor and gearbox\""
    DTDFVocab:fromData SimulatedTorqueDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance SimulatedAngularVelocityData : DTDFVocab:Data [
    base:desc "\"Simulated angular velocity ω of the motor and gearbox\""
    DTDFVocab:fromData SimulatedAngularVelocityDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

// Models
instance StructuralModelMotorGearwheelCycloidal : DTDFVocab:Model [
    base:desc "\"SysML-based structural model of the motor, gearwheel, and cycloidal gearbox\""
    DTDFVocab:inputTo SysMLToolEnabler
]

instance MotorDynamicsSimulinkModel : DTDFVocab:Model [
    base:desc "\"MATLAB Simulink model of permanent‑magnet synchronous motor dynamics\""
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance GearwheelDynamicsSimulinkModel : DTDFVocab:Model [
    base:desc "\"MATLAB Simulink model of gearwheel gearbox dynamics\""
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance CycloidalGearboxSimulinkModel : DTDFVocab:Model [
    base:desc "\"MATLAB Simulink model of cycloidal gearbox dynamics\""
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance FrictionModelCoulombViscous : DTDFVocab:Model [
    base:desc "\"Coulomb–Viscous friction model integrated into simulation\""
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance FrictionModelStribeck : DTDFVocab:Model [
    base:desc "\"Stribeck friction model integrated into simulation\""
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance FrictionModelDahl : DTDFVocab:Model [
    base:desc "\"Dahl friction model integrated into simulation\""
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance FrictionModelLuGre : DTDFVocab:Model [
    base:desc "\"LuGre friction model integrated into simulation\""
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

// Components
instance FirstAxisRobot : DTDFVocab:Component [
    base:desc "\"First axis of the MABI MAX 100 six‑axis industrial robot\""
]

instance PermanentMagnetSynchronousMotor : DTDFVocab:Component [
    base:desc "\"Permanent‑magnet synchronous motor in the first axis\""
]

instance GearwheelGearbox : DTDFVocab:Component [
    base:desc "\"Gearwheel gearbox in the first axis\""
]

instance CycloidalGearbox : DTDFVocab:Component [
    base:desc "\"Cycloidal gearbox in the first axis\""
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time data acquisition and simulation; friction identification performed during operation; data streams and model execution occur at the same sampling frequency as sensor updates (typically tens to hundreds of Hz)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized DT consisting of a processing component that consumes physical sensor data via MQTT, applies simulation and friction models to produce output data traces, and exposes a unified dashboard; linked to the Asset via AAS, encapsulating engineering, simulation, and data calculation models within the digital shadow."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design stage (structural and behavior modeling with SysML), Simulation stage (Simulink models of motor and gearboxes, friction models), Operation stage (live monitoring, continuous friction identification, data collection)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fine‑grained traceability through originates-from associations; comparison of simulated data versus reference sensor data validates model accuracy; continuous identification of friction parameters mitigates uncertainties due to wear, load, and temperature; white‑box and black‑box models jointly improve fidelity; verification performed by overlaying simulated versus measured traces in the dashboard."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "One‑way MQTT protocol over TCP/IP connecting the robot’s data bus to the DT processing server; all sensor streams (current, encoder reads) are published to MQTT topics; DT subscribes to these topics in real time."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted on an on‑premises processing server within the factory network that receives MQTT data, runs Simulink models, and serves the visualization dashboard to engineers; the server may be a Windows/Linux machine configured for real‑time data processing."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML (ISO/IEC 19510) for system modeling, Asset Administration Shells (ISO/IEC 30141) for asset description, and adherence to the Digital Shadow Reference Model (SMArDT) as standardized framework; integration of IEC 6285/ISO 30141 for AAS; use of MDSE practices (RFLP, SPES)."
]