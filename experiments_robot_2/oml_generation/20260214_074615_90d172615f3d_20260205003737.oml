// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor providing the motor current I_M for the first axis"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder delivering the motor shaft angle"
    DTDFVocab:producedData MotorMountedEncoderDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder after the gearbox delivering the output shaft angle"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorMountedEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// C10: Data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Live stream of motor current I_M as an array"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance MotorMountedEncoderAngleData : DTDFVocab:Data [
    base:desc "Live stream of motor‑mounted encoder angle (rad) as an array"
    DTDFVocab:fromData MotorMountedEncoderDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance GearboxEncoderAngleData : DTDFVocab:Data [
    base:desc "Live stream of gearbox output encoder angle (rad) as an array"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MqttBroker
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque τ (Nm) calculated from motor current and motor parameters"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω (rad/s) obtained by differentiating encoder angles"
    DTDFVocab:fromData MotorMountedEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration α (rad/s²) obtained by differentiating angular velocity"
    DTDFVocab:fromData MotorMountedEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEngine
]

// C10: Models
instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Executable MATLAB/Simulink model of the permanent‑magnet synchronous motor"
    DTDFVocab:inputTo SimulinkEngine
]

instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "Executable MATLAB/Simulink model of the gear transmission and cycloidal gearbox"
    DTDFVocab:inputTo SimulinkEngine
]

instance FrictionSimulinkModel : DTDFVocab:Model [
    base:desc "Executable MATLAB/Simulink model of friction (Coulomb‑Viscous, Stribeck, Dahl, LuGre) for the axis"
    DTDFVocab:inputTo SimulinkEngine
]

instance AxisEngineeringModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams describing motor, gearboxes, and connections of the first axis"
    DTDFVocab:inputTo SimulinkEngine
]

// C11: Enablers
instance MqttBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker that streams live sensor data (I_M, encoder angles) from the robot to the digital shadow"
    DTDFVocab:enables RealTimeFrictionIdentificationService, DataTraceVisualizationService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment running the motor, gearbox and friction simulation models"
    DTDFVocab:enables RealTimeFrictionIdentificationService, FrictionParameterGenerationService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard application that visualises data traces and friction identification results"
    DTDFVocab:enables DataTraceVisualizationService
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Provides real‑time friction identification (static, kinetic, viscous) by comparing simulated and measured data"
    DTDFVocab:provides FrictionIdentificationInsight, UpdateControlAlgorithmAction
]

instance DataTraceVisualizationService : DTDFVocab:Service [
    base:desc "Visualises sensor and simulation data traces in an interactive dashboard"
    DTDFVocab:provides DataTraceVisualizationInsight, VisualizeDataTracesAction
]

instance FrictionParameterGenerationService : DTDFVocab:Service [
    base:desc "Generates updated friction model parameters for improving robot motion control accuracy"
    DTDFVocab:provides FrictionIdentificationInsight
]

// C17: Insights
instance FrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Identified friction parameters (static, kinetic, viscous) that can be used to refine robot control"
]

instance DataTraceVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of live sensor traces and simulated model outputs for operator monitoring"
]

// C17: Actions
instance UpdateControlAlgorithmAction : DTDFVocab:Action [
    base:desc "Updates the robot's control algorithm with newly identified friction parameters"
    DTDFVocab:IsAutomatic true
]

instance VisualizeDataTracesAction : DTDFVocab:Action [
    base:desc "Displays the latest data traces on the dashboard for operator analysis"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is defined as a one‑way data flow; no commands or data are sent back to the physical robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time operation synchronized with the robot’s motion; data are processed online during robot operation (up to the robot’s maximum speed of 75 °/s)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow follows the Digital Shadow Reference Model: a Purpose (FrictionDerivation) linked to an Asset (MABI robot first axis), Sources (sensor channels), Processing components (Simulation M, GW, GB) that consume data traces and produce simulated traces, and Models (engineering, simulation) that together form a coherent constellation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow is created in the design/engineering phase (SysML models, simulation models) and is employed during the operation phase for online model adaptation; thus it spans the designed and operated life‑cycle stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability is ensured by linking each data point to its source and processing model; friction models are validated by comparing simulated outputs with measured reference traces, allowing multi‑physics‑aware identification and continuous error correction."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow via the MQTT protocol; the digital shadow consumes these MQTT messages to populate data traces."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation employs the Asset Administration Shell (AAS) standard for asset representation and SysML, an ISO/OMG standard for system modeling."
]