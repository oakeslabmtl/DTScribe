// C2: Acting Components
instance ElectricServoMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Electric servo motor actuator used for precise motion control in industrial robotics applications, incorporating intrinsic models for joint torque dynamics and adaptive control capabilities to handle nonlinear friction phenomena."
]

instance HydraulicPneumaticActuator : DTDFVocab:ActingComponent [
    base:desc "Hydraulic/pneumatic actuator for high-force applications in industrial robotics, supporting precise motion control with adaptive control systems for nonlinear friction compensation."
]

instance AdaptiveControlSystem : DTDFVocab:ActingComponent [
    base:desc "Adaptive control system integrating probabilistic latent variable models for uncertainty-aware control, utilizing closed-loop feedback with real-time sensor data to dynamically adjust actuator behavior."
]

instance RemoteControlInterface : DTDFVocab:ActingComponent [
    base:desc "Digital shadow data flow interface enabling one-way communication from physical system to Digital Twin, supporting remote monitoring and potential bidirectional control via DT-generated commands."
]

// C3: Physical Sensing Components
instance JointPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High-precision joint encoder (≤0.1 mm accuracy) for position/velocity feedback in robotic systems, supporting high-frequency sampling (≥1 kHz) for dynamic motion analysis."
    DTDFVocab:producedData JointPositionDataTransmitted
]

instance ForceTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Force/torque sensor with ±1% full-scale accuracy (e.g., 10 N resolution for 1 kN range) for interaction force measurement, critical for friction modeling and adaptive control."
    DTDFVocab:producedData ForceTorqueDataTransmitted
]

instance StrainGaugeSensor : DTDFVocab:SensingComponent [
    base:desc "Strain gauge sensor for structural health monitoring and dynamic load analysis in manufacturing systems, supporting high-frequency data acquisition for vibration and stress analysis."
    DTDFVocab:producedData StrainDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor measuring temperature, humidity, and other contextual parameters to account for external influences on system behavior and process stability."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance JointPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointPositionEncoder
]

instance ForceTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ForceTorqueSensor
]

instance StrainDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StrainGaugeSensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance ProcessParameterDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InjectionMoldingMachineController
]

// C10: Models/Data
instance PhysicsBasedDynamicModel : DTDFVocab:Model [
    base:desc "White-box physics-based dynamic model implemented in Simulink for interpretable, predictable representation of system dynamics, particularly useful for capturing linear or semi-linear phenomena in robotic systems."
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance DataDrivenFrictionModel : DTDFVocab:Model [
    base:desc "Black-box machine learning model for approximating nonlinear friction relationships using intrinsic system data, leveraging scalable identification methods for real-time friction compensation."
    DTDFVocab:inputTo MachineLearningFramework
]

instance GeometricModel : DTDFVocab:Model [
    base:desc "Geometric model implemented in SysML for spatial representation of components and their interconnections, supporting 3D/4D visualization of manufacturing processes."
    DTDFVocab:inputTo SysMLModelingTool
]

instance BehavioralStateMachine : DTDFVocab:Model [
    base:desc "Behavioral model using SysML v1.7 state machines or MontiArc automata to describe system dynamics at the logical/functional architecture level for process control and decision-making."
    DTDFVocab:inputTo MontiArcTool
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Aggregated real-time sensor streams including joint encoders, force/torque sensors, and environmental data, processed for state data aggregation and model calibration."
    DTDFVocab:fromData JointPositionDataTransmitted, ForceTorqueDataTransmitted, StrainDataTransmitted, EnvironmentalDataTransmitted
    DTDFVocab:inputTo DataAggregationEngine
]

instance HistoricalOperationalData : DTDFVocab:Data [
    base:desc "Historical operational data including manufacturing traces, process logs, and maintenance records, abstracted for contextual analysis and trend identification."
    DTDFVocab:fromData ProcessParameterDataTransmitted
    DTDFVocab:inputTo DataHistorian
]

instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Simulation outputs from MathWorks Simulink or other tools used for validation and augmentation of physical data, supporting predictive analytics and virtual testing."
    DTDFVocab:fromData PhysicsBasedDynamicModel
    DTDFVocab:inputTo SimulationValidationEngine
]

// C11: Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML-based modeling tool for functional and logical architecture modeling, including Internal Block Diagrams (IBDs) to describe components, connectors, and interfaces."
    DTDFVocab:enables DigitalShadowReferenceModeling
]

instance AADLTool : DTDFVocab:Enabler [
    base:desc "AADL (Avionics Architecture Description Language) tool for component-level behavior and timing analysis, supporting detailed architectural modeling of physical systems."
    DTDFVocab:enables ComponentBehaviorAnalysis
]

instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc tool for component-based modeling and state machine implementation, enabling behavioral description of system dynamics."
    DTDFVocab:enables BehavioralModeling
]

instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for dynamic system simulation, including control systems, signal processing, and hybrid modeling for physics-based analysis."
    DTDFVocab:enables PhysicsBasedSimulation
]

instance MachineLearningFramework : DTDFVocab:Enabler [
    base:desc "AI/ML framework for predictive analytics, defect prediction, and parameter optimization using machine learning models (e.g., random forests, neural networks)."
    DTDFVocab:enables PredictiveMaintenanceModel
]

instance DataAggregationEngine : DTDFVocab:Enabler [
    base:desc "Engine for aggregating and abstracting raw sensor data into meaningful traces, tailored to specific purposes like friction modeling or production planning."
    DTDFVocab:enables DigitalShadowDataAggregation
]

instance DigitalShadowReferenceModel : DTDFVocab:Enabler [
    base:desc "UML class diagram-based framework for contextual data aggregation, enabling purpose-driven analytics without autonomous operation."
    DTDFVocab:enables DigitalShadowAnalytics
]

instance OPCUAProtocol : DTDFVocab:Enabler [
    base:desc "OPC UA protocol for industrial automation and data exchange, enabling high-frequency, reliable communication between physical systems and Digital Twin components."
    DTDFVocab:enables RealTimeDataExchange
]

// C6: Services
instance RealTimeStateTrackingService : DTDFVocab:Service [
    base:desc "Service for continuous monitoring of physical system states (e.g., machine health, process variables) via one-way data flows from sensors to the Digital Twin."
    DTDFVocab:provides MachineHealthInsight, ProcessVariableInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Service for identifying deviations from nominal operating conditions using time-series analysis or machine learning models."
    DTDFVocab:provides AnomalyAlertAction, RootCauseAnalysisInsight
]

instance ProcessOptimizationService : DTDFVocab:Service [
    base:desc "Service for dynamic adjustment of injection molding parameters (e.g., injection speed, cooling time) to minimize defect rates or energy consumption."
