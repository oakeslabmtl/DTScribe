instance InjectionMoldingMachineController : DTDFVocab:Component [
    base:desc "Controller system for injection molding machine managing process parameters and coordinating with sensors and actuators."
]

instance DataHistorian : DTDFVocab:Enabler [
    base:desc "Database system for storing and managing historical operational data for trend analysis and long-term pattern recognition."
    DTDFVocab:enables DigitalShadowAnalytics
]

instance SimulationValidationEngine : DTDFVocab:Enabler [
    base:desc "Engine for validating simulation outputs against real-world data to ensure model accuracy and reliability."
    DTDFVocab:enables PhysicsBasedSimulation
]

instance DigitalShadowReferenceModeling : DTDFVocab:Service [
    base:desc "Service for modeling and managing digital shadow data structures to support purpose-driven analytics."
    DTDFVocab:provides DigitalShadowAnalytics
]

instance ComponentConnectorModeling : DTDFVocab:Service [
    base:desc "Service for modeling component interactions and data flows within the system architecture."
    DTDFVocab:provides ComponentBehaviorAnalysis
]

instance PhysicsBasedSimulation : DTDFVocab:Service [
    base:desc "Service providing physics-based simulation capabilities for system behavior analysis."
    DTDFVocab:provides PhysicsBasedSimulation
]

instance ControlSystemSimulation : DTDFVocab:Service [
    base:desc "Service for simulating control system behavior and performance under various conditions."
    DTDFVocab:provides ControlParameterAdjustmentAction
]

instance PredictiveMaintenanceModel : DTDFVocab:Model [
    base:desc "Model for predicting maintenance needs based on historical data and current system conditions."
    DTDFVocab:inputTo MachineLearningFramework
]

instance DefectPredictionModel : DTDFVocab:Model [
    base:desc "Model for predicting potential defects in manufacturing processes using machine learning techniques."
    DTDFVocab:inputTo MachineLearningFramework
]

instance DigitalShadowDataAggregation : DTDFVocab:Service [
    base:desc "Service for aggregating and organizing digital shadow data for analysis and decision support."
