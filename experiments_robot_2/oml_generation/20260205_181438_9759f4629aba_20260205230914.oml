]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Service for forecasting machine failures or component wear using historical data, sensor trends, and degradation models."
    DTDFVocab:provides MaintenanceScheduleAction, RemainingUsefulLifeInsight
]

instance ClosedLoopControlService : DTDFVocab:Service [
    base:desc "Service enabling feedback control loops by processing real-time data and sending commands to PLCs or actuators for autonomous system management."
