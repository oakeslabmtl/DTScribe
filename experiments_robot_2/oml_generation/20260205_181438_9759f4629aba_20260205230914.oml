]

instance RootCauseAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight enabling root-cause analysis of detected anomalies through traceable data lineage and model validation."
]

instance OptimizationRecommendationAction : DTDFVocab:Action [
    base:desc "Automated recommendation for process parameter adjustments to improve efficiency or product quality."
    DTDFVocab:IsAutomatic true
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight analyzing energy consumption patterns and providing recommendations for optimization."
]

instance MaintenanceScheduleAction : DTDFVocab:Action [
    base:desc "Automated scheduling of maintenance activities based on predicted component wear and failure risks."
    DTDFVocab:IsAutomatic true
]

instance RemainingUsefulLifeInsight : DTDFVocab:Insight [
    base:desc "Insight estimating remaining useful life of critical components using hybrid physics-based and data-driven models."
]

instance ActuatorCommandAction : DTDFVocab:Action [
    base:desc "Automatic generation of control commands for actuators based on Digital Twin analysis and real-time feedback."
    DTDFVocab:IsAutomatic true
]

instance ControlParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of control parameters to maintain system stability under varying conditions."
    DTDFVocab:IsAutomatic true
]

instance ProductionLineVisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization of the entire production line, including real-time status of all connected machines and components."
]

instance ProcessCycleVisualizationInsight : DTDFVocab:Insight [
    base:desc "4D visualization of injection molding cycles showing temporal progression of process parameters and quality metrics."
