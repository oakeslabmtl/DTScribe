]

// C17: Insights/Actions
instance MachineHealthInsight : DTDFVocab:Insight [
    base:desc "Insight providing real-time health status of manufacturing machines, including vibration analysis and temperature profiling."
]

instance ProcessVariableInsight : DTDFVocab:Insight [
    base:desc "Insight tracking key process variables such as pressure, flow rate, and cycle time for injection molding operations."
]

instance AnomalyAlertAction : DTDFVocab:Action [
    base:desc "Automatic alert generation for detected anomalies in system behavior, triggering immediate investigation."
