import DTDFVocab from "http://www.example.org/DTDFVocab"
instance RobotAxisSensors : DTDFVocab:SensingComponent [
    base:desc "Sensors providing real-time feedback for MABI MAX 100 robot axes"
    DTDFVocab:producedData RobotSensorDataTransmission
]
instance RobotSensorDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotAxisSensors
]
instance RobotSensorData : DTDFVocab:Data [
    base:desc "Time series sensor data transmitted via MQTT protocol from physical robot sensors"
    DTDFVocab:fromData RobotSensorDataTransmission
    DTDFVocab:inputTo ProcessingComponent
]
instance MotorActuator : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving the first vertical axis of MABI MAX 100 robot"
]
instance MechanicalLinkages : DTDFVocab:Component [
    base:desc "Mechanical linkages enabling precise movement in MABI MAX 100 robot"
]
instance SysML_BDD : DTDFVocab:Model [
    base:desc "SysML Block Definition Diagram for MABI MAX 100 system requirements and functional architecture"
    DTDFVocab:inputTo SysMLTool
]
instance SysML_IBD : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram for MABI MAX 100 component connections"
    DTDFVocab:inputTo SysMLTool
]
instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME architecture description for component & connector perspectives"
    DTDFVocab:inputTo ACMETool
]
instance AADLModel : DTDFVocab:Model [
    base:desc "AADL architecture description for component & connector perspectives"
    DTDFVocab:inputTo AADLTool
]
instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description for component & connector perspectives"
    DTDFVocab:inputTo MontiArcTool
]
instance SysML_StateMachine : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine for behavioral aspects of robot axes"
    DTDFVocab:inputTo SysMLTool
]
instance MontiArcAutomaton : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling of robot control"
    DTDFVocab:inputTo MontiArcTool
]
instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink analytical model for multi-physics simulation"
    DTDFVocab:inputTo SimulinkTool
]
instance FrictionWhiteBoxModel : DTDFVocab:Model [
    base:desc "White-box model for joint friction behavior analysis"
    DTDFVocab:inputTo ProcessingComponent
]
instance FrictionBlackBoxModel : DTDFVocab:Model [
    base:desc "Black-box model for joint friction behavior analysis"
    DTDFVocab:inputTo ProcessingComponent
]
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML-based tool for multi-level system modeling (requirements, functional, logical, technical layers)"
    DTDFVocab:enables SystemModelingService
]
instance ACMETool : DTDFVocab:Enabler [
    base:desc "ACME ADL for component & connector architecture specification"
    DTDFVocab:enables ComponentArchitectureService
]
instance AADLTool : DTDFVocab:Enabler [
    base:desc "AADL ADL for component & connector architecture specification"
    DTDFVocab:enables ComponentArchitectureService
]
instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc ADL for component & connector architecture specification"
    DTDFVocab:enables ComponentArchitectureService
]
instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for behavior modeling and simulation"
    DTDFVocab:enables SimulationService
]
instance CppTool : DTDFVocab:Enabler [
    base:desc "C++ programming language for implementation of digital twin components"
    DTDFVocab:enables ImplementationService
]
instance JavaTool : DTDFVocab:Enabler [
    base:desc "Java programming language for implementation of digital twin components"
    DTDFVocab:enables ImplementationService
]
instance ProcessingComponent : DTDFVocab:Enabler [
    base:desc "Analytics component processing sensor data to derive friction insights and detect loss"
    DTDFVocab:enables FrictionIdentificationService, RealTimeMonitoringService, PredictiveMaintenanceService
]
instance SystemModelingService : DTDFVocab:Service [
    base:desc "System modeling service for requirements, functional, logical, and technical layers using structured abstraction levels"
    DTDFVocab:provides SystemModelInsight
]
instance ComponentArchitectureService : DTDFVocab:Service [
    base:desc "Component and connector architecture service using ADLs (ACME, AADL, MontiArc)"
    DTDFVocab:provides ComponentArchitectureInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Multi-physics simulation service using MathWorks Simulink"
    DTDFVocab:provides SimulationInsight
]
instance ImplementationService : DTDFVocab:Service [
    base:desc "Implementation service using C++ and Java for digital twin components"
    DTDFVocab:provides ImplementationInsight
]
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous multi-physics-aware identification of joint friction using white-box and black-box models"
    DTDFVocab:provides FrictionBehaviorInsight, FrictionLossDetectionInsight
]
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring via dashboard visualization for robot status"
    DTDFVocab:provides RealTimeMonitoringInsight
]
instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance capabilities for the MABI MAX 100 robot"
    DTDFVocab:provides PredictiveMaintenanceInsight
]
instance SystemModelInsight : DTDFVocab:Insight [
    base:desc "Structured abstraction levels for requirements, functional, logical, and technical layers"
]
instance ComponentArchitectureInsight : DTDFVocab:Insight [
    base:desc "Component and connector architecture specifications via ADLs"
]
instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results for multi-physics behavior analysis"
]
instance ImplementationInsight : DTDFVocab:Insight [
    base:desc "Implementation details of digital twin components in C++ and Java"
]
instance FrictionBehaviorInsight : DTDFVocab:Insight [
    base:desc "Derived insights on joint friction behavior for robot control accuracy improvement"
]
instance FrictionLossDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of friction loss in robot joints to prevent operational failures"
]
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of robot status via dashboard visualization for decision support"
]
instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance alerts for robot components based on analysis"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for streaming sensor time series data between physical assets and the digital shadow. No details on network topology, bandwidth, latency, reliability, redundancy, or security protocols are specified."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with Asset Administration Shells (AAS) for semantic interoperability, SysML for system modeling, UML for reference model diagrams (e.g., Fig. 1), and MQTT protocol for real-time data streaming between physical and digital components."
]