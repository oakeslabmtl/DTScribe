// C3: Physical sensing components
instance MotorEncoderPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Rotary encoder mounted on motor shaft providing angular position of the motor."
    DTDFVocab:producedData MotorPositionTrace
]

instance GearboxEncoderPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Rotary encoder mounted on gearbox shaft providing angular position of the gearbox."
    DTDFVocab:producedData GearboxPositionTrace
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor mounted on motor providing motor current I_M."
    DTDFVocab:producedData MotorCurrentTrace
]

// C4: Physical-to-virtual interaction
instance MotorPositionTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderPositionSensor
]

instance GearboxPositionTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderPositionSensor
]

instance MotorCurrentTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Models/Data
instance MotorPositionData : DTDFVocab:Data [
    base:desc "Angular position of the motor shaft transmitted over MQTT."
    DTDFVocab:fromData MotorPositionTrace
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Angular position of the gearbox shaft transmitted over MQTT."
    DTDFVocab:fromData GearboxPositionTrace
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Motor current I_M transmitted over MQTT."
    DTDFVocab:fromData MotorCurrentTrace
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance OutputPositionData : DTDFVocab:Data [
    base:desc "Output shaft position r_out obtained from sensor data."
    DTDFVocab:fromData MotorPositionTrace
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance SimulatedMotorPositionData : DTDFVocab:Data [
    base:desc "Simulated motor position trace from Simulink motor dynamics model."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance SimulatedGearboxPositionData : DTDFVocab:Data [
    base:desc "Simulated gearbox position trace from Simulink gearwheel dynamics model."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance SimulatedOutputPositionData : DTDFVocab:Data [
    base:desc "Simulated output shaft position trace from Simulink cycloidal gearbox model."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque τ calculated by the dynamics model."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω calculated by the dynamics model."
    DTDFVocab:inputTo ProcessingComponentEnabler
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML (v1.7) modeling tool used for structural SysML of Axis, Motor, Gearbox and CycloidalGearbox."
    DTDFVocab:enables FrictionIdentificationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink used for executable simulation of motor, gearwheel, and cycloidal gearbox dynamics."
    DTDFVocab:enables ModelCalibrationService, FrictionIdentificationService
]

instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol engine for real-time streaming of sensor data from the physical robot."
    DTDFVocab:enables DataLinkAggregationService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for exchanging metadata between the digital twin and the physical asset."
    DTDFVocab:enables FrictionParameterProvisionService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard framework for real-time visualization of data and insights."
    DTDFVocab:enables DashboardVisualizationService
]

instance ProcessingComponentEnabler : DTDFVocab:Enabler [
    base:desc "Custom processing component that links sensor streams to simulation models."
    DTDFVocab:enables FrictionIdentificationService, ModelCalibrationService, DataLinkAggregationService
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification and updating of joint friction models (white-box and black-box) using sensor streams."
    DTDFVocab:provides FrictionParameterUpdateAction, WearTrendInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Real-time visualization of sensor and simulated data traces on the dashboard."
    DTDFVocab:provides RealTimeDashboardInsight
]

instance ResidualAnalysisService : DTDFVocab:Service [
    base:desc "Multi-physics aware residual analysis for controller tuning."
    DTDFVocab:provides ResidualAnalysisInsight
]

instance DataLinkAggregationService : DTDFVocab:Service [
    base:desc "Aggregation and linkage of sensor data streams for downstream processing."
    DTDFVocab:provides DataAggregationInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Simulation-based calibration of structural and dynamic models."
    DTDFVocab:provides ModelCalibrationInsight
]

instance FrictionParameterProvisionService : DTDFVocab:Service [
    base:desc "Provision of calibrated friction parameters to improve robot motion accuracy."
    DTDFVocab:provides FrictionParameterUpdateAction
]

// C17: Insights/Actions
instance FrictionParameterUpdateAction : DTDFVocab:Action [
    base:desc "Action to update robot controller with new friction parameters for improved motion accuracy."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceSchedulingSuggestionAction : DTDFVocab:Action [
    base:desc "Action suggesting maintenance scheduling based on wear trend analysis."
    DTDFVocab:IsAutomatic false
]

instance WearTrendInsight : DTDFVocab:Insight [
    base:desc "Insight indicating wear trends detected from continuous data monitoring."
]

instance ResidualAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight into residuals from multi-physics analysis for controller tuning."
]

instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Insight on real-time status of system based on dashboard data streams."
]

instance DataAggregationInsight : DTDFVocab:Insight [
    base:desc "Insight on data linkage and aggregation across sensor streams."
]

instance ModelCalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight on calibration status of simulation models."
]

// C5: Components
instance AxisStructuralComponent : DTDFVocab:Component [
    base:desc "Structural SysML model of the first rotary axis of the MABI MAX 100 robot."
]

instance MotorStructuralComponent : DTDFVocab:Component [
    base:desc "Structural SysML model of the permanent-magnet synchronous motor."
]

instance GearboxStructuralComponent : DTDFVocab:Component [
    base:desc "Structural SysML model of the gearwheel gearbox."
]

instance CycloidalGearboxStructuralComponent : DTDFVocab:Component [
    base:desc "Structural SysML model of the cycloidal gearbox."
]

instance SimulinkProcessingComponent : DTDFVocab:Component [
    base:desc "Simulink based processing component that executes simulation models."
]

// C18: Environment
instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains AxisStructuralComponent, MotorStructuralComponent, GearboxStructuralComponent, CycloidalGearboxStructuralComponent, SimulinkProcessingComponent
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data streaming (millisecond granularity) via MQTT; simulation models run synchronously with physical operation to produce continuous prediction traces; continuous friction model updating during the robot’s operating cycle"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration of data sources (sensors) feeding into a processing component; the component runs simulation models to produce output traces; these traces are aggregated into the digital shadow (purpose FrictionDerivation) and exposed via an MQTT‑based dashboard, all coordinated through the AAS for contextual information"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin spans the design (structural SysML models), the manufactured (simulation models of motor and gearboxes), and the operated stages (real‑time data acquisition and friction identification during normal robot use)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Continuous real‑time identification compensates for wear, temperature and load variations; traceability of each data point back to its source and processing stage; validation performed by comparing simulated and measured torque and angular velocity; uncertainties arise from unmeasured intermediate gearwheel outputs and from model approximations of friction physics"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol used for bidirectional data transmission between the physical robot’s sensors and the digital twin’s processing component, with Asset Administration Shell providing contextual metadata within the same network topology"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Utilizes SysML for modeling, Asset Administration Shell (AAS) for semantic asset description, and MQTT as the messaging protocol – all conforming to industry standards for interoperability"
]