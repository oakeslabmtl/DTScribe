// C3: Physical sensing components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Primary incremental position encoder mounted directly on the PMSM shaft to capture motor rotational displacement"
    DTDFVocab:producedData MotorEncoderMessage
]

instance GearboxOutputEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary incremental position encoder positioned behind the gearbox to measure output shaft position, enabling compensation for gear slip and backlash"
    DTDFVocab:producedData GearboxEncoderMessage
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor collecting input current from the motor drive electronics, streamed over MQTT"
    DTDFVocab:producedData CurrentMessage
]

// C4: Physical-to-virtual interaction
instance MotorEncoderMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxEncoderMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxOutputEncoder
]

instance CurrentMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Models/Data
instance MotorPositionData : DTDFVocab:Data [
    base:desc "Time‑series motor shaft position data derived from the primary encoder"
    DTDFVocab:fromData MotorEncoderMessage
    DTDFVocab:inputTo MQTTGateway
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Time‑series gearbox output shaft position data derived from the secondary encoder"
    DTDFVocab:fromData GearboxEncoderMessage
    DTDFVocab:inputTo MQTTGateway
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series motor current data derived from the motor drive electronics"
    DTDFVocab:fromData CurrentMessage
    DTDFVocab:inputTo MQTTGateway
]

instance PositionControlModel : DTDFVocab:Model [
    base:desc "SysML functional model capturing the closed‑loop speed/position control algorithm implemented in the motor drive"
    DTDFVocab:inputTo SimulationEngine
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation runtime environment interfacing with MathWorks Simulink to execute continuous‑time models"
    DTDFVocab:enables SimulationService
]

// C6: Services
instance EncoderDataIngestionService : DTDFVocab:Service [
    base:desc "Service ingesting position data over MQTT, aligning primary and secondary encoder streams and feeding data to the digital twin"
    DTDFVocab:provides EncoderPositionInsight
]

instance ActuationCurrentMonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring motor current feeds obtained via MQTT for real‑time performance assessment"
    DTDFVocab:provides ActuatorCurrentInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service executing the position control model in simulation and exposing high‑fidelity results to the twin"
    DTDFVocab:provides SimulationAnalysisInsight
]

// C17: Insights/Actions
instance EncoderPositionInsight : DTDFVocab:Insight [
    base:desc "Insight derived from cross‑checking motor shaft and gearbox encoder data, highlighting positional fidelity and error detection"
]

instance ActuatorCurrentInsight : DTDFVocab:Insight [
    base:desc "Insight on motor current levels, enabling early detection of over‑current or overheating conditions"
]

instance SimulationAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insight from simulating the drive control loop, providing validation data for design refinement"
]

// C11: Enablers
instance MQTTGateway : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating real‑time streaming of sensor data from the physical drive to the digital twin"
    DTDFVocab:enables EncoderDataIngestionService, ActuationCurrentMonitoringService
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle is organised into four abstraction layers—requirements, functional architecture, logical architecture, and product/technical. Each layer is described with an appropriate model‑based engineering notation: SysML for requirements and functional models, ACME, AADL, and MontiArc for logical component–connector architectures, and Simulink (together with C++/Java implementation artefacts) for product‑level behaviours. Transitions between layers are guided by system‑engineering methodologies such as RFLP, OOSEM, SPES and SMArDT, which provide traceability and mapping rules to preserve consistency across layers."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data from the physical system are transmitted to the digital twin using the MQTT protocol over an internal network.  The document does not provide additional details on network topology, bandwidth, latency, redundancy, or security mechanisms."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system conforms to industry standards including SysML v1.7 for functional and behavioural modelling, UML for broader system design, the Asset Administration Shell (AAS) specification for semantic interoperability, and MQTT as the messaging protocol for real‑time data exchange."
]