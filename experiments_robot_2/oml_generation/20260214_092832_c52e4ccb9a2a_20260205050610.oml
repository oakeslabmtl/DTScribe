// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) mounted on the motor shaft"
    DTDFVocab:producedData IMTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor position encoder mounted on the motor shaft"
    DTDFVocab:producedData R_MTransmitted
]

instance GearBoxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Gearbox position encoder mounted behind the gearbox"
    DTDFVocab:producedData R_GTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Output angle sensor measuring the joint's angular position"
    DTDFVocab:producedData R_OutTransmitted
]

// C4: Physical-to-virtual interaction
instance IMTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance R_MTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance R_GTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearBoxEncoderSensor
]

instance R_OutTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

// C10: Models/Data
// Engineering models (SysML)
instance AxisSysMLModel : DTDFVocab:Model [
    base:desc "SysML model of the first axis BDD/IBD"
    DTDFVocab:inputTo SysMLModelingTool
]

instance MotorSysMLModel : DTDFVocab:Model [
    base:desc "SysML model of the permanent‑magnet synchronous motor"
    DTDFVocab:inputTo SysMLModelingTool
]

instance GearBoxSysMLModel : DTDFVocab:Model [
    base:desc "SysML model of the low‑ratio cycloidal gearbox"
    DTDFVocab:inputTo SysMLModelingTool
]

// Data calculation models (Simulink)
instance MotorBehaviorSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink executable model for motor behavior"
    DTDFVocab:inputTo SimulinkSimulationEnvironment
]

instance GearBoxBehaviorSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink executable model for gearbox behavior"
    DTDFVocab:inputTo SimulinkSimulationEnvironment
]

// Simulation models (Simulink)
instance IdealMotionSimulationModel : DTDFVocab:Model [
    base:desc "Simulink model for ideal joint motion without friction"
    DTDFVocab:inputTo SimulinkSimulationEnvironment
]

instance FrictionIncludedSimulationModel : DTDFVocab:Model [
    base:desc "Simulink model that includes white‑box friction models (Coulomb‑Viscous, Stribeck, Dahl, LuGre)"
    DTDFVocab:inputTo SimulinkSimulationEnvironment
]

// Data traces (measured)
instance IMTrace : DTDFVocab:Data [
    base:desc "Measured motor current trace I_M"
    DTDFVocab:fromData IMTransmitted
    DTDFVocab:inputTo DataAggregationModule, FrictionProcessingComponent
]

instance MotorEncoderTrace : DTDFVocab:Data [
    base:desc "Measured motor encoder angle trace r_M"
    DTDFVocab:fromData R_MTransmitted
    DTDFVocab:inputTo DataAggregationModule, FrictionProcessingComponent
]

instance GearBoxEncoderTrace : DTDFVocab:Data [
    base:desc "Measured gearbox encoder angle trace r_G"
    DTDFVocab:fromData R_GTransmitted
    DTDFVocab:inputTo DataAggregationModule, FrictionProcessingComponent
]

instance OutputAngleTrace : DTDFVocab:Data [
    base:desc "Measured output joint angle trace r_out"
    DTDFVocab:fromData R_OutTransmitted
    DTDFVocab:inputTo DataAggregationModule, FrictionProcessingComponent
]

// Data traces (simulated)
instance SimulatedMotorEncoderTrace : DTDFVocab:Data [
    base:desc "Simulated motor encoder angle via friction‑included model r_M̂"
    DTDFVocab:inputTo SimulinkSimulationEnvironment
    DTDFVocab:inputTo DataAggregationModule, FrictionProcessingComponent
]

instance SimulatedGearBoxEncoderTrace : DTDFVocab:Data [
    base:desc "Simulated gearbox encoder angle via friction‑included model r_Ĝ"
    DTDFVocab:inputTo SimulinkSimulationEnvironment
    DTDFVocab:inputTo DataAggregationModule, FrictionProcessingComponent
]

instance SimulatedOutputAngleTrace : DTDFVocab:Data [
    base:desc "Simulated joint output angle via friction‑included model r_out̂"
    DTDFVocab:inputTo SimulinkSimulationEnvironment
    DTDFVocab:inputTo DataAggregationModule, FrictionProcessingComponent
]

// C11: Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML modeling tool used for engineering models"
    // DTDFVocab:enables AxisSysMLModel, MotorSysMLModel, GearBoxSysMLModel
]

instance SimulinkSimulationEnvironment : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for executing simulation models"
    // DTDFVocab:enables MotorBehaviorSimulinkModel, GearBoxBehaviorSimulinkModel, IdealMotionSimulationModel, FrictionIncludedSimulationModel
]

instance MQTTSimpleBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating one‑way live data streaming from PT to DT"
    // DTDFVocab:enables IMTrace, MotorEncoderTrace, GearBoxEncoderTrace, OutputAngleTrace
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "AAS for asset description and data linking"
]

instance UnifiedDashboardUI : DTDFVocab:Enabler [
    base:desc "Unified dashboard UI to visualize measured and simulated data"
    DTDFVocab:enables DashboardVisualizationService
]

instance DataAggregationModule : DTDFVocab:Enabler [
    base:desc "Data aggregation and calculation module linking physical data to virtual models"
    // DTDFVocab:enables FrictionProcessingComponent
]

instance FrictionProcessingComponent : DTDFVocab:Enabler [
    base:desc "Processing component executing white‑box (Coulomb‑Viscous, Stribeck, Dahl, LuGre) and black‑box friction models produces refined friction parameters and motion control profiles"
    DTDFVocab:enables FrictionIdentificationService
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service that performs continuous friction identification and generates refined parameters"
    DTDFVocab:provides RefinedFrictionParametersInsight, WearDetectionInsight, MotionControlProfilesInsight, SimulationDeviationVisualizationInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Service providing real‑time visualization of measured and simulated data traces"
]

// C17: Insights/Actions
instance RefinedFrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Refined friction parameters for motor and gearbox derived from live data and simulation"
]

instance WearDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of wear or tool change effects on friction based on deviations between measured and simulated data"
]

instance MotionControlProfilesInsight : DTDFVocab:Insight [
    base:desc "Generation of improved motion control profiles to enhance positioning accuracy"
]

instance SimulationDeviationVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of simulation‑measurement deviations for operator decision‑making"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time, continuous (one‑way) data streaming and model updates synchronized with the robot’s operational cycle; the digital shadow processes live data during operation and feeds the updated friction models back into the motion controller"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Digital shadow comprising engineering, simulation, and data‑calculation models linked via an AAS; data traces are collected from the PT sensors, processed by the processing component, and visualized in the dashboard; the constellation is orchestrated by a one‑way data flow from PT to DT, with all components deployed in a centralized environment"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (structural and dynamic modelling in SysML), Manufacture (implementation of hardware, AAS integration), Operation (continuous data acquisition, real‑time nominal and friction model identification, and ongoing calibration)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of each data trace back to its source (sensor or model), validation of friction models against measured data, continuous identification and refinement of white‑box and black‑box friction parameters, use of simulation models with known motor constants, and uncertainty mitigation through combined modelling approaches"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Digital shadow receives data from the PT via MQTT broker (one‑way publish/subscribe), with data payloads formatted as JSON or binary streams; no bidirectional control commands are sent back to the PT within this model"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML, AAS, and MQTT standards for modeling, asset description, and data exchange"
]