// C3: Physical sensing components
instance JointAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Collects high-precision joint angle measurements from MABI MAX 100 robot's mechanical joints for dynamic load handling analysis."
    DTDFVocab:producedData JointAngleDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors real-time motor current readings to detect operational anomalies and friction effects in the robot's gearboxes."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance OperationalStateLogger : DTDFVocab:SensingComponent [
    base:desc "Records operational logs including environmental parameters and performance metrics for contextual data trace aggregation."
    DTDFVocab:producedData OperationalStateDataTransmitted
]

instance EnvironmentalParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Measures environmental conditions (temperature, humidity) affecting the robot's precision and wear characteristics."
    DTDFVocab:producedData EnvironmentalParameterDataTransmitted
]

// C4: Physical-to-virtual interaction
instance JointAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointAngleSensor
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance OperationalStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalStateLogger
]

instance EnvironmentalParameterDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalParameterSensor
]

// C10: Models/Data
instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based functional architecture model representing requirements, logical architecture, and behavioral modeling (state machines) for MABI MAX 100."
    DTDFVocab:inputTo SysMLEnabler, MontiArcEnabler
]

instance MontiArcComponentConnectorModel : DTDFVocab:Model [
    base:desc "MontiArc-based component-connector architecture model for system decomposition with MontiArc Automaton for behavioral modeling."
    DTDFVocab:inputTo MontiArcEnabler
]

instance SimulinkBehavioralSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for detailed behavioral simulation of robot dynamics, friction effects, and control logic."
    DTDFVocab:inputTo SimulinkEnabler
]

instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "UML-based class diagram framework from Digital Shadow Reference Model for structuring contextual data traces in manufacturing."
    DTDFVocab:inputTo DataAggregationEnabler
]

instance RobotDynamicsModel : DTDFVocab:Model [
    base:desc "High-fidelity model representing nonlinear dynamics, wear, and operational variability of MABI MAX 100's motors, gearboxes, and joints."
    DTDFVocab:inputTo SimulinkEnabler, CppJavaEnabler
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Aggregated and abstracted sensor readings, operational logs, and environmental parameters from physical system."
    DTDFVocab:fromData JointAngleDataTransmitted, MotorCurrentDataTransmitted, OperationalStateDataTransmitted, EnvironmentalParameterDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler, SimulinkEnabler
]

instance PreprocessedSensorData : DTDFVocab:Data [
    base:desc "Transformed, noise-reduced, and validated sensor data ready for integration into digital twin models."
    DTDFVocab:fromData JointAngleDataTransmitted, MotorCurrentDataTransmitted
    DTDFVocab:inputTo CppJavaEnabler
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML (v1.7) framework for requirements, functional/logical architecture, and behavioral modeling (state machines)."
    DTDFVocab:enables BehavioralModelingService, SystemMonitoringService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc architecture description language for component-connector decomposition with MontiArc Automaton for behavioral modeling."
    DTDFVocab:enables ComponentDecompositionService, BehavioralModelingService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed behavioral simulation and dynamic system analysis of robot control algorithms."
    DTDFVocab:enables PredictiveAnalysisService
]

instance CppJavaEnabler : DTDFVocab:Enabler [
    base:desc "General-purpose languages (C++, Java) for custom logic, control algorithms, and data processing within the Digital Twin."
    DTDFVocab:enables CustomLogicExecutionService
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "Digital Shadow Reference Model framework for aggregating and abstracting contextual data traces from physical system."
    DTDFVocab:enables DataAggregationService
]

instance MBSEMethodologiesEnabler : DTDFVocab:Enabler [
    base:desc "MBSE methodologies (RFLP, OOSEM, SPES, SMArDT) guiding multi-layered modeling process for cross-tool consistency."
    DTDFVocab:enables SystemIntegrationService
]

// C6: Services
instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Executable simulation models replicating robot dynamics, friction effects, and control logic in real time."
    DTDFVocab:provides RobotBehaviorInsight
]

instance SystemMonitoringService : DTDFVocab:Service [
    base:desc "Automated bidirectional data synchronization between physical robot and digital twin for real-time state alignment."
    DTDFVocab:provides SystemStateInsight, OperationalAnomalyInsight
]

instance PredictiveAnalysisService : DTDFVocab:Service [
    base:desc "Real-time analysis of system performance under varying loads using Simulink behavioral models."
    DTDFVocab:provides PerformancePredictionInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Processing of contextual data traces (sensor inputs, motor currents, joint angles) into actionable insights."
    DTDFVocab:provides DataQualityInsight
]

instance ComponentDecompositionService : DTDFVocab:Service [
    base:desc "Modular decomposition of system into components with distinct responsibilities using MontiArc ADL."
    DTDFVocab:provides ComponentInterdependencyInsight, SystemArchitectureInsight
]

instance CustomLogicExecutionService : DTDFVocab:Service [
    base:desc "Execution of custom control algorithms and data processing logic using C++/Java."
    DTDFVocab:provides CustomLogicInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Dashboard-based interfaces for monitoring operational metrics, anomalies, and predictive insights."
    DTDFVocab:provides VisualMonitoringInsight
]

instance SystemIntegrationService : DTDFVocab:Service [
    base:desc "Ensures cross-tool consistency for stakeholders with diverse perspectives (engineers, operators)."
    DTDFVocab:provides IntegrationConsistencyInsight
]

// C17: Insights/Actions
instance RobotBehaviorInsight : DTDFVocab:Insight [
    base:desc "Real-time replication of robot's dynamics, friction effects, and control logic behavior."
]

instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Current operational state alignment between physical robot and digital twin."
]

instance OperationalAnomalyInsight : DTDFVocab:Insight [
    base:desc "Identified deviations from expected performance in robot operations."
]

instance PerformancePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted system performance under varying operational loads and conditions."
]

instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Assessment of data consistency, completeness, and validity from physical system."
]

instance ComponentInterdependencyInsight : DTDFVocab:Insight [
    base:desc "Understanding of component relationships and their impact on system behavior."
]

instance SystemArchitectureInsight : DTDFVocab:Insight [
    base:desc "Structural overview of system decomposition and component interactions."
]

instance CustomLogicInsight : DTDFVocab:Insight [
    base:desc "Execution results and performance metrics of custom control algorithms."
]

instance VisualMonitoringInsight : DTDFVocab:Insight [
    base:desc "Visual representation of operational metrics, anomalies, and predictive insights."
]

instance IntegrationConsistencyInsight : DTDFVocab:Insight [
    base:desc "Verification of cross-tool consistency across modeling, simulation, and execution environments."
]

instance OptimizationRecommendationAction : DTDFVocab:Action [
    base:desc "Suggested optimizations for robot performance based on predictive analysis."
    DTDFVocab:IsAutomatic false
]

instance AdaptiveControlAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of control parameters based on real-time system behavior."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin (DT) system’s orchestration and coordination are implicitly tied to **Model-Based Systems Engineering (MBSE)** methodologies, which employ **architecture description languages (ADLs)** like ACME, AADL, MontiArc, or SysML Internal Block Diagrams (IBDs) to define component integration, interfaces, and composition. Behavioral modeling is extended via tools such as **MontiArc Automaton, SysML state machines (v1.7), MathWorks Simulink, or simulation frameworks** (e.g., [29], [30]) to ensure system-wide coordination. The document does not specify explicit orchestration patterns (e.g., microservices, service-oriented architectures) but emphasizes the need to integrate **heterogeneous modeling notations and tools** for comprehensive system description. Resource management is not detailed, though the passive nature of digital shadows (one-way data flow) suggests DTs may require active components (e.g., interpreters or processors) to handle data aggregation and abstraction."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **validation and verification (V&V) methods** to ensure model fidelity and data accuracy, though specific techniques are not detailed in the provided documents. The **Digital Shadow Reference Model** (Kritzinger et al. [32]) emphasizes the **one-way, passive data flow** from physical objects to digital representations, implying that fidelity depends on the **automated aggregation and abstraction of contextual data traces**. Uncertainty sources may arise from **data transmission delays, sensor inaccuracies, or model simplification assumptions**, but no explicit quantification methods (e.g., probabilistic models, Bayesian inference) or error correction mechanisms are described. Quality assurance processes likely involve **cross-referencing models with physical system states**, though the document does not specify formal validation protocols (e.g., traceability matrices, simulation-based testing). The integration of **heterogeneous modeling tools** (e.g., SysML, Simulink) suggests a reliance on **tool-specific validation frameworks**, but no standardized fidelity metrics or uncertainty propagation techniques are mentioned."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for the Digital Shadow system relies on **MQTT** as the primary communication protocol for streaming sensor data in real-time. The architecture integrates **heterogeneous modeling tools and languages**, including **SysML (for system architecture)**, **ADLs (e.g., MontiArc, AADL, ACME) for component-connector descriptions**, and **simulation tools (e.g., MathWorks Simulink)** for behavioral modeling. These tools are interconnected to support **multi-notation modeling**, though specific details on **network topology (e.g., star, mesh)**, **bandwidth/latency requirements**, or **security protocols** (e.g., TLS, OPC UA) are not explicitly described. The system does not provide explicit redundancy mechanisms or hybrid cloud-edge deployments, as the focus is on **one-way data acquisition** rather than bidirectional control or distributed infrastructure."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with external systems through standardized data exchange mechanisms, as evidenced by the streaming of time-series sensor data via **MQTT** to the digital representation. The document explicitly references the **Siemens SINUMERIK 840D sl** controller as a concrete external system dependency, indicating interoperability with industrial control systems. While no other protocols or technologies are detailed, the reliance on MQTT for real-time data transmission suggests adherence to lightweight, event-driven communication standards. The integration pattern aligns with enterprise-level Digital Twin ecosystems, where heterogeneous tools (e.g., simulation environments, ADLs, or general-purpose programming languages) must coexist and exchange data seamlessly."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system incorporates **safety-critical considerations** through the use of a **physical safety cell** for robotic systems (e.g., MABI robotic arm), which restricts the maximum working range to mitigate operational risks. Data streaming between physical and virtual components is facilitated via **MQTT (Message Queuing Telemetry Transport)**, a lightweight protocol for IoT and industrial communication, though no explicit security protocols (e.g., encryption, authentication) are detailed in the provided documents. The system leverages **model-driven engineering (MDE)** and **conformance relations** for structural validation, but no granular cybersecurity measures (e.g., RBAC, OAuth, or compliance frameworks like ISO/IEC 27001) are specified. Risk assessment is implied through **traceability of data origins** (e.g., 'remains fully traceable to its origin and method of computation'), but no formal threat mitigation strategies or fail-safe mechanisms are documented."
]