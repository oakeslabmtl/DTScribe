// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor driven by current I_M in the first axis."
]

instance GearwheelGearbox : DTDFVocab:ActingComponent [
    base:desc "Gearwheel gearbox transmitting torque from the motor to the output shaft."
]

instance CycloidalGearbox : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gearbox providing additional reduction for the robot axis."
]

// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures motor current I_M from the robot controller."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted on the motor shaft providing angular position r_M."
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxSecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the gearboxes giving angular position r_out."
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction (sensor data)
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxSecondaryEncoder
]

// Derived data (produced by calculation model)
instance DerivedTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Derived torque calculated by DataCalculationModel."
]

instance DerivedVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Derived angular velocity calculated by DataCalculationModel."
]

instance DerivedAccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Derived angular acceleration calculated by DataCalculationModel."
]

// C5: Data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor current I_M streamed via MQTT."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MqttBrokerEnabler, DashboardVisualizationEnabler
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Angular position r_M from the motor‑mounted encoder."
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MqttBrokerEnabler, DashboardVisualizationEnabler
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Angular position r_out from the secondary gearbox encoder."
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MqttBrokerEnabler, DashboardVisualizationEnabler
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque calculated from current and encoder data."
    DTDFVocab:fromData DerivedTorqueDataTransmitted
    DTDFVocab:inputTo DashboardVisualizationEnabler
]

instance VelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity obtained from position data."
    DTDFVocab:fromData DerivedVelocityDataTransmitted
    DTDFVocab:inputTo DashboardVisualizationEnabler
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration obtained from velocity data."
    DTDFVocab:fromData DerivedAccelerationDataTransmitted
    DTDFVocab:inputTo DashboardVisualizationEnabler
]

// C10: Models/Data
instance SysmlBlockDefinitionModel : DTDFVocab:Model [
    base:desc "SysML block definition diagram describing the structural view of the first axis."
    DTDFVocab:inputTo SysmlToolEnabler
]

instance SysmlInternalBlockDiagramModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram detailing connections among motor, gearboxes, and sensors."
    DTDFVocab:inputTo SysmlToolEnabler
]

instance MatlabSimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the permanent‑magnet synchronous motor including electrical dynamics."
    DTDFVocab:inputTo MatlabSimulinkEngineEnabler
]

instance MatlabSimulinkGearwheelModel : DTDFVocab:Model [
    base:desc "Simulink model of the gearwheel gearbox with Coulomb‑Viscous friction formulation."
    DTDFVocab:inputTo MatlabSimulinkEngineEnabler
]

instance MatlabSimulinkCycloidalModel : DTDFVocab:Model [
    base:desc "Simulink model of the cycloidal gearbox incorporating the Stribeck friction model."
    DTDFVocab:inputTo MatlabSimulinkEngineEnabler
]

instance FrictionIdentificationModel : DTDFVocab:Model [
    base:desc "Combined white‑box and black‑box model used to identify static, kinetic, and viscous friction."
    DTDFVocab:inputTo MatlabSimulinkEngineEnabler, AssetAdministrationShellEnabler
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Model calculating torque, angular velocity, and acceleration from current and encoder data."
    DTDFVocab:inputTo MatlabSimulinkEngineEnabler
]

instance ModelingService : DTDFVocab:Service [
    base:desc "Provides model validation and traceability within SysML tools."
    DTDFVocab:provides InsightModelingInsight
]

// C11: Enablers
instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker for streaming live sensor data from the robot controller to the digital shadow."
    DTDFVocab:enables FrictionIdentificationService, RealTimeDashboardVisualizationService
]

instance MatlabSimulinkEngineEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink runtime executing simulation and friction identification models."
    DTDFVocab:enables FrictionIdentificationService, MotionControlFeedbackService
]

instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Custom dashboard visualizing friction loss and derived variables for operators."
    DTDFVocab:enables RealTimeDashboardVisualizationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell integration for model exchange and metadata handling."
    DTDFVocab:enables FrictionIdentificationService
]

instance SysmlToolEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling environment."
    DTDFVocab:enables ModelingService
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Identifies static, kinetic, and viscous friction parameters using combined white‑box and black‑box approaches."
    DTDFVocab:provides PositionalAccuracyImprovementInsight, UpdateFrictionParametersAction
]

instance RealTimeDashboardVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of friction loss and derived variables on the dashboard."
    DTDFVocab:provides FrictionLossInsight
]

instance MotionControlFeedbackService : DTDFVocab:Service [
    base:desc "Feeds updated friction parameters back to the robot motion control algorithm to improve accuracy."
    DTDFVocab:provides PositionalAccuracyImprovementInsight
]

// C17: Insights/Actions
instance PositionalAccuracyImprovementInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters adjust motion control, improving positional accuracy."
]

instance FrictionLossInsight : DTDFVocab:Insight [
    base:desc "Dashboard gives operators insight into friction loss during machining."
]

instance InsightModelingInsight : DTDFVocab:Insight [
    base:desc "Ensures consistency between engineering and simulation models."
]

instance UpdateFrictionParametersAction : DTDFVocab:Action [
    base:desc "Automatically updates the motion controller with newly identified friction parameters."
    DTDFVocab:IsAutomatic true
]

// C16: Environment
instance RobotFirstAxisEnvironment : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotor, GearwheelGearbox, CycloidalGearbox,
               MotorCurrentSensor, MotorMountedEncoder, GearboxSecondaryEncoder
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None - the digital shadow follows a one-way data flow from the physical system to the virtual model and does not send commands back to the robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time operation; data are ingested continuously as the robot moves, enabling on-line model updating."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose-driven digital shadow architecture linking the physical first axis (asset) to engineering, simulation and data-calculation models via a Processing component that consumes input data traces and produces simulated outputs, all organized according to the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Applied during the operational phase of the robot to continuously identify friction; the digital shadow does not cover design or manufacturing stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability is ensured by linking each data point to its source and processing model; simulated outputs are compared against measured reference traces to validate friction models and quantify deviation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot controller to the digital shadow over MQTT; the Asset Administration Shell provides a standardized interface for model linking."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation follows the Asset Administration Shell (AAS) specification, a standard for Industry 4.0 digital twins."
]