// -------------------------------------------------
// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (I_M) measuring the electrical current supplied to the permanent‑magnet synchronous motor"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor shaft providing angular position r_M"
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder on the gearbox side providing angular position r_G"
    DTDFVocab:producedData GearboxPositionDataTransmitted
]

// -------------------------------------------------
// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
    base:desc "Live motor current I_M streamed from the robot to the digital shadow via MQTT"
]

instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
    base:desc "Live motor angular position r_M streamed via MQTT"
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
    base:desc "Live gearbox angular position r_G streamed via MQTT"
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorPositionEncoder
    base:desc "Derived torque τ calculated from current and position, streamed via MQTT"
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
    base:desc "Derived angular velocity ω calculated from position encoder, streamed via MQTT"
]

// -------------------------------------------------
// C10: Data
instance MotorCurrentLiveData : DTDFVocab:Data [
    base:desc "Live data trace of motor current I_M with timestamps and metadata"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, WebDashboardEnabler
]

instance MotorPositionLiveData : DTDFVocab:Data [
    base:desc "Live data trace of motor angular position r_M with timestamps and metadata"
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, WebDashboardEnabler
]

instance GearboxPositionLiveData : DTDFVocab:Data [
    base:desc "Live data trace of gearbox angular position r_G with timestamps and metadata"
    DTDFVocab:fromData GearboxPositionDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, WebDashboardEnabler
]

instance MotorTorqueLiveData : DTDFVocab:Data [
    base:desc "Derived live torque τ for the motor, calculated from current and position"
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo FrictionParameterIdentificationEnabler, MATLABSimulinkEnabler
]

instance MotorAngularVelocityLiveData : DTDFVocab:Data [
    base:desc "Derived live angular velocity ω of the motor, calculated from position encoder"
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo FrictionParameterIdentificationEnabler, MATLABSimulinkEnabler
]

// -------------------------------------------------
// C10: Models
instance AxisSysMLStructureModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams describing the vertical axis composition"
    DTDFVocab:inputTo AssetAdministrationShellEnabler
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the permanent‑magnet synchronous motor"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance SimulinkGearwheelModel : DTDFVocab:Model [
    base:desc "Simulink model of the gearwheel subsystem"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "Simulink model of the cycloidal gearbox"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "White‑box analytical friction model combining Coulomb and viscous friction"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "White‑box Stribeck friction model for low‑speed behavior"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "White‑box Dahl friction model capturing micro‑stiction effects"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "White‑box LuGre friction model for dynamic friction phenomena"
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

// -------------------------------------------------
// C11: Enablers (Tools & Platforms)
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker streams live measurement data from the robot to the digital shadow"
    DTDFVocab:enables RealTimeVisualizationService, FrictionParameterIdentificationService
]

instance WebDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard visualizes measured and simulated data in real time"
    DTDFVocab:enables RealTimeVisualizationService
]

instance FrictionParameterIdentificationEnabler : DTDFVocab:Enabler [
    base:desc "Engine processes torque and velocity data to continuously identify static, kinetic and viscous friction parameters"
    DTDFVocab:enables FrictionParameterIdentificationService, UpdatedFrictionParameterGenerationService
]

instance ComparativeFrictionAnalysisEnabler : DTDFVocab:Enabler [
    base:desc "Tool compares friction‑less and friction‑augmented Simulink models"
    DTDFVocab:enables ComparativeFrictionAnalysisService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink executes motor, gearwheel and gearbox models with integrated friction models"
    DTDFVocab:enables FrictionParameterIdentificationService, ComparativeFrictionAnalysisService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell integrates engineering and simulation models into the digital twin"
    DTDFVocab:enables UpdatedFrictionParameterGenerationService
]

instance FrictionParameterUpdateEnabler : DTDFVocab:Enabler [
    base:desc "Updates the robot control algorithm with newly identified friction parameters"
    DTDFVocab:enables UpdatedFrictionParameterGenerationService
]

// -------------------------------------------------
// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of measured and simulated data on a web dashboard"
    DTDFVocab:provides PositioningErrorReductionInsight
]

instance FrictionParameterIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of static, kinetic and viscous friction parameters from live torque and velocity data"
    DTDFVocab:provides DashboardModelSelectionInsight
]

instance ComparativeFrictionAnalysisService : DTDFVocab:Service [
    base:desc "Comparative analysis of friction‑less and friction‑augmented Simulink models"
    DTDFVocab:provides PositioningErrorReductionInsight
]

instance UpdatedFrictionParameterGenerationService : DTDFVocab:Service [
    base:desc "Generation of updated friction model parameters for improving robot motion‑control accuracy"
    DTDFVocab:provides UpdateControlAlgorithmAction
]

// -------------------------------------------------
// C17: Insights / Actions
instance PositioningErrorReductionInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters reduce positioning errors and improve machining accuracy"
]

instance DashboardModelSelectionInsight : DTDFVocab:Insight [
    base:desc "Dashboard insights support engineers in selecting the most appropriate friction model"
]

instance UpdateControlAlgorithmAction : DTDFVocab:Action [
    base:desc "Inject updated friction parameters into the robot control algorithm"
    DTDFVocab:IsAutomatic true
]

instance SelectFrictionModelAction : DTDFVocab:Action [
    base:desc "Engineer manually selects a friction model (Coulomb‑Viscous, Stribeck, Dahl, LuGre) via the dashboard"
    DTDFVocab:IsAutomatic false
]

// -------------------------------------------------
// Environment and Physical Components
instance MabiMax100VerticalAxisEnv : DTDFVocab:Environment [
    base:contains PermanentMagnetSynchronousMotor, CycloidalGearbox, MotorEncoderComponent, GearboxEncoderComponent
]

instance PermanentMagnetSynchronousMotor : DTDFVocab:Component [
    base:desc "Permanent‑magnet synchronous motor driving the vertical axis"
]

instance CycloidalGearbox : DTDFVocab:Component [
    base:desc "Cycloidal gearbox transmitting motion from motor to axis output"
]

instance MotorEncoderComponent : DTDFVocab:Component [
    base:desc "Encoder mounted on the motor shaft providing high‑resolution angular position"
]

instance GearboxEncoderComponent : DTDFVocab:Component [
    base:desc "Encoder on the gearbox side providing secondary angular position feedback"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow is defined as a passive one‑way data flow from the physical system to the virtual model and does not send commands back to the robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Online, real‑time during robot operation; data are acquired continuously and processed on‑the‑fly to update friction estimates."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A one‑way orchestration where the physical robot (asset) provides sensor streams to the digital shadow; the shadow contains processing components that consume the streams, run simulation models, produce derived data traces, and expose them to a dashboard. No feedback loop to the robot is present."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow is applied in the operational stage of the robot to monitor and identify friction; engineering models created earlier represent design/manufacturing knowledge that is reused at runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Combines white‑box analytical and black‑box data‑driven friction models; each data point is traceable to its source and processing model, enabling verification by comparing simulated friction‑free behavior with measured data. Multi‑physics‑aware identification is used to ensure model validity over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Live data are transmitted from the robot to the digital shadow using the MQTT protocol; the Asset Administration Shell provides the structural link between physical asset and virtual representation."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation follows the Asset Administration Shell (AAS) standard for Industry 4.0 digital twins and employs the Digital Shadow Reference Model as a UML‑based reference."
]