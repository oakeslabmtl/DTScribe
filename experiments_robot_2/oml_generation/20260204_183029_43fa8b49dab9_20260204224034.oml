// C3: Physical sensing components
instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor capturing input current of the machine"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Torque sensor measuring torque on the machine spindle"
    DTDFVocab:producedData TorqueDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Angular velocity sensor capturing rotational speed of the shaft"
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

// C4: Physical-to-virtual interaction
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

// C10: Raw data received via MQTT
instance CurrentRawData : DTDFVocab:Data [
    base:desc "Raw current measurement stream received via MQTT"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo MQTTPayloadAggregator
]

instance TorqueRawData : DTDFVocab:Data [
    base:desc "Raw torque measurement stream received via MQTT"
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo MQTTPayloadAggregator
]

instance AngularVelocityRawData : DTDFVocab:Data [
    base:desc "Raw angular velocity measurement stream received via MQTT"
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo MQTTPayloadAggregator
]

// C11: Enablers (technical tools and processing components)
instance MQTTPayloadAggregator : DTDFVocab:Enabler [
    base:desc "Software component that aggregates and abstracts raw MQTT measurements"
    DTDFVocab:enables DataProcessingService
]

instance CppProcessingEngine : DTDFVocab:Enabler [
    base:desc "C++ implementation that executes data‑calculation models such as torque aggregation"
    DTDFVocab:enables InsightGenerationService
]

instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink engine used to run physics‑based simulation models"
    DTDFVocab:enables SimulationService
]

// C10: Models
instance TorqueAggregationModel : DTDFVocab:Model [
    base:desc "RFLP‑based model that aggregates torque measurements into performance metrics"
    DTDFVocab:inputTo CppProcessingEngine
]

instance PerformanceIndicatorModel : DTDFVocab:Model [
    base:desc "Simulink model that calculates aggregated performance indicators from sensor data"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance RequirementsTraceabilityModel : DTDFVocab:Model [
    base:desc "SysML model providing ‘originates‑from’ traceability links between data, models, and insights"
    DTDFVocab:inputTo CppProcessingEngine, SimulinkSimulationEngine
]

// C6: Services
instance DataProcessingService : DTDFVocab:Service [
    base:desc "Processes aggregated sensor traces and prepares them for insight generation"
    DTDFVocab:provides TorqueAggregationInsight
]

instance InsightGenerationService : DTDFVocab:Service [
    base:desc "Generates high‑level performance insights from processed data"
    DTDFVocab:provides PerformanceIndicatorInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Executes simulation models to predict system behavior"
    DTDFVocab:provides SimulationResultInsight
]

// C17: Insights
instance TorqueAggregationInsight : DTDFVocab:Insight [
    base:desc "Aggregated torque insight linking back to raw torque traces and the TorqueAggregationModel"
]

instance PerformanceIndicatorInsight : DTDFVocab:Insight [
    base:desc "Performance indicator insight derived from Simulink simulation and sensor data"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation result insight providing predicted operational metrics"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is structured around the Digital Shadow Reference Model, which defines a set of core concepts as UML classes: Purpose (the intended use), Asset (the physical entity), DataTrace (individual data points), Processing (components that execute computational logic), and Model (engineering, simulation, or data‑calculation models). A Processing component consumes one or more input DataTraces, applies a specific Model, and generates output DataTraces that become part of the digital shadow. The 'originatesFrom' association records the provenance of each DataTrace, linking it transitively to the Processing component, its input traces, and the involved Model, thereby providing fine‑grained traceability across the twin. Concretization of the reference model is achieved by mapping these abstract classes to concrete implementations such as database tables, simulation tools (e.g., Simulink) or code modules (e.g., C++/Java). This component‑based orchestration enables systematic integration of heterogeneous modeling notations and tools, supporting a coordinated flow of data through processing pipelines under the governance of the reference model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin development follows a Model‑Based Systems‑Engineering (MBSE) lifecycle in which models are produced at successive abstraction levels: (1) requirements models, (2) functional architecture models, (3) logical architecture models, and (4) product/technical (implementation) models. Representation types evolve from high‑level SysML requirement diagrams to detailed component‑and‑connector descriptions using architecture description languages such as ACME, AADL, MontiArc, and SysML internal block diagrams, and finally to executable artifacts in simulation tools (e.g., MathWorks Simulink) or code (C++, Java). Transitions between these stages are governed by explicit conformance relations defined in the Digital Shadow reference model, preserving traceability of data traces and model elements across the lifecycle."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on established modelling standards: SysML is used for requirement and internal‑block diagrams; architecture description languages such as ACME, AADL and MontiArc serve as standardized notations for component‑connector specifications; UML class diagrams constitute the basis of the Digital Shadow reference model and its concrete realizations. Conformance relations defined in the reference model provide a formal mechanism to ensure that concrete DT artefacts adhere to these modelling standards."
]