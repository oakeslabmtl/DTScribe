// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real-time temperature readings from physical system components, supporting event-triggered or time-based transmission via industrial protocols."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real-time pressure readings from physical system components, supporting event-triggered or time-based transmission via industrial protocols."
    DTDFVocab:producedData PressureDataTransmitted
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real-time vibration readings from physical system components, supporting event-triggered or time-based transmission via industrial protocols."
    DTDFVocab:producedData VibrationDataTransmitted
]

instance EquipmentStateLogger : DTDFVocab:SensingComponent [
    base:desc "Collects operational logs including equipment states and performance metrics from physical system components, supporting periodic polling or event-triggered transmission."
    DTDFVocab:producedData EquipmentStateDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Aggregated temperature readings transmitted from TemperatureSensor, preprocessed for normalization and validation against expected ranges."
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Aggregated pressure readings transmitted from PressureSensor, preprocessed for normalization and validation against expected ranges."
    DTDFVocab:producedFrom PressureSensor
]

instance VibrationDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Aggregated vibration readings transmitted from VibrationSensor, preprocessed for normalization and validation against expected ranges."
    DTDFVocab:producedFrom VibrationSensor
]

instance EquipmentStateDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Aggregated operational logs including equipment states and performance metrics transmitted from EquipmentStateLogger, supporting heterogeneous data aggregation."
    DTDFVocab:producedFrom EquipmentStateLogger
]

// C10: Models/Data
instance GeometricModel : DTDFVocab:Model [
    base:desc "CAD-based geometric model representing physical system components, used for spatial and structural analysis across multiple abstraction layers."
    DTDFVocab:inputTo SysMLModelingTool, MontiArcADL
]

instance BehavioralStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model representing dynamic behavior of system components, integrated with simulation tools for validation."
    DTDFVocab:inputTo SysMLModelingTool, MathWorksSimulink
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model representing component composition and behavioral logic, supporting formalized interfaces and interconnections."
    DTDFVocab:inputTo MontiArcADL, MathWorksSimulink
]

instance AnalyticalSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model implemented in MathWorks Simulink or other simulation tools for multi-domain behavioral analysis and control system design."
    DTDFVocab:inputTo MathWorksSimulink, CustomIntegrationLayer
]

instance RequirementsModel : DTDFVocab:Model [
    base:desc "SysML-based requirements model structured using RFLP methodology, defining system requirements across functional and technical layers."
    DTDFVocab:inputTo SysMLModelingTool, RFLPMethodology
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "Functional architecture model defined using SysML Internal Block Diagrams (IBDs), representing system functions and their interconnections."
    DTDFVocab:inputTo SysMLModelingTool, OOSEMMethodology
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Logical architecture model defined using Architecture Description Languages (ADLs) like ACME or AADL, representing components, interfaces, and composition."
    DTDFVocab:inputTo ACMEADL, AADLTool
]

instance DigitalShadowData : DTDFVocab:Data [
    base:desc "Passively acquired contextual data traces from physical system, aggregated for specific analytical or monitoring purposes as per Digital Shadow Reference Model."
    DTDFVocab:fromData TemperatureDataTransmitted, PressureDataTransmitted, VibrationDataTransmitted, EquipmentStateDataTransmitted
    DTDFVocab:inputTo DigitalShadowFramework
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Real-time sensor readings including temperature, pressure, and vibration, preprocessed and normalized for active DT processing."
    DTDFVocab:fromData TemperatureDataTransmitted, PressureDataTransmitted, VibrationDataTransmitted
    DTDFVocab:inputTo DataAggregationLayer, SimulationIntegration
]

instance OperationalLogData : DTDFVocab:Data [
    base:desc "Structured operational logs including equipment states and performance metrics, combined with sensor data for comprehensive system analysis."
    DTDFVocab:fromData EquipmentStateDataTransmitted
    DTDFVocab:inputTo DataAggregationLayer, CustomIntegrationLayer
]

// C11: Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML v1.7 toolchain supporting requirements, functional/logical architectures, and state machines across multiple abstraction layers."
    DTDFVocab:enables SystemDesignService, BehavioralSimulationService, RequirementsValidationService
]

instance MontiArcADL : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language enabling component composition, interfaces, and behavioral automata modeling."
    DTDFVocab:enables ComponentConnectorAnalysisService, BehavioralSimulationService
]

instance ACMEADL : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component-based system modeling and interface definition."
    DTDFVocab:enables ComponentConnectorAnalysisService, LogicalArchitectureService
]

instance AADLTool : DTDFVocab:Enabler [
    base:desc "AADL tool for architecture-centric modeling of safety-critical systems, defining components and interconnections."
    DTDFVocab:enables LogicalArchitectureService, SafetyAnalysisService
]

instance MathWorksSimulink : DTDFVocab:Enabler [
    base:desc "Simulation environment for dynamic system simulation, control system design, and multi-domain behavioral analysis."
    DTDFVocab:enables BehavioralSimulationService, PredictiveAnalyticsService, ControlFeedbackService
]

instance CustomIntegrationLayer : DTDFVocab:Enabler [
    base:desc "Custom C++/Java integration layer enabling interoperability between modeling tools and simulation environments."
    DTDFVocab:enables SimulationIntegrationService, DataProcessingService
]

instance DigitalShadowFramework : DTDFVocab:Enabler [
    base:desc "Digital Shadow framework providing one-way automated data flow from physical to digital, with contextual trace aggregation."
    DTDFVocab:enables PassiveDataCollectionService, ContextualDataAggregationService
]

instance DataAggregationLayer : DTDFVocab:Enabler [
    base:desc "Heterogeneous data aggregation layer combining structured sensor data with unstructured logs for higher-level insights."
    DTDFVocab:enables DataInterpretationService, MultiPerspectiveAnalysisService
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements, Functions, Logics, Physics) methodology for structuring system descriptions across abstraction layers."
    DTDFVocab:enables RequirementsValidationService, SystemDesignService
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM (Object-Oriented Systems Engineering Method) for managing complexity in multi-layered system modeling."
    DTDFVocab:enables FunctionalArchitectureService, LogicalArchitectureService
]

instance SimulationIntegration : DTDFVocab:Enabler [
    base:desc "Integration mechanism enabling co-simulation between SysML, ADLs, and simulation tools like MathWorks Simulink."
    DTDFVocab:enables BehavioralSimulationService
]

// C6: Services
instance SystemDesignService : DTDFVocab:Service [
    base:desc "MBSE-driven design service enabling comprehensive system representation across requirements, functional, and technical layers."
    DTDFVocab:provides SystemDesignInsight
]

instance BehavioralSimulationService : DTDFVocab:Service [
    base:desc "Service integrating state machines, automata, and simulation tools for dynamic behavior modeling and validation."
    DTDFVocab:provides BehavioralValidationInsight, SimulationForecastInsight
]

instance ComponentConnectorAnalysisService : DTDFVocab:Service [
    base:desc "Service leveraging ADLs to model interfaces, interconnections, and composition of system components."
    DTDFVocab:provides ComponentInteractionInsight, InterfaceValidationInsight
]

instance RequirementsValidationService : DTDFVocab:Service [
    base:desc "Service validating system requirements against functional and logical architecture models using RFLP methodology."
    DTDFVocab:provides RequirementsComplianceInsight
]

instance FunctionalArchitectureService : DTDFVocab:Service [
    base:desc "Service defining and analyzing functional architecture using SysML IBDs and OOSEM methodology."
    DTDFVocab:provides FunctionalDecompositionInsight
]

instance LogicalArchitectureService : DTDFVocab:Service [
    base:desc "Service defining and analyzing logical architecture using ADLs like ACME or AADL."
    DTDFVocab:provides LogicalComponentInsight, InterfaceConsistencyInsight
]

instance DataInterpretationService : DTDFVocab:Service [
    base:desc "Active service interpreting and processing incoming data from physical system for real-time system state awareness."
    DTDFVocab:provides DataQualityInsight, AnomalyDetectionInsight
]

instance MultiPerspectiveAnalysisService : DTDFVocab:Service [
    base:desc "Service enabling multi-perspective analysis across heterogeneous modeling tools for system performance optimization."
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service supporting simulation-based forecasting for proactive decision-making and system behavior prediction."
    DTDFVocab:provides PredictiveForecastInsight
]

instance ControlFeedbackService : DTDFVocab:Service [
    base:desc "Service providing feedback mechanisms to adjust physical system behavior based on digital insights."
    DTDFVocab:provides ControlAdjustmentAction
]

instance PassiveDataCollectionService : DTDFVocab:Service [
    base:desc "Service aggregating contextual data traces from physical system for passive monitoring and analysis."
    DTDFVocab:provides DataTraceInsight
]

instance ContextualDataAggregationService : DTDFVocab:Service [
    base:desc "Service processing and abstracting contextual data for specific analytical purposes."
    DTDFVocab:provides AggregatedContextInsight
]

instance SimulationIntegrationService : DTDFVocab:Service [
    base:desc "Service enabling co-simulation between SysML, ADLs, and simulation tools for integrated analysis."
    DTDFVocab:provides IntegrationValidationInsight
]

instance DataProcessingService : DTDFVocab:Service [
    base:desc "Service preprocessing and normalizing sensor data for active DT processing and analysis."
    DTDFVocab:provides ProcessedDataInsight
]

instance SafetyAnalysisService : DTDFVocab:Service [
    base:desc "Service analyzing system safety using AADL-based architecture models."
    DTDFVocab:provides SafetyComplianceInsight
]

// C17: Insights/Actions
instance SystemDesignInsight : DTDFVocab:Insight [
    base:desc "Comprehensive system design insights across requirements, functional, and technical layers using MBSE methodologies."
]

instance BehavioralValidationInsight : DTDFVocab:Insight [
    base:desc "Validation insights for dynamic system behavior using state machines and simulation tools."
]

instance SimulationForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasting insights derived from simulation models for predictive analytics."
]

instance ComponentInteractionInsight : DTDFVocab:Insight [
    base:desc "Insights into component interactions and interface consistency using ADL-based models."
]

instance InterfaceValidationInsight : DTDFVocab:Insight [
    base:desc "Validation insights for component interfaces and interconnections."
]

instance RequirementsComplianceInsight : DTDFVocab:Insight [
    base:desc "Insights validating system requirements compliance against functional and logical architecture."
]

instance FunctionalDecompositionInsight : DTDFVocab:Insight [
    base:desc "Insights into functional architecture decomposition and system functions."
]

instance LogicalComponentInsight : DTDFVocab:Insight [
    base:desc "Insights into logical architecture components and their interconnections."
]

instance InterfaceConsistencyInsight : DTDFVocab:Insight [
    base:desc "Insights ensuring consistency across component interfaces in logical architecture."
]

instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Insights into data quality and preprocessing results for active DT processing."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insights identifying anomalies in real-time sensor data and operational logs."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for system performance optimization based on multi-perspective analysis."
]

instance PredictiveForecastInsight : DTDFVocab:Insight [
    base:desc "Predictive insights derived from simulation models for proactive decision-making."
]

instance DataTraceInsight : DTDFVocab:Insight [
    base:desc "Insights from passively collected contextual data traces for monitoring purposes."
]

instance AggregatedContextInsight : DTDFVocab:Insight [
    base:desc "Insights derived from aggregated contextual data for specific analytical purposes."
]

instance IntegrationValidationInsight : DTDFVocab:Insight [
    base:desc "Insights validating integration between SysML, ADLs, and simulation tools."
]

instance ProcessedDataInsight : DTDFVocab:Insight [
    base:desc "Insights from preprocessed and normalized sensor data ready for active DT analysis."
]

instance SafetyComplianceInsight : DTDFVocab:Insight [
    base:desc "Insights ensuring system safety compliance using AADL-based architecture models."
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of physical system behavior based on digital insights and control feedback."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin constellation** in this context is implicitly tied to **Model-Based Systems Engineering (MBSE)** methodologies, where the system is decomposed into **multi-layered abstractions** (requirements, functional, logical, and product/technical layers). Orchestration and coordination are achieved through **architecture description languages (ADLs)** such as ACME, AADL, MontiArc, or SysML IBDs, which define **component & connector perspectives**, including interfaces, interconnections, and composition. Behavioral coordination is further refined using **state machines (SysML v1.7)** or **MontiArc Automaton**, while detailed behavior is modeled via **simulation tools (e.g., MathWorks Simulink)** or **general-purpose programming languages (C++, Java)**. The **system-wide coordination** relies on integrating these heterogeneous models and tools, often requiring **active components** (as opposed to passive digital shadows) to interpret and process data flows. No explicit architecture patterns (e.g., microservices, service-oriented) or resource management strategies are detailed, but the emphasis on **stakeholder integration** and **multi-perspective modeling** suggests a **modular, component-based orchestration** framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **validation and verification (V&V) methods** to ensure model fidelity, though specific techniques are not detailed in the provided document. Fidelity requirements are implicitly tied to the **abstraction layers** of MBSE (e.g., logical vs. physical models) and the **integration of heterogeneous tools** (e.g., ADLs, Simulink, general-purpose languages like C++/Java), which may introduce **uncertainty sources** such as data latency, model discretization errors, or tool-specific approximations. Error detection and correction mechanisms are not explicitly described, but the system relies on **active components** (e.g., DT-specific software) to interpret and process incoming data from the **Digital Shadow**, as referenced in [35]–[37]. Quality assurance processes are inferred to involve **cross-tool consistency checks** (e.g., validating ADL models against simulation outputs) and **stakeholder-specific perspectives**, though no quantitative metrics (e.g., uncertainty quantification, precision thresholds) are provided."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for a Digital Twin (DT) system is not explicitly detailed in the provided document. However, the **one-way data flow** of a digital shadow (as a foundational concept for DTs) implies that the network must support **reliable, low-latency communication** between physical assets and digital representations. While specific protocols (e.g., OPC UA, MQTT, TCP/IP) or topologies (e.g., star, mesh) are not mentioned, the infrastructure must accommodate **heterogeneous stakeholders and perspectives** [31], suggesting a **scalable, modular architecture**. Security protocols (e.g., encryption, authentication) are implied but not specified, as is redundancy (e.g., failover mechanisms) or bandwidth requirements. The document does not provide details on latency constraints or network architecture (e.g., cloud-edge hybrid)."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The **horizontal integration** of the Digital Twin system is not explicitly detailed in the provided document. However, the context implies dependencies on **external systems** through the use of **heterogeneous modeling tools and notations** (e.g., SysML, ADLs, Simulink, C++, Java). Interoperability is inferred from the need to **integrate multiple stakeholders and perspectives**, which may require **data exchange protocols** or **interoperability standards** (not specified). The document does not mention **concrete integration patterns** (e.g., APIs, message brokers, event-driven architectures) or **external system dependencies** (e.g., ERP, MES, or IoT platforms). While the Digital Twin may interact with other Digital Twins or enterprise systems, no technical details (e.g., OPC UA, MQTT, REST) or **enterprise integration frameworks** are provided. Thus, the horizontal integration remains **undefined in the document**."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE)** standards, specifically leveraging **SysML** (Systems Modeling Language) for system modeling across abstraction layers. For architecture description, it complies with **Architecture Description Languages (ADLs)** such as **ACME**, **AADL**, **MontiArc**, and **SysML Internal Block Diagrams (IBDs)**. Behavioral modeling aligns with **SysML state machines** (v1.7+) and **MontiArc Automaton**. Interoperability is facilitated through integration with simulation tools like **MathWorks Simulink** and general-purpose programming languages (**C++**, **Java**). While no explicit certification frameworks or compliance standards (e.g., ISO, IEC) are mentioned, the use of these standardized modeling languages ensures alignment with industry best practices for system description, interoperability, and modularity. The **Digital Shadow Reference Model** (as per Kritzinger et al.) implicitly supports standardization by defining structured data aggregation and abstraction for manufacturing contexts."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system, as described in the context documents, integrates **cybersecurity protocols** and **access control mechanisms** through the **Asset Administration Shell (AAS)** framework (referenced in [46], [47], and [50]). The AAS standardizes data encapsulation and exchange, enabling role-based access control (RBAC) and authentication systems to ensure secure interactions between physical assets and their digital representations. Additionally, the **RAMI4.0 reference architecture** ([48], [49]) incorporates hierarchical security layers aligned with the **automation pyramid**, where each level (e.g., field, station, enterprise) enforces granular access policies and threat mitigation strategies. The **MQTT protocol** ([52]), utilized for lightweight IoT communication, supports TLS/SSL encryption to secure data transmission between Digital Twin components and edge devices. **Fail-safe mechanisms** are implied in model-driven engineering approaches ([43]), where simulation models (e.g., Functional Mockup Interface - FMI ([51])) validate system behavior under fault conditions. Risk assessment is implicitly tied to **conformance relations** ([41]) for structural validation of Digital Twin models, ensuring compliance with safety-critical constraints. However, explicit details on **consent management**, **data anonymization**, or **compliance with regulations** (e.g., GDPR) are not provided in the documents."
]