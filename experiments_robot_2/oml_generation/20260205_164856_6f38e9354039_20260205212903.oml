import DTDFVocab
instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Robot sensor measuring input current",
    DTDFVocab:producedData RobotSensorDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Robot sensor measuring angular velocity",
    DTDFVocab:producedData RobotSensorDataTransmitted
]

instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Robot sensor measuring position",
    DTDFVocab:producedData RobotSensorDataTransmitted
]

instance RobotSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor, AngularVelocitySensor, PositionSensor
]

instance RobotSensorData : DTDFVocab:Data [
    base:desc "Robot sensor data transmitted via MQTT with JSON format",
    DTDFVocab:fromData RobotSensorDataTransmitted,
    DTDFVocab:inputTo AASExecutor, ThingsBoard
]

instance ThingsBoard : DTDFVocab:Enabler [
    base:desc "Data storage and visualization platform for digital twin",
    DTDFVocab:enables VisualizationService
]

instance AASExecutor : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell Executor for populating measured, simulated, and reference values",
    DTDFVocab:enables RealTimeMonitoringCompensationService, PredictiveMaintenanceService
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for physics-based dynamic simulations",
    DTDFVocab:enables SimulativeExperimentationService, RealTimeMonitoringCompensationService
]

instance SysML : DTDFVocab:Enabler [
    base:desc "SysML for system architecture modeling",
    DTDFVocab:enables SimulativeExperimentationService, OptimizationService
]

instance AADL : DTDFVocab:Enabler [
    base:desc "AADL for system architecture modeling",
    DTDFVocab:enables SimulativeExperimentationService, OptimizationService
]

instance ACME : DTDFVocab:Enabler [
    base:desc "ACME for system architecture modeling",
    DTDFVocab:enables SimulativeExperimentationService, OptimizationService
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArcAutomaton for system architecture modeling",
    DTDFVocab:enables SimulativeExperimentationService, OptimizationService
]

instance DEVS : DTDFVocab:Enabler [
    base:desc "DEVS for discrete-event simulation",
    DTDFVocab:enables SimulativeExperimentationService
]

instance NeuralNetworkEnabler : DTDFVocab:Enabler [
    base:desc "Neural network-based modeling for data-driven friction adaptation",
    DTDFVocab:enables PredictiveMaintenanceService, OptimizationService
]

instance UMLReferenceModel : DTDFVocab:Enabler [
    base:desc "UML-based reference models for structured data traceability and conformance relations",
    DTDFVocab:enables MultiPurposeSupportService
]

instance SimulinkPhysicsBasedModel : DTDFVocab:Model [
    base:desc "Physics-based white-box model for joint friction dynamics",
    DTDFVocab:inputTo Simulink
]

instance NeuralNetworkDataDrivenModel : DTDFVocab:Model [
    base:desc "Data-driven black-box neural network model for friction adaptation",
    DTDFVocab:inputTo NeuralNetworkEnabler
]

instance SysMLArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based system architecture model",
    DTDFVocab:inputTo SysML
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL-based system architecture model",
    DTDFVocab:inputTo AADL
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME-based system architecture model",
    DTDFVocab:inputTo ACME
]

instance MontiArcAutomatonArchitectureModel : DTDFVocab:Model [
    base:desc "MontiArcAutomaton-based system architecture model",
    DTDFVocab:inputTo MontiArcAutomaton
]

instance DEVSDiscreteEventModel : DTDFVocab:Model [
    base:desc "DEVS-based discrete-event simulation model",
    DTDFVocab:inputTo DEVS
]

instance UMLTraceabilityModel : DTDFVocab:Model [
    base:desc "UML-based reference model for structured data traceability",
    DTDFVocab:inputTo UMLReferenceModel
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulation model for higher-level system behavior abstractions",
    DTDFVocab:inputTo Simulink, DEVS
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Data calculation model for processing sensor data and generating insights",
    DTDFVocab:inputTo AASExecutor, NeuralNetworkEnabler
]

instance RoboticMachiningSystemEnvironment : DTDFVocab:Environment [
    base:desc "Industrial robotic machining system for high-precision manufacturing",
    base:contains RoboticJoint, ControlSystem, MachiningTool
]

instance RoboticMachiningSystem : DTDFVocab:SystemUnderStudy [
    base:desc "Industrial robotic machining system for high-precision manufacturing",
    DTDFVocab:hasEnvironment RoboticMachiningSystemEnvironment
]

instance RoboticJoint : DTDFVocab:Component [
    base:desc "Robotic joint with dynamic friction behavior affected by operational conditions, loads, and environmental factors",
    base:isContainedIn RoboticMachiningSystemEnvironment
]

instance ControlSystem : DTDFVocab:Component [
    base:desc "Control system for real-time adjustments to compensate for joint friction",
    base:isContainedIn RoboticMachiningSystemEnvironment
]

instance MachiningTool : DTDFVocab:Component [
    base:desc "Machining tool for high-precision manufacturing processes",
    base:isContainedIn RoboticMachiningSystemEnvironment
]

instance RealTimeMonitoringCompensationService : DTDFVocab:Service [
    base:desc "Real-time monitoring and compensation of internal joint friction and external machining forces via control system adjustments",
    DTDFVocab:provides RealTimeMonitoringInsight, CompensationAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance and early fault detection through anomaly identification in friction data",
    DTDFVocab:provides FaultDetectionInsight, MaintenanceAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization of machining parameters for CO2 reduction and product quality prediction",
    DTDFVocab:provides ParameterOptimizationInsight, CO2ReductionAction
]

instance SimulativeExperimentationService : DTDFVocab:Service [
    base:desc "Simulative experimentation for process optimization before real-world execution",
    DTDFVocab:provides SimulationResultInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualization through interactive digital twin cockpits",
    DTDFVocab:provides VisualizationInsight
]

instance MultiPurposeSupportService : DTDFVocab:Service [
    base:desc "Multi-purpose application support for sustainable manufacturing and quality control",
    DTDFVocab:provides SustainableManufacturingInsight, QualityControlInsight
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of joint friction and machining forces"
]

instance CompensationAction : DTDFVocab:Action [
    base:desc "Adjusting control system parameters to compensate for friction",
    DTDFVocab:IsAutomatic true
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Anomaly identification in friction data for early fault detection"
]

instance MaintenanceAction : DTDFVocab:Action [
    base:desc "Predictive maintenance actions based on fault detection",
    DTDFVocab:IsAutomatic true
]

instance ParameterOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization of machining parameters for CO2 reduction and quality prediction"
]

instance CO2ReductionAction : DTDFVocab:Action [
    base:desc "Adjusting machining parameters to reduce CO2 emissions",
    DTDFVocab:IsAutomatic true
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation results for process optimization before real-world execution"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive visualization of digital twin data and models"
]

instance SustainableManufacturingInsight : DTDFVocab:Insight [
    base:desc "Insights for sustainable manufacturing practices"
]

instance QualityControlInsight : DTDFVocab:Insight [
    base:desc "Insights for quality control in manufacturing processes"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with physical system data, where friction model parameters are dynamically updated during runtime to compensate for control system dead time, ensuring continuous adaptation to changing operational conditions."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrated through an Asset Administration Shell (AAS) integrating SysML structural models and Simulink behavioral models via Functional Mock-up Interface (FMI), with data flow managed by ThingsBoard and MQTT protocols for real-time monitoring and visualization. The system includes a pipeline that processes live robot data, runs simulations, and updates the digital shadow with traceable data linking to computation methods."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through traceability and verification of transformations (e.g., from SysML to simulation models), with reliability dependent on model correctness. Dynamic adaptation of physics-based and data-driven friction models occurs via automatic parameter updates and neural network retraining as new data arrives, compensating for wear, temperature changes, or varying payloads. Anomaly detection in friction behavior enables predictive maintenance and early fault detection, reducing trajectory errors and enhancing system reliability. Fine-grained traceability of data traces to their generating components and models supports continuous quality assurance."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT publish-subscribe architecture with hierarchical topics; ThingsBoard as IoT data storage platform; security implemented through topic-based read/write permissions; no specific bandwidth, latency, or redundancy details provided."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration via Asset Administration Shell (AAS) for Industry 4.0 interoperability, utilizing MQTT for IoT data communication and ThingsBoard for visualization, with SysML and Simulink models integrated through Functional Mock-up Interface (FMI) for multi-domain modeling. Data exchange adheres to standardized protocols ensuring seamless connectivity with external IoT devices and enterprise systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system employs Model-Based Systems Engineering (MBSE) standards including SysML [17] for system modeling, ACME [23], AADL [24], and MontiArc [25], [26] as architecture description languages (ADLs) for component & connector perspectives, and adheres to reference model conformance relations [41] to ensure structured development and interoperability."
]