instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted directly on the motor shaft for measuring motor angle"
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder positioned behind the gearbox for measuring output angle"
    DTDFVocab:producedData GearboxOutputAngleDataTransmitted
]

instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor current (IM) as electrical control input"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Real-time motor angle data transmitted via MQTT protocol"
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxOutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Output angle data from gearbox encoder transmitted via MQTT protocol"
    DTDFVocab:producedFrom GearboxEncoder
]

instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Motor current (IM) data transmitted via MQTT protocol"
    DTDFVocab:producedFrom CurrentSensor
]

instance MotorAngleData : DTDFVocab:Data [
    base:desc "Motor shaft angle measurements"
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo SimulinkTool, CPlusPlusLanguage, JavaLanguage, SysMLStateMachines, MontiArcAutomaton
]

instance GearboxOutputAngleData : DTDFVocab:Data [
    base:desc "Output angle measurements after gearbox"
    DTDFVocab:fromData GearboxOutputAngleDataTransmitted
    DTDFVocab:inputTo SimulinkTool, CPlusPlusLanguage, JavaLanguage, SysMLStateMachines, MontiArcAutomaton
]

instance CurrentData : DTDFVocab:Data [
    base:desc "Motor current (IM) measurements"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo SimulinkTool, CPlusPlusLanguage, JavaLanguage, SysMLStateMachines, MontiArcAutomaton
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP MBSE methodology for system abstraction"
    DTDFVocab:enables FrictionModelIdentificationService, RealTimeVisualizationService
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM MBSE methodology for system abstraction"
    DTDFVocab:enables FrictionModelIdentificationService, RealTimeVisualizationService
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES MBSE methodology for system abstraction"
    DTDFVocab:enables FrictionModelIdentificationService, RealTimeVisualizationService
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT MBSE methodology for system abstraction"
    DTDFVocab:enables FrictionModelIdentificationService, RealTimeVisualizationService
]

instance ACMEADL : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component and connector structures"
    DTDFVocab:enables FrictionModelIdentificationService, RealTimeVisualizationService
]

instance AADLADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component and connector structures"
    DTDFVocab:enables FrictionModelIdentificationService, RealTimeVisualizationService
]

instance MontiArcADL : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component and connector structures"
    DTDFVocab:enables FrictionModelIdentificationService, RealTimeVisualizationService
]

instance SysMLIBDsADL : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component and connector structures"
    DTDFVocab:enables FrictionModelIdentificationService, RealTimeVisualizationService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed behavior specification and simulation"
    DTDFVocab:enables FrictionModelIdentificationService
]

instance CPlusPlusLanguage : DTDFVocab:Enabler [
    base:desc "C++ programming language for analytical model implementation"
    DTDFVocab:enables FrictionModelIdentificationService
]

instance JavaLanguage : DTDFVocab:Enabler [
    base:desc "Java programming language for heterogeneous stakeholder integration"
    DTDFVocab:enables FrictionModelIdentificationService
]

instance SysMLStateMachines : DTDFVocab:Enabler [
    base:desc "SysML state machines for behavioral aspects"
    DTDFVocab:enables FrictionModelIdentificationService
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral aspects"
    DTDFVocab:enables FrictionModelIdentificationService
]

instance SysMLStateMachinesModel : DTDFVocab:Model [
    base:desc "SysML state machines for capturing behavioral aspects"
    DTDFVocab:inputTo SysMLStateMachines
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral aspects"
    DTDFVocab:inputTo MontiArcAutomaton
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for dynamic behavior simulation"
    DTDFVocab:inputTo SimulinkTool
]

instance CPlusPlusAnalyticalModel : DTDFVocab:Model [
    base:desc "C++ analytical model for friction compensation"
    DTDFVocab:inputTo CPlusPlusLanguage
]

instance JavaAnalyticalModel : DTDFVocab:Model [
    base:desc "Java analytical model for heterogeneous stakeholder integration"
    DTDFVocab:inputTo JavaLanguage
]

instance WhiteBoxFrictionModel : DTDFVocab:Model [
    base:desc "White-box friction model for precise control"
    DTDFVocab:inputTo SimulinkTool, CPlusPlusLanguage, JavaLanguage
]

instance BlackBoxFrictionModel : DTDFVocab:Model [
    base:desc "Black-box friction model for dynamic identification"
    DTDFVocab:inputTo SimulinkTool, CPlusPlusLanguage, JavaLanguage
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real-time visualization via dashboard interface for system monitoring"
    DTDFVocab:provides RealTimeVisualizationAction
]

instance FrictionModelIdentificationService : DTDFVocab:Service [
    base:desc "Dynamic identification of white-box and black-box friction models"
    DTDFVocab:provides FrictionCompensationAction, PredictiveMaintenanceAction
]

instance RealTimeVisualizationAction : DTDFVocab:Action [
    base:desc "Displaying real-time robot system status on dashboard"
    DTDFVocab:IsAutomatic true
]

instance FrictionCompensationAction : DTDFVocab:Action [
    base:desc "Precise friction compensation for robot control systems"
    DTDFVocab:IsAutomatic true
]

instance PredictiveMaintenanceAction : DTDFVocab:Action [
    base:desc "Predictive maintenance for manufacturing processes"
    DTDFVocab:IsAutomatic true
]

instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving the first axis of the MABI MAX 100 robot"
]

instance PrimaryGear : DTDFVocab:ActingComponent [
    base:desc "Primary gear in the gear transmission system"
]

instance CycloidalGear : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear in the gear transmission system"
]

instance GearTransmissionSystem : DTDFVocab:Component [
    base:desc "Gear transmission system comprising primary and cycloidal gears"
    base:contains PrimaryGear, CycloidalGear
]

instance SiemensSINUMERIK840DslController : DTDFVocab:Component [
    base:desc "Siemens SINUMERIK 840D sl controller for precise motion control"
]

instance MABIMAX100Robot : DTDFVocab:Environment [
    base:desc "MABI MAX 100 serial robot with six axes for complex manufacturing tasks"
    base:contains PermanentMagnetSynchronousMotor, GearTransmissionSystem, SiemensSINUMERIK840DslController
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Architecture description languages (ADLs) such as ACME, AADL, MontiArc, and SysML IBDs model component & connector perspectives for functional and logical architecture, including interfaces, interconnections, and composition. Behavioral aspects are described using MontiArc Automaton or SysML state machines. Methodologies like RFLP, OOSEM, SPES, and SMArDT handle complexity through abstraction levels (requirements, functional, logical, product/technical layers), requiring integration of heterogeneous tools and stakeholders for comprehensive MBSE descriptions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for streaming sensor time series data between physical and digital components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system complies with industry standards including SysML [17], AADL [24], ACME [23], MontiArc [25, 26], and methodologies such as RFLP [18, 19], OOSEM [20], SPES [21], and SMArDT [22]. These standards support interoperability and integration of heterogeneous models and tools (e.g., Simulink, C++, Java) while addressing diverse stakeholder perspectives [31]."
]