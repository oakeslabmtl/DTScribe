// C3: Physical sensing components
instance IndustrialMqttSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor‑generated data traces published via the MQTT protocol (Mosquitto broker); event‑driven one‑way flow from the physical object to its digital shadow."
    DTDFVocab:producedData MqttDataTrace
]

// C4: Physical-to-virtual interaction
instance MqttDataTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndustrialMqttSensor
]

// C11: Data (digital shadow)
instance DigitalShadowDataTrace : DTDFVocab:Data [
    base:desc "Contextual data trace stored in ThingsBoard after MQTT ingestion; available for downstream processing components."
    DTDFVocab:fromData MqttDataTrace
    DTDFVocab:inputTo ThingsBoardIngestionEngine
]

// C17: Enablers (processing platforms)
instance ThingsBoardIngestionEngine : DTDFVocab:Enabler [
    base:desc "ThingsBoard IoT platform that ingests MQTT data, performs basic quality‑assurance, and stores it as contextual traces."
    DTDFVocab:enables DataProvenanceService
]

instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "Runtime environment executing Simulink‑based dynamic simulation models."
    DTDFVocab:enables DataProvenanceService
]

instance DataCalculationEngine : DTDFVocab:Enabler [
    base:desc "Engine that runs data‑calculation models to compute higher‑level abstractions."
    DTDFVocab:enables DataProvenanceService
]

// C10: Models/Data
instance SystemStructureModel : DTDFVocab:Model [
    base:desc "Engineering model describing system structure, properties and behaviour."
    DTDFVocab:inputTo ThingsBoardIngestionEngine
]

instance DynamicSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink‑based dynamic simulation model that computes higher‑level system abstractions."
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance ComputationalDataModel : DTDFVocab:Model [
    base:desc "Data‑calculation model performing computational steps on input data traces."
    DTDFVocab:inputTo DataCalculationEngine
]

// C6: Services
instance DataProvenanceService : DTDFVocab:Service [
    base:desc "Service that provides fine‑grained traceability of each output data trace back to its generating processing component, input traces and involved models (Digital Shadow Reference Model)."
    DTDFVocab:provides ProvenanceTraceInsight
]

// C17: Insights
instance ProvenanceTraceInsight : DTDFVocab:Insight [
    base:desc "Insight enabling end‑to‑end provenance tracking of digital twin data throughout ingestion, processing and model execution."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated through a model‑driven reference model that captures components and connectors. Processing components, instantiated from this reference model, consume input data traces and produce derived traces using either data‑calculation or simulation models. The flow of traces is recorded by the ‘originates‑from’ association, enabling transitive traceability from generated traces back to the responsible processing component, its input traces and the underlying models. Concretization of the reference model is achieved by mapping abstract concepts (e.g., DataTrace, ProcessingComponent) to concrete classes and relations, thereby defining the system’s architecture. This architecture follows the component‑and‑connector style used in ADLs such as ACME, AADL, MontiArc, and SysML internal block diagrams, allowing integration of heterogeneous models (SysML, Simulink, source code) and supporting resource management through explicit model composition."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by selecting appropriate model types: white‑box physics‑based models (e.g., Simulink simulations) for interpretability and predictability, complemented by black‑box data‑driven models (e.g., machine‑learning regressors) for capturing nonlinear effects. Validation and verification are performed on the model‑based development chain, including verification of transformations such as SysML to simulation models. The reliability of the Digital Twin depends on the correctness of underlying models and data transformations; traceability mechanisms (originates‑from links) support uncertainty quantification, error detection, and correction by allowing provenance checks throughout the computational pipeline."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical network connection is based on the MQTT messaging protocol, implemented by the Mosquitto client/server over a TCP/IP IP backbone. Devices acting as data sources (sensors, machines) act as MQTT clients that publish to a central broker; the broker may be hosted locally or in the cloud (e.g., as part of a ThingsBoard deployment). The documents do not provide further details on topology, bandwidth, latency, redundancy, or security mechanisms."
]