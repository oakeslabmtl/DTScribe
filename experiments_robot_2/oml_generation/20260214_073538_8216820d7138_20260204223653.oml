// C3: Physical sensing components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the permanent‑magnet synchronous motor of the first axis"
    DTDFVocab:producedData MotorPositionDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder located behind the gearwheel gearbox of the first axis"
    DTDFVocab:producedData GearboxPositionDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring the motor input current I_M of the first axis"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical‑to‑virtual interaction – raw data
instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C4: Physical‑to‑virtual interaction – derived data
instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorPositionEncoder, GearboxPositionEncoder
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorPositionEncoder, GearboxPositionEncoder
]

instance AccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorPositionEncoder, GearboxPositionEncoder
]

// C10: Data objects
instance MotorPositionData : DTDFVocab:Data [
    base:desc "Time‑series of motor output angle r_M measured by the motor position encoder"
    DTDFVocab:fromData MotorPositionDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Time‑series of gearbox output angle r_G measured by the secondary encoder"
    DTDFVocab:fromData GearboxPositionDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor input current I_M"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque τ calculated from I_M and encoder positions"
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo FrictionIdentificationEngineEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω computed from encoder positions"
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo FrictionIdentificationEngineEnabler
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration α computed from encoder positions"
    DTDFVocab:fromData AccelerationDataTransmitted
    DTDFVocab:inputTo FrictionIdentificationEngineEnabler
]

// C10: Models
instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "Executable Simulink model of the permanent‑magnet synchronous motor"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "Executable Simulink model of the gearwheel‑cycloidal gearbox"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance SimulinkFrictionModel : DTDFVocab:Model [
    base:desc "Simulink model implementing analytical (Coulomb‑Viscous, Stribeck, Dahl, LuGre) and data‑driven friction for the gearbox"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance SimulinkGearwheelModel : DTDFVocab:Model [
    base:desc "Simulink model of the gearwheel sub‑assembly"
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker providing one‑way live streaming from the robot to the digital shadow"
    DTDFVocab:enables RealTimeVisualizationService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Custom dashboard used for real‑time visualization of data traces"
    DTDFVocab:enables RealTimeVisualizationService
]

instance SimulinkExecutionEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment running the executable models"
    DTDFVocab:enables ModelComparisonService
]

instance FrictionIdentificationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Engine performing continuous friction parameter identification from incoming data"
    DTDFVocab:enables FrictionParameterIdentificationService, FrictionParameterProvisionService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell handling model integration and storage of simulation results"
    DTDFVocab:enables ModelComparisonService, FrictionParameterProvisionService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of incoming sensor data in the dashboard"
    DTDFVocab:provides OperatorMonitoringInsight, DisplayDataAction
]

instance FrictionParameterIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of static, kinetic and viscous friction parameters"
    DTDFVocab:provides ImprovedMotionAccuracyInsight, UpdateFrictionParametersAction
]

instance ModelComparisonService : DTDFVocab:Service [
    base:desc "Comparison of simulated data from Simulink models with measured sensor data"
    DTDFVocab:provides ModelValidationInsight, StoreModelComparisonResultAction
]

instance FrictionParameterProvisionService : DTDFVocab:Service [
    base:desc "Provision of updated friction parameters to the robot controller for motion accuracy and predictive maintenance"
    DTDFVocab:provides PredictiveMaintenanceInsight, NotifyMaintenanceAction
]

// C17: Insights
instance ImprovedMotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Identified friction parameters reduce tracking errors and improve motion accuracy"
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Trend analysis of friction parameters enables early maintenance decisions"
]

instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Quantitative assessment of model fidelity by comparing simulated and measured data"
]

instance OperatorMonitoringInsight : DTDFVocab:Insight [
    base:desc "Operator receives live view of current, angle, torque, velocity and acceleration"
]

// C17: Actions
instance UpdateFrictionParametersAction : DTDFVocab:Action [
    base:desc "Automatically update the robot controller with newly identified friction parameters"
    DTDFVocab:IsAutomatic true
]

instance DisplayDataAction : DTDFVocab:Action [
    base:desc "Render incoming data streams on the dashboard for operator monitoring"
    DTDFVocab:IsAutomatic false
]

instance StoreModelComparisonResultAction : DTDFVocab:Action [
    base:desc "Persist model‑vs‑measurement comparison results in the AAS repository"
    DTDFVocab:IsAutomatic true
]

instance NotifyMaintenanceAction : DTDFVocab:Action [
    base:desc "Send maintenance alert when friction parameters exceed predefined thresholds"
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A one‑way architecture where the physical axis provides sensor data to a MQTT broker, which is ingested by processing components (simulation models) that generate computed data traces; all traces are stored in the digital shadow and visualized in a dashboard, adhering to the Digital Shadow Reference Model (purpose, asset, source, processing, model)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow is created for the operational stage of the robot (runtime friction identification) while also using engineering models defined during design; thus it spans both design (engineering model) and operation (live data) phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "All data points are traceable to their origin via the Processing component; friction models are validated by comparing simulated torque/velocity traces against measured references; manufacturer‑provided dynamic parameters are used in the dynamics model, ensuring physical plausibility; both white‑box (analytical) and black‑box (data‑driven) models are employed for cross‑validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data is transmitted from the robot to the digital shadow over MQTT; the Asset Administration Shell (AAS) is used to encapsulate model metadata; no other network protocols are specified."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach uses the Industry 4.0 Asset Administration Shell (AAS) as a standard for model encapsulation and SysML as a standardized modeling language; these standards facilitate interoperability of the digital shadow components."
]