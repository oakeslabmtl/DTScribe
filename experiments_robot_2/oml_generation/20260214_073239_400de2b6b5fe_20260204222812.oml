// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures input current of the robot motor."
    DTDFVocab:producedData MotorCurrentTransmitted
]

instance MotorAngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Measures angular velocity of the robot motor."
    DTDFVocab:producedData MotorAngularVelocityTransmitted
]

instance AxisPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Measures the position of the first robot axis."
    DTDFVocab:producedData AxisPositionTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance MotorCurrentTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorAngularVelocityTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorAngularVelocitySensor
]

instance AxisPositionTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AxisPositionSensor
]

// C10: Data generated from transmission
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Filtered motor current data after low‑pass filtering."
    DTDFVocab:fromData MotorCurrentTransmitted
    DTDFVocab:inputTo RealTimeProcessingEnabler
]

instance MotorAngularVelocityData : DTDFVocab:Data [
    base:desc "Filtered angular velocity data after low‑pass filtering."
    DTDFVocab:fromData MotorAngularVelocityTransmitted
    DTDFVocab:inputTo RealTimeProcessingEnabler
]

instance AxisPositionData : DTDFVocab:Data [
    base:desc "Filtered axis position data after low‑pass filtering."
    DTDFVocab:fromData AxisPositionTransmitted
    DTDFVocab:inputTo RealTimeProcessingEnabler
]

// C10: Models/Data
instance PhysicsBasedFrictionModel : DTDFVocab:Model [
    base:desc "White‑box MATLAB/Simulink model of joint friction used for real‑time compensation."
    DTDFVocab:inputTo RealTimeProcessingEnabler
]

instance NeuralNetworkFrictionModel : DTDFVocab:Model [
    base:desc "Black‑box neural‑network regression model trained on measured friction data."
    DTDFVocab:inputTo RealTimeProcessingEnabler
]

// C11: Enablers
instance RealTimeProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that consumes sensor traces and model inputs to execute simulation or neural‑network calculations within the robot's real‑time control loop."
    DTDFVocab:enables RealTimeFrictionMonitoringService,
                 PredictiveMaintenanceService,
                 EarlyFaultDetectionService,
                 FrictionCompensationControlService,
                 MachiningParameterOptimizationService,
                 CO2ReductionScenarioService,
                 ProductQualityPredictionService,
                 CentralDataMemoryService
]

// C6: Services
instance RealTimeFrictionMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of joint friction and load conditions."
    DTDFVocab:provides JointFrictionInsight, LoadConditionInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Delivers predictive maintenance alerts based on friction trends."
    DTDFVocab:provides MaintenanceAlertInsight
]

instance EarlyFaultDetectionService : DTDFVocab:Service [
    base:desc "Detects early faults in joints and actuators."
    DTDFVocab:provides FaultDetectionInsight
]

instance FrictionCompensationControlService : DTDFVocab:Service [
    base:desc "Executes closed‑loop control for friction compensation."
    DTDFVocab:provides CompensationAction
]

instance MachiningParameterOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes machining parameters (cutting speed, feed) via simulation."
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance CO2ReductionScenarioService : DTDFVocab:Service [
    base:desc "Analyzes CO₂‑reduction scenarios for the machining process."
    DTDFVocab:provides CO2ReductionAnalysisInsight
]

instance ProductQualityPredictionService : DTDFVocab:Service [
    base:desc "Predicts product quality based on process and friction data."
    DTDFVocab:provides QualityPredictionInsight
]

instance CentralDataMemoryService : DTDFVocab:Service [
    base:desc "Provides a central data memory accessible by ancillary applications for visualization and analytics."
    DTDFVocab:provides DataVisualizationAction
]

// C17: Insights
instance JointFrictionInsight : DTDFVocab:Insight [
    base:desc "Current joint friction level derived from combined white‑box and black‑box models."
]

instance LoadConditionInsight : DTDFVocab:Insight [
    base:desc "Real‑time load condition of each robot joint."
]

instance MaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance recommendation based on friction trend analysis."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Early fault detection result indicating potential joint or actuator failures."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommended machining parameter settings to improve efficiency and quality."
]

instance CO2ReductionAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analysis of CO₂‑emission reduction achievable through optimized machining."
]

instance QualityPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted product quality metric based on current process state."
]

// C17: Actions
instance CompensationAction : DTDFVocab:Action [
    base:desc "Automatically adjusts control commands to compensate for measured joint friction."
    DTDFVocab:IsAutomatic true
]

instance DataVisualizationAction : DTDFVocab:Action [
    base:desc "Provides data visualizations to external applications via the central data memory."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin operates in real‑time synchronized with the robot’s control loop. Sensor data are streamed continuously to the twin, processed by the friction simulation, and the resulting model parameters are fed back before the control system’s dead‑time elapses. Thus the synchronization frequency matches the control cycle and latency must be lower than the control system’s dead‑time as required for high‑precision motion control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture consists of a physical robot feeding live sensor streams to an Asset Administration Shell (AAS) executor, which triggers processing components (SysML‑based structural model, Simulink‑based friction simulation wrapped as an FMI component). The processing component generates data traces that are stored in ThingsBoard via MQTT. An automated pipeline builds the digital shadow from the AAS, runs the simulation, and publishes results to a visualization dashboard, providing end‑to‑end orchestration of data acquisition, model execution, and result dissemination."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin lifecycle follows the MBSE development phase in which the system is modelled at successive abstraction levels – requirements, functional architecture, logical architecture, and product/technical layer. At each level a model is created using a suitable language (e.g., SysML for requirements and functional view, ADLs such as ACME, AADL, MontiArc for component‑connector view, and state‑machine or Simulink models for behavior). Transition between stages is managed by traceability links defined in the reference model, allowing propagation of changes from higher‑level specifications to lower‑level implementations. Governance is implied by the need to integrate heterogeneous stakeholders and tools across the abstraction hierarchy."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by combining verified white‑box Simulink models with data‑driven machine‑learning models and by maintaining strict traceability from raw data traces to the generated model outputs. Verification methods include checking the correctness of transformations from SysML specifications to simulation models, as highlighted in the literature. Uncertainty sources are identified in the underlying models and in data preprocessing; they are quantified through traceability links that allow error detection and correction at the level of individual data traces. Quality assurance is achieved by fine‑grained provenance tracking (originates‑from associations) and by enforcing verification of model transformations, as advocated for reliable digital shadow development."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on MQTT (implemented with Mosquitto) as the primary communication protocol. MQTT provides a publish‑subscribe architecture with hierarchical topics and optional read/write permission controls for users. Messages are encoded in JSON and transported over standard TCP/IP networks. Data originating from the robot are sent to the MQTT broker, then forwarded to the AAS Executor and finally to the ThingsBoard IoT platform for storage and visualization. The integration of the Asset Administration Shell ensures that the same data model is used across components, supporting interoperability between the MQTT layer, the AAS layer, and the ThingsBoard dashboard."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is achieved through the use of the Asset Administration Shell (AAS) as the integration backbone, MQTT as the messaging protocol, and ThingsBoard as the IoT data platform. Simulation models are integrated via the Functional Mock‑up Interface (FMI) linking SysML structural models with Simulink behavioral models. This combination enables seamless data exchange between the robot, the twin, and external enterprise systems such as dashboards or optimization services."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The described digital‑twin approach is built on established engineering standards. Structural and architectural models use SysML (OMG standard) for block diagrams, AADL for architecture analysis, ACME for component‑connector descriptions, and MontiArc/Automaton for behavior. Simulation and control logic are expressed in MathWorks Simulink, which is a de‑facto standard for dynamic system simulation. Interoperability between models is achieved through the traceability associations defined in the Digital Shadow Reference Model, but the documents do not specify additional certification or industry‑wide compliance frameworks."
]