import DTDFVocab from "http://example.org/DTDFVocab"

instance TelemetryAcquisitionComponent : DTDFVocab:SensingComponent [
    base:desc "Concrete data traces gathered from the cyber‑physical system and enriched with metadata.",
    DTDFVocab:producedData TelemetryRawTrace
]

instance TelemetryRawTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TelemetryAcquisitionComponent
]

instance ProcessedSimulationData : DTDFVocab:Data [
    base:desc "Output data trace emitted by processing components after executing simulation or data‑calculation models.",
    DTDFVocab:fromData TelemetryRawTrace,
    DTDFVocab:inputTo DataProcessingEngine
]

instance SysMLArchitectureModel : DTDFVocab:Model [
    base:desc "Reference SysML model capturing system structure, properties, and behavior.",
    DTDFVocab:inputTo MBSETransformationEngine
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "Simulink‑based dynamic simulation model used for executing system behavior.",
    DTDFVocab:inputTo SimulinkEngine
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "Data‑calculation model that derives higher‑level abstractions from input data traces.",
    DTDFVocab:inputTo DataProcessingEngine
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation engine executing dynamic models.",
    DTDFVocab:enables SimulationExecutionService
]

instance DataProcessingEngine : DTDFVocab:Enabler [
    base:desc "Processing component that consumes input data traces, runs computational logic of simulation or data‑calculation models, and emits output data traces.",
    DTDFVocab:enables DataDerivationService
]

instance MBSETransformationEngine : DTDFVocab:Enabler [
    base:desc "Model‑based systems‑engineering toolchain (SysML, ADLs) that transforms reference concepts to concrete realizations.",
    DTDFVocab:enables ModelTransformationAction
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Executes simulation models (e.g., Simulink) to generate digital‑shadow data.",
    DTDFVocab:provides SimulationOutcomeInsight
]

instance DataDerivationService : DTDFVocab:Service [
    base:desc "Derives higher‑level data abstractions using data‑calculation models.",
    DTDFVocab:provides DataDerivationInsight
]

instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Insight into system behavior obtained from simulation results."
]

instance DataDerivationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from higher‑level data abstractions produced by data‑calculation models."
]

instance ModelTransformationAction : DTDFVocab:Action [
    base:desc "Transforms SysML models into simulation models while preserving model hierarchy.",
    DTDFVocab:IsAutomatic true
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and validity are addressed through traceability and verification of the model‑based development chain. Reliability depends on the correctness of underlying models and the transformations applied to data (e.g., SysML to simulation models). Verification methods include checking the conformance of concrete models to reference models, ensuring the correctness of transformation rules, and validating white‑box Simulink simulations against expected physical behavior. Uncertainty sources stem from model approximations and data noise; these are managed by maintaining fine‑grained traceability of data traces to their origin, enabling error detection and correction. Quality assurance processes comprise systematic verification of transformations, adherence to reference model constraints, and the use of traceability links to guarantee that each derived data trace can be audited back to its source models and inputs."
]