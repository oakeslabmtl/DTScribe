// C3: Physical sensing components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor position encoder providing angular position of the motor shaft"
    DTDFVocab:producedData MotorPositionData
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary gearbox encoder providing angular position of the cycloidal gearbox"
    DTDFVocab:producedData GearboxPositionData
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring phase current I_M of the motor"
    DTDFVocab:producedData MotorCurrentData
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Data (derived from raw sensor streams)
instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity ω computed from time‑stamped motor position data"
    DTDFVocab:fromData MotorPositionData
    DTDFVocab:inputTo MatlabSimulinkEngine
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Torque τ derived from motor current measurement I_M"
    DTDFVocab:fromData MotorCurrentData
    DTDFVocab:inputTo MatlabSimulinkEngine
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration α derived from angular velocity data"
    DTDFVocab:fromData AngularVelocityData
    DTDFVocab:inputTo MatlabSimulinkEngine
]

// C10: Engineering and simulation models
instance SysMLModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams of the first axis"
    DTDFVocab:inputTo SysMLTool
]

instance FrictionlessSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the motor‑gearbox system without friction"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

instance CoulombViscousSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Coulomb‑Viscous friction"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

instance StribeckSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model implementing the Stribeck friction characteristics"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

instance DahlSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Dahl friction dynamics"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

instance LuGreSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model implementing the LuGre friction model"
    DTDFVocab:inputTo MatlabSimulinkEngine
]

// C11: Enablers (tooling & integration)
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker streaming live sensor data (I_M, encoder angles, derived τ and ω) to the digital shadow"
    DTDFVocab:enables FrictionIdentificationService
]

instance MatlabSimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink runtime executing friction models and processing derived data"
    DTDFVocab:enables FrictionIdentificationService, ModelParameterUpdateService
]

instance DashboardTool : DTDFVocab:Enabler [
    base:desc "Dashboard visualization tool for measured and simulated data"
    DTDFVocab:enables DashboardVisualizationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "AAS providing model integration between engineering tools and the digital twin"
    DTDFVocab:enables FrictionIdentificationService
]

instance SINUMERIK840DController : DTDFVocab:Enabler [
    base:desc "Siemens SINUMERIK 840D controller of the robot axis (passive in the shadow)"
    DTDFVocab:enables ModelParameterUpdateService
]

instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML tool handling block definition and internal block diagrams"
    DTDFVocab:enables FrictionIdentificationService
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction using simulation models"
    DTDFVocab:provides FrictionParameterExtractionInsight, FrictionLossDetectionInsight, UpdateControlParametersAction
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Visualization of measured and simulated motor data on a dashboard"
    DTDFVocab:provides DataVisualizationInsight
]

instance ModelParameterUpdateService : DTDFVocab:Service [
    base:desc "Automatic update of SINUMERIK 840D control parameters to improve positioning accuracy"
    DTDFVocab:provides UpdateControlParametersAction
]

// C17: Insights
instance FrictionParameterExtractionInsight : DTDFVocab:Insight [
    base:desc "Extraction of friction parameters (static, kinetic, viscous) from live data"
]

instance FrictionLossDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of friction loss events during robot operation"
]

instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of measured and simulated motor data on the dashboard"
]

// C17: Actions
instance UpdateControlParametersAction : DTDFVocab:Action [
    base:desc "Automatic update of control parameters to enhance positioning accuracy of the robot"
    DTDFVocab:IsAutomatic true
]

// C17: Components (physical)
instance MotorComponent : DTDFVocab:Component [
    base:desc "Motor of the first axis of the MABI MAX 100 six‑axis industrial robot"
]

instance GearwheelComponent : DTDFVocab:Component [
    base:desc "Gearwheel transmitting torque from the motor to the gearbox"
]

instance CycloidalGearboxComponent : DTDFVocab:Component [
    base:desc "Cycloidal gearbox coupling the gearwheel to the robot axis"
]

// C17: Environment (digital shadow)
instance FrictionShadow : DTDFVocab:Environment [
    base:contains MotorComponent, GearwheelComponent, CycloidalGearboxComponent,
                MotorPositionEncoder, GearboxEncoder, MotorCurrentSensor,
                MotorPositionData, GearboxPositionData, MotorCurrentData,
                AngularVelocityData, TorqueData, AccelerationData,
                SysMLModel, FrictionlessSimulinkModel, CoulombViscousSimulinkModel,
                StribeckSimulinkModel, DahlSimulinkModel, LuGreSimulinkModel,
                MQTTBroker, MatlabSimulinkEngine, DashboardTool,
                AssetAdministrationShell, SINUMERIK840DController, SysMLTool,
                FrictionIdentificationService, DashboardVisualizationService,
                ModelParameterUpdateService,
                FrictionParameterExtractionInsight, FrictionLossDetectionInsight,
                DataVisualizationInsight, UpdateControlParametersAction
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow does not send commands back to the robot"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time operation synchronized with the robot’s sensor update rate (up to the maximum axis speed of 75°/s)"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow consisting of Purpose (FrictionDerivation), Asset (MABI first axis), Sources (sensors, MQTT channels), Processing components (Simulation M, GW, GB), Models (engineering and simulation), and DataTraces (I_M, r_M, r_G, r_out, \u0302r_M, \u0302r_G, \u0302r_out)"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Engineering (SysML structural model), implementation (Simulink simulation and friction models), operational (continuous identification during robot runtime)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Combination of white‑box analytical friction models and black‑box data‑driven models; continuous re‑identification to capture wear, temperature and load effects; validation by comparing simulated outputs with measured data traces; full traceability via processing component provenance"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data transmitted over MQTT (TCP/IP) from the robot controller to the digital shadow; integration with AAS for asset description"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of Asset Administration Shell (AAS) as an Industry 4.0 standard, SysML modeling, and the Digital Shadow Reference Model (UML class diagram)"
]