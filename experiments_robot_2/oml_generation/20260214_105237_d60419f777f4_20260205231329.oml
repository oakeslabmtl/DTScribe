]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D/4D dashboards for real-time system state visualization and scenario simulation."
    DTDFVocab:provides VisualizationInsight, ScenarioSimulationAction
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Context-aware decision support framework integrating multiple data sources for strategic manufacturing planning."
    DTDFVocab:provides DecisionSupportInsight, StrategicPlanningAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance analytics forecasting equipment failures and maintenance needs based on sensor data analysis."
    DTDFVocab:provides FailureForecastInsight, MaintenanceSchedulingAction
]

