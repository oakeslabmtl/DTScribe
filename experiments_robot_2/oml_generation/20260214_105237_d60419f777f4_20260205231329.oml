// C2: Acting Components
// (empty as per requirements)

// C3: Physical Sensing Components
instance JointAngleEncoder : DTDFVocab:SensingComponent [
    base:desc "High-precision encoder capturing dynamic joint angles for robotic systems with millisecond-level resolution to support data-driven friction modeling."
    DTDFVocab:producedData JointAngleDataTransmitted
]

instance ForceTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Distributed force/torque sensor array measuring nonlinear robotic joint dynamics with sub-millisecond sampling for friction coefficient determination."
    DTDFVocab:producedData ForceTorqueDataTransmitted
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency accelerometer array capturing vibration signatures for predictive maintenance in manufacturing processes."
    DTDFVocab:producedData VibrationDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Precision temperature sensor monitoring thermal conditions in injection molding machines for process stability analysis."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OperationalLogCollector : DTDFVocab:SensingComponent [
    base:desc "System event logger capturing operational traces including timestamps, process execution records, and anomaly events for manufacturing systems."
    DTDFVocab:producedData OperationalLogDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance JointAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointAngleEncoder
]

instance ForceTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ForceTorqueSensor
]

instance VibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OperationalLogDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalLogCollector
]

// C10: Models/Data
instance PhysicsBasedRobotDynamicsModel : DTDFVocab:Model [
    base:desc "White-box analytical model implemented in Simulink representing robot kinematics and dynamics with interpretable equations for friction compensation."
    DTDFVocab:inputTo SimulinkSimulationEnabler, DataAggregationEnabler
]

instance MachineLearningFrictionModel : DTDFVocab:Model [
    base:desc "Black-box neural network model trained on historical force/torque data to predict nonlinear friction effects in robotic joints."
    DTDFVocab:inputTo AIMLTrainingEnabler, DataAggregationEnabler
]

instance InjectionMoldingProcessModel : DTDFVocab:Model [
    base:desc "Physics-based CAE model simulating thermal and pressure dynamics in injection molding processes for quality control."
    DTDFVocab:inputTo InjectionMoldingSimulationEnabler, DataAggregationEnabler
]

instance StateMachineBehaviorModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model defining logical architecture and component interaction protocols for manufacturing systems."
    DTDFVocab:inputTo SysMLModelingEnabler, DataAggregationEnabler
]

instance JointAngleData : DTDFVocab:Data [
    base:desc "Aggregated joint angle data traces filtered and normalized for real-time monitoring of robotic system states."
    DTDFVocab:fromData JointAngleDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler, StateTrackingService
]

instance ForceTorqueData : DTDFVocab:Data [
    base:desc "Processed force/torque measurements with noise reduction applied for friction coefficient calculation and predictive maintenance."
    DTDFVocab:fromData ForceTorqueDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler, QualityControlService
]

instance VibrationData : DTDFVocab:Data [
    base:desc "Vibration signature data with frequency domain analysis applied for anomaly detection in manufacturing equipment."
    DTDFVocab:fromData VibrationDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler, FailurePredictionService
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Thermal data with moving average smoothing applied for process stability monitoring in injection molding."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler, ProcessOptimizationService
]

instance OperationalLogData : DTDFVocab:Data [
    base:desc "Structured operational event logs with timestamp normalization for traceability and process execution analysis."
    DTDFVocab:fromData OperationalLogDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler, DecisionSupportService
]

// C11: Enablers
instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink platform enabling detailed behavioral modeling and dynamic system simulation for robotics applications."
    DTDFVocab:enables RealTimeDataAggregationService, StateTrackingService, ClosedLoopAutomationService
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "MQTT-based ThingsBoard v4.0.0 platform aggregating heterogeneous sensor data streams with rule engine for contextual analysis."
    DTDFVocab:enables RealTimeDataAggregationService, FailurePredictionService, VisualizationService
]

instance AIMLTrainingEnabler : DTDFVocab:Enabler [
    base:desc "TensorFlow/PyTorch framework for training machine learning models on historical sensor data to predict nonlinear system behaviors."
    DTDFVocab:enables PredictiveMaintenanceService, QualityControlService
]

instance InjectionMoldingSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Specialized CAE software for injection molding process simulation with thermal and pressure dynamics modeling."
    DTDFVocab:enables ProcessOptimizationService, QualityControlService
]

instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 toolset supporting component-connector architecture modeling with Internal Block Diagrams for system decomposition."
    DTDFVocab:enables DecisionSupportService
]

instance EdgeProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Edge computing framework enabling low-latency processing of sensor data for real-time DT updates in distributed manufacturing."
    DTDFVocab:enables RealTimeDataAggregationService
]

// C6: Services
instance RealTimeDataAggregationService : DTDFVocab:Service [
    base:desc "Passive collection and event-triggered transmission of contextual data traces from physical systems to digital representations."
    DTDFVocab:provides DataAbstractionInsight, StateTrackingInsight
]

instance StateTrackingService : DTDFVocab:Service [
    base:desc "Continuous monitoring of physical system states with anomaly detection for injection molding machines and robotic systems."
    DTDFVocab:provides StateTrackingInsight, AnomalyDetectionAction
]

instance ProcessOptimizationService : DTDFVocab:Service [
    base:desc "Dynamic adjustment of production parameters using AI-driven recommendations for energy efficiency and yield improvement."
