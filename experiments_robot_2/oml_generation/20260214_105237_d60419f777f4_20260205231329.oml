    base:desc "Optimal control parameters for robotic and CNC systems derived from physics-based and data-driven models."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D visualizations of system states with configurable views for different stakeholder roles."
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Contextual decision support outputs integrating multiple data sources for strategic manufacturing planning."
]

