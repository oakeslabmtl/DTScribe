// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the robot joint input electrical current"
    DTDFVocab:producedData InputCurrentTransmission
]

instance MotorAngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the motor angular velocity of the robot joint"
    DTDFVocab:producedData MotorAngularVelocityTransmission
]

instance FirstAxisPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the first‑axis position of the robot during machining"
    DTDFVocab:producedData FirstAxisPositionTransmission
]

// C4: Physical-to-virtual interaction – Data transmitted via MQTT
instance InputCurrentTransmission : DTDFVocab:DataTransmitted [
    base:desc "JSON payload (via Mosquitto MQTT) of pre‑processed input current"
    DTDFVocab:producedFrom InputCurrentSensor
]

instance MotorAngularVelocityTransmission : DTDFVocab:DataTransmitted [
    base:desc "JSON payload (via Mosquitto MQTT) of pre‑processed motor angular velocity"
    DTDFVocab:producedFrom MotorAngularVelocitySensor
]

instance FirstAxisPositionTransmission : DTDFVocab:DataTransmitted [
    base:desc "JSON payload (via Mosquitto MQTT) of pre‑processed first‑axis position"
    DTDFVocab:producedFrom FirstAxisPositionSensor
]

// C10: Data instances
instance InputCurrentData : DTDFVocab:Data [
    base:desc "Pre‑processed input current trace after low‑pass filtering"
    DTDFVocab:fromData InputCurrentTransmission
    DTDFVocab:inputTo AASExecutorEnabler
]

instance MotorAngularVelocityData : DTDFVocab:Data [
    base:desc "Pre‑processed motor angular velocity trace after low‑pass filtering"
    DTDFVocab:fromData MotorAngularVelocityTransmission
    DTDFVocab:inputTo AASExecutorEnabler
]

instance FirstAxisPositionData : DTDFVocab:Data [
    base:desc "Pre‑processed first‑axis position trace after low‑pass filtering"
    DTDFVocab:fromData FirstAxisPositionTransmission
    DTDFVocab:inputTo AASExecutorEnabler
]

// C10: Models (engineering, simulation, data‑calculation)
instance LowPassFilterModel : DTDFVocab:Model [
    base:desc "Low‑pass filter applied to raw sensor traces to remove noise"
    DTDFVocab:inputTo AASExecutorEnabler
]

instance WhiteBoxFrictionModel : DTDFVocab:Model [
    base:desc "Physics‑based (Simulink) white‑box model of joint friction"
    DTDFVocab:inputTo AASExecutorEnabler
]

instance BlackBoxFrictionModel : DTDFVocab:Model [
    base:desc "Data‑driven (neural‑network) black‑box model for non‑linear friction effects"
    DTDFVocab:inputTo AASExecutorEnabler
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Mosquitto MQTT broker that converts measurements to JSON and publishes them"
    DTDFVocab:enables CentralDataMemoryService
]

instance AASExecutorEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) Executor that builds and updates the digital shadow"
    DTDFVocab:enables RealTimeFrictionMonitoringService,
                     FrictionCompensationService,
                     PredictiveMaintenanceService,
                     MachiningParameterOptimizationService,
                     CO2ReductionSupportService,
                     ProductQualityPredictionService,
                     CentralDataMemoryService
]

// C6: Services
instance RealTimeFrictionMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of joint friction using incoming sensor data"
    DTDFVocab:provides FrictionAnomalyInsight
]

instance FrictionCompensationService : DTDFVocab:Service [
    base:desc "Automatic compensation of internal joint friction via the control system"
    DTDFVocab:provides CompensationAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance and early fault detection based on friction anomalies"
    DTDFVocab:provides MaintenanceAlertAction
]

instance MachiningParameterOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of machining parameters through simulated experiments"
    DTDFVocab:provides OptimizationSuggestionAction
]

instance CO2ReductionSupportService : DTDFVocab:Service [
    base:desc "Support for CO₂‑reduction strategies via friction‑aware control adjustments"
    DTDFVocab:provides CO2ReductionInsight
]

instance ProductQualityPredictionService : DTDFVocab:Service [
    base:desc "Prediction of product quality based on friction‑influenced process dynamics"
    DTDFVocab:provides QualityPredictionInsight
]

instance CentralDataMemoryService : DTDFVocab:Service [
    base:desc "Provides a central data repository (digital shadow) for all incoming traces"
    DTDFVocab:provides DataMemoryInsight
]

// C17: Insights / Actions
instance FrictionAnomalyInsight : DTDFVocab:Insight [
    base:desc "Insight detecting abnormal friction behavior indicative of wear or fault"
]

instance CompensationAction : DTDFVocab:Action [
    base:desc "Action that adjusts control commands to compensate for detected internal friction"
    DTDFVocab:IsAutomatic true
]

instance MaintenanceAlertAction : DTDFVocab:Action [
    base:desc "Action that raises a maintenance alert when friction trends exceed thresholds"
    DTDFVocab:IsAutomatic true
]

instance OptimizationSuggestionAction : DTDFVocab:Action [
    base:desc "Action that suggests new machining parameters to improve productivity"
    DTDFVocab:IsAutomatic false
]

instance CO2ReductionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating potential CO₂ savings through friction‑aware operation"
]

instance QualityPredictionInsight : DTDFVocab:Insight [
    base:desc "Insight predicting final product quality based on current friction state"
]

instance DataMemoryInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful storage of latest sensor traces in the digital twin"
]

// C2: Acting components (optional – describe robot joint as acting component)
instance IndustrialRobotJoint : DTDFVocab:ActingComponent [
    base:desc "Physical joint of the industrial robot whose friction is modelled and compensated"
]

// C18: Environment (optional)
instance ManufacturingCellEnvironment : DTDFVocab:Environment [
    base:contains IndustrialRobotJoint, InputCurrentSensor, MotorAngularVelocitySensor, FirstAxisPositionSensor
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates in (near) real‑time, receiving a continuous data stream from the robot’s sensors. Model calculations (e.g., friction‑model simulation) are executed on‑line so that the update latency must stay below the control‑system dead‑time, as required for high‑precision motion control. Synchronisation between physical and digital components is realised by the AAS‑Executor pipeline that populates measured, simulated and reference values into the digital shadow stored in ThingsBoard, but no explicit frequency or granularity is given in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a pipeline‑oriented constellation: physical robot data are collected via MQTT and stored in ThingsBoard; an Asset Administration Shell (AAS) encapsulates the robot’s SysML structural model and Simulink behavioural models linked through FMI; the AAS Executor (Fig. 8) triggers simulation models, computes updated friction parameters and automatically pushes the results back to the digital shadow and a visualization dashboard. This integrates heterogeneous models, processing components, and data stores in a coordinated workflow."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The documents describe a DT lifecycle that starts with MBSE‑based development phases – requirements, functional architecture, logical architecture and product/technical layer – followed by a concretization step where the Digital‑Shadow reference model is instantiated as a concrete DS (mapping reference classes to concrete ones). After the concrete model is realized, processing components generate data traces that become part of the operational digital shadow, and the DT may then be deployed for runtime monitoring and prediction. Transition between phases is managed by traceability links (“originates‑from” associations) that preserve provenance of data traces across processing steps."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by systematically validating and verifying model transformations, for example from SysML specifications to simulation models such as Simulink, as highlighted in the reference literature. Traceability of data traces to their originating processing components and models provides a basis for error detection and correction, ensuring that uncertainties introduced by model conversion or data processing are quantifiable. The approach emphasises real‑time requirements and control‑system dead‑time considerations, requiring that friction models remain accurate throughout the robot’s operational life. Continuous data streams enable dynamic adaptation of both white‑box and black‑box models, supporting ongoing validation against observed behaviour. Quality assurance processes include the verification of correctness of transformations, maintenance of traceability links, and periodic re‑training or re‑parameterisation of models to mitigate drift and maintain the prescribed level of model accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on the MQTT publish‑subscribe protocol, implemented with Mosquitto, to transport JSON‑encoded sensor data from the preprocessing unit to the AAS Executor and further to ThingsBoard. Topics are hierarchical, allowing fine‑grained permission control. ThingsBoard (version 4.0.0, 2024) is used as the IoT platform for storage and visualization, providing a scalable, message‑driven backbone. Communication is message‑based, lightweight, and supports both textual (numbers, JSON) and binary payloads. No explicit bandwidth, latency, redundancy, or security specifications (e.g., TLS) are given in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital shadow pipeline is deployed on a local infrastructure that includes a relational database configured to the digital‑shadow data model, a preprocessing component, an MQTT broker (Mosquitto), an AAS Executor, and a ThingsBoard instance for dashboard visualization. The Asset Administration Shell (AAS) acts as the single source of truth, holding sub‑models, SysML identification points, and links to FMU simulation models exported from Simulink. While the exact hosting platform (cloud, edge, on‑premise) and scaling mechanisms are not detailed, the architecture suggests an edge‑centric deployment with data persisted in the local database and visualised via ThingsBoard, which can be operated either on‑premise or in the cloud."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration relies on standard Industry 4.0 interfaces: MQTT for IoT data transport, ThingsBoard for data storage and visualisation, and the Asset Administration Shell (AAS) as the interoperability backbone. Model exchange uses SysML for structural description and Simulink/FMI for behavioural simulation. These standards enable the digital shadow to interoperate with external dashboards and potentially with other enterprise systems, although concrete external system dependencies are not detailed."
]