// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor electric current measurement (I_M) from the permanent‑magnet synchronous motor."
    DTDFVocab:producedData MotorCurrentTransmission
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor shaft providing raw angular position."
    DTDFVocab:producedData MotorPositionTransmission
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted after the cycloidal gearbox giving post‑gearbox angular position."
    DTDFVocab:producedData GearboxPositionTransmission
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance MotorCurrentTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorPositionTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxPositionTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

instance DerivedTorqueTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor,
    MotorPositionEncoder,
    GearboxPositionEncoder
]

instance DerivedAngularVelocityTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder,
    GearboxPositionEncoder
]

instance DerivedAccelerationTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder,
    GearboxPositionEncoder
]

// C10: Data instances
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Live motor electric current (I_M) time‑series."
    DTDFVocab:fromData MotorCurrentTransmission
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Live motor‑mounted encoder angle time‑series."
    DTDFVocab:fromData MotorPositionTransmission
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Live gearbox‑mounted encoder angle time‑series."
    DTDFVocab:fromData GearboxPositionTransmission
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque (τ) calculated from current and position measurements."
    DTDFVocab:fromData DerivedTorqueTransmission
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity (ω) computed from encoder positions."
    DTDFVocab:fromData DerivedAngularVelocityTransmission
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration computed from successive encoder positions."
    DTDFVocab:fromData DerivedAccelerationTransmission
]

// C10: Engineering and executable models
instance AxisStructureSysMLModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams describing the vertical axis structure of the MABI MAX 100 robot."
    DTDFVocab:inputTo AssetAdministrationShell
]

instance FrictionlessSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model representing the axis dynamics without friction."
]

instance CoulombViscousSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Coulomb‑viscous friction behavior."
]

instance StribeckSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model implementing the Stribeck friction characteristic."
]

instance DahlSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Dahl’s friction model."
]

instance LuGreSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model implementing the LuGre friction model."
]

// C11: Enablers (tooling and integration)
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML used for system modeling of the robot axis."
    DTDFVocab:enables FrictionIdentificationService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink executes the friction models and processes incoming sensor data in real time."
    DTDFVocab:enables FrictionIdentificationService,
    ParameterRefinementService
]

instance MqttBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker streams live sensor data from the physical robot to the digital twin."
    DTDFVocab:enables RealTimeVisualizationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "AAS provides standardized data integration between the physical asset and its digital representation."
    DTDFVocab:enables RealTimeVisualizationService
]

instance WebDashboard : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard visualizes friction parameters and motion‑accuracy insights for operators."
    DTDFVocab:enables RealTimeVisualizationService
]

// C6: Services offered by the digital shadow
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuously identifies static, kinetic and viscous friction using white‑box and black‑box models."
    DTDFVocab:provides MotionAccuracyImprovementInsight,
    OperatorDecisionInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of derived friction parameters and motion‑accuracy metrics on the dashboard."
    DTDFVocab:provides OperatorDecisionInsight
]

instance ParameterRefinementService : DTDFVocab:Service [
    base:desc "Generates refined model parameters to improve robot motion control accuracy."
    DTDFVocab:provides RefinedParametersAction
]

// C17: Insights and actions resulting from services
instance MotionAccuracyImprovementInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters are used to adjust the robot controller for higher motion accuracy."
]

instance OperatorDecisionInsight : DTDFVocab:Insight [
    base:desc "Operators can fine‑tune control strategies based on visualized friction parameters."
]

instance RefinedParametersAction : DTDFVocab:Action [
    base:desc "Update the robot controller with refined friction model parameters to enhance motion precision."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data are exchanged continuously in real time, with live sensor streams synchronized to the robot's control cycle and processed on‑the‑fly for friction identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow is instantiated as a concrete realization of the Digital Shadow Reference Model, comprising purpose (FrictionDerivation), asset (MABI first axis), sources (sensors and derived data), processing components (simulation models), and data traces organized into a unified dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow combines engineering models (structural and behavioral SysML models) representing the design stage with live operational data, thus addressing both the design and operational life‑cycle stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability links each data point to its source and processing model, enabling validation by comparing simulated friction‑less and friction‑augmented outputs against measured reference data; continuous updating of white‑box and black‑box parameters ensures model fidelity over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Live sensor streams are transmitted from the robot to the digital shadow via the MQTT protocol."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Asset Administration Shells (AAS) are employed to standardize the representation and exchange of asset data within the digital shadow ecosystem."
]