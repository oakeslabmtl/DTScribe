// C1: Physical Components
instance MabiMax100Robot : DTDFVocab:Component [
    base:desc "MABI MAX 100 industrial robot, focus on first axis motor and gearbox"
]
instance FirstAxisMotor : DTDFVocab:Component [
    base:desc "High‑precision motor driving the robot's first axis"
]
instance FirstAxisGearbox : DTDFVocab:Component [
    base:desc "Gearbox coupled to the first‑axis motor, providing torque transmission"
]
instance Sinumerik840DController : DTDFVocab:Component [
    base:desc "Siemens SINUMERIK 840D sl controller governing motion of the first axis"
]

// C2: Acting Components (none explicitly described)

// C3: Physical Sensing Components
instance RobotFirstAxisSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor on the MABI MAX 100 robot first axis (motor and gearbox) that captures position, velocity and torque data traces"
    DTDFVocab:producedData FirstAxisDataTransmitted
]

// C4: Physical‑to‑Virtual Interaction
instance FirstAxisDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotFirstAxisSensor
]

// C5: Data
instance FirstAxisRawData : DTDFVocab:Data [
    base:desc "Raw data trace from the first‑axis sensor, containing time‑stamped position, velocity and torque values"
    DTDFVocab:fromData FirstAxisDataTransmitted
    DTDFVocab:inputTo ProcessingComponent
]

// C10: Models / Data
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML internal block diagram defining components, interfaces and composition of the robot"
    DTDFVocab:inputTo ProcessingComponent
]
instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state‑machine model (v1.7) describing behavioural states of the first axis"
    DTDFVocab:inputTo ProcessingComponent
]
instance ADLArchitectureModel : DTDFVocab:Model [
    base:desc "Architecture description (ACME / AADL / MontiArc) specifying component‑connector topology"
    DTDFVocab:inputTo ProcessingComponent
]
instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink simulation model executing physics‑based calculations for the first axis"
    DTDFVocab:inputTo ProcessingComponent
]
instance CppProcessingCode : DTDFVocab:Model [
    base:desc "Generated C++ code implementing processing logic for the digital twin"
    DTDFVocab:inputTo ProcessingComponent
]
instance JavaProcessingCode : DTDFVocab:Model [
    base:desc "Generated Java code implementing auxiliary processing services"
    DTDFVocab:inputTo ProcessingComponent
]

// C11: Enablers
instance ProcessingComponent : DTDFVocab:Enabler [
    base:desc "Processing component that consumes input traces, invokes simulation/calculation models and produces output data with full provenance"
    DTDFVocab:enables VisualizationDashboardService,
                     JointFrictionDiagnosticService,
                     MotionAccuracyOptimizationService
]

// C6: Services
instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Real‑time visualization dashboard presenting first‑axis motion data to operators"
    DTDFVocab:provides RealTimeAxisDataInsight
]
instance JointFrictionDiagnosticService : DTDFVocab:Service [
    base:desc "Diagnostic analysis service that detects joint friction anomalies on the first axis"
    DTDFVocab:provides FrictionAnomalyInsight,
                     RecommendFrictionMitigationAction
]
instance MotionAccuracyOptimizationService : DTDFVocab:Service [
    base:desc "Performance‑optimisation service that predicts motion‑accuracy errors and suggests corrective actions"
    DTDFVocab:provides PerformanceOptimizationInsight,
                     SuggestCorrectiveMotionAction
]

// C17: Insights
instance RealTimeAxisDataInsight : DTDFVocab:Insight [
    base:desc "Insight delivering live status of position, velocity and torque for the robot's first axis"
]
instance FrictionAnomalyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating elevated friction levels in the first‑axis gearbox"
]
instance PerformanceOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight estimating future motion‑accuracy deviations based on current data"
]

// C17: Actions
instance RecommendFrictionMitigationAction : DTDFVocab:Action [
    base:desc "Action recommending maintenance or lubrication to reduce detected joint friction"
    DTDFVocab:IsAutomatic false
]
instance SuggestCorrectiveMotionAction : DTDFVocab:Action [
    base:desc "Action automatically adjusting controller set‑points to improve motion accuracy"
    DTDFVocab:IsAutomatic true
]

// C14: Environment
instance ManufacturingCell : DTDFVocab:Environment [
    base:contains MabiMax100Robot,
                 FirstAxisMotor,
                 FirstAxisGearbox,
                 Sinumerik840DController,
                 RobotFirstAxisSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is defined as a passive entity with an automated one‑way data flow from the physical object to the digital object; it neither operates autonomously nor pushes data back to the physical system. Therefore, no command types, control message formats, validation, authentication, feedback, or execution confirmation mechanisms are present."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by integrating both white‑box Simulink simulations (providing clear interpretability and predictability) and black‑box learning models (capturing complex non‑linear relationships). Validation and verification focus on ensuring the correctness of model transformations, such as from SysML specifications to simulation models, with traceability mechanisms highlighted to track changes. Reliability is linked to the correctness of underlying models and data transformations, prompting systematic verification of transformation steps and verification of model outputs against physical measurements. While explicit uncertainty quantification methods are not detailed, the emphasis on traceability and verification implies a quality‑assurance process aimed at detecting and correcting model errors."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin implementation adheres to multiple established modeling standards. System structure and behavior are captured using Model‑Based Systems‑Engineering (MBSE) with SysML (Systems Modeling Language) for requirements, functional, and logical architectures. Component‑connector specifications rely on architecture description languages (ADLs) such as ACME, AADL, and MontiArc, as well as SysML internal block diagrams (IBDs). The Digital Shadow reference model is expressed as a UML (Unified Modeling Language) class diagram, providing a formal metamodel that can be concretized through a defined conformance relation. These standards ensure interoperability with simulation tools (e.g., MathWorks Simulink) and code generators for languages like C++ and Java."
]