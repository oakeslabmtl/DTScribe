// Physical sensing component
instance RealTimePlantSensor : DTDFVocab:SensingComponent [
    base:desc "Real‑time sensor stream from the physical plant used to feed the digital twin."
    DTDFVocab:producedData RealTimePlantDataTransmitted
]

// Data transmitted by the sensor
instance RealTimePlantDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RealTimePlantSensor
]

// Raw data derived from the transmitted data
instance RealTimePlantData : DTDFVocab:Data [
    base:desc "Aggregated data from the real‑time plant sensor, used by the digital twin models."
    DTDFVocab:fromData RealTimePlantDataTransmitted
]

// Models
instance SimulinkClosedLoopModel : DTDFVocab:Model [
    base:desc "Closed‑loop simulation model integration with MathWorks Simulink."
    DTDFVocab:inputTo SimulinkEngine
]

instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML v1.7 model capturing requirements, functional, logical, and product/technical layers."
    DTDFVocab:inputTo SysMLv17Tool
]

instance ACMEComponentConnectorModel : DTDFVocab:Model [
    base:desc "ACME model representing component‑connector topology and interfaces."
    DTDFVocab:inputTo ACMEModeler
]

instance MontiArcStructuralModel : DTDFVocab:Model [
    base:desc "MontiArc model representing structural component hierarchy."
    DTDFVocab:inputTo MontiArcModeler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model capturing behavioral state machines."
    DTDFVocab:inputTo MontiArcModeler
]

// Enablers
instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink engine for behavioral simulation."
    DTDFVocab:enables SimulationExecutionService
]

instance SysMLv17Tool : DTDFVocab:Enabler [
    base:desc "SysML v1.7 tool for requirement and architecture modeling."
    DTDFVocab:enables RequirementsTraceabilityService
]

instance CppGenerator : DTDFVocab:Enabler [
    base:desc "C++ code generator for MontiArc models."
    DTDFVocab:enables CodeGenerationService
]

instance JavaGenerator : DTDFVocab:Enabler [
    base:desc "Java code generator for MontiArc models."
    DTDFVocab:enables CodeGenerationService
]

instance DataIntegrationPlatform : DTDFVocab:Enabler [
    base:desc "Platform accepting one‑way data streams from sensors."
    DTDFVocab:enables DataIntegrationService
]

instance MontiArcModeler : DTDFVocab:Enabler [
    base:desc "MontiArc ADL modeler for structural and behavioral modeling."
    DTDFVocab:enables MontiArcModelingService
]

instance ACMEModeler : DTDFVocab:Enabler [
    base:desc "ACME modeler for component‑connector topology representation."
    DTDFVocab:enables ACMEModelingService
]

// Services
instance RequirementsTraceabilityService : DTDFVocab:Service [
    base:desc "Service providing traceability between requirements, functions, and logic."
    DTDFVocab:provides RequirementsMappingInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service executing simulations in Simulink and providing simulation results."
    DTDFVocab:provides SimulationResultInsight
]

instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Service generating code in C++ and Java from MontiArc models."
    DTDFVocab:provides GeneratedCodeInsight
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Service integrating data streams from physical sensors into the digital twin."
    DTDFVocab:provides IntegratedDataInsight
]

instance MontiArcModelingService : DTDFVocab:Service [
    base:desc "Service facilitating MontiArc model creation and validation."
    DTDFVocab:provides MontiArcModelInsight
]

instance ACMEModelingService : DTDFVocab:Service [
    base:desc "Service facilitating ACME model creation and validation."
    DTDFVocab:provides ACMEModelInsight
]

// Insights
instance RequirementsMappingInsight : DTDFVocab:Insight [
    base:desc "Insight mapping model relations Functional→Logical→Physical."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight providing simulation outputs and verification metrics."
]

instance GeneratedCodeInsight : DTDFVocab:Insight [
    base:desc "Insight giving details of generated source code."
]

instance IntegratedDataInsight : DTDFVocab:Insight [
    base:desc "Insight detailing integrated data contextual aggregation."
]

instance MontiArcModelInsight : DTDFVocab:Insight [
    base:desc "Insight into MontiArc structural and behavioral model integrity."
]

instance ACMEModelInsight : DTDFVocab:Insight [
    base:desc "Insight into ACME component‑connector topology representation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital Twin development proceeds through multiple MBSE abstraction levels—requirements, functional architecture, logical architecture, and product/technical layers. At the requirements phase, textual and constraint models are captured; the functional architecture is expressed via SysML requirement diagrams and SysML requirement constraints. The logical architecture is captured in SysML interaction blocks or in MontiArc component‑connector models; the product/technical layer is implemented using C++ or Java code and Simulink blocks. Transition between the levels is managed by model synchronization and co‑simulation (e.g., SysML IBDs exported to Simulink for dynamic simulation). Governance across phases requires an overarching MBSE repository and traceability links that tie SysML requirements to C++ code, ensuring that change propagation and version control are maintained via a configuration management system."
]