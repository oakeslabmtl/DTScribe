instance SysMLModelingService : DTDFVocab:Service [
    base:desc "Service for creating and managing SysML structural models",
    provides SysMLModelingInsight
]

instance RFLPService : DTDFVocab:Service [
    base:desc "Service for RFLP-based system modeling",
    provides RFLPInsight
]

instance OOSEMService : DTDFVocab:Service [
    base:desc "Service for OOSEM-based system modeling",
    provides OOSEMInsight
]

instance SPESService : DTDFVocab:Service [
    base:desc "Service for SPES-based system modeling",
    provides SPESInsight
]

instance SMArDTService : DTDFVocab:Service [
    base:desc "Service for SMArDT-based system modeling",
    provides SMArDTInsight
]

instance ACMEModelingService : DTDFVocab:Service [
    base:desc "Service for ACME-based architecture modeling",
    provides ACMEModelingInsight
]

instance AADLModelingService : DTDFVocab:Service [
    base:desc "Service for AADL-based architecture modeling",
    provides AADLModelingInsight
]

instance MontiArcModelingService : DTDFVocab:Service [
    base:desc "Service for MontiArc-based architecture modeling",
    provides MontiArcModelingInsight
]

instance SysMLIBDsService : DTDFVocab:Service [
    base:desc "Service for SysML Internal Block Diagrams modeling",
    provides SysMLIBDsInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for analytical simulations using MathWorks Simulink",
    provides SimulationInsight
]

instance CPlusPlusService : DTDFVocab:Service [
    base:desc "Service for implementing behavior using C++",
    provides CPlusPlusInsight
]

instance JavaService : DTDFVocab:Service [
    base:desc "Service for implementing behavior using Java",
    provides JavaInsight
]

instance SysML : DTDFVocab:Enabler [
    base:desc "SysML methodology for systems engineering modeling",
    enables SysMLModelingService
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "RFLP methodology for systems engineering",
    enables RFLPService
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for object-oriented systems engineering",
    enables OOSEMService
]

instance SPES : DTDFVocab:Enabler [
    base:desc "SPES methodology for embedded systems engineering",
    enables SPESService
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for system modeling and analysis",
    enables SMArDTService
]

instance ACME : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for specifying components, interfaces, interconnections, and composition",
    enables ACMEModelingService
]

instance AADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for specifying components, interfaces, interconnections, and composition",
    enables AADLModelingService
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for specifying components, interfaces, interconnections, and composition",
    enables MontiArcModelingService
]

instance SysMLIBDs : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component and connector modeling",
    enables SysMLIBDsService
]

instance MathWorksSimulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation tool for analytical simulations",
    enables SimulationService
]

instance CPlusPlus : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior description",
    enables CPlusPlusService
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior description",
    enables JavaService
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "Structural model using SysML for system components and interfaces",
    inputTo SysML
]

instance MontiArcBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model using MontiArc Automaton for system dynamics",
    inputTo MontiArc
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "State machine model using SysML state machines for system behavior",
    inputTo SysML
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "Analytical simulation model using MathWorks Simulink",
    inputTo MathWorksSimulink
]

instance PhysicalSystemStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors capturing physical system states for digital shadow transmission",
    producedData PhysicalSystemStatesTransmitted
]

instance PhysicalSystemStatesTransmitted : DTDFVocab:DataTransmitted [
    producedFrom PhysicalSystemStateSensor
]

instance PhysicalSystemStateData : DTDFVocab:Data [
    base:desc "Physical system states transmitted via one-way data flows characteristic of digital shadows",
    fromData PhysicalSystemStatesTransmitted,
    inputTo MathWorksSimulink, SysML, MontiArc, ACME, AADL, CPlusPlus, Java
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Asset Administration Shell (AAS) security submodel (Plattform Industrie 4.0, Document 50) specifies X.509 certificate-based authentication and role-based access control for asset data access. Mosquitto (Document 52) implements MQTT security with TLS encryption and username/password authentication. Thingsboard (Document 53) employs JWT token authentication and fine-grained role-based access control for IoT platform security."
]