// C3: Physical sensing components
instance PhysicalSystemSensor : DTDFVocab:SensingComponent [
    base:desc "Physical system sensor collecting contextual data traces from operational systems (e.g., sensors, IoT devices) as part of the Digital Shadow infrastructure."
    DTDFVocab:producedData PhysicalSystemDataTransmitted
]

instance ManufacturingProcessSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing real-time manufacturing process metrics (e.g., operational logs, environmental metrics) for Digital Twin data aggregation."
    DTDFVocab:producedData ManufacturingProcessDataTransmitted
]

// C4: Physical-to-virtual interaction
instance PhysicalSystemDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemSensor
    base:desc "Automated one-way transmission of contextual data traces (time-series sensor data, discrete event logs, structured metadata) from physical systems to digital representation."
]

instance ManufacturingProcessDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ManufacturingProcessSensor
    base:desc "Event-driven or periodic transmission of manufacturing process data (sensor readings, operational logs) for Digital Twin analysis."
]

// C10: Models/Data
instance RequirementsModel : DTDFVocab:Model [
    base:desc "SysML-based requirements model structured across abstraction layers (requirements, functional architecture) using RFLP/OOSEM methodologies."
    DTDFVocab:inputTo SysMLModelingFramework
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML functional architecture model defining system decomposition via components, interfaces, and interconnections using IBDs."
    DTDFVocab:inputTo SysMLModelingFramework
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Logical architecture model using ACME/AADL/MontiArc ADLs for component-connector-based system decomposition."
    DTDFVocab:inputTo ArchitectureDescriptionLanguageFramework
]

instance BehavioralStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model for behavioral dynamics with integration to MathWorks Simulink for simulation."
    DTDFVocab:inputTo SimulationIntegrationFramework
]

instance PhysicsBasedSimulationModel : DTDFVocab:Model [
    base:desc "Physics-based analytical model implemented in C++/Java for detailed behavioral analysis and simulation."
    DTDFVocab:inputTo SimulationIntegrationFramework
]

instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces from physical systems as defined in Digital Shadow Reference Model."
    DTDFVocab:fromData PhysicalSystemDataTransmitted, ManufacturingProcessDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler
]

instance SimulationInputData : DTDFVocab:Data [
    base:desc "Processed simulation input data combining raw sensor data with model parameters for behavioral analysis."
    DTDFVocab:fromData ManufacturingProcessDataTransmitted
    DTDFVocab:inputTo SimulationIntegrationFramework
]

// C11: Enablers
instance SysMLModelingFramework : DTDFVocab:Enabler [
    base:desc "SysML-based MBSE framework supporting requirements, functional/logical architectures, and state machines (v1.7)."
    DTDFVocab:enables SysMLModelingService, StateMachineBehaviorService
]

instance ArchitectureDescriptionLanguageFramework : DTDFVocab:Enabler [
    base:desc "ADL framework (ACME, AADL, MontiArc) for component-connector-based system decomposition with MontiArc Automaton for behavioral modeling."
    DTDFVocab:enables ComponentDecompositionService, BehavioralModelingService
]

instance SimulationIntegrationFramework : DTDFVocab:Enabler [
    base:desc "Integration framework combining MathWorks Simulink with C++/Java implementations for physics-based simulation."
    DTDFVocab:enables PhysicsBasedSimulationService, DynamicBehaviorAnalysisService
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "Data aggregation and abstraction mechanism for contextual traces as per Digital Shadow Reference Model."
    DTDFVocab:enables DataInterpretationService, ContextualAnalysisService
]

// C6: Services
instance SysMLModelingService : DTDFVocab:Service [
    base:desc "Service providing multi-layered system modeling (requirements, functional, logical) using SysML."
    DTDFVocab:provides SystemDecompositionInsight, ArchitectureConsistencyInsight
]

instance StateMachineBehaviorService : DTDFVocab:Service [
    base:desc "Service enabling behavioral modeling through SysML v1.7 state machines with simulation integration."
    DTDFVocab:provides StateTransitionInsight, DynamicBehaviorInsight
]

instance ComponentDecompositionService : DTDFVocab:Service [
    base:desc "Service decomposing systems into components, interfaces, and connectors using ADLs (ACME, AADL, MontiArc)."
    DTDFVocab:provides ComponentInterfaceInsight, SystemModularityInsight
]

instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Service modeling system behavior using MontiArc Automaton with integration to simulation tools."
    DTDFVocab:provides BehavioralPatternInsight, StateAwareSynchronizationInsight
]

instance PhysicsBasedSimulationService : DTDFVocab:Service [
    base:desc "Service executing physics-based simulations using MathWorks Simulink and C++/Java implementations."
    DTDFVocab:provides SimulationAccuracyInsight, PredictiveAnalysisInsight
]

instance DynamicBehaviorAnalysisService : DTDFVocab:Service [
    base:desc "Service analyzing dynamic system behavior through integrated simulation and analytical models."
    DTDFVocab:provides SystemPerformanceInsight, FailurePredictionInsight
]

instance DataInterpretationService : DTDFVocab:Service [
    base:desc "Service interpreting and processing incoming data from physical systems for Digital Twin context."
    DTDFVocab:provides DataQualityInsight, ContextualUnderstandingInsight
]

instance ContextualAnalysisService : DTDFVocab:Service [
    base:desc "Service aggregating and abstracting contextual data traces for higher-level insights."
    DTDFVocab:provides OperationalContextInsight, AnomalyDetectionInsight
]

// C17: Insights/Actions
instance SystemDecompositionInsight : DTDFVocab:Insight [
    base:desc "Insight into system decomposition across requirements, functional, and logical layers using SysML."
]

