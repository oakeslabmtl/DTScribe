// Sensor-level instance
instance RuntimeTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Captures runtime telemetry streams providing real‑time data for simulation and monitoring."
    DTDFVocab:producedData RuntimeTelemetryDataTransmitted
]

// Data Transmitted instance
instance RuntimeTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RuntimeTelemetrySensor
]

// Actual Data instance
instance RuntimeTelemetryData : DTDFVocab:Data [
    base:desc "Real‑time telemetry data stream extracted from the physical system."
    DTDFVocab:fromData RuntimeTelemetryDataTransmitted
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

// --- Model instances -----------------------------------------------------
instance CADBased3DMeshModel : DTDFVocab:Model [
    base:desc "Derived 3D mesh geometry from CAD models imported into SysML for geometric representation."
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "Behavioral logic encoded as discrete state machines in SysML v1.7."
    DTDFVocab:inputTo MontiArcFrameworkEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "Reactive automata defined in MontiArc with connectors and interaction contracts expressed in ACME or AADL."
    DTDFVocab:inputTo MontiArcFrameworkEnabler
]

instance SimulinkBlockDiagramModel : DTDFVocab:Model [
    base:desc "Analytical dynamics implemented in Simulink block diagrams."
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

instance MATLABScriptModel : DTDFVocab:Model [
    base:desc "MATLAB scripts used for dynamic simulation."
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

instance FMIDataExportModel : DTDFVocab:Model [
    base:desc "Model exported to FMI for simulation and runtime integration."
    DTDFVocab:inputTo FMIModuleEnabler
]

instance RequirementSpecificationModel : DTDFVocab:Data [
    base:desc "Requirements specification data."
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

instance FunctionalArchitectureModel : DTDFVocab:Data [
    base:desc "Functional architecture model data."
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

instance LogicalArchitectureModel : DTDFVocab:Data [
    base:desc "Logical architecture model data."
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

// --- Enabler instances -----------------------------------------------------
instance SysMLFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Uses SysML for structural and behavioral modelling."
    DTDFVocab:enables SimulationExecutionService
]

instance MontiArcFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Supports MontiArc automata and ACME/AADL for component‑connector description."
    DTDFVocab:enables SimulationExecutionService
]

instance SimulinkRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Runs Simulink simulations and validates analytical dynamics."
    DTDFVocab:enables SimulationExecutionService
]

instance FMIModuleEnabler : DTDFVocab:Enabler [
    base:desc "Handles FMI export and integration."
    DTDFVocab:enables FMIIntegrationService
]

instance CppCodeGenEnabler : DTDFVocab:Enabler [
    base:desc "Generates C++ code from models."
    DTDFVocab:enables CodeGenerationService
]

instance JavaCodeGenEnabler : DTDFVocab:Enabler [
    base:desc "Generates Java code from models."
    DTDFVocab:enables CodeGenerationService
]

// --- Service instances -----------------------------------------------------
instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Executes simulations using models and telemetry data."
    DTDFVocab:provides RuntimeMonitoringInsight, SimulationPerformanceInsight
]

instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Generates executable code for simulation models."
    DTDFVocab:provides GenerateSimulationCodeAction
]

instance FMIIntegrationService : DTDFVocab:Service [
    base:desc "Facilitates FMI-based simulation integration."
]

// --- Insight instances -------------------------------------------------------
instance RuntimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Provides real‑time monitoring of simulation performance metrics extracted from runtime telemetry data."
]

instance SimulationPerformanceInsight : DTDFVocab:Insight [
    base:desc "Provides analysis of simulation performance and identifies potential bottlenecks."
]

// --- Action instance --------------------------------------------------------
instance GenerateSimulationCodeAction : DTDFVocab:Action [
    base:desc "Generates executable simulation code in targeted languages (C++/Java)."
    DTDFVocab:IsAutomatic true
]