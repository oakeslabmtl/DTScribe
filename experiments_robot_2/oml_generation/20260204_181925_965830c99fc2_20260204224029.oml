// C3: Physical sensing components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "position encoder mounted directly on the motor shaft, providing high‑resolution angular position data for closed‑loop control"
    DTDFVocab:producedData JointEncoderDataStream
]

instance RedundantEncoder : DTDFVocab:SensingComponent [
    base:desc "secondary position encoder on the same drive axis, used for redundancy and validation of joint position measurements"
    DTDFVocab:producedData JointEncoderDataStream
]

// C4: Physical‑to‑virtual interaction
instance JointEncoderDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder, RedundantEncoder
]

// C10: Data
instance JointPositionContextualTrace : DTDFVocab:Data [
    base:desc "aggregated contextual trace of joint positions derived from the two encoders, forming the digital‑shadow representation"
    DTDFVocab:fromData JointEncoderDataStream
    DTDFVocab:inputTo HybridInferenceEngine
]

// C10: Models/Data
instance WhiteBoxSimulinkModel : DTDFVocab:Model [
    base:desc "white‑box dynamic simulation of the robot’s mechanical system implemented in MathWorks Simulink"
    DTDFVocab:inputTo HybridInferenceEngine
]

instance BlackBoxMLRegressorModel : DTDFVocab:Model [
    base:desc "black‑box machine‑learning regressor capturing nonlinear friction effects, trained on runtime state data"
    DTDFVocab:inputTo HybridInferenceEngine
]

// C11: Enablers
instance HybridInferenceEngine : DTDFVocab:Enabler [
    base:desc "processing component that consumes contextual data traces, executes the Simulink simulation and ML regressor, and generates higher‑level abstractions for decision support"
    DTDFVocab:enables DecisionSupportService
]

// C6: Services
instance DecisionSupportService : DTDFVocab:Service [
    base:desc "service that interprets processed simulation and prediction results and provides analytical insights for control decision making"
    DTDFVocab:provides JointPositionInsight, ControlAdjustmentAction
]

// C17: Insights/Actions
instance JointPositionInsight : DTDFVocab:Insight [
    base:desc "insight describing deviations in joint positions and recommending corrective actions"
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "automatic action that adjusts motor control parameters based on the provided insight"
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the Model‑Based Systems‑Engineering (MBSE) progression described in the documents: starting with a requirements model, proceeding to functional‑architecture models, then logical‑architecture models, and finally to the product/technical layer models that represent the concrete implementation. Each stage is represented with appropriate modeling notations (e.g., SysML requirement diagrams, SysML internal block diagrams, architecture description languages such as ACME, AADL or MontiArc) and transformations between stages are performed by model‑to‑model mappings. Governance of the lifecycle is addressed through the MBSE framework, which coordinates the multiple abstraction levels and ensures traceability across stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through full traceability of each model element to its originating data and to the physical phenomenon it represents. The methodology emphasises verification of model transformations, e.g., confirming the correctness of conversions from SysML specifications to Simulink simulation models. Reliability of the Digital Twin depends on the correctness of underlying models and the data processing chain; therefore, uncertainty sources such as model approximation errors are acknowledged and mitigated by maintaining traceable data traces in the Digital Shadow. Validation is performed by comparing simulated outputs against measured data to detect deviations, supporting corrective actions and quality assurance."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The available documentation mentions the use of the MQTT protocol for streaming sensor data, with Mosquitto cited as a server and client implementation of MQTT. An IoT platform (ThingsBoard) is listed, suggesting that MQTT‑published data may be ingested and visualised via this platform. No further information on network topology, bandwidth, latency, reliability, redundancy, or security mechanisms (e.g., TLS, authentication) is provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The documents align the Digital Twin with established modeling standards: SysML (including internal block diagrams and state machines), UML class diagrams for the reference model, and architecture description languages such as ACME, AADL and MontiArc. Conformance to the Digital‑Shadow Reference Model is expressed as a mapping relation that guarantees that any concrete realization adheres to the reference concepts. No explicit industry certification standards or interoperability protocols are mentioned."
]