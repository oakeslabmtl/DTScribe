// =============================
// Physical Sensing Components
// =============================

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring input current I_M on the axis of the MABI MAX 100 robot"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder mounted directly on the motor shaft providing angular position"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder placed behind the gearbox supplying gearbox shaft position"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

// =============================
// Physical‑to‑Virtual Interaction
// =============================

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// =============================
// Raw Data Instances (from transmitted streams)
// =============================

instance InputCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of input current I_M received from MotorCurrentSensor"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MqttBrokerEnabler, SimulinkSimulationEnabler, ProcessingComponentEnabler
]

instance MotorEncoderPositionData : DTDFVocab:Data [
    base:desc "Angular position trace from MotorEncoderSensor"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo MqttBrokerEnabler, SimulinkSimulationEnabler, ProcessingComponentEnabler
]

instance GearboxEncoderPositionData : DTDFVocab:Data [
    base:desc "Gearbox shaft position trace from GearboxEncoderSensor"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo MqttBrokerEnabler, SimulinkSimulationEnabler, ProcessingComponentEnabler
]

// =============================
// Derived Data (calculated)
// =============================

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Torque τ calculated from input current and encoder information"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo ProcessingComponentEnabler, SimulinkSimulationEnabler
]

instance DerivedAngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity ω derived from encoder position increments"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo ProcessingComponentEnabler, SimulinkSimulationEnabler
]

// =============================
// Enablers (Tooling & Infrastructure)
// =============================

instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker streaming live sensor data as time‑series traces"
    DTDFVocab:enables DataStreamingService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for friction and multi‑physics models"
    DTDFVocab:enables RealTimeFrictionIdentificationService,
                     MultiPhysicsParameterEstimationService,
                     DataCalculationService
]

instance ProcessingComponentEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that runs simulation and data‑calculation models"
    DTDFVocab:enables RealTimeFrictionIdentificationService,
                     ModelBasedControlImprovementService,
                     DataCalculationService
]

instance SysmlModelEnabler : DTDFVocab:Enabler [
    base:desc "SysML toolchain providing structural and functional models of the axis"
    DTDFVocab:enables AssetDescriptionService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) for standardized asset description"
    DTDFVocab:enables AssetDescriptionService
]

instance DashboardUiEnabler : DTDFVocab:Enabler [
    base:desc "Integrated dashboard UI for visualizing measured and simulated data"
    DTDFVocab:enables VisualizationService
]

// =============================
// Services (DT Services)
// =============================

instance DataStreamingService : DTDFVocab:Service [
    base:desc "Stream live sensor data via MQTT to the digital shadow"
    DTDFVocab:provides LiveSensorDataInsight
]

instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction parameters"
    DTDFVocab:provides FrictionParameterInsight, FrictionParameterUpdateAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualization of measured and simulated torque and velocity in a dashboard"
    DTDFVocab:provides MeasuredSimulatedDataInsight
]

instance ModelBasedControlImprovementService : DTDFVocab:Service [
    base:desc "Model‑based control tuning using updated friction parameters"
    DTDFVocab:provides ControlAlgorithmTuningInsight, ControlAlgorithmTuningAction
]

instance MultiPhysicsParameterEstimationService : DTDFVocab:Service [
    base:desc "Continuous multi‑physics aware estimation supporting predictive maintenance"
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance DataCalculationService : DTDFVocab:Service [
    base:desc "Execution of data‑calculation models for torque and velocity derivation"
    DTDFVocab:provides TorqueCalculationInsight, VelocityCalculationInsight
]

instance AssetDescriptionService : DTDFVocab:Service [
    base:desc "Provide standardized asset metadata through Asset Administration Shell"
    DTDFVocab:provides AssetMetadataInsight
]

// =============================
// Insights
// =============================

instance LiveSensorDataInsight : DTDFVocab:Insight [
    base:desc "Live sensor data are available for monitoring and analysis"
]

instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters are fed back to the robot controller to improve motion accuracy"
]

instance MeasuredSimulatedDataInsight : DTDFVocab:Insight [
    base:desc "Measured and simulated torque/velocity data visualized in the dashboard"
]

instance ControlAlgorithmTuningInsight : DTDFVocab:Insight [
    base:desc "Model updates inform control algorithm tuning decisions"
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Model‑based insights support predictive maintenance planning"
]

instance TorqueCalculationInsight : DTDFVocab:Insight [
    base:desc "Torque values calculated from current and encoder data"
]

instance VelocityCalculationInsight : DTDFVocab:Insight [
    base:desc "Angular velocity calculated from encoder position increments"
]

instance AssetMetadataInsight : DTDFVocab:Insight [
    base:desc "Asset description complies with AAS specifications"
]

// =============================
// Actions
// =============================

instance FrictionParameterUpdateAction : DTDFVocab:Action [
    base:desc "Automatically update robot controller with newly identified friction parameters"
    DTDFVocab:IsAutomatic true
]

instance ControlAlgorithmTuningAction : DTDFVocab:Action [
    base:desc "Automatically tune control algorithm based on refined models"
    DTDFVocab:IsAutomatic true
]

// =============================
// Engineering Models
// =============================

instance SysmlAxisModel : DTDFVocab:Model [
    base:desc "SysML Block Definition and Internal Block Diagrams describing motor, gearwheel gearbox, cycloidal gearbox and rotational/current flows"
    DTDFVocab:inputTo SysmlModelEnabler
]

instance SimulinkFrictionlessGearboxModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of a frictionless gearbox used as baseline"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SimulinkCoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Simulink implementation of Coulomb‑Viscous friction"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SimulinkStribeckFrictionModel : DTDFVocab:Model [
    base:desc "Simulink implementation of the Stribeck friction model"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SimulinkDahlFrictionModel : DTDFVocab:Model [
    base:desc "Simulink implementation of the Dahl friction model"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SimulinkLuGreFrictionModel : DTDFVocab:Model [
    base:desc "Simulink implementation of the LuGre friction model"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance TorqueCalculationModel : DTDFVocab:Model [
    base:desc "Data‑calculation model that derives torque τ from input current I_M and encoder positions"
    DTDFVocab:inputTo ProcessingComponentEnabler
]

instance VelocityCalculationModel : DTDFVocab:Model [
    base:desc "Data‑calculation model that derives angular velocity ω from encoder position differences"
    DTDFVocab:inputTo ProcessingComponentEnabler
]

// =============================
// Physical Components (System Under Study)
// =============================

instance MotorComponent : DTDFVocab:Component [
    base:desc "Electric motor of the first axis of the MABI MAX 100 robot"
]

instance GearwheelGearboxComponent : DTDFVocab:Component [
    base:desc "Gearwheel gearbox transmitting torque from motor to output shaft"
]

instance CycloidalGearboxComponent : DTDFVocab:Component [
    base:desc "Cycloidal gearbox providing high reduction ratio for the axis"
]

instance RobotFirstAxisEnvironment : DTDFVocab:Environment [
    base:contains MotorComponent, GearwheelGearboxComponent, CycloidalGearboxComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow is defined as a passive one‑way data flow and does not send commands back to the robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (continuous streaming of sensor data during robot operation)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow comprising a singleton purpose (FrictionDerivation), the asset (MABI robot first axis), processing components (Simulation_M, Simulation_GW, Simulation_GB), engineering and simulation models, and multiple data traces linked through the Digital Shadow Reference Model; all visualized in a unified dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated phase – the digital shadow is created and used while the robot is in service to monitor and improve motion accuracy."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each data point to its source and processing model; continuous identification to capture wear, tool changes, and temperature effects; validation by comparing simulated friction‑free and friction‑included model outputs against measured reference data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data is transmitted from the robot to the digital shadow via MQTT; models and asset metadata are accessed through Asset Administration Shells."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) standard for representing the asset and its metadata; adherence to SysML modeling conventions."
]