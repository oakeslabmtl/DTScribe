// C17: Insights/Actions
instance FrictionParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Updates to friction model parameters after real‑time identification"
]

instance FrictionLossDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of friction loss components in the vertical axis"
]

instance ModelUpdateInsight : DTDFVocab:Insight [
    base:desc "Updates the magnetic and mechanical properties of the digital twin models"
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Recommended maintenance and wear mitigation actions based on detected friction loss",
    DTDFVocab:IsAutomatic false
]

instance TorqueComputationInsight : DTDFVocab:Insight [
    base:desc "Computation of motor torque and velocity for motion control tuning"
]

// C6: Services
instance DynamicsSimulationService : DTDFVocab:Service [
    base:desc "Simulates motor and gearbox dynamics to provide torque and velocity data",
    DTDFVocab:provides TorqueComputationInsight
]

instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time joint friction identification using white‑box analytical and black‑box data‑driven models",
    DTDFVocab:provides FrictionParameterUpdateInsight,
    DTDFVocab:provides FrictionLossDetectionInsight
]

instance ContinuousModelUpdateService : DTDFVocab:Service [
    base:desc "Continuously updates digital twin models based on runtime identification results",
    DTDFVocab:provides ModelUpdateInsight
]

// C10: Enablers
instance SimulinkExecutionEnvironment : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink environment executing motor and gearbox dynamic models",
    DTDFVocab:enables DynamicsSimulationService,
    DTDFVocab:enables RealTimeFrictionIdentificationService,
    DTDFVocab:enables ContinuousModelUpdateService
]

// C4: Physical‑to‑virtual interaction
instance MotorEncoderTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance CurrentSensorTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
]

// C3: Physical sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Primary motor encoder providing motor angular velocity",
    DTDFVocab:producedData MotorEncoderTopic
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary gearbox encoder measuring gearbox angular velocity",
    DTDFVocab:producedData GearboxEncoderTopic
]

instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Electric current sensor (I_M) measuring motor current",
    DTDFVocab:producedData CurrentSensorTopic
]

// C10: Models/Data
instance MotorDynamicsSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of motor dynamics incorporating friction models",
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

instance GearboxDynamicsSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of cycloidal gearbox dynamics",
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Coulomb‑Viscous friction model used in motor and gearbox simulations",
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Stribeck friction model representing velocity‑dependent friction",
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Dahl friction model capturing hysteresis effects in the drivetrain",
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "LuGre friction model for advanced friction characterization",
    DTDFVocab:inputTo SimulinkExecutionEnvironment
]

// C10: Data generated by the simulation models
instance MotorTorqueTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkExecutionEnvironment
]

// Data traces derived from sensor streams
instance MotorAngularVelocityData : DTDFVocab:Data [
    base:desc "Motor angular velocity derived from motor encoder",
    DTDFVocab:fromData MotorEncoderTopic
]

instance GearboxAngularVelocityData : DTDFVocab:Data [
    base:desc "Gearbox angular velocity derived from gearbox encoder",
    DTDFVocab:fromData GearboxEncoderTopic
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Motor current measurement (I_M)",
    DTDFVocab:fromData CurrentSensorTopic
]

// Motor torque data derived from simulation
instance MotorTorqueData : DTDFVocab:Data [
    base:desc "Motor torque computed by Simulink motor model",
    DTDFVocab:fromData MotorTorqueTopic
]

// Environment grouping
instance VerticalAxisDT : DTDFVocab:Environment [
    base:contains MotorEncoder,
    base:contains GearboxEncoder,
    base:contains CurrentSensor,
    base:contains MotorDynamicsSimulinkModel,
    base:contains GearboxDynamicsSimulinkModel,
    base:contains SimulinkExecutionEnvironment
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data acquisition and processing occur in real time at millisecond granularity; simulation models run synchronously with sensor updates, enabling continuous friction model refinement"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Operational architecture consisting of AAS asset representation, engineering and simulation models, a processing component that consumes sensor data, runs friction and dynamics simulations, aggregates data traces, and feeds the results to a dashboard UI via MQTT"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "(1) Design – problem definition and requirement capture; (2) Development – asset analysis, model creation, and simulation; (3) Implementation – building and executing the digital shadow and dashboard; (4) Operation – continuous data acquisition, model refinement, and feedback to the controller; covers the manufactured (physical robot) and operated (runtime) phases"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of data traces to their source sensors and simulation steps; use of white‑box analytical models with verified parameters; continuous validation against measured torque and velocity; cross‑validation between simulated and real data; model uncertainty quantification and parameter re‑identification when drift is observed"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensors stream data to the digital shadow via MQTT (publish/subscribe). Asset Administration Shells expose asset metadata and model references. One‑way data flow from physical system to digital shadow (no feedback). Communication assumed to run over a TCP/IP corporate network; no additional protocols are specified."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Standards and formal tools explicitly used: SysML (for system modelling), MathWorks MATLAB Simulink (for simulation), MQTT (for messaging), and Asset Administration Shell (AAS) for asset metadata; no ISO/IEC standard numbers are referenced in the documents."
]