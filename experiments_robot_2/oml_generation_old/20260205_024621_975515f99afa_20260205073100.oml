// Acting components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor driving the base rotary joint of the MABI MAX 100 robot."
]

instance GearTransmissionActuator : DTDFVocab:ActingComponent [
    base:desc "Gear transmission coupling the motor to the cycloidal gearbox."
]

instance CycloidalGearboxActuator : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gearbox providing the joint torque for the first axis."
]

// Sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor shaft, streaming angular position over MQTT."
    DTDFVocab:producedData MotorEncoderAngleDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind the gearbox, providing angular position from the cycloidal gearbox over MQTT."
    DTDFVocab:producedData GearboxEncoderAngleDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor on the permanent‑magnet synchronous motor, transmitting motor current via MQTT."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance JointAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Joint angle measurement sensor aggregating encoder data, streamed in real‑time over MQTT."
    DTDFVocab:producedData JointAngleDataTransmitted
]

// Physical-to-virtual interaction: Data transmitted instances
instance MotorEncoderAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance JointAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointAngleSensor
]

// Simulation model
instance SimulationModelMatlabSimulink : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable simulation model of the first axis, including motor, gearbox and friction models (Coulomb‑Viscous, Stribeck, Dahl, LuGre)."
    DTDFVocab:inputTo SimulationPipelineEnabler
]

// Data expressed from simulation
instance SimulationTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationModelMatlabSimulink
]

instance SimulationAngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationModelMatlabSimulink
]

// Data traced from simulation
instance SimulatedTorqueData : DTDFVocab:Data [
    base:desc "Simulated torque value of the first axis generated by the MATLAB/Simulink model."
    DTDFVocab:fromData SimulationTorqueDataTransmitted
    DTDFVocab:inputTo SimulationPipelineEnabler
]

instance SimulatedAngularVelocityData : DTDFVocab:Data [
    base:desc "Simulated angular velocity of the first axis generated by the MATLAB/Simulink model."
    DTDFVocab:fromData SimulationAngularVelocityDataTransmitted
    DTDFVocab:inputTo SimulationPipelineEnabler
]

// Engineering model
instance EngineeringModelSysML : DTDFVocab:Model [
    base:desc "SysML component‑connector model of the motor, gearboxes and motor‑gearbox interface for the first axis."
    DTDFVocab:inputTo AASEnabler
]

// Data Calculation model
instance DataCalculationModelProcessing : DTDFVocab:Model [
    base:desc "Processing component that computes torque, angular velocity and acceleration from live sensor data."
    DTDFVocab:inputTo DataProcessingPipelineEnabler
]

// Produced data transmittals from calculation model
instance ComputedTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DataCalculationModelProcessing
]

instance ComputedAngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DataCalculationModelProcessing
]

// Data from calculation model
instance ComputedTorqueData : DTDFVocab:Data [
    base:desc "Computed torque of the first axis derived from live sensor data."
    DTDFVocab:fromData ComputedTorqueDataTransmitted
    DTDFVocab:inputTo DataProcessingPipelineEnabler
]

instance ComputedAngularVelocityData : DTDFVocab:Data [
    base:desc "Computed angular velocity of the first axis derived from live sensor data."
    DTDFVocab:fromData ComputedAngularVelocityDataTransmitted
    DTDFVocab:inputTo DataProcessingPipelineEnabler
]

// Data from sensors
instance MotorEncoderAngleData : DTDFVocab:Data [
    base:desc "Live angular position of motor shaft from MotorEncoder."
    DTDFVocab:fromData MotorEncoderAngleDataTransmitted
    DTDFVocab:inputTo DataProcessingPipelineEnabler
]

instance GearboxEncoderAngleData : DTDFVocab:Data [
    base:desc "Live angular position of gearbox shaft from GearboxEncoder."
    DTDFVocab:fromData GearboxEncoderAngleDataTransmitted
    DTDFVocab:inputTo DataProcessingPipelineEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Motor current measured by MotorCurrentSensor."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo DataProcessingPipelineEnabler
]

instance JointAngleData : DTDFVocab:Data [
    base:desc "Joint angle measurement derived from sensor aggregation."
    DTDFVocab:fromData JointAngleDataTransmitted
    DTDFVocab:inputTo DataProcessingPipelineEnabler
]

// Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker used for real‑time streaming of sensor data."
    DTDFVocab:enables RealTimeVisualizationService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for linking engineering, simulation and data calculation models."
    DTDFVocab:enables DataLinkingAggregationService
]

instance DataProcessingPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Processing pipeline that consumes live data, computes derived quantities and forwards them to services."
    DTDFVocab:enables RealTimeVisualizationService, ContinuousIdentificationService
]

instance SimulationPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation pipeline that executes MATLAB/Simulink models and provides simulated outputs."
    DTDFVocab:enables ContinuousIdentificationService
]

// Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time dashboard displaying live sensor traces, computed and simulated quantities."
    DTDFVocab:provides FrictionLossQuantificationInsight
]

instance DataLinkingAggregationService : DTDFVocab:Service [
    base:desc "Service that aggregates data across models and provides lineage and traceability."
    DTDFVocab:provides FrictionLossQuantificationInsight
]

instance ContinuousIdentificationService : DTDFVocab:Service [
    base:desc "Service that continually identifies friction losses, refines white‑box and black‑box friction models, and recommends parameter adjustments."
    DTDFVocab:provides FrictionModelParameterAdjustmentAction, ControllerTuningRecommendationInsight
]

instance MotionAccuracySupportService : DTDFVocab:Service [
    base:desc "Service that generates updated control trajectories and supports motion accuracy improvements."
    DTDFVocab:provides UpdatedControlTrajectoryGenerationAction
]

// Insights
instance FrictionLossQuantificationInsight : DTDFVocab:Insight [
    base:desc "Detection and quantification of friction loss in the first axis."
]

instance ControllerTuningRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for tuning the motion controller based on friction model refinement."
]

// Actions
instance FrictionModelParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Continuous adjustment of friction model parameters to reflect real‑world behavior."
    DTDFVocab:IsAutomatic true
]

instance UpdatedControlTrajectoryGenerationAction : DTDFVocab:Action [
    base:desc "Generation of updated control trajectories to improve motion accuracy."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin does not send commands back to the robot; it operates passively and does not control or actuate the physical system."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data acquisition and model updates occur in real‑time, synchronized with the native sensor sampling rate; the twin processes live data within the same time scale as the physical system – a continuous time‑series update."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow orchestrates a central processing component that consumes sensor streams, executes simulation models, links engineering models via AAS, aggregates data traces, and feeds a unified dashboard for end‑user inspection."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin covers the manufacturing phase (structural and computational models derived from the robot’s design) and the operating phase (live data integration for continuous model refinement); the lifecycle includes modelling, twin creation, execution, and iterative refinement."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "White‑box friction models based on Coulomb‑viscous, Stribeck, Dahl, and LuGre; continuous identification of model parameters using live data; traceability from data points to originating processing components; validation through quantitative comparison of measured vs simulated torque and angular velocity time‑series; simulation models capture gear ratios and motor dynamics for accurate behaviour."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Live data links employ MQTT protocol; processing components receive data streams and publish results; AAS interfaces conform to the Industry 4.0 Asset Administration Shell standard; data exchanges are time‑tagged and traceable."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for system modeling, Asset Administration Shells (AAS) for semantic asset representation, MQTT for data transport, and common MBSE methodologies (RFLP, OOSEM, SPES, SMArDT); these constitute the adopted standards for the digital twin engineering process."
]