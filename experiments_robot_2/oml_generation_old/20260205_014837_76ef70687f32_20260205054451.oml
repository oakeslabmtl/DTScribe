// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures input current from the manufacturing machinery."
    DTDFVocab:producedData InputCurrentMsg
]

instance OutputPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Measures output position of the rotating joint."
    DTDFVocab:producedData OutputPositionMsg
]

// C4: Physical-to-virtual interaction
instance InputCurrentMsg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance OutputPositionMsg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputPositionSensor
]

// C10: Models/Data
instance SimulinkTorqueModel : DTDFVocab:Model [
    base:desc "Simulink model that computes torque from input current."
    DTDFVocab:inputTo DynamicsComputationEnabler
]

instance MontiArcVelocityModel : DTDFVocab:Model [
    base:desc "MontiArc model that computes angular velocity from output position."
    DTDFVocab:inputTo DynamicsComputationEnabler
]

instance ProcessedTorqueData : DTDFVocab:Data [
    base:desc "Aggregated torque computed from input current for friction analysis."
    DTDFVocab:fromData InputCurrentMsg
    DTDFVocab:inputTo MQTTTransportEnabler, DynamicsComputationEnabler
]

instance ProcessedAngularVelocityData : DTDFVocab:Data [
    base:desc "Aggregated angular velocity computed from output position for friction analysis."
    DTDFVocab:fromData OutputPositionMsg
    DTDFVocab:inputTo MQTTTransportEnabler, DynamicsComputationEnabler
]

// C11: Enablers
instance MQTTTransportEnabler : DTDFVocab:Enabler [
    base:desc "Handles MQTT messaging between the physical plant and the digital twin."
    DTDFVocab:enables JointFrictionAnalysisService
]

instance DynamicsComputationEnabler : DTDFVocab:Enabler [
    base:desc "Enables simulation via Simulink and MontiArc for torque and angular velocity computation."
    DTDFVocab:enables JointFrictionAnalysisService
]

instance ACMEDescriptorEnabler : DTDFVocab:Enabler [
    base:desc "Provides ACME architectural description integration."
    DTDFVocab:enables JointFrictionAnalysisService
]

instance AADLDescriptorEnabler : DTDFVocab:Enabler [
    base:desc "Provides AADL architectural description integration."
    DTDFVocab:enables JointFrictionAnalysisService
]

instance MontiArcDescriptorEnabler : DTDFVocab:Enabler [
    base:desc "Provides MontiArc architectural description integration."
    DTDFVocab:enables JointFrictionAnalysisService
]

instance SMArDTMethodEnabler : DTDFVocab:Enabler [
    base:desc "Enables SMArDT modeling methodology."
    DTDFVocab:enables JointFrictionAnalysisService
]

instance RFLPMethodEnabler : DTDFVocab:Enabler [
    base:desc "Enables RFLP (Requirements, Functions, Logics, Physics) methodology."
    DTDFVocab:enables JointFrictionAnalysisService
]

instance OOSEMMethodEnabler : DTDFVocab:Enabler [
    base:desc "Enables OOSEM (Object-Oriented Systems Engineering Methodology) methodology."
    DTDFVocab:enables JointFrictionAnalysisService
]

instance SPESMethodEnabler : DTDFVocab:Enabler [
    base:desc "Enables SPES (System Performance and Engineering Specification) methodology."
    DTDFVocab:enables JointFrictionAnalysisService
]

// C6: Services
instance JointFrictionAnalysisService : DTDFVocab:Service [
    base:desc "Aggregates processed torque and angular velocity to identify joint friction variations in real-time."
    DTDFVocab:provides JointFrictionInsight
]

// C17: Insights
instance JointFrictionInsight : DTDFVocab:Insight [
    base:desc "Provides identification of joint friction variations based on processed torque and angular velocity data, visualised in a real‑time dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital Twin lifecycle follows a Model‑Based Systems Engineering (MBSE) process comprising four abstraction levels: a requirements stage that captures stakeholder needs and constraints; a functional architecture stage where SysML IBD diagrams describe component–connector relationships; a logical architecture stage where behavior is modeled using SysML state‑machines or MontiArc automata; and a product/technical layer stage that translates models into Simulink models or C++ code. Transition between stages is governed through model‑driven engineering, generating abstractions from one level to the next, while lifecycle governance is supported by MBSE methodologies such as RFLP, OOSEM, SPES, and SMArDT."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Telemetry from the physical components is streamed to the digital twin via the MQTT messaging protocol. The documents do not provide further detail on the network topology, bandwidth, latency, redundancy, or security mechanisms beyond the use of MQTT itself. The interface is therefore a simple client‑to‑broker one‑way data channel."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin architecture adheres to widely recognised MBSE and modelling standards. SysML (v1.7) is employed for structural and behavioural diagramming; ACME and AADL provide component‑connector formalism for functional and logical layers; MontiArc specifies automaton‑based behavioural models; and Simulink is used for hybrid system simulation and code generation. The integration of these ADLs supports interoperability across industry toolchains and facilitates traceability between requirements and implementation artefacts. No additional ISO or IEEE standard numbers are cited in the document, so compliance is limited to the utilisation of SysML, ACME, AADL, MontiArc, and Simulink as the foundational modelling languages."
]