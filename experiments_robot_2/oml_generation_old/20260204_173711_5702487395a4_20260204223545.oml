// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor I_M measuring real‑time motor current"
    DTDFVocab:producedData MotorCurrentDataTx
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder providing motor shaft angle"
    DTDFVocab:producedData MotorEncoderDataTx
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the gearbox measuring output shaft angle"
    DTDFVocab:producedData GearboxEncoderDataTx
]

instance TorqueDerivationComponent : DTDFVocab:SensingComponent [
    base:desc "Software component deriving torque from motor current and encoder data"
    DTDFVocab:producedData DerivedTorqueDataTx
]

instance VelocityDerivationComponent : DTDFVocab:SensingComponent [
    base:desc "Software component deriving angular velocity from encoder positions"
    DTDFVocab:producedData DerivedVelocityDataTx
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorCurrentDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

instance DerivedTorqueDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueDerivationComponent, MotorCurrentSensor, MotorEncoderSensor
]

instance DerivedVelocityDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VelocityDerivationComponent, MotorEncoderSensor, GearboxEncoderSensor
]

instance SimulatedCurrentDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkFrictionFreeModel
]

instance SimulatedTorqueDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkCoulombViscousModel, SimulinkStribeckModel, SimulinkDahlModel, SimulinkLuGreModel
]

instance SimulatedVelocityDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkFrictionFreeModel
]

// C10: Data (DataTraces)
instance MeasuredCurrentTrace : DTDFVocab:Data [
    base:desc "Time‑series trace of measured motor current I_M streamed via MQTT"
    DTDFVocab:fromData MotorCurrentDataTx
    DTDFVocab:inputTo MQTTBrokerEnabler, DashboardEnabler
]

instance MeasuredTorqueTrace : DTDFVocab:Data [
    base:desc "Time‑series trace of derived motor torque computed from current and encoder data"
    DTDFVocab:fromData DerivedTorqueDataTx
    DTDFVocab:inputTo MQTTBrokerEnabler, DashboardEnabler
]

instance MeasuredVelocityTrace : DTDFVocab:Data [
    base:desc "Time‑series trace of derived angular velocity from encoder positions"
    DTDFVocab:fromData DerivedVelocityDataTx
    DTDFVocab:inputTo MQTTBrokerEnabler, DashboardEnabler
]

instance SimulatedCurrentTrace : DTDFVocab:Data [
    base:desc "Simulated motor current trace generated by Simulink friction‑free model"
    DTDFVocab:fromData SimulatedCurrentDataTx
    DTDFVocab:inputTo DashboardEnabler
]

instance SimulatedTorqueTrace : DTDFVocab:Data [
    base:desc "Simulated torque trace from various Simulink friction‑law models"
    DTDFVocab:fromData SimulatedTorqueDataTx
    DTDFVocab:inputTo DashboardEnabler
]

instance SimulatedVelocityTrace : DTDFVocab:Data [
    base:desc "Simulated angular velocity trace from Simulink friction‑free model"
    DTDFVocab:fromData SimulatedVelocityDataTx
    DTDFVocab:inputTo DashboardEnabler
]

// C10: Models
instance SysMLStructureModel : DTDFVocab:Model [
    base:desc "SysML Block Definition and Internal Block Diagram representing structural topology of the axis (motor, gearbox, encoders)"
    DTDFVocab:inputTo AASEnabler
]

instance SimulinkFrictionFreeModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of friction‑free axis dynamics"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulinkCoulombViscousModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Coulomb‑Viscous friction law"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulinkStribeckModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Stribeck friction law"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulinkDahlModel : DTDFVocab:Model [
    base:desc "Simulink model implementing Dahl friction law"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulinkLuGreModel : DTDFVocab:Model [
    base:desc "Simulink model implementing LuGre friction law"
    DTDFVocab:inputTo SimulinkEnabler
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker transporting live sensor data streams to the digital twin"
    DTDFVocab:enables RealTimeFrictionIdentificationService, SimulationComparisonService, DashboardVisualizationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for running friction models and generating simulated data"
    DTDFVocab:enables RealTimeFrictionIdentificationService, SimulationComparisonService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell providing standardized model integration for the digital twin"
    DTDFVocab:enables RealTimeFrictionIdentificationService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Interactive dashboard visualizing measured and simulated data traces and insights"
    DTDFVocab:enables DashboardVisualizationService
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction using combined white‑box and black‑box models"
    DTDFVocab:provides DerivedFrictionParametersInsight, UpdateControllerFrictionParametersAction
]

instance SimulationComparisonService : DTDFVocab:Service [
    base:desc "Comparison of simulated and measured torque/velocity to evaluate model performance"
    DTDFVocab:provides ModelPerformanceInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization of data traces, friction loss and model performance on a unified dashboard"
    DTDFVocab:provides FrictionLossInsight
]

// C17: Insights
instance DerivedFrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters (static, kinetic, viscous) identified by the service"
]

instance ModelPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight on the agreement between simulated and measured torque/velocity indicating model fidelity"
]

instance FrictionLossInsight : DTDFVocab:Insight [
    base:desc "Insight showing the amount of friction loss in the axis and its impact on machining performance"
]

// C17: Actions
instance UpdateControllerFrictionParametersAction : DTDFVocab:Action [
    base:desc "Automatic update of robot controller with newly identified friction parameters to improve motion accuracy"
    DTDFVocab:IsAutomatic true
]

// System component
instance AxisMABIMAX100Axis : DTDFVocab:Component [
    base:desc "First axis of the MABI MAX 100 six‑axis industrial robot, comprising a permanent‑magnet synchronous motor, gear transmission and cycloidal gearbox"
]

// Environment (optional grouping)
instance RobotDigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains AxisMABIMAX100Axis, MotorCurrentSensor, MotorEncoderSensor, GearboxEncoderSensor, TorqueDerivationComponent, VelocityDerivationComponent,
                 MQTTBrokerEnabler, SimulinkEnabler, AASEnabler, DashboardEnabler
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, online processing of incoming MQTT data, enabling real‑time updating of friction models during robot operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow composed of a Purpose (FrictionDerivation), an Asset (MABI first axis), Processing components (Simulation M, GW, GB) that consume measured DataTraces and produce simulated traces, and Model elements (engineering, simulation, data‑calculation) linked via the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational/run‑time stage focusing on the as‑operated physical system; the digital shadow leverages engineering models created during design."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each DataPoint to its source and processing component; validation by comparing simulated friction‑free and friction‑augmented outputs with measured data; continuous re‑identification to account for wear, temperature, and load variations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot controller to the digital shadow over MQTT; the digital shadow consumes these streams for processing."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) standard and SysML modeling conventions as defined in the referenced Digital Shadow Reference Model."
]