    DTDFVocab:provides ComponentInteractionInsight
]

instance SafetyCriticalArchitectureAnalysisService : DTDFVocab:Service [
    base:desc "Service analyzing safety-critical system architecture using AADL with timing constraints"
    DTDFVocab:provides SafetyCriticalDesignInsight
]

instance ComponentBehaviorSimulationService : DTDFVocab:Service [
    base:desc "Service simulating component behavior using MontiArc automata"
    DTDFVocab:provides ComponentBehaviorInsight
]

instance DynamicBehaviorSimulationService : DTDFVocab:Service [
    base:desc "Service providing dynamic system simulation using MathWorks Simulink"
    DTDFVocab:provides DynamicBehaviorInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service enabling simulation-based forecasting and predictive analytics"
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance ContextualDataAggregationService : DTDFVocab:Service [
    base:desc "Service aggregating and abstracting contextual traces from manufacturing equipment for Digital Shadow"
    DTDFVocab:provides ContextualDataInsight
]

instance MultiPerspectiveAnalysisService : DTDFVocab:Service [
    base:desc "Service enabling multi-perspective analysis across heterogeneous modeling tools and simulation environments"
    DTDFVocab:provides IntegratedSystemInsight
]

instance ModelValidationService : DTDFVocab:Service [
    base:desc "Service validating integrated models against system requirements and operational constraints"
    DTDFVocab:provides ModelValidationInsight
]

instance RequirementsFunctionalAnalysisService : DTDFVocab:Service [
    base:desc "Service analyzing requirements and functional architecture using RFLP methodology"
    DTDFVocab:provides RequirementsFunctionalAlignmentInsight
]

instance ObjectOrientedSystemDesignService : DTDFVocab:Service [
    base:desc "Service enabling object-oriented system design using OOSEM methodology"
    DTDFVocab:provides ObjectOrientedDesignInsight
]

