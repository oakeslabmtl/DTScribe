// C3: Physical sensing components
instance ManufacturingProcessTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real-time temperature readings from manufacturing equipment to enable contextual trace aggregation for Digital Shadow"
    DTDFVocab:producedData ManufacturingProcessTemperatureDataTransmitted
]

instance ManufacturingProcessPressureSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real-time pressure readings from manufacturing equipment to enable contextual trace aggregation for Digital Shadow"
    DTDFVocab:producedData ManufacturingProcessPressureDataTransmitted
]

instance ManufacturingProcessVibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real-time vibration readings from manufacturing equipment to enable contextual trace aggregation for Digital Shadow"
    DTDFVocab:producedData ManufacturingProcessVibrationDataTransmitted
]

instance EquipmentStateLogger : DTDFVocab:SensingComponent [
    base:desc "Collects operational logs and equipment state data from manufacturing systems for Digital Shadow contextual traces"
    DTDFVocab:producedData EquipmentStateDataTransmitted
]

instance PerformanceMetricLogger : DTDFVocab:SensingComponent [
    base:desc "Collects performance metrics and operational parameters from manufacturing equipment for Digital Shadow aggregation"
    DTDFVocab:producedData PerformanceMetricDataTransmitted
]

// C4: Physical-to-virtual interaction
instance ManufacturingProcessTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ManufacturingProcessTemperatureSensor
]

instance ManufacturingProcessPressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ManufacturingProcessPressureSensor
]

instance ManufacturingProcessVibrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ManufacturingProcessVibrationSensor
]

instance EquipmentStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EquipmentStateLogger
]

instance PerformanceMetricDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PerformanceMetricLogger
]

// C10: Models/Data
instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML-based requirements model capturing system requirements across all abstraction layers (requirements, functional, logical, product/technical)"
    DTDFVocab:inputTo SysMLToolchainEnabler
]

instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) representing functional architecture components, interfaces, and interconnections"
    DTDFVocab:inputTo SysMLToolchainEnabler
]

instance SysMLLogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML IBD representing logical architecture components, interfaces, and composition relationships"
    DTDFVocab:inputTo SysMLToolchainEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model representing dynamic behavior of system components"
    DTDFVocab:inputTo SysMLToolchainEnabler
]

instance ACMEComponentModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language model defining component-based system structure with interfaces and composition"
    DTDFVocab:inputTo ACMEToolchainEnabler
]

instance AADLSafetyCriticalModel : DTDFVocab:Model [
    base:desc "AADL model for safety-critical system architecture with component connectors and timing constraints"
    DTDFVocab:inputTo AADLToolchainEnabler
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "MontiArc model defining component composition, interfaces, and behavioral automata"
    DTDFVocab:inputTo MontiArcToolchainEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model representing dynamic system behavior with state transitions"
    DTDFVocab:inputTo MontiArcToolchainEnabler
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for dynamic system simulation and control system design"
    DTDFVocab:inputTo SimulinkToolchainEnabler
]

instance ManufacturingProcessContextualData : DTDFVocab:Data [
    base:desc "Aggregated contextual traces from manufacturing equipment including sensor readings and operational logs"
    DTDFVocab:fromData ManufacturingProcessTemperatureDataTransmitted, ManufacturingProcessPressureDataTransmitted,
                  ManufacturingProcessVibrationDataTransmitted, EquipmentStateDataTransmitted,
                  PerformanceMetricDataTransmitted
    DTDFVocab:inputTo DigitalShadowFrameworkEnabler
]

instance HeterogeneousModelIntegrationData : DTDFVocab:Data [
    base:desc "Consolidated data from multiple modeling tools and simulation environments for multi-perspective analysis"
    DTDFVocab:inputTo MBSEIntegrationEnabler
]

// C11: Enablers
instance SysMLToolchainEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 toolchain enabling requirements modeling, functional/logical architecture, and state machine modeling"
    DTDFVocab:enables SysMLModelingService, SysMLStateMachineSimulationService
]

instance ACMEToolchainEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language toolchain for component-based system modeling with interfaces and composition"
    DTDFVocab:enables ComponentConnectorAnalysisService
]

instance AADLToolchainEnabler : DTDFVocab:Enabler [
    base:desc "AADL toolchain for architecture-centric modeling of safety-critical systems with timing constraints"
    DTDFVocab:enables SafetyCriticalArchitectureAnalysisService
]

instance MontiArcToolchainEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc toolchain supporting component composition, interfaces, and behavioral automata modeling"
    DTDFVocab:enables ComponentBehaviorSimulationService
]

instance SimulinkToolchainEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink toolchain for dynamic system simulation and control system design"
    DTDFVocab:enables DynamicBehaviorSimulationService, PredictiveAnalyticsService
]

instance DigitalShadowFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Digital Shadow framework providing one-way automated data flow from physical manufacturing systems to digital representation"
    DTDFVocab:enables ContextualDataAggregationService
]

instance MBSEIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "MBSE methodology enabler integrating heterogeneous modeling tools and simulation environments (RFLP, OOSEM, SPES, SMArDT)"
    DTDFVocab:enables MultiPerspectiveAnalysisService, ModelValidationService
]

instance RFLPMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements, Functions, Logics, Physics) methodology enabler for structuring multi-layered system modeling"
    DTDFVocab:enables RequirementsFunctionalAnalysisService
]

instance OOSEMMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM (Object-Oriented Systems Engineering Method) enabler for object-oriented system modeling"
    DTDFVocab:enables ObjectOrientedSystemDesignService
]

// C6: Services
instance SysMLModelingService : DTDFVocab:Service [
    base:desc "Service providing SysML-based modeling across requirements, functional, and logical architecture layers"
    DTDFVocab:provides SystemRequirementsInsight, FunctionalArchitectureInsight
]

instance SysMLStateMachineSimulationService : DTDFVocab:Service [
