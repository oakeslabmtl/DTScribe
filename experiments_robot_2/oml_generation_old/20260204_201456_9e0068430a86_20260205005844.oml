prefix DTDFVocab: http://example.com/DTDFVocab
prefix base: http://example.com/base
instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results for system analysis"
]

instance DataProcessingInsight : DTDFVocab:Insight [
    base:desc "Processed data for system behavior analysis"
]

instance RequirementsInsight : DTDFVocab:Insight [
    base:desc "System requirements data for validation"
]

instance FunctionalArchitectureInsight : DTDFVocab:Insight [
    base:desc "Functional architecture data for system design"
]

instance LogicalArchitectureInsight : DTDFVocab:Insight [
    base:desc "Logical architecture data for system design"
]

instance ProductTechnicalLayerInsight : DTDFVocab:Insight [
    base:desc "Product technical layer data for implementation"
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service provided by MathWorks Simulink",
    DTDFVocab:provides SimulationInsight
]

instance DataProcessingService : DTDFVocab:Service [
    base:desc "Data processing service using C++ and Java",
    DTDFVocab:provides DataProcessingInsight
]

instance RequirementsService : DTDFVocab:Service [
    base:desc "Requirements management service",
    DTDFVocab:provides RequirementsInsight
]

instance FunctionalArchitectureService : DTDFVocab:Service [
    base:desc "Functional architecture service",
    DTDFVocab:provides FunctionalArchitectureInsight
]

instance LogicalArchitectureService : DTDFVocab:Service [
    base:desc "Logical architecture service",
    DTDFVocab:provides LogicalArchitectureInsight
]

instance ProductTechnicalLayerService : DTDFVocab:Service [
    base:desc "Product technical layer service",
    DTDFVocab:provides ProductTechnicalLayerInsight
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation",
    DTDFVocab:enables SimulationService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for behavior specification and data processing",
    DTDFVocab:enables DataProcessingService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for behavior specification and data processing",
    DTDFVocab:enables DataProcessingService
]

instance RflpMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "RFLP methodology for hierarchical abstraction levels",
    DTDFVocab:enables RequirementsService, FunctionalArchitectureService
]

instance OosemMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for hierarchical abstraction levels",
    DTDFVocab:enables RequirementsService, FunctionalArchitectureService
]

instance SpesMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for hierarchical abstraction levels",
    DTDFVocab:enables LogicalArchitectureService, ProductTechnicalLayerService
]

instance SmardtMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for hierarchical abstraction levels",
    DTDFVocab:enables LogicalArchitectureService, ProductTechnicalLayerService
]

instance SysmlModel : DTDFVocab:Model [
    base:desc "SysML for structural and behavioral modeling",
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler, JavaEnabler
]

instance SysmlIbdModel : DTDFVocab:Model [
    base:desc "SysML Interface Block Diagrams for component interfaces",
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler, JavaEnabler
]

instance AcmeModel : DTDFVocab:Model [
    base:desc "ACME architecture description language for component-connector modeling",
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler, JavaEnabler
]

instance AadlModel : DTDFVocab:Model [
    base:desc "AADL architecture description language for component-connector modeling",
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler, JavaEnabler
]

instance MontiarcModel : DTDFVocab:Model [
    base:desc "MontiArc architecture description language for component-connector modeling",
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler, JavaEnabler
]

instance MontiarcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling",
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler, JavaEnabler
]

instance SysmlStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavioral modeling",
    DTDFVocab:inputTo SimulinkEnabler, CppEnabler, JavaEnabler
]

instance SimulinkSimulationData : DTDFVocab:DataTransmitted [
]

instance RequirementsDataTransmitted : DTDFVocab:DataTransmitted [
]

instance FunctionalArchitectureDataTransmitted : DTDFVocab:DataTransmitted [
]

instance LogicalArchitectureDataTransmitted : DTDFVocab:DataTransmitted [
]

instance ProductTechnicalLayerDataTransmitted : DTDFVocab:DataTransmitted [
]

instance CppDataTransmitted : DTDFVocab:DataTransmitted [
]

instance JavaDataTransmitted : DTDFVocab:DataTransmitted [
]

instance SimulationData : DTDFVocab:Data [
    base:desc "Simulation results from MathWorks Simulink",
    DTDFVocab:fromData SimulinkSimulationData,
    DTDFVocab:inputTo CppEnabler, JavaEnabler
]

instance CppData : DTDFVocab:Data [
    base:desc "Data processed by C++ programming language",
    DTDFVocab:fromData CppDataTransmitted,
    DTDFVocab:inputTo JavaEnabler
]

instance JavaData : DTDFVocab:Data [
    base:desc "Data processed by Java programming language",
    DTDFVocab:fromData JavaDataTransmitted,
    DTDFVocab:inputTo CppEnabler
]

instance RequirementsData : DTDFVocab:Data [
    base:desc "System requirements data",
    DTDFVocab:fromData RequirementsDataTransmitted,
    DTDFVocab:inputTo RflpMethodologyEnabler, OosemMethodologyEnabler
]

instance FunctionalArchitectureData : DTDFVocab:Data [
    base:desc "Functional architecture data",
    DTDFVocab:fromData FunctionalArchitectureDataTransmitted,
    DTDFVocab:inputTo RflpMethodologyEnabler, OosemMethodologyEnabler
]

instance LogicalArchitectureData : DTDFVocab:Data [
    base:desc "Logical architecture data",
    DTDFVocab:fromData LogicalArchitectureDataTransmitted,
    DTDFVocab:inputTo SpesMethodologyEnabler, SmardtMethodologyEnabler
]

instance ProductTechnicalLayerData : DTDFVocab:Data [
    base:desc "Product technical layer data",
    DTDFVocab:fromData ProductTechnicalLayerDataTransmitted,
    DTDFVocab:inputTo SpesMethodologyEnabler, SmardtMethodologyEnabler
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to industry standards including SysML for Model-Based Systems Engineering (MBSE), ACME, AADL, and MontiArc as architecture description languages (ADLs) for component & connector perspectives, ensuring structured system modeling across abstraction levels such as requirements, functional architecture, logical architecture, and product/technical layer."
]