// C3: Physical sensing components
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Dual position encoder located on the motor shaft, captures motor angular position in real time."
    DTDFVocab:producedData MotorCurrentTransmit
]
instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Dual position encoder located after the gearbox, captures output angular position for joint monitoring."
    DTDFVocab:producedData JointAngleTransmit
]
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor feeding the CNC, measures phase‑current I_M for motor performance evaluation."
    DTDFVocab:producedData MotorCurrentTransmit
]
instance CNCMotorMeasurementSensor : DTDFVocab:SensingComponent [
    base:desc "CNC internal measurement unit deriving joint angle, torque, and angular velocity from encoder data."
    DTDFVocab:producedData JointAngleTransmit, MotorTorqueTransmit, MotorAngularVelocityTransmit, GearwheelAngularVelocityTransmit, SystemOutputTorqueTransmit
]

// C4: Physical‑to‑virtual interaction
instance MotorCurrentTransmit : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]
instance JointAngleTransmit : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder, CNCMotorMeasurementSensor
]
instance MotorTorqueTransmit : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CNCMotorMeasurementSensor
]
instance MotorAngularVelocityTransmit : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CNCMotorMeasurementSensor
]
instance GearwheelAngularVelocityTransmit : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CNCMotorMeasurementSensor
]
instance SystemOutputTorqueTransmit : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CNCMotorMeasurementSensor
]

// C10: Models/Data
instance MotorSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink block representing the permanent‑magnet synchronous motor with Coulomb‑Viscous friction."
    DTDFVocab:inputTo DataProcessingUnit
]
instance GearwheelSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink block representing the gearwheel with Stribeck and LuGre friction models."
    DTDFVocab:inputTo DataProcessingUnit
]
instance GearboxSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink block representing the cycloidal gearbox with Dahl friction dynamics."
    DTDFVocab:inputTo DataProcessingUnit
]
instance SysMLEngineeringModel : DTDFVocab:Model [
    base:desc "SysML block‑definition and internal diagrams describing the first vertical axis of the MABI MAX 100 robot."
    DTDFVocab:inputTo DataProcessingUnit
]

instance MeasuredMotorCurrent : DTDFVocab:Data [
    base:desc "Measured motor current I_M captured in real time via MQTT."
    DTDFVocab:inputTo DataProcessingUnit
    DTDFVocab:fromData MotorCurrentTransmit
]
instance MeasuredJointAngle : DTDFVocab:Data [
    base:desc "Measured joint angle from dual encoders, available in real time."
    DTDFVocab:inputTo DataProcessingUnit
    DTDFVocab:fromData JointAngleTransmit
]
instance MeasuredMotorTorque : DTDFVocab:Data [
    base:desc "Measured motor torque τ derived from encoder data, streamed via MQTT."
    DTDFVocab:inputTo DataProcessingUnit
    DTDFVocab:fromData MotorTorqueTransmit
]
instance MeasuredMotorAngularVelocity : DTDFVocab:Data [
    base:desc "Measured angular velocity ω_M of the motor shaft, obtained from encoder data."
    DTDFVocab:inputTo DataProcessingUnit
    DTDFVocab:fromData MotorAngularVelocityTransmit
]
instance MeasuredGearwheelAngularVelocity : DTDFVocab:Data [
    base:desc "Measured angular velocity ω_G of the gearwheel, derived from encoder data."
    DTDFVocab:inputTo DataProcessingUnit
    DTDFVocab:fromData GearwheelAngularVelocityTransmit
]
instance MeasuredSystemOutputTorque : DTDFVocab:Data [
    base:desc "Measured system output torque τ_out of the first axis, received from CNC measurement unit."
    DTDFVocab:inputTo DataProcessingUnit
    DTDFVocab:fromData SystemOutputTorqueTransmit
]

// C11: Enablers
instance DataProcessingUnit : DTDFVocab:Enabler [
    base:desc "Central processing unit that streams real‑time sensor data via MQTT, performs friction identification, simulation comparison, and drives dashboard updates."
    DTDFVocab:enables FrictionIdentificationService, RealTimeModelComparisonService, DashboardVisualizationService, ParameterTuningService
]
instance MATLABSimulinkEnvironment : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment used to run axis simulation models and perform friction parameter estimation."
]
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating real‑time data transportation from physical sensors to the digital twin."
]
instance DashboardApplication : DTDFVocab:Enabler [
    base:desc "Custom dashboard application for visualizing measured and simulated data traces and actionable insights."
]
instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell providing asset metadata and linking data traces to their origin models."
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Automated friction identification service that updates static, kinetic, and viscous friction coefficients per axis."
    DTDFVocab:provides StaticFrictionCoefficientInsight, KineticFrictionCoefficientInsight, ViscousFrictionCoefficientInsight, UpdateFrictionParametersAction
]
instance RealTimeModelComparisonService : DTDFVocab:Service [
    base:desc "Service that continuously compares simulated and measured joint behaviour in real time."
    DTDFVocab:provides RealTimeSimulationAlignmentInsight
]
instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Service responsible for rendering live data traces and insights on the dashboard interface."
    DTDFVocab:provides DashboardVisualizationInsight
]
instance ParameterTuningService : DTDFVocab:Service [
    base:desc "Service that proposes actionable insights for parameter tuning to improve motion accuracy."
    DTDFVocab:provides ImprovedControlConfigurationInsight, AdjustControlParametersAction
]

// C17: Insights/Actions
instance StaticFrictionCoefficientInsight : DTDFVocab:Insight [
    base:desc "Insight identifying the static friction coefficient for the first vertical axis."
]
instance KineticFrictionCoefficientInsight : DTDFVocab:Insight [
    base:desc "Insight identifying the kinetic friction coefficient for the first vertical axis."
]
instance ViscousFrictionCoefficientInsight : DTDFVocab:Insight [
    base:desc "Insight identifying the viscous friction coefficient for the first vertical axis."
]
instance RealTimeSimulationAlignmentInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight indicating alignment between simulated and measured joint states."
]
instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing live visualization of data traces on the dashboard."
]
instance ImprovedControlConfigurationInsight : DTDFVocab:Insight [
    base:desc "Insight offering improved control configuration recommendations to the CNC controller for higher motion accuracy."
]
instance UpdateFrictionParametersAction : DTDFVocab:Action [
    base:desc "Automated action to update friction model parameters within the simulation environment."
    DTDFVocab:IsAutomatic true
]
instance AdjustControlParametersAction : DTDFVocab:Action [
    base:desc "Action to adjust CNC control parameters based on friction identification insights."
    DTDFVocab:IsAutomatic false
]

// Optional: Environment representation
instance RobotMABI100Axis1Environment : DTDFVocab:Environment [
    base:desc "Environment representing the first vertical axis of the MABI MAX 100 robot."
    base:contains MotorPositionEncoder, GearboxPositionEncoder, MotorCurrentSensor, CNCMotorMeasurementSensor
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time operation; data streams at the rate of the CNC controller outputs (typically hundreds of Hz) and processing performed online to keep the DT synchronized with the PT operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central DT consisting of an Asset Administration Shell, a processing component that consumes sensor streams, executes the simulation models, and outputs data traces, all orchestrated within a dashboard for user interaction."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated phase – the digital shadow represents the robot while in operation, providing real‑time monitoring and model calibration for that operating condition."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability of every data point back to its source and the processing model; comparison of simulated versus measured signals to validate friction models; continuous identification updating parameters in both white‑box physics‑based and black‑box data‑driven models; use of AAS to enforce consistency of asset metadata."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT is used to stream real‑time sensor data from the PT to the DT; the DT exposes data through the AAS interface; internal processing uses standard TCP/IP networking within the local network."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Data exchange is facilitated by the Asset Administration Shell, which enables standard interfaces; no explicit integration with other DTs or enterprise systems is mentioned."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Standards applied: SysML for system modeling, UML for class diagrams, Asset Administration Shell (AAS) as standard semantic layer, MBSE practices (RFLP/SPES) for engineering discipline."
]