// C2: Acting Components
// (none described)

// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor current I_M on the first robot axis"
    DTDFVocab:producedData CurrentDataStream
]
instance MotorSideEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor-side encoder measuring motor angle θ_motor on the first robot axis"
    DTDFVocab:producedData MotorAngleDataStream
]
instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Gearbox-side encoder measuring gearwheel angle θ_gearwheel on the first robot axis"
    DTDFVocab:producedData GearboxAngleDataStream
]
instance AxisPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Controller sensor measuring axis angular position θ_out on the first robot axis"
    DTDFVocab:producedData AxisAngleDataStream
]

// C4: Physical-to-virtual interaction
instance CurrentDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]
instance MotorAngleDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSideEncoder
]
instance GearboxAngleDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]
instance AxisAngleDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AxisPositionSensor
]

// C10: Models/Data
instance MotorCurrentTrace : DTDFVocab:Data [
    base:desc "Time‑stamped sequence of motor current I_M transmitted via MQTT"
    DTDFVocab:fromData CurrentDataStream
    DTDFVocab:inputTo SimulationEnabler
]
instance MotorAngleTrace : DTDFVocab:Data [
    base:desc "Time‑stamped series of motor angle θ_motor from motor-side encoder"
    DTDFVocab:fromData MotorAngleDataStream
    DTDFVocab:inputTo SimulationEnabler
]
instance GearboxAngleTrace : DTDFVocab:Data [
    base:desc "Time‑stamped series of gearwheel angle θ_gearwheel from gearbox encoder"
    DTDFVocab:fromData GearboxAngleDataStream
    DTDFVocab:inputTo SimulationEnabler
]
instance AxisAngleTrace : DTDFVocab:Data [
    base:desc "Time‑stamped series of overall axis angle θ_out from controller"
    DTDFVocab:fromData AxisAngleDataStream
    DTDFVocab:inputTo SimulationEnabler
]

// Simulation modules
instance MotorSimulationModel : DTDFVocab:Model [
    base:desc "Simulink executable for the motor dynamics, parameterised with friction models"
    DTDFVocab:inputTo SimulationEnabler
]
instance GearwheelSimulationModel : DTDFVocab:Model [
    base:desc "Simulink executable for the gearwheel dynamics within the cycloidal gearbox"
    DTDFVocab:inputTo SimulationEnabler
]
instance GearboxSimulationModel : DTDFVocab:Model [
    base:desc "Simulink executable for the overall cycloidal gearbox dynamics"
    DTDFVocab:inputTo SimulationEnabler
]
instance DynamicsCalculationModel : DTDFVocab:Model [
    base:desc "Equation‑based calculation model for motor torque and acceleration"
    DTDFVocab:inputTo SimulationEnabler
]

// Simulation output data traces
instance MotorTorqueSimTrace : DTDFVocab:Data [
    base:desc "Simulated motor torque τ_M output from motor simulation model"
    DTDFVocab:inputTo SimulationEnabler
]
instance GearwheelTorqueSimTrace : DTDFVocab:Data [
    base:desc "Simulated gearwheel torque τ_G output from gearwheel simulation model"
    DTDFVocab:inputTo SimulationEnabler
]
instance OutputTorqueSimTrace : DTDFVocab:Data [
    base:desc "Simulated overall axis torque τ_out output from gearbox simulation model"
    DTDFVocab:inputTo SimulationEnabler
]
instance MotorSpeedSimTrace : DTDFVocab:Data [
    base:desc "Simulated motor speed ω_M from motor simulation model"
    DTDFVocab:inputTo SimulationEnabler
]
instance GearwheelSpeedSimTrace : DTDFVocab:Data [
    base:desc "Simulated gearwheel speed ω_G from gearwheel simulation model"
    DTDFVocab:inputTo SimulationEnabler
]
instance OutputSpeedSimTrace : DTDFVocab:Data [
    base:desc "Simulated overall axis speed ω_out from gearbox simulation model"
    DTDFVocab:inputTo SimulationEnabler
]

// Friction parameter trace
instance FrictionParameterTrace : DTDFVocab:Data [
    base:desc "Time‑series of updated friction parameters determined by the digital twin"
    DTDFVocab:inputTo FrictionModelEnabler
]

// C11: Enablers
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for simulation models"
    DTDFVocab:enables FrictionIdentificationService, DashboardVisualizationService
]
instance FrictionModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler integrating white‑box and black‑box friction models into the simulation workflow"
    DTDFVocab:enables FrictionIdentificationService, WearDiagnosticsService, MaintenancePlanningService, ProcessOptimizationService
]
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Custom processing component that consumes raw sensor traces, runs calculations, and outputs processed traces"
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time friction identification and modelling service for the first vertical axis"
    DTDFVocab:provides FrictionParameterInsight, UpdateFrictionParametersAction
]
instance WearDiagnosticsService : DTDFVocab:Service [
    base:desc "Diagnostics service detecting wear or tool change effects on joint dynamics"
    DTDFVocab:provides WearDiagnosticsInsight, DiagnoseWearAction
]
instance MaintenancePlanningService : DTDFVocab:Service [
    base:desc "Service that provides maintenance planning guidance"
    DTDFVocab:provides MaintenancePlanningInsight, PlanMaintenanceAction
]
instance ProcessOptimizationService : DTDFVocab:Service [
    base:desc "Service that supports process optimisation based on twin insights"
    DTDFVocab:provides ProcessOptimizationInsight, OptimizeProcessAction
]
instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Dashboard service visualising motor, gearbox, and joint dynamics in real time"
    DTDFVocab:provides DashboardDisplayInsight, DashboardDisplayAction
]

// C17: Insights/Actions
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Insight providing updated friction parameters for controller tuning"
]
instance WearDiagnosticsInsight : DTDFVocab:Insight [
    base:desc "Insight diagnosing wear or tool change effects on axis dynamics"
]
instance MaintenancePlanningInsight : DTDFVocab:Insight [
    base:desc "Insight aiding maintenance planning based on friction trends"
]
instance ProcessOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight supporting process optimisation by comparing reference and simulated signals"
]
instance DashboardDisplayInsight : DTDFVocab:Insight [
    base:desc "Real‑time dashboard visualising motor, gearbox, and joint dynamics"
]

instance UpdateFrictionParametersAction : DTDFVocab:Action [
    base:desc "Action to inject updated friction parameters into Siemens SINUMERIK 840D CNC controller"
    DTDFVocab:IsAutomatic true
]
instance DiagnoseWearAction : DTDFVocab:Action [
    base:desc "Action to diagnose wear or tool change effects"
    DTDFVocab:IsAutomatic false
]
instance PlanMaintenanceAction : DTDFVocab:Action [
    base:desc "Action to plan maintenance activities"
    DTDFVocab:IsAutomatic false
]
instance OptimizeProcessAction : DTDFVocab:Action [
    base:desc "Action to optimise machining process based on twin insights"
    DTDFVocab:IsAutomatic true
]
instance DashboardDisplayAction : DTDFVocab:Action [
    base:desc "Action to refresh dashboard display"
    DTDFVocab:IsAutomatic true
]

// Environment containing the twin artefacts
instance AssetRepresentationAAS : DTDFVocab:Environment [
    base:contains MotorCurrentSensor, MotorSideEncoder, GearboxEncoder, AxisPositionSensor,
    CurrentDataStream, MotorAngleDataStream, GearboxAngleDataStream, AxisAngleDataStream,
    MotorCurrentTrace, MotorAngleTrace, GearboxAngleTrace, AxisAngleTrace,
    MotorSimulationModel, GearwheelSimulationModel, GearboxSimulationModel, DynamicsCalculationModel,
    FrictionModelEnabler, SimulationEnabler, DataProcessingEnabler,
    FrictionIdentificationService, WearDiagnosticsService, MaintenancePlanningService, ProcessOptimizationService, DashboardVisualizationService
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates at real‑time, synchronizing continuously with the robot’s sampling rate. Sensor data is streamed live over MQTT and processed immediately, enabling multi‑physics‑aware identification of friction during each robot cycle."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated twin consisting of: the asset (Axis 1), its engineering model, an Asset Administration Shell exposing configuration and metadata, a processing component that converts MQTT sensor streams into data traces, simulation modules for motor, gearwheel, and gearbox, and a dashboard that visualises all relevant signals and model outputs in real time."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the manufactured and operated phases. Initial engineering models (SysML BDD/IBD) are created during manufacturing, and during operation the twin performs continuous identification and calibration of friction models, thereby covering the operated stage."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is ensured by combining analytical (white‑box) and data‑driven (black‑box) friction models, continuous real‑time identification during operation, and traceability of each data point back to its source. Validation is performed by comparing simulated outputs against measured reference data, and uncertainties originate from sensor noise, model parameter drift, and temperature‑dependent friction effects. The twin supports stochastic updates of friction coefficients to maintain model validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual communication utilizes the MQTT protocol to stream sensor data from the robot’s controller to the digital shadow processing component. The Asset Administration Shell communicates asset metadata via its standard REST/JSON interface, although details are not specified. No bidirectional network protocols are described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture follows Industry 4.0 standards: SysML for engineering representation, Asset Administration Shell (ISO/IEC 30100) for asset metadata, and MQTT (ISO/IEC 20922) for communication. No specific modelling or data‑exchange standards beyond these are cited."
]