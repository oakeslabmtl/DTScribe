instance PhysicalSystemDataTraceSensor : DTDFVocab:SensingComponent [
    base:desc "Sensing component for contextual data traces from physical system"
    DTDFVocab:producedData ContextualDataTrace
]

instance ContextualDataTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemDataTraceSensor
]

instance ContextualData : DTDFVocab:Data [
    base:desc "Contextual data traces from physical system"
    DTDFVocab:fromData ContextualDataTrace
    DTDFVocab:inputTo MathWorksSimulink, CppCompiler, JavaCompiler
]

instance RFLPModel : DTDFVocab:Model [
    base:desc "RFLP methodology for requirements, functions, logics, physics abstraction levels"
    DTDFVocab:inputTo SysMLTool
]

instance OOSEMModel : DTDFVocab:Model [
    base:desc "OOSEM methodology for system complexity management"
    DTDFVocab:inputTo SysMLTool
]

instance SPESModel : DTDFVocab:Model [
    base:desc "SPES methodology for system complexity management"
    DTDFVocab:inputTo SysMLTool
]

instance SMArDTModel : DTDFVocab:Model [
    base:desc "SMArDT methodology for system complexity management"
    DTDFVocab:inputTo SysMLTool
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML for structural modeling"
    DTDFVocab:inputTo SysMLTool
]

instance ACMEComponentConnectorModel : DTDFVocab:Model [
    base:desc "ACME ADL for component & connector perspectives"
    DTDFVocab:inputTo ACMETool
]

instance AADLComponentConnectorModel : DTDFVocab:Model [
    base:desc "AADL ADL for component & connector perspectives"
    DTDFVocab:inputTo AADLTool
]

instance MontiArcComponentConnectorModel : DTDFVocab:Model [
    base:desc "MontiArc ADL for component & connector perspectives"
    DTDFVocab:inputTo MontiArcTool
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML IBDs for component & connector perspectives"
    DTDFVocab:inputTo SysMLTool
]

instance MontiArcAutomatonBehavioralModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcTool
]

instance SysMLStateMachineBehavioralModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machines for behavioral modeling"
    DTDFVocab:inputTo SysMLTool
]

instance MathWorksSimulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation of dynamic behavior"
    DTDFVocab:enables SimulationService
]

instance CppCompiler : DTDFVocab:Enabler [
    base:desc "C++ compiler for detailed behavior implementation"
    DTDFVocab:enables CppCodeExecutionService
]

instance JavaCompiler : DTDFVocab:Enabler [
    base:desc "Java compiler for detailed behavior implementation"
    DTDFVocab:enables JavaCodeExecutionService
]

instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc tool for architecture description and behavior modeling"
    DTDFVocab:enables MontiArcService
]

instance ACMETool : DTDFVocab:Enabler [
    base:desc "ACME tool for architecture description"
    DTDFVocab:enables ACMEService
]

instance AADLTool : DTDFVocab:Enabler [
    base:desc "AADL tool for architecture description"
    DTDFVocab:enables AADLService
]

instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML tool for structural and behavioral modeling"
    DTDFVocab:enables SysMLService
]

instance RFLPRequirementsService : DTDFVocab:Service [
    base:desc "Service for requirements analysis using RFLP methodology"
    DTDFVocab:provides RequirementsValidationInsight
]

instance OOSEMFunctionalService : DTDFVocab:Service [
    base:desc "Service for functional architecture management using OOSEM"
    DTDFVocab:provides FunctionalArchitectureInsight
]

instance SPESLogicalService : DTDFVocab:Service [
    base:desc "Service for logical architecture management using SPES"
    DTDFVocab:provides LogicalDesignInsight
]

instance SMArDTTechnicalService : DTDFVocab:Service [
    base:desc "Service for technical layer management using SMArDT"
    DTDFVocab:provides TechnicalLayerInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service for system simulation"
    DTDFVocab:provides PerformanceInsight
]

instance CppCodeExecutionService : DTDFVocab:Service [
    base:desc "Service for executing C++ code behavior"
    DTDFVocab:provides CodePerformanceInsight
]

instance JavaCodeExecutionService : DTDFVocab:Service [
    base:desc "Service for executing Java code behavior"
    DTDFVocab:provides JavaPerformanceInsight
]

instance MontiArcService : DTDFVocab:Service [
    base:desc "Service for MontiArc-based modeling"
    DTDFVocab:provides MontiArcInsight
]

instance ACMEService : DTDFVocab:Service [
    base:desc "Service for ACME-based architecture description"
    DTDFVocab:provides ACMEInsight
]

instance AADLService : DTDFVocab:Service [
    base:desc "Service for AADL-based architecture description"
    DTDFVocab:provides AADLInsight
]

instance SysMLService : DTDFVocab:Service [
    base:desc "Service for SysML-based modeling"
    DTDFVocab:provides SysMLInsight
]

instance RequirementsValidationInsight : DTDFVocab:Insight [
    base:desc "Insight into requirements validation against system specifications"
]

instance FunctionalArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight into functional architecture design and optimization"
]

instance LogicalDesignInsight : DTDFVocab:Insight [
    base:desc "Insight into logical architecture design"
]

instance TechnicalLayerInsight : DTDFVocab:Insight [
    base:desc "Insight into product/technical layer implementation"
]

instance PerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight into system performance metrics from simulation"
]

instance CodePerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight into C++ code execution performance"
]

instance JavaPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight into Java code execution performance"
]

instance MontiArcInsight : DTDFVocab:Insight [
    base:desc "Insight from MontiArc modeling"
]

instance ACMEInsight : DTDFVocab:Insight [
    base:desc "Insight from ACME architecture description"
]

instance AADLInsight : DTDFVocab:Insight [
    base:desc "Insight from AADL architecture description"
]

instance SysMLInsight : DTDFVocab:Insight [
    base:desc "Insight from SysML modeling"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to industry standards including SysML [17], ACME [23], AADL [24], MontiArc [25], [26], and methodologies such as RFLP [18], [19], OOSEM [20], SPES [21], and SMArDT [22] for structured system modeling, component & connector architecture, and behavior specification, ensuring interoperability among heterogeneous stakeholders."
]