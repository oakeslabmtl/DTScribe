    base:desc "Service integrating real-time dimensional measurements with engineering models for quality control and defect prediction."
    DTDFVocab:provides QualityControlReport, DimensionalDeviationAlert
]

instance RoboticsOptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing robot dynamics and friction phenomena using AI-driven processing models."
    DTDFVocab:provides RoboticsOptimizationRecommendation
]

instance InjectionMoldingSimulationService : DTDFVocab:Service [
    base:desc "Service simulating dynamic behavior of injection molding cycles for predictive analytics and optimization."
