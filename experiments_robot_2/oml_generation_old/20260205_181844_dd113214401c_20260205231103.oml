]

instance QualityAssuranceEngine : DTDFVocab:Enabler [
    base:desc "Engineering model integration engine combining CAD/CAM data with real-time measurements for quality control."
    DTDFVocab:enables QualityControlService
]

instance DigitalShadowReferenceModel : DTDFVocab:Enabler [
    base:desc "UML-based reference model defining concepts like data traces, processing components, and their relationships for traceability."
    DTDFVocab:enables TraceabilityService
]

instance InjectionMoldingSimulationEngine : DTDFVocab:Enabler [
    base:desc "Engine for running injection molding simulations"
]

