// C3: Physical Sensing Components
instance ForceTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Heterogeneous sensor capturing nonlinear physical effects like robot friction and torque dynamics for data-driven model calibration in cyber-physical systems."
    DTDFVocab:producedData RobotFrictionDataTrace
]

instance DisplacementSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring displacement parameters in injection molding processes to enable dynamic behavior modeling and process optimization."
    DTDFVocab:producedData InjectionMoldingDisplacementData
]

instance TemperaturePressureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing temperature and pressure readings from manufacturing processes to support real-time monitoring and predictive analytics."
    DTDFVocab:producedData ProcessTemperaturePressureData
]

instance EnvironmentalConditionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring environmental parameters (e.g., humidity, ambient temperature) affecting manufacturing processes and digital shadow fidelity."
    DTDFVocab:producedData EnvironmentalConditionData
]

instance DimensionalDeviationSensor : DTDFVocab:SensingComponent [
    base:desc "High-precision sensor measuring dimensional deviations in manufactured parts to support quality control and defect prediction."
    DTDFVocab:producedData PartDimensionalData
]

// C4: Physical-to-Virtual Interaction
instance RobotFrictionDataTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ForceTorqueSensor
]

instance InjectionMoldingDisplacementData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DisplacementSensor
]

instance ProcessTemperaturePressureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperaturePressureSensor
]

instance EnvironmentalConditionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalConditionSensor
]

instance PartDimensionalData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DimensionalDeviationSensor
]

// C10: Models/Data
instance PhysicsBasedInjectionModel : DTDFVocab:Model [
    base:desc "White-box physics-based model using Simulink for interpretable dynamic simulation of injection molding processes with analytical formulations."
    DTDFVocab:inputTo InjectionMoldingSimulationEngine
]

instance DataDrivenFrictionModel : DTDFVocab:Model [
    base:desc "Black-box machine learning model capturing nonlinear robot friction phenomena not easily representable analytically."
    DTDFVocab:inputTo RoboticsAIProcessingEngine
]

instance ProcessOptimizationModel : DTDFVocab:Model [
    base:desc "Simulation model for continuous process optimization generating optimized parameters for injection speed, cooling time, and energy efficiency."
    DTDFVocab:inputTo ManufacturingOptimizationEngine
]

instance QualityControlModel : DTDFVocab:Model [
    base:desc "Engineering model integrating CAD/CAM data with real-time dimensional measurements for quality control and defect prediction."
    DTDFVocab:inputTo QualityAssuranceEngine
]

instance ProcessTemperaturePressureDataStore : DTDFVocab:Data [
    base:desc "Structured data store containing aggregated temperature and pressure data traces with contextual metadata for advanced processing."
    DTDFVocab:fromData ProcessTemperaturePressureData
    DTDFVocab:inputTo DataProcessingComponent
]

instance InjectionMoldingSimulationData : DTDFVocab:Data [
    base:desc "Simulation output data representing dynamic behavior of injection molding cycles used for predictive analytics and optimization."
    DTDFVocab:fromData InjectionMoldingDisplacementData
    DTDFVocab:inputTo InjectionMoldingSimulationEngine
]

instance RobotStateData : DTDFVocab:Data [
    base:desc "Intrinsic system data from robot state capturing dynamic parameters for scalable identification methods without dedicated setups."
    DTDFVocab:fromData RobotFrictionDataTrace
    DTDFVocab:inputTo RoboticsAIProcessingEngine
]

// C11: Enablers
instance SysMLInjectionMoldingModel : DTDFVocab:Enabler [
    base:desc "SysML-based architecture model using Internal Block Diagrams to describe functional and logical architecture of injection molding processes."
    DTDFVocab:enables InjectionMoldingMonitoringService, ProcessOptimizationService
]

instance MathWorksSimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink tool for detailed simulation of control logic and dynamic processes in injection molding systems."
    DTDFVocab:enables InjectionMoldingSimulationService, QualityControlService
]

instance DataProcessingComponent : DTDFVocab:Enabler [
    base:desc "General-purpose processing component implemented in C++/Java for real-time data trace processing and output abstraction."
    DTDFVocab:enables AnomalyDetectionService, PredictiveMaintenanceService
]

instance RoboticsAIProcessingEngine : DTDFVocab:Enabler [
    base:desc "AI-driven processing engine implementing machine learning models for robot dynamics analysis and adaptive control."
    DTDFVocab:enables RoboticsOptimizationService
]

instance ManufacturingOptimizationEngine : DTDFVocab:Enabler [
    base:desc "Simulation and calculation engine for continuous process optimization generating optimized parameters for energy efficiency."
