// C3: Physical sensing components (contextual data collection)
instance CpsContextualDataCollector : DTDFVocab:SensingComponent [
    base:desc "Collects contextual data traces from the cyber‑physical system as described in the twinning process, serving as the source of raw data for the Digital Twin."
    DTDFVocab:producedData RawDataTrace
]

// C4: Physical-to-virtual interaction (raw data transmission)
instance RawDataTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CpsContextualDataCollector
]

// C10: Data (processed & traceable)
instance ProcessedData : DTDFVocab:Data [
    base:desc "Data derived from raw traces after processing, linking to engineering, simulation, and data‑calculation models via traceability."
    DTDFVocab:fromData RawDataTrace
    DTDFVocab:inputTo SysMLTool, SimulinkTool, MLProcessingEngine
]

// C10: Models/Data - Engineering model
instance EngineeringModelSysML : DTDFVocab:Model [
    base:desc "Engineering model describing system structure and behavior using SysML block diagrams as part of the reference model."
    DTDFVocab:inputTo SysMLTool
]

// C10: Models/Data - Simulation model
instance SimulationModelSimulink : DTDFVocab:Model [
    base:desc "Simulation model implementing dynamic behavior in MathWorks Simulink as referenced in the DT framework."
    DTDFVocab:inputTo SimulinkTool
]

// C10: Models/Data - Data‑calculation model
instance DataCalculationModelML : DTDFVocab:Model [
    base:desc "Data‑calculation model generating higher‑level abstractions from raw traces, e.g., statistical or machine‑learning models."
    DTDFVocab:inputTo MLProcessingEngine
]

// C11: Enablers - SysML tool
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "Tool supporting MBSE with SysML for architecture description and engineering model execution."
    DTDFVocab:enables SimulationService
]

// C11: Enablers - Simulink tool
instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "Simulation environment MathWorks Simulink used to run dynamic models within the Digital Twin."
    DTDFVocab:enables PredictionService
]

// C11: Enablers - ML processing engine
instance MLProcessingEngine : DTDFVocab:Enabler [
    base:desc "Processing engine executing data‑calculation models (statistical or machine‑learning) for insight generation."
    DTDFVocab:enables TraceabilityService
]

// C6: Services - Simulation service
instance SimulationService : DTDFVocab:Service [
    base:desc "Provides simulation capabilities to predict physical object state based on simulation models."
    DTDFVocab:provides SystemStateInsight
]

// C6: Services - Prediction service
instance PredictionService : DTDFVocab:Service [
    base:desc "Offers predictive analytics using data‑calculation models to forecast future system behavior."
    DTDFVocab:provides AnomalyDetectionInsight, ModelUpdateAction
]

// C6: Services - Traceability service
instance TraceabilityService : DTDFVocab:Service [
    base:desc "Manages persistent traceability links between data traces, models, and processing steps for versioning and evolution."
    DTDFVocab:provides SystemStateInsight
]

// C17: Insights
instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Insight into the current state of the physical system derived from simulation and engineering models."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects deviations or anomalies in system behavior using statistical or ML models."
]

// C17: Action
instance ModelUpdateAction : DTDFVocab:Action [
    base:desc "Triggers automated update of models based on new data or detected anomalies."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows a Model‑Based Systems‑Engineering (MBSE) approach that is split into several abstraction levels: (1) requirements modeling, (2) functional architecture, (3) logical architecture, and (4) product/technical (physical) layer. During development the twin is first represented by high‑level SysML requirement and block diagrams, then refined into functional and logical models using architecture description languages such as ACME, AADL, MontiArc or SysML internal block diagrams, and finally instantiated with concrete engineering, simulation or data‑calculation models (e.g., Simulink). Transition between stages is governed by explicit traceability links (the “originates‑from” association) that connect data traces to the processing components and the models that generated them, ensuring that each refinement step can be audited and that governance of the lifecycle is based on conformance to the Digital Shadow Reference Model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and validity are addressed through traceability and verification of model transformations. The reliability of a digital shadow (and by extension a Digital Twin) is directly linked to the correctness of its underlying models and the data‑processing steps; therefore, verification methods such as systematic checks of transformations from SysML to simulation models are employed. Uncertainty sources include errors in the original data traces and inaccuracies in the physics‑based (white‑box) or data‑driven (black‑box) models; these are quantified by maintaining fine‑grained traceability, which allows the origin of any computed trace to be identified and inspected. Error detection is supported by the “originates‑from” association that enables back‑propagation of inconsistencies, and correction mechanisms rely on re‑executing processing components with validated input. Quality assurance is ensured by conforming concrete realizations to the Digital Shadow Reference Model, guaranteeing that all modeling concepts and their relationships satisfy the defined conformance relation."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin framework adopts several industry modelling standards: SysML (OMG) for requirements and behavior models, AADL (SAE) for architecture description, ACME for component‑connector specifications, MontiArcAutomaton for combined architecture and automaton behavior, and Simulink (MathWorks) for simulation models. Conformance to the Digital Shadow Reference Model is achieved through a defined conformance relation that maps concrete class diagrams to the reference concepts, ensuring interoperability across tools and adherence to the referenced standards."
]