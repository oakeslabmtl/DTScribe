// C3: Physical sensing components
instance MotorMountedEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder providing motor angle, derived torque, angular velocity and acceleration; live data streamed via MQTT."
    DTDFVocab:producedData MotorEncoderDataStream
]

instance GearboxSecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind the gearbox providing gearbox angle, derived torque, angular velocity and acceleration; live data streamed via MQTT."
    DTDFVocab:producedData GearboxEncoderDataStream
]

// C4: Physical‑to‑virtual interaction (Data transmitted)
instance MotorEncoderDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorMountedEncoder
]

instance GearboxEncoderDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxSecondaryEncoder
]

// C10: Data instances
instance MotorEncoderRawData : DTDFVocab:Data [
    base:desc "Time‑series of current, motor angle, torque, angular velocity and acceleration received from MotorMountedEncoder."
    DTDFVocab:fromData MotorEncoderDataStream
    DTDFVocab:inputTo MQTTBroker, MATLABSimulinkEngine
]

instance GearboxEncoderRawData : DTDFVocab:Data [
    base:desc "Time‑series of gearbox angle, derived torque, angular velocity and acceleration received from GearboxSecondaryEncoder."
    DTDFVocab:fromData GearboxEncoderDataStream
    DTDFVocab:inputTo MQTTBroker, MATLABSimulinkEngine
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker used for live one‑way data flow from robot sensors to the digital shadow."
    DTDFVocab:enables RealTimeFrictionIdentificationService,
                ModelUpdatingService,
                SimulationComparisonService,
                DashboardVisualizationService
]

instance MATLABSimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for friction models, identification algorithms and simulation."
    DTDFVocab:enables RealTimeFrictionIdentificationService,
                ModelUpdatingService,
                SimulationComparisonService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell integrating engineering and simulation models into the digital twin."
    DTDFVocab:enables ModelUpdatingService
]

instance DashboardVisualization : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard visualizing identified friction parameters, simulated vs measured data, and model updates."
    DTDFVocab:enables DashboardVisualizationService
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction parameters from streamed sensor data."
    DTDFVocab:provides FrictionParameterInsight
]

instance ModelUpdatingService : DTDFVocab:Service [
    base:desc "Updates white‑box and black‑box friction models (Coulomb‑Viscous, Stribeck, Dahl, LuGre) based on latest identified parameters."
    DTDFVocab:provides FrictionParameterInsight
]

instance SimulationComparisonService : DTDFVocab:Service [
    base:desc "Compares simulated torque/velocity curves with measured data to validate model accuracy."
    DTDFVocab:provides FrictionParameterInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Provides integrated visualization of friction identification results, model updates, and comparison plots on a dashboard."
    DTDFVocab:provides FrictionParameterInsight
]

// C17: Insight
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Derived static, kinetic and viscous friction parameters identified in real time."
]

// C17: Action
instance MotionControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Feeds derived friction parameters back to the Siemens SINUMERIK 840D controller to adjust motion control for improved accuracy."
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor driving the first robot axis; input current I_M, output torque τ_M."
]

instance GearwheelGearbox : DTDFVocab:ActingComponent [
    base:desc "Gearwheel gearbox reducing motor speed and increasing torque for the first axis."
]

instance CycloidalGearbox : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gearbox providing high reduction ratio and precise positioning for the first axis."
]

instance SINUMERIK840DController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D SL controller commanding the motor current and receiving feedback."
]

// C10: Models
instance SysMLAxisStructureModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagram describing the axis structure (motor, gearboxes, sensors)."
    DTDFVocab:inputTo AssetAdministrationShell
]

instance SimulinkFrictionFreeModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction‑free model of the axis used as reference for identification."
    DTDFVocab:inputTo MATLABSimulinkEngine
]

instance SimulinkCoulombViscousModel : DTDFVocab:Model [
    base:desc "Simulink implementation of Coulomb‑Viscous friction model for the axis."
    DTDFVocab:inputTo MATLABSimulinkEngine
]

instance SimulinkLugreModel : DTDFVocab:Model [
    base:desc "Simulink implementation of the LuGre dynamic friction model."
    DTDFVocab:inputTo MATLABSimulinkEngine
]

instance TorqueVelocityCalculationModel : DTDFVocab:Model [
    base:desc "Data calculation model deriving torque and angular velocity from measured current and angle."
    DTDFVocab:inputTo MATLABSimulinkEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow is passive and does not send commands back to the robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time operation during robot runtime; data are processed online as they arrive."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow comprising a processing component that consumes MQTT data traces, applies simulation and data‑calculation models, and produces derived data traces; all linked to the physical asset (first axis) via the AAS."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational stage – the digital shadow is used while the robot is running to improve motion accuracy."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Combination of analytical white‑box and data‑driven black‑box friction models; full traceability of each data point to its source and processing model; validation by comparing simulated outputs with measured reference data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol used for streaming sensor data from the robot to the digital shadow; data organized as DataTraces and DataPoints according to the Digital Shadow Reference Model."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) as an industry‑standard representation, and adherence to SysML modelling standards."
]