instance model : DTDFVocab:Model [
    base:desc "Model description"
    DTDFVocab:inputTo enabler
]
instance enabler : DTDFVocab:Enabler [
    base:desc "Enabler description"
    DTDFVocab:enables service
]
instance service : DTDFVocab:Service [
    base:desc "Service description"
    DTDFVocab:provides insight
]
instance insight : DTDFVocab:Insight [
    base:desc "Insight description"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to industry standards including SysML [17] for model-based systems engineering, AADL [24] for architecture description, ACME [23] for component-based modeling, and MontiArc [25], [26] for architectural descriptions, ensuring interoperability and integration of heterogeneous stakeholder perspectives as required in MBSE practices."
]