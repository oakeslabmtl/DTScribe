// C10: Models
instance ADLInterfaceBlockDiagramModel : DTDFVocab:Model [
    base:desc "Component-connector ADL representation using ACME, AADL, and MontiArc for logical architecture."
    DTDFVocab:inputTo ADLToSimulinkTranslatorEnabler
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state‑machine diagram specifying behavioural logic."
    DTDFVocab:inputTo ADLToSimulinkTranslatorEnabler
]

instance SimulinkNumericalModel : DTDFVocab:Model [
    base:desc "Functional simulation model instantiated in MathWorks Simulink."
    DTDFVocab:inputTo SimulinkToExecutableCompilerEnabler
]

instance NativeExecutableModel : DTDFVocab:Model [
    base:desc "Compiled behavioural logic in C++/Java from model-based code generation."
    DTDFVocab:inputTo SimulinkToExecutableCompilerEnabler
]

// C11: Enablers
instance ADLToSimulinkTranslatorEnabler : DTDFVocab:Enabler [
    base:desc "Translates ADL component‑connector artefacts into Simulink block diagrams."
    DTDFVocab:enables SimulationExecutionService
]

instance SimulinkToExecutableCompilerEnabler : DTDFVocab:Enabler [
    base:desc "Compiles Simulink models into executable C++/Java code."
    DTDFVocab:enables SimulationExecutionService
]

// C6: Services
instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Executes generated binaries to perform real‑time simulation and control."
    DTDFVocab:provides RunSimulationInsight, SimulationExecutionAction
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Performs model‑based verification, generating safety case traceability."
    DTDFVocab:provides ValidateModelInsight, ModelValidationAction
]

// C17: Insights/Actions
instance RunSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight generated by simulation runs, including performance metrics and control strategy evaluation."
]

instance SimulationExecutionAction : DTDFVocab:Action [
    base:desc "Runs the compiled executable for simulation."
    DTDFVocab:IsAutomatic true
]

instance ValidateModelInsight : DTDFVocab:Insight [
    base:desc "Insight derived from automated test generation and traceability analysis."
]

instance ModelValidationAction : DTDFVocab:Action [
    base:desc "Automated generation of tests from SysML state machines."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the MBSE abstraction hierarchy defined in the document: (1) Requirements – captured with SysML requirement diagrams; (2) Functional Architecture – represented through SysML block definition diagrams and interface specifications, or ADLs such as ACME or AADL; (3) Logical Architecture – modeled with MontiArc automaton extensions and SysML sequence/activity diagrams; (4) Product/Technical Layer – realized by simulation models in MathWorks Simulink or generated C++/Java code. Transition management between these phases relies on traceability links between the different modeling notations and a version‑controlled model repository (e.g., Git). Governance of the lifecycle is supported by the RFLP methodology (Requirements, Functions, Logics, Physics) and the SMArDT approach to refine twin representations progressively from abstract concepts to concrete product models."
]