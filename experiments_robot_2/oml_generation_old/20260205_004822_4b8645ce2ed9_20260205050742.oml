// C3: Sensing Components
instance JointAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder sensor capturing joint angles for each of the six revolute joints on the MABI MAX 100 manipulator."
    DTDFVocab:producedData JointAngleTelemetry
]

instance EncoderCountSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder sensor providing encoder counts corresponding to the rotational positions of each joint."
    DTDFVocab:producedData EncoderCountTelemetry
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor currents on each joint axis to monitor load and friction."
    DTDFVocab:producedData MotorCurrentTelemetry
]

// C4: Data Transmitted
instance JointAngleTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointAngleSensor
]

instance EncoderCountTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EncoderCountSensor
]

instance MotorCurrentTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Models
instance SimulinkPlantModel : DTDFVocab:Model [
    base:desc "Simulink model of the MABI MAX 100 plant dynamics used for real‑time simulation and code generation."
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance FrictionEstimationModel : DTDFVocab:Model [
    base:desc "Physics‑based friction estimation model integrated in the Simulink environment."
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

// C2: Enablers
instance SimulinkExecutionEnabler : DTDFVocab:Enabler [
    base:desc "Runs the Simulink plant and friction estimation models in real‑time, receiving sensor telemetry via MQTT."
    DTDFVocab:enables JointFrictionEstimationService
]

// C11: Services
instance JointFrictionEstimationService : DTDFVocab:Service [
    base:desc "Real‑time joint‑friction estimation service that processes live sensor streams, refines motion models, and publishes calibration updates."
    DTDFVocab:provides JointFrictionInsight
    DTDFVocab:provides FrictionCompensationAction
]

// C10: Data
instance JointAngleTelemetryData : DTDFVocab:Data [
    base:desc "Aggregated joint‑angle data transmitted over MQTT, used by the friction estimation model."
    DTDFVocab:fromData JointAngleTelemetry
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance EncoderCountTelemetryData : DTDFVocab:Data [
    base:desc "Aggregated encoder‑count data transmitted over MQTT, used by the friction estimation model."
    DTDFVocab:fromData EncoderCountTelemetry
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

instance MotorCurrentTelemetryData : DTDFVocab:Data [
    base:desc "Aggregated motor‑current data transmitted over MQTT, used by the friction estimation model."
    DTDFVocab:fromData MotorCurrentTelemetry
    DTDFVocab:inputTo SimulinkExecutionEnabler
]

// C17: Insights and Actions
instance JointFrictionInsight : DTDFVocab:Insight [
    base:desc "Real‑time estimated friction forces for each joint axis, available for monitoring and predictive maintenance."
]

instance FrictionCompensationAction : DTDFVocab:Action [
    base:desc "AutomaticallyGenerated correction to motor current commands to counteract estimated joint friction, sent back to the SINUMERIK PLC."
    DTDFVocab:IsAutomatic true
]

// C17: Environment
instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains JointAngleSensor, EncoderCountSensor, MotorCurrentSensor,
    JointAngleTelemetry, EncoderCountTelemetry, MotorCurrentTelemetry,
    JointAngleTelemetryData, EncoderCountTelemetryData, MotorCurrentTelemetryData,
    SimulinkPlantModel, FrictionEstimationModel,
    SimulinkExecutionEnabler, JointFrictionEstimationService,
    JointFrictionInsight, FrictionCompensationAction
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Based on the MBSE approach outlined in Document 1, the Digital Twin system orchestrates its components using a layered architecture defined through Specification and Description languages such as SysML for high‑level functional and logical views and architecture description languages (e.g., ACME, AADL, MontiArc) for component‑connector modeling. The framework supports a multi‑level abstraction pipeline—requirements, functional architecture, logical architecture, and product/technical layers—allowing interoperability between heterogeneous modeling notations. Component behavior is expressed via state machines in SysML v1.7 or MontiArc Automaton, and executed or simulated with tools such as MathWorks Simulink or general‑purpose code (C++/Java). Resource allocation and coordination between subsystems are managed by integrating the models into a simulation engine (e.g., Simulink) that resolves data exchanges, propagates state changes, and enforces consistency across the twin. The overall coordination follows established MBSE methodologies such as RFLP, OOSEM, SPES, and SMArDT, which prescribe structured workflows for requirement traceability, function decomposition, logical design, and physics‑based execution, thereby ensuring a synchronized, verifiable digital representation of the physical product."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system adopts standard modelling and interoperability frameworks: architectural models are expressed in SysML; the digital twin follows the Asset Administration Shell (AAS) specification for digital asset representation; integration interfaces comply with industry‑standard protocols to support data exchange within Industry 4.0 ecosystems."
]