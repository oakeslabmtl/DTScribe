// Acting Component
instance FirstAxisActuator : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor with cycloidal gear transmission driving the first robot axis; provides closed‑loop position control with torque limits, motion‑range guards and safety constraints."
]

// Sensing Components
instance PositionEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution angular position encoder mounted on each drive, sampled at kHz rates and streamed via MQTT."
    DTDFVocab:producedData EncoderDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor winding current for each axis, sampled at control‑loop frequency and published over MQTT."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// Data Transmitted
instance EncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// Data Instances
instance EncoderData : DTDFVocab:Data [
    base:desc "Aggregated encoder position trace representing joint angles."
    DTDFVocab:fromData EncoderDataTransmitted
    DTDFVocab:inputTo MQTTIngestionEngine
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Stream of motor current measurements used for health monitoring and friction identification."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo MQTTIngestionEngine
]

// Enablers
instance MQTTIngestionEngine : DTDFVocab:Enabler [
    base:desc "MQTT broker and ingestion pipeline that receives sensor streams and forwards them to processing components."
    DTDFVocab:enables RealTimeMonitoringService, FrictionModelIdentificationService
]

instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink runtime executing white‑box friction and dynamic robot models."
    DTDFVocab:enables FrictionErrorPredictionService, FeedForwardControlAdjustmentService
]

instance MLInferenceEngine : DTDFVocab:Enabler [
    base:desc "Machine‑learning inference service executing black‑box friction models trained on historical sensor data."
    DTDFVocab:enables FrictionModelIdentificationService, FrictionErrorPredictionService
]

instance DashboardEngine : DTDFVocab:Enabler [
    base:desc "Web‑based visualization stack (JavaScript) presenting sensor streams, model outputs and control actions."
    DTDFVocab:enables DashboardVisualizationService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides live monitoring of joint positions, motor currents and encoder streams."
    DTDFVocab:provides PositionInsight, EnergyConsumptionInsight
]

instance FrictionModelIdentificationService : DTDFVocab:Service [
    base:desc "Identifies both physics‑based (white‑box) and data‑driven (black‑box) friction models online."
    DTDFVocab:provides FrictionModelInsight
]

instance FrictionErrorPredictionService : DTDFVocab:Service [
    base:desc "Predicts friction‑induced errors and their propagation to end‑effector trajectories."
    DTDFVocab:provides FrictionErrorInsight
]

instance FeedForwardControlAdjustmentService : DTDFVocab:Service [
    base:desc "Computes feed‑forward control set‑points that compensate identified friction, improving motion accuracy."
    DTDFVocab:provides AdjustControlSetpointAction
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Integrates sensor streams, model parameters and performance metrics into an operator dashboard."
    DTDFVocab:provides ValidateHypothesisAction, InitiateCorrectiveAction
]

// Insights
instance PositionInsight : DTDFVocab:Insight [
    base:desc "Detection of deviations between measured joint positions and expected trajectories."
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight on deviations from expected energy consumption derived from traceability of data and models."
]

instance PredictedWearInsight : DTDFVocab:Insight [
    base:desc "Prediction of component wear based on accumulated friction estimations."
]

instance FrictionModelInsight : DTDFVocab:Insight [
    base:desc "Result of online identification of friction characteristics (coefficients, stiffness)."
]

instance FrictionErrorInsight : DTDFVocab:Insight [
    base:desc "Forecast of friction‑induced positional error at the end‑effector."
]

// Actions
instance AdjustControlSetpointAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of control set‑points based on identified friction to compensate motion errors."
    DTDFVocab:IsAutomatic true
]

instance ValidateHypothesisAction : DTDFVocab:Action [
    base:desc "Operator validates hypotheses about system behavior via the dashboard."
    DTDFVocab:IsAutomatic false
]

instance InitiateCorrectiveAction : DTDFVocab:Action [
    base:desc "Operator initiates a corrective control command to mitigate detected anomalies."
    DTDFVocab:IsAutomatic false
]

// Models
instance SimulinkFrictionModel : DTDFVocab:Model [
    base:desc "White‑box physics‑based gearbox friction model implemented in Simulink."
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance MLBasedFrictionModel : DTDFVocab:Model [
    base:desc "Black‑box machine‑learning model trained on sensor data to estimate nonlinear friction."
    DTDFVocab:inputTo MLInferenceEngine
]

instance SysMLSystemModel : DTDFVocab:Model [
    base:desc "SysML block diagram capturing RFLP hierarchy: requirements → functions → logical → physical."
    DTDFVocab:inputTo MQTTIngestionEngine
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle follows the MBSE development flow split into abstraction layers: requirements engineering, functional architecture modeling, logical architecture design, and product/technical layer implementation. Representation evolves from high‑level SysML requirement diagrams to detailed SysML internal block diagrams, ADL component‑connector models (e.g., ACME, AADL, MontiArc) and finally executable code in C++/Java or simulation models in Simulink. Transitions between stages are managed by traceability links defined in the reference model, and governance is provided by the conformance relation of concrete realizations to the digital‑shadow reference model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The documents stress that the reliability of the Digital Twin depends on the correctness of its underlying models and data transformations. Validation and verification activities include traceability of model transformations (e.g., from SysML to simulation models) and verification of both white‑box Simulink models and black‑box machine‑learning models. Uncertainty sources are identified in the data‑driven identification process, and quality assurance requires systematic verification of model fidelity against the aggregated contextual data traces. The approach calls for explicit verification of model transformations to ensure that model fidelity is maintained throughout the development chain."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin conforms to several industry and modeling standards. Its core artefacts are specified with standardized modeling languages (SysML, ACME, AADL, MontiArc) and stored as UML class diagrams, ensuring interoperability. The reference model adopts a formal conformance relation that aligns concrete realizations with the standardised concepts of the model. In the manufacturing domain, the Twin implements the Asset Administration Shell (AAS) specification, providing a certified interface for data exchange and lifecycle management. Compliance with these standards is documented in the model’s metadata, supporting certification processes and cross‑vendor interoperability."
]