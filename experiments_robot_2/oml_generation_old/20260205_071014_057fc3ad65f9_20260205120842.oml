// C1: Architecture Description Languages
instance ArchitectureDescriptionLanguageACME : DTDFVocab:Enabler [
    base:desc "Architecture Description Language (ADL) ACME for structural modeling of system components, interfaces, and composition in Model-Based Systems Engineering (MBSE) frameworks"
]

instance ArchitectureDescriptionLanguageAADL : DTDFVocab:Enabler [
    base:desc "AADL (Aircraft Adapters and Architectures Language) for detailed component-based architecture description, supporting interfaces, connectors, and composition in industrial manufacturing systems"
]

instance ArchitectureDescriptionLanguageMontiArc : DTDFVocab:Enabler [
    base:desc "MontiArc ADL for multi-layered system architecture modeling, particularly for functional and logical architecture decomposition in manufacturing environments"
]

instance SysMLIBD : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagram (IBD) for representing system components, connectors, and composition in multi-abstraction layer modeling of complex physical systems"
]

// C2: Behavioral Modeling Tools
instance MontiArcAutomata : DTDFVocab:Model [
    base:desc "MontiArc Automata models capturing dynamic behavior of system components across functional and logical architecture layers in manufacturing systems"
    DTDFVocab:inputTo ArchitectureDescriptionLanguageMontiArc
]

instance SysMLStateMachine : DTDFVocab:Model [
    base:desc "SysML state machines (v1.7) for representing system dynamics and operational states across abstraction layers in industrial manufacturing environments"
    DTDFVocab:inputTo ArchitectureDescriptionLanguageAADL, ArchitectureDescriptionLanguageMontiArc
]

// C3: Physical Sensing Components
instance ManufacturingSensorNetwork : DTDFVocab:SensingComponent [
    base:desc "Industrial IoT sensor network infrastructure for passive data aggregation in manufacturing environments, collecting contextual data traces for digital shadow representation"
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature measurement sensor component within manufacturing equipment, providing raw temperature data traces for digital shadow aggregation"
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Pressure measurement sensor component in industrial machinery, transmitting pressure data traces for digital shadow contextualization"
]

instance MotionSensor : DTDFVocab:SensingComponent [
    base:desc "Motion detection sensor component in automated manufacturing systems, capturing motion metrics for digital shadow data aggregation"
]

// C4: Data Transmission
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

instance MotionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionSensor
]

instance ManufacturingContextDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ManufacturingSensorNetwork
]

// C5: Digital Shadow Data
instance RawSensorData : DTDFVocab:Data [
    base:desc "Raw contextual data traces collected from physical manufacturing sensors, aggregated for digital shadow representation without preprocessing"
    DTDFVocab:fromData TemperatureDataTransmitted, PressureDataTransmitted, MotionDataTransmitted, ManufacturingContextDataTransmitted
    DTDFVocab:inputTo DigitalShadowReferenceModel
]

instance AbstractedOperationalData : DTDFVocab:Data [
    base:desc "Abstraction layer of raw sensor data traces, processed for specific operational purposes in manufacturing digital shadow systems"
    DTDFVocab:fromData RawSensorData
    DTDFVocab:inputTo DigitalShadowReferenceModel
]

// C6: Simulation Tools
instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation environment for detailed system behavior validation and prototyping across multiple abstraction layers in manufacturing systems"
]

instance GeneralPurposeSimulation : DTDFVocab:Enabler [
    base:desc "General-purpose simulation methodologies for complex system behavior analysis and validation in MBSE frameworks"
]

// C7: Development Platforms
instance CPlusPlusPlatform : DTDFVocab:Enabler [
    base:desc "C++ development platform for integrating active components (AI/ML models) into Digital Twin architectures for autonomous operations"
]

instance JavaPlatform : DTDFVocab:Enabler [
    base:desc "Java development platform for creating active software components that interpret digital shadow data for manufacturing Digital Twin systems"
]

// C8: Digital Shadow Reference Model
instance DigitalShadowReferenceModel : DTDFVocab:Enabler [
    base:desc "Digital Shadow reference model framework (Kritzinger et al.) for passive data aggregation and abstraction from physical manufacturing systems to digital representations"
    DTDFVocab:enables DigitalShadowDataAggregationService
]

// C9: Data Processing Services
instance DigitalShadowDataAggregationService : DTDFVocab:Service [
    base:desc "Service for one-way automated data aggregation from physical manufacturing sensors to digital shadow representations, implementing passive data flow patterns"
    DTDFVocab:provides ContextualDataAggregationInsight
]

// C10: Insights
instance ContextualDataAggregationInsight : DTDFVocab:Insight [
    base:desc "Insight generated from aggregated contextual data traces in digital shadow systems, providing operational context for manufacturing processes"
]

// C11: Environment
instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:contains ManufacturingSensorNetwork, TemperatureSensor, PressureSensor, MotionSensor
]

instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains DigitalShadowReferenceModel, MontiArcAutomata, SysMLStateMachine, Simulink, CPlusPlusPlatform, JavaPlatform
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The provided documents do not explicitly detail synchronization frequencies, latency requirements, or temporal granularity for Digital Twin (DT) systems. However, the distinction between **Digital Shadows** and **Digital Twins** implies that while Digital Shadows operate as passive, one-way data flows (e.g., aggregated contextual data traces), Digital Twins incorporate **active components** to process and respond to data in real-time. This suggests that **twinning time scales** for DTs may involve **frequent, bidirectional synchronization** (e.g., sub-second to real-time updates) to enable autonomous operations and decision-making. The absence of specific numerical values or tools (e.g., synchronization protocols like MQTT, WebSockets, or time-stamped data pipelines) in the documents means this characteristic is inferred from the functional distinction between passive shadows and active twins. Thus, **twinning_time_scale** is not explicitly documented but implies dynamic, high-frequency temporal alignment between physical and digital components for DTs."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A **Digital Twin constellation** is not explicitly defined in the provided documents. However, the context implies that Digital Twins (DTs) may operate within a **hierarchical or federated architecture**, where multiple DT instances coordinate through **centralized or decentralized mechanisms** to manage system-wide responsibilities. The documents reference **Model-Based Systems Engineering (MBSE)** methodologies (e.g., SysML, ADLs like AADL, MontiArc) for describing component interactions, suggesting that DTs could leverage **architecture description languages (ADLs)** to define **component multiplicities, interconnections, and behavior** (e.g., state machines or automata). While no specific constellation patterns (e.g., master-slave, peer-to-peer) or coordination protocols (e.g., consensus algorithms) are mentioned, the **orchestration of DTs** would likely involve **resource management tools** (e.g., Simulink for simulation-based coordination) to ensure seamless integration across heterogeneous stakeholders and perspectives."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "
  A Digital Twin (DT) lifecycle in the provided context spans **model-based systems engineering (MBSE)** phases, structured through **multi-level abstraction** (requirements, functional architecture, logical architecture, and product/technical layers) as defined by methodologies like **RFLP (Requirements, Functions, Logics, Physics)**, **OOSEM**, **SPES**, or **SMArDT**. The lifecycle transitions involve:
  - **Development Phase**: Utilizes **SysML** (including **IBDs for architecture description**) and **ADLs** (e.g., **ACME, AADL, MontiArc**) to model components, interfaces, and behavior (e.g., **MontiArc Automaton, state machines in SysML v1.7**).
  - **Representation Types**: Models are heterogeneous, combining **SysML diagrams**, **simulation tools** (e.g., **MathWorks Simulink**), and **code** (e.g., **C++, Java**) across abstraction layers.
  - **Transition Management**: Requires integration of **heterogeneous stakeholders’ perspectives** and tools, ensuring consistency via **model transformation** and **interoperability frameworks** (e.g., **SysML’s compatibility with AADL/ACME**).
  - **Lifecycle Governance**: Implicitly governed by **MBSE methodologies**, emphasizing **complexity management** through structured abstraction hierarchies and stakeholder alignment.
  **Note**: The document does not explicitly detail DT-specific lifecycle stages post-development, but the provided context implies a **continuous evolution** tied to **digital shadow** aggregation (e.g., data traces, abstraction) for manufacturing applications.
"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
    Fidelity is ensured through **multi-layered MBSE abstraction** (requirements → functional/logical architecture → simulation), where **ADLs (e.g., AADL, MontiArc)** and behavioral models (e.g., state machines) validate structural and dynamic consistency. Validation/verification methods are implied via **simulation tools** (e.g., MathWorks Simulink) and **code-based modeling** (C++/Java), though specific error detection/correction mechanisms or uncertainty quantification are not detailed. Quality assurance processes are implicitly tied to **stakeholder-integrated MBSE frameworks** (e.g., RFLP, OOSEM), ensuring alignment across abstraction layers.
  "
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "
  **Network Infrastructure:**
  The Digital Twin’s technical connection is implicitly referenced through the *Digital Shadow* reference model, which defines a **UML class diagram** (Fig. 1) outlining concepts for manufacturing DTs. While not explicitly detailed, the system’s communication infrastructure likely adheres to:
  - **Communication Protocols:** Industrial-grade protocols (e.g., **OPC UA**, **MQTT**, or proprietary OT/IIoT protocols) for real-time data exchange, though specifics are not provided.
  - **Network Topology:** The topology is not specified, but the context suggests a **hierarchical or distributed architecture** (e.g., cloud-edge-on-premise) to support heterogeneous stakeholders’ perspectives (as noted in MBSE complexity).
  - **Bandwidth/Latency Requirements:** Not quantified; assumed to meet **real-time or near-real-time** constraints for critical applications (e.g., predictive maintenance, automation).
  - **Reliability/Redundancy:** The documents do not mention redundancy mechanisms, but the passive nature of the digital shadow implies **high availability** via redundant data paths or failover systems (e.g., dual communication links).
  - **Security Protocols:** Not detailed; however, the integration with MBSE tools (e.g., SysML, AADL) suggests adherence to **industrial cybersecurity standards** (e.g., IEC 62443) for data integrity and authentication, though no specific protocols (e.g., TLS, encryption) are named.
"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "
  **Deployment Infrastructure:**
  The hosting and deployment of the Digital Twin system are implicitly tied to **Model-Based Systems Engineering (MBSE)** methodologies, which support heterogeneous platforms. The documents do not specify exact hosting environments (e.g., cloud, edge, on-premise), but the following can be inferred:
  - **Platforms:** Deployment is likely supported across **cloud, edge, or on-premise** environments, given the need to integrate diverse stakeholders’ perspectives (e.g., engineers, operators).
  - **Computational/Storage Requirements:** Not quantified; however, the system requires **high-performance computing** to handle:
    - **Modeling tools** (e.g., SysML, MontiArc) for architecture description.
    - **Simulation tools** (e.g., MathWorks Simulink, proprietary simulation frameworks) for behavior modeling.
    - **Data aggregation and abstraction** layers (e.g., digital shadows) to process contextual traces.
  - **Scalability Mechanisms:** The documents mention **heterogeneous stakeholders** and **complexity handling** (e.g., RFLP, OOSEM methodologies), implying **scalable architectures** (e.g., microservices, containerization) to accommodate growth.
  - **Availability/Reliability Assurance:** Not specified; but the passive digital shadow design suggests **high availability** via redundant data pipelines and automated failover mechanisms (e.g., cloud redundancy, edge caching).
  - **Deployment Models:** Supported models include **cloud-native**, **edge computing**, and **on-premise** deployments, aligned with MBSE’s need for cross-platform integration.
"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "
  **Standards Compliance**:
  - **Industry Standards**:
    - **Modeling Languages**: **SysML** (ISO/IEC 19450), **AADL** (IEEE 15288), **ACME** (ISO/IEC 19888), **MontiArc** (ISO/IEC 26283).
    - **Architecture Description Languages (ADLs)**: **AADL** (for aerospace/automotive), **SysML IBDs** (for multi-domain systems).
    - **Simulation Tools**: **MathWorks Simulink** (compliant with SysML).
  - **Specifications**:
    - **RFLP/SPES/OOSEM Methodologies**: Align with **ISO/IEC 15288** (Systems Engineering) for lifecycle management.
    - **Digital Shadow/Digital Twin Differentiation**: Defined via **Kritzinger et al. [32]** (one-way vs. bidirectional data flow).
  - **Certification Requirements**: Not explicitly listed; implied via **ADL/toolchain compliance** (e.g., **AADL certification**).
  - **Interoperability Standards**:
    - **SysML/AADL interoperability** (e.g., **SysML’s compatibility with AADL components**).
    - **Digital Shadow interoperability**: Enforced via **UML class diagrams** (Fig. 1) for manufacturing data aggregation.
  - **Compliance Frameworks**:
    - **MBSE frameworks** (e.g., **SMArDT**) ensure adherence to **ISO/IEC 19450** (MBSE standards).
"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "
    **Cybersecurity Protocols:**
    The **Asset Administration Shell (AAS)** framework, as referenced in documents [50] and [47], underpins the digital twin's security by leveraging standardized interfaces for secure data exchange. The AAS employs **semantic asset administration shell (SAAS)** principles (document [46]) to ensure interoperability and security through structured ontologies and knowledge graphs, mitigating risks associated with unstructured data.

    **Access Control Mechanisms:**
    The **RAMI 4.0** reference architecture (document [49] and [48]) specifies layered security controls across the automation pyramid, including **authentication via MQTT protocol** (document [52]) for IoT-based digital twins, ensuring only authorized entities (e.g., devices, applications) can interact with the twin. The **Thingsboard IoT platform** (document [53]) integrates role-based access control (RBAC) and mutual TLS (mTLS) for secure communication between digital twin components and external systems.

    **Authentication Systems:**
    The **MQTT protocol** (document [52]) supports lightweight authentication mechanisms, including client certificates and pre-shared keys, to validate device identities in real-time. The **Functional Mockup Interface (FMI)** (document [51]) for simulation models enforces secure data exchange via standardized interfaces, ensuring only compliant systems can access twin data.

    **Threat Mitigation Strategies:**
    The **Digital Shadow** approach in the automation pyramid (document [42]) includes **fail-safe mechanisms** for critical systems, where digital twins automatically trigger predefined responses (e.g., emergency shutdowns) if cyber threats (e.g., DDoS attacks) are detected. The **Model-Driven Engineering (MDE)** methodology (document [43]) enables automated validation of twin models against security policies, reducing vulnerabilities through static analysis.

    **Fail-Safe Mechanisms:**
    The **RAMI 4.0** framework (document [49]) mandates **safety-critical layers** for digital twins, where physical and digital components are isolated via **sandboxed execution environments** (e.g., containerized IoT devices) to prevent cascading failures. The **AAS** (document [50]) integrates **safety-critical event handling** via standardized interfaces, ensuring real-time monitoring of twin states (e.g., temperature, pressure) and automatic intervention if thresholds are breached.

    **Risk Assessment Approaches:**
    The **conformance relations** in reference models (document [41]) enable systematic risk assessment by validating digital twin structures against predefined security profiles (e.g., ISO 27001 compliance). The **friction modeling** technique (document [45]) for robot dynamics can be extended to model cyber-physical risks by simulating adversarial scenarios (e.g., robotic arm manipulation attacks) to preemptively harden twin systems.

    **Safety-Critical System Considerations:**
    For **manufacturing digital twins** (document [43]), the integration of **MABI robotic arms** (document [44]) requires adherence to **ISO 10218-2** safety standards, where digital twins must replicate real-time kinematic and dynamic constraints (e.g., collision avoidance) via **real-time simulation engines**. The **AAS** (document [50]) supports **safety-critical data streams** by separating operational and diagnostic data channels, ensuring only authorized systems can access safety-relevant information."
]