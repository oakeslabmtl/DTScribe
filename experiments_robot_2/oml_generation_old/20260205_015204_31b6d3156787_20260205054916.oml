// Sensing Components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Absolute position encoder mounted directly on the motor shaft, providing rotational angle."
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Absolute position encoder mounted behind the gearbox, providing rotational angle."
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring input current to the motor shaft."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// Data Transmitted
instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder, GearboxEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// Data
instance MotorAngleData : DTDFVocab:Data [
    base:desc "Time series of motor rotational angle in degrees."
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo DataProcessorEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time series of motor current in amperes."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo DataProcessorEnabler
]

// Enabler for data processing
instance DataProcessorEnabler : DTDFVocab:Enabler [
    base:desc "C++/Java component applying a 4th-order low‑pass filter, unit mapping, and storing processed data in a time‑series database."
    DTDFVocab:enables DataProcessingService
]

// Insights
instance MotorCurrentThresholdInsight : DTDFVocab:Insight [
    base:desc "Insight indicating when motor current exceeds a configurable threshold."
]

instance MotorAnglePositionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating current motor position relative to safety limits."
]

// Service for data processing
instance DataProcessingService : DTDFVocab:Service [
    base:desc "Service that processes raw sensor data and provides real‑time insights."
    DTDFVocab:provides MotorCurrentThresholdInsight, MotorAnglePositionInsight
]

// Action
instance AdjustTorqueAction : DTDFVocab:Action [
    base:desc "Automatic command to adjust motor torque based on current and position insights."
    DTDFVocab:IsAutomatic true
]

// Service for actuator control
instance ActuatorControlService : DTDFVocab:Service [
    base:desc "Service that sends torque commands to the Siemens SINUMERIK 840D servo processor."
    DTDFVocab:provides AdjustTorqueAction
]

// Acting Component
instance ServoProcessor : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D servo processor translating current setpoints into torque outputs."
]

// Enabler for actuator control via OPC UA
instance ServoProcessorEnabler : DTDFVocab:Enabler [
    base:desc "OPC UA interface to the servo processor exposing CONTROL.TORQUE, CONTROL.SPEED, SAFETY.FLAG."
    DTDFVocab:enables ActuatorControlService
]

// Model for simulation
instance SimulinkInterfaceModel : DTDFVocab:Model [
    base:desc "Matlab Simulink model representing the motor dynamics."
    DTDFVocab:inputTo SimulinkSimulatorEnabler
]

// Enabler for simulation
instance SimulinkSimulatorEnabler : DTDFVocab:Enabler [
    base:desc "Simulink simulator executing the motor model."
    DTDFVocab:enables SimulationService
]

// Service for simulation
instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs the Simulink model and provides simulation insights."
    DTDFVocab:provides SimulatedMotorBehaviorInsight
]

// Insight from simulation
instance SimulatedMotorBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight describing simulated motor behavior for comparison with real measurements."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration is grounded in Model-Based Systems Engineering (MBSE) practices, leveraging system modeling languages such as SysML for functional and logical architecture, and architecture description languages (ADLs) like ACME, AADL, MontiArc, or SysML IBDs for component and connector descriptions. These models are often combined with simulation tools such as MathWorks Simulink or general-purpose code (C++/Java) to describe behavior. Coordination at the constellation level hinges on these integrated representations, with resource management and system-wide coordination inferred from the combined usage of methodology frameworks such as RFLP, OOSEM, SPES, or SMArDT, though explicit orchestration patterns are not detailed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Information from the physical asset is transmitted via MQTT over TCP/IP. Topics are organized per subsystem (e.g., /sensor/current, /actuator/angle). The MQTT broker is positioned on the local edge gateway, providing non‑blocking publish/subscribe semantics. No specific QoS level is mandated in the source; reliability expectations are left implicit."
]