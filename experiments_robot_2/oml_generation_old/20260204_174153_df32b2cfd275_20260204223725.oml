// ===================================================
// C17: Insights
// ===================================================
instance RealTimeVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live visualization of measured sensor traces versus simulated model outputs"
]

instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Estimated static, kinetic and viscous friction parameters derived from sensor data"
]

instance RefinedMotionControlInsight : DTDFVocab:Insight [
    base:desc "Estimated friction parameters are fed back to the robot controller to refine motion‑control algorithms and reduce positioning errors"
]

instance ImprovedAccuracyInsight : DTDFVocab:Insight [
    base:desc "Automatic model updating improves motion‑control accuracy"
]

// ===================================================
// C17: Actions
// ===================================================
instance SwitchFrictionModelAction : DTDFVocab:Action [
    base:desc "Automatically switches between white‑box and black‑box friction models based on identification confidence",
    DTDFVocab:IsAutomatic true
]

instance ModelUpdateAction : DTDFVocab:Action [
    base:desc "Updates the digital twin with newly identified friction parameter values",
    DTDFVocab:IsAutomatic true
]

instance UpdateControllerAction : DTDFVocab:Action [
    base:desc "Updates the robot controller with refined friction parameters",
    DTDFVocab:IsAutomatic true
]

// ===================================================
// C6: Services
// ===================================================
instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Provides real‑time dashboard visualization of measured vs. simulated data",
    DTDFVocab:provides RealTimeVisualizationInsight
]

instance ContinuousFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuously identifies and estimates static, kinetic and viscous friction parameters",
    DTDFVocab:provides FrictionParameterInsight, RefinedMotionControlInsight
]

instance AutomaticModelUpdateService : DTDFVocab:Service [
    base:desc "Automatically selects and updates white‑box or black‑box friction models to improve motion‑control accuracy",
    DTDFVocab:provides SwitchFrictionModelAction, ModelUpdateAction
]

// ===================================================
// C11: Enablers
// ===================================================
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML tool used for engineering structural models of the robot axis"
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for executable simulation and parameter identification",
    DTDFVocab:enables ContinuousFrictionIdentificationService, AutomaticModelUpdateService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker for streaming live sensor data from the robot to the digital shadow",
    DTDFVocab:enables RealTimeDashboardService, ContinuousFrictionIdentificationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for model integration and metadata management",
    DTDFVocab:enables AutomaticModelUpdateService
]

instance WebDashboard : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard visualising measured versus simulated data in real time",
    DTDFVocab:enables RealTimeDashboardService
]

// ===================================================
// C10: Models / Data
// ===================================================
instance SysMLRobotAxisModel : DTDFVocab:Model [
    base:desc "SysML block diagram describing the motor, primary gear transmission and cycloidal gearbox of the first robot axis",
    DTDFVocab:inputTo SysMLTool
]

instance SimulinkMotorGearboxModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink simulation model of motor, gear transmission and cycloidal gearbox (without friction)",
    DTDFVocab:inputTo SimulinkTool
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Data‑calculation model implementing Coulomb‑viscous friction equations (static, kinetic, viscous terms)",
    DTDFVocab:inputTo SimulinkTool
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Data‑calculation model implementing the Stribeck friction characteristic",
    DTDFVocab:inputTo SimulinkTool
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Data‑calculation model implementing Dahl friction hysteresis",
    DTDFVocab:inputTo SimulinkTool
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "Data‑calculation model implementing the LuGre friction formulation",
    DTDFVocab:inputTo SimulinkTool
]

// ===================================================
// C3: Physical sensing components (without forward reference)
// ===================================================
instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor position encoder measuring the motor shaft angle for the first robot axis"
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Gearbox position encoder measuring the secondary gearbox output angle for the first robot axis"
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring the motor phase current I_M of the first robot axis"
]

// ===================================================
// C4: Physical‑to‑virtual interaction
// ===================================================
instance MotorPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance DerivedTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorPositionEncoder, GearboxPositionEncoder
]

instance DerivedAngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder, GearboxPositionEncoder
]

instance DerivedAccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder, GearboxPositionEncoder
]

// ===================================================
// C5: Data
// ===================================================
instance MotorPositionData : DTDFVocab:Data [
    base:desc "Time‑series of motor shaft angle",
    DTDFVocab:fromData MotorPositionDataTransmitted,
    DTDFVocab:inputTo MQTTBroker, SimulinkTool
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Time‑series of gearbox output angle",
    DTDFVocab:fromData GearboxPositionDataTransmitted,
    DTDFVocab:inputTo MQTTBroker, SimulinkTool
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time‑series of motor phase current I_M",
    DTDFVocab:fromData MotorCurrentDataTransmitted,
    DTDFVocab:inputTo MQTTBroker, SimulinkTool
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Calculated torque trace derived from current and position data",
    DTDFVocab:fromData DerivedTorqueDataTransmitted,
    DTDFVocab:inputTo SimulinkTool
]

instance DerivedAngularVelocityData : DTDFVocab:Data [
    base:desc "Calculated angular‑velocity trace derived from position data",
    DTDFVocab:fromData DerivedAngularVelocityDataTransmitted,
    DTDFVocab:inputTo SimulinkTool
]

instance DerivedAccelerationData : DTDFVocab:Data [
    base:desc "Calculated acceleration trace derived from position data",
    DTDFVocab:fromData DerivedAccelerationDataTransmitted,
    DTDFVocab:inputTo SimulinkTool
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time operation during robot runtime; data are processed and visualized as they are received, enabling on‑line model updating."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A digital shadow composed of DataTraces linked to Sources, a Processing component that executes simulation and friction models, and a set of Models (engineering, simulation, data‑calculation) instantiated for the first robot axis, all tied to the asset via an AAS representation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Focused on the operational stage of the robot; the digital shadow is created and used while the physical system is running to monitor and refine friction behavior."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each DataPoint to its generating model and source; validation by comparing simulated friction‑free and friction‑included outputs against measured reference traces; continuous re‑identification of model parameters to maintain accuracy despite wear or environmental changes."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are published over MQTT; the digital shadow consumes these MQTT messages to populate DataTraces. No other networking details are specified."
]