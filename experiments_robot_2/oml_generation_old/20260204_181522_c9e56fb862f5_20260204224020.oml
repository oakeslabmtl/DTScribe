// C3: Physical sensing component (contextual data collector)
instance ContextualDataCollector : DTDFVocab:SensingComponent [
    base:desc "Collects contextual data traces from the physical system as part of the digital shadow, providing raw input data for processing."
    DTDFVocab:producedData RawDataTrace
]

// C4: Physical-to-virtual interaction – data transmitted
instance RawDataTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContextualDataCollector
]

// C10: Data (aggregated and abstracted)
instance AggregatedContextualData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces, used as input for both white‑box (physics‑based) and black‑box (data‑driven) models."
    DTDFVocab:fromData RawDataTrace
    DTDFVocab:inputTo ModelTransformationEngine, DataProcessingEngine
]

// C10: Models
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML model capturing the structural architecture of the physical system, defining components, interfaces, and connectors."
    DTDFVocab:inputTo ModelTransformationEngine
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "Executable simulation model created in MathWorks Simulink, representing behavioural aspects of the system."
    DTDFVocab:inputTo SimulationExecutionEngine
]

// C11: Enablers (processing & tooling)
instance ModelTransformationEngine : DTDFVocab:Enabler [
    base:desc "Transforms SysML structural models into Simulink simulation models, ensuring propagation of structural information to behavioural simulation."
    DTDFVocab:enables DataProcessingService
]

instance SimulationExecutionEngine : DTDFVocab:Enabler [
    base:desc "Executes Simulink simulation models to generate derived output data."
    DTDFVocab:enables DataProcessingService
]

instance DataProcessingEngine : DTDFVocab:Enabler [
    base:desc "Processing component that consumes aggregated data and runs data‑calculation or simulation models to produce higher‑level output with full provenance."
    DTDFVocab:enables DataProcessingService
]

instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "Model‑Based Systems Engineering (MBSE) tool using SysML for requirements, functional, logical and product layers."
    DTDFVocab:enables DataProcessingService
]

instance ACMEArchitectureTool : DTDFVocab:Enabler [
    base:desc "Architecture description language tool (ACME) used for component and connector specifications."
    DTDFVocab:enables DataProcessingService
]

instance AADLTool : DTDFVocab:Enabler [
    base:desc "Architecture Analysis & Design Language (AADL) tool for modeling system components and interactions."
    DTDFVocab:enables DataProcessingService
]

instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc tool for modeling component architectures and state‑machine extensions."
    DTDFVocab:enables DataProcessingService
]

instance SimulinkSimulationTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for building executable simulation models."
    DTDFVocab:enables DataProcessingService
]

instance CppExecutableEngine : DTDFVocab:Enabler [
    base:desc "C++ runtime engine for executing generated code from models."
    DTDFVocab:enables DataProcessingService
]

instance JavaRuntimeEngine : DTDFVocab:Enabler [
    base:desc "Java runtime for executing model‑derived components."
    DTDFVocab:enables DataProcessingService
]

instance ReferenceModelConformanceChecker : DTDFVocab:Enabler [
    base:desc "Checks conformance of updated concrete reference models to the admissible set, supporting twin evolution."
    DTDFVocab:enables TwinEvolutionService
]

// C6: Services
instance DataProcessingService : DTDFVocab:Service [
    base:desc "Processes aggregated contextual data via simulation or data‑calculation models, generating derived outputs with complete provenance."
    DTDFVocab:provides DerivedPerformanceIndicatorInsight
]

instance TwinEvolutionService : DTDFVocab:Service [
    base:desc "Manages evolution of the digital twin by updating reference models and re‑instantiating processing logic."
    DTDFVocab:provides DerivedPerformanceIndicatorInsight
]

// C17: Insight
instance DerivedPerformanceIndicatorInsight : DTDFVocab:Insight [
    base:desc "Derived performance indicators computed from processed data traces, supplying actionable insight to downstream decision‑support applications."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The document states that a Digital Twin can provide active components that may generate control commands back to the physical system, but it does not specify command types, message formats, validation, authentication, or feedback mechanisms."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the MBSE development hierarchy described in the documents: it starts with a requirements model, proceeds to functional‑architecture models, then logical‑architecture models, and finally to the product/technical layer. At each stage the Twin is represented with appropriate artifacts – SysML requirement diagrams, SysML internal‑block diagrams or IBDs for functional and logical structures, and concrete component‑connector models in ADLs (e.g., ACME, AADL, MontiArc) for the technical layer. Transition between stages is managed by concretizing the Digital Shadow Reference Model into a concrete realization (a mapping of reference concepts to concrete classes and associations) and by extending the model with simulation or calculation models (e.g., Simulink) that generate data traces. Governance is achieved through the reference‑model conformance relation that defines which concrete models are admissible at each lifecycle phase."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The approach stresses traceability of every model element back to its source data and verification of model transformations (e.g., from SysML architectural models to simulation models) to preserve semantics. Fidelity is addressed by combining physics‑based (white‑box) models with data‑driven (black‑box) components, thereby leveraging the predictability of analytical models and the expressive power of machine‑learning models. Validation relies on the correctness of the underlying models and on systematic verification methods proposed in the literature, which aim to ensure that the digital representation accurately reflects the physical system."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on a reference‑model based standardisation strategy: a Digital Shadow Reference Model defines domain concepts and a formal conformance relation that identifies all admissible concrete models. Modelling is performed with standard languages and standards – SysML for system modelling, ADLs such as ACME, AADL and MontiArc for component‑connector architecture, and simulation tools like Simulink for behavior. The concrete realization of the reference model follows a mapping (conformance) to these standard artefacts, ensuring interoperability and compliance with the established modelling standards."
]