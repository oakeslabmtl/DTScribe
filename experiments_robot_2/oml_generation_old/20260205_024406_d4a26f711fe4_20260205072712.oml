// C3: Physical sensing components // Return code: 1 | Stderr:
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor (input I_M) for the first axis of the MABI MAX0100 industrial robot"
]
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution rotary encoder measuring motor shaft position for the first axis"
]
instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution rotary encoder measuring gearbox output position for the first axis"
]

// C4: Physical-to-virtual interaction (data transmitted via MQTT)
instance CurrentIMTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]
instance MotorAngleQ_MTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]
instance GearboxAngleQ_GTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]
instance SimulatedMotorTorqueTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSimulinkModel
]
instance SimulatedMotorVelocityTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorSimulinkModel
]

// C5: Data
instance CurrentIMData : DTDFVocab:Data [
    base:desc "Sequence of floating‑point current measurements I_M"
    DTDFVocab:fromData CurrentIMTopic
    DTDFVocab:inputTo MQTTBrokerEnabler
]
instance MotorAngleQ_MData : DTDFVocab:Data [
    base:desc "Sequence of floating‑point motor angular position measurements Q_M"
    DTDFVocab:fromData MotorAngleQ_MTopic
    DTDFVocab:inputTo MQTTBrokerEnabler
]
instance GearboxAngleQ_GData : DTDFVocab:Data [
    base:desc "Sequence of floating‑point gearbox angular position measurements Q_G"
    DTDFVocab:fromData GearboxAngleQ_GTopic
    DTDFVocab:inputTo MQTTBrokerEnabler
]
instance MotorTorqueData : DTDFVocab:Data [
    base:desc "Computed motor torque τ_M derived from current and encoder signals"
    DTDFVocab:fromData CurrentIMTopic
    DTDFVocab:inputTo SimulinkEngine
]
instance MotorAngularVelocityData : DTDFVocab:Data [
    base:desc "Computed motor angular velocity ω_M derived from encoder signals"
    DTDFVocab:fromData MotorAngleQ_MTopic
    DTDFVocab:inputTo SimulinkEngine
]
instance GearwheelTorqueData : DTDFVocab:Data [
    base:desc "Computed gearwheel torque τ_G derived from motor torque and gearbox kinematics"
    DTDFVocab:fromData CurrentIMTopic
    DTDFVocab:inputTo SimulinkEngine
]
instance SystemTorqueData : DTDFVocab:Data [
    base:desc "Computed overall system torque τ_out from gearwheel torque"
    DTDFVocab:fromData CurrentIMTopic
    DTDFVocab:inputTo SimulinkEngine
]
instance SimulatedMotorTorqueData : DTDFVocab:Data [
    base:desc "Simulated motor torque data produced by the Simulink motor model"
    DTDFVocab:fromData SimulatedMotorTorqueTopic
    DTDFVocab:inputTo SimulinkEngine
]
instance SimulatedMotorVelocityData : DTDFVocab:Data [
    base:desc "Simulated motor velocity data produced by the Simulink motor model"
    DTDFVocab:fromData SimulatedMotorVelocityTopic
    DTDFVocab:inputTo SimulinkEngine
]

// C10: Models
instance MotorSysMLModel : DTDFVocab:Model [
    base:desc "SysML component diagram for the permanent‑magnet synchronous motor of the first axis"
    DTDFVocab:inputTo SysMLToolkit
]
instance GearboxSysMLModel : DTDFVocab:Model [
    base:desc "SysML component diagram for the gear transmission (gearwheel and cycloidal gearbox) of the first axis"
    DTDFVocab:inputTo SysMLToolkit
]
instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Executable MATLAB/Simulink model producing simulated torque and velocity for the motor"
    DTDFVocab:inputTo SimulinkEngine
]
instance GearwheelSimulinkModel : DTDFVocab:Model [
    base:desc "Executable MATLAB/Simulink model producing simulated torque for the gearwheel"
    DTDFVocab:inputTo SimulinkEngine
]
instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "Executable MATLAB/Simulink model producing simulated torque for the cycloidal gearbox"
    DTDFVocab:inputTo SimulinkEngine
]

// C11: Enablers
instance SysMLToolkit : DTDFVocab:Enabler [
    base:desc "SysML (v1.7) modeling tool used to create component and connector diagrams"
    DTDFVocab:enables ServiceModelCreation
]
instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution engine for dynamic simulation and friction identification"
    DTDFVocab:enables ServiceSimulinkExecution, ServiceFrictionIdentification
]
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker for real‑time transport of sensor data and model outputs"
    DTDFVocab:enables ServiceDataTransport
]
instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell storage for asset metadata and traceability"
    DTDFVocab:enables ServiceAssetAdministration
]
instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard for visualization of joint motion and diagnostics"
    DTDFVocab:enables ServiceLiveVisualization
]

// C6: Services
instance ServiceModelCreation : DTDFVocab:Service [
    base:desc "Creation of SysML models for motor and gearbox"
]
instance ServiceSimulinkExecution : DTDFVocab:Service [
    base:desc "Execution of executable Simulink models for motor and gearbox dynamics"
]
instance ServiceDataTransport : DTDFVocab:Service [
    base:desc "Transport of sensor data and model outputs via MQTT protocol"
]
instance ServiceAssetAdministration : DTDFVocab:Service [
    base:desc "Management of asset metadata via AAS format"
]
instance ServiceLiveVisualization : DTDFVocab:Service [
    base:desc "Live visualization of joint motion data in a unified dashboard"
    DTDFVocab:provides InsightLiveJointMotion
]
instance ServiceFrictionIdentification : DTDFVocab:Service [
    base:desc "Real‑time identification of joint friction using analytical and data‑driven models"
    DTDFVocab:provides InsightFrictionLossDetected, InsightFrictionParameterUpdate, ActionUpdateFrictionParameters
]

// C17: Insights
instance InsightLiveJointMotion : DTDFVocab:Insight [
    base:desc "Live joint motion data displayed in the dashboard"
]
instance InsightFrictionLossDetected : DTDFVocab:Insight [
    base:desc "Detected friction losses compared to simulated torque/velocity"
]
instance InsightFrictionParameterUpdate : DTDFVocab:Insight [
    base:desc "Computed friction parameters are prepared for update of the robot controller"
]

// C17: Actions
instance ActionUpdateFrictionParameters : DTDFVocab:Action [
    base:desc "Send updated friction parameters to the robot controller for motion accuracy improvement"
    DTDFVocab:IsAutomatic true
]
instance ActionTriggerMaintenanceDecision : DTDFVocab:Action [
    base:desc "Notify operators to perform maintenance based on diagnostics"
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time continuous data acquisition and model simulation at the control loop rate of the robot (up to 75 [°]/s angular speed, sensors sampled at the controller’s update frequency)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized digital twin consisting of: (1) AAS‑based asset descriptor for the MABI MAX axis; (2) Engineering and simulation models (SysML + Simulink) forming the computational core; (3) Data traces and processing pipeline that consumes sensor streams, runs friction models, and aggregates results; (4) Dashboard interface presenting live plots and diagnostics. The constellation orchestrates data flow from PT to DT via MQTT, processing in the PT‑to‑DT pipeline, and visualization to end users."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational phase: the digital shadow is built and maintained during the robot’s in‑service operation for continuous identification and tuning of friction models; it does not cover the design or manufacturing stage of the PT."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Models combine white‑box analytical friction terms (Coulomb‑Viscous, Stribeck, Dahl, LuGre) with data‑driven black‑box components; runtime validation is achieved by comparing simulation outputs with measured data traces; traceability links each data point to its origin (sensor or model) and processing step; uncertainty is reduced through continuous online parameter adaptation and multi‑physics awareness."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Live data from the robot’s controller is published over MQTT (TCP/IP) to the digital shadow; the Asset Administration Shell provides semantic metadata, and the processing components consume these MQTT messages for real‑time analysis."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML (Unified Modeling Language) and Asset Administration Shells (a key Industrie 4.0 standard); adherence to UML class diagrams for the reference model."
]