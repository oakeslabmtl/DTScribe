// C3: Physical sensing component
instance CyberPhysicalDataAcquisitionComponent : DTDFVocab:SensingComponent [
    base:desc "Component that gathers concrete data traces from the cyber‑physical system, as described in the DT models and data characteristic."
    DTDFVocab:producedData AcquiredDataTransmission
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance AcquiredDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CyberPhysicalDataAcquisitionComponent
]

// C10: Data
instance RawSensorDataTrace : DTDFVocab:Data [
    base:desc "Concrete data trace gathered from the CPS, enriched with metadata."
    DTDFVocab:fromData AcquiredDataTransmission
    DTDFVocab:inputTo SimulinkEngine
]

// C10: Models
instance EngineeringStructureModel : DTDFVocab:Model [
    base:desc "Engineering model describing system structure, properties, and behavior."
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Simulink‑based dynamic simulation model executing computational logic."
    DTDFVocab:inputTo SimulinkEngine
]

instance DataCalculationAbstractionModel : DTDFVocab:Model [
    base:desc "Data‑calculation model deriving higher‑level abstractions from data traces."
    DTDFVocab:inputTo DataCalcEngine
]

// C11: Enablers
instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation engine that processes simulation models and data traces."
    DTDFVocab:enables SimulationExecutionService
]

instance DataCalcEngine : DTDFVocab:Enabler [
    base:desc "Engine that executes data‑calculation models to produce higher‑level abstracted data."
    DTDFVocab:enables DataAbstractionService
]

// C6: Services
instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service that runs simulation models and generates output data traces."
    DTDFVocab:provides SimulationResultInsight
]

instance DataAbstractionService : DTDFVocab:Service [
    base:desc "Service that processes raw data through calculation models to produce abstracted data."
    DTDFVocab:provides DataAbstractionInsight
]

// C17: Insights
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulation output enabling performance analysis."
]

instance DataAbstractionInsight : DTDFVocab:Insight [
    base:desc "Insight derived from higher‑level abstracted data supporting decision making."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and validity are addressed through traceability and verification of the model‑based development chain. Reliability depends on the correctness of underlying models and the transformations applied to data (e.g., SysML to simulation models). Verification methods include checking the conformance of concrete models to reference models, ensuring the correctness of transformation rules, and validating white‑box Simulink simulations against expected physical behavior. Uncertainty sources stem from model approximations and data noise; these are managed by maintaining fine‑grained traceability of data traces to their origin, enabling error detection and correction. Quality assurance processes comprise systematic verification of transformations, adherence to reference model constraints, and the use of traceability links to guarantee that each derived data trace can be audited back to its source models and inputs."
]