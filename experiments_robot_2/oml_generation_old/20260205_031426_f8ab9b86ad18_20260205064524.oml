// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "PMSM rated 5 kW, 5 000 rpm, max torque 20 Nm, controlled by Siemens SINUMERIK 840D PLC implementing cascaded PID loops and safety limits"
]

// C3: Physical sensing components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution incremental encoder on the motor shaft providing 0.1° absolute resolution with 5 V quadrature output, sampled at 10 kHz and transmitted over RS‑485 fiber‑optic link (125 kBaud)"
    DTDFVocab:producedData MotorShaftAngleDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Incremental encoder mounted on the gearbox delivering 0.01° absolute resolution after gear reduction, 5 V quadrature output, sampled at 10 kHz and transmitted over RS‑485 fiber‑optic link (125 kBaud)"
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

instance HallCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Hall‑effect current sensor measuring 0‑30 A range, sampled synchronously at 10 kHz, output transmitted over RS‑485 fiber‑optic link (125 kBaud)"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical‑to‑virtual interaction (Data Transmitted)
instance MotorShaftAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HallCurrentSensor
]

// C10: Models/Data
instance MotorShaftAngleData : DTDFVocab:Data [
    base:desc "Motor shaft angle measurement with 0.1° absolute resolution"
    DTDFVocab:fromData MotorShaftAngleDataTransmitted
    DTDFVocab:inputTo TelemetryIngestionEnabler
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Gearbox output angle with 0.01° absolute resolution after gear reduction"
    DTDFVocab:fromData GearboxAngleDataTransmitted
    DTDFVocab:inputTo TelemetryIngestionEnabler
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Instantaneous motor current measurement (0‑30 A) sampled at 10 kHz"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo TelemetryIngestionEnabler
]

// C11: Enablers
instance TelemetryIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Ingests sensor stream data, stores in PostgreSQL with microsecond timestamp, and publishes via OPCUA and MQTT"
    DTDFVocab:enables TwinInsightService
]

// C6: Services
instance TwinInsightService : DTDFVocab:Service [
    base:desc "Aggregates and analyzes ingested telemetry, provides real‑time insights and control recommendations"
    DTDFVocab:provides FrictionCoefficientInsight, TemperatureInsight, ControlAdjustmentAction
]

// C17: Insights/Actions
instance FrictionCoefficientInsight : DTDFVocab:Insight [
    base:desc "Real‑time inference of joint‑friction coefficients from encoder and current data"
]

instance TemperatureInsight : DTDFVocab:Insight [
    base:desc "Real‑time inference of temperature‑dependent material properties from inferred friction and motor load curves"
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Applies recommended controller parameter adjustments to improve execution accuracy by up to 3%"
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle is organized according to classical MBSE abstraction layers: (1) **Requirements** – traceable stakeholder needs expressed in natural‑language or SysML requirements blocks; (2) **Functional architecture** – SysML activity or sequence diagrams that decompose high‑level functions into observable interactions; (3) **Logical architecture** – a component‑connector model built with SysML IBDs, ACME or AADL that specifies interfaces and data flows; (4) **Product/Technical layer** – a concrete Instantiation of the logical model in a target platform (e.g., a Simulink block‑set, C++/Java classes, or a MontiArc simulation model). Transitions between layers are governed by traceability links that map requirements to functional activities, functional blocks to logical components, and logical interfaces to concrete implementation objects. Governance is achieved through a MBSE “Requirements‑Functions‑Logics‑Physics” (RFLP) workflow, ensuring that any change at the requirement level propagates automatically downwards via version‑controlled SysML models and that any prototype‑level behaviour is validated before promotion to the next abstraction tier.*"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The only technical connection described in the source is the MQTT transport of sensor data from the physical machines to the digital shadow. No additional details on network topology, QoS, security protocols, or bandwidth requirements are provided."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin complies with several industry standards: it implements **Asset Administration Shells (AAS)** – the ISO‑based reference model for digital product representation; it uses **SysML** (ISO 19464) and **ACME** for component–connector abstraction; and it streams telemetry via the lightweight **MQTT** protocol, conforming to IEC 61499 event‑driven architectures. All exchanged data types follow the AAS information model, ensuring interoperability across Industrial IoT platforms.*"
]