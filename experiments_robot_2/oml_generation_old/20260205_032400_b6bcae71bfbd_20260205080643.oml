// C3 Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring the current I_m of the motor"
    DTDFVocab:producedData CurrentI_mDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder directly mounted on the motor to measure motor angle"
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind gearbox measuring output angle q of the axis"
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

// C4 Physical-to-virtual interaction
instance CurrentI_mDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// C10 Models/Data
instance MotorStructuralModel : DTDFVocab:Model [
    base:desc "Engineering structural model of the motor and two gearboxes"
    DTDFVocab:inputTo EnablerSimulink
]

instance GearwheelModel : DTDFVocab:Model [
    base:desc "Model of the gearwheel in the first rotary axis"
    DTDFVocab:inputTo EnablerSimulink
]

instance GearboxModel : DTDFVocab:Model [
    base:desc "Model of the gearbox associated with the axis"
    DTDFVocab:inputTo EnablerSimulink
]

instance DataCurrent : DTDFVocab:Data [
    base:desc "Measured motor current I_m retrieved from MQTT stream"
    DTDFVocab:inputTo EnablerMQTT
    DTDFVocab:fromData CurrentI_mDataTransmitted
]

instance DataMotorAngle : DTDFVocab:Data [
    base:desc "Measured motor angle from motor encoder pulled via MQTT"
    DTDFVocab:inputTo EnablerMQTT
    DTDFVocab:fromData MotorAngleDataTransmitted
]

instance DataGearboxAngle : DTDFVocab:Data [
    base:desc "Measured gearbox output angle q from secondary encoder streamed over MQTT"
    DTDFVocab:inputTo EnablerMQTT
    DTDFVocab:fromData GearboxAngleDataTransmitted
]

instance DataTorque : DTDFVocab:Data [
    base:desc "Torque τ derived from motor current I_m using motor dynamics"
    DTDFVocab:inputTo EnablerMQTT
    DTDFVocab:fromData CurrentI_mDataTransmitted
]

instance DataAngularVelocity : DTDFVocab:Data [
    base:desc "Angular velocity ω derived from gearbox output angle q"
    DTDFVocab:inputTo EnablerMQTT
    DTDFVocab:fromData GearboxAngleDataTransmitted
]

instance DataSimulatedTrace_R_M : DTDFVocab:Data [
    base:desc "Simulated trace of motor output r_M from the motor structural model"
]

instance DataSimulatedTrace_R_G : DTDFVocab:Data [
    base:desc "Simulated trace of gearwheel output r_G from the gearwheel model"
]

instance DataSimulatedTrace_R_Out : DTDFVocab:Data [
    base:desc "Simulated trace of axis output r_out from the gearbox model"
]

// C11 Enablers
instance EnablerSimulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment used for executable simulation of the motor, gearwheel, and gearbox models"
    DTDFVocab:enables ServiceFrictionIdentification, ServiceMotionAccuracyCalibration
]

instance EnablerMQTT : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating real‑time streaming of current I_m and output angle q data from the sensors"
    DTDFVocab:enables ServiceVisualizationDashboard
]

instance EnablerWebDashboard : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard for visualizing measured versus simulated data traces"
    DTDFVocab:enables ServiceVisualizationDashboard
]

instance EnablerAssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell providing the digital twin context for the simulated and measured data"
    DTDFVocab:enables ServiceFrictionIdentification, ServiceMotionAccuracyCalibration
]

// C6 Services
instance ServiceVisualizationDashboard : DTDFVocab:Service [
    base:desc "Dashboard service that displays measured versus simulated data traces for the rotary axis"
    DTDFVocab:provides InsightVisualizationComparison
]

instance ServiceFrictionIdentification : DTDFVocab:Service [
    base:desc "Continuous, multi‑physics‑aware friction identification service applying Coulomb‑Viscous, Stribeck, Dahl, and LuGre friction models"
    DTDFVocab:provides InsightFrictionIdentification
]

instance ServiceMotionAccuracyCalibration : DTDFVocab:Service [
    base:desc "Service that updates calibrated friction model parameters into the robot’s control loop for motion accuracy"
    DTDFVocab:provides ActionApplyFrictionParams
]

// C17 Insights/Actions
instance InsightFrictionIdentification : DTDFVocab:Insight [
    base:desc "Insight extracting calibrated friction model parameters from continuous identification"
]

instance InsightVisualizationComparison : DTDFVocab:Insight [
    base:desc "Insight comparing measured data traces with simulated data traces in the visualization dashboard"
]

instance ActionApplyFrictionParams : DTDFVocab:Action [
    base:desc "Action applying updated friction model parameters to the robot’s control loop for motion correction"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data acquisition and processing with each sensor sample (e.g., sampled at the controller rate); the DT continually evaluates simulation models concurrently with live data."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestration of sensors feeding MQTT topics, a Processing component executing the Simulink models, generating data traces, and a dashboard consuming these traces; the digital shadow remains passive and is tied to the Asset via its AAS."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Designed in MBSE with SysML, simulated in Simulink, instantiated during operation as a digital shadow, refined continuously via live data identification; covers as operated lifecycle stage."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "White‑box friction models (Coulomb‑viscous, Stribeck, Dahl, LuGre) and black‑box data‑driven models are validated by comparing simulated torque and velocity traces against measured data; traceability of data points to their generation path is maintained; uncertainties arise from load, temperature, wear, and are managed through continuous re‑identification."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor and control data are transmitted over MQTT from the robot controller to the digital shadow processing component. The AAS provides a semantically enriched interface for asset description but the transport protocol remains MQTT. No explicit mention of additional protocols such as OPC UA or TCP/IP in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with SysML for system architecture, UML (class diagrams), AAS standards for asset representation, MQTT protocol for messaging, Simulink for model‑based simulation."
]