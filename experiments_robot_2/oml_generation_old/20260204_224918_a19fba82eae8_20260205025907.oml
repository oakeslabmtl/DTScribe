import DTDFVocab from "http://www.example.org/DTDFVocab"
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted directly on the drive shaft of the MABI MAX 100 robot"
    DTDFVocab:producedData MotorEncoderPositionData
]
instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder positioned behind the gearbox of the MABI MAX 100 robot"
    DTDFVocab:producedData GearboxEncoderPositionData
]
instance MotorEncoderPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]
instance GearboxEncoderPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor with gear transmission in the MABI MAX 100 robot"
]
instance SiemensSINUMERIK840DController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl controller for precise actuator control"
]
instance MABI_MAX_100_Robot : DTDFVocab:Environment [
    base:desc "Six-axis serial industrial robot for machining tasks with high path repeatability and flexible rotary joints"
    base:contains PermanentMagnetSynchronousMotor, SiemensSINUMERIK840DController, MotorEncoder, GearboxEncoder
]
instance FrictionLossDetectionInsight : DTDFVocab:Insight [
    base:desc "Analytics for detecting friction loss in the robot system"
]
instance FrictionLossDetectionService : DTDFVocab:Service [
    base:desc "Analytics service for detecting friction loss and improving robot control accuracy"
    DTDFVocab:provides FrictionLossDetectionInsight
]
instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Dashboard visualization for real-time monitoring and actionable insights"
    DTDFVocab:provides FrictionLossDetectionInsight
]
instance RFLP_Enabler : DTDFVocab:Enabler [
    base:desc "MBSE methodology for Requirements, Functions, Logics, Physics layers"
    DTDFVocab:enables FrictionLossDetectionService
]
instance OOSEM_Enabler : DTDFVocab:Enabler [
    base:desc "Object-Oriented Software Engineering Methodology for system complexity management"
    DTDFVocab:enables FrictionLossDetectionService
]
instance SPES_Enabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for system complexity management"
    DTDFVocab:enables FrictionLossDetectionService
]
instance SMArDT_Enabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for system complexity management"
    DTDFVocab:enables FrictionLossDetectionService
]
instance ACME_Enabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component interfaces and connections"
    DTDFVocab:enables FrictionLossDetectionService
]
instance AADL_Enabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component composition"
    DTDFVocab:enables FrictionLossDetectionService
]
instance MontiArc_Enabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component modeling"
    DTDFVocab:enables FrictionLossDetectionService
]
instance SysML_IBD_Enabler : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams for component modeling"
    DTDFVocab:enables FrictionLossDetectionService
]
instance MontiArcAutomaton_Enabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavior description"
    DTDFVocab:enables FrictionLossDetectionService
]
instance SysML_StateMachine_Enabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 state machines for behavior description"
    DTDFVocab:enables FrictionLossDetectionService
]
instance Simulink_Enabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and behavior modeling"
    DTDFVocab:enables FrictionLossDetectionService
]
instance Cpp_Enabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for simulation implementation"
    DTDFVocab:enables FrictionLossDetectionService
]
instance Java_Enabler : DTDFVocab:Enabler [
    base:desc "Java programming language for simulation implementation"
    DTDFVocab:enables FrictionLossDetectionService
]
instance DataManagementEnabler : DTDFVocab:Enabler [
    base:desc "Manages integration of heterogeneous data sources across abstraction levels"
    DTDFVocab:enables DashboardVisualizationService
]
instance RFLP_Model : DTDFVocab:Model [
    base:desc "MBSE methodology with Requirements, Functions, Logics, Physics layers for structural modeling"
    DTDFVocab:inputTo RFLP_Enabler
]
instance SysML_Model : DTDFVocab:Model [
    base:desc "SysML for structural modeling of the digital twin"
    DTDFVocab:inputTo SysML_IBD_Enabler
]
instance AADL_Model : DTDFVocab:Model [
    base:desc "Architecture Description Language for component interfaces and interconnections"
    DTDFVocab:inputTo AADL_Enabler
]
instance ACME_Model : DTDFVocab:Model [
    base:desc "Architecture Description Language for component composition and interfaces"
    DTDFVocab:inputTo ACME_Enabler
]
instance MontiArc_Model : DTDFVocab:Model [
    base:desc "Architecture Description Language for component modeling"
    DTDFVocab:inputTo MontiArc_Enabler
]
instance MontiArcAutomaton_BehavioralModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling of system components"
    DTDFVocab:inputTo MontiArcAutomaton_Enabler
]
instance SysML_StateMachine : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine for behavioral modeling"
    DTDFVocab:inputTo SysML_StateMachine_Enabler
]
instance Simulink_Simulation : DTDFVocab:Model [
    base:desc "MathWorks Simulink for analytical simulations"
    DTDFVocab:inputTo Simulink_Enabler
]
instance Cpp_Simulation : DTDFVocab:Model [
    base:desc "C++ code for general-purpose simulation"
    DTDFVocab:inputTo Cpp_Enabler
]
instance Java_Simulation : DTDFVocab:Model [
    base:desc "Java code for general-purpose simulation"
    DTDFVocab:inputTo Java_Enabler
]
instance MotorEncoderPositionDataAsData : DTDFVocab:Data [
    base:desc "Position data from motor encoder, streamed via MQTT protocol"
    DTDFVocab:fromData MotorEncoderPositionData
    DTDFVocab:inputTo DataManagementEnabler
]
instance GearboxEncoderPositionDataAsData : DTDFVocab:Data [
    base:desc "Position data from gearbox encoder, streamed via MQTT protocol"
    DTDFVocab:fromData GearboxEncoderPositionData
    DTDFVocab:inputTo DataManagementEnabler
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through sensor arrangements that minimize positional uncertainty. Validation is conducted by analyzing deviations between simulated and measured data, with systematic error correction and uncertainty quantification processes to maintain data integrity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT communication protocol used for streaming sensor data. No details on network topology, bandwidth, latency, reliability, redundancy, or security protocols are provided in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system complies with industry standards including SysML (including IBDs), AADL, ACME, and MontiArc as architecture description languages used in Model-Based Systems Engineering (MBSE) for system modeling."
]