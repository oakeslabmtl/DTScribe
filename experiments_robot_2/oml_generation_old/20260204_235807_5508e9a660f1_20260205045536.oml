// Sensing component capturing real‑time telemetry from the physical plant
instance PhysicalPlantTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Real‑time telemetry from the physical plant is stored as contextual data traces"
    DTDFVocab:producedData PlantTelemetryDataTransmitted
]

// Live input stream transmitted to simulation
instance PlantTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalPlantTelemetrySensor
    base:desc "Live input streams to the simulation"
]

// Aggregated contextual data traces in the Digital Shadow reference model
instance PlantTelemetryData : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces stored in the Digital Shadow reference model (Fig. 1)"
    DTDFVocab:fromData PlantTelemetryDataTransmitted
    DTDFVocab:inputTo SimulinkSimulationEngine, MontiArcRuntimeEngine
]

// Digital Shadow computational model
instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "Digital Shadow reference model (Fig. 1) aggregating data traces"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

// Enabler for Simulink simulation
instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation leveraging MathWorks Simulink to generate dynamic behavior"
    DTDFVocab:enables DynamicBehaviorSimulationService
]

// Enabler for MontiArc runtime execution
instance MontiArcRuntimeEngine : DTDFVocab:Enabler [
    base:desc "Simulation leveraging MontiArc runtime to translate MontiArc automata into executable code"
    DTDFVocab:enables ModelCodeGenerationService
]

// Service that simulates dynamic behavior
instance DynamicBehaviorSimulationService : DTDFVocab:Service [
    base:desc "Service that simulates dynamic behavior using Simulink"
    DTDFVocab:provides StateSynchronizationInsight
]

// Service that generates C++ code
instance ModelCodeGenerationService : DTDFVocab:Service [
    base:desc "Service that generates executable C++ code from MontiArc or SysML models"
    DTDFVocab:provides GenerateCPlusPlusRuntimeAction
]

// Insight on state synchronisation
instance StateSynchronizationInsight : DTDFVocab:Insight [
    base:desc "Insight that monitors synchronisation state between digital and physical artefacts"
]

// Action to generate C++ runtime code
instance GenerateCPlusPlusRuntimeAction : DTDFVocab:Action [
    base:desc "Action that generates C++ runtime code from the model"
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital Twin development follows a multi‑layered MBSE lifecycle, beginning with high‑level requirements, progressing through functional architecture, logical architecture, and finally the product/technical implementation. At each layer the twin is represented in increasingly detailed models: requirements are captured in natural language and requirement tables; functional architecture is expressed in SysML Requirements diagrams and block definition diagrams; logical architecture uses SysML IBDs or ADLs such as ACME or AADL to describe component‑connector structure; the product/technical layer is modeled with simulation primitives in tools like MathWorks Simulink or MontiArc automata. Transition between layers is managed by traceability links and model transformation rules, ensuring that each abstraction level is consistently derived from the preceding one. Lifecycle governance is typically performed through a model management system that enforces version control, change request workflows, and compliance checks against the MBSE methodology."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin employs SysML v1.7 for architecture modeling, with component‑connector descriptions in SysML IBDs, block definition diagrams and requirement diagrams. For logical and functional architecture, ACME, AADL, and MontiArc are also used as ADL standards. Simulation behavior is implemented using MathWorks Simulink, which follows the Simulink modeling standard."
]