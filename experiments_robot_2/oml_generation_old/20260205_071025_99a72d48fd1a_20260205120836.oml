// C2: Acting Components
instance ManufacturingSystemController : DTDFVocab:ActingComponent [
    base:desc "Active component implementing autonomous decision-making for system optimization via state machines (SysML v1.7) and simulation tools (MathWorks Simulink)"
]

instance PredictiveFailureAnalyzer : DTDFVocab:ActingComponent [
    base:desc "Software system leveraging machine learning for real-time failure forecasting using aggregated contextual data traces from physical objects"
]

instance PerformanceOptimizer : DTDFVocab:ActingComponent [
    base:desc "Component processing data flows to autonomously optimize system performance through closed-loop control mechanisms"
]

// C3: Physical Sensing Components (inferred from Digital Shadow characteristics)
instance ManufacturingProcessSensorCluster : DTDFVocab:SensingComponent [
    base:desc "Cluster of contextual sensors aggregating data traces for manufacturing process monitoring"
]

instance EnvironmentalParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring environmental parameters (temperature, pressure, humidity) for process context"
]

instance QualityControlInspectionSystem : DTDFVocab:SensingComponent [
    base:desc "Automated inspection system providing quality metrics and defect detection data"
]

// C4: Data Transmission Components
instance ProcessDataTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom "ManufacturingProcessSensorCluster"
    base:desc "Contextual data traces from manufacturing process sensors aggregated for operational visibility"
]

instance EnvironmentalContextTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom "EnvironmentalParameterSensor"
    base:desc "Aggregated environmental parameter data traces providing contextual information for process monitoring"
]

instance QualityMetricsTrace : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom "QualityControlInspectionSystem"
    base:desc "Defect detection and quality metrics data traces for manufacturing quality assurance"
]

// C10: Models
instance ManufacturingProcessModel : DTDFVocab:Model [
    base:desc "Behavioral model of manufacturing process using SysML state machines (v1.7) for operational simulation"
    DTDFVocab:inputTo "MontiArcAutomataEngine"
]

instance EnvironmentalSimulationModel : DTDFVocab:Model [
    base:desc "Environmental context simulation model using MontiArc Automata for process impact analysis"
    DTDFVocab:inputTo "MontiArcAutomataEngine"
]

instance QualityAssuranceModel : DTDFVocab:Model [
    base:desc "Defect detection and quality validation model implemented in SysML state machines"
    DTDFVocab:inputTo "SysMLSimulationEngine"
]

instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "UML-based class diagram defining data trace aggregation and abstraction logic for Digital Shadow implementation"
    DTDFVocab:inputTo "UMLClassDiagramTool"
]

// C11: Enablers
instance MontiArcAutomataEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine for behavioral modeling using MontiArc Automata framework"
    DTDFVocab:enables "ManufacturingProcessModel", "EnvironmentalSimulationModel"
]

instance SysMLSimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation tool for SysML state machine implementation (v1.7) and validation"
    DTDFVocab:enables "QualityAssuranceModel"
]

instance DigitalShadowAggregator : DTDFVocab:Enabler [
    base:desc "Software system implementing UML-based data trace aggregation and abstraction logic"
    DTDFVocab:enables "DigitalShadowReferenceModel"
]

instance MBSEIntegrationPlatform : DTDFVocab:Enabler [
    base:desc "Platform enabling multi-tool compatibility across SysML, MontiArc, Simulink, C++/Java frameworks"
    DTDFVocab:enables "ManufacturingProcessModel", "EnvironmentalSimulationModel", "QualityAssuranceModel"
]

instance SimulationValidationFramework : DTDFVocab:Enabler [
    base:desc "Framework for validating DT models through simulation consistency checks (e.g., behavioral consistency in state machines)"
    DTDFVocab:enables "ManufacturingProcessModel", "QualityAssuranceModel"
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology (Requirements, Functions, Logics, Physics) for complex system abstraction"
    DTDFVocab:enables "ManufacturingProcessModel", "DigitalShadowReferenceModel"
]

// C12: Data Components
instance ProcessPerformanceData : DTDFVocab:Data [
    base:desc "Aggregated real-time manufacturing process performance metrics derived from contextual data traces"
    DTDFVocab:fromData "ProcessDataTrace"
    DTDFVocab:inputTo "ManufacturingProcessModel", "PerformanceOptimizer"
]

instance EnvironmentalContextData : DTDFVocab:Data [
    base:desc "Normalized environmental parameter data providing contextual information for process operations"
    DTDFVocab:fromData "EnvironmentalContextTrace"
    DTDFVocab:inputTo "EnvironmentalSimulationModel", "ManufacturingProcessModel"
]

instance QualityMetrics : DTDFVocab:Data [
    base:desc "Defect detection scores and quality validation metrics from inspection systems"
    DTDFVocab:fromData "QualityMetricsTrace"
    DTDFVocab:inputTo "QualityAssuranceModel", "PredictiveFailureAnalyzer"
]

instance ContextualDataTraceAggregate : DTDFVocab:Data [
    base:desc "Final aggregated contextual data trace set for Digital Shadow implementation"
    DTDFVocab:fromData "ProcessDataTrace", "EnvironmentalContextTrace", "QualityMetricsTrace"
    DTDFVocab:inputTo "DigitalShadowAggregator", "ManufacturingProcessController"
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time passive data aggregation and contextual monitoring of manufacturing processes via digital shadows"
    DTDFVocab:provides "ProcessPerformanceData", "EnvironmentalContextData"
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Autonomous system performance optimization through state machine-based decision processes"
    DTDFVocab:provides "PerformanceOptimizationActions"
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Predictive analytics for failure forecasting and performance degradation using simulation models"
    DTDFVocab:provides "FailurePredictionInsights"
]

instance ControlService : DTDFVocab:Service [
    base:desc "Closed-loop control implementation pushing optimization signals back to physical manufacturing systems"
    DTDFVocab:provides "ControlCommands"
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Multi-perspective stakeholder visualization integrating requirements, functional, logical, and technical layers"
    DTDFVocab:provides "StakeholderDashboards"
]

// C17: Insights/Actions
instance ProcessPerformanceInsights : DTDFVocab:Insight [
    base:desc "Real-time operational performance metrics derived from aggregated manufacturing data traces"
]

instance EnvironmentalImpactInsights : DTDFVocab:Insight [
    base:desc "Contextual environmental impact analysis supporting process optimization decisions"
]

instance FailurePredictionInsights : DTDFVocab:Insight [
    base:desc "Predictive analytics results indicating potential failure points and degradation trends"
]

instance QualityAssuranceInsights : DTDFVocab:Insight [
    base:desc "Defect detection and quality validation metrics for manufacturing processes"
]

instance PerformanceOptimizationActions : DTDFVocab:Action [
    base:desc "Autonomous control actions generated by optimization algorithms to improve system performance"
    DTDFVocab:IsAutomatic true
]

instance ControlCommands : DTDFVocab:Action [
    base:desc "Closed-loop control signals sent back to physical manufacturing systems for real-time adjustments"
    DTDFVocab:IsAutomatic true
]

instance StakeholderDashboards : DTDFVocab:Action [
    base:desc "Multi-perspective visualization outputs for engineers, operators, and decision-makers across lifecycle phases"
    DTDFVocab:IsAutomatic false
]

// C17: Environment
instance ManufacturingProcessEnvironment : DTDFVocab:Environment [
    base:contains "ManufacturingProcessSensorCluster", "EnvironmentalParameterSensor", "QualityControlInspectionSystem",
    "ManufacturingSystemController", "PredictiveFailureAnalyzer", "PerformanceOptimizer"
]

instance DigitalTwinSystemEnvironment : DTDFVocab:Environment [
    base:contains "ManufacturingProcessModel", "EnvironmentalSimulationModel", "QualityAssuranceModel",
    "DigitalShadowReferenceModel", "DigitalShadowAggregator", "MBSEIntegrationPlatform",
    "SimulationValidationFramework", "RFLPMethodology"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The provided documents do not explicitly detail synchronization frequencies, latency requirements, or temporal granularity for Digital Twin (DT) systems. However, the distinction between **Digital Shadows** and **Digital Twins** implies that DTs must incorporate **active components** to process and respond to data in real-time or near-real-time, suggesting a **low-latency, high-frequency synchronization** mechanism (e.g., sub-second or millisecond intervals) to maintain temporal coherence between physical and digital counterparts. While no specific tools or protocols are named for timing synchronization, the context implies reliance on **MBSE methodologies** (e.g., SysML, AADL) for modeling time-sensitive behaviors, potentially leveraging **state machines** or **automaton-based models** (e.g., MontiArc) to enforce temporal constraints. The aggregation of contextual data traces in digital shadows (as defined) implies a **time-aware abstraction layer**, but no granularity specifications are provided beyond the passive nature of shadows."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin (DT) constellation** is not explicitly defined in the documents, but the **Digital Shadow Reference Model** (Fig. 1) provides foundational concepts for orchestration. A DT system, as implied by the context, likely employs **architecture description languages (ADLs)** such as **AADL, MontiArc, or SysML IBDs** to describe component integration, interconnections, and behavior (e.g., state machines or automata). The **orchestration** of DTs would involve **active components** (as opposed to passive digital shadows) to interpret and process data, potentially using **simulation tools** (e.g., MathWorks Simulink) or **general-purpose languages** (e.g., C++, Java) for behavior modeling. The **resource management** and **system-wide coordination** would rely on **MBSE methodologies** (e.g., RFLP, OOSEM) to align functional, logical, and physical layers. The absence of specific patterns (e.g., microservices, edge computing) suggests a **centralized or hybrid** approach, with coordination mediated by **model-driven engineering (MDE) workflows** to ensure consistency across heterogeneous stakeholders."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "
  **Not explicitly detailed in the provided documents**, but inferred from broader MBSE (Model-Based Systems Engineering) practices:
  - **Development Phase**:
    - **Requirements**: Defined via stakeholder needs and functional specifications.
    - **Functional Architecture**: Described using ADLs (e.g., SysML IBDs, AADL) to model components, interfaces, and connectors.
    - **Logical Architecture**: Refines functional architecture with behavioral models (e.g., state machines, automata in MontiArc).
    - **Product/Technical Layer**: Implementation in code (e.g., C++, Java) or simulation tools (e.g., Simulink).
  - **Lifecycle Governance**: Implicitly governed by MBSE methodologies (e.g., RFLP, OOSEM) that ensure alignment across abstraction layers and stakeholder perspectives.
  - **Transition Management**: Not explicitly detailed, but implied by iterative refinement between modeling layers and tool integration (e.g., combining SysML with Simulink).
"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
    **Fidelity and validity** in this Digital Twin framework are ensured through:
    - **Digital Shadow Integration**: Data traces from digital shadows are aggregated and abstracted for fidelity, with **one-way automated data flow** (passive) ensuring minimal latency but no autonomous feedback.
    - **Model Validation/Verification**: While not explicitly detailed, the reliance on **MBSE methodologies (e.g., RFLP, OOSEM)** and **ADLs (ACME, AADL)** implies rigorous validation across **requirements, functional, and physical layers**, leveraging tools like **Simulink** for simulation-based validation.
    - **Uncertainty Quantification**: Not explicitly addressed, but implied through **contextual abstraction** of digital shadows and **multi-tool consistency checks** across heterogeneous models.
    - **Error Detection/Correction**: Implicitly handled via **model reconciliation** between ADLs and simulation tools, ensuring alignment between logical and physical representations.
    - **Quality Assurance**: Enforced through **stakeholder-integrated MBSE workflows**, where heterogeneous perspectives (e.g., engineers, analysts) validate model accuracy and data integrity.
  "
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "
The **Digital Twin (DT)** infrastructure leverages **Model-Based Systems Engineering (MBSE)** methodologies (e.g., SysML, ADLs like AADL, MontiArc) to enable bidirectional interaction. Key technical aspects include:
- **Communication Protocols**: Not explicitly named, but implied to support **real-time simulation tools** (e.g., MathWorks Simulink [28], other simulation methods [29], [30]) via standardized interfaces (e.g., ROS, OPC UA) for seamless data exchange.
- **Network Topology**: Not detailed; assumed to follow **hierarchical or distributed architectures** (e.g., cloud-edge-on-premise hybrid) to support multi-layered DT systems (e.g., requirements → functional architecture → simulation).
- **Bandwidth/Latency**: Not specified; critical for **high-fidelity DTs**, but implied to require **low-latency communication** (e.g., <10ms for critical control loops) to ensure real-time synchronization.
- **Reliability/Redundancy**: Not detailed; however, **ADLs (e.g., MontiArc)** and **simulation tools** inherently support fault-tolerant designs via redundancy (e.g., duplicate components, failover mechanisms).
- **Security Protocols**: Not explicitly mentioned, but implied to integrate **authentication/validation mechanisms** (e.g., TLS, digital signatures) for secure DT communication, especially in industrial environments.
"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "
The **Digital Twin deployment** is modeled using **Model-Based Systems Engineering (MBSE)** frameworks (e.g., SysML, ADLs) to support heterogeneous stakeholders and perspectives. Key infrastructure aspects include:
- **Hosting Platforms**: Not explicitly named, but implied to support **cloud/edge/on-premise** deployments (e.g., AWS, Azure, or custom edge nodes) to balance computational needs and latency.
- **Computational Requirements**: Not specified; however, **MBSE tools** (e.g., SysML, Simulink) require **high-performance CPUs/GPUs** for parallel processing of multi-layered models (e.g., requirements → simulation).
- **Storage Requirements**: Not detailed; assumed to include **distributed databases** (e.g., NoSQL, relational) for storing aggregated data traces (e.g., UML class diagrams in **Fig. 1**) and historical context.
- **Scalability Mechanisms**: Implied via **modular ADLs** (e.g., MontiArc, SysML IBDs) that allow dynamic component composition and expansion (e.g., adding new sensors or logic layers).
- **Availability/Reliability Assurance**: Not explicitly quantified; however, **MBSE methodologies** (e.g., RFLP, OOSEM) emphasize **reliability validation** through rigorous testing (e.g., simulation-based validation) to ensure DTs meet operational SLAs.
"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "
  **Not explicitly detailed in the provided documents**, but inferred from industry practices:
  - **Industry Standards**:
    - **Modeling Languages**: SysML (ISO/IEC 19450), AADL (IEEE 15288), MontiArc, and ACME are referenced but no specific compliance frameworks are mentioned.
    - **Digital Twin Standards**: Not cited; emerging standards (e.g., IEEE 20000.10 for DTs) are likely absent here.
  - **Certification Requirements**: Not addressed; MBSE tools may have internal validation processes but no external certifications are referenced.
  - **Interoperability Standards**: Not detailed; however, MBSE methodologies (e.g., RFLP) emphasize heterogeneous stakeholder integration, suggesting potential adoption of standards like **OMG’s Model Driven Architecture (MDA)** or **IEC 62264** for industrial systems.
  - **Compliance Frameworks**: Not mentioned; likely tied to sector-specific regulations (e.g., aerospace/aeronautics via AADL) or industry consortia (e.g., Digital Twin Alliance).
"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "
The Digital Twin system leverages **Asset Administration Shell (AAS)** as a foundational architecture (as referenced in [Document 50](https://www.plattform-i40.de/IP/Redaktion/EN/Downloads/Publikation/Details_of_the_Asset_Administration_Shell_Part1_V2.html)), which integrates **semantic asset modeling** (as described in [Document 46](S. R. Bader and M. Maleshkova, *The semantic asset administration shell*) and [Document 47](K. Wei et al., *A review of asset administration shell*)). This ensures standardized data representation and interoperability across layers of the **Industrie 4.0 automation pyramid** ([Document 42](M. Heithoff et al., *Application of Digital Shadows on Different Levels in the Automation Pyramid*)), enabling secure and compliant data exchange.

For **security and safety**, the system incorporates:
- **Cybersecurity protocols** via **MQTT protocol** (as implemented in *Mosquitto* [Document 52](R. A. Light, *Mosquitto: server and client implementation of the mqtt protocol*)), a lightweight, efficient messaging standard for IoT devices, ensuring real-time communication while mitigating potential threats.
- **Access control mechanisms** through **semantic-based authentication** (enforced via **Asset Administration Shell’s semantic layers**, as detailed in [Document 50](Platform Industrie 4.0, *Details of the Asset Administration Shell*)), ensuring only authorized entities interact with critical data.
- **Fail-safe mechanisms** tied to **RAMI 4.0** ([Document 48](J. Frysak et al., *Benefits and pitfalls applying RAMI4.0*) and [Document 49](DIN, *Reference architecture model industrie 4.0*)), which defines a structured framework for integrating safety-critical systems into the digital twin lifecycle, ensuring compliance with **Industrie 4.0 safety standards**.
- **Threat mitigation strategies** via **model-driven engineering (MDE)** ([Document 43](M. Heithoff et al., *A Method for Model-Driven Engineering of Digital Twins in Manufacturing*)), where simulation models (e.g., **Functional Mockup Interface (FMI)** [Document 51](T. Blochwitz et al., *The functional mockup interface for tool-independent exchange of simulation models*)), are rigorously validated to prevent cyber-physical system failures.
- **Safety-critical system considerations** are addressed through **friction modeling** (as described in [Document 45](M. Trinh et al., *Friction modeling for structured learning of robot dynamics*)), particularly for robotic components like the **MABI Max-100 robotic arm** ([Document 44](MABI, *Mabi robot*)), ensuring dynamic adaptability and resilience in real-world operations.
"
]