// Sensing Component
instance ProcessSensor : DTDFVocab:SensingComponent [
    base:desc "Continuous sensor providing time-series data streamed over MQTT."
    DTDFVocab:producedData MqttDataTransmission
]

// Data Transmission
instance MqttDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProcessSensor
]

// Data Instance
instance NumericMeasurementsData : DTDFVocab:Data [
    base:desc "Numeric temperature and other measurement data captured by the on-board sensor."
    DTDFVocab:fromData MqttDataTransmission
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

// Models (MBSE stack)
instance FunctionalSysMLModel : DTDFVocab:Model [
    base:desc "Functional architecture captured in SysML using requirement, block, and interface block diagrams."
    DTDFVocab:inputTo OOSEMMethodEnabler
]

instance PhysicalSysMLModel : DTDFVocab:Model [
    base:desc "Physical modeling captured in SysML using block diagrams."
    DTDFVocab:inputTo RFLPMethodEnabler
]

instance OptimizationSysMLModel : DTDFVocab:Model [
    base:desc "Optimization modeling captured in SysML using block diagrams."
    DTDFVocab:inputTo SMArDTMethodEnabler
]

instance PerformanceSysMLModel : DTDFVocab:Model [
    base:desc "Performance modeling captured in SysML using block diagrams."
    DTDFVocab:inputTo SPESMethodEnabler
]

instance SimulationModelSimulinkModel : DTDFVocab:Model [
    base:desc "Continuous-time simulation model in MathWorks Simulink."
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

// Enablers
instance OOSEMMethodEnabler : DTDFVocab:Enabler [
    base:desc "Utilizes the Object-Oriented Systems Engineering (OOSEM) method for modeling."
    DTDFVocab:enables CodeGenerationService
]

instance RFLPMethodEnabler : DTDFVocab:Enabler [
    base:desc "Employs Rapid, Functional, Lightweight, and Predictable (RFLP) engineering method."
    DTDFVocab:enables CodeGenerationService
]

instance SMArDTMethodEnabler : DTDFVocab:Enabler [
    base:desc "Applies SMArDT (Smart Modular Advanced Real-Time Digital Twin) engineering method."
    DTDFVocab:enables CodeGenerationService
]

instance SPESMethodEnabler : DTDFVocab:Enabler [
    base:desc "Uses SPES (System Process Engineering System) method for performance engineering."
    DTDFVocab:enables CodeGenerationService
]

instance SimulinkRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Executes Simulink model with real-time numeric measurement data."
    DTDFVocab:inputTo SimulationModelSimulinkModel, NumericMeasurementsData
    DTDFVocab:enables RealTimeSimulationService
]

// Services
instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Generates executable C++ or Java code from SysML models."
    DTDFVocab:provides CodeGenerationInsight
]

instance RealTimeSimulationService : DTDFVocab:Service [
    base:desc "Runs real-time simulation of the digital twin using Simulink."
    DTDFVocab:provides RealTimeSimulationInsight
]

// Insights
instance CodeGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful generation of C++ or Java code from models."
]

instance RealTimeSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight into real-time simulation results from the digital twin."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is defined as a purely passive, one‑way data consumer; therefore it does not issue command messages back to the physical robot. Consequently there is no virtual to physical control flow, no command format or authentication mechanism, and no feedback or conflict‑resolution protocols are defined."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration of the Digital Twin system follows a Model‑Based Systems Engineering (MBSE) approach that spans multiple abstraction levels—requirements, functional, logical, and product/technical. System architecture is captured through component‑and‑connector models using ADLs such as ACME, AADL, MontiArc or SysML IBDs, which describe the composition and interfaces of system elements. Behaviour is specified either via SysML state machines (v1.7) or MontiArc automata, and is co‑simulated with domain‑specific tools such as MathWorks Simulink or other simulation environments. Integration between the different models is achieved through tool‑specific transformations and co‑simulation setups, allowing each component’s behaviour model, data flow, and control logic to be reconciled within a unified simulation environment."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the Model-Based Systems Engineering (MBSE) abstraction hierarchy, progressing through (1) Requirements – where system purpose and constraints are captured; (2) Functional Architecture – represented in SysML activity or block definition diagrams; (3) Logical Architecture – modelled with Architecture Description Languages (ADLs) such as ACME, AADL, MontiArc, capturing component interfaces and connector relationships; and (4) Product/Technical Layer – translated into executable artefacts (e.g., C++/Java code or Simulink models). Transitions between stages are handled by mappings between modelling notations, while governance relies on MBSE standards and model versioning practices."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data ingestion requires MQTT acting over a TCP/IP network. The architecture presumes an MQTT broker mediating connections between physical sensors and the twin. No further details on bandwidth, topology or redundancy are given."
]