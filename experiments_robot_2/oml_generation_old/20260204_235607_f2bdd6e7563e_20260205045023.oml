// Sensing component that receives raw sensor data from the physical environment
instance ActiveSensorDataReceiver : DTDFVocab:SensingComponent [
    base:desc "Component that receives incoming sensor data from external sources for processing by the Digital Twin."
]

// Data transmitted by the sensor receiving component
instance IncomingSensorDataTransmission : DTDFVocab:DataTransmitted [
    base:desc "Transmission of raw sensor data received by ActiveSensorDataReceiver."
    DTDFVocab:producedFrom ActiveSensorDataReceiver
]

// Raw sensor data captured by the Digital Twin
instance RawSensorData : DTDFVocab:Data [
    base:desc "Raw sensor data captured from the physical environment, used as input for behavior models and analytics."
    DTDFVocab:fromData IncomingSensorDataTransmission
]

// Enablers embodying various MBSE methodologies
instance RFLPEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that implements RFLP (Requirements, Functions, Logics, Physics) methodology to manage model layers."
    DTDFVocab:enables RealTimeAnalyticsService
]
instance OOSEMEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that applies OOSEM methodology for object-oriented systems engineering."
    DTDFVocab:enables RealTimeAnalyticsService
]
instance SPESEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that implements SPES methodology."
    DTDFVocab:enables RealTimeAnalyticsService
]
instance SMArDTEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that utilizes SMArDT methodology for integrated model-based design."
    DTDFVocab:enables RealTimeAnalyticsService
]

// Service that processes sensor data using state-machine or automata behavior models
instance RealTimeAnalyticsService : DTDFVocab:Service [
    base:desc "Service that processes incoming sensor data using state-machine or automata behavior models to infer system state, detect anomalies, and recommend corrective actions in real-time."
    DTDFVocab:provides AnomalyDetectionInsight, RecommendCorrectiveAction
]

// Insight indicating anomaly detection
instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating detection of anomalies in system behavior based on state-machine analysis."
]

// Action recommending corrective measures upon anomaly detection
instance RecommendCorrectiveAction : DTDFVocab:Action [
    base:desc "Action representing recommendation of corrective measures upon anomaly detection."
    DTDFVocab:IsAutomatic true
]

// Models representing the system architecture across different description languages
instance SysMLModel : DTDFVocab:Model [
    base:desc "System structure and architecture defined using SysML for requirements, functional, logical, and product layers."
    DTDFVocab:inputTo RFLPEnabler, OOSEMEnabler, SPESEnabler, SMArDTEnabler
]
instance MontiArcModel : DTDFVocab:Model [
    base:desc "Architecture defined using MontiArc, including automaton/state-machine extensions."
    DTDFVocab:inputTo RFLPEnabler, OOSEMEnabler, SPESEnabler, SMArDTEnabler
]
instance ACMEModel : DTDFVocab:Model [
    base:desc "System architecture described using ACME."
    DTDFVocab:inputTo RFLPEnabler, OOSEMEnabler, SPESEnabler, SMArDTEnabler
]
instance AADLModel : DTDFVocab:Model [
    base:desc "Architecture described using AADL."
    DTDFVocab:inputTo RFLPEnabler, OOSEMEnabler, SPESEnabler, SMArDTEnabler
]
instance SimulinkModel : DTDFVocab:Model [
    base:desc "Simulation and verification done with Simulink models, combined with MontiArc Automaton state machines."
    DTDFVocab:inputTo RFLPEnabler, OOSEMEnabler, SPESEnabler, SMArDTEnabler
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the MBSE abstraction hierarchy: beginning with the requirements level, proceeding through functional architecture, logical architecture, and culminating in the product/technical layer representation. Transition management between phases is facilitated by parallel conceptual models, such as RFLP, which help map requirements to physics‑based representations. Governance of the lifecycle is anchored by the use of SysML for modeling, with validation at each level via state machine automata or MontiArc automaton models. Additionally, the digital twin evolves from the passive digital shadow (one‑way data flow) to an active simulation or decision support tool through intentional transition management steps."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The document does not reference any specific industry standards, certifications, compliance frameworks, or interoperability standards applicable to the Digital Twin or Digital Shadow. Consequently, no standardization information is available."
]