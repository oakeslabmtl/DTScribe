// C3: Physical sensing components
instance Axis1ServoMotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor on the servo motor of Axis 1 of the MABI MAX 100 robot"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance Axis1GearboxTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Torque sensor on the gearbox of Axis 1 of the MABI MAX 100 robot"
    DTDFVocab:producedData TorqueDataTransmitted
]

instance Axis1EncoderVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Angular‑velocity sensor on the encoder of Axis 1 of the MABI MAX 100 robot"
    DTDFVocab:producedData VelocityDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmitted)
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Axis1ServoMotorCurrentSensor
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Axis1GearboxTorqueSensor
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom Axis1EncoderVelocitySensor
]

// C10: Data (raw time‑series)
instance CurrentTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of input current measured from Axis 1 servo motor (MQTT, Mosquitto broker)"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo DataPreprocessingEnabler
]

instance TorqueTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of torque measured from Axis 1 gearbox (MQTT, Mosquitto broker)"
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo DataPreprocessingEnabler
]

instance VelocityTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of angular velocity measured from Axis 1 encoder (MQTT, Mosquitto broker)"
    DTDFVocab:fromData VelocityDataTransmitted
    DTDFVocab:inputTo DataPreprocessingEnabler
]

// C10: Models / Data (computational artifacts)
instance SysMLRobotStructureModel : DTDFVocab:Model [
    base:desc "SysML internal‑block diagram that captures the structural hierarchy of the MABI MAX 100 robot"
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance SimulinkRobotDynamicsModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model providing a physics‑based white‑box simulation of robot dynamics"
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance HybridBlackBoxModel : DTDFVocab:Model [
    base:desc "Black‑box data‑driven component (e.g., C++/Java) that augments the physics model with empirical behavior"
    DTDFVocab:inputTo ProcessingEngineEnabler
]

// C11: Enablers (tools & infrastructure)
instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Mosquitto MQTT broker used for one‑way data flow from physical sensors to the digital shadow"
    DTDFVocab:enables RealTimeMonitoringService
]

instance DataPreprocessingEnabler : DTDFVocab:Enabler [
    base:desc "Active software component that validates, aggregates and abstracts incoming MQTT time‑series"
    DTDFVocab:enables RealTimeMonitoringService, FeedbackControlService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Execution engine that runs SysML‑derived transformations and Simulink simulations"
    DTDFVocab:enables RealTimeMonitoringService, FeedbackControlService
]

instance ProcessingEngineEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that consumes input traces, applies engineering/simulation models, and emits derived output traces"
    DTDFVocab:enables DecisionSupportPredictionService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of the physical state of the robot using ingested sensor traces"
    DTDFVocab:provides PerformanceMetricInsight, AnomalyIndicatorInsight
]

instance FeedbackControlService : DTDFVocab:Service [
    base:desc "Executes feedback control actions on the robot based on processed sensor data and model predictions"
    DTDFVocab:provides FeedbackControlAction
]

instance DecisionSupportPredictionService : DTDFVocab:Service [
    base:desc "Generates decision‑support predictions such as optimization recommendations for operators"
    DTDFVocab:provides OptimizationRecommendationInsight, FeedbackControlAction
]

// C17: Insights
instance PerformanceMetricInsight : DTDFVocab:Insight [
    base:desc "Derived performance metrics (e.g., positioning accuracy, cycle time) computed from processed traces"
]

instance AnomalyIndicatorInsight : DTDFVocab:Insight [
    base:desc "Anomaly indicators that flag deviations from expected behavior based on provenance‑linked data"
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendations (e.g., trajectory smoothing, torque reduction) produced by the processing component"
]

// C17: Actions
instance FeedbackControlAction : DTDFVocab:Action [
    base:desc "Automatic feedback control command sent to the Siemens SINUMERIK 840D sl controller"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components (optional representation of the physical robot)
instance MabiMax100Robot : DTDFVocab:ActingComponent [
    base:desc "Serial industrial robot MABI MAX 100 with six rotational axes controlled by a Siemens SINUMERIK 840D sl controller"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through traceability and verification of model transformations, notably from SysML specifications to executable Simulink simulations. The reliability of the Digital Twin depends on the correctness of both the underlying models and the data integration steps. Verification activities include checking consistency of model abstractions across abstraction layers and confirming that transformations preserve intended semantics. The approach emphasizes the need to combine complementary white‑box and black‑box models to improve overall accuracy, while maintaining documentation of model provenance to support validation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on MQTT (Message Queuing Telemetry Transport) over standard IP networks. Physical sensors act as MQTT publishers, sending time‑series sensor data to an MQTT broker (Mosquitto) that serves as the communication hub. The network topology follows a typical star arrangement where edge devices connect directly to the broker. MQTT provides lightweight messaging suitable for low‑bandwidth, low‑latency transmission; however, explicit bandwidth, latency or redundancy specifications are not detailed in the documents. Security mechanisms such as TLS for MQTT are not described in the source material."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin is modelled with SysML, the OMG‑defined systems‑engineering modelling language, and its structure follows the Digital Shadow Reference Model, which enforces a formal conformance relation between a concrete class diagram and the reference diagram as described in [41]. Architectural descriptions may also employ standardized ADLs such as ACME, AADL or MontiArc, providing a component‑connector view that is consistent with established industry modelling standards."
]