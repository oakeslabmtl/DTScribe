// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that provides the motor input current I_M"
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder sensor measuring motor shaft angular position"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Encoder sensor measuring gearbox output angular position"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// C10: Data instances
instance InputCurrentData : DTDFVocab:Data [
    base:desc "Raw motor input current I_M streamed via MQTT"
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler
]

instance MotorEncoderAngleData : DTDFVocab:Data [
    base:desc "Angular position from motor encoder"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler
]

instance GearboxEncoderAngleData : DTDFVocab:Data [
    base:desc "Angular position from gearbox encoder"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Torque τ derived from encoder positions"
    DTDFVocab:inputTo SimulinkEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity ω derived from encoder positions"
    DTDFVocab:inputTo SimulinkEnabler
]

instance AngularAccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration derived from encoder positions"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulatedTorqueData : DTDFVocab:Data [
    base:desc "Torque simulated by Simulink friction models"
    DTDFVocab:inputTo DashboardEnabler
]

instance SimulatedVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity simulated by Simulink friction models"
    DTDFVocab:inputTo DashboardEnabler
]

// C11: Enablers
instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker used for publishing live sensor streams"
    DTDFVocab:enables DataIngestionService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for executing motor, gearbox and friction models"
    DTDFVocab:enables FrictionIdentificationService, DataComparisonService
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML tool used for structural and behavioral modeling of the axis"
    DTDFVocab:enables StructuralModelService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Custom dashboard application for visualization of real‑time identification results"
    DTDFVocab:enables DashboardVisualizationService
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction parameters"
    DTDFVocab:provides FrictionParameterInsight, UpdateControlAlgorithmAction
]

instance DataComparisonService : DTDFVocab:Service [
    base:desc "Comparison of measured torque/velocity with Simulink simulated results"
    DTDFVocab:provides MotionAccuracyInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Visualization of measured vs simulated data and identified friction parameters"
    DTDFVocab:provides RealTimeFrictionIdentificationInsight
]

instance StructuralModelService : DTDFVocab:Service [
    base:desc "Provision of SysML block‑definition and internal‑block diagrams for the axis"
    DTDFVocab:provides AxisStructureInsight
]

instance DataIngestionService : DTDFVocab:Service [
    base:desc "Ingests live MQTT streams into the digital shadow"
    DTDFVocab:provides DataIngestionInsight
]

// C17: Insights / Actions
instance FrictionParameterInsight : DTDFVocab:Insight [
    base:desc "Identified friction parameters (static, kinetic, viscous) derived from sensor data"
]

instance UpdateControlAlgorithmAction : DTDFVocab:Action [
    base:desc "Feeds back identified friction parameters to the robot controller to adapt model‑based control"
    DTDFVocab:IsAutomatic true
]

instance MotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Improved motion accuracy obtained by comparing measured and simulated torque/velocity"
]

instance RealTimeFrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Provides operators with live friction identification results for decision making"
]

instance AxisStructureInsight : DTDFVocab:Insight [
    base:desc "Structural and behavioral representation of the first axis of MABI MAX 100"
]

instance DataIngestionInsight : DTDFVocab:Insight [
    base:desc "Successful ingestion of live MQTT sensor streams into the digital twin"
]

// C2: Acting Components (none – the DT is passive; no acting components are modeled)

// C10: Engineering / Simulation Models
instance AxisSysMLModel : DTDFVocab:Model [
    base:desc "SysML block‑definition and internal‑block diagrams of the first robot axis"
    DTDFVocab:inputTo SysMLEnabler
]

instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the permanent‑magnet synchronous motor"
    DTDFVocab:inputTo SimulinkEnabler
]

instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the cycloidal gearbox and gear transmission"
    DTDFVocab:inputTo SimulinkEnabler
]

instance FrictionSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink friction models (Coulomb‑Viscous, Stribeck, Dahl, LuGre)"
    DTDFVocab:inputTo SimulinkEnabler
]

// C10: Asset Administration Shell (AAS) Enabler
instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell used for model integration and semantic interoperability"
    DTDFVocab:enables ModelIntegrationService
]

instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Integrates SysML and Simulink models into the digital twin via AAS"
    DTDFVocab:provides ModelIntegrationInsight
]

instance ModelIntegrationInsight : DTDFVocab:Insight [
    base:desc "Successful integration of engineering models into the digital shadow using AAS"
]

// Instance representing the digital shadow (aggregation)
instance FrictionShadow : DTDFVocab:Component [
    base:desc "Passive digital shadow instance aggregating data traces and processing components for the first axis"
    base:contains InputCurrentSensor, MotorEncoderSensor, GearboxEncoderSensor,
                 InputCurrentData, MotorEncoderAngleData, GearboxEncoderAngleData,
                 DerivedTorqueData, AngularVelocityData, AngularAccelerationData,
                 SimulatedTorqueData, SimulatedVelocityData,
                 AxisSysMLModel, MotorSimulinkModel, GearboxSimulinkModel, FrictionSimulinkModel,
                 FrictionIdentificationService, DataComparisonService, DashboardVisualizationService,
                 MQTTEnabler, SimulinkEnabler, SysMLEnabler, DashboardEnabler, AASEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "No data or commands are sent from the digital shadow back to the robot; the digital shadow functions as a one‑way passive entity."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time acquisition and processing during robot operation; the digital shadow updates friction estimates continuously as new sensor data arrive."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow follows the Digital Shadow Reference Model: it comprises a Purpose (FrictionDerivation), an Asset (MABI axis), multiple DataTraces, Sources, Processing components (simulation models), and Models (engineering, simulation, data‑calculation) linked together to form the FrictionShadow instance."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the design stage (engineering SysML model, simulation models) and the operational stage (run‑time data collection and friction monitoring) of the robot."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability is maintained by linking each data point to its source and processing model. Friction estimates are validated by comparing simulated friction‑less behavior with measured data; continuous multi‑physics‑aware identification ensures model fidelity over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow using the MQTT messaging protocol."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach leverages the Asset Administration Shell (AAS) standard and uses SysML as a standardized modelling language; the Digital Shadow Reference Model provides a standardized conceptual framework."
]