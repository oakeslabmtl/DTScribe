// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring the input current I_M, streamed via MQTT"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor, providing motor shaft angle"
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder located behind the gearbox, providing gearbox output angle"
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorEncoder
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance AccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

// C10: Data objects
instance CurrentData : DTDFVocab:Data [
    base:desc "Live stream of measured motor current I_M"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

instance MotorAngleData : DTDFVocab:Data [
    base:desc "Live stream of motor shaft angle from the motor encoder"
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Live stream of gearbox output angle from the secondary encoder"
    DTDFVocab:fromData GearboxAngleDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque trace τ calculated from current and angle"
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω trace from encoder angle"
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration trace from encoder angle"
    DTDFVocab:fromData AccelerationDataTransmitted
    DTDFVocab:inputTo DashboardEnabler
]

// C11: Enablers
instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard that consumes data streams and visualizes measured vs simulated traces"
    DTDFVocab:enables RealTimeDashboardService, FrictionIdentificationService, TraceComparisonService, FrictionParameterGenerationService
]

instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker enabling real‑time one‑way data flow from robot sensors to the digital shadow"
]

instance SimulinkRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for running the motor, gearwheel and gearbox simulation models"
]

instance AASIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell integration layer for exposing engineering models to the digital twin ecosystem"
]

// C10: Models / Data calculation components
instance AxisStructuralModel : DTDFVocab:Model [
    base:desc "SysML Block Definition and Internal Block Diagram describing the structural composition of the first robot axis"
    DTDFVocab:inputTo AASIntegrationEnabler
]

instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Executable Simulink model of the permanent‑magnet synchronous motor"
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

instance GearwheelSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of the gearwheel gearbox (frictionless version)"
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

instance GearboxSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of the cycloidal gearbox with selectable friction models"
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Simulink implementation of a Coulomb‑Viscous friction model for the gearbox"
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Simulink implementation of a Stribeck friction model for the gearbox"
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Simulink implementation of a Dahl friction model for the gearbox"
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "Simulink implementation of a LuGre friction model for the gearbox"
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

instance TorqueCalculationModel : DTDFVocab:Model [
    base:desc "Processing component that calculates torque τ from measured current I_M and motor angle"
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

instance VelocityCalculationModel : DTDFVocab:Model [
    base:desc "Processing component that derives angular velocity ω from encoder angle data"
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

instance AccelerationCalculationModel : DTDFVocab:Model [
    base:desc "Processing component that derives angular acceleration from encoder angle data"
    DTDFVocab:inputTo SimulinkRuntimeEnabler
]

// C6: Services
instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Real‑time visualization of measured and simulated data on a web dashboard"
    DTDFVocab:provides DashboardVisualizationInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of static, kinetic and viscous friction parameters within the gearbox"
    DTDFVocab:provides FrictionTrendInsight
]

instance TraceComparisonService : DTDFVocab:Service [
    base:desc "Comparison of simulated versus measured torque and velocity traces"
    DTDFVocab:provides ModelMeasurementDeviationInsight
]

instance FrictionParameterGenerationService : DTDFVocab:Service [
    base:desc "Generation of friction parameters used to adjust the robot controller for higher motion accuracy"
    DTDFVocab:provides AdjustRobotControllerAction
]

// C17: Insights
instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Operator can monitor live measured and simulated traces via the dashboard"
]

instance FrictionTrendInsight : DTDFVocab:Insight [
    base:desc "Insight into static, kinetic and viscous friction trends over time"
]

instance ModelMeasurementDeviationInsight : DTDFVocab:Insight [
    base:desc "Insight into deviations between simulated and measured torque/velocity traces"
]

// C17: Actions
instance AdjustRobotControllerAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of robot controller parameters using identified friction values"
    DTDFVocab:IsAutomatic true
]

// C14: Environment and Component
instance FirstAxisComponent : DTDFVocab:Component [
    base:desc "First axis of the MABI MAX 100 industrial robot, comprising a permanent‑magnet synchronous motor, a gearwheel gearbox and a cycloidal gearbox"
]

instance RobotOperatingEnvironment : DTDFVocab:Environment [
    base:contains FirstAxisComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is passive; no data or commands are sent from the virtual model back to the robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time operation synchronized with the robot’s motion; data are acquired and processed at the robot’s sampling rate (implicitly tied to the live MQTT feed) to enable on‑line friction identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A digital shadow composed of (1) the physical asset (first robot axis), (2) engineering models (SysML), (3) simulation models (Simulink), (4) processing components that consume measured data traces and produce simulated traces, (5) data storage for DataTraces, and (6) a visualization dashboard, all linked through the Digital Shadow Reference Model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each DataTrace back to its source and processing component ensures model fidelity; validation is performed by comparing simulated friction‑compensated outputs with measured reference data to assess accuracy of white‑box and black‑box friction models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Live data are transmitted from the robot to the digital shadow over MQTT; the Asset Administration Shell (AAS) provides semantic linking of data and models."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) as a standard for digital twin integration and SysML as a modeling standard; reference to IEC‑62304 is not made, but AAS and SysML are explicitly employed."
]