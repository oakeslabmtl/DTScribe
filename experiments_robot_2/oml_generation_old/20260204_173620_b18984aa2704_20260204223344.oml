// C3: Physical sensing component
instance ContextualDataSensor : DTDFVocab:SensingComponent [
    base:desc "Passive physical sensing component that collects contextual data traces from the asset for the digital shadow (one‑way automated flow)."
    DTDFVocab:producedData ContextualDataTransmitted
]

// C4: Physical-to-virtual interaction
instance ContextualDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContextualDataSensor
]

// C10: Data (aggregated)
instance AggregatedContextualData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces used as input for processing components that generate insights."
    DTDFVocab:fromData ContextualDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler, SimulationProcessingEnabler, MachineLearningProcessingEnabler
]

// C10: Models/Data
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML structural model captured in internal block diagrams representing the system architecture (MBSE)."
    DTDFVocab:inputTo DataAggregationEnabler
]

instance ADLArchitectureModel : DTDFVocab:Model [
    base:desc "Architecture model expressed in ADLs (e.g., ACME, AADL, MontiArc) describing component connectors and interfaces."
    DTDFVocab:inputTo DataAggregationEnabler
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based white‑box simulation model built in MathWorks Simulink for dynamic behavior."
    DTDFVocab:inputTo SimulationProcessingEnabler
]

instance MachineLearningFrictionModel : DTDFVocab:Model [
    base:desc "Data‑driven black‑box machine learning model representing nonlinear robot friction effects."
    DTDFVocab:inputTo MachineLearningProcessingEnabler
]

// C11: Enablers
instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that aggregates and abstracts incoming contextual data traces."
    DTDFVocab:enables InsightComputationService
]

instance SimulationProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that executes physics‑based simulation models (Simulink) to produce higher‑level data."
    DTDFVocab:enables InsightComputationService
]

instance MachineLearningProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that runs machine learning models for data‑driven inference."
    DTDFVocab:enables InsightComputationService
]

// C6: Services
instance InsightComputationService : DTDFVocab:Service [
    base:desc "Service that consumes processed data to compute performance indicators and predictive diagnostics."
    DTDFVocab:provides PerformanceIndicatorInsight, PredictiveDiagnosticInsight
]

// C17: Insights
instance PerformanceIndicatorInsight : DTDFVocab:Insight [
    base:desc "Higher‑level performance indicator derived from processed data."
]

instance PredictiveDiagnosticInsight : DTDFVocab:Insight [
    base:desc "Predictive diagnostic insight indicating future system states or failures."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the MBSE abstraction chain described in Document 1: (1) Requirements stage where stakeholder requirements are captured; (2) Functional architecture stage modeling functional blocks; (3) Logical architecture stage defining component‑connector structures using ADLs such as SysML internal block diagrams, ACME, AADL, MontiArc; (4) Product/technical stage where the concrete physical and software artifacts (e.g., generated code, Simulink models) are instantiated. Transitions between stages are governed by the conformance relation of the Digital Shadow Reference Model (Document 2), which maps concrete elements to the reference concepts and ensures traceability of data traces across stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and validity are addressed through traceability and verification of model transformations (e.g., from SysML to simulation models). The reliability of the digital shadow – and consequently the Digital Twin – depends on the correctness of its underlying models and data pipelines. Verification methods aim to ensure correctness of transformations, while validation involves comparing model predictions against observed data. Sources of uncertainty include modeling errors and data acquisition inaccuracies; the documents stress the importance of quantifying these uncertainties but do not provide specific measurement techniques."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The documents cite the MQTT protocol (implemented by Mosquitto) and the open‑source ThingsBoard IoT platform as communication technologies for linking physical devices with their digital representations. MQTT provides lightweight publish/subscribe messaging over TCP/IP, and ThingsBoard can serve as a broker and data management layer. No explicit network topology, bandwidth, latency, redundancy, or security protocol details are provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "One reference mentions the use of cloud‑based technologies for deploying a CNC‑machine digital shadow (Martinov et al., 2023), implying that the digital twin can be hosted on cloud infrastructure. However, the documents do not specify concrete hosting platforms, computational or storage requirements, scalability mechanisms, deployment models, or availability/reliability assurances."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin implementation adheres to the reference‑model‑based standardization approach described in Document 2. The reference model defines domain concepts and a conformance relation that must be satisfied by any concrete Digital Twin model. Conformance is expressed through explicit mappings of concrete classes and associations to the reference class diagram, ensuring interoperability with other twins that follow the same reference model. No external industry standards are cited in the provided documents."
]