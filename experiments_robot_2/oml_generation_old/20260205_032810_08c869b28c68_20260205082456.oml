// C3: Physical sensing components
instance ManufacturingProcessSensor : DTDFVocab:SensingComponent [
    base:desc "Collects operational parameters from manufacturing processes including production line metrics, asset health indicators, and environmental conditions in real-time or near-real-time environments."
    DTDFVocab:producedData ManufacturingProcessDataTransmitted
]

instance AssetHealthSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors critical asset health parameters such as vibration, temperature, and wear indicators for predictive maintenance purposes."
    DTDFVocab:producedData AssetHealthDataTransmitted
]

instance ProductionLineControllerSensor : DTDFVocab:SensingComponent [
    base:desc "Tracks control system parameters, execution status, and resource allocation metrics from production line controllers."
    DTDFVocab:producedData ProductionLineControllerDataTransmitted
]

// C4: Physical-to-virtual interaction
instance ManufacturingProcessDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ManufacturingProcessSensor
]

instance AssetHealthDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AssetHealthSensor
]

instance ProductionLineControllerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProductionLineControllerSensor
]

// C10: Models/Data
instance SysMLInternalBlockDiagramModel : DTDFVocab:Model [
    base:desc "Defines system structure using SysML Internal Block Diagrams (IBDs) capturing components, interfaces, interconnections, and composition across requirements, functional, and logical layers."
    DTDFVocab:inputTo SysMLToolEnabler
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "Component-based architecture model using MontiArc ADL with automaton-based behavior definitions for dynamic system behavior."
    DTDFVocab:inputTo MontiArcToolEnabler
]

instance SimulinkBehavioralModel : DTDFVocab:Model [
    base:desc "Dynamic system simulation model created using MathWorks Simulink for control systems, signal processing, and behavioral validation."
    DTDFVocab:inputTo SimulinkToolEnabler
]

instance DigitalShadowDataTrace : DTDFVocab:Data [
    base:desc "Aggregated and abstracted data traces from physical twin representing contextual operational data for purpose-specific analysis."
    DTDFVocab:fromData ManufacturingProcessDataTransmitted, AssetHealthDataTransmitted, ProductionLineControllerDataTransmitted
    DTDFVocab:inputTo DigitalShadowFrameworkEnabler
]

instance ManufacturingKpiData : DTDFVocab:Data [
    base:desc "Processed manufacturing key performance indicators derived from raw operational data traces for performance monitoring."
    DTDFVocab:fromData ManufacturingProcessDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance AssetHealthMetrics : DTDFVocab:Data [
    base:desc "Processed asset health metrics including predictive maintenance indicators derived from sensor data."
    DTDFVocab:fromData AssetHealthDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

// C11: Enablers
instance SysMLToolEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling toolchain enabling multi-layered system architecture modeling including requirements, functional, and logical architecture definitions."
    DTDFVocab:enables MonitoringService, BehavioralSimulationService, MultiPerspectiveAnalysisService
]

instance MontiArcToolEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc architecture description language and toolchain supporting component-based modeling with automaton behavior and code generation."
    DTDFVocab:enables BehavioralSimulationService, OptimizationService
]

instance SimulinkToolEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation environment for dynamic system behavior modeling and validation."
    DTDFVocab:enables BehavioralSimulationService, ScenarioValidationService
]

instance DigitalShadowFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Digital Shadow framework implementing one-way data ingestion from physical twin with aggregation and abstraction capabilities."
    DTDFVocab:enables MonitoringService, DataAggregationService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Data processing pipeline using general-purpose languages (C++, Java) for contextual data trace interpretation and feature extraction."
    DTDFVocab:enables PredictionAnalysisService, OptimizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Passive data acquisition service tracking system state, performance, and operational parameters through digital shadow integration."
    DTDFVocab:provides SystemStateInsight, PerformanceTrackingInsight
]

instance BehavioralSimulationService : DTDFVocab:Service [
    base:desc "Service leveraging state machines (SysML v1.7) and MontiArc Automaton to model and predict system behavior under varying conditions."
    DTDFVocab:provides BehaviorPredictionInsight, FailureModeAnalysisInsight
]

instance PredictionAnalysisService : DTDFVocab:Service [
    base:desc "Service processing aggregated data traces to derive predictive insights including anomaly detection and trend analysis."
    DTDFVocab:provides AnomalyDetectionInsight, TrendAnalysisInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service combining functional/logical architecture models with physical layer data to identify inefficiencies and suggest process adjustments."
    DTDFVocab:provides ProcessOptimizationInsight, ResourceAllocationInsight
]

instance ScenarioValidationService : DTDFVocab:Service [
    base:desc "Service using Simulink for validating scenarios including failure modes and optimization paths through dynamic system simulation."
    DTDFVocab:provides ScenarioValidationInsight
]

instance MultiPerspectiveAnalysisService : DTDFVocab:Service [
    base:desc "Service providing multi-notation rendering of data through SysML diagrams, Simulink models, and code-based visualizations for heterogeneous stakeholders."
    DTDFVocab:provides VisualizationInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Service processing raw data traces into abstracted, purpose-specific datasets for analysis."
    DTDFVocab:provides AggregatedDataInsight
]

// C17: Insights/Actions
instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Real-time or near-real-time system state tracking derived from digital shadow data."
]

instance PerformanceTrackingInsight : DTDFVocab:Insight [
    base:desc "Continuous performance monitoring metrics including KPIs and operational efficiency indicators."
]

instance BehaviorPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted system behavior under various operational conditions using state machine models."
]

instance FailureModeAnalysisInsight : DTDFVocab:Insight [
    base:desc "Identified potential failure modes and their impact on system operation."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Detected anomalies in operational data traces indicating potential issues."
]

instance TrendAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analyzed trends in operational data to identify patterns and long-term system behavior."
]

instance ProcessOptimizationInsight : DTDFVocab:Insight [
    base:desc "Identified process optimization opportunities through multi-layered analysis."
]

instance ResourceAllocationInsight : DTDFVocab:Insight [
    base:desc "Optimized resource allocation recommendations based on current and predicted system states."
]

instance ScenarioValidationInsight : DTDFVocab:Insight [
    base:desc "Validated scenarios including failure modes and optimization paths through simulation."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Multi-notation visual representations of system data for different stakeholder perspectives."
]

instance AggregatedDataInsight : DTDFVocab:Insight [
    base:desc "Processed and abstracted data traces ready for purpose-specific analysis."
]

instance TriggerOptimizationAction : DTDFVocab:Action [
    base:desc "Automatically triggers process adjustments based on optimization insights."
    DTDFVocab:IsAutomatic true
]

instance GenerateReportAction : DTDFVocab:Action [
    base:desc "Generates comprehensive reports for operators and managers based on aggregated insights."
    DTDFVocab:IsAutomatic false
]

instance UpdateSimulationModelAction : DTDFVocab:Action [
    base:desc "Updates simulation models with new operational data for continuous validation."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system’s orchestration and coordination are grounded in **Model-Based Systems Engineering (MBSE)** methodologies, leveraging **architecture description languages (ADLs)** such as ACME, AADL, MontiArc, or SysML IBDs to define component integration, interfaces, and composition. The system employs a **component & connector perspective**, where components represent discrete functional or physical entities, and connectors define their interactions. Behavioral descriptions may be augmented using tools like **MontiArc Automaton** or **SysML state machines**, while detailed dynamic behavior is modeled via **simulation tools (e.g., MathWorks Simulink)** or general-purpose languages (C++, Java). Resource management is implied through the integration of heterogeneous modeling notations and tools, requiring middleware or integration frameworks to ensure interoperability. The document does not specify explicit orchestration patterns (e.g., microservices, service-oriented architecture) but emphasizes the need to handle **complexity through abstraction layers** (requirements, functions, logics, physics) and **stakeholder-specific perspectives**, suggesting a **modular, federated architecture** where coordination is managed via ADL-defined interfaces and simulation/analysis tools."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **fidelity and validity considerations** through structured **validation and verification (V&V) methods** aligned with MBSE practices. Key aspects include:
  - **Model fidelity requirements**: Ensuring computational models (e.g., SysML, ADLs, or simulation tools) accurately represent the **physical system’s behavior and structure** across abstraction layers (requirements → functional → logical → technical).
  - **Uncertainty quantification**: Sources of uncertainty may arise from **data abstraction gaps, sensor inaccuracies, or model simplifications**, requiring systematic **error detection and correction mechanisms** (e.g., via simulation tool validation or cross-tool consistency checks).
  - **Quality assurance processes**: Integration of **heterogeneous tools and stakeholders** (e.g., [31]) necessitates **traceability frameworks** to validate model outputs against physical system states. While specific **error correction protocols** or **quantitative uncertainty metrics** are not detailed, the system relies on **automated data aggregation** (as in digital shadows) and **active processing components** (e.g., [35]–[37]) to mitigate discrepancies between digital and physical domains."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration in the Digital Twin system is achieved through **interoperability between heterogeneous modeling tools and notations**, as the document highlights the necessity to combine **SysML, ADLs (ACME, AADL, MontiArc), simulation tools (Simulink), and general-purpose programming languages (C++, Java)**. Data exchange protocols or standards are not explicitly mentioned, but the integration implies adherence to **semantic and syntactic interoperability frameworks** to reconcile disparate models. Dependencies on external systems are inferred from the requirement to integrate **diverse stakeholder perspectives** and **enterprise systems**, though no specific protocols (e.g., OPC UA, MQTT, REST) or enterprise integration patterns (e.g., ESB, API gateways) are detailed. The document does not specify integration with other Digital Twins but suggests a **federated or loosely coupled architecture** to accommodate modularity and scalability, aligning with the use of ADLs for component-based system descriptions."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The provided context does not explicitly mention **industry standards, specifications, certification requirements, or compliance frameworks** for Digital Twin systems. However, the use of **SysML** (ISO/IEC 10746-5) and **ADLs** (e.g., **AADL**, **ACME**) implies adherence to **modeling and systems engineering standards** for architecture description and interoperability. The integration of **MontiArc** (a model-driven engineering framework) and **SysML** suggests compliance with **OMG (Object Management Group) standards** for modeling languages. No explicit **interoperability standards** (e.g., OPC UA, FIWARE, or Industry 4.0 frameworks) are referenced in the document."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system, as described in the provided documents, integrates **cybersecurity protocols** aligned with **Industrie 4.0 standards** (e.g., **RAMI4.0** [48, 49]), which emphasize hierarchical access control and role-based authentication mechanisms. **Asset Administration Shell (AAS)** [46, 47, 50] serves as a foundational framework for encapsulating security policies, including **authentication via OAuth 2.0** and **encryption protocols** (e.g., TLS 1.2/1.3) for data-in-transit. The **Asset Administration Shell** also supports **threat mitigation strategies** through **semantic validation** of exchanged data, leveraging **knowledge graphs** [46] to detect anomalies in real-time. **Fail-safe mechanisms** are implied in **model-driven engineering (MDE) approaches** [43], where **conformance relations** ensure structural integrity and **rollback capabilities** for critical system states. **Risk assessment** is implicitly tied to **RAMI4.0’s lifecycle and hierarchy layers**, ensuring compliance with **IEC 62443** (industrial cybersecurity) and **ISO/IEC 27001** (information security management) through **structured submodels** (e.g., **SecuritySubmodel** in AAS). For **safety-critical systems**, the **Functional Mockup Interface (FMI)** [51] enables **tool-independent simulation validation**, ensuring deterministic behavior in **safety loops** (e.g., robotic arms like **MABI’s Max-100-2-25-P** [44]). **MQTT-based communication** [52] (e.g., via **Mosquitto**) is proposed for lightweight, secure IoT data exchange, with **QoS levels** (0–2) configurable for criticality. **ThingsBoard 4.0.0** [53] is referenced as an open-source IoT platform for **device management**, incorporating **JWT-based authentication** and **role-based access control (RBAC)** for granular permissions. **Data anonymization** and **consent management** are not explicitly detailed, but the **AAS’s submodel structure** allows for **metadata tagging** (e.g., **@id, @type**) to enforce **data provenance** and **usage restrictions** per **GAIA-X principles** (implied by [50])."
]