// =========================
// C3: Physical sensing components
// =========================
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor I_M that measures the input current of the permanent‑magnet synchronous motor"
    DTDFVocab:producedData MotorCurrentMqtt
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor side position encoder providing angular position of the motor shaft"
    DTDFVocab:producedData MotorPositionMqtt
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Gearbox side position encoder providing angular position after the cycloidal gearbox"
    DTDFVocab:producedData GearboxPositionMqtt
]

// =========================
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// =========================
instance MotorCurrentMqtt : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorPositionMqtt : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearboxPositionMqtt : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

instance DerivedTorqueMqtt : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorPositionEncoder
]

instance DerivedAngularVelocityMqtt : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder, GearboxPositionEncoder
]

// =========================
// C10: Data
// =========================
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Live measurement of motor input current I_M streamed via MQTT"
    DTDFVocab:fromData MotorCurrentMqtt
    DTDFVocab:inputTo DataProcessingEnabler, VisualizationEnabler
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Live measurement of motor angular position from motor encoder"
    DTDFVocab:fromData MotorPositionMqtt
    DTDFVocab:inputTo DataProcessingEnabler, VisualizationEnabler
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Live measurement of gearbox angular position from gearbox encoder"
    DTDFVocab:fromData GearboxPositionMqtt
    DTDFVocab:inputTo DataProcessingEnabler, VisualizationEnabler
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Derived torque τ time‑series calculated from current and position data"
    DTDFVocab:fromData DerivedTorqueMqtt
    DTDFVocab:inputTo DataProcessingEnabler, VisualizationEnabler
]

instance DerivedAngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω time‑series calculated from consecutive position samples"
    DTDFVocab:fromData DerivedAngularVelocityMqtt
    DTDFVocab:inputTo DataProcessingEnabler, VisualizationEnabler
]

// =========================
// C10: Models
// =========================
instance AxisEngineeringModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams describing the composition of axis 1 (motor, gearbox, encoders, drive electronics)"
    DTDFVocab:inputTo DataProcessingEnabler
]

instance MotorSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the permanent‑magnet synchronous motor (white‑box and black‑box friction variants)"
    DTDFVocab:inputTo SimulationEnablerM
]

instance GearwheelSimulationModel : DTDFVocab:Model [
    base:desc "Simulink model of the cycloidal gearwheel component"
    DTDFVocab:inputTo SimulationEnablerGW
]

instance GearboxSimulationModel : DTDFVocab:Model [
    base:desc "Simulink model of the overall gearbox assembly"
    DTDFVocab:inputTo SimulationEnablerGB
]

instance WhiteBoxFrictionModel : DTDFVocab:Model [
    base:desc "Analytical (white‑box) friction model covering static, kinetic and viscous friction"
    DTDFVocab:inputTo DataProcessingEnabler
]

instance BlackBoxFrictionCoulombViscousModel : DTDFVocab:Model [
    base:desc "Black‑box Coulomb‑Viscous friction model implemented in Simulink"
    DTDFVocab:inputTo SimulationEnablerM
]

instance BlackBoxFrictionStribeckModel : DTDFVocab:Model [
    base:desc "Black‑box Stribeck friction model (includes pre‑slip behaviour) in Simulink"
    DTDFVocab:inputTo SimulationEnablerM
]

instance BlackBoxFrictionDahlModel : DTDFVocab:Model [
    base:desc "Black‑box Dahl friction model (dynamic friction) in Simulink"
    DTDFVocab:inputTo SimulationEnablerM
]

instance BlackBoxFrictionLuGreModel : DTDFVocab:Model [
    base:desc "Black‑box LuGre friction model (state‑space formulation) in Simulink"
    DTDFVocab:inputTo SimulationEnablerM
]

// =========================
// C11: Enablers (Processing components & tools)
// =========================
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that ingests live data, performs identification of static, kinetic and viscous friction parameters and prepares data for services"
    DTDFVocab:enables FrictionParameterIdentificationService, ComparativeAnalysisService, FrictionModelUpdateService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard that visualizes measured and simulated data in real time"
    DTDFVocab:enables RealTimeVisualizationService
]

instance SimulationEnablerM : DTDFVocab:Enabler [
    base:desc "Execution environment for the motor simulation model and associated friction black‑box models"
    DTDFVocab:enables RealTimeVisualizationService
]

instance SimulationEnablerGW : DTDFVocab:Enabler [
    base:desc "Execution environment for the gearwheel simulation model"
    DTDFVocab:enables RealTimeVisualizationService
]

instance SimulationEnablerGB : DTDFVocab:Enabler [
    base:desc "Execution environment for the gearbox simulation model"
    DTDFVocab:enables RealTimeVisualizationService
]

// =========================
// C6: Services
// =========================
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of measured and simulated data on a web dashboard"
    DTDFVocab:provides InsightImprovedMachiningAccuracy
]

instance FrictionParameterIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of static, kinetic and viscous friction parameters from live data"
    DTDFVocab:provides InsightFrictionParametersForControl, ActionAdjustControlAlgorithm
]

instance ComparativeAnalysisService : DTDFVocab:Service [
    base:desc "Comparative analysis of friction‑less and friction‑augmented Simulink models"
    DTDFVocab:provides InsightFrictionParametersForControl
]

instance FrictionModelUpdateService : DTDFVocab:Service [
    base:desc "Generation of updated friction model parameters to improve robot motion‑control accuracy"
    DTDFVocab:provides ActionGenerateUpdatedFrictionParameters
]

// =========================
// C17: Insights & Actions
// =========================
instance InsightFrictionParametersForControl : DTDFVocab:Insight [
    base:desc "Derived friction parameters are used to adjust the robot's control algorithms, reducing positioning errors"
]

instance InsightImprovedMachiningAccuracy : DTDFVocab:Insight [
    base:desc "Real‑time dashboard insights support engineers in selecting the most appropriate friction model, improving machining accuracy"
]

instance ActionAdjustControlAlgorithm : DTDFVocab:Action [
    base:desc "Automatically update the robot's motion‑control algorithm with newly identified friction parameters"
    DTDFVocab:IsAutomatic true
]

instance ActionGenerateUpdatedFrictionParameters : DTDFVocab:Action [
    base:desc "Generate and persist updated friction model parameters for the digital twin"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow is defined as a passive one‑way data flow from the physical system to the virtual model and does not send commands back to the robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Online, real‑time during robot operation; data are acquired continuously and processed on‑the‑fly to update friction estimates."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A one‑way orchestration where the physical robot (asset) provides sensor streams to the digital shadow; the shadow contains processing components that consume the streams, run simulation models, produce derived data traces, and expose them to a dashboard. No feedback loop to the robot is present."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow is applied in the operational stage of the robot to monitor and identify friction; engineering models created earlier represent design/manufacturing knowledge that is reused at runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Combines white‑box analytical and black‑box data‑driven friction models; each data point is traceable to its source and processing model, enabling verification by comparing simulated friction‑free behavior with measured data. Multi‑physics‑aware identification is used to ensure model validity over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Live data are transmitted from the robot to the digital shadow using the MQTT protocol; the Asset Administration Shell provides the structural link between physical asset and virtual representation."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The implementation follows the Asset Administration Shell (AAS) standard for Industry 4.0 digital twins and employs the Digital Shadow Reference Model as a UML‑based reference."
]