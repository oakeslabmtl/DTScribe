// C2: Acting Components
instance SynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor (PMSM) mounted on the joint, providing position, velocity, or acceleration control."
]
instance Gearbox : DTDFVocab:ActingComponent [
    base:desc "Gearbox coupling the PMSM to the joint, delivering mechanical advantage and shrinking gear backlash."
]
instance CANFDSafetyNet : DTDFVocab:ActingComponent [
    base:desc "CAN‑FD based safety‑net receiving desired joint values, clamping them to physical limits, and forwarding signals to microcontrollers."
]

// C3: Physical sensing components
instance PrimaryMotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "High‑resolution rotary encoder mounted directly on the motor shaft, producing 10 kHz quadrature output."
    DTDFVocab:producedData JointEncoderDataTransmitted
]
instance SecondaryGearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary rotary encoder positioned after the gearbox, reducing backlash and improving resolution to 0.0001 ° per tick."
    DTDFVocab:producedData JointEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction
instance JointEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PrimaryMotorShaftEncoder, SecondaryGearboxEncoder
]

// C10: Models/Data
instance JointEncoderData : DTDFVocab:Data [
    base:desc "Aggregated joint position and velocity time‑series, serialized in JSON payloads and streamed via MQTT."
    DTDFVocab:fromData JointEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkExecutionEnabler, CPPExecutionEnabler, JavaExecutionEnabler
]
instance SysMLComponentDiagramModel : DTDFVocab:Model [
    base:desc "SysML component diagram representing the joint, motor, gearbox and safety‑net architecture."
    DTDFVocab:inputTo AcmeArchitectureEnabler, AADLArchitectureEnabler
]
instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine depicting joint control logic and safety states."
    DTDFVocab:inputTo AcmeArchitectureEnabler, AADLArchitectureEnabler
]
instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model of the joint controller behaviour."
    DTDFVocab:inputTo MontiArcModelEnabler
]
instance SimulinkExecutionModel : DTDFVocab:Model [
    base:desc "Simulink representation of the joint dynamics for simulation and code generation."
    DTDFVocab:inputTo SimulinkExecutionEnabler, CPPExecutionEnabler, JavaExecutionEnabler
]

// C11: Enablers
instance AcmeArchitectureEnabler : DTDFVocab:Enabler [
    base:desc "Acme ADL enabler orchestrating component composition and refinement."
    DTDFVocab:enables VisualizationService, HealthMonitoringService
]
instance AADLArchitectureEnabler : DTDFVocab:Enabler [
    base:desc "AADL ADL enabler linking real‑time operating system tasks to hardware components."
    DTDFVocab:enables HealthMonitoringService
]
instance MontiArcModelEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc model enabler translating automaton specifications into executable wiring."
    DTDFVocab:enables VisualizationService
]
instance SimulinkExecutionEnabler : DTDFVocab:Enabler [
    base:desc "Simulink runtime enabler generating C++ and Java code for real‑time execution."
    DTDFVocab:enables VisualizationService
]
instance CPPExecutionEnabler : DTDFVocab:Enabler [
    base:desc "C++ execution enabler employed for high‑performance joint control."
    DTDFVocab:enables HealthMonitoringService
]
instance JavaExecutionEnabler : DTDFVocab:Enabler [
    base:desc "Java execution erabler supporting cross‑platform deployment and flexibility."
    DTDFVocab:enables HealthMonitoringService
]

// C6: Services
instance VisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization service aggregating sensor streams onto a dashboard via MQTT."
    DTDFVocab:provides DashboardInsight
]
instance HealthMonitoringService : DTDFVocab:Service [
    base:desc "Health monitoring service processing fault tags and telemetry for safety management."
    DTDFVocab:provides HealthInsight, JointAdjustmentAction
]

// C17: Insights/Actions
instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Insight into joint position, velocity trends, and system health displayed on a digital dashboard."
]
instance HealthInsight : DTDFVocab:Insight [
    base:desc "Insight revealing detected faults such as over‑current or missing encoder ticks, prompting safety checks."
]
instance JointAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment action to recalibrate joint limits upon detecting overshoot."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is orchestrated using a Model‑Based Systems Engineering (MBSE) approach. The component and connector structure is described in SysML via an Architecture Design Block Diagram (Fig. 3). Behavioural dynamics are captured in executable MATLAB/Simulink models which are linked to the SysML model. The twin’s architecture follows a hierarchical multi‑level abstraction (requirements, functional, logical, product) with a centralised model repository. Coordination between the structural and behavioural models is achieved through model integration within the MBSE toolchain, enabling automatic generation of simulation and code artifacts."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin lifecycle is built on four stacked abstraction layers: a requirements layer that captures system constraints, a functional architecture layer that defines high‑level capabilities, a logical architecture layer that describes component interactions, and a product/technical layer that specifies concrete implementation details."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A robust fidelity and validity protocol balances analytical simplicity with realistic dynamics. The twin employs a multi‑resolution modeling hierarchy: lower‑order kinematics models for rapid controller tuning, and higher‑order dynamic models that incorporate detailed motor electrical characteristics, gearbox backlash, and nonlinear friction. Validation is performed by systematic comparison of simulated joint trajectories against measured data collected during a calibration routine. The deviation metric employs the mean absolute deviation over a five‑second test step, with a threshold of <0.05 degrees for position and <0.3 degrees per second for velocity. Exceedances trigger a re‑parameterization loop where parameters are adjusted via a gradient‑based optimizer. Uncertainty quantification is performed through Monte‑Carlo simulation of sensor noise and component tolerances, yielding confidence intervals for predicted states. Error detection is integrated at both data and model levels: outlier filtering removes transient spikes, while residual analysis flags model mismatch when the difference between predicted and measured signals exceeds three sigma. Quality assurance is maintained through automated regression tests that run on every code and model revision, generating a signed “fit report” that documents validation status, test coverage, and any identified regressions."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Shadow is a passive one‑way data consumer; it receives data streams from the physical object without pushing data back. The integration is limited to a single data flow channel; no bidirectional communication or external enterprise system integration (e.g., MES/ERP) is described. Inter‑system protocols are not specified beyond the generic one‑way data ingestion."
]