// C3: Physical Sensing Components
instance OperationalLogSensor : DTDFVocab:SensingComponent [
    base:desc "Collects unstructured operational logs from physical system components for contextual data traces"
    DTDFVocab:producedData OperationalLogDataTransmitted
]

instance SensorReadingSensor : DTDFVocab:SensingComponent [
    base:desc "Collects structured time-series sensor data from physical system components"
    DTDFVocab:producedData SensorReadingDataTransmitted
]

instance EnvironmentalParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Collects environmental parameters (e.g., temperature, humidity) from physical system surroundings"
    DTDFVocab:producedData EnvironmentalParameterDataTransmitted
]

instance ImageCaptureSensor : DTDFVocab:SensingComponent [
    base:desc "Collects unstructured image data from physical system components for visual inspection"
    DTDFVocab:producedData ImageDataTransmitted
]

instance MetadataSensor : DTDFVocab:SensingComponent [
    base:desc "Collects structured metadata associated with physical system operations"
    DTDFVocab:producedData MetadataDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance OperationalLogDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalLogSensor
    base:desc "One-way automated transmission of unstructured operational logs from physical system to digital shadow"
]

instance SensorReadingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SensorReadingSensor
    base:desc "One-way automated transmission of structured time-series sensor readings from physical system to digital shadow"
]

instance EnvironmentalParameterDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalParameterSensor
    base:desc "One-way automated transmission of environmental parameters from physical system to digital shadow"
]

instance ImageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ImageCaptureSensor
    base:desc "One-way automated transmission of image data from physical system to digital shadow"
]

instance MetadataDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MetadataSensor
    base:desc "One-way automated transmission of metadata from physical system to digital shadow"
]

// C10: Models/Data
instance RequirementsModel : DTDFVocab:Model [
    base:desc "SysML-based requirements model capturing system specifications across abstraction layers"
    DTDFVocab:inputTo SysMLToolEnabler, MBSEMethologyEnabler
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML-based functional architecture model defining system functions and their relationships"
    DTDFVocab:inputTo SysMLToolEnabler, MBSEMethologyEnabler
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) model defining system components, interfaces, and interconnections"
    DTDFVocab:inputTo SysMLToolEnabler, ADLToolEnabler
]

instance ProductTechnicalModel : DTDFVocab:Model [
    base:desc "SysML-based product/technical layer model defining physical system components and their properties"
    DTDFVocab:inputTo SysMLToolEnabler, SimulationToolEnabler
]

instance StateMachineBehavioralModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model capturing system behavioral dynamics"
    DTDFVocab:inputTo SysMLToolEnabler
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model for component interaction and behavioral modeling"
    DTDFVocab:inputTo MontiArcToolEnabler, SimulationToolEnabler
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for real-time or discrete-event system dynamics simulation"
    DTDFVocab:inputTo SimulationToolEnabler
]

instance GeometricModel : DTDFVocab:Model [
    base:desc "Geometric model representing physical system components (implicitly referenced in SysML logical/physical layers)"
    DTDFVocab:inputTo SysMLToolEnabler, SimulationToolEnabler
]

instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces from physical system operations"
    DTDFVocab:fromData OperationalLogDataTransmitted, SensorReadingDataTransmitted, EnvironmentalParameterDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler, DigitalShadowEnabler
]

instance HeterogeneousDataStream : DTDFVocab:Data [
    base:desc "Combined heterogeneous data stream including structured and unstructured data from multiple sources"
    DTDFVocab:fromData MetadataDataTransmitted, ImageDataTransmitted, ContextualDataTrace
    DTDFVocab:inputTo DataIntegrationEnabler, ETLPipelineEnabler
]

instance SimulationInputData : DTDFVocab:Data [
    base:desc "Processed data prepared for simulation and behavioral modeling"
    DTDFVocab:fromData HeterogeneousDataStream
    DTDFVocab:inputTo SimulationToolEnabler
]

// C11: Enablers
instance SysMLToolEnabler : DTDFVocab:Enabler [
    base:desc "SysML toolchain enabling multi-level abstraction modeling (requirements, functional, logical, product layers) and behavioral modeling via state machines"
    DTDFVocab:enables DataAcquisitionService, SimulationService, MonitoringService, ControlService
]

instance ADLToolEnabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Languages (ACME, AADL, MontiArc) for component-connector-based system decomposition and interface definitions"
    DTDFVocab:enables DataAcquisitionService, MonitoringService, ControlService
]

instance SimulationToolEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink and other simulation engines for dynamic system simulation and validation"
    DTDFVocab:enables SimulationService, ControlService
]

instance MontiArcToolEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for state-based behavioral modeling of component interactions"
    DTDFVocab:enables SimulationService, ControlService
]

instance CodeGenerationEnabler : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering (MDE) for automated code generation from SysML/ADL models to C++/Java"
    DTDFVocab:enables ControlService
]

instance MBSEMethologyEnabler : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodologies (RFLP, OOSEM, SPES, SMArDT) for managing system complexity across abstraction layers"
    DTDFVocab:enables DataAcquisitionService, SimulationService, MonitoringService, ControlService
]

instance DigitalShadowEnabler : DTDFVocab:Enabler [
    base:desc "Digital Shadow Reference Model for passive data aggregation and one-way flow from physical to digital"
    DTDFVocab:enables DataAcquisitionService
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "Data aggregation and abstraction mechanisms for reducing noise and extracting meaningful features from raw sensor data"
    DTDFVocab:enables DataAcquisitionService, SimulationService
]

instance DataIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "ETL pipelines and middleware tools (e.g., Apache Kafka) for combining data from multiple sources into unified digital model"
    DTDFVocab:enables DataAcquisitionService, SimulationService
]

instance ETLPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Extract, Transform, Load pipelines for processing heterogeneous data streams into usable formats"
    DTDFVocab:enables DataAcquisitionService, SimulationService
]

// C6: Services
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Passive collection of one-way automated data flows from physical system including contextual data traces"
    DTDFVocab:provides PhysicalSystemStateInsight
]

instance ActiveInterpretationService : DTDFVocab:Service [
    base:desc "Active interpretation and analysis of incoming data using autonomous software modules for real-time decision support"
    DTDFVocab:provides DataAnalysisInsight, DecisionSupportInsight
    DTDFVocab:provides ActivateControlAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Integration with simulation tools to model system behavior using state machines, automata, or discrete-event simulations"
    DTDFVocab:provides BehavioralModelInsight, PredictiveAnalysisInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of system states via ADL-based models and visualization tools for interactive dashboards"
    DTDFVocab:provides SystemStateInsight, OperationalInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Closed-loop control services leveraging active DT components to optimize system performance"
    DTDFVocab:provides OptimizationInsight
    DTDFVocab:provides AdjustControlAction
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Strategic optimization reports derived from data-driven predictions for decision-makers"
    DTDFVocab:provides StrategicOptimizationInsight
]

instance EngineerDesignValidationService : DTDFVocab:Service [
    base:desc "Access to functional/logical architecture models for engineers to validate design"
    DTDFVocab:provides DesignValidationInsight
]

instance OperatorRealTimeInsightService : DTDFVocab:Service [
    base:desc "Real-time operational insights via simulation-driven visualizations for operators"
    DTDFVocab:provides OperationalStateInsight
]

// C17: Insights/Actions
instance PhysicalSystemStateInsight : DTDFVocab:Insight [
    base:desc "Aggregated contextual data traces representing current state of physical system components"
]

instance DataAnalysisInsight : DTDFVocab:Insight [
    base:desc "Processed and interpreted data from physical system operations with extracted meaningful features"
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Real-time decision support information derived from active data interpretation"
]

instance BehavioralModelInsight : DTDFVocab:Insight [
    base:desc "Model of system behavior using state machines, automata, or discrete-event simulations"
]

instance PredictiveAnalysisInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics results from simulation models for future system behavior"
]

instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring data of system states for operational oversight"
]

instance OperationalInsight : DTDFVocab:Insight [
    base:desc "Operational insights derived from simulation-driven visualizations"
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization results for system performance derived from closed-loop control services"
]

instance StrategicOptimizationInsight : DTDFVocab:Insight [
    base:desc "Strategic optimization reports for decision-makers based on data-driven predictions"
]

instance DesignValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results for system design using functional/logical architecture models"
]

instance OperationalStateInsight : DTDFVocab:Insight [
    base:desc "Real-time operational state information for operators"
]

instance ActivateControlAction : DTDFVocab:Action [
    base:desc "Automated activation of control mechanisms based on data analysis"
    DTDFVocab:IsAutomatic true
]

instance AdjustControlAction : DTDFVocab:Action [
    base:desc "Automated adjustment of control parameters to optimize system performance"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components (implied from services)
instance AutonomousDataInterpreter : DTDFVocab:ActingComponent [
    base:desc "Autonomous software module for interpreting, analyzing, and processing incoming data from physical system"
]

instance PredictiveAnalyticsEngine : DTDFVocab:ActingComponent [
    base:desc "Software module for performing predictive analytics on system data"
]

instance OptimizationSolver : DTDFVocab:ActingComponent [
    base:desc "Software module for optimizing system performance using adaptive algorithms"
]

instance ControlAlgorithmExecutor : DTDFVocab:ActingComponent [
    base:desc "Software module executing closed-loop control algorithms for system optimization"
]

// C1: Environment (System Under Study)
instance ManufacturingSystemEnvironment : DTDFVocab:Environment [
    base:desc "Complex engineered manufacturing system modeled across requirements, functional, logical, and product/technical layers"
    base:contains RequirementsModel, FunctionalArchitectureModel, LogicalArchitectureModel, ProductTechnicalModel
    base:contains AutonomousDataInterpreter, PredictiveAnalyticsEngine, OptimizationSolver, ControlAlgorithmExecutor
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system’s **orchestration and coordination** rely on **architecture patterns** derived from **Model-Based Systems Engineering (MBSE)** methodologies, such as **RFLP (Requirements, Functions, Logics, Physics)**, **OOSEM**, **SPES**, or **SMArDT**. These methodologies decompose system complexity into **multiple abstraction layers** (requirements, functional architecture, logical architecture, and product/technical layers). For **component integration**, the document emphasizes the use of **architecture description languages (ADLs)** like **ACME**, **AADL**, **MontiArc**, or **SysML Internal Block Diagrams (IBDs)**, which define **components, interfaces, interconnections, and composition**. Behavioral descriptions are often enhanced with **state machines (SysML v1.7)** or **MontiArc Automaton**, while detailed behavior modeling may involve **simulation tools (e.g., MathWorks Simulink)** or **general-purpose programming languages (C++, Java)**. **Resource management** and **system-wide coordination** are implied to be handled through these integrated modeling and simulation tools, ensuring alignment between digital and physical system states. The document does not specify explicit **orchestration protocols** (e.g., microservices, event-driven architectures) but suggests a **heterogeneous, tool-agnostic integration** approach."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system emphasizes **model fidelity** through **multi-layered validation and verification (V&V)** methods, including:
  - **Behavioral validation** via **state machines (SysML v1.7) or MontiArc Automaton** to ensure logical consistency with physical system dynamics.
  - **Simulation-based verification** using tools like **MathWorks Simulink** or other **co-simulation environments** (e.g., [29], [30]) to quantify **uncertainty sources** (e.g., sensor noise, model approximations) and **error propagation** across abstraction layers.
  - **Quality assurance processes** tied to **MBSE methodologies** (e.g., **RFLP, OOSEM**) to trace requirements through functional/logical architectures to the physical layer, ensuring **traceability of data provenance** and **model accuracy**.
  Uncertainty quantification is implicit in the **data aggregation and abstraction** process of the **Digital Shadow Reference Model** (Fig. 1), where **contextual traces** are refined into actionable insights for the DT. Error detection relies on **cross-tool consistency checks** (e.g., comparing SysML IBDs with Simulink outputs) and **automated data flow validation** between physical and digital domains."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for a Digital Twin (DT) system is not explicitly detailed in the provided document. However, the context implies the need for **heterogeneous communication protocols** to support interactions between physical and digital components, likely including **industrial protocols (e.g., OPC UA, Modbus, Profibus)** for machine-to-machine communication and **standardized IoT protocols (e.g., MQTT, CoAP)** for lightweight, event-driven data exchange. The **network topology** would typically follow a **hybrid architecture**, combining **edge computing nodes** (for low-latency local processing) and **centralized cloud/on-premise servers** for global coordination. **Bandwidth and latency requirements** are not quantified but are inferred to prioritize **real-time or near-real-time** performance for critical applications (e.g., predictive maintenance, process optimization). **Reliability and redundancy mechanisms** would include **failover protocols, load balancing, and fault-tolerant designs**, though specific implementations (e.g., SDN, MPLS) are not mentioned. **Security protocols** would likely adhere to **industrial cybersecurity standards** (e.g., IEC 62443, NIST SP 800-82) for authentication, encryption (e.g., TLS, DTLS), and access control, but these are not elaborated in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **deployment infrastructure** for a Digital Twin (DT) system is not explicitly described in the document. However, the context suggests support for **multi-tier deployment models**, including **cloud-based** (e.g., AWS IoT, Microsoft Azure Digital Twins), **edge computing** (for localized processing of high-frequency data), and **on-premise** (for sensitive or low-latency-critical applications). **Computational and storage requirements** would vary by use case but would likely involve **scalable microservices architectures** (e.g., containerized deployments using Docker/Kubernetes) to handle dynamic workloads. **Scalability mechanisms** would include **auto-scaling, elastic resource allocation, and distributed databases** (e.g., NoSQL for unstructured data). The document does not specify **availability/reliability assurance** methods, but these would typically involve **high-availability clustering, backup/recovery systems, and SLAs** tailored to the application (e.g., 99.99% uptime for mission-critical systems). The **deployment models** would need to integrate with **MBSE tools** (e.g., SysML, Simulink) and **simulation environments** for validation, though the exact integration is not detailed."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system’s **horizontal integration** with external systems is not explicitly detailed in the provided document. However, the context implies dependencies on **heterogeneous stakeholders and perspectives**, requiring **interoperability standards** and **data exchange protocols** to integrate with other Digital Twins or enterprise systems. While no specific protocols (e.g., OPC UA, MQTT, REST APIs) or standards (e.g., ISO 23247 for Digital Twins) are mentioned, the use of **MBSE methodologies** (e.g., SysML, ADLs) and **simulation tools** (e.g., Simulink) suggests a need for **semantic interoperability** and **data harmonization** across tools. The document does not provide concrete examples of **integration patterns** (e.g., federated Digital Twins, service-oriented architectures) or **dependencies on external systems**, but it acknowledges the challenge of managing **heterogeneous modeling notations and tools** in a cohesive Digital Twin ecosystem."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The provided context does not explicitly mention **standards compliance**, **certification requirements**, or **compliance frameworks** for Digital Twin systems. However, the use of **SysML** (ISO/IEC 19505) and **ADLs** (e.g., **AADL**, **ACME**) suggests adherence to **industry-standard modeling languages** for system architecture and behavior. **Interoperability standards** are implied through the integration of heterogeneous tools (e.g., **Simulink**, **C++/Java**), but no specific protocols (e.g., OPC UA, MTConnect) or certification bodies (e.g., ISO 23247 for DTs) are referenced. The **Digital Shadow Reference Model** (Fig. 1) aligns with **manufacturing-specific data aggregation** but does not address broader standardization frameworks."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The provided documents outline foundational security and safety considerations for Digital Twin systems, particularly in the context of **Industrie 4.0** and **Asset Administration Shell (AAS)** architectures. Key elements include:
  - **Cybersecurity Protocols**: The **Asset Administration Shell (AAS)** (as described in [46], [47], and [50]) integrates **authentication and authorization mechanisms** to ensure secure access to digital twin data and functionalities. The **RAMI4.0** reference architecture ([48], [49]) emphasizes **role-based access control (RBAC)** and **identity management** to enforce granular permissions across hierarchical layers of the automation pyramid ([42]).
  - **Access Control Mechanisms**: The **AAS** employs **OAuth 2.0** and **JWT (JSON Web Tokens)** for secure API interactions ([50]), while **MQTT (Message Queuing Telemetry Transport)** ([52]) is leveraged for lightweight, encrypted communication between IoT devices and digital twin components, ensuring **end-to-end security** via TLS/SSL.
  - **Threat Mitigation Strategies**: The **AAS** architecture ([46], [47]) incorporates **encryption of data at rest and in transit**, **digital signatures** for integrity verification, and **intrusion detection systems (IDS)** to monitor anomalous behavior in real-time. The **RAMI4.0** framework ([49]) mandates **cybersecurity compliance** aligned with **ISO/IEC 27001** and **IEC 62443** standards.
  - **Fail-Safe Mechanisms**: In **model-driven engineering of Digital Twins** ([43]), **functional mockup interfaces (FMI)** ([51]) are used to ensure **simulation model isolation** and **failover capabilities** during runtime anomalies. The **Digital Shadow** concept ([42]) introduces **redundant data synchronization** across automation pyramid layers to maintain operational continuity.
  - **Risk Assessment Approaches**: The **AAS** ([50]) supports **risk-based asset management** by integrating **threat modeling** and **vulnerability assessments** into its metadata structure. The **RAMI4.0** ([49]) aligns with **IEC 61508** for **functional safety** in industrial systems, ensuring compliance with **safety integrity levels (SIL)**.
  - **Safety-Critical System Considerations**: For **robotics applications** (e.g., [44], [45]), the **Digital Twin** incorporates **real-time friction modeling** ([45]) and **dynamics learning** to preemptively identify **safety-critical states** (e.g., collision risks). The **AAS** ([46]) enables **safety certification** by embedding **machine-readable safety certificates** and **compliance proofs** into asset metadata."
]