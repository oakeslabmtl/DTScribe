// C3: Physical sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor position encoder on the permanent‑magnet synchronous motor of the first axis"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder located behind the gearwheel/gearbox of the first axis"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor input current I_M of the first axis"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Data
instance MotorAngularPositionData : DTDFVocab:Data [
    base:desc "Angular position of the motor shaft derived from MotorEncoder"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkTool
]

instance GearboxAngularPositionData : DTDFVocab:Data [
    base:desc "Angular position after gearbox derived from GearboxEncoder"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkTool
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor input current I_M"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkTool
]

instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Derived torque computed from motor current I_M and motor model"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkTool
]

instance DerivedAngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity derived from motor position data"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkTool
]

instance DerivedAngularAccelerationData : DTDFVocab:Data [
    base:desc "Angular acceleration derived from motor position data"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo SimulinkTool
]

// C10: Models
instance SysMLAxisModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagram of the first axis"
    DTDFVocab:inputTo SysMLTool
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the permanent‑magnet synchronous motor"
    DTDFVocab:inputTo SimulinkTool
]

instance SimulinkGearwheelModel : DTDFVocab:Model [
    base:desc "Simulink model of the gearwheel gearbox"
    DTDFVocab:inputTo SimulinkTool
]

instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "Simulink model of the cycloidal gearbox"
    DTDFVocab:inputTo SimulinkTool
]

instance SimulinkFrictionFreeModel : DTDFVocab:Model [
    base:desc "Friction‑free simulation model for baseline behavior"
    DTDFVocab:inputTo SimulinkTool
]

instance SimulinkFrictionModel : DTDFVocab:Model [
    base:desc "Friction model (static, kinetic, viscous) for the axis"
    DTDFVocab:inputTo SimulinkTool
]

instance TorqueCalculationModel : DTDFVocab:Model [
    base:desc "Data calculation model generating torque from current and motor parameters"
    DTDFVocab:inputTo SimulinkTool
]

instance VelocityCalculationModel : DTDFVocab:Model [
    base:desc "Data calculation model generating angular velocity from position data"
    DTDFVocab:inputTo SimulinkTool
]

instance AccelerationCalculationModel : DTDFVocab:Model [
    base:desc "Data calculation model generating angular acceleration from position data"
    DTDFVocab:inputTo SimulinkTool
]

// C11: Enablers
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML modeling environment for creating the engineering model of the robot axis"
    DTDFVocab:enables FrictionParameterUpdateService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment executing motor, gearbox and friction models"
    DTDFVocab:enables RealTimeFrictionIdentificationService, DataVisualizationService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker streaming live sensor data to the digital shadow"
    DTDFVocab:enables DataVisualizationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell integrating model data and enabling parameter updates"
    DTDFVocab:enables FrictionParameterUpdateService
]

instance VisualizationDashboard : DTDFVocab:Enabler [
    base:desc "Dashboard visualizing live and simulated data for operators"
    DTDFVocab:enables DataVisualizationService
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction using combined white‑box and black‑box models"
    DTDFVocab:provides FrictionParameterFeedbackInsight, UpdateFrictionParametersAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Visualization of live sensor data and simulated model outputs in an operator dashboard"
    DTDFVocab:provides LiveDataVisualizationInsight
]

instance FrictionParameterUpdateService : DTDFVocab:Service [
    base:desc "Generation and injection of updated friction parameters into the robot controller for improved motion accuracy"
    DTDFVocab:provides ModelBasedControlAdjustmentInsight, ApplyFrictionParameterUpdateAction
]

// C17: Insights
instance FrictionParameterFeedbackInsight : DTDFVocab:Insight [
    base:desc "Derived friction parameters are fed back to the robot controller to enhance motion accuracy"
]

instance ModelBasedControlAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Digital shadow supports model‑based control adjustments based on updated parameters"
]

instance LiveDataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Operators receive live visual feedback of sensor and simulation data"
]

// C17: Actions
instance UpdateFrictionParametersAction : DTDFVocab:Action [
    base:desc "Automatic update of friction parameters in the controller"
    DTDFVocab:IsAutomatic true
]

instance ApplyFrictionParameterUpdateAction : DTDFVocab:Action [
    base:desc "Apply newly identified friction parameters to the robot motion control loop"
    DTDFVocab:IsAutomatic true
]

// System under study
instance MabiMax100AxisComponent : DTDFVocab:Component [
    base:desc "First axis of the MABI MAX 100 six‑axis industrial robot, comprising permanent‑magnet synchronous motor, gearwheel gearbox and cycloidal gearbox"
]

// Environment containing the component
instance RobotEnvironment : DTDFVocab:Environment [
    base:contains MabiMax100AxisComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital shadow is defined as having a one‑way data flow only from the physical system to the virtual model; no data or commands are sent from the virtual side back to the robot, i.e., there is no virtual‑to‑physical interaction."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization; data are captured and processed as the robot operates, enabling on‑line model updates."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A digital shadow consisting of an Asset (first axis), Sources (sensors and derived data), Processing components (simulation models and friction calculation modules), DataTraces (measured and simulated torque/velocity arrays), and a visualization dashboard, all conforming to the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operative stage – the digital shadow is created and used during runtime of the robot to monitor and improve its motion accuracy."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each DataTrace to its generating Processing component and underlying models; comparison of simulated friction‑free behavior with measured data to validate and continuously update white‑box and black‑box friction models, ensuring model fidelity during runtime."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol is used for transmitting sensor streams from the robot to the digital shadow; Asset Administration Shells provide standardized metadata linkage."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) standard for model encapsulation and SysML as an engineering modeling standard."
]