instance MABI_MAX_0100_FirstAxisRobot : DTDFVocab:Component [
    base:desc "First rotary joint of the six‑axial MABI MAX 0100 industrial robot featuring a permanent‑magnet synchronous motor, dual‑gear transmission, and dual encoders."
]

// --- Physical Sensing Components --------------------------------------------------
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor on the permanent‑magnet synchronous motor measuring I_M."
    DTDFVocab:producedData CurrentDataStream
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Angular encoder mounted on the motor side providing r_M."
    DTDFVocab:producedData MotorPositionDataStream
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Angular encoder mounted on the gearbox side providing r_G."
    DTDFVocab:producedData GearboxPositionDataStream
]

// -----------------------------------------------------------------------------
// Instances of the physical data streams (DataTransmitted)
instance CurrentDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]
instance MotorPositionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]
instance GearboxPositionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

// Derived data streams (torque and angular velocity)
instance DerivedTorqueDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorPositionEncoder, GearboxPositionEncoder
]
instance DerivedAngularVelocityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder, GearboxPositionEncoder
]

// -----------------------------------------------------------------------------
// Data instances corresponding to the transmitted streams
instance CurrentData : DTDFVocab:Data [
    base:desc "Instantaneous motor current I_M measured as a time‑stamped data trace."
    DTDFVocab:fromData CurrentDataStream
    DTDFVocab:inputTo MqttBrokerEnabler
]
instance MotorPositionData : DTDFVocab:Data [
    base:desc "Motor‑side angular position r_M as a time‑stamped data trace."
    DTDFVocab:fromData MotorPositionDataStream
    DTDFVocab:inputTo MqttBrokerEnabler
]
instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Gearbox‑side angular position r_G as a time‑stamped data trace."
    DTDFVocab:fromData GearboxPositionDataStream
    DTDFVocab:inputTo MqttBrokerEnabler
]
instance DerivedTorqueData : DTDFVocab:Data [
    base:desc "Derived torque τ computed from motor current and position signals."
    DTDFVocab:fromData DerivedTorqueDataStream
    DTDFVocab:inputTo MqttBrokerEnabler
]
instance DerivedAngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω computed from motor and gearbox position signals."
    DTDFVocab:fromData DerivedAngularVelocityDataStream
    DTDFVocab:inputTo MqttBrokerEnabler
]

// -----------------------------------------------------------------------------
// Enablers --------------------------------------------------------------------
instance MqttBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker used to stream sensor data (I_M, r_M, r_G, τ, ω) to the digital twin."
    DTDFVocab:enables RealTimeFrictionModelIdentificationService, MaintenanceSchedulingService
]

instance MultiPhysicsSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight into the accuracy of multi‑physics simulation models."
]
instance RunMultiPhysicsSimulationAction : DTDFVocab:Action [
    base:desc "Runs the multi‑physics simulation for the joint."
    DTDFVocab:IsAutomatic true
]

instance MultiPhysicsSimulationService : DTDFVocab:Service [
    base:desc "Multi‑physics simulation of motor, gearbox, and friction models."
    DTDFVocab:provides MultiPhysicsSimulationInsight, RunMultiPhysicsSimulationAction
]

instance SimulinkExecutionEnvironmentEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink environment feeding simulation models of motor, gearbox and friction."
    DTDFVocab:enables MultiPhysicsSimulationService, ContinuousFrictionParameterAdaptationService, SimulationModelRefinementService
]

instance SysMLModelingToolEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling tool used to create the structural model of the first joint."
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell providing semantic metadata and traceability for the digital twin."
    DTDFVocab:enables AssetAdministrationShellIntegrationService
]

// -----------------------------------------------------------------------------
// Models ---------------------------------------------------------------------
instance SysMLStructuralModelFirstAxis : DTDFVocab:Model [
    base:desc "SysML structural model of the first rotary joint, including motor, gearbox, encoders, and friction elements."
    DTDFVocab:inputTo SysMLModelingToolEnabler
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model of the permanent‑magnet synchronous motor dynamics."
    DTDFVocab:inputTo SimulinkExecutionEnvironmentEnabler
]
instance SimulinkGearboxModel : DTDFVocab:Model [
    base:desc "MATLAB Simulink model of the dual‑gear transmission."
    DTDFVocab:inputTo SimulinkExecutionEnvironmentEnabler
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Coulomb‑Viscous white‑box friction model used in Simulink simulations."
    DTDFVocab:inputTo SimulinkExecutionEnvironmentEnabler
]
instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Stribeck white‑box friction model providing velocity‑dependent friction for the joint."
    DTDFVocab:inputTo SimulinkExecutionEnvironmentEnabler
]
instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Dahl white‑box friction model capturing adhesion and stiction effects."
    DTDFVocab:inputTo SimulinkExecutionEnvironmentEnabler
]
instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "LuGre white‑box friction model used to represent hysteresis in the joint."
    DTDFVocab:inputTo SimulinkExecutionEnvironmentEnabler
]

// -----------------------------------------------------------------------------
// Services --------------------------------------------------------------------
instance RealTimeFrictionModelIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic, and viscous friction parameters from live sensor data."
    DTDFVocab:provides StaticFrictionInsight, KineticFrictionInsight, ViscousFrictionInsight
]

instance ContinuousFrictionParameterAdaptationService : DTDFVocab:Service [
    base:desc "Continuous update of friction parameters in the control algorithm based on live data."
    DTDFVocab:provides ParameterUpdateInsight, UpdateControlAlgorithmAction
]

instance MaintenanceSchedulingService : DTDFVocab:Service [
    base:desc "Maintenance scheduling service that analyzes friction trends to recommend intervention times."
    DTDFVocab:provides MaintenanceSchedulingInsight, ScheduleMaintenanceAction
]

instance MotionControlOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes robot motion control by adjusting torque trajectories using updated friction models."
    DTDFVocab:provides MotionControlOptimizationInsight, OptimizeMotionControlAction
]

instance SimulationModelRefinementService : DTDFVocab:Service [
    base:desc "Refines MATLAB Simulink models of motor, gearbox, and friction to enhance fidelity."
    DTDFVocab:provides SimulationModelRefinementInsight, RefineSimulationModelAction
]

instance AssetAdministrationShellIntegrationService : DTDFVocab:Service [
    base:desc "Integrates proprietary metadata and traceability information into the Asset Administration Shell."
    DTDFVocab:provides MetadataTraceabilityInsight
]

// -----------------------------------------------------------------------------
// Insights -------------------------------------------------------------------
instance StaticFrictionInsight : DTDFVocab:Insight [
    base:desc "Measurement and analysis of static friction coefficient in the joint."
]
instance KineticFrictionInsight : DTDFVocab:Insight [
    base:desc "Measurement and analysis of kinetic friction coefficient in the joint."
]
instance ViscousFrictionInsight : DTDFVocab:Insight [
    base:desc "Measurement and analysis of viscous friction coefficient in the joint."
]
instance ParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight on optimal updates for control algorithm friction parameters."
]
instance MaintenanceSchedulingInsight : DTDFVocab:Insight [
    base:desc "Analysis of friction trend to schedule preventive maintenance."
]
instance MotionControlOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight for optimizing robot motion control using refined friction models."
]
instance SimulationModelRefinementInsight : DTDFVocab:Insight [
    base:desc "Insight on the refinement of simulation models to increase accuracy."
]
instance MetadataTraceabilityInsight : DTDFVocab:Insight [
    base:desc "Metadata and traceability information integrated within the Asset Administration Shell."
]

// -----------------------------------------------------------------------------
// Actions ----------------------------------------------------------------------
instance UpdateControlAlgorithmAction : DTDFVocab:Action [
    base:desc "Automatic update of control algorithm friction parameters based on live data."
    DTDFVocab:IsAutomatic true
]
instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Manual scheduling of maintenance activities for the joint."
    DTDFVocab:IsAutomatic false
]
instance RefineSimulationModelAction : DTDFVocab:Action [
    base:desc "Adjustment of simulation model parameters to better fit observed data."
    DTDFVocab:IsAutomatic false
]
instance OptimizeMotionControlAction : DTDFVocab:Action [
    base:desc "Automatic optimization of motion control trajectories using updated friction models."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time updates synchronized with the sensor sampling rate; data are processed and visualised immediately upon publication via MQTT (every sensor time step)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is a digital shadow consisting of the asset (MABI MAX 100 first axis), its engineering SysML model, a processing component that ingests sensor data traces, simulation models that generate virtual traces, and an AAS that links all elements; all components are integrated and visualised via a dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated (runtime) stage—uses live operational data for continuous identification and refinement of friction models; does not cover design or manufacturing phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Ensured full traceability from sensor source through processing to data points; combined analytic and data‑driven models for cross‑validation; continuously identified and updated friction parameters to account for wear or load changes; simulation parameters derived from manufacturer data; validity assessed by comparing simulated and measured traces (r_M, r_G, r_out) and analysing residuals."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT as the lightweight publish/subscribe protocol used to transmit sensor data streams from the robot controller to the digital shadow application."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The modeling approach follows SysML for structural and functional design; Asset Administration Shell (AAS) is used for semantic asset representation."
]