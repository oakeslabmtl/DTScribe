instance SysMLIBDsGeometricModel : DTDFVocab:Model [
    base:desc "Geometric representations via SysML Integrated Block Diagrams"
    DTDFVocab:inputTo SysMLIBDsADLEnabler, SimulinkEnabler
]

instance SysMLStateMachinesBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral models using state machines in SysML v1.7"
    DTDFVocab:inputTo SysMLIBDsADLEnabler
]

instance MontiArcAutomatonBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral models using MontiArc Automaton"
    DTDFVocab:inputTo MontiArcADLEnabler
]

instance SimulinkAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical models through MathWorks Simulink simulations"
    DTDFVocab:inputTo SimulinkEnabler
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for requirements, functional, logical, and product layers"
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "Object-Oriented Systems Engineering Methodology for system complexity management across abstraction levels"
]

instance SPES : DTDFVocab:Enabler [
    base:desc "SPES methodology for system engineering across abstraction levels"
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for system complexity management"
]

instance ACME : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component and connector modeling"
]

instance AADL : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for embedded systems"
]

instance MontiArcADLEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component-based modeling"
]

instance SysMLIBDsADLEnabler : DTDFVocab:Enabler [
    base:desc "SysML Integrated Block Diagrams for system architecture modeling"
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and model-based design"
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed behavior description and system simulation"
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed behavior description and system simulation"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Industry standards such as SysML (including state machines in SysML v1.7), ACME, AADL, and MontiArc (including MontiArc Automaton) are utilized for architecture description, enabling component & connector modeling, interface specifications, and behavior description, with integration into modeling tools like MathWorks Simulink and general-purpose programming languages such as C++ and Java."
]