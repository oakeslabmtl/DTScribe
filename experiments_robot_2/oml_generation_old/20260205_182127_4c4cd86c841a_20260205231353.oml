// C3: Physical Sensing Components
instance RobotPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "State sensor capturing robot position and velocity dynamics for nonlinear friction modeling using high-resolution data acquisition."
    DTDFVocab:producedData RobotPositionData
]

instance RobotForceTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "State sensor measuring force/torque dynamics in industrial robots to capture complex physical effects for state estimation."
    DTDFVocab:producedData RobotForceTorqueData
]

instance InjectionMoldingTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing temperature parameters in injection molding processes for real-time process monitoring and optimization."
    DTDFVocab:producedData InjectionMoldingTemperatureData
]

instance InjectionMoldingPressureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring pressure parameters in injection molding processes to detect anomalies and optimize production parameters."
    DTDFVocab:producedData InjectionMoldingPressureData
]

instance ProductionLineFlowRateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing material flow rates in continuous production processes for process control and optimization."
    DTDFVocab:producedData ProductionLineFlowRateData
]

// C4: Physical-to-Virtual Interaction
instance RobotPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotPositionEncoder
]

instance RobotForceTorqueData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotForceTorqueSensor
]

instance InjectionMoldingTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InjectionMoldingTemperatureSensor
]

instance InjectionMoldingPressureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InjectionMoldingPressureSensor
]

instance ProductionLineFlowRateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProductionLineFlowRateSensor
]

// C10: Models/Data
instance DigitalShadowReferenceModel : DTDFVocab:Model [
    base:desc "UML class diagram defining standardized data trace aggregation framework for digital shadow enrichment in manufacturing DTs."
    DTDFVocab:inputTo DigitalShadowAggregationPipeline
]

instance RobotDynamicsModel : DTDFVocab:Model [
    base:desc "Physics-based model capturing nonlinear friction phenomena and robot dynamics using scalable identification methods."
    DTDFVocab:inputTo RobotDynamicsSimulationEngine
]

instance InjectionMoldingProcessModel : DTDFVocab:Model [
    base:desc "Multi-physics model simulating thermal, pressure, and material flow dynamics in injection molding processes."
    DTDFVocab:inputTo InjectionMoldingSimulationEngine
]

instance ProductionLineControlModel : DTDFVocab:Model [
    base:desc "Hybrid model combining white-box and black-box approaches for production line optimization and control."
    DTDFVocab:inputTo ProductionLineOptimizationEngine
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Aggregated and abstracted sensor data traces from physical assets, contextualized for specific manufacturing purposes."
    DTDFVocab:fromData InjectionMoldingTemperatureData, InjectionMoldingPressureData, ProductionLineFlowRateData
    DTDFVocab:inputTo DigitalShadowAggregationPipeline
]

instance ProcessParameterData : DTDFVocab:Data [
    base:desc "Normalized and temporally aggregated sensor data for performance monitoring and optimization."
    DTDFVocab:fromData RobotPositionData, RobotForceTorqueData
    DTDFVocab:inputTo DataPreprocessingPipeline
]

// C11: Enablers
instance DigitalShadowAggregationPipeline : DTDFVocab:Enabler [
    base:desc "Apache Kafka/Spark-based pipeline aggregating and abstracting digital shadow data traces for DT enrichment."
    DTDFVocab:enables DigitalShadowDataService
]

instance DataPreprocessingPipeline : DTDFVocab:Enabler [
    base:desc "Normalization, temporal aggregation, and feature extraction pipeline for sensor data preprocessing."
    DTDFVocab:enables DataQualityService
]

instance RobotDynamicsSimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulink-based simulation engine modeling robot dynamics with high-frequency data acquisition for adaptive control."
    DTDFVocab:enables RobotControlService
]

instance InjectionMoldingSimulationEngine : DTDFVocab:Enabler [
    base:desc "Multi-physics simulation engine (e.g., ANSYS) modeling thermal, pressure, and material flow dynamics in injection molding."
    DTDFVocab:enables InjectionMoldingOptimizationService, ProcessMonitoringService
]

instance ProductionLineOptimizationEngine : DTDFVocab:Enabler [
    base:desc "AI/ML-based optimization engine using predictive analytics for production line scheduling and resource allocation."
    DTDFVocab:enables ProductionPlanningService
]

instance MQTTDataTransmissionProtocol : DTDFVocab:Enabler [
    base:desc "MQTT-based protocol for lightweight, publish-subscribe communication between physical sensors and digital twin components."
    DTDFVocab:enables RealTimeDataService
]

instance SysMLModelingFramework : DTDFVocab:Enabler [
    base:desc "SysML-based framework for multi-layered system modeling (requirements, functional/logical architecture, physical layer)."
    DTDFVocab:enables ModelTransformationService
]

instance AADLComponentFramework : DTDFVocab:Enabler [
    base:desc "AADL-based framework describing component-connector structures and interfaces for modular DT architecture."
    DTDFVocab:enables ComponentIntegrationService
]

