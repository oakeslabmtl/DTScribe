]

// C1: Environment
instance ManufacturingDigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains InjectionMoldingSystem, RoboticsSystem, ProductionLineSystem
]

// C2: Components
instance InjectionMoldingSystem : DTDFVocab:Component [
    base:desc "Modular component representing injection molding machines and production lines with integrated digital twin capabilities."
    base:isContainedIn ManufacturingDigitalTwinEnvironment
]

instance RoboticsSystem : DTDFVocab:Component [
    base:desc "Modular component representing industrial robots with integrated state estimation and control capabilities."
    base:isContainedIn ManufacturingDigitalTwinEnvironment
]

instance ProductionLineSystem : DTDFVocab:Component [
    base:desc "Modular component representing continuous production lines with integrated optimization and planning services."
    base:isContainedIn ManufacturingDigitalTwinEnvironment
]

// C12: Relationships
instance ConformingModelRelationship : DTDFVocab:Relationship [
    base:desc "Hierarchical conforming model relationship derived from Digital Shadow Reference Model enabling customized concretizations."
    DTDFVocab:relatesTo DigitalShadowReferenceModel
    DTDFVocab:relatesTo InjectionMoldingProcessModel
    DTDFVocab:relatesTo RobotDynamicsModel
]

instance TraceabilityFramework : DTDFVocab:Relationship [
    base:desc "Transitive associations linking data traces to processing components and models ensuring consistency across DT instances."
    DTDFVocab:relatesTo ContextualDataTraces
    DTDFVocab:relatesTo DataPreprocessingPipeline
    DTDFVocab:relatesTo InjectionMoldingOptimizationService
]

instance PurposeDrivenDesign : DTDFVocab:Relationship [
    base:desc "Scope of responsibilities managed through purpose-driven design aligning data traces and processing logic with specific objectives."
