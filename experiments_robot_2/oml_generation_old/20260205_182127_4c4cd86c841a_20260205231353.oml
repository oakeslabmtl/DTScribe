    DTDFVocab:relatesTo ProductionPlanningService
]

instance HeterogeneousToolIntegration : DTDFVocab:Relationship [
    base:desc "Integration of heterogeneous modeling tools (SysML, Simulink, AADL) for multi-layered system descriptions."
