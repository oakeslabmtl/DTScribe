// C3: Physical sensing components
instance PhysicalObjectStateCollector : DTDFVocab:SensingComponent [
    base:desc "Collects raw state information from the physical object for the digital shadow as described in Document 1"
    DTDFVocab:producedData DigitalShadowMQTTStream
]

// C4: Data transmitted (digital shadow)
instance DigitalShadowMQTTStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalObjectStateCollector
    base:desc "One‑way MQTT data flow (Mosquitto) carrying contextual data traces from the physical object to the digital twin"
]

// C10: Data (aggregated contextual data)
instance AggregatedContextualData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces prepared for higher‑level models"
    DTDFVocab:fromData DigitalShadowMQTTStream
    DTDFVocab:inputTo DataPreprocessingEngine
]

// C11: Enablers
instance DataPreprocessingEngine : DTDFVocab:Enabler [
    base:desc "Software component that interprets, filters, aggregates and ensures quality of received shadow data before model integration"
    DTDFVocab:enables SimulationExecutionService
]

instance ModelTransformationEngine : DTDFVocab:Enabler [
    base:desc "Executes model‑to‑model transformations (e.g., SysML → Simulink) and couples white‑box simulations with black‑box ML models"
    DTDFVocab:enables SimulationExecutionService
]

// C6: Service
instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Runs combined analytical, geometric and behavioral simulations using transformed models and preprocessed data"
    DTDFVocab:provides AnalyticalInsightGeneration
]

// C17: Insight
instance AnalyticalInsightGeneration : DTDFVocab:Insight [
    base:desc "Generates insights by analysing simulation results and contextual data for decision support"
]

// C10: Models – MBSE and ADL artifacts
instance SysMLRequirementModel : DTDFVocab:Model [
    base:desc "SysML requirement diagram extracted from MBSE artifacts"
    DTDFVocab:inputTo ModelTransformationEngine
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML functional diagram defining system functions"
    DTDFVocab:inputTo ModelTransformationEngine
]

