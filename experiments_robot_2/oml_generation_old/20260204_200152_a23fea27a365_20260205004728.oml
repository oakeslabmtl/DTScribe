instance RobotIntrinsicStateSensor : DTDFVocab:SensingComponent [
    base:desc "Internal sensors providing intrinsic robot state data"
    DTDFVocab:producedData RobotIntrinsicStateDataTransmitted
]

instance SensorMeasurementsSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensors providing sensor measurements"
    DTDFVocab:producedData SensorMeasurementsDataTransmitted
]

instance RobotIntrinsicStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotIntrinsicStateSensor
    DTDFVocab:fromData RobotIntrinsicStateData
]

instance SensorMeasurementsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SensorMeasurementsSensor
    DTDFVocab:fromData SensorMeasurementsData
]

instance RobotIntrinsicStateData : DTDFVocab:Data [
    base:desc "Intrinsic robot state data from internal sensors"
    DTDFVocab:fromData RobotIntrinsicStateDataTransmitted
    DTDFVocab:inputTo SysMLEnabler, SimulinkEnabler
]

instance SensorMeasurementsData : DTDFVocab:Data [
    base:desc "Sensor measurements from robot's physical sensors"
    DTDFVocab:fromData SensorMeasurementsDataTransmitted
    DTDFVocab:inputTo SysMLEnabler, SimulinkEnabler
]

instance PhysicsBasedDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Physics-based white-box model using Simulink for dynamic simulations"
    DTDFVocab:inputTo SimulinkEnabler
]

instance MachineLearningNonlinearFrictionModel : DTDFVocab:Model [
    base:desc "Data-driven black-box machine learning model for nonlinear friction"
    DTDFVocab:inputTo MachineLearningEnabler
]

instance RFLPEnabler : DTDFVocab:Enabler [
    base:desc "RFLP methodology for Requirements, Functions, Logics, Physics"
    DTDFVocab:enables HeterogeneousEnvironmentConsistencyService
]

instance OOSEMEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for Object-Oriented Software Engineering"
    DTDFVocab:enables HeterogeneousEnvironmentConsistencyService
]

instance SPESEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for Software Product Line Engineering"
    DTDFVocab:enables HeterogeneousEnvironmentConsistencyService
]

instance SMArDTEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for System Modeling and Analysis"
    DTDFVocab:enables HeterogeneousEnvironmentConsistencyService
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for structural components (IBDs) and behavioral modeling"
    DTDFVocab:enables HeterogeneousEnvironmentConsistencyService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME architecture description language for component modeling"
    DTDFVocab:enables HeterogeneousEnvironmentConsistencyService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL for real-time embedded systems modeling"
    DTDFVocab:enables HeterogeneousEnvironmentConsistencyService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc for architectural description"
    DTDFVocab:enables HeterogeneousEnvironmentConsistencyService
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:enables HeterogeneousEnvironmentConsistencyService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for dynamic simulations"
    DTDFVocab:enables HeterogeneousEnvironmentConsistencyService
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ for detailed behavior and integration"
    DTDFVocab:enables HeterogeneousEnvironmentConsistencyService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java for detailed behavior and integration"
    DTDFVocab:enables HeterogeneousEnvironmentConsistencyService
]

instance MachineLearningEnabler : DTDFVocab:Enabler [
    base:desc "Machine learning for nonlinear friction modeling"
    DTDFVocab:enables HeterogeneousEnvironmentConsistencyService
]

instance HeterogeneousEnvironmentConsistencyService : DTDFVocab:Service [
    base:desc "Ensures consistency across heterogeneous modeling environments through traceable transformations between SysML and simulation tools"
    DTDFVocab:provides ModelConsistencyInsight
]

instance ModelConsistencyInsight : DTDFVocab:Insight [
    base:desc "Consistency maintained between SysML models and simulation tools for accurate physical effect capture"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity requires precise integration of physics-based and data-driven models to accurately represent nonlinear phenomena. Validation and verification include traceability checks between SysML models and simulation tools (e.g., Simulink), ensuring transformation correctness. Uncertainty is quantified using probabilistic latent variable models, while quality assurance involves cross-validation of model outputs for consistency and accuracy."
]