// C3: Physical sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor position encoder providing angular position of the permanent‑magnet synchronous motor shaft."
    DTDFVocab:producedData MotorAngleDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Gearbox encoder providing angular position of the cycloidal gearbox output."
    DTDFVocab:producedData GearboxAngleDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor electrical current of the permanent‑magnet synchronous motor."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

// C4: Physical‑to‑virtual interaction data transmitted
instance MotorAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Data instances
instance MotorAngleData : DTDFVocab:Data [
    base:desc "Structured time‑series of motor angle (radians) transmitted via MQTT."
    DTDFVocab:fromData MotorAngleDataTransmitted
    DTDFVocab:inputTo DataProcessingComponent
]

instance GearboxAngleData : DTDFVocab:Data [
    base:desc "Structured time‑series of gearbox angle (radians) transmitted via MQTT."
    DTDFVocab:fromData GearboxAngleDataTransmitted
    DTDFVocab:inputTo DataProcessingComponent
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Structured time‑series of motor electrical current (A) transmitted via MQTT."
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo DataProcessingComponent
]

// C10: Model instances
instance MotorSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model simulating motor electrical and mechanical behavior."
    DTDFVocab:inputTo DataProcessingComponent
]

instance GearboxSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model simulating gear transmission dynamics."
    DTDFVocab:inputTo DataProcessingComponent
]

instance FrictionSimulationModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model simulating joint friction characteristics."
    DTDFVocab:inputTo DataProcessingComponent
]

instance EngineeringModelSysML : DTDFVocab:Model [
    base:desc "SysML engineering model capturing structural and behavioral aspects of the joint."
    DTDFVocab:inputTo DataProcessingComponent
]

// C11: Enabler
instance DataProcessingComponent : DTDFVocab:Enabler [
    base:desc "Processing component consuming sensor and simulation data, computing derived torque, angular velocity, friction parameters and forwarding results to services."
    DTDFVocab:enables RealTimeVisualizationService, JointFrictionIdentificationService, ModelAdaptationService, DashboardMonitoringService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Renders live visualization of joint angles, torque, and friction state in a custom dashboard."
    DTDFVocab:provides MotorAngleVisualizationInsight, TorqueVisualizationInsight, FrictionStateVisualizationInsight
]

instance JointFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuously identifies joint friction using white‑box analytic and black‑box data‑driven models."
    DTDFVocab:provides FrictionParameterUpdateInsight, WearDetectionInsight, ControlAdjustmentRecommendationAction
]

instance ModelAdaptationService : DTDFVocab:Service [
    base:desc "Performs online model adaptation to support improved motion control."
    DTDFVocab:provides ModelUpdateAction, ImprovedMotionControlInsight
]

instance DashboardMonitoringService : DTDFVocab:Service [
    base:desc "Provides dashboards for monitoring and decision support, including maintenance scheduling."
    DTDFVocab:provides MaintenanceSchedulingRecommendationAction, TrajectoryReplanningRecommendationAction
]

// C17: Insights
instance MotorAngleVisualizationInsight : DTDFVocab:Insight [
    base:desc "Current motor angular position displayed in real‑time."
]

instance TorqueVisualizationInsight : DTDFVocab:Insight [
    base:desc "Current joint torque visualized in real‑time."
]

instance FrictionStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time display of friction state and identified parameters."
]

instance FrictionParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Updates to friction model parameters."
]

instance WearDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of wear or backlash changes."
]

instance ImprovedMotionControlInsight : DTDFVocab:Insight [
    base:desc "Insight indicating improved motion control quality after model adaptation."
]

// C17: Actions
instance ControlAdjustmentRecommendationAction : DTDFVocab:Action [
    base:desc "Recommendation for control adjustments based on friction identification."
    DTDFVocab:IsAutomatic false
]

instance ModelUpdateAction : DTDFVocab:Action [
    base:desc "Online model adaptation to update simulation parameters."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceSchedulingRecommendationAction : DTDFVocab:Action [
    base:desc "Recommendation for maintenance scheduling derived from insights."
    DTDFVocab:IsAutomatic false
]

instance TrajectoryReplanningRecommendationAction : DTDFVocab:Action [
    base:desc "Recommendation for trajectory re‑planning based on updated joint data."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time, continuous stream of data with near‑instantaneous processing. The computational models run at the same rate or faster than the sensor updates to enable on‑the‑fly friction model updates."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation comprises the physical asset (robot axis), an engineering model, simulation and data‑calculation models, a processing component that generates derived data, a dashboard for user interaction, and an AAS that links all components in a semantically coherent architecture."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the ideal (design/simulation) phase through the operated phase. Simulation models represent the ideal physics; live sensor data captures the manufacturing/operated reality, enabling continuous model refinement."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "High traceability between data traces and the models that generated them. Continuous comparison of simulated and measured signals validates the friction models. Uncertainties from load, temperature, and wear are considered by combining white‑box and black‑box approaches, with ongoing data‑driven refinement."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Live sensor data transmitted from the robot to the twin via MQTT, a lightweight publish/subscribe protocol typically running over TCP/IP."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of Asset Administration Shell (AAS) following the IEC/ISO standard for digital twins; SysML modeling adhering to ISO/IEC 15926 adaptation; simulation models based on MATLAB/Simulink which follows standard engineering modeling practices."
]