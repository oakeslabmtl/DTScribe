// C11: Enablers
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML tool for structural and behavioral modeling of robot axis components."
    DTDFVocab:enables RobotAxisModelingService
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink environment for friction model simulations and multi-physics analysis."
    DTDFVocab:enables RealTimeFrictionModelingService, MultiPhysicsSimulationService, ContinuousModelImprovementService
]

instance MQTTStreaming : DTDFVocab:Enabler [
    base:desc "MQTT protocol for real-time sensor data transmission from physical twin to digital shadow."
    DTDFVocab:enables LiveMeasurementService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) for linking data and models with metadata traceability."
    DTDFVocab:enables DataTraceabilityService
]

instance UnifiedDashboard : DTDFVocab:Enabler [
    base:desc "Unified dashboard (e.g., Grafana) for visualizing measured vs. simulated data and system health metrics."
    DTDFVocab:enables FrictionAnalysisVisualizationService, SystemHealthMonitoringService
]

instance ModelBasedSystemsEngineering : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering (MBSE) methodology for integrating heterogeneous models."
    DTDFVocab:enables MultiPhysicsSimulationService
]

instance DigitalShadowReferenceModel : DTDFVocab:Enabler [
    base:desc "Digital Shadow Reference Model (DSRM) for structuring the digital shadow with assets, data traces, and models."
    DTDFVocab:enables DigitalShadowEvolutionService, ScalableFrictionModelingService
]

instance SiemensSINUMERIK840Dsl : DTDFVocab:Enabler [
    base:desc "Siemens SINUMERIK 840D sl CNC controller for robot control via position, speed, or acceleration inputs."
    DTDFVocab:enables ControlImprovementService, OperationalDecisionService
]

// C6: Services
instance RealTimeFrictionModelingService : DTDFVocab:Service [
    base:desc "Combines white-box (analytical) and black-box (data-driven) models to identify static, kinetic, and viscous friction in real-time."
    DTDFVocab:provides StaticFrictionIdentificationInsight, KineticFrictionIdentificationInsight, ViscousFrictionIdentificationInsight
    DTDFVocab:provides FrictionCompensationParameterUpdateAction, MaintenanceRecommendationAction
]

instance MultiPhysicsSimulationService : DTDFVocab:Service [
    base:desc "Simulates motor, gearbox, and system behavior under varying conditions (load, temperature) for friction analysis."
    DTDFVocab:provides MultiPhysicsSimulationInsight
    DTDFVocab:provides ProcessOptimizationRecommendationAction, ToolSelectionRecommendationAction
]

instance DataTraceabilityService : DTDFVocab:Service [
    base:desc "Links simulated and measured data to understand deviations (e.g., due to wear or backlash) with metadata."
    DTDFVocab:provides DataSourceTraceabilityInsight, FrictionDeviationDetectionInsight
]

instance FrictionAnalysisVisualizationService : DTDFVocab:Service [
    base:desc "Unified dashboard displaying measured vs. simulated data, friction model outputs, and system health metrics."
    DTDFVocab:provides FrictionAnalysisDashboardInsight
]

instance ContinuousModelImprovementService : DTDFVocab:Service [
    base:desc "Updates friction models dynamically during operation to adapt to changes (e.g., wear, tool swaps)."
    DTDFVocab:provides AdaptiveFrictionModelInsight
    DTDFVocab:provides DynamicParameterUpdateAction
]

instance FrictionModelValidationService : DTDFVocab:Service [
    base:desc "Compares simulated vs. measured data to detect friction deviations and validate model accuracy."
    DTDFVocab:provides ModelValidationInsight
]

instance RobotAxisModelingService : DTDFVocab:Service [
    base:desc "Creates SysML structural and behavioral models of the robot axis components (motor, gearboxes)."
    DTDFVocab:provides RobotAxisModelInsight
]

instance ControlImprovementService : DTDFVocab:Service [
    base:desc "Provides parameter updates for CNC controllers (e.g., adjusting friction compensation gains)."
    DTDFVocab:provides CNCParameterUpdateInsight
    DTDFVocab:provides FrictionCompensationGainAdjustmentAction
]

instance OperationalDecisionService : DTDFVocab:Service [
    base:desc "Generates recommendations for process optimization and tool selection to minimize friction-induced errors."
    DTDFVocab:provides ProcessOptimizationInsight, ToolSelectionInsight
    DTDFVocab:provides RobotPathAdjustmentAction, ToolRecommendationAction
]

instance DigitalShadowEvolutionService : DTDFVocab:Service [
    base:desc "Continuously updates friction models to adapt to wear or environmental changes and ensures scalability."
    DTDFVocab:provides DigitalShadowEvolutionInsight
    DTDFVocab:provides ModelUpdateAction
]

instance ScalableFrictionModelingService : DTDFVocab:Service [
    base:desc "Extends methodology to other axes or robots while maintaining modular component reuse."
    DTDFVocab:provides ScalabilityInsight
]

instance LiveMeasurementService : DTDFVocab:Service [
    base:desc "Processes real-time sensor data (current, encoders) for friction analysis and system health monitoring."
    DTDFVocab:provides LiveMeasurementInsight
]

instance SystemHealthMonitoringService : DTDFVocab:Service [
    base:desc "Monitors system health metrics derived from friction analysis and operational data."
    DTDFVocab:provides SystemHealthInsight
]

