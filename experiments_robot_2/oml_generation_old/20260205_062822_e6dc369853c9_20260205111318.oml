]

instance GearwheelTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring gearwheel output torque (τ_G) after transmission."
    DTDFVocab:producedData GearwheelTorqueSensorDataTransmitted
]

instance SystemOutputTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring final system output torque (τ_out) after cycloidal gearbox."
