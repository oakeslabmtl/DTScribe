]

instance MultiAbstractionModelingService : DTDFVocab:Service [
    base:desc "Multi-abstraction modeling using RFLP methodology"
    DTDFVocab:provides MultiAbstractionModelingInsight
]

instance DataAggregationService : DTDFVocab:Service [
