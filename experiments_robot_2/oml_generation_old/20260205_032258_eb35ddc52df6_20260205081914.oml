// C3: Physical sensing components
instance OperationalLogSensor : DTDFVocab:SensingComponent [
    base:desc "Collects contextual data traces from physical system operations including sensor data and operational logs via one-way data flow mechanisms"
    DTDFVocab:producedData OperationalLogDataTransmitted
]

instance IoTSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real-time sensor feeds from IIoT protocols for manufacturing/industrial systems"
    DTDFVocab:producedData IoTSensorDataTransmitted
]

instance ExternalContextSensor : DTDFVocab:SensingComponent [
    base:desc "Aggregates external contextual traces relevant to system operation"
    DTDFVocab:producedData ExternalContextDataTransmitted
]

// C4: Physical-to-virtual interaction
instance OperationalLogDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalLogSensor
]

instance IoTSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IoTSensor
]

instance ExternalContextDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalContextSensor
]

// C10: Models/Data
instance RequirementsModel : DTDFVocab:Model [
    base:desc "MBSE requirements layer modeled using RFLP methodology (Requirements, Functions, Logics, Physics) across multiple abstraction layers"
    DTDFVocab:inputTo SysMLModelingEnabler, RFLPMethodologyEnabler
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "Functional architecture layer modeled using SysML IBDs and MontiArc component-based architecture"
    DTDFVocab:inputTo SysMLModelingEnabler, MontiArcEnabler
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Logical architecture layer with interface definitions and composition rules using ACME/AADL"
    DTDFVocab:inputTo ACMEAADLEngine, MontiArcEnabler
]

instance ProductTechnicalModel : DTDFVocab:Model [
    base:desc "Product/technical layer with detailed behavioral and physics-based models"
    DTDFVocab:inputTo SimulinkEngine, CppJavaImplementationEnabler
]

instance DigitalShadowData : DTDFVocab:Data [
    base:desc "Passively collected contextual data traces from Digital Shadow mechanisms including sensor data, logs, and operational traces"
    DTDFVocab:fromData OperationalLogDataTransmitted, IoTSensorDataTransmitted, ExternalContextDataTransmitted
    DTDFVocab:inputTo DigitalShadowIntegrationEnabler
]

instance SimulationData : DTDFVocab:Data [
    base:desc "Data generated from simulation tools for validating system behavior under different scenarios"
    DTDFVocab:fromData IoTSensorDataTransmitted
    DTDFVocab:inputTo SimulinkEngine, HybridSimulationEnabler
]

instance HeterogeneousData : DTDFVocab:Data [
    base:desc "Aggregated data from disparate sources bridged for multi-notation/model tool interoperability"
    DTDFVocab:fromData OperationalLogDataTransmitted, ExternalContextDataTransmitted
    DTDFVocab:inputTo DataIntegrationEnabler
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML (Systems Modeling Language) for structuring system descriptions across multiple abstraction layers using IBDs and state machines"
    DTDFVocab:enables SystemArchitectureService, BehavioralModelingService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc for component-based modeling with automata and event-driven interactions"
    DTDFVocab:enables ComponentInteractionService, StatefulBehaviorService
]

instance ACMEAADLEngine : DTDFVocab:Enabler [
    base:desc "ACME/AADL for formal architecture description with interface definitions and composition rules"
    DTDFVocab:enables ArchitectureValidationService, InterfaceDefinitionService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed behavioral simulation, control system design, and co-simulation"
    DTDFVocab:enables SimulationValidationService, ControlSystemDesignService
]

instance HybridSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Generic discrete-event, continuous-time, or hybrid simulation platforms for system performance validation"
    DTDFVocab:enables PerformanceValidationService
]

instance CppJavaImplementationEnabler : DTDFVocab:Enabler [
    base:desc "General-purpose languages (C++/Java) for low-level implementation of DT components and control algorithms"
    DTDFVocab:enables ControlAlgorithmService, DataProcessingService
]

instance RFLPMethodologyEnabler : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements, Functions, Logics, Physics) methodology for multi-abstraction modeling and traceability"
    DTDFVocab:enables RequirementsTraceabilityService, MultiAbstractionModelingService
]

instance DigitalShadowIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Digital Shadow Reference Model for standardizing DS data structures and integration points with DT"
    DTDFVocab:enables DataAggregationService, DSIntegrationService
]

instance DataIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Tools and frameworks for bridging gaps between DS data formats and MBSE models"
    DTDFVocab:enables HeterogeneousDataIntegrationService
]

