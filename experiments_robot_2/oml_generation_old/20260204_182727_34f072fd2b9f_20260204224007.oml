// C1: Physical Asset Component
instance RobotMabiMax100 : DTDFVocab:Component [
    base:desc "Six‑axis industrial robot MABI MAX 100 equipped with permanent‑magnet synchronous motors and Siemens SINUMERIK 840D controller, used for high‑precision machining tasks"
]

// C2: MQTT Broker (communication infrastructure)
instance MqttBroker : DTDFVocab:Component [
    base:desc "MQTT broker that receives one‑way sensor streams from the robot and forwards them to the digital twin"
]

// C3: Sensing Components (physical sensors)
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the electric input current of each axis motor, streams floating‑point values via MQTT"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the joint output angle of each axis, streams floating‑point values via MQTT"
    DTDFVocab:producedData AngleDataTransmitted
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Torque sensor (τ) measuring motor torque for each axis, streams floating‑point values via MQTT"
    DTDFVocab:producedData TorqueDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Angular‑velocity sensor (ω) measuring joint speed, streams floating‑point values via MQTT"
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

// C4: Data transmitted via MQTT
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance AngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

// C5: Processed Data (post‑pre‑processing)
instance CurrentData : DTDFVocab:Data [
    base:desc "Floating‑point time series of motor input current after MQTT type conversion and unit validation"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo MqttPreprocessingEnabler
]

instance AngleData : DTDFVocab:Data [
    base:desc "Floating‑point time series of joint angle after MQTT preprocessing"
    DTDFVocab:fromData AngleDataTransmitted
    DTDFVocab:inputTo MqttPreprocessingEnabler
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Floating‑point time series of motor torque after MQTT preprocessing"
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo MqttPreprocessingEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Floating‑point time series of joint angular velocity after MQTT preprocessing"
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo MqttPreprocessingEnabler
]

// C6: Enablers (processing & simulation)
instance MqttPreprocessingEnabler : DTDFVocab:Enabler [
    base:desc "Preprocesses MQTT streams: type conversion to float, unit validation, and time‑alignment aggregation"
    DTDFVocab:enables DataValidationService, AggregationService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Executes white‑box Simulink models and integrates generated C++/Java code to compute performance KPIs"
    DTDFVocab:enables SimulationService
]

// C7: Services
instance DataValidationService : DTDFVocab:Service [
    base:desc "Validates sensor data ranges and units after preprocessing"
    DTDFVocab:provides DataQualityInsight
]

instance AggregationService : DTDFVocab:Service [
    base:desc "Aggregates time‑aligned sensor arrays into a coherent multi‑attribute dataset"
    DTDFVocab:provides AggregatedDataInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs Simulink and executable models to generate higher‑level performance indicators"
    DTDFVocab:provides CalculatedKPIInsight
]

// C8: Insights (derived from processing)
instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Indicates that incoming sensor data conforms to expected units and value ranges"
]

instance AggregatedDataInsight : DTDFVocab:Insight [
    base:desc "Represents the aggregated multi‑sensor dataset ready for simulation and analysis"
]

instance CalculatedKPIInsight : DTDFVocab:Insight [
    base:desc "Derived KPI such as trajectory repeatability error and motor‑load efficiency, with provenance from processing components and models"
]

// C9: Models (MBSE artifacts)
instance SysMLRequirementModel : DTDFVocab:Model [
    base:desc "SysML requirements model specifying performance and safety constraints for the MABI MAX 100 robot"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML functional architecture linking sensor and actuator functions of the robot cell"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME ADL specification of component connectors and interfaces for the manufacturing cell"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "White‑box Simulink model capturing the multi‑physics dynamics of the six‑axis robot"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance CppExecutableModel : DTDFVocab:Model [
    base:desc "Generated C++ executable implementing low‑level motion‑control algorithms"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

// C10: Environment (manufacturing cell)
instance ManufacturingCellEnvironment : DTDFVocab:Environment [
    base:contains RobotMabiMax100, MqttBroker
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "A Digital Twin, in contrast to a digital shadow, can provide active components that are capable of pushing data or commands back to the physical system. The twin therefore supports bi‑directional interaction, enabling control actions and feedback loops, although the documents do not detail specific command formats or validation mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows the Digital Shadow Reference Model, concretized as a component‑based architecture comprising an Asset, a Processing component, and Model elements; orchestration is achieved through Asset Administration Shells (AAS) that expose the asset’s data and invoke processing components, while the processing logic executes data‑calculation or simulation models to produce derived data traces, thereby coordinating the overall digital twin functionality."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle follows the MBSE abstraction hierarchy described in Document 1: a requirements stage, a functional‑architecture stage, a logical‑architecture stage and a product/technical (physics) stage. At each stage the system is represented by models in a suitable notation (e.g., SysML requirement diagrams, SysML internal‑block diagrams for functional architecture, ADL class‑connector diagrams such as ACME, AADL or MontiArc for logical architecture, and physics‑based simulation models or C++/Java code for the product layer). Transition between stages is managed by a concretisation step that maps the abstract reference concepts to concrete model elements, enforced by a formal conformance relation (Document 2). Lifecycle governance is achieved through the reference‑model‑based approach, which defines a set of admissible model elements and their traceable ‘originates‑from’ links, ensuring that every data trace and processing component can be traced back to its originating design artefact."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The reliability of the Digital Twin is tied to the correctness of its underlying models and the data transformation pipelines. The approach stresses traceability of model artifacts (e.g., from SysML to Simulink) and verification of model‑to‑model transformations to ensure semantic consistency. Validation activities include checking that the white‑box (physics‑based) and black‑box (data‑driven) model components accurately represent the physical phenomena, although specific uncertainty quantification or error‑correction mechanisms are not detailed in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Data from the physical controller (e.g., Siemens SINUMERIK 840D sl) are streamed to the digital shadow via MQTT, and the digital shadow is wrapped in an Asset Administration Shell to enable interoperability with other enterprise systems and external Digital Twins, following AAS‑based standards for protocol and data exchange."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT adheres to modeling standards defined by the SysML language for system structure and behavior, and to component‑connector ADL standards such as ACME, AADL and MontiArc. The reference model concept incorporates a formal conformance relation that maps concrete class‑diagram elements to the abstract reference concepts, providing a basis for interoperability across heterogeneous tools and stakeholder views. Conformance is established through explicit mappings (e.g., class‑to‑reference‑class) as described for class diagrams."
]