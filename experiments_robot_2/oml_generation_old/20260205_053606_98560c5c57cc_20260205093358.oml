// C3: Physical sensing components
instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted directly on the motor shaft providing sub-millimeter angular positioning accuracy for friction identification and dynamic behavior modeling. Part of dual encoder system to reduce backlash and positional uncertainty."
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearbox providing cross-verification of angular measurements with sub-millimeter accuracy. Works in tandem with motor encoder to ensure precise feedback for control loops."
    DTDFVocab:producedData SecondaryEncoderDataTransmitted
]

instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input current to the permanent magnet synchronous motor with real-time sampling for operational monitoring and torque calculation."
    DTDFVocab:producedData CurrentSensorDataTransmitted
]

instance AngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring output angle from the gearbox transmission with sub-millimeter precision for kinematic validation and dynamic behavior analysis."
    DTDFVocab:producedData AngleSensorDataTransmitted
]

// C4: Physical-to-virtual interaction
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
    base:desc "Time-series data of motor shaft angle transmitted via MQTT protocol for digital shadow aggregation."
]

instance SecondaryEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoder
    base:desc "Time-series data of gearbox output angle transmitted via MQTT protocol for cross-verification and backlash compensation."
]

instance CurrentSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
    base:desc "Real-time input current measurements transmitted via MQTT protocol for torque calculation and energy monitoring."
]

instance AngleSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngleSensor
    base:desc "Real-time output angle measurements transmitted via MQTT protocol for kinematic validation and dynamic behavior analysis."
]

// C10: Models/Data
instance RobotKinematicModel : DTDFVocab:Model [
    base:desc "Physics-based model of the six-axis serial robot's kinematic behavior including motor-gearbox coupling and axis coordination, implemented in MathWorks Simulink."
    DTDFVocab:inputTo SimulinkEnabler
]

instance RobotDynamicModel : DTDFVocab:Model [
    base:desc "Physics-based model of the robot's dynamic behavior including torque, velocity profiles, and operational constraints for simulation validation."
    DTDFVocab:inputTo SimulinkEnabler
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces including sensor readings, operational logs, and time-series data for performance analysis and fault detection."
    DTDFVocab:fromData MotorEncoderDataTransmitted, SecondaryEncoderDataTransmitted, CurrentSensorDataTransmitted, AngleSensorDataTransmitted
    DTDFVocab:inputTo SysMLEnabler, DigitalShadowEnabler
]

instance SimulationInputData : DTDFVocab:Data [
    base:desc "Processed simulation input data derived from aggregated sensor traces for executable simulation models in MathWorks Simulink."
    DTDFVocab:fromData MotorEncoderDataTransmitted, SecondaryEncoderDataTransmitted, CurrentSensorDataTransmitted, AngleSensorDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML modeling environment used for multi-layered modeling including Internal Block Diagrams (IBDs) to describe robot components, interfaces, and hierarchical architecture."
    DTDFVocab:enables DataAggregationService, VisualizationService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink platform for creating executable simulation models of the robot's dynamic behavior including kinematics, control loops, and physics validation."
    DTDFVocab:enables SimulationService
]

instance DigitalShadowEnabler : DTDFVocab:Enabler [
    base:desc "Digital Shadow Reference Model implemented via UML class diagrams to structure and process contextual data traces for manufacturing applications."
    DTDFVocab:enables DataAggregationService
]

instance MQTTProtocol : DTDFVocab:Enabler [
    base:desc "MQTT protocol enabling lightweight and efficient communication of sensor data from physical components to digital twin for IoT/industrial applications."
    DTDFVocab:enables DataTransmissionService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Service providing executable simulation models of the robot's behavior including dynamic interactions, motor-gearbox coupling, and physics-based validation."
    DTDFVocab:provides RobotBehaviorInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service supporting dashboard-based monitoring of the robot's state including real-time axis positions and operational metrics derived from aggregated data traces."
    DTDFVocab:provides OperationalStateInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Service passively collecting and processing contextual data traces for specific purposes including performance analysis and fault detection."
    DTDFVocab:provides DataQualityInsight
]

instance DataTransmissionService : DTDFVocab:Service [
    base:desc "Service managing the automated one-way data flow from physical components to digital twin via MQTT protocol for lightweight IoT communication."
    DTDFVocab:provides DataFlowInsight
]

// C17: Insights/Actions
instance RobotBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insights into the robot's dynamic behavior including torque, velocity profiles, and kinematic validation derived from simulation models."
]

instance OperationalStateInsight : DTDFVocab:Insight [
    base:desc "Real-time insights into the robot's operational state including axis positions, safety metrics, and performance indicators for monitoring."
]

instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Assessment of data quality through structured aggregation and abstraction of contextual traces without explicit validation mechanisms."
]

instance DataFlowInsight : DTDFVocab:Insight [
    base:desc "Insights into the automated one-way data flow characteristics including MQTT protocol efficiency and lightweight communication performance."
]

// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor providing precise motion control with real-time current and torque capabilities for the robot's actuation system."
]

instance CycloidalGearTransmission : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear transmission coupled with the motor to enable precise motion control and define actuation range and torque capabilities."
]

instance SINUMERIK840DslController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl CNC controller governing the robot's actuation with real-time processing for position, speed, and acceleration commands while enforcing safety constraints."
]

// C1: System Under Study
instance MabiMax100Robot : DTDFVocab:Component [
    base:desc "Six-axis serial robot MABI MAX 100 deployed in manufacturing environments requiring precise motion control, real-time monitoring, and safety compliance."
    base:isContainedIn ManufacturingEnvironment
]

instance RobotSafetyCell : DTDFVocab:Component [
    base:desc "Safety cell component of the MABI MAX 100 system ensuring operational safety compliance and collision avoidance in manufacturing environments."
    base:isContainedIn ManufacturingEnvironment
]

instance RobotAxisSystem : DTDFVocab:Component [
    base:desc "Hierarchical system of six individual axes with motor-gearbox coupling and joint interactions for complex kinematic and dynamic behavior modeling."
    base:isContainedIn ManufacturingEnvironment
]

// C12: Environment
instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:desc "Manufacturing domain environment where the MABI MAX 100 robot operates with requirements for precise motion control, real-time monitoring, and safety compliance."
    base:contains MabiMax100Robot, RobotSafetyCell, RobotAxisSystem
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system’s orchestration and coordination are implicitly tied to the integration of heterogeneous modeling tools and methodologies from Model-Based Systems Engineering (MBSE). The system may adopt architecture patterns such as component & connector perspectives (e.g., ACME, AADL, MontiArc, or SysML Internal Block Diagrams) to describe system structure, interfaces, and interconnections. Behavioral descriptions may be handled via state machines (SysML v1.7) or simulation tools like MathWorks Simulink, C++, or Java. Resource management and system-wide coordination are not explicitly detailed, but the document suggests a need for integrating multiple modeling notations and tools (e.g., ADLs for architecture, simulation tools for behavior) to achieve a comprehensive system description. The orchestration likely involves active components (e.g., Digital Twins) processing data from passive digital shadows, with no explicit mention of centralized vs. decentralized control mechanisms."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system’s horizontal integration is not explicitly detailed in the provided context. The document focuses on internal modeling methodologies (e.g., MBSE, ADLs, simulation tools) and the conceptual distinction between digital shadows (one-way data flow) and Digital Twins (active processing). There is no mention of external data exchange protocols, interoperability standards (e.g., OPC UA, MQTT, REST APIs), dependencies on enterprise systems, or integration patterns with other Digital Twins. The document does not provide specifics on how the system interacts with external stakeholders, systems, or ecosystems beyond its passive (shadow) and active (twin) components."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE) standards**, particularly leveraging **SysML** for modeling and **architecture description languages (ADLs)** such as **ACME**, **AADL**, and **MontiArc** for component-based system representation. Interoperability is facilitated through **multi-tool integration**, including **MathWorks Simulink** and general-purpose languages (**C++**, **Java**). While no explicit **industry standards** (e.g., ISO, IEC) or **certification frameworks** are mentioned, the use of **SysML v1.7** (supporting state machines) and **MontiArc Automaton** for behavioral modeling aligns with **modeling and simulation standards** in systems engineering. The **Digital Shadow Reference Model** (Fig. 1) implies adherence to **UML-based class modeling** for data aggregation and abstraction, though no compliance frameworks or interoperability protocols (e.g., OPC UA, FIWARE) are specified."
]