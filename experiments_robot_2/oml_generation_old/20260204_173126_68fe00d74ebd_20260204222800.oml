// ------------------------------------------------------
// C3: Physical sensing components
// ------------------------------------------------------
instance RobotCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Measures the robot joint input current"
    DTDFVocab:producedData CurrentDataPacket
]

instance RobotAngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Measures motor angular velocity of the robot joint"
    DTDFVocab:producedData VelocityDataPacket
]

instance RobotAxisPositionSensor : DTDFVocab:SensingComponent [
    base:desc "Measures first‑axis position of the industrial robotic manipulator"
    DTDFVocab:producedData PositionDataPacket
]

// ------------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// ------------------------------------------------------
instance CurrentDataPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotCurrentSensor
]

instance VelocityDataPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotAngularVelocitySensor
]

instance PositionDataPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotAxisPositionSensor
]

// ------------------------------------------------------
// C10: Data (raw traces)
// ------------------------------------------------------
instance CurrentRawData : DTDFVocab:Data [
    base:desc "Raw current trace from robot joint"
    DTDFVocab:fromData CurrentDataPacket
    DTDFVocab:inputTo LowPassFilterEnabler, SimulationEnabler, NeuralNetworkEnabler
]

instance VelocityRawData : DTDFVocab:Data [
    base:desc "Raw angular velocity trace from robot joint"
    DTDFVocab:fromData VelocityDataPacket
    DTDFVocab:inputTo LowPassFilterEnabler, SimulationEnabler, NeuralNetworkEnabler
]

instance PositionRawData : DTDFVocab:Data [
    base:desc "Raw position trace from robot first axis"
    DTDFVocab:fromData PositionDataPacket
    DTDFVocab:inputTo LowPassFilterEnabler, SimulationEnabler, NeuralNetworkEnabler
]

// ------------------------------------------------------
// C11: Enablers (processing components)
// ------------------------------------------------------
instance LowPassFilterEnabler : DTDFVocab:Enabler [
    base:desc "Applies a low‑pass filter to sensor traces to remove noise"
    DTDFVocab:enables RealTimeFrictionMonitoringService, PredictiveMaintenanceService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Executes the white‑box Simulink friction model using pre‑processed data"
    DTDFVocab:enables SimulationBasedOptimizationService, WhatIfScenarioExecutionService
]

instance NeuralNetworkEnabler : DTDFVocab:Enabler [
    base:desc "Runs a trained neural‑network model to predict friction trends from sensor data"
    DTDFVocab:enables PredictiveMaintenanceService, DataRepositoryService
]

instance ControlEnabler : DTDFVocab:Enabler [
    base:desc "Performs closed‑loop control adjustments based on friction insights"
    DTDFVocab:enables ClosedLoopControlService
]

instance RepositoryEnabler : DTDFVocab:Enabler [
    base:desc "Publishes all measured, simulated and reference values to Thingsboard via MQTT and AAS Executor"
    DTDFVocab:enables DataRepositoryService
]

// ------------------------------------------------------
// C10: Models (referenced by enablers)
// ------------------------------------------------------
instance WhiteBoxFrictionSimModel : DTDFVocab:Model [
    base:desc "Simulink dynamic model representing robot joint friction as white‑box physics"
    DTDFVocab:inputTo SimulationEnabler
]

instance NeuralNetworkFrictionModel : DTDFVocab:Model [
    base:desc "Neural network trained on incoming sensor traces to predict friction"
    DTDFVocab:inputTo NeuralNetworkEnabler
]

// ------------------------------------------------------
// C6: Services
// ------------------------------------------------------
instance RealTimeFrictionMonitoringService : DTDFVocab:Service [
    base:desc "Delivers real‑time friction monitoring based on filtered sensor data"
    DTDFVocab:provides FrictionAnomalyInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Detects early fault conditions and generates maintenance recommendations"
    DTDFVocab:provides MaintenanceRecommendationInsight
]

instance ClosedLoopControlService : DTDFVocab:Service [
    base:desc "Compensates internal joint friction via the robot controller in a closed‑loop"
    DTDFVocab:provides ControlCompensationAction
]

instance SimulationBasedOptimizationService : DTDFVocab:Service [
    base:desc "Optimises machining parameters through simulation‑based evaluation of friction models"
    DTDFVocab:provides ParameterOptimizationInsight
]

instance WhatIfScenarioExecutionService : DTDFVocab:Service [
    base:desc "Executes what‑if scenarios to assess impact of parameter changes on friction and quality"
    DTDFVocab:provides ScenarioOutcomeInsight
]

instance DataRepositoryService : DTDFVocab:Service [
    base:desc "Stores all measured, simulated and reference values in Thingsboard for downstream visualization and product‑quality prediction"
    DTDFVocab:provides DataVisualizationInsight
]

// ------------------------------------------------------
// C17: Insights / Actions
// ------------------------------------------------------
instance FrictionAnomalyInsight : DTDFVocab:Insight [
    base:desc "Detects abnormal friction levels indicating potential mechanical issues"
]

instance MaintenanceRecommendationInsight : DTDFVocab:Insight [
    base:desc "Generates a maintenance schedule based on predicted friction degradation"
]

instance ControlCompensationAction : DTDFVocab:Action [
    base:desc "Automatically adjusts controller set‑points to compensate identified friction"
    DTDFVocab:IsAutomatic true
]

instance ParameterOptimizationInsight : DTDFVocab:Insight [
    base:desc "Identifies optimal machining parameters that minimise friction while preserving precision"
]

instance ScenarioOutcomeInsight : DTDFVocab:Insight [
    base:desc "Shows predicted outcomes of hypothetical parameter changes on friction and product quality"
]

instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides visual dashboards of stored data to support quality prediction"
]

// ------------------------------------------------------
// C19: Tooling & Enablers (infrastructure)
// ------------------------------------------------------
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker that forwards JSON messages on hierarchical topics to the AAS Executor"
    DTDFVocab:enables RepositoryEnabler
]

instance AASExecutor : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell executor that interprets AAS sub‑models, links data traces to SysML identification points and stores them"
    DTDFVocab:enables RepositoryEnabler
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture adopts a model‑driven approach: the robot’s physical structure is described with a SysML model and its friction dynamics with executable simulation models (e.g., Simulink). Both models and their metadata are encapsulated in an Asset Administration Shell (AAS). An automated pipeline continuously ingests live sensor data from the robot, triggers the simulation models, updates the AAS with computed results, and pushes the refreshed data to a ThingsBoard dashboard via MQTT. Thus the constellation consists of three coordinated layers – the physical robot, the AAS‑based digital twin, and the IoT/visualisation platform – orchestrated by the pipeline that handles data acquisition, model execution, and result dissemination."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows a Model‑Based Systems‑Engineering (MBSE) sequence: first requirements are modelled, then a functional architecture, followed by a logical architecture and finally a product/technical layer. These stages are represented with SysML and component‑&‑connector ADLs such as ACME, AADL, MontiArc or SysML IBDs. After the abstract stages, a concretization step instantiates the Digital‑Shadow reference model into a concrete Realisation; this is achieved by defining a conformance relation (a mapping of reference concepts to concrete classes) as described in the reference‑model approach. Transition between stages is managed by the 'originates‑from' traceability links that connect data traces to the processing components that generated them, thereby providing governance over the lifecycle through traceable data provenance."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by continuously updating model parameters with live data streams. Validation and verification are supported by the traceability links defined in the reference model, enabling verification of model transformations (e.g., SysML to Simulink) and back‑tracing of derived data to their source models. Uncertainty is managed by combining white‑box physics models with black‑box statistical models and by employing adaptive control loops that detect deviations in friction behavior for early fault detection. Quality assurance processes include transitive traceability, runtime monitoring of prediction error, and automatic triggering of model re‑training or parameter recalibration when deviations exceed predefined thresholds."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The implementation relies on an MQTT broker that provides a lightweight, publish‑subscribe message transport (MQTT) with hierarchical topics and optional read/write permissions. Data are encoded as JSON. The MQTT network connects the robot’s preprocessing unit, the AAS Executor, and the ThingsBoard IoT platform used for visualization. Communication is broker‑centric; no explicit bandwidth, latency, or redundancy specifications are given, but MQTT’s design offers low overhead and supports reliable delivery via QoS levels. Security is implied through topic‑based permissioning, but specific security protocols are not detailed."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The twin employs MQTT as the publish/subscribe protocol and the ThingsBoard platform for real‑time IoT data collection, storage and visualisation, ensuring compatibility with any MQTT‑enabled device. The Asset Administration Shell (AAS) provides a standards‑based wrapper that follows the Industry 4.0 AAS specification, exposing structural (SysML) and behavioural (Simulink) models via the Functional Mock‑up Interface (FMI) for multi‑domain model exchange. These standards enable seamless data exchange with external enterprise systems, production‑planning tools, and other digital twins."
]