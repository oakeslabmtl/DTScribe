// Component representing the first rotary axis of the MABI MAX 100 robot
instance MabiMax100FirstAxis : DTDFVocab:Component [
    base:desc "First rotary axis of the MABI MAX 100 industrial robot comprising a permanent‑magnet synchronous motor, gearwheel gearbox, and cycloidal gearbox, used for precision machining tasks."
]

// Environment containing the axis component
instance RobotEnvironment : DTDFVocab:Environment [
    base:contains MabiMax100FirstAxis
]

// Physical sensing components
instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted on the permanent‑magnet synchronous motor."
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance SecondaryEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder located behind the gearbox measuring output shaft position."
    DTDFVocab:producedData SecondaryEncoderDataTransmitted
]

instance CurrentSensorSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring the motor current."
    DTDFVocab:producedData CurrentSensorDataTransmitted
]

instance AxisAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Angle sensor for the axis output."
    DTDFVocab:producedData AxisAngleSensorDataTransmitted
]

// Data transmitted via MQTT broker
instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance SecondaryEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryEncoderSensor
]

instance CurrentSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensorSensor
]

instance AxisAngleSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AxisAngleSensor
]

// Collected data stored in DTML
instance MotorEncoderData : DTDFVocab:Data [
    base:desc "Encoded position data from the motor encoder mounted on the permanent‑magnet synchronous motor."
    DTDFVocab:inputTo AssetAdministrationShell, SimulinkModelEnabler
    DTDFVocab:fromData MotorEncoderDataTransmitted
]

instance SecondaryEncoderData : DTDFVocab:Data [
    base:desc "Output shaft position data from the secondary encoder behind the gearbox."
    DTDFVocab:inputTo AssetAdministrationShell, SimulinkModelEnabler
    DTDFVocab:fromData SecondaryEncoderDataTransmitted
]

instance CurrentSensorData : DTDFVocab:Data [
    base:desc "Motor current measurement data."
    DTDFVocab:inputTo AssetAdministrationShell, SimulinkModelEnabler
    DTDFVocab:fromData CurrentSensorDataTransmitted
]

instance AxisAngleData : DTDFVocab:Data [
    base:desc "Axis output angle data."
    DTDFVocab:inputTo AssetAdministrationShell, SimulinkModelEnabler
    DTDFVocab:fromData AxisAngleSensorDataTransmitted
]


// Enablers providing services
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker for live data transport of sensor streams from the robot's CNC controller."
    DTDFVocab:enables RealTimeDataTransmissionService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) providing semantic description of the axis and encapsulating data and models."
    DTDFVocab:enables MaintenanceService
]

instance SimulinkModelEnabler : DTDFVocab:Enabler [
    base:desc "Matlab/Simulink simulation model enabling real‑time simulation of motor, gearbox, and friction models."
    DTDFVocab:enables FrictionModelSimulationService, DataComparisonService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Custom dashboard for visualization of joint kinematics, friction estimates, and action recommendations."
    DTDFVocab:enables OperatorDecisionSupportService
]


// Services delivering insights and actions
instance RealTimeDataTransmissionService : DTDFVocab:Service [
    base:desc "Transmits sensor data streams in real‑time via MQTT from the robot's CNC controller."
]

instance FrictionModelSimulationService : DTDFVocab:Service [
    base:desc "Simulates friction models of the first rotary axis and delivers updated friction parameters to the controller."
    DTDFVocab:provides FrictionTrendInsight, ControllerParameterUpdateAction
]

instance DataComparisonService : DTDFVocab:Service [
    base:desc "Compares simulated joint kinematics and friction against measured data."
    DTDFVocab:provides ComparisonInsight
]

instance MaintenanceService : DTDFVocab:Service [
    base:desc "Provides maintenance scheduling insights and actions based on wear trends."
    DTDFVocab:provides MaintenanceSchedulingInsight, MaintenanceScheduleAction
]

instance OperatorDecisionSupportService : DTDFVocab:Service [
    base:desc "Provides operator decision support through dashboards displaying friction estimates, wear trends, and maintenance recommendations."
    DTDFVocab:provides OperatorDecisionSupportInsight
]


// Insights derived from data and models
instance FrictionTrendInsight : DTDFVocab:Insight [
    base:desc "Friction estimates and trends derived from simulation and sensor data, informing controller tuning."
]

instance ComparisonInsight : DTDFVocab:Insight [
    base:desc "Comparison between simulated and measured joint kinematics and friction, highlighting discrepancies."
]

instance MaintenanceSchedulingInsight : DTDFVocab:Insight [
    base:desc "Maintenance scheduling recommendation based on wear trends and friction analysis."
]

instance OperatorDecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Operator decision support insights displayed on dashboards with friction estimates and wear data."
]


// Actions triggered by services
instance ControllerParameterUpdateAction : DTDFVocab:Action [
    base:desc "Update of controller parameters based on friction estimates."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceScheduleAction : DTDFVocab:Action [
    base:desc "Scheduling maintenance tasks according to wear trends and predictions."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Shadow produces friction estimates and torque corrections that can be transmitted back to the CNC controller to adjust motor commands for improved motion accuracy, acting as a feed‑forward compensation source."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time operation; sensor data are streamed at the native update rate of the robot’s controllers (typically in the millisecond range), enabling on‑line model identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Physical robot and sensors → MQTT broker → Digital Shadow (processing component using AAS‑defined models) → dashboard display; the Twin orchestrates data ingestion, model execution, and user interface."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (ideal modeling of motor and gearbox dynamics), Manufacturing (physical hardware with embedded sensors), and Operation (online data streaming and friction identification during machine usage)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "White‑box analytical friction models provide physics‑based fidelity; black‑box models capture unmodeled dynamics; continuous parameter identification validates models by comparing simulated and measured torque/velocity; uncertainties due to wear, temperature, and load variations are addressed through real‑time adaptation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted via MQTT over TCP/IP on Ethernet; the Digital Shadow subscribes to MQTT topics; Asset Administration Shells expose metadata through a RESTful API; the system relies on standard OPC UA for AAS communication."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for model definition, Asset Administration Shell (OPC UA) for semantic asset description, MQTT protocol for real‑time data exchange, and Simulink for simulation."
]