// C3: Physical sensing component (inferred from digital‑shadow description)
instance PhysicalStateSensor : DTDFVocab:SensingComponent [
    base:desc "Automated capture of the physical object's state used for the one‑way digital‑shadow data flow."
    DTDFVocab:producedData PhysicalStateDataTransmitted
]

// C4: Physical‑to‑virtual interaction – data transmitted
instance PhysicalStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalStateSensor
]

// C5: Data (digital shadow)
instance DigitalShadowDataTrace : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces representing the digital shadow as defined by the reference‑model UML class diagram."
    DTDFVocab:fromData PhysicalStateDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

// C10: Models / Data
instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "Structural description captured in SysML block‑definition and internal‑block diagrams."
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral description captured in SysML state‑machine diagrams (v1.7)."
    DTDFVocab:inputTo SysMLEnabler
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "Dynamic behavior represented by a MathWorks Simulink white‑box simulation model."
    DTDFVocab:inputTo SimulinkEnabler
]

instance MachineLearningPredictorModel : DTDFVocab:Model [
    base:desc "Black‑box machine‑learning predictor model incorporated for insight generation."
    DTDFVocab:inputTo MLFrameworkEnabler
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML toolchain used to capture requirements, functional, logical and physical architectures."
    DTDFVocab:enables DataProcessingService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for executing white‑box simulation models."
    DTDFVocab:enables DataProcessingService
]

instance MLFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Machine‑learning framework (e.g., TensorFlow or PyTorch) executing black‑box predictor models."
    DTDFVocab:enables InsightGenerationService
]

instance IntegrationCodeEnabler : DTDFVocab:Enabler [
    base:desc "General‑purpose programming (C++/Java) integrating models, runtime observations and services."
    DTDFVocab:enables DashboardVisualizationService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Runtime execution layer that consumes digital‑shadow data traces and invokes engineering/simulation models."
    DTDFVocab:enables DataProcessingService
]

// C6: Services
instance DataProcessingService : DTDFVocab:Service [
    base:desc "Processing component that consumes input traces, applies engineering, simulation or data‑calculation models and produces output traces constituting the digital shadow."
    DTDFVocab:provides JointFrictionLevelInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Operator dashboard visualising continuous multi‑physics aware insights for system‑health assessment."
    DTDFVocab:provides VisualDashboardInsight
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Decision‑support service that enables human operators to trigger corrective actions based on insight confidence."
    DTDFVocab:provides TriggerCorrectiveAction
]

instance InsightGenerationService : DTDFVocab:Service [
    base:desc "Service that derives high‑level insights from machine‑learning predictor outputs."
    DTDFVocab:provides JointFrictionLevelInsight
]

// C17: Insights
instance JointFrictionLevelInsight : DTDFVocab:Insight [
    base:desc "Identification of joint friction levels derived from processed digital‑shadow data."
]

instance VisualDashboardInsight : DTDFVocab:Insight [
    base:desc "Visual representation of system health and multi‑physics insights on operator dashboards."
]

// C18: Actions
instance TriggerCorrectiveAction : DTDFVocab:Action [
    base:desc "Human‑initiated corrective action to address identified issues."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "In contrast to a digital shadow, a Digital Twin can provide active components that interpret incoming data and generate command messages that are sent back to the physical system, enabling bidirectional interaction. The documents do not specify command formats, protocols, or validation mechanisms, only that the Twin is capable of pushing data to the physical object."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin lifecycle described in the documents follows the Model‑Based Systems‑Engineering (MBSE) development flow. It starts with the requirements abstraction, proceeds to functional architecture, then logical architecture, and finally the product/technical layer where the concrete implementation resides. At each stage the system is represented by models in languages such as SysML, ADLs (e.g., ACME, AADL, MontiArc) and may be refined into simulation or code artifacts. Transition between stages is managed by mapping abstract concepts to concrete realizations (concretization) and by maintaining traceability through the ‘originates‑from’ association. Governance is implicit in the need to keep the concrete model conformant to the reference digital‑shadow model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The approach stresses traceability of every model and data artifact to its origin and mandates verification of model transformations (e.g., from SysML specifications to simulation models). Fidelity requirements are addressed by combining white‑box physics models with black‑box data‑driven models and by validating simulated outputs against measured sensor data. Uncertainty is recognized as stemming from model simplifications and data noise; quality assurance includes systematic verification of transformation correctness and continuous validation loops that compare digital‑twin predictions with real‑world observations."
]