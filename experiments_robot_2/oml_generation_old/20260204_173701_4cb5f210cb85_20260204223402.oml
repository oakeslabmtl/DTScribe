// C3: Physical sensing components
instance RobotStateSensor : DTDFVocab:SensingComponent [
    base:desc "Intrinsic robot state data sensor publishing robot pose, joint angles, velocities via MQTT."
    DTDFVocab:producedData RobotStateMQTTStream
]

instance FrictionMeasurementSensor : DTDFVocab:SensingComponent [
    base:desc "Friction‑related measurement sensor publishing friction coefficients and forces via MQTT."
    DTDFVocab:producedData FrictionMQTTStream
]

// C4: Physical-to-virtual interaction – data transmitted
instance RobotStateMQTTStream : DTDFVocab:DataTransmitted [
    base:desc "MQTT publish/subscribe data stream carrying robot state measurements (pose, joint angles, velocities)."
    DTDFVocab:producedFrom RobotStateSensor
]

instance FrictionMQTTStream : DTDFVocab:DataTransmitted [
    base:desc "MQTT publish/subscribe data stream carrying friction measurement data (coefficients, forces)."
    DTDFVocab:producedFrom FrictionMeasurementSensor
]

// C10: Data objects
instance RobotStateData : DTDFVocab:Data [
    base:desc "Robot state data (pose, joint angles, velocities) received from MQTT stream."
    DTDFVocab:fromData RobotStateMQTTStream
    DTDFVocab:inputTo MosquittoBroker
]

instance FrictionData : DTDFVocab:Data [
    base:desc "Friction measurement data (coefficients, forces) received from MQTT stream."
    DTDFVocab:fromData FrictionMQTTStream
    DTDFVocab:inputTo MosquittoBroker
]

// C11: Enablers
instance MosquittoBroker : DTDFVocab:Enabler [
    base:desc "Mosquitto MQTT broker that receives publications from physical sensors and forwards to downstream digital models."
    DTDFVocab:enables HybridDigitalTwinService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation engine executing the physics‑based white‑box model."
    DTDFVocab:enables HybridDigitalTwinService
]

instance MachineLearningEngine : DTDFVocab:Enabler [
    base:desc "Machine‑learning runtime environment executing the black‑box latent‑variable model."
    DTDFVocab:enables HybridDigitalTwinService
]

instance ThingsboardPlatform : DTDFVocab:Enabler [
    base:desc "Thingsboard IoT platform that consumes MQTT streams for visualization and further analytics."
    DTDFVocab:enables HybridDigitalTwinService
]

// C6: Services
instance HybridDigitalTwinService : DTDFVocab:Service [
    base:desc "Hybrid composition service that integrates the Simulink white‑box model with the ML black‑box model, exposing combined insights."
    DTDFVocab:provides InterpretabilityInsight, NonLinearCaptureInsight
]

// C17: Insights
instance InterpretabilityInsight : DTDFVocab:Insight [
    base:desc "Provides interpretability of the system behavior derived from the white‑box Simulink model."
]

instance NonLinearCaptureInsight : DTDFVocab:Insight [
    base:desc "Captures nonlinear effects identified by the black‑box ML latent‑variable model."
]

// C10: Models/Data (white‑box and black‑box)
instance SimulinkDynamicsModel : DTDFVocab:Model [
    base:desc "Physics‑based white‑box dynamic simulation model of the robot, built in MathWorks Simulink."
    DTDFVocab:inputTo SimulinkEngine
]

instance MLLatentVariableModel : DTDFVocab:Model [
    base:desc "Data‑driven black‑box latent‑variable model capturing nonlinear robot dynamics, trained with machine learning."
    DTDFVocab:inputTo MachineLearningEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "A digital twin can include active components that push control or command information back to the physical system, unlike the passive digital shadow (Document 1). The provided documents do not detail the specific command types, message formats, validation, authentication, feedback loops, conflict resolution, or confirmation mechanisms used for this reverse flow."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through verification and traceability of model transformations (e.g., SysML to simulation models). Validation depends on the correctness of the underlying models and the data processing pipeline. Reliability is tied to model accuracy; uncertainty arises from model approximations and data quality, and quality assurance is achieved via systematic verification of transformations and maintained traceability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical network infrastructure described relies on the MQTT protocol implemented by Mosquitto (Document 2) together with an open‑source IoT platform such as Thingsboard (Document 2). This implies a client‑server (publisher‑subscriber) topology over IP networks, where edge devices act as MQTT clients communicating with a central broker that may be hosted on‑premise or in the cloud. No explicit bandwidth, latency, reliability, redundancy, or security (e.g., TLS) requirements are given beyond the use of MQTT."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment of the digital shadow/twin can be cloud‑based, as illustrated by the CNC‑machine digital shadow approach that employs cloud‑based technologies (Document 2). Platforms like Thingsboard can be run on cloud, edge, or on‑premise environments, providing scalability and availability, but the documents do not specify exact computational, storage, or reliability specifications."
]