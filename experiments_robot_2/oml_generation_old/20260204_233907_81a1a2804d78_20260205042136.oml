import DTDFVocab
instance FrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Friction identification insights used to refine robot control algorithms for improved motion accuracy"
]

instance TraceableDataLinkingInsight : DTDFVocab:Insight [
    base:desc "Traceable data linking simulation results to physical measurements for informed parameter updates"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of robot state and simulation results for monitoring and decision making"
]

instance TwinningProcessInsight : DTDFVocab:Insight [
    base:desc "Purpose-driven methodology for digital twin realization involving problem identification, asset/model analysis, simulation model creation, and data identification"
]

instance SysMLModelingInsight : DTDFVocab:Insight [
    base:desc "Structural model insights from SysML BDD and IBD"
]

instance AASManagementInsight : DTDFVocab:Insight [
    base:desc "Asset management insights from Asset Administration Shells"
]

instance MQTTDataStreamingInsight : DTDFVocab:Insight [
    base:desc "Real-time data streaming insights via MQTT protocol"
]

instance ControlAlgorithmRefinement : DTDFVocab:Action [
    base:desc "Refine robot control algorithms for improved motion accuracy based on friction identification and traceable data",
    DTDFVocab:IsAutomatic false
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous multi-physics-aware identification of joint friction using white-box and black-box models",
    DTDFVocab:provides FrictionIdentificationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Integrated visualization in unified dashboard",
    DTDFVocab:provides VisualizationInsight
]

instance ControlRefinementService : DTDFVocab:Service [
    base:desc "Motion accuracy improvement through friction model refinement for robot control algorithms",
    DTDFVocab:provides ControlAlgorithmRefinement
]

instance TwinningProcessService : DTDFVocab:Service [
    base:desc "Purpose-driven methodology for digital twin realization following steps from [15] for concrete realization of DSRM",
    DTDFVocab:provides TwinningProcessInsight
]

instance SysMLModelingService : DTDFVocab:Service [
    base:desc "Structural modeling using SysML",
    DTDFVocab:provides SysMLModelingInsight
]

instance AASManagementService : DTDFVocab:Service [
    base:desc "Asset management using Asset Administration Shells",
    DTDFVocab:provides AASManagementInsight
]

instance MQTTDataStreamingService : DTDFVocab:Service [
    base:desc "Data streaming via MQTT protocol",
    DTDFVocab:provides MQTTDataStreamingInsight
]

instance SysML : DTDFVocab:Enabler [
    base:desc "SysML for system modeling",
    DTDFVocab:enables SysMLModelingService
]

instance MATLABSimulink : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink for simulation",
    DTDFVocab:enables FrictionIdentificationService, VisualizationService
]

instance AssetAdministrationShells : DTDFVocab:Enabler [
    base:desc "Asset Administration Shells for asset management",
    DTDFVocab:enables AASManagementService
]

instance MQTT : DTDFVocab:Enabler [
    base:desc "MQTT for data streaming",
    DTDFVocab:enables MQTTDataStreamingService
]

instance DashboardVisualization : DTDFVocab:Enabler [
    base:desc "Dashboard visualization tools",
    DTDFVocab:enables VisualizationService
]

instance SysMLBDDModel : DTDFVocab:Model [
    base:desc "SysML Block Definition Diagram for structural modeling of first axis",
    DTDFVocab:inputTo SysML
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram for structural modeling of first axis",
    DTDFVocab:inputTo SysML
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Coulomb-Viscous friction model for joint friction identification",
    DTDFVocab:inputTo MATLABSimulink
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Stribeck friction model for joint friction identification",
    DTDFVocab:inputTo MATLABSimulink
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Dahl friction model for joint friction identification",
    DTDFVocab:inputTo MATLABSimulink
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "LuGre friction model for joint friction identification",
    DTDFVocab:inputTo MATLABSimulink
]

instance AssetAdministrationShellsModel : DTDFVocab:Model [
    base:desc "Asset Administration Shell model for MABI MAX 100 robot first axis",
    DTDFVocab:inputTo AssetAdministrationShells
]

instance PermanentMagnetSynchronousMotorActing : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor for first axis of MABI MAX 100 robot, with input current I_M and output torque τ_M"
]

instance GearwheelActing : DTDFVocab:ActingComponent [
    base:desc "Gearwheel in first axis of MABI MAX 100 robot, with torque τ_G"
]

instance CycloidalGearboxActing : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gearbox in first axis of MABI MAX 100 robot, with torque τ_out"
]

instance SinumerikControllerActing : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl CNC controller controlling axes via position, speed, or acceleration inputs"
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on motor for first axis of MABI MAX 100 robot",
    DTDFVocab:producedData RobotSensorDataStream
]

instance SecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder behind gearbox for first axis of MABI MAX 100 robot",
    DTDFVocab:producedData RobotSensorDataStream
]

instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring input current for permanent magnet synchronous motor",
    DTDFVocab:producedData RobotSensorDataStream
]

instance SimulationOutputSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor for simulated data outputs in digital twin",
    DTDFVocab:producedData SimulatedDataTransmitted
]

instance RobotSensorDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder, SecondaryEncoder, CurrentSensor
]

instance SimulatedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulationOutputSensor
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Position data from motor encoder",
    DTDFVocab:fromData RobotSensorDataStream,
    DTDFVocab:inputTo MATLABSimulink, DashboardVisualization
]

instance GearboxOutputPositionData : DTDFVocab:Data [
    base:desc "Gearbox output position data (axis output angle)",
    DTDFVocab:fromData RobotSensorDataStream,
    DTDFVocab:inputTo MATLABSimulink, DashboardVisualization
]

instance MotorInputCurrentData : DTDFVocab:Data [
    base:desc "Motor input current data",
    DTDFVocab:fromData RobotSensorDataStream,
    DTDFVocab:inputTo MATLABSimulink, DashboardVisualization
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Torque data for first axis",
    DTDFVocab:fromData RobotSensorDataStream,
    DTDFVocab:inputTo MATLABSimulink, DashboardVisualization
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity data for first axis",
    DTDFVocab:fromData RobotSensorDataStream,
    DTDFVocab:inputTo MATLABSimulink, DashboardVisualization
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Acceleration data for first axis",
    DTDFVocab:fromData RobotSensorDataStream,
    DTDFVocab:inputTo MATLABSimulink, DashboardVisualization
]

instance SimulatedMotorOutputData : DTDFVocab:Data [
    base:desc "Simulated motor output (r_M)",
    DTDFVocab:fromData SimulatedDataTransmitted,
    DTDFVocab:inputTo DashboardVisualization
]

instance SimulatedGearwheelOutputData : DTDFVocab:Data [
    base:desc "Simulated gearwheel output (r_G)",
    DTDFVocab:fromData SimulatedDataTransmitted,
    DTDFVocab:inputTo DashboardVisualization
]

instance SimulatedOutputData : DTDFVocab:Data [
    base:desc "Simulated output (r_out)",
    DTDFVocab:fromData SimulatedDataTransmitted,
    DTDFVocab:inputTo DashboardVisualization
]

instance FirstAxisEnvironment : DTDFVocab:Environment [
    base:desc "First axis of MABI MAX 100 industrial robot with maximum working range [-90°, 90°] and maximum speed 75°/s",
    base:contains PermanentMagnetSynchronousMotorActing, GearwheelActing, CycloidalGearboxActing, SinumerikControllerActing, MotorEncoder, SecondaryEncoder, CurrentSensor
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time data streaming with live measurements during robot operation, enabling immediate synchronization between physical system state and digital shadow representations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose-driven digital shadow structured around the Digital Shadow Reference Model (DSRM), with concrete incarnations of Purpose (FrictionDerivation), Asset (Mabi), DataTraces (e.g., I_M, r_M), Processing components (Simulation M, Simulation GW), and simulation models (SysML, Simulink) linked via MQTT data streams."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "As-operated phase, capturing real-time operational data during robot use, including wear effects, tool changes, and application-specific variations in joint friction."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation through comparison of simulated data versus measured reference data to detect friction loss, with multi-physics-aware identification using white-box (analytical) and black-box (data-driven) friction models to ensure accuracy of friction dynamics."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol for real-time streaming of sensor data (current, position, torque) from physical robot to digital shadow, with data traces structured as time-series arrays of torque and angular velocity values."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Asset Administration Shells (AAS) for industrial asset modeling, SysML for system architecture description, and Industrie 4.0 standards for digital shadow implementation."
]