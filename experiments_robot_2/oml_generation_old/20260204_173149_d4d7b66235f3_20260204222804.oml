// -------------------------------------------------------
// C3: Physical sensing components
// -------------------------------------------------------
instance JointTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring joint torque/force related to friction, operating loads, and temperature."
    DTDFVocab:producedData JointTorqueDataTransmitted
]

instance JointLoadSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring operational load on robot joints."
    DTDFVocab:producedData JointLoadDataTransmitted
]

instance JointTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring joint temperature that influences friction behavior."
    DTDFVocab:producedData JointTemperatureDataTransmitted
]

instance CurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor generating the input‑current measurement of each joint."
    DTDFVocab:producedData CurrentDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor angular velocity for each joint."
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the first‑axis position of the robot."
    DTDFVocab:producedData PositionDataTransmitted
]

// -------------------------------------------------------
// C4: Physical‑to‑virtual interaction (DataTransmitted)
// -------------------------------------------------------
instance JointTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointTorqueSensor
]

instance JointLoadDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointLoadSensor
]

instance JointTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointTemperatureSensor
]

instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensor
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
]

// -------------------------------------------------------
// C10: Data
// -------------------------------------------------------
instance JointTorqueData : DTDFVocab:Data [
    base:desc "Measured joint torque values used for friction compensation."
    DTDFVocab:fromData JointTorqueDataTransmitted
    DTDFVocab:inputTo PreprocessingEnabler, MQTTBrokerEnabler, AASExecutorEnabler, TwinProcessingEnabler
]

instance JointLoadData : DTDFVocab:Data [
    base:desc "Measured operational load on each joint."
    DTDFVocab:fromData JointLoadDataTransmitted
    DTDFVocab:inputTo PreprocessingEnabler, MQTTBrokerEnabler, AASExecutorEnabler, TwinProcessingEnabler
]

instance JointTemperatureData : DTDFVocab:Data [
    base:desc "Measured joint temperature influencing friction."
    DTDFVocab:fromData JointTemperatureDataTransmitted
    DTDFVocab:inputTo PreprocessingEnabler, MQTTBrokerEnabler, AASExecutorEnabler, TwinProcessingEnabler
]

instance CurrentData : DTDFVocab:Data [
    base:desc "Raw input‑current measurement before filtering."
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo PreprocessingEnabler, MQTTBrokerEnabler, AASExecutorEnabler, TwinProcessingEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Measured motor angular velocity per joint."
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo PreprocessingEnabler, MQTTBrokerEnabler, AASExecutorEnabler, TwinProcessingEnabler
]

instance PositionData : DTDFVocab:Data [
    base:desc "Measured first‑axis position of the robot."
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo PreprocessingEnabler, MQTTBrokerEnabler, AASExecutorEnabler, TwinProcessingEnabler
]

// -------------------------------------------------------
// C10: Models
// -------------------------------------------------------
instance WhiteBoxFrictionModel : DTDFVocab:Model [
    base:desc "Physics‑based white‑box Simulink model of robot joint friction dynamics."
    DTDFVocab:inputTo TwinProcessingEnabler
]

instance BlackBoxNNFrictionModel : DTDFVocab:Model [
    base:desc "Data‑driven neural‑network model predicting friction from torque, load, and temperature."
    DTDFVocab:inputTo TwinProcessingEnabler
]

// -------------------------------------------------------
// C11: Enablers (tooling & processing)
// -------------------------------------------------------
instance PreprocessingEnabler : DTDFVocab:Enabler [
    base:desc "Applies a low‑pass filter to the current signal to remove noise."
    DTDFVocab:enables RealTimeFrictionMonitoringService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Converts filtered measurements to JSON and publishes them on hierarchical MQTT topics."
    DTDFVocab:enables RealTimeFrictionMonitoringService,
                     PredictiveMaintenanceService,
                     ClosedLoopControlService,
                     MachiningParameterOptimizationService,
                     ProductQualityPredictionService
]

instance AASExecutorEnabler : DTDFVocab:Enabler [
    base:desc "Executes the Asset Administration Shell logic, links traces to models, and stores them in the digital shadow (ThingsBoard)."
    DTDFVocab:enables PredictiveMaintenanceService,
                     ClosedLoopControlService,
                     ProductQualityPredictionService
]

instance TwinProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Aggregates sensor data and model outputs, providing inputs to all twin services."
    DTDFVocab:enables RealTimeFrictionMonitoringService,
                     PredictiveMaintenanceService,
                     ClosedLoopControlService,
                     MachiningParameterOptimizationService,
                     ProductQualityPredictionService
]

// -------------------------------------------------------
// C6: Services
// -------------------------------------------------------
instance RealTimeFrictionMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of joint friction behavior."
    DTDFVocab:provides FrictionBehaviorInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Detects early faults and predicts maintenance needs based on friction trends."
    DTDFVocab:provides EarlyFaultDetectionInsight, MaintenanceAlertAction
]

instance ClosedLoopControlService : DTDFVocab:Service [
    base:desc "Compensates internal and external friction forces in the robot control loop."
    DTDFVocab:provides FrictionCompensationAction
]

instance MachiningParameterOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes machining parameters (including CO₂ reduction) via simulative experiments."
    DTDFVocab:provides CO2ReductionInsight, OptimizationAction
]

instance ProductQualityPredictionService : DTDFVocab:Service [
    base:desc "Predicts product quality based on twin simulations and stored traces."
    DTDFVocab:provides QualityPredictionInsight
]

// -------------------------------------------------------
// C17: Insights / Actions
// -------------------------------------------------------
instance FrictionBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight into the current friction state of each robot joint."
]

instance EarlyFaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Early detection of abnormal friction patterns indicating potential faults."
]

instance MaintenanceAlertAction : DTDFVocab:Action [
    base:desc "Triggers a maintenance work order when early fault detection fires."
    DTDFVocab:IsAutomatic true
]

instance FrictionCompensationAction : DTDFVocab:Action [
    base:desc "Sends real‑time compensation commands to motor drives based on model predictions."
    DTDFVocab:IsAutomatic true
]

instance CO2ReductionInsight : DTDFVocab:Insight [
    base:desc "Provides recommendations for machining parameter adjustments that reduce CO₂ emissions."
]

instance OptimizationAction : DTDFVocab:Action [
    base:desc "Applies optimized machining parameters to the robot controller."
    DTDFVocab:IsAutomatic true
]

instance QualityPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicts final product quality from simulated twin outcomes."
]

// -------------------------------------------------------
// C2: Acting Component (physical actuator interface)
// -------------------------------------------------------
instance RobotActuatorComponent : DTDFVocab:ActingComponent [
    base:desc "Actuator subsystem (motor drives) that receives compensation commands from the Twin."
]

// -------------------------------------------------------
// C5: Component (the industrial robot itself)
// -------------------------------------------------------
instance IndustrialRobot : DTDFVocab:Component [
    base:desc "Industrial robot used for machining, whose joint friction varies with load, temperature, and payload."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin operates under real‑time constraints: friction identification calculations must be performed within the control loop’s dead‑time, and continuous data streams from the physical robot are transmitted via MQTT to ThingsBoard, implying sub‑second latency and a granularity sufficient for online joint‑friction compensation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a model‑driven orchestration: a SysML structural model of the robot and executable Simulink simulation models (integrated via FMI) are combined in an Asset Administration Shell (AAS). An AAS Executor consumes live robot data (published over MQTT), runs the simulation models to compute friction estimates, stores the resulting data in the digital shadow on ThingsBoard, and pushes updates to a visualization dashboard, forming an automated pipeline that links data acquisition, model execution, and result dissemination."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "According to the MBSE discussion in Document 1, the Digital Twin lifecycle is organized into successive abstraction layers that mirror traditional system development phases: (1) requirements modeling, (2) functional‑architecture modeling, (3) logical‑architecture modeling, and (4) product/technical‑layer modeling. At each stage the twin is represented by appropriate artifacts – SysML requirement diagrams, SysML/internal‑block diagrams or ADL component‑connector diagrams for functional and logical structures, and concrete simulation models (e.g., Simulink) or executable code for the technical layer. Transitions between stages are managed by the MBSE process, which refines and refactors higher‑level models into lower‑level ones while preserving traceability links (the “originates‑from” association described in Document 2). Governance is achieved through integration of heterogeneous stakeholder views and consistent use of the reference model, ensuring that each phase conforms to the same underlying ontology."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by combining verified white‑box Simulink models with calibrated black‑box neural networks, while traceability of each data trace to its generating processing component and underlying model is maintained via the ‘originates‑from’ relation; validation includes runtime comparison of simulated and measured values, uncertainty quantification is addressed through continuous model updating, and quality assurance relies on verification of SysML‑to‑simulation transformations and real‑time dead‑time analysis."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The data‑transport layer is built on the MQTT protocol (implemented with Mosquitto) using a publish‑subscribe topology. Sensor data are encapsulated as JSON messages and published on hierarchical topics, allowing clients to subscribe to the needed streams. The MQTT broker mediates communication between the preprocessing component, the AAS Executor, and the ThingsBoard IoT platform, which consumes the same MQTT streams for storage and visualization. No explicit bandwidth, latency, redundancy or security specifications are provided in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration relies on standardized IIoT protocols and standards: MQTT is used for sensor data acquisition, ThingsBoard serves as the IoT platform for data storage and visualization, the Asset Administration Shell provides semantic interoperability, and FMI enables coupling of SysML structural models with Simulink behavioral models. This stack allows the digital twin to interoperate with other enterprise systems and to be extended by additional applications via the central data memory."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Documents 4 and 1 reference several established industry modelling standards that are adopted in the described Digital Twin approach: the Systems Modeling Language (SysML) for requirements and internal‑block diagrams, the Architecture Analysis & Design Language (AADL) for component‑level architecture, the ACME ADL for component‑connector specifications, and MontiArc/ MontiArcAutomaton for combined structural and behavioral models. The SMArDT framework (Document 4) is also cited as a modelling approach for automotive software testing, indicating compliance with domain‑specific standards. The use of a reference model with an explicit conformance relation (Document 2) enforces adherence to these standards across concrete realizations, but no specific certification schemes or interoperability protocols (e.g., OPC UA, MQTT) are mentioned for the twin itself."
]