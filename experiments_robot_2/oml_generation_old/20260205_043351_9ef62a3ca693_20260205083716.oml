// C3: Physical sensing components
instance JointAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real-time joint angle measurements from MABI MAX 100 robot's mechanical joints for dynamic behavior analysis"
    DTDFVocab:producedData JointAngleDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors motor current levels to detect operational anomalies and performance degradation in the robot's actuators"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance EnvironmentalParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Gathers contextual environmental parameters (temperature, humidity) affecting robot operation in manufacturing environments"
    DTDFVocab:producedData EnvironmentalParameterDataTransmitted
]

instance OperationalStateSensor : DTDFVocab:SensingComponent [
    base:desc "Tracks operational states including motion profiles, load conditions, and system health metrics for real-time monitoring"
    DTDFVocab:producedData OperationalStateDataTransmitted
]

// C4: Physical-to-virtual interaction
instance JointAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointAngleSensor
    base:desc "Event-triggered data stream of joint angle measurements transmitted via communication protocols to digital representation"
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
    base:desc "Time-based data stream of motor current readings with preprocessing for noise reduction before integration"
]

instance EnvironmentalParameterDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalParameterSensor
    base:desc "Aggregated environmental context data filtered and normalized for consistency in digital twin integration"
]

instance OperationalStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalStateSensor
    base:desc "Heterogeneous operational state data combined through middleware for unified digital representation"
]

// C10: Models/Data
instance RobotDynamicsModel : DTDFVocab:Model [
    base:desc "Executable simulation model in MathWorks Simulink replicating MABI MAX 100's nonlinear dynamics including friction effects and control logic"
    DTDFVocab:inputTo SimulationEnabler, ControlAlgorithmEnabler
]

instance FrictionCompensationModel : DTDFVocab:Model [
    base:desc "Specialized model for identifying and compensating friction effects in robot's mechanical joints using real-time data"
    DTDFVocab:inputTo SimulationEnabler, AdaptiveControlEnabler
]

instance ContextualDataRepository : DTDFVocab:Data [
    base:desc "Aggregated and abstracted contextual data traces including sensor inputs, motor currents, and joint angles processed for actionable insights"
    DTDFVocab:fromData JointAngleDataTransmitted, MotorCurrentDataTransmitted, EnvironmentalParameterDataTransmitted, OperationalStateDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, VisualizationEnabler
]

instance PerformanceMetricsData : DTDFVocab:Data [
    base:desc "Derived performance metrics from raw sensor data including anomaly detection results and operational efficiency indicators"
    DTDFVocab:fromData OperationalStateDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, DecisionSupportEnabler
]

// C11: Enablers
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink integration platform enabling real-time behavioral simulation and predictive analysis of robot dynamics"
    DTDFVocab:enables BehavioralModelingService, PredictiveAnalysisService
]

instance ControlAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "C++/Java-based control algorithm framework supporting adaptive calibration and real-time intervention capabilities"
    DTDFVocab:enables AdaptiveControlService, OptimizationService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Middleware framework handling data aggregation, normalization, and feature extraction from heterogeneous sensor streams"
    DTDFVocab:enables DataAggregationService, AnomalyDetectionService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard-based visualization interface providing multi-perspective views of robot's operational state and predictive insights"
    DTDFVocab:enables VisualizationService, MonitoringService
]

instance DecisionSupportEnabler : DTDFVocab:Enabler [
    base:desc "MBSE methodology implementation (RFLP/OOSEM) enabling heterogeneous stakeholder access to system insights through structured modeling"
    DTDFVocab:enables DecisionSupportService
]

instance AdaptiveControlEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton integration for behavioral modeling and real-time adaptive control logic execution"
    DTDFVocab:enables AdaptiveControlService, CalibrationService
]

// C6: Services
instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Real-time replication of robot's dynamics, friction effects, and control logic using executable simulation models"
    DTDFVocab:provides RobotBehaviorInsight, PredictivePerformanceInsight
]

instance LiveDataLinkingService : DTDFVocab:Service [
    base:desc "Automated bidirectional synchronization between physical robot and digital twin ensuring real-time state alignment"
    DTDFVocab:provides SystemStateAlignmentAction, InterventionTriggerAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Dashboard-based interface for monitoring operational metrics, anomalies, and predictive insights across heterogeneous stakeholders"
    DTDFVocab:provides OperationalMetricsInsight, AnomalyDetectionInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Processing of contextual data traces into actionable insights through aggregation, abstraction, and feature extraction"
    DTDFVocab:provides ProcessedDataInsight, FeatureExtractionAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Real-time identification of operational anomalies through pattern recognition in processed sensor data"
    DTDFVocab:provides AnomalyDetectionInsight, MaintenanceRecommendationAction
]

instance AdaptiveControlService : DTDFVocab:Service [
    base:desc "Real-time adaptive control logic execution based on digital twin insights for performance optimization"
    DTDFVocab:provides ControlOptimizationInsight, AdaptiveCalibrationAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Performance optimization through predictive analysis and control parameter adjustment based on digital twin models"
    DTDFVocab:provides OptimizationRecommendationInsight, ParameterAdjustmentAction
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous real-time monitoring of robot's operational state and performance metrics for proactive maintenance"
    DTDFVocab:provides SystemHealthInsight, AlertGenerationAction
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Provides structured insights and recommendations to heterogeneous stakeholders for manufacturing workflow decision-making"
    DTDFVocab:provides DecisionSupportInsight, WorkflowRecommendationAction
]

// C17: Insights/Actions
instance RobotBehaviorInsight : DTDFVocab:Insight [
    base:desc "Real-time insights into robot's dynamic behavior including friction effects and control response characteristics"
]

instance PredictivePerformanceInsight : DTDFVocab:Insight [
    base:desc "Predictive analysis of system performance under varying loads and operational conditions"
]

instance SystemStateAlignmentAction : DTDFVocab:Action [
    base:desc "Automated synchronization of physical and virtual system states"
    DTDFVocab:IsAutomatic true
]

instance InterventionTriggerAction : DTDFVocab:Action [
    base:desc "Automated triggering of corrective interventions based on real-time state alignment"
    DTDFVocab:IsAutomatic true
]

instance OperationalMetricsInsight : DTDFVocab:Insight [
    base:desc "Comprehensive operational metrics including motion profiles, load conditions, and system health indicators"
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Identified operational anomalies and their potential impact on system performance"
]

instance ProcessedDataInsight : DTDFVocab:Insight [
    base:desc "Aggregated and abstracted contextual data ready for actionable insights generation"
]

instance FeatureExtractionAction : DTDFVocab:Action [
    base:desc "Automated feature extraction from raw sensor data for pattern recognition"
    DTDFVocab:IsAutomatic true
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Automated generation of maintenance recommendations based on anomaly detection"
    DTDFVocab:IsAutomatic true
]

instance ControlOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized control parameters and strategies based on real-time system behavior"
]

instance AdaptiveCalibrationAction : DTDFVocab:Action [
    base:desc "Automated adaptive calibration of control systems based on digital twin insights"
    DTDFVocab:IsAutomatic true
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for performance optimization through control parameter adjustments"
]

instance ParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated adjustment of control parameters based on optimization insights"
    DTDFVocab:IsAutomatic true
]

instance SystemHealthInsight : DTDFVocab:Insight [
    base:desc "Comprehensive assessment of robot's current health and operational status"
]

instance AlertGenerationAction : DTDFVocab:Action [
    base:desc "Automated generation of alerts for critical operational conditions"
    DTDFVocab:IsAutomatic true
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Structured insights supporting decision-making for manufacturing workflow optimization"
]

instance WorkflowRecommendationAction : DTDFVocab:Action [
    base:desc "Recommendations for manufacturing workflow adjustments based on system insights"
    DTDFVocab:IsAutomatic false
]

// Added missing services to resolve reference errors
instance PredictiveAnalysisService : DTDFVocab:Service [
    base:desc "Provides predictive analysis capabilities based on simulation models"
    DTDFVocab:provides PredictivePerformanceInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service for adaptive calibration of control systems"
    DTDFVocab:provides AdaptiveCalibrationAction
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin (DT) system’s orchestration and coordination are implicitly tied to **Model-Based Systems Engineering (MBSE)** methodologies, which employ **architecture description languages (ADLs)** like ACME, AADL, MontiArc, or SysML Internal Block Diagrams (IBDs) to define component integration, interfaces, and composition. Behavioral modeling is extended via tools such as **MontiArc Automaton, SysML state machines (v1.7), MathWorks Simulink, or simulation frameworks** (e.g., [29], [30]) to ensure system-wide coordination. The document does not specify explicit orchestration patterns (e.g., microservices, service-oriented architectures) but emphasizes the need to integrate **heterogeneous modeling notations and tools** for comprehensive system description. Resource management is not detailed, though the passive nature of digital shadows (one-way data flow) suggests DTs may require active components (e.g., interpreters or processors) to handle data aggregation and abstraction."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **validation and verification (V&V) methods** to ensure model fidelity and data accuracy, though specific techniques are not detailed in the provided documents. The **Digital Shadow Reference Model** (Kritzinger et al. [32]) emphasizes the **one-way, passive data flow** from physical objects to digital representations, implying that fidelity depends on the **automated aggregation and abstraction of contextual data traces**. Uncertainty sources may arise from **data transmission delays, sensor inaccuracies, or model simplification assumptions**, but no explicit quantification methods (e.g., probabilistic models, Bayesian inference) or error correction mechanisms are described. Quality assurance processes likely involve **cross-referencing models with physical system states**, though the document does not specify formal validation protocols (e.g., traceability matrices, simulation-based testing). The integration of **heterogeneous modeling tools** (e.g., SysML, Simulink) suggests a reliance on **tool-specific validation frameworks**, but no standardized fidelity metrics or uncertainty propagation techniques are mentioned."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for the Digital Shadow system relies on **MQTT** as the primary communication protocol for streaming sensor data in real-time. The architecture integrates **heterogeneous modeling tools and languages**, including **SysML (for system architecture)**, **ADLs (e.g., MontiArc, AADL, ACME) for component-connector descriptions**, and **simulation tools (e.g., MathWorks Simulink)** for behavioral modeling. These tools are interconnected to support **multi-notation modeling**, though specific details on **network topology (e.g., star, mesh)**, **bandwidth/latency requirements**, or **security protocols** (e.g., TLS, OPC UA) are not explicitly described. The system does not provide explicit redundancy mechanisms or hybrid cloud-edge deployments, as the focus is on **one-way data acquisition** rather than bidirectional control or distributed infrastructure."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with external systems through standardized data exchange mechanisms, as evidenced by the streaming of time-series sensor data via **MQTT** to the digital representation. The document explicitly references the **Siemens SINUMERIK 840D sl** controller as a concrete external system dependency, indicating interoperability with industrial control systems. While no other protocols or technologies are detailed, the reliance on MQTT for real-time data transmission suggests adherence to lightweight, event-driven communication standards. The integration pattern aligns with enterprise-level Digital Twin ecosystems, where heterogeneous tools (e.g., simulation environments, ADLs, or general-purpose programming languages) must coexist and exchange data seamlessly."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system incorporates **safety-critical considerations** through the use of a **physical safety cell** for robotic systems (e.g., MABI robotic arm), which restricts the maximum working range to mitigate operational risks. Data streaming between physical and virtual components is facilitated via **MQTT (Message Queuing Telemetry Transport)**, a lightweight protocol for IoT and industrial communication, though no explicit security protocols (e.g., encryption, authentication) are detailed in the provided documents. The system leverages **model-driven engineering (MDE)** and **conformance relations** for structural validation, but no granular cybersecurity measures (e.g., RBAC, OAuth, or compliance frameworks like ISO/IEC 27001) are specified. Risk assessment is implied through **traceability of data origins** (e.g., 'remains fully traceable to its origin and method of computation'), but no formal threat mitigation strategies or fail-safe mechanisms are documented."
]