// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current sensor measuring input current I_M"
    DTDFVocab:producedData CurrentDataTransmitted
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder directly mounted on the motor shaft"
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder behind the gearbox measuring gearbox output shaft position"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance CurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// C11: Data (derived measurements)
instance TorqueData : DTDFVocab:Data [
    base:desc "Derived torque τ calculated from motor current I_M"
    DTDFVocab:fromData CurrentDataTransmitted
    DTDFVocab:inputTo ProcessingComponent
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Motor shaft angular position from motor encoder"
    DTDFVocab:fromData MotorEncoderDataTransmitted
    DTDFVocab:inputTo ProcessingComponent
]

instance GearboxPositionData : DTDFVocab:Data [
    base:desc "Gearbox output shaft angular position from secondary encoder"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo ProcessingComponent
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω obtained from gearbox encoder data"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo ProcessingComponent
]

// C11: Enablers (tooling and execution platforms)
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker handling live sensor data streaming as time‑series"
    DTDFVocab:enables RealTimeFrictionIdentification
]

instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink engine executing friction and gearbox simulation models"
    DTDFVocab:enables RealTimeFrictionIdentification
    DTDFVocab:enables ContinuousParameterEstimation
]

instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML tool used for structural Block Definition and Internal Block Diagrams"
    DTDFVocab:enables ModelBasedControlImprovement
]

instance DashboardUI : DTDFVocab:Enabler [
    base:desc "Integrated dashboard UI visualizing measured and simulated data"
    DTDFVocab:enables VisualizationDashboard
]

instance ProcessingComponent : DTDFVocab:Enabler [
    base:desc "Processing component that consumes derived data and runs model‑based estimation"
    DTDFVocab:enables RealTimeFrictionIdentification
    DTDFVocab:enables ModelBasedControlImprovement
    DTDFVocab:enables ContinuousParameterEstimation
]

// C6: Services
instance RealTimeFrictionIdentification : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction parameters"
    DTDFVocab:provides ImprovedMotionAccuracy
    DTDFVocab:provides FeedFrictionParametersToController
]

instance VisualizationDashboard : DTDFVocab:Service [
    base:desc "Visualization of measured and simulated data in an integrated dashboard"
    DTDFVocab:provides ControlAlgorithmTuning
]

instance ModelBasedControlImprovement : DTDFVocab:Service [
    base:desc "Model‑based improvement of robot controller motion accuracy"
    DTDFVocab:provides PredictiveMaintenanceDecisions
]

instance ContinuousParameterEstimation : DTDFVocab:Service [
    base:desc "Continuous multi‑physics aware estimation of friction parameters during operation"
    DTDFVocab:provides PredictiveMaintenanceDecisions
]

// C17: Insights
instance ImprovedMotionAccuracy : DTDFVocab:Insight [
    base:desc "Derived friction parameters fed back to the controller improve motion accuracy"
]

instance PredictiveMaintenanceDecisions : DTDFVocab:Insight [
    base:desc "Model updates inform predictive maintenance decisions"
]

instance ControlAlgorithmTuning : DTDFVocab:Insight [
    base:desc "Model updates inform tuning of the control algorithm"
]

// C17: Actions
instance FeedFrictionParametersToController : DTDFVocab:Action [
    base:desc "Automatically feed identified friction parameters to the robot controller"
    DTDFVocab:IsAutomatic true
]

instance RefineDigitalShadowModels : DTDFVocab:Action [
    base:desc "Continuously refine digital shadow models during operation"
    DTDFVocab:IsAutomatic true
]

// C10: Engineering & Simulation Models
instance StructuralModelSysML : DTDFVocab:Model [
    base:desc "SysML Block Definition and Internal Block Diagrams describing motor, gearboxes, and rotational/current flows"
    DTDFVocab:inputTo SysMLModelingTool
]

instance FrictionlessGearboxSimulink : DTDFVocab:Model [
    base:desc "Simulink model of a frictionless gearbox"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance FrictionModelCoulombViscous : DTDFVocab:Model [
    base:desc "Simulink friction model implementing Coulomb and viscous friction"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance FrictionModelStribeck : DTDFVocab:Model [
    base:desc "Simulink friction model implementing the Stribeck effect"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance FrictionModelDahl : DTDFVocab:Model [
    base:desc "Simulink friction model based on the Dahl formulation"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance FrictionModelLuGre : DTDFVocab:Model [
    base:desc "Simulink friction model using the LuGre dynamics"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance DataCalculationModelTorqueVelocity : DTDFVocab:Model [
    base:desc "Data calculation model for deriving torque and angular velocity from sensor data"
    DTDFVocab:inputTo ProcessingComponent
]

// C2: Component representing the studied asset
instance FirstAxisMABIMax100 : DTDFVocab:Component [
    base:desc "First axis of the MABI MAX 100 six‑axis industrial robot, comprising motor, gearwheel gearbox and cycloidal gearbox used for machining tasks"
]

// C12: Environment (optional grouping)
instance RobotLabEnvironment : DTDFVocab:Environment [
    base:contains FirstAxisMABIMax100, MotorCurrentSensor, MotorEncoder, GearboxEncoder
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None – the digital shadow is defined as a passive one‑way data flow and does not send commands back to the robot."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (continuous streaming of sensor data during robot operation)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow comprising a singleton purpose (FrictionDerivation), the asset (MABI robot first axis), processing components (Simulation_M, Simulation_GW, Simulation_GB), engineering and simulation models, and multiple data traces linked through the Digital Shadow Reference Model; all visualized in a unified dashboard."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated phase – the digital shadow is created and used while the robot is in service to monitor and improve motion accuracy."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each data point to its source and processing model; continuous identification to capture wear, tool changes, and temperature effects; validation by comparing simulated friction‑free and friction‑included model outputs against measured reference data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data is transmitted from the robot to the digital shadow via MQTT; models and asset metadata are accessed through Asset Administration Shells."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) standard for representing the asset and its metadata; adherence to SysML modeling conventions."
]