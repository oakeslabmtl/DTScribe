// C3: Physical sensing components
instance JointPositionSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board encoder providing high‑resolution joint position data for each of the six axes of the MABI MAX 100 robot"
    DTDFVocab:producedData JointPositionDataTransmitted
]

instance JointForceSensor : DTDFVocab:SensingComponent [
    base:desc "On‑board force/torque sensor delivering high‑resolution joint force measurements for the six axes of the MABI MAX 100 robot"
    DTDFVocab:producedData JointForceDataTransmitted
]

// C4: Physical‑to‑virtual interaction (Data transmitted)
instance JointPositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointPositionSensor
]

instance JointForceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointForceSensor
]

// C10: Data artifacts
instance JointPositionData : DTDFVocab:Data [
    base:desc "Aggregated joint position trace collected from JointPositionSensor"
    DTDFVocab:fromData JointPositionDataTransmitted
    DTDFVocab:inputTo MQTTCommunicationEnabler, SimulinkSimulationEnabler, MLInferenceEnabler
]

instance JointForceData : DTDFVocab:Data [
    base:desc "Aggregated joint force trace collected from JointForceSensor"
    DTDFVocab:fromData JointForceDataTransmitted
    DTDFVocab:inputTo MQTTCommunicationEnabler, SimulinkSimulationEnabler, MLInferenceEnabler
]

// C10: Models (white‑box & black‑box)
instance WhiteBoxDynamicsModel : DTDFVocab:Model [
    base:desc "Simulink‑based multi‑physics dynamic simulation of the robot’s kinematics and dynamics (white‑box model)"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance BlackBoxFrictionMLModel : DTDFVocab:Model [
    base:desc "Data‑driven machine‑learning model capturing nonlinear joint friction behavior (black‑box model)"
    DTDFVocab:inputTo MLInferenceEnabler
]

// C11: Enablers (tooling & infrastructure)
instance MQTTCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker enabling one‑way streaming of sensor traces from the physical robot to the digital shadow"
    DTDFVocab:enables FrictionIdentificationService, VisualizationDashboardService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink engine executing the white‑box dynamics model for continuous multi‑physics identification"
    DTDFVocab:enables FrictionIdentificationService
]

instance MLInferenceEnabler : DTDFVocab:Enabler [
    base:desc "Machine‑learning inference runtime evaluating the black‑box friction model on incoming force data"
    DTDFVocab:enables FrictionIdentificationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) providing standardized semantic wrapper for model and data exchange"
    DTDFVocab:enables VisualizationDashboardService
]

instance SysMLModelEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 model repository (requirements, functional, logical architectures) driving traceability"
    DTDFVocab:enables FrictionIdentificationService, VisualizationDashboardService
]

instance MBSEProcessEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Based Systems Engineering (RFLP, OOSEM, SPES, SMArDT) process orchestrating model transformation and concretization"
    DTDFVocab:enables FrictionIdentificationService, VisualizationDashboardService
]

instance ADLSpecificationEnabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Language specifications (ACME, AADL, MontiArc) governing structural model integration"
    DTDFVocab:enables VisualizationDashboardService
]

// C6: Services offered by the Digital Twin
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous multi‑physics‑aware identification of joint friction, providing real‑time friction levels and wear prediction"
    DTDFVocab:provides RealTimeFrictionInsight, ControlLoopAdjustmentAction
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Operator dashboard visualizing friction trends, joint states and generating alerts for monitoring, diagnostics and trajectory optimisation"
    DTDFVocab:provides FrictionTrendInsight
]

// C17: Insights / Actions
instance RealTimeFrictionInsight : DTDFVocab:Insight [
    base:desc "Instantaneous estimate of each joint’s friction coefficient derived from combined white‑box and black‑box analyses"
]

instance ControlLoopAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic feeding of friction estimates back into the robot’s motion control loops to improve trajectory accuracy"
    DTDFVocab:IsAutomatic true
]

instance FrictionTrendInsight : DTDFVocab:Insight [
    base:desc "Historical trend analysis of friction evolution used to alert operators about abnormal wear patterns"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "According to the reference model the digital shadow is a passive entity and does not issue commands back to the physical system. No control messages, command formats, authentication, or execution confirmations are defined; the interaction is strictly one‑way from physical to virtual."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is organized around a Digital Shadow Reference Model expressed as a UML class diagram that defines three core concepts – Asset, Model, and Processing – together with Data Traces and their provenance associations. A concrete digital shadow is realized by mapping concrete elements (e.g., specific sensor data sources, simulation or data‑calculation models, and software processing components) onto these reference concepts, thereby forming a conforming class diagram. The architecture follows a component‑and‑connector style typical of MBSE: assets represent physical CPS elements, models encode engineering, simulation, or calculation logic, and processing components consume input data traces, invoke the associated models, and produce new output traces. Traceability is maintained via the 'originates‑from' association, allowing transitive back‑tracking from any data trace to its generating processing component, input traces, and involved models. The overall orchestration is defined through MBSE modeling languages such as SysML (including internal block diagrams and state machines) and ADLs (e.g., ACME, AADL, MontiArc), enabling hierarchical decomposition from requirements through functional and logical architectures down to the product/technical layer. Resource management and system‑wide coordination rely on the explicit mapping between concrete realizations and reference concepts, supporting heterogeneous stakeholder integration and multi‑tool interoperability."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle described follows an MBSE‑driven progression through successive abstraction layers: (1) requirements modelling, (2) functional architecture, (3) logical architecture, and (4) product/technical (physical) layer. During development, a reference Digital Shadow model is instantiated, then a concrete realization (concretization) is performed, yielding a digital twin that embodies the same concepts with concrete elements. Transition between stages is managed by mapping associations (e.g., originates‑from) that preserve traceability of data traces and processing components. Governance relies on the conformance relation defined for the reference class diagram, ensuring that each concrete model adheres to the reference model."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by traceability and verification of the transformation chain from high‑level SysML specifications to lower‑level simulation or executable models (e.g., SysML → Simulink, SysML → C++). Validation consists of comparing simulation outputs with measured data traces collected from the physical system; deviations are used to assess model accuracy. The approach emphasizes verification of model transformations to guarantee consistency, and relies on explicit traceability links to support quality assurance of both models and the underlying data."
]