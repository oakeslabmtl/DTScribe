instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring input current in MABI MAX 100 robot"
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring output angle in MABI MAX 100 robot"
    DTDFVocab:producedData OutputAngleDataTransmitted
]

instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "MQTT-transmitted time-series input current data"
    DTDFVocab:producedFrom InputCurrentSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "MQTT-transmitted time-series output angle data"
    DTDFVocab:producedFrom OutputAngleSensor
]

instance InputCurrentData : DTDFVocab:Data [
    base:desc "Time-series input current data for friction modeling"
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo Simulink, MontiArcAutomaton, Cpp
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Time-series output angle data for motion accuracy improvement"
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo Simulink, MontiArcAutomaton, Cpp
]

instance SysML : DTDFVocab:Enabler [
    base:desc "SysML for structural modeling across requirements, functional, logical, and product/technical layers"
    DTDFVocab:enables DashboardVisualizationService
]

instance RFLP : DTDFVocab:Enabler [
    base:desc "RFLP methodology for MBSE"
    DTDFVocab:enables FrictionIdentificationService
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for MBSE"
    DTDFVocab:enables FrictionIdentificationService
]

instance SPES : DTDFVocab:Enabler [
    base:desc "SPES methodology for MBSE"
    DTDFVocab:enables FrictionIdentificationService
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for MBSE"
    DTDFVocab:enables FrictionIdentificationService
]

instance ACME : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for component and connector perspectives"
    DTDFVocab:enables DashboardVisualizationService
]

instance AADL : DTDFVocab:Enabler [
    base:desc "AADL for component and connector perspectives"
    DTDFVocab:enables DashboardVisualizationService
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "MontiArc for architecture description"
    DTDFVocab:enables DashboardVisualizationService
]

instance SysMLIBDs : DTDFVocab:Enabler [
    base:desc "SysML IBDs for defining components, interfaces, and interconnections"
    DTDFVocab:enables DashboardVisualizationService
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:enables FrictionIdentificationService
]

instance SysMLStateMachines : DTDFVocab:Enabler [
    base:desc "SysML v1.7 state machines for behavioral modeling"
    DTDFVocab:enables FrictionIdentificationService
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for behavioral simulation and detailed behavior specification"
    DTDFVocab:enables FrictionIdentificationService, AccuracyImprovementService, DashboardVisualizationService
]

instance Cpp : DTDFVocab:Enabler [
    base:desc "C++ for detailed behavior specification"
    DTDFVocab:enables AccuracyImprovementService
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java for detailed behavior specification"
    DTDFVocab:enables DashboardVisualizationService
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous multi-physics-aware joint friction identification"
    DTDFVocab:provides FrictionLossInsight
]

instance AccuracyImprovementService : DTDFVocab:Service [
    base:desc "Accuracy improvement through real-time adjustments based on sensor data"
    DTDFVocab:provides MotionAccuracyInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Dashboard-based visualization of system state and performance metrics"
    DTDFVocab:provides SystemStateVisualizationInsight
]

instance FrictionLossInsight : DTDFVocab:Insight [
    base:desc "Detection of friction loss in robot joints"
]

instance MotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Improvement of robot motion accuracy through real-time analytics"
]

instance SystemStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of system state and performance metrics in unified dashboard"
]

instance BaseAxis : DTDFVocab:Component [
    base:desc "Base axis component of MABI MAX 100 robot"
]

instance Joints : DTDFVocab:Component [
    base:desc "Six-axis joints of MABI MAX 100 robot"
]

instance MechanicalStructure : DTDFVocab:Component [
    base:desc "Mechanical structure of MABI MAX 100 robot"
]

instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:desc "Manufacturing environment where MABI MAX 100 robot operates"
    base:contains BaseAxis, Joints, MechanicalStructure
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system maintains real-time synchronization with the physical asset through continuous data streams from live sensor measurements, ensuring the digital representation reflects the current physical state with minimal latency for critical operational monitoring."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system employs a Digital Shadow Reference Model as a UML class diagram to define the structure of contextual data traces, their aggregation, and abstraction for manufacturing applications, orchestrating the integration of physical data into the digital representation through standardized component interfaces and data flow mechanisms."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between physical and virtual components uses MQTT protocol for sensor data transmission; network topology, bandwidth, and redundancy specifications are not detailed in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Sensor data is streamed via MQTT protocol; Asset Administration Shells (AAS) are implemented."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system implements Asset Administration Shells (AAS) for standardized asset management, adheres to Model-Based Systems Engineering (MBSE) using SysML for requirements and architecture modeling, and employs UML class diagrams for reference model definitions, with architecture description languages (ADLs) such as AADL, ACME, and MontiArc ensuring interoperability and component-based system descriptions."
]