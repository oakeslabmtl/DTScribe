// Sensing Components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the actuator's input electrical current of the MABI MAX 100 robot."
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance RotationalAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the actuator's rotational angle of the MABI MAX 100 robot."
    DTDFVocab:producedData RotationalAngleDataTransmitted
]

// Data Transmitted
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance RotationalAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RotationalAngleSensor
]

// Data Aggregation (Digital Shadow)
instance MotorCurrentTraceData : DTDFVocab:Data [
    base:desc "Aggregated time-series trace of motor current measurements."
    DTDFVocab:inputTo SimulinkTool, AASTool
    DTDFVocab:fromData MotorCurrentDataTransmitted
]

instance AngularPositionTraceData : DTDFVocab:Data [
    base:desc "Aggregated time-series trace of rotational angle measurements."
    DTDFVocab:inputTo SimulinkTool, AASTool
    DTDFVocab:fromData RotationalAngleDataTransmitted
]

instance DigitalShadowReferenceModel : DTDFVocab:Data [
    base:desc "Digital Shadow Reference Model aggregating sensor traces and contextual metadata for the MABI MAX 100."
    DTDFVocab:inputTo AASTool
    DTDFVocab:fromData MotorCurrentTraceData, AngularPositionTraceData
]

// Models
instance ComponentConnectorArchitectureModel : DTDFVocab:Model [
    base:desc "SysML component-connector architecture model (IBD diagrams) describing the component-connector structure of MABI MAX 100."
    DTDFVocab:inputTo SysMLTool
]

instance MechanicalElectricalControlSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model simulating mechanical, electrical, and control dynamics of the MABI MAX 100 robotic arm."
    DTDFVocab:inputTo SimulinkTool
]

// Enablers
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "Tools and techniques for SysML functional and logical architecture modeling."
    DTDFVocab:enables JointFrictionIdentificationService, DashboardDisplayService
]

instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink used for continuous-time simulation of mechanical, electrical, and control dynamics."
    DTDFVocab:enables JointFrictionIdentificationService, MQTTStreamingService
]

instance MontiArcTool : DTDFVocab:Enabler [
    base:desc "MontiArc component-interconnection modeling used for formal mapping between physical hardware and virtual representations."
    DTDFVocab:enables JointFrictionIdentificationService
]

instance AASTool : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell encapsulates semantic data for the MABI MAX 100 robot."
    DTDFVocab:enables MQTTStreamingService
]

instance MQTTTool : DTDFVocab:Enabler [
    base:desc "MQTT publish/subscribe protocol used for real‑time telemetry exchange between physical robot and digital twin."
    DTDFVocab:enables MQTTStreamingService
]

// Services
instance JointFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Service estimating joint friction by fusing kinematic, dynamic, and electromagnetic measurements in real‑time."
    DTDFVocab:provides FrictionDiagnosticInsight, SendAlertAction
]

instance DashboardDisplayService : DTDFVocab:Service [
    base:desc "Service streaming processed diagnostics to operators via a web‑based dashboard for real‑time display."
    DTDFVocab:provides DashboardUpdateAction
]

instance MQTTStreamingService : DTDFVocab:Service [
    base:desc "Service publishing raw telemetry and identified parameters via MQTT for low‑latency data streaming."
    DTDFVocab:provides SendTelemetryAction
]

// Insights and Actions
instance FrictionDiagnosticInsight : DTDFVocab:Insight [
    base:desc "Insight indicating estimated joint friction values for MABI MAX 100."
]

instance DashboardUpdateAction : DTDFVocab:Action [
    base:desc "Action to update the web dashboard with latest diagnostics."
    DTDFVocab:IsAutomatic true
]

instance SendTelemetryAction : DTDFVocab:Action [
    base:desc "Action to publish telemetry and identified parameters to MQTT topics."
    DTDFVocab:IsAutomatic true
]

instance SendAlertAction : DTDFVocab:Action [
    base:desc "Action to send operational alerts based on friction thresholds."
    DTDFVocab:IsAutomatic true
]

// Component and Environment
instance RobotComponent : DTDFVocab:Component [
    base:desc "Industrial robot platform MABI MAX 100 operated by Siemens SINUMERIK 840D motion controller."
]

instance RobotEnvironment : DTDFVocab:Environment [
    base:contains RobotComponent
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the Model‑Based Systems Engineering (MBSE) abstraction hierarchy: (1) Requirements phase, (2) Functional architecture, (3) Logical architecture, and (4) Product/technical layer.  At each level, different modeling notations and tools are employed.  Requirements are typically captured in textual or diagrammatic form.  Functional architecture is expressed with SysML, notably SysML Interaction Block Diagrams (IBDs) for component structure and inter‑connectivity.  Logical architecture is described using Architecture Description Languages (ADLs) such as ACME, AADL, or MontiArc, which capture components, interfaces, and connectors from a component‑and‑connector perspective.  The product/technical layer is realized with code (e.g., C++ or Java) or simulation models (e.g., MathWorks Simulink).  The document emphasizes that these phases are complementary and that a comprehensive Digital Twin may integrate models across multiple notations, although explicit transition management and governance mechanisms are not detailed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The twin’s technical connection is based on the MQTT publish/subscribe protocol, where the physical robot publishes telemetry to the 'robots/telemetry' topic and the digital twin subscribes to this feed. No explicit details on network topology, latency, bandwidth, redundancy, or security measures are provided in the documents supplied."
]