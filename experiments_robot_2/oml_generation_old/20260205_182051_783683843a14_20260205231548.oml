// C2: Acting Components //
instance ProcessOptimizationController : DTDFVocab:ActingComponent [
    base:desc "Active feedback controller for real-time process adjustments in manufacturing systems, enabling closed-loop optimization of parameters like temperature, pressure, and speed based on digital twin insights."
]

// C3: Physical Sensing Components //
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency temperature sensor for monitoring process parameters in continuous manufacturing systems, transmitting real-time data for digital twin validation and optimization."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "Pressure sensor for capturing operational state variables in injection molding and continuous processes, providing event-triggered data for anomaly detection."
    DTDFVocab:producedData PressureDataTransmitted
]

instance StateMonitoringSensor : DTDFVocab:SensingComponent [
    base:desc "Machine health and production status sensor that tracks state transitions and operational metrics for digital twin decision support."
    DTDFVocab:producedData StateDataTransmitted
]

instance ContextualDataAggregator : DTDFVocab:SensingComponent [
    base:desc "Aggregator component for collecting and preprocessing structured/unstructured data from IoT devices and ERP systems, enabling purpose-driven digital shadow modeling."
    DTDFVocab:producedData ContextualDataTracesTransmitted
]

// C4: Physical-to-Virtual Interaction //
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

instance StateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StateMonitoringSensor
]

instance ContextualDataTracesTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContextualDataAggregator
]

// C10: Models/Data //
instance PhysicsBasedDynamicModel : DTDFVocab:Model [
    base:desc "White-box Simulink-based dynamic simulation model for interpretable, nonlinear process behavior modeling (e.g., robot friction, manufacturing dynamics) with analytical approaches."
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance MachineLearningBehaviorModel : DTDFVocab:Model [
    base:desc "Black-box AI/ML model capturing complex, nonlinear relationships in process data not easily representable analytically, derived from intrinsic state data (e.g., robot dynamics)."
    DTDFVocab:inputTo AIMLProcessingEngine
]

instance SysMLInternalBlockDiagram : DTDFVocab:Model [
    base:desc "SysML IBD model defining component-connector perspectives including interfaces, interconnections, and composition for multi-layered system architecture."
    DTDFVocab:inputTo SysMLModelingTool
]

instance AADLComponentModel : DTDFVocab:Model [
    base:desc "AADL architecture description defining physical and logical components, connectors, and interfaces for heterogeneous system integration."
    DTDFVocab:inputTo AADLToolchain
]

instance MontiArcStateMachineModel : DTDFVocab:Model [
    base:desc "MontiArc automaton model for behavioral description of stateful components in manufacturing systems, supporting state transitions and event handling."
    DTDFVocab:inputTo MontiArcFramework
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "High-frequency real-time sensor data streams (milliseconds to seconds) transmitted via MQTT/CoAP protocols for critical process monitoring and validation."
    DTDFVocab:fromData TemperatureDataTransmitted, PressureDataTransmitted, StateDataTransmitted
    DTDFVocab:inputTo DataPreprocessingPipeline
]

instance AggregatedContextualData : DTDFVocab:Data [
    base:desc "Purpose-driven aggregated data traces combining historical and real-time sensor data, operational logs, and environmental parameters for decision support."
    DTDFVocab:fromData ContextualDataTracesTransmitted
    DTDFVocab:inputTo DigitalShadowProcessingEngine
]

instance ProcessParameterData : DTDFVocab:Data [
    base:desc "Structured process parameters (temperature, pressure, speed) transmitted via OPC UA/Modbus protocols for factory automation integration."
    DTDFVocab:fromData TemperatureDataTransmitted, PressureDataTransmitted
    DTDFVocab:inputTo ProcessOptimizationController
]

// C11: Enablers //
instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink simulation engine for detailed behavioral modeling of physical systems, integrated with SysML/ADLs for cross-layer consistency."
    DTDFVocab:enables PhysicsBasedSimulationService
]

instance AIMLProcessingEngine : DTDFVocab:Enabler [
    base:desc "AI/ML processing framework enabling data-driven model training and inference for capturing complex system behaviors not amenable to analytical approaches."
    DTDFVocab:enables PredictiveAnalyticsService
]

instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML v1.7 modeling tool supporting internal block diagrams, state machines, and architecture description for multi-abstraction layer modeling."
    DTDFVocab:enables ArchitectureModelingService
]

instance AADLToolchain : DTDFVocab:Enabler [
    base:desc "AADL toolchain for component-connector modeling, enabling heterogeneous system integration through standardized architecture descriptions."
    DTDFVocab:enables SystemIntegrationService
]

instance MontiArcFramework : DTDFVocab:Enabler [
    base:desc "MontiArc framework supporting state machines and automata for behavioral description of complex systems, integrated with SysML for cross-tool consistency."
    DTDFVocab:enables BehavioralModelingService
]

instance DataPreprocessingPipeline : DTDFVocab:Enabler [
    base:desc "ETL pipeline for filtering, normalizing, and aggregating heterogeneous sensor data streams, ensuring data quality for digital twin inputs."
    DTDFVocab:enables DataQualityService
]

instance DigitalShadowProcessingEngine : DTDFVocab:Enabler [
    base:desc "One-way data aggregation engine for creating purpose-driven digital shadows from contextual data traces, supporting production planning and optimization."
