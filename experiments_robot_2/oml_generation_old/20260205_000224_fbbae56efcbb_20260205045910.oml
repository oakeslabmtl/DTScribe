instance PhysicalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Physical temperature sensor measuring ambient temperature of the system, providing real-time data for the digital twin."
    DTDFVocab:producedData TemperatureSensorDataTransmitted
]

instance PhysicalPressureSensor : DTDFVocab:SensingComponent [
    base:desc "Physical pressure sensor measuring hydraulic pressure within the system, providing data streams for virtual modeling."
    DTDFVocab:producedData PressureSensorDataTransmitted
]

instance TemperatureSensorDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Temperature data transmitted from PhysicalTemperatureSensor for digital twin processing."
    DTDFVocab:producedFrom PhysicalTemperatureSensor
]

instance PressureSensorDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Pressure data transmitted from PhysicalPressureSensor for digital twin processing."
    DTDFVocab:producedFrom PhysicalPressureSensor
]

instance TemperatureMeasurementData : DTDFVocab:Data [
    base:desc "Temperature measurement data derived from TemperatureSensorDataTransmitted, used for functional and dynamic modeling."
    DTDFVocab:fromData TemperatureSensorDataTransmitted
    DTDFVocab:inputTo SysMLModelProcessor
]

instance PressureMeasurementData : DTDFVocab:Data [
    base:desc "Pressure measurement data derived from PressureSensorDataTransmitted, used for simulation modeling."
    DTDFVocab:fromData PressureSensorDataTransmitted
    DTDFVocab:inputTo SimulinkRuntime
]

instance SysMLFunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "Functional architecture expressed in SysML v1.7, defines system functional logic and architecture."
    DTDFVocab:inputTo SysMLModelProcessor
]

instance MontiArcDynamicBehaviorModel : DTDFVocab:Model [
    base:desc "Dynamic behavior encoded with MontiArc Automaton and SysML state mechanisms, captures component interactions over time."
    DTDFVocab:inputTo MontiArcCodeGenerator
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model built in MathWorks Simulink, represents continuous-time dynamics for validation against physical measurements."
    DTDFVocab:inputTo SimulinkRuntime
]

instance SysMLModelProcessor : DTDFVocab:Enabler [
    base:desc "MBSE tooling component that processes SysML functional models, supporting multiple abstraction levels and traceability."
    DTDFVocab:enables FunctionalModelService
]

instance MontiArcCodeGenerator : DTDFVocab:Enabler [
    base:desc "Code generator that transforms MontiArc models into C++ or Java classes for active runtime execution."
    DTDFVocab:enables DynamicModelService
]

instance SimulinkRuntime : DTDFVocab:Enabler [
    base:desc "Runtime environment for Simulink models, executing continuous-time simulations and producing output data."
    DTDFVocab:enables SimulationExecutionService
]

instance FunctionalModelService : DTDFVocab:Service [
    base:desc "Service that orchestrates functional model evaluation, generating insights on system behavior."
    DTDFVocab:provides FunctionalBehaviorInsight
]

instance DynamicModelService : DTDFVocab:Service [
    base:desc "Service that handles dynamic model execution, providing insights into time-based system interactions."
    DTDFVocab:provides DynamicBehaviorInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service that runs Simulink simulations, validating physical behavior against modeled dynamics."
    DTDFVocab:provides SimulationExecutionResultInsight
]

instance FunctionalBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight derived from SysML functional model evaluation, indicating functional correctness and potential improvements."
]

instance DynamicBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight derived from MontiArc dynamic behavior model execution, highlighting timing and state transition accuracy."
]

instance SimulationExecutionResultInsight : DTDFVocab:Insight [
    base:desc "Insight from Simulink simulation execution, assessing fidelity between simulated and measured system behavior."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The document identifies that MBSE modeling is typically split into multiple levels of abstraction—requirements, functional architecture, logical architecture, and product/technical layer—providing a staged development approach for the concept of a digital twin. However, it does not explicitly describe representation types at each phase, transition management mechanisms, or explicit lifecycle governance frameworks."
]