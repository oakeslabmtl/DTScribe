// Sensing Component representing contextual data traces from the physical domain
instance ContextualDataSource : DTDFVocab:SensingComponent [
    base:desc "Abstracted contextual data traces extracted from the physical domain for modeling and simulation"
    DTDFVocab:producedData ContextualDataTransmitted
]

// Data transmitted by the sensing component
instance ContextualDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ContextualDataSource
]

// Data instance derived from the transmitted data
instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Contextual data trace representing extracted physical domain data used in simulations and real‑time analytics"
    DTDFVocab:fromData ContextualDataTransmitted
    DTDFVocab:inputTo SimulationRuntimeEnvironment, RealTimeDataProcessor
]

// Model instances describing the system architecture and behavior
instance SysMLSystemStructureModel : DTDFVocab:Model [
    base:desc "SysML v1.7 component‑and‑connector structure model using Interface Block Diagrams and activity diagrams"
    DTDFVocab:inputTo SimulationRuntimeEnvironment
]

instance MontiArcAutomationModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model for behavior refinement via state machines or automaton extensions"
    DTDFVocab:inputTo SimulationRuntimeEnvironment
]

instance SimulinkDynamicModel : DTDFVocab:Model [
    base:desc "Analytical and numerical simulation model instantiated in MathWorks Simulink supporting continuous‑time dynamic representation"
    DTDFVocab:inputTo SimulationRuntimeEnvironment
]

// Enabler instances for simulation, code generation and real‑time data processing
instance SimulationRuntimeEnvironment : DTDFVocab:Enabler [
    base:desc "Execution environment for MathWorks Simulink simulation and code generation in C++ or Java, supporting iterative refinement of the twin model"
    DTDFVocab:enables SimulationService
]

instance CodeGenerationTool : DTDFVocab:Enabler [
    base:desc "Code generation tool that converts Simulink models to C++ or Java source code for deployment"
    DTDFVocab:enables SimulationService
]

instance RealTimeDataProcessor : DTDFVocab:Enabler [
    base:desc "Active processing component integrated to receive and interpret real‑time data, enabling monitoring, control, optimization, and prediction with bidirectional communication"
    DTDFVocab:enables RealTimeMonitoringService
]

// Service instances that provide insights based on the processed data and models
instance SimulationService : DTDFVocab:Service [
    base:desc "Service performing simulation of SysML and MontiArc models in Simulink and generating simulation insights"
    DTDFVocab:provides SimulationResultInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service responsible for real‑time monitoring, control, optimization, and prediction based on incoming data"
    DTDFVocab:provides ControlDecisionInsight
]

// Insight instances derived from the services
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight comprising results of simulation, validating model behavior and guiding model refinement"
]

instance ControlDecisionInsight : DTDFVocab:Insight [
    base:desc "Insight derived from real‑time data interpretation to enable control decisions and optimization"
]

// Action instance that may be performed based on the insight
instance ExecuteControlAction : DTDFVocab:Action [
    base:desc "Action to execute control commands derived from control decisions"
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "In a digital twin implementation following MBSE best practices, the development is partitioned into four primary abstraction levels. At the requirements level the twin’s functional and performance targets are captured in textual or SysML requirement diagrams. The functional architecture level is expressed through SysML Block Definition Diagrams and ACME components, mapping out the high‑level functional decomposition. The logical architecture is modeled with SysML IBDs, MontiArc connectors, and AADL to describe component interactions and data flows. The product/technical layer includes code generation, Simulink simulation models, and Java/C++ implementation. Transition between levels is traced via SysML model relationships to preserve consistency, while governance is achieved through iterative review cycles, stakeholder alignment, and traceability of changes."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "The digital twin relies on the Asset Administration Shell (AAS) as defined in the Plattform Industrie 4.0 “Details of the Asset Administration Shell” (2021). The AAS instance encapsulates ownership metadata, including the asset owner, legal domain, and governance policies. Access is controlled via a role‑based access control (RBAC) model embedded in the AAS profile, allowing fine‑grained read/write permissions and the definition of data sharing agreements. Optional privacy tags can be attached to data sets; these tags allow automated anonymisation and compliance with privacy regulations such as GDPR. Data in transit is protected by TLS 1.3 over MQTT (Mosquitto 2017) and data at rest is encrypted with AES‑256, combining encrypt‑then‑MAC security best practices."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security is achieved through a multi‑layered approach: 
1. The RAMI 4.0 reference architecture (Platform Industrie 4.0 2016) prescribes network segmentation, secure gateways, and safety‑critical components.
2. The AAS specification mandates secure communication with TLS 1.3 and client certificates for MQTT endpoints (Mosquitto 2017). 
3. Authentication is handled by the ThingsBoard IoT platform (Jan 2024) via OAuth 2.0 and JSON Web Tokens (JWTs). 
4. Threat mitigation includes firewall rules, intrusion detection on the EMQX broker, and continuous monitoring of AAS data via anomaly detection algorithms. 
5. Safety‑critical behaviors are modeled using the Functional Mockup Interface (FMI) standard (2011), where safety constraints and deadlines are encoded in the FMU. The digital twin implements watchdog timers that revert the system to the last safe state upon detecting lapses, complying with IEC 61508 safety integrity level 2 where applicable."
]