// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Permanent‑magnet synchronous motor input current is sensor‑derived"
    DTDFVocab:producedData CurrentDataStream
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor angular position measured by encoder"
    DTDFVocab:producedData MotorEncoderAngleStream
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Gearbox angular position measured by encoder"
    DTDFVocab:producedData GearboxEncoderAngleStream
]

// C4: Physical-to-virtual interaction
instance CurrentDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderAngleStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance GearboxEncoderAngleStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// C10: Models/Data
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Live motor current value derived from sensor"
    DTDFVocab:inputTo DashboardSoftware, FrictionModelEnabler
    DTDFVocab:fromData CurrentDataStream
]

instance MotorEncoderAngleData : DTDFVocab:Data [
    base:desc "Motor encoder angle measurement"
    DTDFVocab:inputTo DashboardSoftware, FrictionModelEnabler
    DTDFVocab:fromData MotorEncoderAngleStream
]

instance GearboxEncoderAngleData : DTDFVocab:Data [
    base:desc "Gearbox encoder angle measurement"
    DTDFVocab:inputTo DashboardSoftware, FrictionModelEnabler
    DTDFVocab:fromData GearboxEncoderAngleStream
]

// C11: Enablers
instance DashboardSoftware : DTDFVocab:Enabler [
    base:desc "Unified dashboard for real‑time data visualization using MQTT streams"
    DTDFVocab:enables RealTimeDataVisualizationService
]

instance FrictionModelEnabler : DTDFVocab:Enabler [
    base:desc "Executable continuous multi‑physics friction identification using white‑box and black‑box models"
    DTDFVocab:enables FrictionIdentificationService, ParameterProvisionService
]

// C6: Services
instance RealTimeDataVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time data visualization in a unified dashboard"
    DTDFVocab:provides LiveDataInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous multi‑physics friction identification using concurrent white‑box and black‑box models"
    DTDFVocab:provides UpdatedFrictionParametersInsight, MaintenancePlanningInsight, ToolWearMonitoringInsight, ScheduleMaintenanceAction
]

instance ParameterProvisionService : DTDFVocab:Service [
    base:desc "Provision of updated friction model parameters to robot control for improved motion accuracy"
    DTDFVocab:provides UpdateControlParametersAction
]

// C17: Insights/Actions
instance LiveDataInsight : DTDFVocab:Insight [
    base:desc "Live visualization of sensor data streams in dashboard"
]

instance UpdatedFrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Derived friction model parameters used to improve robot motion accuracy"
]

instance MaintenancePlanningInsight : DTDFVocab:Insight [
    base:desc "Insights from model validation results inform maintenance planning"
]

instance ToolWearMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insights for tool wear monitoring derived from joint‑friction characteristics"
]

instance UpdateControlParametersAction : DTDFVocab:Action [
    base:desc "Update robot control parameters with updated friction model"
    DTDFVocab:IsAutomatic true
]

instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Schedule maintenance based on friction analysis"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time streaming of sensor data and simulation runs; digital shadow maintained in real‑time synchronized with PT operation (no explicit sampling interval given)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital shadow consists of the asset model, live data sources, processing components that compute simulation and friction models, and a dashboard that aggregates and visualizes the resulting data traces; all components are connected via MQTT and AAS interfaces."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "DT covers the operated phase of the physical robot; it uses design‑time engineering and behaviour models but is actively used during live operation to identify and update friction dynamics."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Four‑way traceability of data points to source measurements and model computations; simultaneous use of analytical white‑box friction models and data‑driven black‑box models to validate against live measurements; multi‑physics awareness and continuous re‑identification mitigates drift due to wear or temperature; uncertainty analysis not explicitly quantified in the paper."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data transmitted via MQTT; data traces are identified by their sources and processed by the processing component; Asset Administration Shells provide semantic metadata for data exchange."
]