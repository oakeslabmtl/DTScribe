// C3: Physical Sensing Components
instance PrimaryMotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Primary encoder on the motor shaft providing sub-millimeter resolution (repeatability of 0.06 mm and positional accuracy of 0.1 mm) for the permanent magnet synchronous motor. Samples input current reflecting motor torque and output angle measuring positional displacement at high frequencies."
    DTDFVocab:producedData MotorShaftEncoderDataTransmitted
]

instance SecondaryGearTransmissionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder on the gear transmission output compensating for gearbox compliance. Provides sub-millimeter resolution (repeatability of 0.06 mm and positional accuracy of 0.1 mm) with spatial distribution to minimize backlash and positional uncertainty."
    DTDFVocab:producedData GearTransmissionEncoderDataTransmitted
]

instance SiemensSINUMERIKControllerInterface : DTDFVocab:SensingComponent [
    base:desc "Controller interface aggregating data traces from motor and gear transmission encoders via internal communication protocols. Transmits processed sensor data to the Digital Shadow for real-time monitoring."
    DTDFVocab:producedData ControllerAggregatedDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance MotorShaftEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PrimaryMotorShaftEncoder
    base:desc "Transmits raw encoder data from motor shaft including input current and output angle measurements at high frequency for real-time monitoring."
]

instance GearTransmissionEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecondaryGearTransmissionEncoder
    base:desc "Transmits raw encoder data from gear transmission output compensating for gearbox compliance with sub-millimeter precision."
]

instance ControllerAggregatedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SiemensSINUMERIKControllerInterface
    base:desc "Aggregated data from controller interface combining processed sensor readings and operational logs for the Digital Shadow."
]

// C10: Models/Data
instance MABIMAX100KinematicModel : DTDFVocab:Model [
    base:desc "SysML-based kinematic model of the MABI MAX 100 six-axis serial robot using Internal Block Diagrams (IBDs) for component-connector perspectives and state machines for behavioral descriptions."
    DTDFVocab:inputTo SysMLModelingFramework, MathWorksSimulink
]

instance RobotDynamicSimulationModel : DTDFVocab:Model [
    base:desc "Detailed behavioral model for dynamic simulations of robot kinematics using MathWorks Simulink, integrated with general-purpose languages (C++, Java) for execution."
    DTDFVocab:inputTo MathWorksSimulink, GeneralPurposeProgramming
]

instance RobotOperationalData : DTDFVocab:Data [
    base:desc "Structured contextual data traces including sensor readings (current, angle), operational logs, and kinematic states aggregated from the physical robot."
    DTDFVocab:fromData MotorShaftEncoderDataTransmitted, GearTransmissionEncoderDataTransmitted, ControllerAggregatedDataTransmitted
    DTDFVocab:inputTo MQTTDataStreaming, AssetAdministrationShell
]

instance RobotPerformanceMetrics : DTDFVocab:Data [
    base:desc "Processed performance metrics derived from raw sensor data including positional accuracy, repeatability, and torque measurements for visualization and diagnostics."
    DTDFVocab:fromData ControllerAggregatedDataTransmitted
    DTDFVocab:inputTo MQTTDataStreaming, AssetAdministrationShell
]

// C11: Enablers
instance SysMLModelingFramework : DTDFVocab:Enabler [
    base:desc "SysML (Systems Modeling Language) v1.7 used for multi-layered system description (requirements, functional/logical architecture, physical layer) via Internal Block Diagrams (IBDs) and state machines."
    DTDFVocab:enables RobotKinematicModelingService, SystemArchitectureValidationService
]

instance MathWorksSimulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink employed for detailed behavioral modeling (e.g., dynamic simulations of robot kinematics) and integration with general-purpose languages (C++, Java) for execution."
    DTDFVocab:enables RobotDynamicSimulationService, ControlLogicIntegrationService
]

instance MQTTDataStreaming : DTDFVocab:Enabler [
    base:desc "MQTT (Message Queuing Telemetry Transport) for lightweight, publish-subscribe data streaming between the physical robot and digital shadow, ensuring low-latency, high-frequency data acquisition."
    DTDFVocab:enables DataAcquisitionService, RealTimeMonitoringService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shells (AAS) for standardized data encapsulation and semantic interoperability between the digital shadow and industrial IoT ecosystems."
    DTDFVocab:enables DataStandardizationService, HeterogeneousIntegrationService
]

instance GeneralPurposeProgramming : DTDFVocab:Enabler [
    base:desc "General-purpose programming languages (C++, Java) for custom logic or control implementations integrated with simulation frameworks."
    DTDFVocab:enables ControlLogicIntegrationService
]

// C6: Services
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Automated collection of contextual data traces (sensor readings, operational logs) from the physical MABI MAX 100 robot for digital shadow aggregation."
    DTDFVocab:provides RobotOperationalDataInsight
]

instance DataAbstractionService : DTDFVocab:Service [
    base:desc "Transformation of raw data into structured, purpose-specific abstractions (e.g., kinematic states, performance metrics) via predefined aggregation rules."
    DTDFVocab:provides RobotPerformanceMetricsInsight
]

instance RobotKinematicModelingService : DTDFVocab:Service [
    base:desc "Creation and validation of SysML-based kinematic models for the MABI MAX 100 robot using Internal Block Diagrams (IBDs) and state machines."
    DTDFVocab:provides KinematicModelValidationInsight
]

instance RobotDynamicSimulationService : DTDFVocab:Service [
    base:desc "Execution of detailed dynamic simulations of robot operations using MathWorks Simulink for validating data traces against expected behaviors."
    DTDFVocab:provides DynamicBehaviorValidationInsight
]

instance ControlLogicIntegrationService : DTDFVocab:Service [
    base:desc "Integration of control logic implemented in general-purpose languages (C++, Java) with simulation models for execution and validation."
    DTDFVocab:provides ControlLogicValidationInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Presentation of processed data to stakeholders through a dashboard interface enabling real-time situational awareness."
    DTDFVocab:provides RealTimeSituationalAwarenessInsight
]

instance SystemArchitectureValidationService : DTDFVocab:Service [
    base:desc "Validation of system architecture across multiple abstraction layers (requirements, functional, logical, physical) using SysML and MBSE methodologies."
    DTDFVocab:provides ArchitectureConsistencyInsight
]

instance DataStandardizationService : DTDFVocab:Service [
    base:desc "Standardized encapsulation of data using Asset Administration Shells (AAS) for semantic interoperability in industrial IoT ecosystems."
    DTDFVocab:provides DataInteroperabilityInsight
]

instance HeterogeneousIntegrationService : DTDFVocab:Service [
    base:desc "Integration of heterogeneous stakeholder perspectives and tools requiring semantic alignment across modeling notations and platforms."
    DTDFVocab:provides StakeholderIntegrationInsight
]

// C17: Insights/Actions
instance RobotOperationalDataInsight : DTDFVocab:Insight [
    base:desc "Aggregated contextual data traces from the physical robot including sensor readings and operational logs for monitoring purposes."
]

instance RobotPerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Processed performance metrics derived from raw sensor data including positional accuracy, repeatability, and torque measurements."
]

instance KinematicModelValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results of the SysML-based kinematic model against physical robot behavior using Internal Block Diagrams (IBDs)."
]

instance DynamicBehaviorValidationInsight : DTDFVocab:Insight [
    base:desc "Validation of dynamic simulations against expected robot behaviors using MathWorks Simulink."
]

instance ControlLogicValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results of control logic implemented in C++/Java integrated with simulation models."
]

instance RealTimeSituationalAwarenessInsight : DTDFVocab:Insight [
    base:desc "Real-time dashboard visualization of processed robot data for stakeholders."
]

instance ArchitectureConsistencyInsight : DTDFVocab:Insight [
    base:desc "Consistency validation across system architecture layers (requirements, functional, logical, physical) using SysML and MBSE."
]

instance DataInteroperabilityInsight : DTDFVocab:Insight [
    base:desc "Standardized data encapsulation and semantic interoperability achieved through Asset Administration Shells (AAS)."
]

instance StakeholderIntegrationInsight : DTDFVocab:Insight [
    base:desc "Semantic alignment across heterogeneous stakeholder perspectives and tools."
]

// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor coupled with a cycloidal gear transmission system driving the MABI MAX 100 robot axes. Controlled via Siemens SINUMERIK controller with encoder-based positional feedback."
]

instance CycloidalGearTransmissionSystem : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear transmission system providing precise motion control for the robot axes with encoder-based positional feedback to correct deviations."
]

instance SiemensSINUMERIKController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK controller managing actuation commands for the motor, enforcing safety constraints via closed-loop feedback mechanisms and supporting remote control interfaces."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin (DT) constellation** in this context is implicitly defined by the **Model-Based Systems Engineering (MBSE) framework**, which integrates **heterogeneous modeling notations and tools** (e.g., SysML for architecture, MontiArc Automaton/state machines for behavior, and simulation tools like MathWorks Simulink or general-purpose languages like C++/Java). The orchestration relies on **architecture description languages (ADLs)** such as ACME, AADL, or MontiArc to define **component & connector perspectives**, including interfaces, interconnections, and composition. While the document does not specify **orchestration patterns** (e.g., microservices, event-driven, or service-oriented architectures), it implies a **modular and tool-agnostic integration** approach. The **Digital Shadow Reference Model** (Fig. 1) further suggests that DTs must include **active components** (e.g., data processing modules) to interpret and act upon aggregated data traces, but no explicit **resource management** (e.g., load balancing, fault tolerance) or **system-wide coordination mechanisms** (e.g., middleware like Apache Kafka or OPC UA) are detailed. The document emphasizes **stakeholder integration** and **heterogeneous tool interoperability** as critical for constellation design."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through **high-precision sensor calibration** (repeatability: **0.06 mm**, positional accuracy: **0.1 mm**) and **closed-loop validation** comparing **reference values** (e.g., controller commands) against **simulated values** (e.g., physics-based models of friction). Uncertainty sources, such as **gear backlash** and **motor current ripple**, are quantified via empirical testing and incorporated into the Digital Twin’s predictive models. Error detection relies on **real-time discrepancy analysis** between simulated and actual system states, while correction mechanisms adjust control parameters dynamically. Quality assurance processes include **friction parameter derivation** (validated by comparing simulated vs. measured trajectories) and **periodic recalibration** of sensor offsets to maintain model accuracy."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates horizontally via **MBSE toolchains**, enabling interoperability between **SysML (for architecture modeling), ADLs (e.g., AADL, MontiArc), and simulation/analysis tools (e.g., Simulink, C++/Java)**. Data exchange occurs through **sensor time-series streams** transmitted via **MQTT**, as referenced in the **Digital Shadow Reference Model** for manufacturing contexts. The system adheres to **heterogeneous stakeholder perspectives** and **multi-notation modeling** (e.g., combining SysML with simulation tools) to ensure seamless data flow between **physical objects (e.g., sensors/actuators) and digital representations**. No explicit integration with **ERP systems, IoT platforms, or other Digital Twins** is documented, but the architecture supports **modular, standards-based interoperability** (e.g., via ADL/ADL mappings) to accommodate external dependencies. The focus is on **real-time data aggregation** (e.g., sensor traces) rather than batch-oriented enterprise integrations."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **Model-Based Systems Engineering (MBSE) standards**, specifically leveraging **SysML** as the primary modeling language. **Architecture Description Languages (ADLs)** such as **ACME**, **AADL**, and **MontiArc** are utilized for component-based system modeling, though no explicit alignment with **ISO 10303 (STEP)** or **OMG standards** is mentioned. The document does not reference industry-specific standards like **ISO 23247 (Digital Twin Framework)**, **OPC UA**, or **FIWARE**, nor does it detail **certification requirements** or **compliance frameworks**. Interoperability is implicitly supported through the integration of heterogeneous modeling tools (e.g., **SysML**, **Simulink**, **C++/Java**), but no standardized protocols or APIs are explicitly defined."
]