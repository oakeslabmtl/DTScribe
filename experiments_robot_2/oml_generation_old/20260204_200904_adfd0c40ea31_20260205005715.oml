instance RFLP : DTDFVocab:Enabler [
    base:desc "Model-Based Systems Engineering methodology for requirements, functional, logical, and technical layers"
    DTDFVocab:enables RequirementsManagementService
]

instance OOSEM : DTDFVocab:Enabler [
    base:desc "Object-Oriented Software Engineering Methodology for system modeling"
    DTDFVocab:enables OOSEMService
]

instance SPES : DTDFVocab:Enabler [
    base:desc "Software Product line Engineering and Systems Engineering methodology"
    DTDFVocab:enables SPESService
]

instance SMArDT : DTDFVocab:Enabler [
    base:desc "System Model-based Architecture and Design Tool methodology"
    DTDFVocab:enables SMArDTService
]

instance ACME : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component interfaces and interconnections"
    DTDFVocab:enables ACMEArchitectureService
]

instance AADL : DTDFVocab:Enabler [
    base:desc "Architecture Analysis & Design Language for embedded systems"
    DTDFVocab:enables AADLService
]

instance MontiArc : DTDFVocab:Enabler [
    base:desc "Architecture Description Language for component composition and behavior"
    DTDFVocab:enables MontiArcService
]

instance SysMLIBD : DTDFVocab:Enabler [
    base:desc "SysML Interface Block Diagrams for component interfaces"
    DTDFVocab:enables SysMLIBDService
]

instance MontiArcAutomaton : DTDFVocab:Enabler [
    base:desc "Behavioral modeling using MontiArc Automaton"
    DTDFVocab:enables MontiArcAutomatonService
]

instance SysMLStateMachine : DTDFVocab:Enabler [
    base:desc "SysML state machines for behavioral modeling"
    DTDFVocab:enables SysMLStateMachineService
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for simulation and dynamic system modeling"
    DTDFVocab:enables SimulinkService
]

instance CppCompiler : DTDFVocab:Enabler [
    base:desc "C++ compiler for general-purpose code execution"
    DTDFVocab:enables CppCodeService
]

instance JavaCompiler : DTDFVocab:Enabler [
    base:desc "Java compiler for general-purpose code execution"
    DTDFVocab:enables JavaCodeService
]

instance AdditionalSimulationTools : DTDFVocab:Enabler [
    base:desc "Additional simulation tools for detailed behavior modeling"
    DTDFVocab:enables AdditionalSimulationService
]

instance RequirementsManagementService : DTDFVocab:Service [
    base:desc "Service for managing system requirements using RFLP methodology"
    DTDFVocab:provides RequirementsInsight
]

instance OOSEMService : DTDFVocab:Service [
    base:desc "Service for object-oriented system modeling"
    DTDFVocab:provides OOSEMInsight
]

instance SPESService : DTDFVocab:Service [
    base:desc "Service for software product line engineering and systems engineering"
    DTDFVocab:provides SPESInsight
]

instance SMArDTService : DTDFVocab:Service [
    base:desc "Service for system model-based architecture and design"
    DTDFVocab:provides SMArDTInsight
]

instance ACMEArchitectureService : DTDFVocab:Service [
    base:desc "Service for architecture description using ACME"
    DTDFVocab:provides ACMEArchitectureInsight
]

instance AADLService : DTDFVocab:Service [
    base:desc "Service for architecture analysis and design using AADL"
    DTDFVocab:provides AADLInsight
]

instance MontiArcService : DTDFVocab:Service [
    base:desc "Service for component composition using MontiArc"
    DTDFVocab:provides MontiArcInsight
]

instance SysMLIBDService : DTDFVocab:Service [
    base:desc "Service for interface block diagrams using SysML"
    DTDFVocab:provides SysMLIBDInsight
]

instance MontiArcAutomatonService : DTDFVocab:Service [
    base:desc "Service for behavioral modeling with MontiArc Automaton"
    DTDFVocab:provides MontiArcAutomatonInsight
]

instance SysMLStateMachineService : DTDFVocab:Service [
    base:desc "Service for state machine modeling with SysML"
    DTDFVocab:provides SysMLStateMachineInsight
]

instance SimulinkService : DTDFVocab:Service [
    base:desc "Service for dynamic system simulation using Simulink"
    DTDFVocab:provides SimulinkInsight
]

instance CppCodeService : DTDFVocab:Service [
    base:desc "Service for C++ code execution and behavior implementation"
    DTDFVocab:provides CppCodeInsight
]

instance JavaCodeService : DTDFVocab:Service [
    base:desc "Service for Java code execution and behavior implementation"
    DTDFVocab:provides JavaCodeInsight
]

instance AdditionalSimulationService : DTDFVocab:Service [
    base:desc "Service for additional simulation tools"
    DTDFVocab:provides AdditionalSimulationInsight
]

instance RequirementsInsight : DTDFVocab:Insight [
    base:desc "Insight into system requirements and specifications"
]

instance OOSEMInsight : DTDFVocab:Insight [
    base:desc "Insight from object-oriented system analysis"
]

instance SPESInsight : DTDFVocab:Insight [
    base:desc "Insight from software product line engineering processes"
]

instance SMArDTInsight : DTDFVocab:Insight [
    base:desc "Insight from system model-based architecture design"
]

instance ACMEArchitectureInsight : DTDFVocab:Insight [
    base:desc "Insight from ACME-based architecture description"
]

instance AADLInsight : DTDFVocab:Insight [
    base:desc "Insight from AADL-based embedded system analysis"
]

instance MontiArcInsight : DTDFVocab:Insight [
    base:desc "Insight from MontiArc component composition"
]

instance SysMLIBDInsight : DTDFVocab:Insight [
    base:desc "Insight from SysML Interface Block Diagrams"
]

instance MontiArcAutomatonInsight : DTDFVocab:Insight [
    base:desc "Insight from MontiArc Automaton behavioral modeling"
]

instance SysMLStateMachineInsight : DTDFVocab:Insight [
    base:desc "Insight from SysML state machine models"
]

instance SimulinkInsight : DTDFVocab:Insight [
    base:desc "Insight from Simulink simulation results"
]

instance CppCodeInsight : DTDFVocab:Insight [
    base:desc "Insight from C++ code execution"
]

instance JavaCodeInsight : DTDFVocab:Insight [
    base:desc "Insight from Java code execution"
]

instance AdditionalSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from additional simulation tools"
]

instance RequirementsModel : DTDFVocab:Model [
    base:desc "SysML-based model for system requirements"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model for functional architecture decomposition"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "SysML model for logical architecture design"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance ProductTechnicalLayerModel : DTDFVocab:Model [
    base:desc "SysML model for product and technical layer specifications"
    DTDFVocab:inputTo RFLP, OOSEM, SPES, SMArDT
]

instance ACMEModel : DTDFVocab:Model [
    base:desc "ACME-based architecture description for component interfaces"
    DTDFVocab:inputTo ACME
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL model for embedded system architecture"
    DTDFVocab:inputTo AADL
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc model for component composition"
    DTDFVocab:inputTo MontiArc
]

instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "SysML Interface Block Diagram for component interconnections"
    DTDFVocab:inputTo SysMLIBD
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "Behavioral model using MontiArc Automaton"
    DTDFVocab:inputTo MontiArcAutomaton
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machine for behavioral modeling"
    DTDFVocab:inputTo SysMLStateMachine
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for dynamic system simulation"
    DTDFVocab:inputTo Simulink
]

instance CppCodeModel : DTDFVocab:Model [
    base:desc "General-purpose C++ code for detailed behavior implementation"
    DTDFVocab:inputTo CppCompiler
]

instance JavaCodeModel : DTDFVocab:Model [
    base:desc "General-purpose Java code for detailed behavior implementation"
    DTDFVocab:inputTo JavaCompiler
]

instance SimulationToolsModel : DTDFVocab:Model [
    base:desc "Additional simulation tools for detailed behavior modeling"
    DTDFVocab:inputTo AdditionalSimulationTools
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Relevant industry standards include SysML [17], AADL [24], ACME [23], and MontiArc [25,26] for architecture description and system modeling, ensuring interoperability and structured representation across different abstraction levels."
]