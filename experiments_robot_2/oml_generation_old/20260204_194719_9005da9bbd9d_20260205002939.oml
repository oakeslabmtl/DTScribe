// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor current I_M of the base vertical axis",
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Motor‑mounted position encoder providing angle r_M on the base axis",
    DTDFVocab:producedData MotorEncoderDataTransmitted
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder situated behind the gearbox providing output angle r_out",
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides live visualization of sensor data and identified friction parameters on the dashboard",
    DTDFVocab:provides LiveFrictionVisualizationInsight, UpdatedFrictionParametersInsight
]

instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuously identifies static, kinetic and viscous friction coefficients from incoming sensor data",
    DTDFVocab:provides UpdatedFrictionParametersInsight, MotionControlRefinementAction
]

instance ModelBasedControlAdaptationService : DTDFVocab:Service [
    base:desc "Adapts motion‑control algorithms using refined friction parameters to improve positional accuracy",
    DTDFVocab:provides MotionControlRefinementAction, AdaptiveControlAlgorithmUpdateAction
]

// C11: Enablers
instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker transporting live sensor streams to the digital shadow",
    DTDFVocab:enables RealTimeVisualizationService, FrictionIdentificationService
]

instance SimulinkSimulatorEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink execution environment for motor and gearbox models",
    DTDFVocab:enables ModelBasedControlAdaptationService
]

instance DashboardWebAppEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard visualizing real‑time data and friction estimates",
    DTDFVocab:enables RealTimeVisualizationService
]

instance AASEnvironmentEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell binding model data to digital twin components",
    DTDFVocab:enables ModelBasedControlAdaptationService
]

instance FrictionIdentificationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Processing engine executing friction identification models",
    DTDFVocab:enables FrictionIdentificationService
]

// C10: Data
instance AxisSensorData : DTDFVocab:Data [
    base:desc "Time‑series of motor current, motor encoder angle, gearbox encoder angle, and derived torque & angular velocity",
    DTDFVocab:fromData MotorCurrentDataTransmitted, MotorEncoderDataTransmitted, GearboxEncoderDataTransmitted,
    DTDFVocab:inputTo MQTTBrokerEnabler
]

// C17: Insights
instance LiveFrictionVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of identified friction coefficients on the dashboard"
]

instance UpdatedFrictionParametersInsight : DTDFVocab:Insight [
    base:desc "Updated static, kinetic and viscous friction parameters derived from the digital shadow"
]

// C17: Actions
instance MotionControlRefinementAction : DTDFVocab:Action [
    base:desc "Feeds updated friction parameters back to the robot controller to refine motion‑control algorithms",
    DTDFVocab:IsAutomatic true
]

instance AdaptiveControlAlgorithmUpdateAction : DTDFVocab:Action [
    base:desc "Updates the model‑based control algorithm in the robot controller using refined friction data",
    DTDFVocab:IsAutomatic true
]

// C10: Models / Data
instance SysMLAxisBlockModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagrams of the base vertical axis",
    DTDFVocab:inputTo AASEnvironmentEnabler
]

instance SimulinkMotorModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the permanent‑magnet synchronous motor",
    DTDFVocab:inputTo SimulinkSimulatorEnabler
]

instance SimulinkGearwheelModel : DTDFVocab:Model [
    base:desc "Simulink model of the gearwheel gearbox",
    DTDFVocab:inputTo SimulinkSimulatorEnabler
]

instance SimulinkCycloidalGearboxModel : DTDFVocab:Model [
    base:desc "Simulink model of the cycloidal gearbox",
    DTDFVocab:inputTo SimulinkSimulatorEnabler
]

instance FrictionCoulombViscousModel : DTDFVocab:Model [
    base:desc "Friction identification model combining Coulomb and viscous coefficients",
    DTDFVocab:inputTo FrictionIdentificationEngineEnabler
]

instance FrictionStribeckModel : DTDFVocab:Model [
    base:desc "Stribeck friction model used for dynamic friction identification",
    DTDFVocab:inputTo FrictionIdentificationEngineEnabler
]

instance FrictionDahlModel : DTDFVocab:Model [
    base:desc "Dahl friction model capturing pre‑slip behavior",
    DTDFVocab:inputTo FrictionIdentificationEngineEnabler
]

instance FrictionLuGreModel : DTDFVocab:Model [
    base:desc "LuGre friction model for detailed friction dynamics",
    DTDFVocab:inputTo FrictionIdentificationEngineEnabler
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates in real‑time: sensor time series are continuously acquired and processed, enabling on‑line friction identification during robot operation. The pipeline supports dynamic exchange of friction models and continuous update of the virtual model while the robot runs."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation consists of a purpose (FrictionDerivation), an asset representation (Mabi), processing components (Simulation_M, Simulation_GW, Simulation_GB) that consume input traces and produce simulated outputs, a set of data traces (I_M, r_M, r_G, r_out, ˆr_M, ˆr_G, ˆr_out), and a visualization dashboard that aggregates the results for user interpretation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital shadow operates on the 'as‑operated' stage of the robot, ingesting live operational data to continuously update friction models during runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Traceability is maintained by linking each data trace to its generating processing component and underlying model; simulated friction‑free behavior is compared against measured traces to quantify deviation; both white‑box (analytical) and black‑box (data‑driven) friction models are continuously updated, providing multi‑physics‑aware identification and validation against live data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow over MQTT; Asset Administration Shells are used to bind physical assets to their virtual representations; the processing components run locally and consume MQTT topics to generate simulated data."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach employs the Asset Administration Shell (AAS) standard for asset representation and SysML, an OMG modelling language, for engineering models."
]