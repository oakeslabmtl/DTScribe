// Sensing Components
instance SimulinkSimulationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor representing the Simulink simulation environment that generates simulation output data."
    DTDFVocab:producedData SimulationOutputDataTransmitted
]
instance CompiledCodeMetricsSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that collects compiled code metrics from the build process."
    DTDFVocab:producedData CompiledCodeMetricsDataTransmitted
]
instance DigitalShadowContextSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that captures real‑time contextual data traces from the digital shadow."
    DTDFVocab:producedData RealTimeContextDataTransmitted
]

// Data Transmitted
instance SimulationOutputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkSimulationSensor
]
instance CompiledCodeMetricsDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CompiledCodeMetricsSensor
]
instance RealTimeContextDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DigitalShadowContextSensor
]

// Data
instance SimulationOutputData : DTDFVocab:Data [
    base:desc "Simulation output data generated by the MathWorks Simulink model."
    DTDFVocab:fromData SimulationOutputDataTransmitted
    DTDFVocab:inputTo SimulinkEngine
]
instance CompiledCodeMetricsData : DTDFVocab:Data [
    base:desc "Compiled code metrics extracted from the source code."
    DTDFVocab:fromData CompiledCodeMetricsDataTransmitted
    DTDFVocab:inputTo DatabaseStorage
]
instance RealTimeContextData : DTDFVocab:Data [
    base:desc "Real‑time contextual data traces captured by the digital shadow."
    DTDFVocab:fromData RealTimeContextDataTransmitted
    DTDFVocab:inputTo ModelAlignmentTool
]

// Models
instance RequirementsModel : DTDFVocab:Model [
    base:desc "Model that captures the system requirements."
    DTDFVocab:inputTo ModelAlignmentTool
]
instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "Model that represents the functional architecture."
    DTDFVocab:inputTo ModelAlignmentTool
]
instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Model that captures the logical architecture."
    DTDFVocab:inputTo ModelAlignmentTool
]
instance ProductTechnicalModel : DTDFVocab:Model [
    base:desc "Model that represents the product/technical layer."
    DTDFVocab:inputTo ModelAlignmentTool
]
instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML v1.7 state machine model encoding behavioral dynamics."
    DTDFVocab:inputTo SimulinkEngine
]
instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model encoding behavioral dynamics."
    DTDFVocab:inputTo SimulinkEngine
]
instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model used for analytical and predictive capabilities."
    DTDFVocab:inputTo SimulinkEngine
]
instance CPlusPlusModule : DTDFVocab:Model [
    base:desc "C++ module implementing algorithmic functionality."
    DTDFVocab:inputTo SimulinkEngine
]
instance JavaModule : DTDFVocab:Model [
    base:desc "Java module implementing algorithmic functionality."
    DTDFVocab:inputTo DatabaseStorage
]

// Enablers
instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "Simulink runtime environment that executes simulation models."
    DTDFVocab:enables SimulationAnalyticsService
]
instance ModelAlignmentTool : DTDFVocab:Enabler [
    base:desc "Tool that aligns heterogeneous model notations and maps component interfaces across functional, logical, and product layers."
    DTDFVocab:enables ModelIntegrationService
]
instance DatabaseStorage : DTDFVocab:Enabler [
    base:desc "Database that archives code metrics and contextual data traces."
    DTDFVocab:enables DataArchivalService
]

// Services
instance SimulationAnalyticsService : DTDFVocab:Service [
    base:desc "Service that performs simulation analysis and generates predictive insights."
    DTDFVocab:provides PredictiveInsight, AdjustControlAction
]
instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Service that integrates models across layers and ensures alignment."
    DTDFVocab:provides RequirementComplianceInsight
]
instance DataArchivalService : DTDFVocab:Service [
    base:desc "Service that archives data into the database."
    DTDFVocab:provides ArchiveDataAction
]

// Insights
instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulation analysis that predicts future system behavior."
]
instance RequirementComplianceInsight : DTDFVocab:Insight [
    base:desc "Insight indicating compliance of the system with defined requirements."
]

// Actions
instance AdjustControlAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust control parameters based on predictive insight."
    DTDFVocab:IsAutomatic true
]
instance ArchiveDataAction : DTDFVocab:Action [
    base:desc "Action to archive simulation output and contextual data into the database."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "During the development of a Digital Twin the system is modeled in a multi‑level MBSE hierarchy: a requirements level described with SysML; a functional architecture level also captured using SysML; a logical architecture level defined with Architecture Description Languages such as ACME, AADL or MontiArc; and a product (technical) level where detailed component interfaces and composition are specified by SysML Interaction Block Diagrams (IBDs). Transition between these abstraction levels is typically mediated by MBSE practices such as RFLP, OOSEM, SPES, or SMArDT, and the evolution of the models is maintained in a version‑controlled repository. Governance is implicit in the MBSE workflow, requiring integration of heterogeneous stakeholder perspectives."
]