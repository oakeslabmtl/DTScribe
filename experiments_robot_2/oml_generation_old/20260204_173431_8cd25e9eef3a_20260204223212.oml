// ------------------- Sensing Component -------------------
instance DigitalShadowIngestor : DTDFVocab:SensingComponent [
    base:desc "Component that ingests the one‑way data flow from the physical asset (digital shadow) as described in dt_services"
    DTDFVocab:producedData ShadowDataTransmitted
]

// ------------------- Data Transmitted -------------------
instance ShadowDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DigitalShadowIngestor
]

// ------------------- Data -------------------
instance CpsContextualTrace : DTDFVocab:Data [
    base:desc "Contextual data trace collected from the cyber‑physical system and enriched with metadata, per dt_models_and_data"
    DTDFVocab:fromData ShadowDataTransmitted
    DTDFVocab:inputTo SysMLModelingEnabler, SimulinkSimulationEnabler, MachineLearningEnabler
]

// ------------------- Enablers (Tooling) -------------------
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML (block definition and internal block diagrams) MBSE tooling used to capture system structure"
    DTDFVocab:enables MonitoringService, PredictionService, ControlService
]

instance ACMEConnectorEnabler : DTDFVocab:Enabler [
    base:desc "ACME ADL tooling encoding component interfaces and interconnections"
    DTDFVocab:enables MonitoringService
]

instance AADLConnectorEnabler : DTDFVocab:Enabler [
    base:desc "AADL ADL tooling encoding component interfaces and interconnections"
    DTDFVocab:enables MonitoringService
]

instance MontiArcConnectorEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc ADL tooling encoding component interfaces and interconnections"
    DTDFVocab:enables MonitoringService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for white‑box dynamic simulations of physics‑based models"
    DTDFVocab:enables MonitoringService, PredictionService
]

instance MachineLearningEnabler : DTDFVocab:Enabler [
    base:desc "Software modules (C++/Java) executing data‑calculation or machine‑learning regression models"
    DTDFVocab:enables PredictionService, ControlService
]

// ------------------- Services -------------------
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time state monitoring service ingesting processed data and providing monitoring insights"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Predictive indicator generation service that creates forecasts based on hybrid models"
    DTDFVocab:provides PredictiveIndicatorInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Control service that pushes processed information back to the physical system for actuation"
    DTDFVocab:provides ActuatePhysicalSystemAction
]

// ------------------- Insights / Actions -------------------
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Provides operators with up‑to‑date state information of the asset"
]

instance PredictiveIndicatorInsight : DTDFVocab:Insight [
    base:desc "Generates forecasted health or performance indicators"
]

instance ActuatePhysicalSystemAction : DTDFVocab:Action [
    base:desc "Executes control actions on the physical asset based on processed predictions"
    DTDFVocab:IsAutomatic true
]

// ------------------- Models -------------------
instance SysMLBlockDefinitionModel : DTDFVocab:Model [
    base:desc "SysML block definition diagram capturing system structure per dt_models_and_data"
    DTDFVocab:inputTo SysMLModelingEnabler
]

instance ACMEComponentModel : DTDFVocab:Model [
    base:desc "ACME ADL model encoding component interfaces and connections"
    DTDFVocab:inputTo ACMEConnectorEnabler
]

instance AADLComponentModel : DTDFVocab:Model [
    base:desc "AADL ADL model encoding component interfaces and connections"
    DTDFVocab:inputTo AADLConnectorEnabler
]

instance MontiArcComponentModel : DTDFVocab:Model [
    base:desc "MontiArc ADL model encoding component interfaces and connections"
    DTDFVocab:inputTo MontiArcConnectorEnabler
]

instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "White‑box dynamic simulation model implemented in MathWorks Simulink"
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance MachineLearningRegressorModel : DTDFVocab:Model [
    base:desc "Data‑driven machine‑learning regression model combined with physics‑based models"
    DTDFVocab:inputTo MachineLearningEnabler
]

instance HybridPhysicsMLModel : DTDFVocab:Model [
    base:desc "Hybrid model merging physics‑based simulations and ML regressors"
    DTDFVocab:inputTo SimulinkSimulationEnabler, MachineLearningEnabler
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by combining white‑box physics‑based models (e.g., Simulink dynamic simulations) with black‑box data‑driven models to capture complex, non‑linear phenomena. Validation and verification rely on fine‑grained traceability: each generated data trace can be traced back through the ‘originates‑from’ association to the processing component and the specific models that produced it, ensuring correctness of model transformations (e.g., SysML to simulation). Uncertainty sources such as sensor noise or model simplifications are acknowledged, and the traceability infrastructure supports error detection and correction. Quality assurance is achieved through verification of transformations, conformance checking between concrete realizations and the reference digital shadow model, and systematic documentation of model‑data relationships."
]