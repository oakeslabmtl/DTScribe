instance PhysicalSystemTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Physical system telemetry sensor for one-way data flow from physical system"
    DTDFVocab:producedData PhysicalSystemTelemetryDataTransmitted
]

instance PhysicalSystemTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSystemTelemetrySensor
]

instance PhysicalSystemTelemetryData : DTDFVocab:Data [
    base:desc "Data originating from physical system telemetry via digital shadow's one-way data flow"
    DTDFVocab:fromData PhysicalSystemTelemetryDataTransmitted
    DTDFVocab:inputTo Simulink, CPlusPlus, Java
]

instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML model for structural modeling across requirements, functional, logical, and product/technical layers"
    DTDFVocab:inputTo MBSEWithSysML, SysMLIBDs
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL model for component-connector architecture description"
    DTDFVocab:inputTo AADL
]

instance MontiArcComponentConnectorModel : DTDFVocab:Model [
    base:desc "MontiArc model for component-connector architecture description"
    DTDFVocab:inputTo MontiArc
]

instance MontiArcAutomatonBehavioralModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral aspects modeling"
    DTDFVocab:inputTo MontiArc
]

instance SysMLStateMachineModel : DTDFVocab:Model [
    base:desc "SysML state machine for behavioral aspects modeling"
    DTDFVocab:inputTo SysMLIBDs
]

instance SimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for analytical simulations"
    DTDFVocab:inputTo Simulink
]

instance CPlusPlusImplementationModel : DTDFVocab:Model [
    base:desc "C++ implementation for detailed behavior"
    DTDFVocab:inputTo CPlusPlus
]

instance JavaImplementationModel : DTDFVocab:Model [
    base:desc "Java implementation for detailed behavior"
    DTDFVocab:inputTo Java
]

