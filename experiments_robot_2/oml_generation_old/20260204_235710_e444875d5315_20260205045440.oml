// Sensing Component
instance EnvironmentalDataSensor : DTDFVocab:SensingComponent [
    base:desc "Collects contextual data traces from the real‑world environment, including temperature, pressure, and humidity"
    DTDFVocab:producedData EnvironmentalDataTransmission
]

// Data Transmitted
instance EnvironmentalDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalDataSensor
]

// Data
instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated contextual data trace abstracted per the digital shadow reference model"
    DTDFVocab:inputTo SimulinkSimulationEngine
    DTDFVocab:fromData EnvironmentalDataTransmission
]

// Models
instance FunctionalLayerModel : DTDFVocab:Model [
    base:desc "Functional layer model defined using SysML and MontiArc to represent component‑connector architectures"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance LogicalLayerModel : DTDFVocab:Model [
    base:desc "Logical layer model defined in SysML IBDs capturing interactions between logical components"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance ProductTechnicalLayerModel : DTDFVocab:Model [
    base:desc "Product/Technical layer model using AADL and ACME to represent system‑level architecture and implementation details"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

instance StateMachineModel : DTDFVocab:Model [
    base:desc "Behavior model captured via SysML state machines or MontiArc Automaton"
    DTDFVocab:inputTo SimulinkSimulationEngine
]

// Enablers
instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulink engine used to simulate the holistic behavior of the digital twin"
    DTDFVocab:enables SimulationService
]

instance StateMachineExecutionEngine : DTDFVocab:Enabler [
    base:desc "State machine execution engine for processing SysML or MontiArc state machines"
    DTDFVocab:enables StateMachineExecutionService
]

// Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Service that runs Simulink simulations of the digital twin, producing insight and actions"
    DTDFVocab:provides ModelBasedInsight, PerformsSimulationAction
]

instance StateMachineExecutionService : DTDFVocab:Service [
    base:desc "Service that executes state machine definitions, delivering state transition insights"
    DTDFVocab:provides StateMachineExecutionInsight, UpdatePhysicalComponentAction
]

// Insights
instance ModelBasedInsight : DTDFVocab:Insight [
    base:desc "Insight derived from cross‑layer simulation results, aiding decision making about component behavior"
]

instance StateMachineExecutionInsight : DTDFVocab:Insight [
    base:desc "Insight into state progression and control logic execution within the digital twin"
]

// Actions
instance PerformsSimulationAction : DTDFVocab:Action [
    base:desc "Triggers simulation execution in Simulink automatically when data updates occur"
    DTDFVocab:IsAutomatic true
]

instance UpdatePhysicalComponentAction : DTDFVocab:Action [
    base:desc "Manually applied action to adjust physical components based on simulation insights"
    DTDFVocab:IsAutomatic false
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system leverages MQTT as the primary messaging protocol, implemented via the Mosquitto broker (see [52]). Mosquitto supports secure authentication through username/password credentials and optional client certificates, and enforces strict Access Control Lists (ACLs) at the topic level to restrict publish/subscribe rights. Transport security is achieved using TLS v1.2/v1.3, permitting both server‑side and mutual client‑server TLS authentication, and the broker optionally supports SASL mechanisms (PLAIN, EXTERNAL) to further strengthen the authentication channel. In addition, the system integrates the ThingsBoard 4.0.0 open‑source IoT platform (see [53]), which provides comprehensive security and safety controls: JWT‑based authentication for cloud services, OAuth2 and LDAP integration for enterprise single‑sign‑on, role‑based access control (admin, tenant, customer, gateway) that scopes permissions to specific device groups and dashboards, TLS 1.2+ over HTTPS for all HTTP endpoints and MQTT transport, per‑device client certificates or shared access keys, and detailed audit logs for all connection events, message deliveries, and configuration changes. ThingsBoard also implements fail‑safe mechanisms such as automatic reconnect, message persistence, and keep‑alive timeouts, ensuring reliable operation even under network disruptions. The combination of broker‑level ACLs, TLS encryption, and platform‑level RBAC and audit logging forms a layered security posture that mitigates unauthorized access, data tampering, and eavesdropping, while supporting safety‑critical requirements through deterministic message handling and controlled device access."
]