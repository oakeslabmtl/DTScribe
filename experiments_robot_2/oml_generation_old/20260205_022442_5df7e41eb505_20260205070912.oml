// C2: Acting Components
instance PermanentMagneticSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "First axis of the MABI MAX 100 industrial robot uses a permanent‑magnet synchronous motor driving a gear transmission and a cycloidal gearbox for machining tasks."
]

// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Electrical current sensor (I_M) capturing motor current for real‑time monitoring."
    DTDFVocab:producedData MotorCurrentDataMsg
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder on the motor spindle recording joint angles."
    DTDFVocab:producedData MotorPositionDataMsg
]

instance GearwheelPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Position encoder on the gearwheel shaft recording joint angles."
    DTDFVocab:producedData GearwheelPositionDataMsg
]

// C4: Data transmitted by sensors
instance MotorCurrentDataMsg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorPositionDataMsg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance GearwheelPositionDataMsg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearwheelPositionEncoder
]

// C10: Models/Data (processed traces)
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Processed current trace of the permanent‑magnet synchronous motor."
    DTDFVocab:fromData MotorCurrentDataMsg
    DTDFVocab:inputTo MATLABSimulinkEnvironment
]

instance MotorPositionData : DTDFVocab:Data [
    base:desc "Processed motor angle trace derived from motor encoder data."
    DTDFVocab:fromData MotorPositionDataMsg
    DTDFVocab:inputTo MATLABSimulinkEnvironment
]

instance GearwheelPositionData : DTDFVocab:Data [
    base:desc "Processed gearwheel angle trace derived from gearwheel encoder data."
    DTDFVocab:fromData GearwheelPositionDataMsg
    DTDFVocab:inputTo MATLABSimulinkEnvironment
]

instance UpdatedFrictionParametersData : DTDFVocab:Data [
    base:desc "Updated joint friction model parameters derived from continuous identification."
    DTDFVocab:fromData MotorCurrentDataMsg
    DTDFVocab:inputTo MATLABSimulinkEnvironment
]

instance SimulationTraceMotorData : DTDFVocab:Data [
    base:desc "Simulated motor trace output by the motor model."
    DTDFVocab:fromData MotorPositionDataMsg
    DTDFVocab:inputTo MATLABSimulinkEnvironment
]

instance SimulationTraceGearwheelData : DTDFVocab:Data [
    base:desc "Simulated gearwheel trace output by the gearwheel model."
    DTDFVocab:fromData GearwheelPositionDataMsg
    DTDFVocab:inputTo MATLABSimulinkEnvironment
]

// C11: Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML modeling tool used for architectural design and model creation."
    DTDFVocab:enables FrictionIdentificationService, SimulationVisualizationService
]

instance MATLABSimulinkEnvironment : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment used for simulation and continuous friction identification."
    DTDFVocab:enables FrictionIdentificationService, SimulationVisualizationService
]

instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating real‑time sensor data streaming into the digital twin."
    DTDFVocab:enables FrictionIdentificationService, SimulationVisualizationService
]

instance AssetAdministrationShell : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell (AAS) for semantic data integration of the twin."
    DTDFVocab:enables FrictionIdentificationService, SimulationVisualizationService
]

// C6: Services
instance FrictionIdentificationService : DTDFVocab:Service [
    base:desc "Continuous identification of joint friction parameters (Coulomb‑viscous, Stribeck, Dahl, LuGre)."
    DTDFVocab:provides UpdatedFrictionModelParametersInsight, FineTuneControlAction
]

instance SimulationVisualizationService : DTDFVocab:Service [
    base:desc "Visualization service displaying discrepancies between measured and simulated joint behavior."
    DTDFVocab:provides VisualDiscrepancyInsight
]

// C17: Insights
instance UpdatedFrictionModelParametersInsight : DTDFVocab:Insight [
    base:desc "Insight into updated friction model parameters enabling fine‑tuned control accuracy."
]

instance VisualDiscrepancyInsight : DTDFVocab:Insight [
    base:desc "Insight visualizing discrepancies between measured sensor data and simulated traces."
]

// C17: Actions
instance FineTuneControlAction : DTDFVocab:Action [
    base:desc "Allows operators to fine‑tune motor control parameters for improved motion accuracy."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time continuous data streaming and processing; friction models are updated continuously during operation, with no explicit discrete update interval mentioned."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Digital shadow comprising a single asset (first axis), a defined purpose (friction understanding), source data traces (sensors and derived traces), processing component (simulation and data calculation models), simulation models, and a dashboard for visualization; all components are tied together through AAS and an upstream MQTT data pipeline."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Defines four phases: 1) problem identification (friction detection), 2) asset and model analysis (structural and behavioural models), 3) creation of simulation/calculation models (Simulink), 4) data identification and continuous identification during operation; lifecycle includes design, development, validation and runtime refinement."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Ensures fine‑grained traceability linking each data trace back to its generating processing component and underlying models; compares measured PT data to simulated traces to detect deviations; continuous identification mitigates wear‑induced drift; validation performed by overlaying simulation results on live sensor data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data and state streams are transmitted from the robot to the digital shadow via MQTT over TCP/IP; the digital shadow consumes the MQTT topics and processes the data locally; no reverse communication channel is defined."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to SysML for structural and behavioral modeling, Asset Administration Shell for asset representation, use of ACME and AADL for architecture description, and use of MontiArc for component & connector modeling; no specific ISO/IEC numbers mentioned."
]