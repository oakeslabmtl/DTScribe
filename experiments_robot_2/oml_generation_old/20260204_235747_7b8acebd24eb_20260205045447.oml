// ------------------- 1. Real-time sensor chain  -------------------
instance RealTimeSensorStream : DTDFVocab:SensingComponent [
    base:desc "Receives real‑time sensor streams from the physical plant, feeding data into the twin for continuous behavior refinement"
    DTDFVocab:producedData RealTimeDataFeed
]

instance RealTimeDataFeed : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RealTimeSensorStream
]

instance RealTimeDataPackage : DTDFVocab:Data [
    base:desc "Raw data captured from real‑time sensor streams, including temperature, pressure, and vibration metrics"
    DTDFVocab:fromData RealTimeDataFeed
    DTDFVocab:inputTo SimulinkRuntimeEngine
]

instance SimulinkRuntimeEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink engine used to simulate the twin models and verify behavior under defined test conditions"
    DTDFVocab:enables TwinSimulationService
]

instance TwinSimulationService : DTDFVocab:Service [
    base:desc "Provides simulation of data‑driven twin models, enabling adaptive behavior based on real‑time feedback"
    DTDFVocab:provides BehaviorAdaptationInsight
]

instance BehaviorAdaptationInsight : DTDFVocab:Insight [
    base:desc "Insight into refinement of twin behavior, derived from simulation results of real‑time data"
]

// ------------------- 2. Platform data chain  -------------------
instance SpecializedPlatformDataStream : DTDFVocab:SensingComponent [
    base:desc "Receives one‑way data streams from specialized software platforms for contextual data aggregation"
    DTDFVocab:producedData PlatformDataFeed
]

instance PlatformDataFeed : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SpecializedPlatformDataStream
]

instance ContextualDataPackage : DTDFVocab:Data [
    base:desc "Contextual data aggregated from external platforms, used to enrich the twin environment"
    DTDFVocab:fromData PlatformDataFeed
    DTDFVocab:inputTo DatabaseAggregationEngine
]

instance DatabaseAggregationEngine : DTDFVocab:Enabler [
    base:desc "Central database (e.g., InfluxDB) that aggregates contextual data and provides it to the twin"
    DTDFVocab:enables DataContextService
]

instance DataContextService : DTDFVocab:Service [
    base:desc "Provides enrichment of twin data with contextual information retrieved from database"
    DTDFVocab:provides ContextualDataInsight
]

instance ContextualDataInsight : DTDFVocab:Insight [
    base:desc "Insight into contextual data relevance for improving twin decisions"
]

// ------------------- 3. Modeling layer instances  -------------------
instance SysMLRequirementsModel : DTDFVocab:Model [
    base:desc "SysML model capturing high‑level requirements of the twin, following SMArDT methodology"
]

instance SysMLFunctionalModel : DTDFVocab:Model [
    base:desc "SysML model that defines the functional architecture of the twin, mapping requirements to functions"
]

instance SysMLLogicalModel : DTDFVocab:Model [
    base:desc "SysML model representing the logical architecture of the twin, detailing data flows and control logic"
]

instance SysMLProductModel : DTDFVocab:Model [
    base:desc "SysML model that describes product and technical layers of the twin, including physical interfaces"
]

instance ACMEComponentArchitectureModel : DTDFVocab:Model [
    base:desc "ACME model representing component-and-connector topology, interfaces, and compositional hierarchy of the twin"
]

instance AADLComponentArchitectureModel : DTDFVocab:Model [
    base:desc "AADL model used to describe the behavior and structure of ACU components and their real‑time properties"
]

instance MontiArcStructuralModel : DTDFVocab:Model [
    base:desc "MontiArc ADL model that outlines the structural architecture of the twin components and connectivity"
]

instance MontiArcAutomatonBehaviorModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton model capturing detailed behavioral state machines for twin components"
]

// ------------------- 4. Model generation tooling chain  -------------------
instance MontiArcArchitectureTool : DTDFVocab:Enabler [
    base:desc "MontiArc ADL tool used to generate component-and-connector topology from high‑level SysML models"
    DTDFVocab:enables MontiArcModelGenerationService
]

instance MontiArcModelGenerationService : DTDFVocab:Service [
    base:desc "Service that generates MontiArc model artifacts and bridges SysML models to executable code"
    DTDFVocab:provides ModelArtifactInsight
]

instance ModelArtifactInsight : DTDFVocab:Insight [
    base:desc "Provides traceability between high‑level requirements, logic, and generated model artifacts"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital Twin development proceeds through multiple MBSE abstraction levels—requirements, functional architecture, logical architecture, and product/technical layers. At the requirements phase, textual and constraint models are captured; the functional architecture is expressed via SysML requirement diagrams and SysML requirement constraints. The logical architecture is captured in SysML interaction blocks or in MontiArc component‑connector models; the product/technical layer is implemented using C++ or Java code and Simulink blocks. Transition between the levels is managed by model synchronization and co‑simulation (e.g., SysML IBDs exported to Simulink for dynamic simulation). Governance across phases requires an overarching MBSE repository and traceability links that tie SysML requirements to C++ code, ensuring that change propagation and version control are maintained via a configuration management system."
]