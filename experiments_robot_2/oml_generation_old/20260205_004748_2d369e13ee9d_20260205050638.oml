// Sensing Components
instance AngleEncoderDrive1 : DTDFVocab:SensingComponent [
    base:desc "High‑resolution incremental encoder on the first axis, delivering angular position with sub‑millidegree precision."
    DTDFVocab:producedData AngleMqttData
]

instance CurrentSensorDrive1 : DTDFVocab:SensingComponent [
    base:desc "High‑resolution current sensor on the first axis, measuring electrical input current."
    DTDFVocab:producedData CurrentMqttData
]

instance TorqueSensorDrive1 : DTDFVocab:SensingComponent [
    base:desc "Torque sensor on the first axis, recording load torque."
    DTDFVocab:producedData TorqueMqttData
]

instance TrajectoryReferenceGenerator : DTDFVocab:Component [
    base:desc "Component generating desired motion trajectory signals for the first axis."
    DTDFVocab:producedData ReferenceTrajectoryMqttData
]

// Data Transmitted via MQTT
instance AngleMqttData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngleEncoderDrive1
    base:desc "MQTT time‑series packet containing angular position from AngleEncoderDrive1; sampled up to 1 kHz with timestamps synchronized via NTP."
]

instance CurrentMqttData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CurrentSensorDrive1
    base:desc "MQTT time‑series packet containing input current data from CurrentSensorDrive1; sampled up to 1 kHz and transmitted up to 50 kB/s."
]

instance TorqueMqttData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensorDrive1
    base:desc "MQTT time‑series packet containing torque measurements from TorqueSensorDrive1; sampled up to 1 kHz with NTP timestamps."
]

instance ReferenceTrajectoryMqttData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TrajectoryReferenceGenerator
    base:desc "MQTT packet containing desired motion trajectory signals generated by TrajectoryReferenceGenerator; sampled 1 kHz."
]

// Processed Data
instance AngleData : DTDFVocab:Data [
    base:desc "Processed angle measurement data derived from AngleMqttData."
    DTDFVocab:fromData AngleMqttData
    DTDFVocab:inputTo AnalyticsEngine
]

instance CurrentData : DTDFVocab:Data [
    base:desc "Processed current measurement data derived from CurrentMqttData."
    DTDFVocab:fromData CurrentMqttData
    DTDFVocab:inputTo AnalyticsEngine
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Processed torque measurement data derived from TorqueMqttData."
    DTDFVocab:fromData TorqueMqttData
    DTDFVocab:inputTo AnalyticsEngine
]

instance ReferenceTrajectoryData : DTDFVocab:Data [
    base:desc "Processed reference trajectory data derived from ReferenceTrajectoryMqttData."
    DTDFVocab:fromData ReferenceTrajectoryMqttData
    DTDFVocab:inputTo AnalyticsEngine
]

// Simulink simulation output
instance FrictionSimulinkOutput : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SimulinkEngine
    base:desc "Simulink model output containing simulated friction characteristics on the first axis."
]

instance SimulatedFrictionData : DTDFVocab:Data [
    base:desc "Simulated friction data derived from FrictionSimulinkOutput."
    DTDFVocab:fromData FrictionSimulinkOutput
    DTDFVocab:inputTo DataStorageDB
]

// Enablers
instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink execution environment enabling simulation of mechanical models."
    DTDFVocab:enables SimulationService
]

instance AnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Lightweight analytics engine normalising sensor streams, applying threshold checks, and computing key performance indicators."
    DTDFVocab:enables AnalyticsService
]

instance DataStorageDB : DTDFVocab:Enabler [
    base:desc "Database technology storing time‑series data traces and simulation outputs; provides persistence and state management."
    DTDFVocab:enables DataPersistenceService
]

instance MaintenanceWorkflowEngine : DTDFVocab:Enabler [
    base:desc "Event‑driven maintenance workflow engine executing automated tasks based on anomaly alerts."
    DTDFVocab:enables MaintenanceService
]

// Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation execution service that produces simulated friction insights."
    DTDFVocab:provides SimulatedFrictionInsight
]

instance AnalyticsService : DTDFVocab:Service [
    base:desc "Analytics service that provides vibrational‑to‑angle ratio insight and anomaly alerts."
    DTDFVocab:provides VibrationAngleRatioInsight, AnomalyAlertInsight
]

instance DataPersistenceService : DTDFVocab:Service [
    base:desc "Service exposing persistent storage of sensor and simulation data."
    DTDFVocab:provides DataStoredInsight
]

instance MaintenanceService : DTDFVocab:Service [
    base:desc "Action service triggering maintenance workflows when anomalies are detected."
    DTDFVocab:provides TriggeredMaintenanceAction
]

// Insights
instance SimulatedFrictionInsight : DTDFVocab:Insight [
    base:desc "Insight exposing simulated friction characteristics produced by the Simulink model."
]

instance VibrationAngleRatioInsight : DTDFVocab:Insight [
    base:desc "Insight computing vibration‑to‑angle ratio from processed sensor data."
]

instance AnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Insight indicating deviation beyond confidence bounds in monitored metrics."
]

instance DataStoredInsight : DTDFVocab:Insight [
    base:desc "Acknowledgement that data has been stored to the database."
]

// Actions
instance TriggeredMaintenanceAction : DTDFVocab:Action [
    base:desc "Automatic maintenance workflow action triggered by anomaly alerts; logs recommendations with confidence scores."
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle is organized into hierarchical abstraction levels: (1) Requirements, where high‑level specifications are captured; (2) Functional Architecture, modelled with SysML to specify system components and interfaces; (3) Logical Architecture, represented through architecture description languages (ACME, AADL, MontiArc), often enriched with state‑machine constructs; (4) Product/Technical Layer, producing executable artifacts (C++/Java code, Simulink models). Transition between phases is managed through MBSE model refinement, with each lower‑level model concretizing the preceding one, and traceability maintained via SysML‑based artifacts. Governance is typically achieved by applying MBSE practices—traceability, versioned model artifacts—though the document does not detail a formal framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed by quantitative comparison of simulated outputs against measured sensor data, with deviations used to define acceptable error margins. Validation employs statistical residual analysis, uncertainty quantification via Monte Carlo simulation, and runtime consistency checks that flag out‑of‑spec data. Corrections are applied by iteratively tuning Simulink model parameters. Quality assurance follows structured processes similar to IEC 61400‑6, guaranteeing that both data integrity and model accuracy meet documented specifications."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin relies on MQTT for transmitting real‑time sensor streams from the physical system. Data is aggregated within an Asset Administration Shell for integration. No further specifications on bandwidth, latency, redundancy or security are provided in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The system conforms to several interoperability and architecture standards: the data model is encapsulated within an Asset Administration Shell (AAS) following the ISO 23249‑2/IEC 61560 framework for industrial systems; MQTT 3.1.1 is employed for real‑time bi‑directional messaging, while JSON payloads are wrapped in OPC UA data types for gateway integration; behavioural models are authored in SysML v1.7, ensuring compatibility with standard modelling tools. The combination supports certified data exchange and facilitates linkage to broader industry‑wide digital‑twin ecosystems."
]