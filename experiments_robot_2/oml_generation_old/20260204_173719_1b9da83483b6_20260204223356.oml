// C3: Physical sensing components
instance RobotStateSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor that continuously emits intrinsic robot state data, used as the source of contextual data traces for the digital shadow."
    DTDFVocab:producedData RobotStateDataTransmitted
]

// C4: Physical-to-virtual interaction - data transmitted
instance RobotStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RobotStateSensor
]

// C10: Data
instance RobotStateData : DTDFVocab:Data [
    base:desc "Aggregated and abstracted robot state data trace collected from the physical sensor, forming the raw input for processing components."
    DTDFVocab:fromData RobotStateDataTransmitted
    DTDFVocab:inputTo InsightProcessingEnabler
]

// C10: Models
instance SimulinkDynamicSimulationModel : DTDFVocab:Model [
    base:desc "White‑box dynamic simulation model realized in MathWorks Simulink, representing physics‑based behavior of the robot."
    DTDFVocab:inputTo InsightProcessingEnabler
]

instance MachineLearningInferenceModel : DTDFVocab:Model [
    base:desc "Black‑box data‑driven machine‑learning model that ingests intrinsic robot state data to predict higher‑level conditions."
    DTDFVocab:inputTo InsightProcessingEnabler
]

// C11: Enablers
instance InsightProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processing component that consumes raw robot state data and executes attached simulation and ML models to generate derived insights."
    DTDFVocab:enables InsightGenerationService
]

// C6: Services
instance InsightGenerationService : DTDFVocab:Service [
    base:desc "Service that provides decision‑support insights by transforming processed data into higher‑level abstractions."
    DTDFVocab:provides DerivedInsight
]

// C17: Insights
instance DerivedInsight : DTDFVocab:Insight [
    base:desc "Higher‑level abstraction derived from raw sensor traces via simulation and ML models, used for decision support and transparent analytics."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the Model‑Based Systems‑Engineering (MBSE) approach that separates models into successive abstraction levels: (1) requirements model, (2) functional architecture model, (3) logical architecture model, and (4) product/technical layer model. Early phases use SysML requirement diagrams; functional architecture is represented with SysML internal‑block diagrams; logical architecture is captured with component‑connector ADLs such as ACME, AADL, and MontiArc (including MontiArc Automaton for behavior); and the product layer is realized by executable code (C++, Java) or simulation models (e.g., MathWorks Simulink). Transitions between phases are governed by traceability links defined by the “originates‑from” association in the Digital Shadow reference model, which allow each lower‑level element to be traced back to its higher‑level source. Lifecycle governance is achieved by mapping concrete class diagrams to the reference model and enforcing conformance relations during each development step."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by combining white‑box (Simulink) and black‑box (ML) models and by verifying transformations such as SysML‑to‑simulation code to guarantee correctness. Reliability of the digital shadow depends on traceability of model artefacts and verification of data transformations. Sources of uncertainty (e.g., measurement noise, model approximation) are to be quantified, and error detection/correction mechanisms are implied through systematic model‑based verification and validation processes."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The documents mention the MQTT protocol as a communication mechanism, with Mosquitto providing a server and client implementation. IoT platforms such as ThingsBoard (v4.0.0) can be used to manage MQTT‑based data exchange, offering a lightweight publish/subscribe network layer for connecting physical devices to the digital twin."
]