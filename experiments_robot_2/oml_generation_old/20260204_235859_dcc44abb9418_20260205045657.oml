// Sensing components
instance DigitalShadowReferenceSensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensing component representing the digital shadow reference model; it aggregates contextual data traces and abstractions for a specific purpose, creating a continuous one-way data flow into the twin for monitoring and analysis."
    DTDFVocab:producedData ShadowDataTransmitted
]

// Physical‑to‑virtual interaction
instance ShadowDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DigitalShadowReferenceSensor
]

// Data
instance ShadowData : DTDFVocab:Data [
    base:desc "Data representing contextual information for computational modelling and monitoring of the digital twin."
    DTDFVocab:fromData ShadowDataTransmitted
]

// Models/Data
instance SysMLIBDModel : DTDFVocab:Model [
    base:desc "Computational model defined in SysML Integrated Block Diagrams to describe system components, interfaces, and interconnections across functional, logical, and physical abstraction layers."
    DTDFVocab:inputTo CodeGenerator
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "Model expressed in MontiArc with Automaton extension, describing component behaviours via state machines."
    DTDFVocab:inputTo CodeGenerator
]

instance SimulinkSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model implemented in MathWorks Simulink for virtual testing of computational models."
    DTDFVocab:inputTo CodeGenerator
]

instance CppImplementationModel : DTDFVocab:Model [
    base:desc "Executable implementation model generated in C++ from higher-level modeling abstractions."
    DTDFVocab:inputTo CodeGenerator
]

// Enablers
instance CodeGenerator : DTDFVocab:Enabler [
    base:desc "Enabler that targets general‑purpose programming languages such as C++ or Java for runtime deployment of models."
    DTDFVocab:enables MonitoringService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors the twin state, performing analysis and providing insights."
    DTDFVocab:provides TwinStateInsight
]

// Insights / Actions
instance TwinStateInsight : DTDFVocab:Insight [
    base:desc "Insight representing the current state of the digital twin, derived from simulation and real‑time data."
]

// Environment
instance SystemEnvironment : DTDFVocab:Environment [
    base:contains DigitalShadowReferenceSensor, ShadowDataTransmitted, ShadowData,
            SysMLIBDModel, MontiArcAutomatonModel, SimulinkSimulationModel,
            CppImplementationModel, CodeGenerator, MonitoringService, TwinStateInsight
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin’s communication stack is built on Mosquitto, the open‑source MQTT broker described in document 52, which implements the MQTT 3.1.1 protocol with explicit support for TLS encryption (currently TLS 1.2/1.3) and username/password authentication; optional client‑side certificates can be used for mutual TLS to guarantee that only authenticated controllers exchange telemetry.  At the application level, the platform employs Thingsboard (document 53) as an IoT back‑end, providing a multi‑tenant architecture with fine‑grained role‑based access control, JWT‑based device authentication, and mandatory TLS for all MQTT, HTTP and WebSocket traffic, with integrated audit logging for device, tenant and subscription events.  In the overall architecture, the RAMI 4.0 reference model (document 48) offers a dedicated cybersecurity layer that mandates risk assessment procedures, fail‑safe safeguards and a comprehensive resource‑based access control system, ensuring that safety‑critical data flows are isolated, encrypted, and monitored.  The Asset Administration Shell (document 50) encapsulates security metadata at the asset level—security categories, access rules, and cryptographic keys—allowing automated enforcement of ownership and authentication policies when the twin interfaces with the physical robot.  Finally, the functional mockup interface (FMI, document 51) can be employed to exchange simulation models in a version‑controlled, signed‑file format, further protecting model integrity and preventing unauthorized modification."
]