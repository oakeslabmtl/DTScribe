// C3: Physical sensing components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "position encoder mounted on the motor shaft, providing motor shaft angle"
    DTDFVocab:producedData MotorShaftEncoderDataTransmitted
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "secondary encoder placed behind the gearbox, providing gearbox output angle"
    DTDFVocab:producedData GearboxEncoderDataTransmitted
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "current sensor measuring the motor current I_M"
    DTDFVocab:producedData MotorCurrentDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "controller output angle measurement used to derive torque τ and angular velocity ω"
    DTDFVocab:producedData OutputAngleDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance MotorShaftEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxEncoderDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

instance MotorCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

// C10: Data
instance MotorShaftPositionData : DTDFVocab:Data [
    base:desc "time‑series of motor shaft position angle"
    DTDFVocab:fromData MotorShaftEncoderDataTransmitted
    DTDFVocab:inputTo RealTimeFrictionEngine, ControlAdaptationEngine
]

instance GearboxOutputPositionData : DTDFVocab:Data [
    base:desc "time‑series of gearbox output position angle"
    DTDFVocab:fromData GearboxEncoderDataTransmitted
    DTDFVocab:inputTo RealTimeFrictionEngine, ControlAdaptationEngine
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "time‑series of measured motor current I_M"
    DTDFVocab:fromData MotorCurrentDataTransmitted
    DTDFVocab:inputTo RealTimeFrictionEngine, ControlAdaptationEngine
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "time‑series of controller output angle (used for torque and velocity derivation)"
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo RealTimeFrictionEngine, ControlAdaptationEngine
]

// C10: Models/Data (Models)
instance SysMLAxisModel : DTDFVocab:Model [
    base:desc "SysML block definition and internal block diagram of the axis, motor and gearboxes"
    DTDFVocab:inputTo RealTimeFrictionEngine
]

instance SimulinkGearboxFrictionModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the gearbox including friction‑free and friction models (Coulomb‑Viscous, Stribeck, Dahl, LuGre)"
    DTDFVocab:inputTo RealTimeFrictionEngine
]

instance DataCalculationModel : DTDFVocab:Model [
    base:desc "model for deriving torque τ and angular velocity ω from measured current I_M and angle"
    DTDFVocab:inputTo RealTimeFrictionEngine, ControlAdaptationEngine
]

// C11: Enablers
instance RealTimeFrictionEngine : DTDFVocab:Enabler [
    base:desc "MQTT‑based processing engine that receives live sensor streams and computes friction parameters using MATLAB/Simulink models"
    DTDFVocab:enables RealTimeFrictionIdentificationService, ParameterExtractionService
]

instance DashboardEngine : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard engine that visualizes measured and simulated data"
    DTDFVocab:enables DashboardVisualizationService
]

instance ControlAdaptationEngine : DTDFVocab:Enabler [
    base:desc "Engine that applies updated friction parameters to the SINUMERIK 840D controller to improve motion‑control accuracy"
    DTDFVocab:enables MotionControlImprovementService
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "real‑time identification of static, kinetic and viscous friction in the gearbox"
    DTDFVocab:provides InsightFrictionParameterDerivation
]

instance ParameterExtractionService : DTDFVocab:Service [
    base:desc "extraction of friction model parameters for updating the robot controller"
    DTDFVocab:provides ActionUpdateControllerParameters
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "visualization of measured and simulated data on a web dashboard"
    DTDFVocab:provides InsightSimulationMeasurementDeviation
]

instance MotionControlImprovementService : DTDFVocab:Service [
    base:desc "supports improving robot motion‑control accuracy using updated friction parameters"
    DTDFVocab:provides ActionSupportMotionControlAccuracy
]

// C17: Insights
instance InsightFrictionParameterDerivation : DTDFVocab:Insight [
    base:desc "derived static, kinetic and viscous friction parameters for the gearbox"
]

instance InsightSimulationMeasurementDeviation : DTDFVocab:Insight [
    base:desc "identified deviations between simulated and measured behavior of the axis"
]

// C17: Actions
instance ActionUpdateControllerParameters : DTDFVocab:Action [
    base:desc "provides updated friction parameters to improve the robot controller’s accuracy"
    DTDFVocab:IsAutomatic true
]

instance ActionSupportMotionControlAccuracy : DTDFVocab:Action [
    base:desc "applies updated parameters to enhance robot motion‑control accuracy"
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation synchronized with the robot’s sensor update cycle; data are processed continuously during robot operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A purpose‑driven digital shadow (FrictionShadow) comprising a purpose object (FrictionDerivation), the asset (MABI axis), multiple DataTrace objects (measured I_M, r_M, r_G, r_out and simulated ˆr_M, ˆr_G, ˆr_out), Processing components (Simulation_M, Simulation_GW, Simulation_GB) that execute the Simulink models, and linkage to engineering, data‑calculation and simulation model types according to the Digital Shadow Reference Model."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated (runtime) stage – the digital shadow is created and used while the robot is executing machining tasks to monitor and improve performance."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each data point to its source and processing component, use of both white‑box (analytical) and black‑box (data‑driven) friction models, multi‑physics aware identification, and validation by comparing simulated friction‑free behavior with measured data to assess model accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are transmitted from the robot to the digital shadow over MQTT; the Asset Administration Shell framework is employed for model‑data linking, but specific network protocols beyond MQTT are not detailed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) standard for model integration, SysML as an engineering modeling standard, and adherence to the Digital Shadow Reference Model (UML class diagram) for structuring the digital shadow."
]