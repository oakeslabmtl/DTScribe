instance SysMLStructuralModel : DTDFVocab:Model [
    base:desc "SysML for structural modeling (component & connector perspectives via IBDs)"
    DTDFVocab:inputTo SysMLTool
]

instance MontiArcAutomatonModel : DTDFVocab:Model [
    base:desc "MontiArc Automaton for behavioral modeling"
    DTDFVocab:inputTo MontiArcADL
]

instance SysMLStateMachinesModel : DTDFVocab:Model [
    base:desc "SysML state machines for behavioral modeling"
    DTDFVocab:inputTo SysMLTool, Simulink
]

instance RequirementsModel : DTDFVocab:Model [
    base:desc "Requirements abstraction level model"
    DTDFVocab:inputTo RFLPMethodology, OOSEMMethodology, SPESMethodology, SMArDTMethodology
]

instance FunctionalArchitectureModel : DTDFVocab:Model [
    base:desc "Functional architecture model"
    DTDFVocab:inputTo RFLPMethodology, OOSEMMethodology, SPESMethodology, SMArDTMethodology
]

instance LogicalArchitectureModel : DTDFVocab:Model [
    base:desc "Logical architecture model"
    DTDFVocab:inputTo RFLPMethodology, OOSEMMethodology, SPESMethodology, SMArDTMethodology
]

instance ProductTechnicalLayerModel : DTDFVocab:Model [
    base:desc "Product/technical layer model"
    DTDFVocab:inputTo CPlusPlus, Java
]

instance SysMLTool : DTDFVocab:Enabler [
    base:desc "SysML for structural modeling"
    DTDFVocab:enables StructuralModelingService
]

instance ACME : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language"
    DTDFVocab:enables ArchitectureDescriptionService
]

instance AADL : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language"
    DTDFVocab:enables ArchitectureDescriptionService
]

instance MontiArcADL : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language"
    DTDFVocab:enables BehavioralModelingService
]

instance RFLPMethodology : DTDFVocab:Enabler [
    base:desc "RFLP methodology for abstraction level management"
    DTDFVocab:enables AbstractionLevelManagementService
]

instance OOSEMMethodology : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for abstraction level management"
    DTDFVocab:enables AbstractionLevelManagementService
]

instance SPESMethodology : DTDFVocab:Enabler [
    base:desc "SPES methodology for abstraction level management"
    DTDFVocab:enables AbstractionLevelManagementService
]

instance SMArDTMethodology : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for abstraction level management"
    DTDFVocab:enables AbstractionLevelManagementService
]

instance Simulink : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for dynamic behavior simulation"
    DTDFVocab:enables SimulationService
]

instance CPlusPlus : DTDFVocab:Enabler [
    base:desc "C++ general-purpose programming language for detailed implementation"
    DTDFVocab:enables ImplementationService
]

instance Java : DTDFVocab:Enabler [
    base:desc "Java general-purpose programming language for detailed implementation"
    DTDFVocab:enables ImplementationService
]

instance StructuralModelingService : DTDFVocab:Service [
    base:desc "Structural modeling service using SysML"
    DTDFVocab:provides StructuralModelingInsight
]

instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Behavioral modeling service using MontiArc and SysML state machines"
    DTDFVocab:provides BehavioralModelingInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Dynamic behavior simulation service using Simulink"
    DTDFVocab:provides SimulationInsight
]

instance ArchitectureDescriptionService : DTDFVocab:Service [
    base:desc "Architecture description service using ACME, AADL, MontiArc"
    DTDFVocab:provides ArchitectureDescriptionInsight
]

instance AbstractionLevelManagementService : DTDFVocab:Service [
    base:desc "Abstraction level management service using RFLP, OOSEM, SPES, SMArDT"
    DTDFVocab:provides AbstractionLevelManagementInsight
]

instance ImplementationService : DTDFVocab:Service [
    base:desc "Detailed implementation service using C++ and Java"
    DTDFVocab:provides ImplementationInsight
]

instance RequirementsManagementService : DTDFVocab:Service [
    base:desc "Requirements management service"
    DTDFVocab:provides RequirementsManagementInsight
]

instance StructuralModelingInsight : DTDFVocab:Insight [
    base:desc "Structural model analysis insight"
]

instance BehavioralModelingInsight : DTDFVocab:Insight [
    base:desc "Behavioral model analysis insight"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results insight"
]

instance ArchitectureDescriptionInsight : DTDFVocab:Insight [
    base:desc "Architecture description insight"
]

instance AbstractionLevelManagementInsight : DTDFVocab:Insight [
    base:desc "Abstraction level management insight"
]

instance ImplementationInsight : DTDFVocab:Insight [
    base:desc "Implementation details insight"
]

instance RequirementsManagementInsight : DTDFVocab:Insight [
    base:desc "Requirements management insight"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system utilizes Model-Based Systems Engineering (MBSE) with SysML [17] for system modeling across abstraction levels (requirements, functional architecture, logical architecture, product/technical layer). Architecture Description Languages (ADLs) such as ACME [23], AADL [24], MontiArc [25], [26], and SysML IBDs [17], [27] are employed for component-based descriptions, including interfaces and interconnections. Behavior modeling is handled via MontiArc Automaton and SysML state machines, enhanced by tools like MathWorks Simulink [28], simulation methods [29], [30], and general-purpose languages (C++, Java). Methodologies including RFLP [18], [19], OOSEM [20], SPES [21], and SMArDT [22] manage complexity."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security measures include X.509 certificate-based authentication and role-based access control (RBAC) for Asset Administration Shell (AAS) components per Plattform Industrie 4.0 standards, TLS encryption for MQTT communication using Mosquitto server, JWT token authentication and RBAC in Thingsboard IoT platform, and RAMI4.0 security dimension integration for cross-layer cybersecurity protocols."
]