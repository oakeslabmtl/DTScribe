// C10: Models/Data
instance KinematicStateModel : DTDFVocab:Model [
    base:desc "Structured digital representation of robot kinematic states (joint angles, trajectories) derived from sensor data for validation against physical system behavior."
    DTDFVocab:inputTo SysMLModelingTool, SimulinkSimulationEngine
]

instance FrictionModel : DTDFVocab:Model [
    base:desc "Physics-based friction model for cycloidal gear transmissions and motor actuators, validated through simulation-based comparison with real-time sensor data."
    DTDFVocab:inputTo SysMLModelingTool, SimulinkSimulationEngine
]

instance RobotStateMachineModel : DTDFVocab:Model [
    base:desc "State machine representation of MABI MAX 100 operational modes (idle, machining, calibration) using SysML v1.7 or equivalent for behavioral modeling."
    DTDFVocab:inputTo SysMLModelingTool
]

instance JointAngleData : DTDFVocab:Data [
    base:desc "Time-series angular position data from all six axes, aggregated with high sampling frequency for kinematic accuracy validation."
    DTDFVocab:fromData JointAngleDataAxis1, JointAngleDataAxis2, JointAngleDataAxis3,
                   JointAngleDataAxis4, JointAngleDataAxis5, JointAngleDataAxis6
    DTDFVocab:inputTo SysMLModelingTool, SimulinkSimulationEngine
]

instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Time-series motor current measurements from all six axes, used for friction coefficient estimation and dynamic validation."
    DTDFVocab:fromData MotorCurrentDataAxis1, MotorCurrentDataAxis2, MotorCurrentDataAxis3,
                   MotorCurrentDataAxis4, MotorCurrentDataAxis5, MotorCurrentDataAxis6
    DTDFVocab:inputTo SysMLModelingTool, SimulinkSimulationEngine
]

instance GearboxTemperatureData : DTDFVocab:Data [
    base:desc "Temperature data from gearbox components, passively collected for thermal friction model validation (implicit in characteristics)."
    DTDFVocab:inputTo SysMLModelingTool
]

// C11: Enablers
instance SiemensSinumerik840DslController : DTDFVocab:Enabler [
    base:desc "Primary control system providing real-time kinematic and dynamic data (joint angles, motor currents) via MQTT protocol for Digital Shadow integration."
    DTDFVocab:enables DataAcquisitionService, SimulationValidationService
]

instance MQTTProtocol : DTDFVocab:Enabler [
    base:desc "Lightweight publish-subscribe protocol enabling real-time, event-triggered data streaming from Siemens SINUMERIK 840D sl controller to Digital Shadow."
    DTDFVocab:enables DataAcquisitionService
]

instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "Systems Modeling Language tool for multi-abstraction-level modeling (requirements, functional/logical architecture, product layer) of MABI robot components and interfaces."
    DTDFVocab:enables BehavioralModelingService, DataVisualizationService
]

instance SimulinkSimulationEngine : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink environment for detailed behavioral modeling of friction dynamics and control system validation, integrated with SysML for system-level behavior description."
    DTDFVocab:enables SimulationValidationService, DataVisualizationService
]

// C6: Services
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Passive collection and preprocessing of contextual data traces (joint torques, motor currents, gearbox temperatures) from Siemens SINUMERIK 840D sl controller via MQTT protocol."
    DTDFVocab:provides FrictionModelValidationInsight, KinematicAccuracyInsight
]

instance SimulationValidationService : DTDFVocab:Service [
    base:desc "Simulation-based validation of friction models and kinematic accuracy using MathWorks Simulink integrated with SysML for system-level behavior description."
    DTDFVocab:provides ModelValidationInsight, PerformanceDeviationInsight
]

instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "State machine-based behavioral modeling of robot operational modes (idle, machining, calibration) using SysML v1.7 or equivalent."
    DTDFVocab:provides OperationalModeInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Real-time and historical data visualization in dashboard interface, enabling comparative analysis between simulated and physical system states."
    DTDFVocab:provides VisualComparisonInsight, SystemHealthInsight
]

// C17: Insights/Actions
instance FrictionModelValidationInsight : DTDFVocab:Insight [
    base:desc "Validation of friction model accuracy through comparison between simulated and real-time sensor data, identifying deviations in cycloidal gear transmissions."
]

instance KinematicAccuracyInsight : DTDFVocab:Insight [
    base:desc "Assessment of joint trajectory accuracy and synchronization across all six axes, highlighting discrepancies between physical and digital representations."
]

instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Verification of simulation models against physical system behavior, ensuring alignment between digital twin predictions and real-world performance."
]

instance PerformanceDeviationInsight : DTDFVocab:Insight [
    base:desc "Identification of performance deviations in machining tasks due to unmodeled friction or kinematic errors, quantified through comparative analysis."
]

instance OperationalModeInsight : DTDFVocab:Insight [
    base:desc "Behavioral validation of robot operational states (idle, machining, calibration) against expected state machine transitions and timing constraints."
]

instance VisualComparisonInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of friction model deviations, joint trajectories, and system health metrics for intuitive comparative analysis."
]

instance SystemHealthInsight : DTDFVocab:Insight [
    base:desc "Monitoring of gearbox temperatures and motor currents to assess system health and potential degradation over time."
]

