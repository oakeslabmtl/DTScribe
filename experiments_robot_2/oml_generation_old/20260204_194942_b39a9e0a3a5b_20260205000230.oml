// ===========================
// Physical Sensing Components
// ===========================

instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the electrical input current of each robot joint motor"
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the output angular position (angle) of each robot joint"
    DTDFVocab:producedData OutputAngleDataTransmitted
]

instance JointTorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the torque delivered by each joint motor‑gearbox unit"
    DTDFVocab:producedData JointTorqueDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the angular velocity of each robot joint"
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

instance AngularAccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the angular acceleration of each robot joint"
    DTDFVocab:producedData AngularAccelerationDataTransmitted
]

// ===========================
// Data Transmitted (Physical → Virtual)
// ===========================

instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

instance JointTorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointTorqueSensor
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
]

instance AngularAccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularAccelerationSensor
]

// ===========================
// Raw Data (Aggregated / Abstracted)
// ===========================

instance InputCurrentData : DTDFVocab:Data [
    base:desc "Aggregated input current trace for friction analysis"
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkEngineEnabler
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Aggregated joint angle trace for friction analysis"
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkEngineEnabler
]

instance JointTorqueData : DTDFVocab:Data [
    base:desc "Aggregated torque trace for friction analysis"
    DTDFVocab:fromData JointTorqueDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkEngineEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Aggregated angular velocity trace for friction analysis"
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkEngineEnabler
]

instance AngularAccelerationData : DTDFVocab:Data [
    base:desc "Aggregated angular acceleration trace for friction analysis"
    DTDFVocab:fromData AngularAccelerationDataTransmitted
    DTDFVocab:inputTo MQTTBrokerEnabler, SimulinkEngineEnabler
]

// ===========================
// Enablers (Software / Middleware)
// ===========================

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Mosquitto MQTT broker implementing the one‑way automated data flow from the robot to the digital shadow"
    DTDFVocab:enables AggregationAndAbstractionService, MonitoringVisualizationService
]

instance SimulinkEngineEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink engine executing the friction simulation model"
    DTDFVocab:enables MonitoringVisualizationService
]

instance MBSEToolChainEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Based Systems Engineering tool chain (SysML, ACME, AADL) generating digital‑shadow artefacts and versioned models"
    DTDFVocab:enables AggregationAndAbstractionService
]

// ===========================
// Services (Digital Shadow)
// ===========================

instance AggregationAndAbstractionService : DTDFVocab:Service [
    base:desc "Automated aggregation and abstraction of contextual sensor data to support friction‑related analysis in a dashboard"
    DTDFVocab:provides FrictionRelationInsight
]

instance MonitoringVisualizationService : DTDFVocab:Service [
    base:desc "Monitoring and diagnostic visualisation of friction‑related relations for operators"
    DTDFVocab:provides DiagnosticInsight
]

// ===========================
// Insights / Actions
// ===========================

instance FrictionRelationInsight : DTDFVocab:Insight [
    base:desc "Insight into friction‑related relationships derived from aggregated sensor data"
]

instance DiagnosticInsight : DTDFVocab:Insight [
    base:desc "Diagnostic insight highlighting abnormal friction or wear conditions for operator awareness"
]

// ===========================
// Models (Structural & Behavioural)
// ===========================

instance RobotGeometricModel : DTDFVocab:Model [
    base:desc "Geometric/structural model of the six‑axis MABI MAX 100 robot captured in SysML block diagrams"
    DTDFVocab:inputTo MBSEToolChainEnabler
]

instance RobotBehaviorStateMachineModel : DTDFVocab:Model [
    base:desc "State‑machine model of robot joint behaviour (SysML v1.7, MontiArc Automaton) used for simulation"
    DTDFVocab:inputTo MBSEToolChainEnabler
]

instance FrictionSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink friction model that predicts torque losses based on sensor inputs"
    DTDFVocab:inputTo SimulinkEngineEnabler
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated through a Processing component as defined in the Digital Shadow Reference Model. This component consumes input data traces, applies either simulation models or data‑calculation models, and produces output data traces that become part of the shadow. Traceability is encoded by the 'originates from' association, allowing each output trace to be linked back to the generating processing component, the consumed input traces, and the specific models used; this traceability is maintained transitively across the workflow. Concretization of the reference model yields concrete classes, associations, and mappings that instantiate the orchestration logic for a particular domain."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The document outlines a digital‑twin lifecycle that follows a Model‑Based Systems‑Engineering (MBSE) sequence: starting with requirement modelling, progressing to functional architecture, then logical architecture, and finally the product/technical layer. During the development phase the twin is represented with SysML models; when the physical system is deployed, a digital shadow is instantiated that receives an automated one‑way data flow from the asset. Transition between these phases is managed by maintaining traceability links between the MBSE artefacts and the generated data‑trace aggregation that constitutes the shadow, while governance relies on preserving consistency across heterogeneous modelling notations and stakeholder perspectives."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between the physical sensors and the digital shadow relies on the MQTT protocol, with Mosquitto serving as the broker and client implementations referenced (Light, 2017). The network follows a broker‑client topology where sensor endpoints publish MQTT messages to the broker, which are then consumed by the digital twin services (e.g., Thingsboard platform). Bandwidth and latency requirements are not quantified in the documents, and reliability is assumed to be provided by MQTT’s QoS mechanisms. No explicit security protocols (e.g., TLS) or redundancy schemes are described."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The methodology adopts widely recognised modelling standards: SysML (an OMG standard) for requirements and structural diagrams, and several ADLs—including ACME, AADL, and MontiArc—that are established language specifications for component‑connector architectures. The digital shadow reference model itself is expressed as a UML class diagram, aligning with the UML standard for system description."
]