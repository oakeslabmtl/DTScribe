// C3: Physical sensing components
instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Captures real-time input current measurements from the MABI MAX 100 robot's permanent magnet synchronous motor for friction loss analysis."
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance TorqueSensor : DTDFVocab:SensingComponent [
    base:desc "Measures torque output from the robot's gearbox to detect mechanical wear and friction characteristics."
    DTDFVocab:producedData TorqueDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Tracks angular velocity of the robot axis to enable real-time kinematic modeling and motion accuracy validation."
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

// C4: Physical-to-virtual interaction
instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
    base:desc "Transmits raw input current measurements via MQTT protocol for low-bandwidth sensor data aggregation."
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TorqueSensor
    base:desc "Transmits torque measurements via MQTT protocol for contextual data trace aggregation."
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
    base:desc "Transmits angular velocity data via MQTT protocol for real-time motion analysis."
]

// C10: Models/Data
instance RobotKinematicModel : DTDFVocab:Model [
    base:desc "SysML-based component-connector architecture model representing the MABI MAX 100's mechanical structure including motor, gearbox, and controller."
    DTDFVocab:inputTo SysMLModelingEnabler, SimulinkSimulationEnabler
]

instance FrictionLossSimulationModel : DTDFVocab:Model [
    base:desc "Physics-based simulation model implemented in MATLAB Simulink for analyzing friction characteristics and loss detection."
    DTDFVocab:inputTo SimulinkSimulationEnabler
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Aggregated time-series sensor data (input current, torque, angular velocity) collected via Digital Shadow for analytical purposes."
    DTDFVocab:fromData InputCurrentDataTransmitted, TorqueDataTransmitted, AngularVelocityDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler
]

instance RobotControlParameters : DTDFVocab:Data [
    base:desc "Calibration and control parameters derived from simulation analysis for improving motion accuracy."
    DTDFVocab:fromData FrictionLossSimulationOutputData
    DTDFVocab:inputTo ControlParameterEnabler
]

instance FrictionLossSimulationOutputData : DTDFVocab:Data [
    base:desc "Output data from friction loss simulation model containing analysis results for control parameter derivation."
    DTDFVocab:fromData FrictionLossSimulationModel
]

// C11: Enablers
instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML Internal Block Diagrams (IBDs) for defining component-connector architecture of the robot system."
    DTDFVocab:enables RobotArchitectureService
]

instance SimulinkSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB Simulink environment for executing behavioral models and friction loss simulations."
    DTDFVocab:enables SimulationAnalysisService, ControlParameterEnabler
]

instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "MQTT-based data aggregation layer for passive collection of sensor traces from the physical system."
    DTDFVocab:enables PassiveDataCollectionService
]

instance ControlParameterEnabler : DTDFVocab:Enabler [
    base:desc "Software system for interpreting simulation results and generating control parameter adjustments."
    DTDFVocab:enables MotionAccuracyImprovementAction
]

// C6: Services
instance PassiveDataCollectionService : DTDFVocab:Service [
    base:desc "Acts as a digital shadow with automated one-way data flow from physical system to digital model for contextual data trace aggregation."
    DTDFVocab:provides RobotStateInsight
]

instance SimulationAnalysisService : DTDFVocab:Service [
    base:desc "Leverages MATLAB Simulink for behavioral modeling and friction loss simulation integrated with Siemens SINUMERIK 840D sl controller."
    DTDFVocab:provides FrictionLossInsight, MotionAccuracyInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Provides dashboard-based visualization of system states, data trends, and simulation results for stakeholder monitoring."
    DTDFVocab:provides VisualizedRobotStateInsight
]

instance RobotArchitectureService : DTDFVocab:Service [
    base:desc "Defines and maintains the SysML component-connector architecture of the MABI MAX 100 robot system."
    DTDFVocab:provides StructuralModelInsight
]

// C17: Insights/Actions
instance RobotStateInsight : DTDFVocab:Insight [
    base:desc "Aggregated contextual data traces representing current operational state of the robot axis for monitoring purposes."
]

instance FrictionLossInsight : DTDFVocab:Insight [
    base:desc "Identified friction characteristics and loss patterns derived from torque and current measurements."
]

instance MotionAccuracyInsight : DTDFVocab:Insight [
    base:desc "Real-time kinematic accuracy assessment based on angular velocity and position feedback."
]

instance VisualizedRobotStateInsight : DTDFVocab:Insight [
    base:desc "Dashboard visualization of robot operational parameters including current, torque, and angular velocity trends."
]

instance StructuralModelInsight : DTDFVocab:Insight [
    base:desc "Component-connector architecture representation of the robot's mechanical and control system structure."
]

instance MotionAccuracyImprovementAction : DTDFVocab:Action [
    base:desc "Automated generation of control parameter adjustments based on friction loss analysis to improve robot motion accuracy."
    DTDFVocab:IsAutomatic true
]

// C1: Physical Twin System Environment
instance MABIMax100RobotEnvironment : DTDFVocab:Environment [
    base:desc "High-precision manufacturing environment containing the MABI MAX 100 serial industrial robot with permanent magnet synchronous motor, gearbox, and Siemens SINUMERIK 840D sl controller."
    base:contains PermanentMagnetSynchronousMotor, GearboxComponent, SINUMERIK840DslController
]

instance PermanentMagnetSynchronousMotor : DTDFVocab:Component [
    base:desc "Primary actuator driving the first axis of the MABI MAX 100 robot with input current and torque measurement capabilities."
    base:isContainedIn MABIMax100RobotEnvironment
]

instance GearboxComponent : DTDFVocab:Component [
    base:desc "Mechanical transmission system connecting the motor to the robot axis with torque measurement capabilities."
    base:isContainedIn MABIMax100RobotEnvironment
]

instance SINUMERIK840DslController : DTDFVocab:Component [
    base:desc "Siemens industrial controller interfacing with the physical system to collect real-time operational data and execute motion commands."
    base:isContainedIn MABIMax100RobotEnvironment
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system leverages real-time data streaming via **MQTT** for synchronization between the physical and digital components, implying low-latency, event-driven updates. The temporal granularity is determined by the frequency of sensor data acquisition, which is streamed continuously to maintain an up-to-date digital representation. While the document does not specify exact synchronization frequencies or latency requirements, the use of MQTT suggests a **real-time or near-real-time** operational paradigm, where data is pushed asynchronously to the Digital Twin for immediate processing. The system's temporal aspects are inherently tied to the **data-driven, real-time** nature of the Digital Twin, ensuring alignment between the physical and digital states through continuous data flow."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellation in this context is orchestrated through **Model-Based Systems Engineering (MBSE)** methodologies, leveraging **architecture description languages (ADLs)** such as **ACME, AADL, MontiArc, or SysML Internal Block Diagrams (IBDs)** to define component-based structures, interfaces, and interconnections. The system employs **component & connector perspectives** to model interactions, with some ADLs (e.g., MontiArc Automaton or SysML state machines) extending to behavioral descriptions. Integration of heterogeneous tools (e.g., **MathWorks Simulink, simulation tools, or general-purpose languages like C++/Java**) is required to manage complexity across **requirements, functional, logical, and product/technical layers**. The constellation lacks explicit details on resource management or system-wide coordination mechanisms but implies a **modular, hierarchical architecture** where active components (e.g., Digital Twin services) process data traces from digital shadows (passive entities)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **validation and verification processes** to ensure model fidelity, primarily through **comparative analysis of simulated data against measured data** to quantify deviations and uncertainties. The **sensor arrangement** (e.g., position encoders) is designed to **reduce backlash and positional uncertainty**, indirectly contributing to data accuracy. However, the document does not specify formal verification methods (e.g., model checking, theorem proving), explicit uncertainty quantification frameworks, or structured quality assurance processes (e.g., ISO/IEC standards, traceability matrices). Error detection mechanisms are implied through data-driven validation but lack detailed correction protocols or automated feedback loops. The system’s reliance on **MBSE methodologies** (e.g., RFLP, OOSEM) suggests layered validation but does not provide granularity on fidelity metrics or error propagation studies."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for the Digital Shadow system leverages the **MQTT protocol** for streaming sensor data from physical assets to the digital representation. While the document does not specify **network topology**, **bandwidth requirements**, or **latency constraints**, the use of MQTT implies support for **low-power, intermittent connectivity** environments typical in industrial IoT deployments. No details are provided regarding **reliability mechanisms** (e.g., redundancy, failover), **security protocols** (e.g., TLS, authentication), or **network architecture** (e.g., star, mesh). The infrastructure is designed to handle **time-series data** with minimal overhead, but no explicit **data routing** or **protocol extensions** are mentioned."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with **external data sources** through **MQTT-based streaming protocols**, enabling real-time exchange of **sensor time-series data** from the physical system. While the document does not explicitly mention **interoperability standards** (e.g., OPC UA, REST APIs) or **enterprise system dependencies**, the use of MQTT implies adherence to **lightweight, publish-subscribe communication** for data exchange. Integration patterns are **data-centric**, focusing on **asynchronous, event-driven** updates rather than synchronous or transactional interactions. No details are provided on **cross-Digital Twin coordination** or **enterprise-level integration**, but the system is designed to **consume and process external data streams** dynamically."
]