// C3: Physical Sensing Components
instance OperationalLogSensor : DTDFVocab:SensingComponent [
    base:desc "Collects operational logs from the physical system for contextual data traces, supporting real-time or near-real-time transmission."
    DTDFVocab:producedData OperationalLogDataTransmitted
]

instance EnvironmentalMetricsSensor : DTDFVocab:SensingComponent [
    base:desc "Gathers environmental metrics (e.g., temperature, humidity) from the physical system for aggregation and abstraction."
    DTDFVocab:producedData EnvironmentalMetricsDataTransmitted
]

instance PhysicalSystemSensor : DTDFVocab:SensingComponent [
    base:desc "Collects raw sensor readings from the physical system, including time-series or discrete event data."
    DTDFVocab:producedData PhysicalSystemDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance OperationalLogDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Aggregated operational logs transmitted from the physical system to the digital representation in a unidirectional flow."
    DTDFVocab:producedFrom OperationalLogSensor
]

instance EnvironmentalMetricsDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Environmental metrics (e.g., temperature, humidity) transmitted in real-time or near-real-time from the physical system."
    DTDFVocab:producedFrom EnvironmentalMetricsSensor
]

instance PhysicalSystemDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Raw or preprocessed sensor readings (time-series or discrete events) transmitted from the physical system."
    DTDFVocab:producedFrom PhysicalSystemSensor
]

// C10: Models/Data
instance ContextualDataTraceModel : DTDFVocab:Model [
    base:desc "Structured representation of aggregated contextual data traces (e.g., sensor readings, operational logs) for analytical purposes."
    DTDFVocab:inputTo DataAggregationEnabler, DataAbstractionEnabler
]

instance HeterogeneousDataIntegrationModel : DTDFVocab:Model [
    base:desc "Model ensuring compatibility with heterogeneous data sources and modeling tools (e.g., SysML IBDs, MontiArc ADLs)."
    DTDFVocab:inputTo DataIntegrationEnabler
]

instance OperationalLogData : DTDFVocab:Data [
    base:desc "Processed operational logs aggregated from the physical system, filtered or normalized for analysis."
    DTDFVocab:fromData OperationalLogDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler, DataAbstractionEnabler
]

instance EnvironmentalMetricsData : DTDFVocab:Data [
    base:desc "Aggregated environmental metrics (e.g., temperature, humidity) after preprocessing (e.g., scaling, noise reduction)."
    DTDFVocab:fromData EnvironmentalMetricsDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler, DataAbstractionEnabler
]

instance PhysicalSystemData : DTDFVocab:Data [
    base:desc "Structured sensor readings (time-series or discrete events) after preprocessing (e.g., feature extraction, normalization)."
    DTDFVocab:fromData PhysicalSystemDataTransmitted
    DTDFVocab:inputTo DataAggregationEnabler, DataAbstractionEnabler
]

// C11: Enablers
instance DataAggregationEnabler : DTDFVocab:Enabler [
    base:desc "Middleware component responsible for aggregating raw data traces (e.g., sensor readings, logs) into structured representations."
    DTDFVocab:enables DataInterpretationService, DataMonitoringService
]

instance DataAbstractionEnabler : DTDFVocab:Enabler [
    base:desc "Component applying abstraction techniques (e.g., filtering, normalization) to preprocessed data for analytical use."
    DTDFVocab:enables DataAnalysisService, PredictiveModelingService
]

instance DataIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Enables interoperability between heterogeneous data sources (e.g., SysML IBDs, MontiArc ADLs) and modeling tools."
    DTDFVocab:enables SystemSimulationService, CrossToolCollaborationService
]

instance SysMLModelingEnabler : DTDFVocab:Enabler [
    base:desc "SysML-based framework for multi-layered system abstraction (requirements, functional/logical/technical architectures)."
    DTDFVocab:enables SystemDesignService, BehavioralModelingService
]

instance MontiArcADLEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Architecture Description Language for component-connector modeling and behavioral specifications (e.g., automata)."
    DTDFVocab:enables ComponentModelingService, BehavioralSimulationService
]

instance MathWorksSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "Simulation tool for detailed behavioral modeling and hybrid system dynamics (discrete-event and continuous-time)."
    DTDFVocab:enables SimulationExecutionService, CoSimulationService
]

instance CppJavaCodeGenerationEnabler : DTDFVocab:Enabler [
    base:desc "General-purpose programming languages (C++/Java) for custom logic implementation and code generation from models."
    DTDFVocab:enables CustomLogicService, ModelExecutionService
]

// C6: Services
instance DataInterpretationService : DTDFVocab:Service [
    base:desc "Service interpreting aggregated data traces (e.g., sensor readings, logs) for monitoring and analysis."
    DTDFVocab:provides DataInterpretationInsight
]

instance DataMonitoringService : DTDFVocab:Service [
    base:desc "Real-time or near-real-time monitoring of aggregated data for operational state tracking."
    DTDFVocab:provides OperationalStateInsight
]

instance DataAnalysisService : DTDFVocab:Service [
    base:desc "Analytical service processing abstracted data for trend analysis, anomaly detection, or performance metrics."
    DTDFVocab:provides DataTrendInsight, AnomalyDetectionInsight
]

instance PredictiveModelingService : DTDFVocab:Service [
    base:desc "Service leveraging abstracted data for predictive modeling (e.g., failure prediction, performance forecasting)."
    DTDFVocab:provides PredictiveForecastInsight
]

instance SystemSimulationService : DTDFVocab:Service [
    base:desc "Service executing system simulations (e.g., via Simulink) for behavioral analysis and validation."
    DTDFVocab:provides SimulationValidationInsight
]

instance CrossToolCollaborationService : DTDFVocab:Service [
    base:desc "Service ensuring interoperability across heterogeneous tools (e.g., SysML → Simulink → C++ code)."
    DTDFVocab:provides ToolchainIntegrationInsight
]

instance SystemDesignService : DTDFVocab:Service [
    base:desc "Service managing multi-layered system design (requirements, functional/logical/technical architectures)."
    DTDFVocab:provides SystemDesignInsight
]

instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Service modeling system behavior using state machines (SysML) or automata (MontiArc)."
    DTDFVocab:provides BehavioralModelInsight
]

instance ComponentModelingService : DTDFVocab:Service [
    base:desc "Service modeling components, connectors, and interfaces using ADLs (e.g., ACME, AADL, MontiArc)."
    DTDFVocab:provides ComponentModelInsight
]

instance BehavioralSimulationService : DTDFVocab:Service [
    base:desc "Service simulating behavioral models (e.g., MontiArc Automaton) for dynamic analysis."
    DTDFVocab:provides BehavioralSimulationInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service executing simulations (e.g., Simulink) for real-time or batch analysis."
    DTDFVocab:provides SimulationExecutionInsight
]

instance CoSimulationService : DTDFVocab:Service [
    base:desc "Service enabling hybrid modeling (e.g., discrete-event + continuous-time) via co-simulation frameworks."
    DTDFVocab:provides CoSimulationInsight
]

instance CustomLogicService : DTDFVocab:Service [
    base:desc "Service implementing custom logic (e.g., C++/Java) for domain-specific requirements."
    DTDFVocab:provides CustomLogicInsight
]

instance ModelExecutionService : DTDFVocab:Service [
    base:desc "Service executing models generated from MBSE methodologies (e.g., RFLP, OOSEM)."
    DTDFVocab:provides ModelExecutionInsight
]

// C17: Insights/Actions
instance DataInterpretationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from interpreted aggregated data traces (e.g., sensor readings, logs) for operational awareness."
]

instance OperationalStateInsight : DTDFVocab:Insight [
    base:desc "Insight into the current operational state of the physical system based on real-time monitoring."
]

instance DataTrendInsight : DTDFVocab:Insight [
    base:desc "Trend analysis insights derived from abstracted data (e.g., performance degradation, usage patterns)."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight identifying anomalies or deviations in aggregated data for proactive maintenance."
]

instance PredictiveForecastInsight : DTDFVocab:Insight [
    base:desc "Predictive insights (e.g., failure likelihood, performance forecasts) based on abstracted data."
]

instance SimulationValidationInsight : DTDFVocab:Insight [
    base:desc "Validation insights from system simulations (e.g., behavioral correctness, performance metrics)."
]

instance ToolchainIntegrationInsight : DTDFVocab:Insight [
    base:desc "Insight into the integration status and compatibility across heterogeneous modeling tools."
]

instance SystemDesignInsight : DTDFVocab:Insight [
    base:desc "Insight into the multi-layered system design (requirements, functional/logical/technical architectures)."
]

instance BehavioralModelInsight : DTDFVocab:Insight [
    base:desc "Insight into system behavior modeled via state machines (SysML) or automata (MontiArc)."
]

instance ComponentModelInsight : DTDFVocab:Insight [
    base:desc "Insight into component-connector models (e.g., ACME, AADL, MontiArc) for structural analysis."
]

instance BehavioralSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from behavioral simulations (e.g., MontiArc Automaton) for dynamic system analysis."
]

instance SimulationExecutionInsight : DTDFVocab:Insight [
    base:desc "Insight from executed simulations (e.g., Simulink) for real-time or batch analysis results."
]

instance CoSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from hybrid co-simulations (e.g., discrete-event + continuous-time) for comprehensive analysis."
]

instance CustomLogicInsight : DTDFVocab:Insight [
    base:desc "Insight from custom logic implementations (e.g., C++/Java) for domain-specific requirements."
]

instance ModelExecutionInsight : DTDFVocab:Insight [
    base:desc "Insight from executed models generated via MBSE methodologies (e.g., RFLP, OOSEM)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin (DT) constellation** is not explicitly defined in the document, but the **orchestration and coordination** of the system are implicitly addressed through **MBSE methodologies** (e.g., RFLP, OOSEM, SPES, SMArDT) and **architecture description languages (ADLs)** like ACME, AADL, or MontiArc. These frameworks enable **component integration** via **component & connector perspectives**, describing interfaces, interconnections, and composition. The document also references **behavioral modeling** (e.g., MontiArc Automaton, SysML state machines) and **simulation tools** (e.g., MathWorks Simulink, other simulation methods) to manage system-wide coordination. **Resource management** is not explicitly detailed, but the integration of **heterogeneous modeling notations and tools** suggests a need for **orchestration frameworks** to handle cross-tool dependencies. The document does not specify architecture patterns (e.g., microservices, service-oriented) but implies a **modular, multi-layered approach** (requirements → functional → logical → technical)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin system incorporates **fidelity and validity considerations** through **Model-Based Systems Engineering (MBSE)** validation and verification (V&V) processes. Key aspects include:
  - **Model fidelity requirements**: Defined via **multi-layered abstraction** (e.g., requirements → functional → logical → physical layers) to ensure alignment with system complexity.
  - **Validation/verification methods**: Leveraging **ADLs (e.g., AADL, MontiArc)** and **SysML** for structural/behavioral consistency checks, supplemented by **simulation tools (Simulink, domain-specific languages)** for dynamic validation.
  - **Uncertainty sources**: Quantified through **data trace aggregation** (Digital Shadow Reference Model) and **model integration** across heterogeneous tools, with potential discrepancies arising from **tool-specific interpretations** or **abstraction gaps**.
  - **Error detection/correction**: Implemented via **automated data flow analysis** (e.g., passive Digital Shadow data traces) and **active DT components** (e.g., Simulink-based behavioral models) to reconcile discrepancies.
  - **Quality assurance**: Enforced through **stakeholder-integrated MBSE methodologies** (e.g., RFLP, OOSEM) to ensure traceability and consistency across models and data."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The document does not explicitly address **horizontal integration** with external systems, but it implies **interoperability challenges** through the use of **heterogeneous modeling notations** (e.g., SysML, ADLs) and **tools** (e.g., Simulink, C++, Java). **Data exchange protocols** or **interoperability standards** are not specified, though the integration of **digital shadows** (as defined by Kritzinger et al.) suggests a **one-way data flow** from physical to digital systems, requiring **active components** (e.g., DTs) to process incoming data. The document does not mention **dependencies on external systems** (e.g., ERP, MES, IoT platforms) or **integration patterns** (e.g., APIs, message brokers) but highlights the need to **aggregate and abstract contextual data traces** for specific purposes, which may involve **external data sources**. No concrete protocols (e.g., OPC UA, MQTT) or enterprise system integrations (e.g., SAP, PTC ThingWorx) are referenced."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The provided documents reference **cybersecurity protocols** and **safety-critical system considerations** primarily through the **Asset Administration Shell (AAS)** framework (referenced in [46], [47], [50]) and **RAMI4.0** (referenced in [48], [49]). Specifically:
  - **Access Control Mechanisms**: The **Asset Administration Shell (AAS)** (per [46], [47], [50]) defines a standardized structure for digital twins, including **role-based access control (RBAC)** and **authentication layers** via **OAuth 2.0** and **JWT (JSON Web Tokens)** for secure communication between components (e.g., submodels, submodel elements).
  - **Threat Mitigation Strategies**: The **AAS** incorporates **encryption protocols (TLS 1.2+)** for data-in-transit and **digital signatures** for integrity verification (as outlined in [50]). Additionally, **RAMI4.0** (per [48], [49]) emphasizes **cybersecurity compliance** across the **automation pyramid**, mandating **firewall segmentation** and **intrusion detection systems (IDS)** for critical layers (e.g., Field Level, Station Level).
  - **Fail-Safe Mechanisms**: The **Functional Mockup Interface (FMI)** (referenced in [51]) supports **fault-tolerant simulation models** by enabling **rollback mechanisms** and **state recovery** in digital twin environments, particularly for **safety-critical manufacturing processes** (e.g., robotic systems like the **MABI Max-100-2-25-P** robotic arm [44]).
  - **Risk Assessment Approaches**: The **AAS** framework (per [46], [50]) integrates **risk assessment methodologies** aligned with **IEC 62443** (industrial cybersecurity standards) and **ISO 27001**, focusing on **asset lifecycle risk management** and **vulnerability scanning** for digital twin components.
  - **Safety-Critical Systems**: The **MABI robotic arm** ([44]) and **friction modeling for robot dynamics** ([45]) highlight the need for **real-time safety monitoring** via **PLC (Programmable Logic Controller) integration** and **emergency stop protocols** (e.g., **EN ISO 10218-1** compliance). The **Digital Shadow** concept ([42]) further emphasizes **predictive safety analytics** using **digital twin replicas** to preemptively identify hazards in automation systems.
  - **Protocol Stack**: The **MQTT protocol** (referenced in [52]) is leveraged for **lightweight, secure IoT communication** in digital twin ecosystems, with **QoS (Quality of Service) levels** (e.g., QoS 1 for acknowledged delivery) ensuring data integrity in safety-critical applications. The **ThingsBoard IoT platform** ([53]) extends this by providing **device authentication (X.509 certificates)** and **audit logging** for compliance tracking."
]