// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent‑magnet synchronous motor (input current I_M, output torque τ_M) driving the first axis"
]

instance GearwheelGearbox : DTDFVocab:ActingComponent [
    base:desc "Gearwheel gearbox transmitting torque τ_G to the cycloidal gearbox"
]

instance CycloidalGearbox : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gearbox delivering the final output torque τ_out for the first axis"
]

// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring the motor input current I_M"
    DTDFVocab:producedData MotorCurrentDataTx
]

instance MotorEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Position encoder mounted on the motor shaft providing motor angle r_M"
    DTDFVocab:producedData MotorEncoderAngleDataTx
]

instance GearboxEncoderSensor : DTDFVocab:SensingComponent [
    base:desc "Secondary position encoder located behind the gearwheel gearbox providing gearbox angle r_G"
    DTDFVocab:producedData GearboxEncoderAngleDataTx
]

instance DerivedOmegaSensor : DTDFVocab:SensingComponent [
    base:desc "Derived sensor delivering angular velocity ω computed from encoder data"
    DTDFVocab:producedData OmegaDataTx
]

instance DerivedAccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Derived sensor delivering angular acceleration α computed from velocity data"
    DTDFVocab:producedData AccelerationDataTx
]

// C4: Physical-to-virtual interaction
instance MotorCurrentDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance MotorEncoderAngleDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoderSensor
]

instance GearboxEncoderAngleDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoderSensor
]

instance OmegaDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DerivedOmegaSensor
]

instance AccelerationDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DerivedAccelerationSensor
]

// C5: Data (virtual side)
instance MotorCurrentData : DTDFVocab:Data [
    base:desc "Measured motor current I_M streaming via MQTT"
    DTDFVocab:fromData MotorCurrentDataTx
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance MotorEncoderAngleData : DTDFVocab:Data [
    base:desc "Measured motor shaft angle r_M streaming via MQTT"
    DTDFVocab:fromData MotorEncoderAngleDataTx
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance GearboxEncoderAngleData : DTDFVocab:Data [
    base:desc "Measured gearbox angle r_G streaming via MQTT"
    DTDFVocab:fromData GearboxEncoderAngleDataTx
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance OmegaData : DTDFVocab:Data [
    base:desc "Derived angular velocity ω streaming via MQTT"
    DTDFVocab:fromData OmegaDataTx
    DTDFVocab:inputTo MQTTBrokerEnabler
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration α streaming via MQTT"
    DTDFVocab:fromData AccelerationDataTx
    DTDFVocab:inputTo MQTTBrokerEnabler
]

// C10: Models/Data
instance AxisSysMLModel : DTDFVocab:Model [
    base:desc "SysML Block Definition and Internal Block Diagrams of the first vertical axis"
    DTDFVocab:inputTo SysMLToolEnabler
]

instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink executable model of the permanent‑magnet synchronous motor (including white‑box friction)"
    DTDFVocab:inputTo SimulinkToolEnabler
]

instance GearwheelSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the gearwheel gearbox (including friction representation)"
    DTDFVocab:inputTo SimulinkToolEnabler
]

instance CycloidalGearboxSimulinkModel : DTDFVocab:Model [
    base:desc "MATLAB/Simulink model of the cycloidal gearbox (including black‑box friction)"
    DTDFVocab:inputTo SimulinkToolEnabler
]

instance FrictionIdentificationModel : DTDFVocab:Model [
    base:desc "Calculation model that derives static, kinetic and viscous friction parameters from measured and simulated data traces"
    DTDFVocab:inputTo SimulinkToolEnabler, MQTTBrokerEnabler
]

// C11: Enablers
instance SysMLToolEnabler : DTDFVocab:Enabler [
    base:desc "SysML tooling used for structural and behavioral modeling of the axis"
    DTDFVocab:enables ContinuousModelUpdateService
]

instance SimulinkToolEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment for executable simulation of motor and gear models"
    DTDFVocab:enables RealTimeFrictionIdentificationService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker supporting live streaming of measurement data from the robot controller"
    DTDFVocab:enables RealTimeFrictionIdentificationService
]

instance AASEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell linking model data with the physical asset"
    DTDFVocab:enables ContinuousModelUpdateService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Custom dashboard used for visualization of model updates and friction parameters"
    DTDFVocab:enables DashboardVisualizationService
]

// C6: Services
instance RealTimeFrictionIdentificationService : DTDFVocab:Service [
    base:desc "Real‑time identification of static, kinetic and viscous friction parameters"
    DTDFVocab:provides StaticFrictionInsight, KineticFrictionInsight, ViscousFrictionInsight, ProvideFrictionParametersAction
]

instance ContinuousModelUpdateService : DTDFVocab:Service [
    base:desc "Continuous update of simulation models based on identified friction parameters"
    DTDFVocab:provides ModelUpdateInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Integrated dashboard visualizing friction parameters and axis performance"
    DTDFVocab:provides FrictionParametersVisualizationInsight
]

// C17: Insights/Actions
instance StaticFrictionInsight : DTDFVocab:Insight [
    base:desc "Derivation of static friction coefficient for the gear train"
]

instance KineticFrictionInsight : DTDFVocab:Insight [
    base:desc "Derivation of kinetic friction coefficient for the gear train"
]

instance ViscousFrictionInsight : DTDFVocab:Insight [
    base:desc "Derivation of viscous friction coefficient for the gear train"
]

instance ModelUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight that simulation models have been updated with newly identified friction parameters"
]

instance FrictionParametersVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of current friction parameters on the dashboard"
]

instance ProvideFrictionParametersAction : DTDFVocab:Action [
    base:desc "Provision of identified friction parameters to the Siemens SINUMERIK 840D CNC controller"
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time acquisition and processing of sensor streams (live data flow) to enable on‑line friction model identification."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A digital shadow consisting of a Purpose (FrictionDerivation), an Asset (MABI first axis), Sources (sensor channels), Processing components (Simulation_M, Simulation_GW, Simulation_GB) that consume measured data and simulation models, and resulting DataTraces stored in the shadow; all linked via the AAS and MQTT infrastructure."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operational/run‑time stage – the digital shadow is created for the operated robot to analyse friction during actual machining tasks."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Full traceability of each DataPoint to its generating Processing component and source; use of both analytical (white‑box) and data‑driven (black‑box) friction models; comparison of simulated friction‑free behavior with measured data to validate model accuracy; continuous model exchange ensures up‑to‑date fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Sensor data are streamed from the robot to the digital shadow using the MQTT protocol; the Asset Administration Shell provides the semantic linking of data and models."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of the Asset Administration Shell (AAS) standard for digital twin data integration and SysML as a standardized modeling language."
]