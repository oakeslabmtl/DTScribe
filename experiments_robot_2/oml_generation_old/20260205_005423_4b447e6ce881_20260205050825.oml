// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Motor current measurement used to infer applied torque via known motor constants."
    DTDFVocab:producedData CurrentDataStream
]

instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Incremental encoder mounted directly on the motor shaft providing angular position measurements."
    DTDFVocab:producedData ShaftAngleDataStream
]

instance GearboxEncoder : DTDFVocab:SensingComponent [
    base:desc "Incremental encoder positioned behind the gearbox providing angular position measurements."
    DTDFVocab:producedData GearboxAngleDataStream
]

// C4: Physical-to-virtual interaction
instance CurrentDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance ShaftAngleDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxAngleDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxEncoder
]

// C10: Models/Data
instance CurrentMeasurement : DTDFVocab:Data [
    base:desc "Time‑series value of motor current delivered by MotorCurrentSensor."
    DTDFVocab:fromData CurrentDataStream
    DTDFVocab:inputTo SensorDataAggregationEngine
]

instance ShaftPositionMeasurement : DTDFVocab:Data [
    base:desc "Time‑series value of motor shaft angle delivered by MotorShaftEncoder."
    DTDFVocab:fromData ShaftAngleDataStream
    DTDFVocab:inputTo SensorDataAggregationEngine
]

instance GearboxPositionMeasurement : DTDFVocab:Data [
    base:desc "Time‑series value of gearbox output angle delivered by GearboxEncoder."
    DTDFVocab:fromData GearboxAngleDataStream
    DTDFVocab:inputTo SensorDataAggregationEngine
]

// C11: Enablers
instance SysMLModelingTool : DTDFVocab:Enabler [
    base:desc "SysML modeling environment used for component & connector specification across requirement, functional, logical, and product layers."
    DTDFVocab:enables ComponentSpecificationService
]

instance MATLABSimulinkEngine : DTDFVocab:Enabler [
    base:desc "MathWorks MATLAB/Simulink engine executing heterogeneous simulations of robot kinematics and friction."
    DTDFVocab:enables SimulationExecutionService
]

instance DigitalShadowReferenceFramework : DTDFVocab:Enabler [
    base:desc "Digital shadow framework processing one‑way sensor data stream via a data‑aggregation layer."
    DTDFVocab:enables SensorDataAggregationService
]

instance SensorDataAggregationEngine : DTDFVocab:Enabler [
    base:desc "In‑memory data aggregation layer that stores processed sensor data for further analysis and visualization."
    DTDFVocab:enables RealTimeDashboardService
]

// C6: Services
instance ComponentSpecificationService : DTDFVocab:Service [
    base:desc "Service to generate component and connector specifications using SysML diagrams."
    DTDFVocab:provides ComponentModelInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Service to execute Simulink models of robot kinematics and friction on MATLAB engine."
    DTDFVocab:provides SimulationResultInsight
]

instance SensorDataAggregationService : DTDFVocab:Service [
    base:desc "Service that aggregates streamed sensor data into a digital shadow for real‑time analysis."
    DTDFVocab:provides AggregatedDataInsight
]

instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Service providing real‑time dashboard with live data streams, derived parameters, and alerts."
    DTDFVocab:provides JointFrictionInsight, FrictionAlertInsight, AdjustMaintenanceAction, AdjustOperationalSettingAction
]

instance TwinEngineeringWorkflowService : DTDFVocab:Service [
    base:desc "Service that documents the four‑step digital twin engineering workflow: problem identification, asset and model analysis, calculations, and data identification."
    DTDFVocab:provides ProcessTraceabilityInsight
]

// C17: Insights/Actions
instance JointFrictionInsight : DTDFVocab:Insight [
    base:desc "Active insight into joint friction derived from live sensor measurements and continuous system identification."
]

instance FrictionAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating abnormal friction characteristics detected in real‑time monitoring."
]

instance ComponentModelInsight : DTDFVocab:Insight [
    base:desc "Model traceability insight showing requirement to logical to physical mapping."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insight on simulation outputs from Simulink models of robot kinematics and friction."
]

instance AggregatedDataInsight : DTDFVocab:Insight [
    base:desc "Insight into aggregated sensor data stored in digital shadow reference framework."
]

instance ProcessTraceabilityInsight : DTDFVocab:Insight [
    base:desc "Insight tracing the process of digital twin engineering across problem identification, asset analysis, model creation, and data integration."
]

instance AdjustMaintenanceAction : DTDFVocab:Action [
    base:desc "Operator action to adjust maintenance settings based on dashboard insights."
    DTDFVocab:IsAutomatic false
]

instance AdjustOperationalSettingAction : DTDFVocab:Action [
    base:desc "Operator action to adjust operational settings guided by real‑time friction monitoring."
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system orchestrates its architecture and behaviour using a Model‑Based Systems Engineering (MBSE) approach. System components and connectors are modeled in SysML (including component diagrams, block definition diagrams, internal block diagrams, and state machines in SysML v1.7). Behaviours that cannot be captured solely in SysML are expressed with MontiArc automaton primitives, and dynamic simulation is performed with MathWorks Simulink. The resulting artefacts can be translated into executable code using general‑purpose programming languages such as C++ or Java, enabling deployment in digital‑twin runtime environments."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The digital twin follows industry‑standard modeling languages: SysML (v1.7) for architectural description and UML class diagram for the digital shadow reference model. An Asset Administration Shell (AAS) is referenced for structuring twin data. No specific certification or compliance framework is detailed in the supplied document."
]