// C3: Physical sensing component
instance PhysicalObjectStateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that captures the real‑time state of the physical object, providing the raw context for the digital shadow."
    DTDFVocab:producedData MqttDataChannel
]

// C4: Physical‑to‑virtual data transmission
instance MqttDataChannel : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalObjectStateSensor
]

// C10: Data – contextual traces from the physical object
instance ContextualDataTrace : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces collected from the physical object, used as input for simulation and analytics."
    DTDFVocab:fromData MqttDataChannel
    DTDFVocab:inputTo ProcessingEngine
]

// C10: Model – white‑box Simulink simulation
instance SimulinkWhiteBoxModel : DTDFVocab:Model [
    base:desc "White‑box physics‑based simulation model implemented in MathWorks Simulink, generating the twin's current state."
    DTDFVocab:inputTo ProcessingEngine
]

// C11: Enabler – processing engine (simulation / data‑calculation)
instance ProcessingEngine : DTDFVocab:Enabler [
    base:desc "Execution engine that runs simulation and data‑calculation models, transforming input traces into higher‑level twin state."
    DTDFVocab:enables ProcessingService
]

// C6: Service – processing & analytics
instance ProcessingService : DTDFVocab:Service [
    base:desc "Service that consumes simulation output and contextual traces, producing the digital twin's current state for analytics and decision support."
    DTDFVocab:provides DigitalTwinCurrentStateInsight,
                     AnalyticsDecisionSupportInsight,
                     DecisionSupportAction
]

// C17: Insight – current state representation
instance DigitalTwinCurrentStateInsight : DTDFVocab:Insight [
    base:desc "Higher‑level abstraction representing the digital twin's current state, derived from processed data traces."
]

// C17: Insight – analytics & decision support
instance AnalyticsDecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Insight extracted from the twin's state to support analytics and inform decision‑making processes."
]

// C17: Action – decision support trigger
instance DecisionSupportAction : DTDFVocab:Action [
    base:desc "Action that presents decision‑support recommendations to operators based on twin analytics."
    DTDFVocab:IsAutomatic false
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle follows the typical MBSE development ladder: (1) Requirements modelling, (2) Functional architecture, (3) Logical architecture, and (4) Product/technical architecture. At each stage SysML diagrams capture the artefacts. After the engineering models are defined, a Digital Shadow Reference Model is instantiated as a concrete class diagram (concretization), linking data‑trace entities to processing components. In the operational phase the physical system pushes one‑way data traces into the twin; processing components consume these traces, run simulation or data‑calculation models and generate output traces that become the twin’s runtime representation. Transition between the design and operational representations is managed by the “originates‑from” association that preserves traceability across stages. Lifecycle governance is implied by the conformance relation between the reference model and its concrete realization."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and validity are addressed through explicit traceability and verification of all model transformations, as emphasized in the literature. Correctness of the mapping from high‑level SysML specifications to executable simulation models (e.g., Simulink) is verified to guarantee that the digital shadow faithfully reproduces the physical system’s behaviour. Reliability is directly tied to the correctness of underlying models and data transformations, prompting the use of verification methods and quality‑assurance processes to detect and correct errors. Uncertainty sources stem from both the physics‑based models and the data‑driven models; while the documents do not quantify them, they highlight the need for uncertainty quantification and validation against measured data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on the MQTT protocol (Mosquitto) for message transport between physical devices and the digital shadow, using a typical client‑broker topology. IoT platform ThingsBoard is mentioned as a possible integration point. The documents do not provide further details on network topology, bandwidth, latency, redundancy, or additional security protocols."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The documents refer to cloud‑based technologies for deploying a CNC‑machine digital shadow (Document 2) and to the use of IoT platforms, but they do not specify the hosting platform (cloud/edge/on‑premise), computational or storage requirements, scalability mechanisms, deployment models, or availability/reliability guarantees."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on established modelling standards: SysML (systems engineering language), architecture description languages such as ACME, AADL, MontiArc, and simulation/modeling tools like MATLAB/Simulink. The Digital Shadow Reference Model itself is defined as a UML class diagram, adhering to UML standard specifications. No further industry standard, certification or interoperability framework is mentioned."
]