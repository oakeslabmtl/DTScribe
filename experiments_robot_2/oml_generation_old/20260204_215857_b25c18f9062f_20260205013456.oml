instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor measuring input current for robot joints"
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Physical sensor measuring output angle for robot joints"
    DTDFVocab:producedData OutputAngleDataTransmitted
]

instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
]

instance OutputAngleDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

instance InputCurrentData : DTDFVocab:Data [
    base:desc "Time series data of input current from physical robot joint"
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, CPlusPlusEnabler
]

instance OutputAngleData : DTDFVocab:Data [
    base:desc "Time series data of output angle from physical robot joint"
    DTDFVocab:fromData OutputAngleDataTransmitted
    DTDFVocab:inputTo SimulinkEnabler, CPlusPlusEnabler
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Language (ACME) for component and connector architecture specification"
    DTDFVocab:enables StructuralModelingService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Language (AADL) for component and connector architecture specification"
    DTDFVocab:enables StructuralModelingService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "Architecture Description Language (MontiArc) for component and connector architecture specification"
    DTDFVocab:enables StructuralModelingService
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for Model-Based Systems Engineering (MBSE) system modeling"
    DTDFVocab:enables StructuralModelingService
]

instance MontiArcAutomatonEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc Automaton for behavior modeling"
    DTDFVocab:enables BehavioralModelingService
]

instance SysMLStateMachinesEnabler : DTDFVocab:Enabler [
    base:desc "SysML v1.7 state machines for behavior modeling"
    DTDFVocab:enables BehavioralModelingService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed simulation and dynamic analysis"
    DTDFVocab:enables SimulationService
]

instance SpecializedSimulationToolsEnabler : DTDFVocab:Enabler [
    base:desc "Specialized simulation tools for detailed dynamic analysis"
    DTDFVocab:enables SimulationService
]

instance CPlusPlusEnabler : DTDFVocab:Enabler [
    base:desc "C++ programming language for detailed simulation and dynamic analysis"
    DTDFVocab:enables SimulationService
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java programming language for detailed simulation and dynamic analysis"
    DTDFVocab:enables SimulationService
]

instance RFLPEnabler : DTDFVocab:Enabler [
    base:desc "RFLP (Requirements, Functions, Logics, Physics) methodology for system complexity management"
    DTDFVocab:enables SystemComplexityManagementService
]

instance OOSEMEnabler : DTDFVocab:Enabler [
    base:desc "OOSEM methodology for system complexity management"
    DTDFVocab:enables SystemComplexityManagementService
]

instance SPESEnabler : DTDFVocab:Enabler [
    base:desc "SPES methodology for system complexity management"
    DTDFVocab:enables SystemComplexityManagementService
]

instance SMArDTEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT methodology for system complexity management"
    DTDFVocab:enables SystemComplexityManagementService
]

instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard visualization tool for user interaction"
    DTDFVocab:enables DashboardVisualizationService
]

instance StructuralModel_ACME : DTDFVocab:Model [
    base:desc "Structural component & connector descriptions using ACME architecture description language"
    DTDFVocab:inputTo ACMEEnabler
]

instance StructuralModel_AADL : DTDFVocab:Model [
    base:desc "Structural component & connector descriptions using AADL architecture description language"
    DTDFVocab:inputTo AADLEnabler
]

instance StructuralModel_MontiArc : DTDFVocab:Model [
    base:desc "Structural component & connector descriptions using MontiArc architecture description language"
    DTDFVocab:inputTo MontiArcEnabler
]

instance StructuralModel_SysML : DTDFVocab:Model [
    base:desc "Structural component & connector descriptions using SysML Interface Block Diagrams (IBDs)"
    DTDFVocab:inputTo SysMLEnabler
]

instance BehavioralModel_MontiArcAutomaton : DTDFVocab:Model [
    base:desc "Behavioral model implemented using MontiArc Automaton"
    DTDFVocab:inputTo MontiArcAutomatonEnabler
]

instance BehavioralModel_SysMLStateMachines : DTDFVocab:Model [
    base:desc "Behavioral model implemented using SysML v1.7 state machines"
    DTDFVocab:inputTo SysMLStateMachinesEnabler
]

instance SimulationModel_Simulink : DTDFVocab:Model [
    base:desc "Detailed simulation model integrated with MathWorks Simulink"
    DTDFVocab:inputTo SimulinkEnabler
]

instance SimulationModel_SpecializedTools : DTDFVocab:Model [
    base:desc "Detailed simulation model using specialized simulation tools"
    DTDFVocab:inputTo SpecializedSimulationToolsEnabler
]

instance SimulationModel_CPlusPlus : DTDFVocab:Model [
    base:desc "Detailed simulation model implemented in C++"
    DTDFVocab:inputTo CPlusPlusEnabler
]

instance SimulationModel_Java : DTDFVocab:Model [
    base:desc "Detailed simulation model implemented in Java"
    DTDFVocab:inputTo JavaEnabler
]

instance StructuralModelingService : DTDFVocab:Service [
    base:desc "Structural component and connector descriptions for system architecture modeling"
    DTDFVocab:provides StructuralModelInsight
]

instance BehavioralModelingService : DTDFVocab:Service [
    base:desc "Behavioral modeling using MontiArc Automaton and SysML state machines"
    DTDFVocab:provides BehavioralModelInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation-based identification of joint friction using white-box and black-box models"
    DTDFVocab:provides JointFrictionIdentificationInsight
]

instance SystemComplexityManagementService : DTDFVocab:Service [
    base:desc "System complexity management using RFLP, OOSEM, SPES, and SMArDT methodologies"
    DTDFVocab:provides SystemComplexityInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Decision support through dashboard visualizations for user interaction"
    DTDFVocab:provides DashboardVisualizationInsight
]

instance StructuralModelInsight : DTDFVocab:Insight [
    base:desc "Structural component and connector descriptions for system architecture"
]

instance BehavioralModelInsight : DTDFVocab:Insight [
    base:desc "Behavioral model descriptions for system dynamics"
]

instance JointFrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Continuous, multi-physics-aware identification of joint friction to enhance robot motion accuracy"
]

instance SystemComplexityInsight : DTDFVocab:Insight [
    base:desc "System complexity management through methodologies"
]

instance DashboardVisualizationInsight : DTDFVocab:Insight [
    base:desc "Dashboard visualizations for decision support in robot motion accuracy"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data from physical assets is streamed via MQTT in real-time, capturing live measurements to ensure continuous synchronization between the physical and digital components with minimal latency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Shadow Reference Model, defined as a UML class diagram, structures components including DataTrace (for contextual data collection), Source (data origin), and Asset (physical entities), with defined relationships for aggregation and abstraction of data traces."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems uses Asset Administration Shells (AAS) as an interoperability standard, MQTT for real-time data exchange, and interfaces with the Siemens SINUMERIK 840D sl controller for industrial automation processes."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with industry standards including SysML for systems engineering modeling, AADL for architecture description, ACME for component-based architecture, and MontiArc for modular architecture design. Interoperability is addressed through the integration of heterogeneous modeling notations and tools as per MBSE practices."
]