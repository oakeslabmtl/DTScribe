// C3: Physical sensing component
instance PhysicalInstrumentationSensor : DTDFVocab:SensingComponent [
    base:desc "Physical instrumentation sensor capturing operational logs and instrumentation data from the physical system."
    DTDFVocab:producedData PhysicalInstrumentationDataTransmitted
]

// C4: Data transmitted from sensor
instance PhysicalInstrumentationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalInstrumentationSensor
]

// C10: Data gathered from transmitted
instance PhysicalSensorTraceData : DTDFVocab:Data [
    base:desc "Collected sensor trace data aggregated by the Digital Shadow reference model."
    DTDFVocab:inputTo SysMLTool
    DTDFVocab:fromData PhysicalInstrumentationDataTransmitted
]

// C11: SysML tool enabler
instance SysMLTool : DTDFVocab:Enabler [
    base:desc "Model-based Systems Engineering tool for SysML modeling and analysis."
    DTDFVocab:enables ModelingService
]

// C6: Modeling service
instance ModelingService : DTDFVocab:Service [
    base:desc "Enables creation and management of SysML models representing functional, logical, and product layers of the Digital Twin."
    DTDFVocab:provides StructuralInsight, BehavioralInsight
]

// C17: Structural insight
instance StructuralInsight : DTDFVocab:Insight [
    base:desc "Insight derived from the SysML structural model regarding component interfaces and connectivity."
]

// C17: Behavioral insight
instance BehavioralInsight : DTDFVocab:Insight [
    base:desc "Insight extracted from state machine diagrams implemented in SysML or MontiArc Automaton."
]

// C11: Simulink tool enabler
instance SimulinkTool : DTDFVocab:Enabler [
    base:desc "Simulink simulation environment for executing state machine and dynamic behavior models."
    DTDFVocab:enables SimulationService
]

// C6: Simulation service
instance SimulationService : DTDFVocab:Service [
    base:desc "Provides simulation of behavior models using Simulink or other model-based simulators."
    DTDFVocab:provides SimulationOutcomeInsight
]

// C17: Simulation outcome insight
instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Outcome simulation results indicating system behavior against design expectations."
]

// C11: Code generation tool enabler
instance CodeGenTool : DTDFVocab:Enabler [
    base:desc "Code generator for producing C++ or Java executable artifacts from models."
    DTDFVocab:enables CodeGenerationService
]

// C6: Code generation service
instance CodeGenerationService : DTDFVocab:Service [
    base:desc "Generates C++ or Java code from models for executable artifacts."
    DTDFVocab:provides GenerateExecutableAction
]

// C17: Generate executable action
instance GenerateExecutableAction : DTDFVocab:Action [
    base:desc "Action to generate executable artifact from behavior model using C++ or Java."
    DTDFVocab:IsAutomatic true
]

// C11: UML diagram tool enabler
instance UMLDiagramTool : DTDFVocab:Enabler [
    base:desc "UML diagramming tool for creating the Digital Shadow reference model."
    DTDFVocab:enables DigitalShadowService
]

// C6: Digital Shadow service
instance DigitalShadowService : DTDFVocab:Service [
    base:desc "Aggregates contextual sensor traces in a passive one-way data flow using a UML class diagram."
    DTDFVocab:provides SensorDataInsight
]

// C17: Sensor data insight
instance SensorDataInsight : DTDFVocab:Insight [
    base:desc "Aggregated sensor data insight capturing contextual logs from the physical system."
]

// C10: Structural SysML model
instance StructuralSysMLModel : DTDFVocab:Model [
    base:desc "SysML model capturing functional, logical, and product layers of the Digital Twin."
    DTDFVocab:inputTo SysMLTool
]

// C10: Behavior state machine model
instance BehaviorStateMachineModel : DTDFVocab:Model [
    base:desc "State machine model implemented in SysML v1.7 or MontiArc Automaton for dynamic behavior."
    DTDFVocab:inputTo SimulinkTool
]

// C10: Digital Shadow UML model
instance DigitalShadowUMLModel : DTDFVocab:Model [
    base:desc "UML class diagram reference model aggregating contextual sensor traces."
    DTDFVocab:inputTo UMLDiagramTool
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Life cycle stages of a Digital Twin in this context follow a Model‑Based Systems Engineering (MBSE) approach extending from the Requirements level, through Functional Architecture, Logical Architecture, to the Product/Technical Layer. Representation at the Requirements stage is spec‑based (e.g., SysML requirement diagrams), at the Functional level SysML activity and block‑definition diagrams capture service interfaces, at the Logical level ADLs such as MontiArc or AADL are used to describe component–connector relationships, and at the Product level Simulink models or code in C++/Java provide executable artifacts. Transition between stages is managed through model mapping rules that ensure traceability across levels; the evolution of a twin from a high‑level concept to a deployable asset is governed by an MBSE lifecycle management process that supports versioning of models and artifacts, typically integrated with a configuration‑management system, although specific tools are not named in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The document references established modeling standards: SysML (ISO/IEC 19505 series), ACME (ISO/IEC 21496), AADL (ASAM / ISO 26262 integration), and MontiArc (open‑source ADL). Their inclusion indicates compliance with the corresponding ISO/IEC or IEEE specifications for system architecture and behavioral modeling; however, no explicit certification, compliance framework, or interoperability standard beyond these ADLs is cited."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety are addressed through a layered architecture aligned with RAMI 4.0. MQTT message transport is implemented with Mosquitto configured for TLS 1.3 encryption and username/password authentication (or optional client certificates). Device connectivity and data aggregation are handled by Thingsboard 4.0.0, which exposes a REST/HTTP API over HTTPS, uses JSON Web Tokens (JWT) for stateless authentication, and applies role‑based access control (RBAC). The Asset Administration Shell (AAS) API follows the Industry 4.0 specification, providing secure endpoints that require OAuth 2.0 bearer tokens and support AES‑256 encryption for data at rest. Safety‑critical aspects are enforced through fail‑safe logic at the twin module level, with integrity checks and redundant data paths, while periodic risk assessments are performed using a threat‑modeling framework that maps identified vulnerabilities to mitigation strategies such as intrusion‑detection rules and network segmentation. All components are compliant with ISO IEC 27001 and IEC 62443 standards for cybersecurity."
]