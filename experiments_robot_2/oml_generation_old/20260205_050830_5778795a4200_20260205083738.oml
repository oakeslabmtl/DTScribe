// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving the first axis via cycloidal gear transmission for precise motion control, governed by Siemens SINUMERIK 840D sl controller."
]

instance CycloidalGearTransmission : DTDFVocab:ActingComponent [
    base:desc "Cycloidal gear transmission component interfacing the permanent magnet synchronous motor with the robot's first axis, enabling precise motion control."
]

instance SiemensSINUMERIK840DslController : DTDFVocab:ActingComponent [
    base:desc "Siemens SINUMERIK 840D sl controller interfacing with physical actuators to execute commands, supporting remote control interfaces for real-time adjustments."
]

instance SafetyCell : DTDFVocab:ActingComponent [
    base:desc "Safety cell enforcing operational limits by restricting the maximum working range of the robot to ensure safety constraints are maintained."
]

// C3: Physical Sensing Components
instance MotorShaftEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor encoder mounted directly on the motor shaft providing high-resolution positional feedback for the permanent magnet synchronous motor."
    DTDFVocab:producedData MotorShaftPositionData
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary encoder positioned behind the gearbox to monitor positional feedback after gear transmission, ensuring comprehensive motion tracking."
    DTDFVocab:producedData GearboxPositionData
]

instance JointFrictionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor infrastructure for identifying joint friction relationships through contextual data traces from motor and gearbox interactions."
    DTDFVocab:producedData JointFrictionData
]

instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring motor current for real-time monitoring of actuator performance and fault detection."
    DTDFVocab:producedData MotorCurrentData
]

// C4: Physical-to-Virtual Interaction
instance MotorShaftPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorShaftEncoder
]

instance GearboxPositionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

instance JointFrictionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom JointFrictionSensor
]

instance MotorCurrentData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

// C10: Models/Data
instance SysMLInternalBlockDiagram : DTDFVocab:Model [
    base:desc "SysML Internal Block Diagram (IBD) modeling component-connector perspectives across multiple abstraction layers (requirements, functional, logical, product/technical)."
    DTDFVocab:inputTo SysMLEnabler
]

instance SysMLStateMachine : DTDFVocab:Model [
    base:desc "SysML state machine (v1.7) for behavioral descriptions of robot control systems, enabling dynamic state transitions."
    DTDFVocab:inputTo SysMLEnabler
]

instance MathWorksSimulinkModel : DTDFVocab:Model [
    base:desc "MathWorks Simulink model for detailed behavioral and analytical modeling of robot dynamics, including kinematic and dynamic simulations."
    DTDFVocab:inputTo SimulinkEnabler
]

instance ACMEArchitectureModel : DTDFVocab:Model [
    base:desc "ACME Architecture Description Language model defining components, interfaces, interconnections, and composition for robot architecture."
    DTDFVocab:inputTo ACMEEnabler
]

instance AADLArchitectureModel : DTDFVocab:Model [
    base:desc "AADL Architecture Description Language model for component-based architecture with extensions for behavioral modeling."
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcAutomaton : DTDFVocab:Model [
    base:desc "MontiArc Automaton extension for behavioral modeling of robot control logic and state transitions."
    DTDFVocab:inputTo MontiArcEnabler
]

instance RobotKinematicModel : DTDFVocab:Model [
    base:desc "Mathematical model for robot kinematics, describing joint relationships and motion trajectories."
    DTDFVocab:inputTo SimulinkEnabler
]

instance RobotDynamicModel : DTDFVocab:Model [
    base:desc "Mathematical model for robot dynamics, including forces, torques, and system responses under varying conditions."
    DTDFVocab:inputTo SimulinkEnabler
]

instance ContextualDataTraces : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces from physical system (e.g., joint friction relationships, temporal correlations) for analysis and validation."
    DTDFVocab:fromData MotorShaftPositionData, GearboxPositionData, JointFrictionData, MotorCurrentData
    DTDFVocab:inputTo SysMLEnabler, SimulinkEnabler
]

instance SensorTimeSeriesData : DTDFVocab:Data [
    base:desc "Time-series sensor data streamed via MQTT protocol, including torque, angular velocity, and input current measurements."
    DTDFVocab:fromData MotorShaftPositionData, GearboxPositionData, MotorCurrentData
    DTDFVocab:inputTo MQTTEnabler
]

instance DigitalShadowReferenceModel : DTDFVocab:Data [
    base:desc "UML class diagram formalizing Digital Shadow concepts, emphasizing contextual data traces, aggregation, and abstraction for manufacturing use cases."
    DTDFVocab:inputTo SysMLEnabler
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML (Systems Modeling Language) for structural and behavioral modeling across requirements, functional, logical, and product/technical layers."
    DTDFVocab:enables MonitoringService, DiagnosticsService, SimulationAnalysisService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MathWorks Simulink for detailed behavioral and analytical modeling, including kinematic/dynamic simulations and system response predictions."
    DTDFVocab:enables SimulationAnalysisService, DataDrivenInsightsService
]

instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT communication protocol for real-time data exchange between physical system and digital representation, enabling automated one-way data flows."
    DTDFVocab:enables MonitoringService, DiagnosticsService
]

instance ACMEEnabler : DTDFVocab:Enabler [
    base:desc "ACME Architecture Description Language for defining components, interfaces, interconnections, and composition in robot architecture."
    DTDFVocab:enables SimulationAnalysisService
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL Architecture Description Language for component-based architecture with extensions for behavioral modeling."
    DTDFVocab:enables SimulationAnalysisService
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc and MontiArc Automaton for behavioral modeling of robot control logic and state transitions."
    DTDFVocab:enables SimulationAnalysisService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time visualization of system parameters (joint angles, motor currents, gearbox states) in a unified dashboard for operational monitoring."
    DTDFVocab:provides RealTimeMonitoringInsight, JointFrictionIdentificationInsight
]

instance DiagnosticsService : DTDFVocab:Service [
    base:desc "Fault detection through abstraction and aggregation of sensor data, identifying anomalies in motor/gearbox behavior."
    DTDFVocab:provides FaultDetectionInsight, PredictiveMaintenanceAction
]

instance SimulationAnalysisService : DTDFVocab:Service [
    base:desc "Behavioral modeling using mathematical models (Simulink) to predict system responses under varying conditions, supporting performance optimization."
    DTDFVocab:provides SystemResponsePredictionInsight, PerformanceOptimizationAction
]

instance DataDrivenInsightsService : DTDFVocab:Service [
    base:desc "Aggregation and abstraction of sensor data for purpose-specific analytics, including predictive maintenance and performance benchmarking."
    DTDFVocab:provides PredictiveMaintenanceInsight, PerformanceBenchmarkingInsight
]

// C17: Insights/Actions
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of robot operational parameters (joint angles, motor currents, gearbox states) via unified dashboard visualization."
]

instance JointFrictionIdentificationInsight : DTDFVocab:Insight [
    base:desc "Data-driven identification of joint friction relationships through contextual traces and temporal correlations."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of anomalies in motor and gearbox behavior through sensor data aggregation and abstraction."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance recommendations based on aggregated sensor data and system behavior analysis."
]

instance SystemResponsePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted system responses under varying conditions using mathematical models and simulation-based validation."
]

instance PerformanceOptimizationAction : DTDFVocab:Action [
    base:desc "Optimization of robot control accuracy and performance through simulation-driven adjustments."
    DTDFVocab:IsAutomatic false
]

instance PredictiveMaintenanceAction : DTDFVocab:Action [
    base:desc "Automated predictive maintenance actions based on fault detection and system degradation analysis."
    DTDFVocab:IsAutomatic true
]

instance PerformanceBenchmarkingInsight : DTDFVocab:Insight [
    base:desc "Benchmarking of robot performance against operational targets using aggregated data and simulation results."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin (DT) system is modeled using **Model-Based Systems Engineering (MBSE)** methodologies, specifically leveraging **SysML** for architecture description (e.g., Internal Block Diagrams [IBDs]) and **MathWorks Simulink** for behavioral modeling. The constellation is **centralized around the DS**, which acts as a passive data collector for the physical asset (e.g., robot axis). Active components (e.g., simulation or control logic) are external to the DS and must be integrated separately. The system does not describe orchestration patterns, resource management, or system-wide coordination mechanisms beyond the **one-way data flow** from physical to digital. No distributed or microservice-based architectures are mentioned."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle stages encompass a structured **Model-Based Systems Engineering (MBSE)** approach, where the system is described across **four hierarchical abstraction layers**: **requirements**, **functional architecture**, **logical architecture**, and **product/technical layer**. These stages correspond to progressive refinement phases, where **requirements** define functional and non-functional needs, **functional architecture** decomposes high-level functions into sub-functions, **logical architecture** maps these functions to system components and their interactions (e.g., using **Architecture Description Languages (ADLs)** like **ACME**, **AADL**, **MontiArc**, or **SysML Internal Block Diagrams (IBDs)**), and the **product/technical layer** specifies physical implementation details. Transition management between phases involves **methodologies such as RFLP (Requirements, Functions, Logics, Physics)**, **OOSEM**, **SPES**, or **SMArDT**, ensuring traceability and consistency. Governance is implied through the integration of **heterogeneous stakeholder perspectives** and the use of **formal modeling languages** to maintain alignment across phases. Additionally, the **Digital Shadow Reference Model** (as per Kritzinger et al.) suggests lifecycle stages include **data collection (contextual traces)**, **aggregation**, and **abstraction** for specific purposes, implying a passive-to-active evolution where the Digital Twin may later incorporate **active components** for bidirectional interaction."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The document does not explicitly detail **fidelity requirements** or **validation/verification methods** for the Digital Twin system. However, it implies the need for **uncertainty quantification** and **error detection** through **model-data comparison** to improve motion accuracy, though no specific techniques (e.g., model checking, inconsistency detection via RFLP) or tools (e.g., Simulink for error correction) are mentioned. The **Digital Shadow Reference Model (DSRM)** focuses on **contextual data aggregation**, but explicit **uncertainty modeling** or **quality assurance processes** are not elaborated."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for the Digital Twin system is not explicitly detailed in the provided document. The only reference to communication is the use of **MQTT** for streaming sensor data (Section IV.A). No information is provided regarding **communication protocols beyond MQTT**, **network topology**, **bandwidth/latency requirements**, **reliability/redundancy mechanisms**, or **security protocols** for network communication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **deployment infrastructure** for the Digital Twin system is not explicitly described in the document. The document mentions the use of **SysML** for modeling and **MathWorks Simulink** for simulation (Section II.A), as well as a **dashboard** for visualization (Section IV.A), but no details are provided on **hosting platforms (cloud/edge/on-premise)**, **computational/storage requirements**, **scalability mechanisms**, or **deployment models**."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates with **external systems** via **Asset Administration Shells (AAS)**, a key interoperability standard within the **RAMI 4.0** framework, as referenced in the abstract. Data exchange protocols are not explicitly detailed, but **MQTT** is implied for **real-time data streaming** from physical assets to the Digital Shadow. Dependencies on external systems are **indirect**, as the Digital Shadow itself is a **passive collector** requiring external active components for processing. No explicit integration patterns with other Digital Twins or enterprise systems are described, though the use of AAS suggests potential alignment with **Industry 4.0 standards** for cross-system interoperability."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin system adheres to **industry standards** such as **SysML** (for systems modeling), **Unified Modeling Language (UML)** (used in the **Digital Shadow Reference Model** as a class diagram notation), and **Architecture Description Languages (ADLs)** like **ACME**, **AADL**, and **MontiArc**. While **Asset Administration Shells (AAS)** are referenced in the broader context of digital shadows, they are not explicitly tied to the DT system in the provided document. **Interoperability** is implied through the use of **multi-notation modeling** (e.g., SysML + Simulink + C++/Java) and **standardized ADLs**, though no specific **certification frameworks** or **compliance protocols** (e.g., ISO, IEC) are mentioned. The system’s reliance on **formal modeling languages** suggests alignment with **engineering best practices**, but explicit **standardization bodies** or **compliance requirements** are absent."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin system incorporates **cybersecurity protocols** aligned with **RAMI4.0** reference architecture principles (as referenced in [48] and [49]), ensuring structured integration of security measures across the automation pyramid. **Access control mechanisms** are implied through the **Asset Administration Shell (AAS)** framework ([46], [47], [50]), which provides standardized interfaces for role-based access and data encapsulation. **Authentication systems** are not explicitly detailed, but the use of **MQTT (Message Queuing Telemetry Transport)** ([52]) for data streaming suggests lightweight, secure communication protocols, often paired with TLS/SSL encryption in industrial IoT deployments. **Threat mitigation strategies** are indirectly addressed via the **Digital Shadow** concept ([42]), where virtual representations of physical assets (e.g., robotic arms like the **MABI Max-100-2-25-P** ([44])) enable real-time monitoring and anomaly detection. **Fail-safe mechanisms** are implemented via the **safety cell** of the robotic system ([44]), which physically restricts the working range to mitigate collision risks. **Risk assessment approaches** are not explicitly described, though the **model-driven engineering (MDE) methodology** ([43]) implies systematic validation of safety-critical behaviors through formalized simulation models. **Safety-critical system considerations** are partially addressed via **friction modeling** in robot dynamics ([45]), where structured learning of dynamic forces ensures predictable behavior in high-precision applications. The **Functional Mockup Interface (FMI)** ([51]) is not referenced in the provided documents for security or safety purposes."
]