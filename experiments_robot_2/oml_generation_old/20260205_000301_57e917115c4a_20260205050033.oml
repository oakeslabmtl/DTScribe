// C3: Physical sensing components
instance PermaMagMotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Permanent magnet synchronous motor current sensor measuring I_M."
    DTDFVocab:producedData IMDataTransmitted
]

instance MotorPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Motor position encoder providing motor angle measurement r_M."
    DTDFVocab:producedData RMDataTransmitted
]

instance GearboxPositionEncoder : DTDFVocab:SensingComponent [
    base:desc "Gearbox position encoder providing gearbox angle measurement r_G."
    DTDFVocab:producedData RGDataTransmitted
]

// C4: Physical-to-virtual interaction
instance IMDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PermaMagMotorCurrentSensor
]

instance RMDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorPositionEncoder
]

instance RGDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxPositionEncoder
]

// C10: Models/Data
instance IMData : DTDFVocab:Data [
    base:desc "Real-time current data trace I_M streamed via MQTT."
    DTDFVocab:fromData IMDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler, MQTTBrokerEnabler
]

instance RMData : DTDFVocab:Data [
    base:desc "Real-time motor encoder data trace r_M streamed via MQTT."
    DTDFVocab:fromData RMDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler, MQTTBrokerEnabler
]

instance RGData : DTDFVocab:Data [
    base:desc "Real-time gearbox encoder data trace r_G streamed via MQTT."
    DTDFVocab:fromData RGDataTransmitted
    DTDFVocab:inputTo MATLABSimulinkEnabler, MQTTBrokerEnabler
]

// C10: Simulation models
instance MotorSimulationModel : DTDFVocab:Model [
    base:desc "Matlab Simulink model representing the motor dynamics."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance GearboxSimulationModel : DTDFVocab:Model [
    base:desc "Matlab Simulink model representing the gearbox dynamics."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance CoulombViscousFrictionModel : DTDFVocab:Model [
    base:desc "Coulomb-Viscous friction model applied in simulation."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance StribeckFrictionModel : DTDFVocab:Model [
    base:desc "Stribeck friction model applied in simulation."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance DahlFrictionModel : DTDFVocab:Model [
    base:desc "Dahl friction model applied in simulation."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

instance LuGreFrictionModel : DTDFVocab:Model [
    base:desc "LuGre friction model applied in simulation."
    DTDFVocab:inputTo MATLABSimulinkEnabler
]

// Define services referenced by enablers before their use
instance ModelingService : DTDFVocab:Service [
    base:desc "Service providing SysML modeling capabilities."
]

instance AssetMetadataService : DTDFVocab:Service [
    base:desc "Service handling asset metadata within AAS."
]

instance DataAggregationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from aggregated data streams via MQTT."
]

// C11: Enablers
instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML tool for defining and managing engineering models."
    DTDFVocab:enables ModelingService
]

instance MATLABSimulinkEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink enabler for executing simulation models."
    DTDFVocab:enables ContinuousIdentificationService, SimulationComparisonService, ParameterUpdateService
]

instance MQTTBrokerEnabler : DTDFVocab:Enabler [
    base:desc "MQTT broker facilitating live data streaming."
    DTDFVocab:enables DataAggregationService
]

instance AssetAdministrationShellEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell for asset identity and metadata."
    DTDFVocab:enables AssetMetadataService
]

instance DashboardPlatformEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard platform enabling real-time visualization."
    DTDFVocab:enables RealTimeVisualizationDashboardService
]

// C6: Services
instance DataAggregationService : DTDFVocab:Service [
    base:desc "Service aggregating live data streams via MQTT."
    DTDFVocab:provides DataAggregationInsight
]

instance ContinuousIdentificationService : DTDFVocab:Service [
    base:desc "Service continuously identifying friction models using live data."
    DTDFVocab:provides FrictionModelIdentificationInsight
]

instance SimulationComparisonService : DTDFVocab:Service [
    base:desc "Service comparing simulation outputs with real measurements."
    DTDFVocab:provides MotionAccuracyImprovedInsight
]

instance RealTimeVisualizationDashboardService : DTDFVocab:Service [
    base:desc "Real-time dashboard visualizing robot state and friction insights."
    DTDFVocab:provides RealTimeFrictionInsight, DecisionSupportInsight
]

instance ParameterUpdateService : DTDFVocab:Service [
    base:desc "Service updating friction model parameters to improve motion accuracy."
    DTDFVocab:provides UpdateFrictionParametersAction
]

// C17: Insights/Actions
instance RealTimeFrictionInsight : DTDFVocab:Insight [
    base:desc "Real-time friction insight derived from live data."
]

instance FrictionModelIdentificationInsight : DTDFVocab:Insight [
    base:desc "Identification of friction model based on live data."
]

instance MotionAccuracyImprovedInsight : DTDFVocab:Insight [
    base:desc "Improvement in motion accuracy after friction model identification."
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Dashboard-based decision support insight for operators."
]

instance UpdateFrictionParametersAction : DTDFVocab:Action [
    base:desc "Action to update friction model parameters."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "None; the digital shadow does not send control commands to PT in this implementation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time data interchange; synchronization aligned with robot operation; data streaming at sensor sampling rate (not specified), simulations executed in real‑time to match live data."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Consists of Asset (first axis), Engineering models, Data Calculation and Simulation models, Processing component that consumes measurement traces and executes simulation, Data Traces (I_M, r_M, r_G, r_out, etc.), and Dashboard viewer; all orchestrated to provide real‑time friction analysis."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design/ideal (structural and behavior models), Manufacturing (actual robot hardware), Operated (live measurements and continuous identification), and Maintenance/upgrade (model updates)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Hybrid white‑box and black‑box friction models with continual identification; traceability of data points to their origins and computational model; comparison of simulated outputs to measured sensor data; uncertainty handled by updating model parameters during operation; validation through real‑time error monitoring."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol used for real‑time data transfer between PT and DT; AAS for asset metadata; possible use of SysML tools for model exchange; no explicit network topology defined."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML for modeling; AAS standard for asset administration; reference model DSRM; utilization of ISO/IEC standards for digital twin reference but not specified."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Not addressed; passive DT so no risk of remote execution on PT."
]