// C2: Acting Components (none specified in extracted characteristics)

// C3: Physical Sensing Components
instance ManufacturingEnvironmentSensor : DTDFVocab:SensingComponent [
    base:desc "Contextual data aggregation sensor for manufacturing operational monitoring (passive data traces for environmental parameters)"
]

instance ProcessParameterSensor : DTDFVocab:SensingComponent [
    base:desc "High-resolution real-time sensor for process-specific operational metrics in manufacturing systems"
]

instance MotionTrackingSensor : DTDFVocab:SensingComponent [
    base:desc "Distributed sensor network for localized motion tracking data aggregation in automated manufacturing environments"
]

// C4: Physical-to-Virtual Data Transmission
instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ManufacturingEnvironmentSensor
]

instance ProcessParameterDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProcessParameterSensor
]

instance MotionTrackingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionTrackingSensor
]

// C10: Models/Data
instance ManufacturingContextModel : DTDFVocab:Model [
    base:desc "Hierarchical abstraction model integrating requirements, functional, logical, and physical architecture layers for manufacturing systems via ADLs (ACME, AADL, MontiArc)"
    DTDFVocab:inputTo DigitalShadowAggregatorEnabler
]

instance ProcessBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model using MontiArc Automata or SysML state machines to capture dynamic manufacturing process behaviors"
    DTDFVocab:inputTo SimulationEnabler
]

instance OperationalDataStore : DTDFVocab:Data [
    base:desc "Aggregated contextual data traces for specific manufacturing purposes with real-time synchronization via digital shadows"
    DTDFVocab:fromData EnvironmentalDataTransmitted, ProcessParameterDataTransmitted, MotionTrackingDataTransmitted
    DTDFVocab:inputTo DigitalShadowAggregatorEnabler, AnalyticsEnabler
]

instance ProcessMetricsDatabase : DTDFVocab:Data [
    base:desc "Historical and contextualized manufacturing process metrics database for decision support"
    DTDFVocab:fromData ProcessParameterDataTransmitted
    DTDFVocab:inputTo DecisionSupportEnabler
]

// C11: Enablers
instance DigitalShadowAggregatorEnabler : DTDFVocab:Enabler [
    base:desc "Automated one-way data flow system for passive aggregation and abstraction of contextual manufacturing data traces via industrial protocols (OPC UA, Ethernet/IP)"
    DTDFVocab:enables DataAggregationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation integration platform using MathWorks Simulink or equivalent for dynamic behavior validation with ADL-based component models"
    DTDFVocab:enables PerformanceValidationService
]

instance AnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Real-time analytics platform for processing contextual manufacturing data traces with stakeholder-integrated MBSE models"
    DTDFVocab:enables InsightGenerationService
]

instance DecisionSupportEnabler : DTDFVocab:Enabler [
    base:desc "Structured decision-making framework integrating MBSE models (functional/logical architectures) for manufacturing operations"
    DTDFVocab:enables DecisionMakingService
]

// C6: Services
instance DataAggregationService : DTDFVocab:Service [
    base:desc "Service for collecting and abstracting contextual manufacturing data traces from distributed sensors via digital shadows"
    DTDFVocab:provides OperationalContextInsight
]

instance PerformanceValidationService : DTDFVocab:Service [
    base:desc "Service for validating system performance through simulation integration with ADL-based component models"
    DTDFVocab:provides FidelityValidationInsight
]

instance InsightGenerationService : DTDFVocab:Service [
    base:desc "Real-time analytics service generating contextual insights from aggregated manufacturing data traces"
    DTDFVocab:provides OperationalContextInsight, EfficiencyMetricsInsight
]

instance DecisionMakingService : DTDFVocab:Service [
    base:desc "Structured decision-making service using MBSE models for manufacturing operations coordination"
    DTDFVocab:provides ProcessOptimizationAction, SafetyAlertAction
]

// C17: Insights/Actions
instance OperationalContextInsight : DTDFVocab:Insight [
    base:desc "Contextual data traces aggregated for specific manufacturing purposes showing real-time operational context"
]

instance EfficiencyMetricsInsight : DTDFVocab:Insight [
    base:desc "Process-specific efficiency metrics derived from aggregated manufacturing data traces for performance optimization"
]

instance FidelityValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results confirming digital twin model fidelity through simulation-based performance verification"
]

instance ProcessOptimizationAction : DTDFVocab:Action [
    base:desc "Automated process optimization actions derived from stakeholder-integrated MBSE models"
    DTDFVocab:IsAutomatic true
]

instance SafetyAlertAction : DTDFVocab:Action [
    base:desc "Autonomous safety alerts generated from decision-making framework analyzing manufacturing operational data"
    DTDFVocab:IsAutomatic true
]

// C17: Environment
instance ManufacturingSystemEnvironment : DTDFVocab:Environment [
    base:contains ManufacturingEnvironmentSensor, ProcessParameterSensor, MotionTrackingSensor,
        ManufacturingContextModel, ProcessBehaviorModel, OperationalDataStore,
        DigitalShadowAggregatorEnabler, SimulationEnabler, AnalyticsEnabler,
        DecisionSupportEnabler, DataAggregationService, PerformanceValidationService,
        InsightGenerationService, DecisionMakingService,
        OperationalContextInsight, EfficiencyMetricsInsight, FidelityValidationInsight,
        ProcessOptimizationAction, SafetyAlertAction
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "A Digital Twin system in this context does not explicitly define synchronization frequencies, latency requirements, or temporal granularity for twinning. However, the distinction between **Digital Shadows** and **Digital Twins** implies that while a **Digital Shadow** operates as a passive, one-way data flow (e.g., aggregating contextual data traces with abstraction for a specific purpose), a **Digital Twin** would inherently require **active components** to interpret and process incoming data in real-time or near-real-time. This suggests that the **twinning time scale** for a Digital Twin would involve **active synchronization loops** (e.g., periodic or event-driven updates) to ensure real-time or high-frequency data alignment between physical and digital counterparts. The documents do not specify exact frequencies or granularity, but the emphasis on **active components** implies a requirement for **low-latency, high-bandwidth communication** to maintain temporal coherence. If not explicitly defined, the system’s temporal behavior would depend on the integration of **simulation tools** (e.g., MathWorks Simulink) or **code-based implementations** (e.g., C++/Java) for dynamic behavior modeling, which may introduce variable synchronization granularity based on computational constraints."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin constellation** in this context is not explicitly detailed, but the distinction between **Digital Shadows** (passive, one-way data flow) and **Digital Twins** (active, bidirectional) implies a **centralized orchestration framework** where the Digital Twin acts as an active controller or interpreter of the Digital Shadow data. The **architecture description languages (ADLs)** mentioned (e.g., ACME, AADL, MontiArc) suggest that the Digital Twin system would be modeled using **component & connector patterns**, where components could represent **coordinated sub-twins** or specialized digital twins. The **SMArDT methodology** (for Digital Twin-specific modeling) could provide structured patterns for **system-wide coordination**, though its specifics are not elaborated. The **MathWorks Simulink** or **general-purpose languages (C++, Java)** integration for behavior modeling implies that the Digital Twin constellation would rely on **simulation-driven orchestration** to manage interactions between physical and digital components. If no explicit constellation architecture is provided, the system’s coordination would likely follow a **centralized, model-based approach** with **real-time simulation loops** to ensure alignment."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "
    **Not in Document**: The provided documents do not explicitly describe the lifecycle stages of Digital Twins (DTs). However, based on general industry practices, a typical DT lifecycle includes:
    - **Design & Development**: Creation of initial models using MBSE (Model-Based Systems Engineering) with SysML, ADLs (e.g., AADL, MontiArc), and simulation tools (e.g., Simulink).
    - **Deployment & Integration**: Incorporation of DTs into physical systems via digital shadows (one-way data flow) or active DT components.
    - **Operation & Monitoring**: Continuous data aggregation, abstraction, and contextualization for real-time insights.
    - **Evolution & Maintenance**: Updates via version control, quality assurance, and iterative refinement (not detailed in the provided text).
    Transition management is implied through iterative model updates and stakeholder alignment (e.g., via MBSE methodologies like RFLP or SMArDT).
  "
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
    **Model fidelity** is ensured through:
    - **Validation/Verification (V&V) methods**: Implicitly tied to **MBSE methodologies** (e.g., RFLP, OOSEM) and **ADLs** (e.g., AADL’s formal verification tools), though no specific tools or protocols are named.
    - **Uncertainty quantification**: Addressed via **digital shadows’ abstraction** (e.g., filtering noise, aggregating relevant traces), but no explicit error models or quantification techniques are detailed.
    - **Quality assurance**: Enforced by **stakeholder integration** (e.g., cross-domain model consistency checks) and **tool interoperability** (e.g., SysML’s compatibility with simulation tools like Simulink).
    **Error detection/correction** is implied by the **active components** (e.g., DTs) that process incoming data, though no mechanisms (e.g., machine learning, calibration loops) are specified.
    **Fidelity requirements** are implicitly tied to the **purpose of data aggregation** (e.g., manufacturing monitoring), but no quantitative thresholds (e.g., % accuracy, latency bounds) are provided.
  "
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "
  The **Digital Twin (DT)** infrastructure leverages **Model-Based Systems Engineering (MBSE)** methodologies to ensure seamless integration with physical systems, though the documents do not specify explicit protocols or architectures. Key technical aspects inferred from the context include:
  - **Communication flow**: The DT **actively engages** in bidirectional interaction with the physical system, contrasting with the passive digital shadow. This implies the use of **active protocols** (e.g., OPC UA, ROS, or custom gRPC APIs) for real-time command/data exchange.
  - **Network infrastructure**: While not detailed, the DT’s technical connection likely relies on **industrial-grade networks** (e.g., Ethernet/IP, PROFINET) with **low-latency requirements** (e.g., <10ms for critical control loops) to support real-time synchronization.
  - **Reliability/Redundancy**: The DT’s connection must ensure **high availability** (e.g., 99.99% uptime) and redundancy (e.g., failover mechanisms) to mitigate disruptions in physical-digital synchronization.
  - **Security protocols**: Encryption (e.g., TLS 1.3) and authentication (e.g., OAuth 2.0, mutual TLS) are implied for protecting data integrity and preventing unauthorized access, though specifics are not provided.
  - **No explicit mention of bandwidth requirements, topology, or deployment models** in the documents, but the context suggests integration with **MBSE tools** (e.g., SysML, AADL) and simulation environments (e.g., Simulink) for cross-platform compatibility.
"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "
  The **Digital Twin’s hosting and deployment** are designed to support **heterogeneous stakeholder perspectives** and **multi-layered abstraction** (e.g., requirements → functional architecture → logical architecture → technical layer) via **Model-Based Systems Engineering (MBSE)** frameworks. Key technical aspects include:
  - **Platforms**: Deployment can occur on **cloud, edge, or on-premise** infrastructures, though the documents do not specify a preferred model. The DT likely integrates with **cloud-native architectures** (e.g., Kubernetes, Docker) for scalability and **edge computing** for latency-sensitive applications.
  - **Computational/storage requirements**: The DT requires **high-performance computing (HPC)** resources to handle:
    - **Multi-abstraction models** (e.g., SysML, AADL) across different tools (e.g., MathWorks Simulink, custom C++/Java implementations).
    - **Real-time simulation** (e.g., state machines, automata) for behavior modeling.
    - **Data storage**: Scalable storage solutions (e.g., distributed databases like Cassandra or MongoDB) to persist contextual traces and aggregated data for analysis.
  - **Scalability mechanisms**: The DT must support **horizontal scaling** (e.g., load balancing) and **dynamic resource allocation** to accommodate varying workloads (e.g., during peak operational phases).
  - **Availability/reliability**: Assurance mechanisms include **redundant hosting** (e.g., multi-AZ deployments), **automated failover**, and **disaster recovery protocols** to ensure continuous operation.
  - **Deployment models**: The documents mention **methodologies like SMArDT** (a SysML-based approach) for structured deployment, implying adherence to **DevOps practices** (e.g., CI/CD pipelines) for seamless integration with physical systems.
  - **Stakeholder integration**: The DT’s hosting must accommodate **heterogeneous perspectives** (e.g., engineers, operators, analysts) via **interoperable interfaces** (e.g., REST APIs, WebSockets) and **collaborative modeling tools** (e.g., SysML IDEs).
"
]

