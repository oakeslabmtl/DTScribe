instance InputCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Robot sensor measuring input current for precision machining processes"
    DTDFVocab:producedData InputCurrentDataTransmitted
]

instance AngularVelocitySensor : DTDFVocab:SensingComponent [
    base:desc "Robot sensor measuring angular velocity during operation"
    DTDFVocab:producedData AngularVelocityDataTransmitted
]

instance PositionSensor : DTDFVocab:SensingComponent [
    base:desc "Robot sensor measuring position data in precision machining"
    DTDFVocab:producedData PositionDataTransmitted
]

instance InputCurrentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InputCurrentSensor
    base:desc "Filtered input current data transmitted via MQTT with JSON serialization and hierarchical topics"
]

instance AngularVelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AngularVelocitySensor
    base:desc "Angular velocity data transmitted via MQTT with JSON serialization"
]

instance PositionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionSensor
    base:desc "Position data transmitted via MQTT with JSON serialization"
]

instance InputCurrentData : DTDFVocab:Data [
    base:desc "Filtered input current data stored in ThingsBoard for real-time monitoring"
    DTDFVocab:fromData InputCurrentDataTransmitted
    DTDFVocab:inputTo AASExecutorEnabler, ThingsBoardEnabler
]

instance AngularVelocityData : DTDFVocab:Data [
    base:desc "Angular velocity data stored in ThingsBoard for real-time monitoring"
    DTDFVocab:fromData AngularVelocityDataTransmitted
    DTDFVocab:inputTo AASExecutorEnabler, ThingsBoardEnabler
]

instance PositionData : DTDFVocab:Data [
    base:desc "Position data stored in ThingsBoard for real-time monitoring"
    DTDFVocab:fromData PositionDataTransmitted
    DTDFVocab:inputTo AASExecutorEnabler, ThingsBoardEnabler
]

instance ThingsBoardEnabler : DTDFVocab:Enabler [
    base:desc "ThingsBoard platform for data storage and visualization"
    DTDFVocab:enables RealTimeFrictionMonitoringService
]

instance AASExecutorEnabler : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell Executor for populating measured and simulated data into digital shadow"
    DTDFVocab:enables DynamicModelAdaptationService, PredictiveMaintenanceService
]

instance SimulinkEnabler : DTDFVocab:Enabler [
    base:desc "Simulink-based physics simulation for dynamic modeling"
    DTDFVocab:enables SimulativeProcessOptimizationService, CuttingParameterOptimizationService
]

instance DataDrivenModelingEnabler : DTDFVocab:Enabler [
    base:desc "Data-driven modeling for friction analysis using neural networks"
    DTDFVocab:enables ProductQualityPredictionService, PredictiveMaintenanceService
]

instance SysMLEnabler : DTDFVocab:Enabler [
    base:desc "SysML for system architecture modeling and component interfaces"
    DTDFVocab:enables EngineeringModel
]

instance AADLEnabler : DTDFVocab:Enabler [
    base:desc "AADL (SAE standard) for system architecture modeling"
    DTDFVocab:enables AADLModel
]

instance MontiArcEnabler : DTDFVocab:Enabler [
    base:desc "MontiArc for component & connector design"
    DTDFVocab:enables MontiArcModel
]

instance SMArDTEnabler : DTDFVocab:Enabler [
    base:desc "SMArDT for structured modeling methodologies"
    DTDFVocab:enables SMArDTModel
]

instance CppEnabler : DTDFVocab:Enabler [
    base:desc "C++ implementation for detailed behavior modeling"
    DTDFVocab:enables CppModel
]

instance JavaEnabler : DTDFVocab:Enabler [
    base:desc "Java implementation for digital twin components"
    DTDFVocab:enables JavaModel
]

instance PhysicsBasedModel : DTDFVocab:Model [
    base:desc "Simulink-based dynamic simulation model for robot joint dynamics"
    DTDFVocab:inputTo SimulinkEnabler
]

instance DataDrivenModel : DTDFVocab:Model [
    base:desc "Neural network model for friction behavior analysis"
    DTDFVocab:inputTo DataDrivenModelingEnabler
]

instance EngineeringModel : DTDFVocab:Model [
    base:desc "SysML-based structural and functional model of industrial robot"
    DTDFVocab:inputTo SysMLEnabler
]

instance AADLModel : DTDFVocab:Model [
    base:desc "AADL-based model of system architecture and interfaces"
    DTDFVocab:inputTo AADLEnabler
]

instance MontiArcModel : DTDFVocab:Model [
    base:desc "MontiArc model for component and connector design"
    DTDFVocab:inputTo MontiArcEnabler
]

instance SMArDTModel : DTDFVocab:Model [
    base:desc "SMArDT structured model for system components"
    DTDFVocab:inputTo SMArDTEnabler
]

instance CppModel : DTDFVocab:Model [
    base:desc "C++-based model for robot control system behavior"
    DTDFVocab:inputTo CppEnabler
]

instance JavaModel : DTDFVocab:Model [
    base:desc "Java-based model for digital twin system components"
    DTDFVocab:inputTo JavaEnabler
]

instance RealTimeFrictionMonitoringService : DTDFVocab:Service [
    base:desc "Monitors friction in robot joints and external forces in real-time"
    DTDFVocab:provides FrictionMonitoringInsight
]

instance DynamicModelAdaptationService : DTDFVocab:Service [
    base:desc "Dynamically adapts physics-based and data-driven models using new data streams"
    DTDFVocab:provides ModelAdaptationInsight
]

instance CuttingParameterOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes cutting parameters for CO2 reduction"
    DTDFVocab:provides CuttingParameterOptimizationAction
]

instance ProductQualityPredictionService : DTDFVocab:Service [
    base:desc "Predicts product quality based on friction and operational data"
    DTDFVocab:provides ProductQualityPredictionInsight
]

instance SimulativeProcessOptimizationService : DTDFVocab:Service [
    base:desc "Simulates process optimization prior to execution"
    DTDFVocab:provides SimulativeProcessOptimizationInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Detects anomalies in friction behavior for predictive maintenance"
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance FrictionMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time analysis of friction behavior for internal joints and external forces"
]

instance ModelAdaptationInsight : DTDFVocab:Insight [
    base:desc "Insights from dynamic model adaptation based on new data"
]

instance CuttingParameterOptimizationAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of cutting parameters to reduce CO2 emissions"
    DTDFVocab:IsAutomatic true
]

instance ProductQualityPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted product quality metrics based on simulation and data analysis"
]

instance SimulativeProcessOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized process parameters from simulation prior to execution"
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection in friction behavior indicating potential maintenance needs"
]

instance ManufacturingEnvironment : DTDFVocab:Environment [
    base:desc "Precision machining environment for industrial robot operations"
    base:contains RobotJointComponent, ControlSystemComponent
]

instance RobotJointComponent : DTDFVocab:Component [
    base:desc "Robot joint component affecting positioning accuracy in precision machining"
]

instance ControlSystemComponent : DTDFVocab:Component [
    base:desc "Control system for industrial robot managing dead time and compensation"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system integrates the Asset Administration Shell (AAS) as a central data repository, utilizing ThingsBoard for IoT data storage and visualization via MQTT protocol. It combines SysML structural models with Simulink behavioral models through the Functional Mock-up Interface (FMI) for multi-domain simulation. A pipeline automatically processes live robot data, executes simulation models, and updates the digital shadow in ThingsBoard for real-time monitoring and visualization."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained through traceability and verification of transformations (e.g., SysML to simulation models) and simulative experiments to validate before real-world execution. Uncertainty sources such as wear, temperature changes, and varying payloads are addressed by dynamically updating model parameters and retraining neural networks. Error detection mechanisms identify anomalies in friction behavior for predictive maintenance, while quality assurance processes include continuous validation against reference data and real-time adaptation to operational changes."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol (Mosquitto broker) with publish-subscribe architecture for data transmission; hierarchical topic structure enabling message routing and access control via user-specific read/write permissions; ThingsBoard platform for data storage and visualization; secure communication through topic-based permissions."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through standardized protocols including MQTT for real-time data streaming from IoT sensors, and the Asset Administration Shell (AAS) as an Industry 4.0 interoperability standard. Multi-domain model integration uses FMI (Functional Mock-up Interface) to combine SysML structural models with Simulink behavioral models, ensuring seamless data exchange and interoperability with enterprise systems and other digital twins."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with industry standards includes SysML [17] for systems engineering modeling, AADL [24] as an SAE standard for architecture analysis and design, ACME [23] for component-based system architecture, and MontiArc [25, 26] for robotic system modeling. These standards ensure interoperability and structured representation of system components and behaviors."
]