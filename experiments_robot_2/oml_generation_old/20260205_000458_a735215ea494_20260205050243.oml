// C2: Acting Components
instance PermanentMagnetSynchronousMotor : DTDFVocab:ActingComponent [
    base:desc "Permanent magnet synchronous motor driving first axis of MABI 100 robot"
]

// C3: Physical sensing components
instance MotorCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "Current sensor measuring motor current I_M"
    DTDFVocab:producedData IMDataTransmitted
]

instance MotorEncoder : DTDFVocab:SensingComponent [
    base:desc "Encoder on motor rotor capturing angle r_M"
    DTDFVocab:producedData RMDataTransmitted
]

instance GearboxSecondaryEncoder : DTDFVocab:SensingComponent [
    base:desc "Secondary gearbox encoder behind cycloidal gearbox capturing angle r_G"
    DTDFVocab:producedData RGDataTransmitted
]

instance OutputAngleSensor : DTDFVocab:SensingComponent [
    base:desc "Output angle sensor transmitting angle r_out over MQTT"
    DTDFVocab:producedData RoutDataTransmitted
]

// C4: Physical-to-virtual interaction
instance IMDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor
]

instance RMDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance RGDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GearboxSecondaryEncoder
]

instance RoutDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutputAngleSensor
]

instance TorqueDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorCurrentSensor, MotorEncoder
]

instance VelocityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

instance AccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotorEncoder
]

// C10: Models/Data (Engineering Structural and Simulink models)
instance AxisStructuralModel : DTDFVocab:Model [
    base:desc "Structural model of first axis including motor, gearwheel, cycloidal gearbox"
]

instance MotorSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of permanent magnet synchronous motor dynamics"
]

instance GearwheelSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of gearwheel gearbox dynamics"
]

instance CycloidalSimulinkModel : DTDFVocab:Model [
    base:desc "Simulink model of cycloidal gearbox dynamics"
]

instance FrictionModelCoulombViscous : DTDFVocab:Model [
    base:desc "Coulomb–Viscous friction model used in Simulink"
]

instance FrictionModelStribeck : DTDFVocab:Model [
    base:desc "Stribeck friction model used in Simulink"
]

instance FrictionModelDahl : DTDFVocab:Model [
    base:desc "Dahl friction model used in Simulink"
]

instance FrictionModelLuGre : DTDFVocab:Model [
    base:desc "LuGre friction model used in Simulink"
]

instance DataCalculationModelTorque : DTDFVocab:Model [
    base:desc "Data calculation model for computing motor torque"
]

instance DataCalculationModelVelocity : DTDFVocab:Model [
    base:desc "Data calculation model for computing angular velocity"
]

instance DataCalculationModelAcceleration : DTDFVocab:Model [
    base:desc "Data calculation model for computing angular acceleration"
]

// C10: Data instances linked to data traces and models
instance IMData : DTDFVocab:Data [
    base:desc "Measured motor current I_M"
    DTDFVocab:fromData IMDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance RMData : DTDFVocab:Data [
    base:desc "Measured rotor angle r_M"
    DTDFVocab:fromData RMDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance RGData : DTDFVocab:Data [
    base:desc "Measured gearbox angle r_G"
    DTDFVocab:fromData RGDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance RoutData : DTDFVocab:Data [
    base:desc "Measured output angle r_out"
    DTDFVocab:fromData RoutDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance TorqueData : DTDFVocab:Data [
    base:desc "Derived motor torque from current and angle"
    DTDFVocab:fromData TorqueDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance VelocityData : DTDFVocab:Data [
    base:desc "Derived angular velocity"
    DTDFVocab:fromData VelocityDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance AccelerationData : DTDFVocab:Data [
    base:desc "Derived angular acceleration"
    DTDFVocab:fromData AccelerationDataTransmitted
    DTDFVocab:inputTo MQTTBroker
]

instance SimulatedIMData : DTDFVocab:Data [
    base:desc "Simulated motor current from Simulink model"
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulatedRMData : DTDFVocab:Data [
    base:desc "Simulated rotor angle from Simulink model"
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulatedRGData : DTDFVocab:Data [
    base:desc "Simulated gearbox angle from Simulink model"
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulatedRoutData : DTDFVocab:Data [
    base:desc "Simulated output angle from Simulink model"
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulatedTorqueData : DTDFVocab:Data [
    base:desc "Simulated motor torque from Simulink model"
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulatedVelocityData : DTDFVocab:Data [
    base:desc "Simulated angular velocity from Simulink model"
    DTDFVocab:inputTo SimulinkEngine
]

instance SimulatedAccelerationData : DTDFVocab:Data [
    base:desc "Simulated angular acceleration from Simulink model"
    DTDFVocab:inputTo SimulinkEngine
]

// C11: Enablers
instance MQTTBroker : DTDFVocab:Enabler [
    base:desc "MQTT broker transmitting sensor data streams to digital twin"
    DTDFVocab:enables SensorDataIngestionService
]

instance SimulinkEngine : DTDFVocab:Enabler [
    base:desc "Simulink runtime executing motor and gearbox dynamics models"
    DTDFVocab:enables SimulationExecutionService
]

instance AASLinking : DTDFVocab:Enabler [
    base:desc "Asset Administration Shell linking data traces and models for traceability"
    DTDFVocab:enables DataLinkingService
]

instance DashboardVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard visualization enabler providing real‑time view of traces"
    DTDFVocab:enables DashboardVisualizationService
]

instance FrictionIdentificationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for continuous white‑ and black‑box friction model identification"
    DTDFVocab:enables FrictionModelIdentificationService
]

// C6: Services
instance SensorDataIngestionService : DTDFVocab:Service [
    base:desc "Ingests sensor data streams from MQTT broker"
    DTDFVocab:provides DataLinkabilityInsight
]

instance SimulationExecutionService : DTDFVocab:Service [
    base:desc "Executes Simulink models for motor & gearbox dynamics"
    DTDFVocab:provides SimulationAccuracyInsight
]

instance DataLinkingService : DTDFVocab:Service [
    base:desc "Links measured and simulated data traces via Asset Administration Shell"
    DTDFVocab:provides DataTraceabilityInsight
]

instance DashboardVisualizationService : DTDFVocab:Service [
    base:desc "Visualizes real‑time measured and simulated data traces in dashboard"
    DTDFVocab:provides MotionControlAccuracyInsight, MaintenanceSchedulingInsight, ToolWearMonitoringInsight
]

instance FrictionModelIdentificationService : DTDFVocab:Service [
    base:desc "Identifies and refines friction models in white‑ and black‑box manner"
    DTDFVocab:provides FrictionLossQuantificationInsight, ModelParameterUpdateInsight, ParameterCalibrationInsight
]

// C17: Insights
instance DataLinkabilityInsight : DTDFVocab:Insight [
    base:desc "Ensures data traces are linked and traceable via Asset Administration Shell"
]

instance SimulationAccuracyInsight : DTDFVocab:Insight [
    base:desc "Assesses accuracy of simulated motor and gearbox dynamics"
]

instance DataTraceabilityInsight : DTDFVocab:Insight [
    base:desc "Collects traceability information between measured and simulated data"
]

instance MotionControlAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantifies improvement in motion control after friction model updates"
]

instance MaintenanceSchedulingInsight : DTDFVocab:Insight [
    base:desc "Recommends maintenance actions based on friction loss quantification"
]

instance ToolWearMonitoringInsight : DTDFVocab:Insight [
    base:desc "Monitors tool wear inferred from torque and acceleration data"
]

instance FrictionLossQuantificationInsight : DTDFVocab:Insight [
    base:desc "Detects and quantifies friction loss in first axis"
]

instance ModelParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Suggests updates to friction model parameters"
]

instance ParameterCalibrationInsight : DTDFVocab:Insight [
    base:desc "Facilitates calibration of model parameters against real data"
]

// C17: Actions
instance UpdateFrictionModelAction : DTDFVocab:Action [
    base:desc "Updates friction model parameters in Simulink model"
    DTDFVocab:IsAutomatic true
]

instance TriggerMaintenanceCheckAction : DTDFVocab:Action [
    base:desc "Triggers maintenance check for axis based on high friction loss"
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous data acquisition and processing at every control cycle (real‑time); dynamic substitution of friction models during operation, enabling near‑instantaneous updates to the robot controller."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central digital shadow comprising an engineering model of the axis, a processing component executing simulation and data‑calculation models, multiple data traces (measured and simulated), and an AAS for seamless integration; all orchestrated to provide real‑time insight into friction behavior of the first axis."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design stage: engineering structural model of the axis in SysML; manufacturing stage: physical asset data captured by sensors; operational stage: live data streams and dynamic friction model updates during normal robot operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation by comparing simulated outputs against measured data traces; traceability of every data point to its originating processing component and model; uncertainty handled via continuous parameter identification of white‑box and black‑box friction models; model fidelity increased by including temperature, load, and time dependencies."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "One‑way data flow from the physical robot to the digital shadow via MQTT messages; Asset Administration Shells providing semantic metadata; no direct output from the shadow to the robot (passive)."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of SysML (UML) for modeling; AAS (ISO/IEC 42042) for digital asset representation; UML class diagram for reference model; adherence to MBSE methodologies (RFLP, SPES, SMArDT) implied."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Digital shadow is passive, eliminating risk of unsafe remote actuation; data transmission over MQTT may be secured via TLS if configured; no safety controls required on physical system; compliance with industrial safety standards assumed but not specified."
]