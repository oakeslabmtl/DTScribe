// C2: Acting Components
instance OccupancyActuator : DTDFVocab:ActingComponent [
    base:desc "Building control system actuator for occupancy-based lighting control in post-occupancy IoT-enabled building infrastructure"
]

instance TemperatureActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator for temperature regulation in building control system, synchronized with real-time environmental data"
]

instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Dimmer actuator for adaptive lighting control in building infrastructure, integrated with BIM for spatial configuration"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC system actuator for energy-efficient climate control, managed via reinforcement learning in BOREALIS framework"
]

// C3: Physical Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled occupancy sensor for real-time detection of building occupants, synchronized with Eclipse Hono/Ditto middleware"
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled temperature sensor for environmental monitoring, providing real-time temperature readings (0-50°C) via BIM-defined placements"
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled humidity sensor for indoor environmental quality monitoring, synchronized with building DT via Eclipse Hono"
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled CO₂ sensor for air quality monitoring, integrated with BIM for spatial configuration and real-time data transmission"
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled light level sensor for ambient lighting monitoring, synchronized with DT via Ditto protocol"
]

instance PressureSensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled pressure sensor for structural monitoring in building infrastructure, integrated with BIM for spatial relationships"
]

// C4: Data Transmitted
instance OccupancyData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance CO2Data : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance LightLevelData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance PressureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PressureSensor
]

// C10: Models/Data
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "BIM model enriched with IoT device configurations and sensor placements for building digital twin deployment"
    DTDFVocab:inputTo BIMEnrichmentTool
]

instance RuntimeMetadataModel : DTDFVocab:Model [
    base:desc "Runtime metadata model containing sensor configurations, control logic, and operational parameters extracted from BIM"
    DTDFVocab:inputTo ModelDrivenTransformation
]

instance OperationalDataStore : DTDFVocab:Data [
    base:desc "Structured data store for real-time operational data (sensor readings, control signals) in service-oriented architecture"
    DTDFVocab:inputTo EclipseHonoMiddleware
    DTDFVocab:fromData TemperatureData, HumidityData, CO2Data, LightLevelData, PressureData, OccupancyData
]

instance BIMGeometryModel : DTDFVocab:Data [
    base:desc "3D geometry model derived from BIM for spatial representation in Unreal Engine visualization"
    DTDFVocab:inputTo UnrealEngineVisualization
]

// C11: Enablers
instance EclipseHonoMiddleware : DTDFVocab:Enabler [
    base:desc "Real-time data exchange middleware (Eclipse Hono) for bidirectional communication between physical building and digital twin"
    DTDFVocab:enables DataSynchronizationService, ActuationService
]

instance DittoMiddleware : DTDFVocab:Enabler [
    base:desc "Protocol for real-time data transmission (Ditto) enabling low-overhead updates in digital twin architecture"
]

instance BIMEnrichmentTool : DTDFVocab:Enabler [
    base:desc "Model-driven tooling for BIM model enrichment with IoT device configurations and sensor placements"
]

instance ModelDrivenTransformation : DTDFVocab:Enabler [
    base:desc "Automated transformation framework converting BIM models into runtime artifacts for digital twin deployment"
    DTDFVocab:enables ValidationPipeline
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Immersive 3D visualization platform (Unreal Engine 5) for interactive digital twin representation"
    DTDFVocab:enables VisualizationService
]

instance BOREALISReinforcementLearning : DTDFVocab:Enabler [
    base:desc "Domain-specific reinforcement learning framework for adaptive control logic (e.g., lighting/HVAC optimization)"
    DTDFVocab:enables ControlOptimizationService
]

instance TwinLightFramework : DTDFVocab:Enabler [
    base:desc "BIM-centric framework for building control configurations and digital twin evolution"
    DTDFVocab:enables ModularServiceIntegration
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring service providing real-time data streams (temperature, occupancy, CO₂) via Unreal Engine visualization"
    DTDFVocab:provides OccupancyMonitoringInsight, EnvironmentalMonitoringInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Energy consumption forecasting service using predictive models for operational optimization"
    DTDFVocab:provides EnergyConsumptionForecast, ComfortPredictions
]

instance ControlOptimizationService : DTDFVocab:Service [
    base:desc "Adaptive control service implementing reinforcement learning for HVAC/lighting optimization (BOREALIS framework)"
    DTDFVocab:provides AdaptiveLightingSchedule, HVACOptimization
]

instance InteractiveSimulationService : DTDFVocab:Service [
    base:desc "Performance analysis service enabling interactive simulation during design phases"
    DTDFVocab:provides DesignPhaseAnalysis, OperationalSimulation
]

instance ModularServiceIntegration : DTDFVocab:Service [
    base:desc "Framework for incremental upgrades enabling custom plugins for analytics and IoT device management"
    DTDFVocab:provides CustomAnalyticsPlugin, DeviceManagementPlugin
]

instance DataSynchronizationService : DTDFVocab:Service [
    base:desc "Service coordinating bidirectional data exchange between physical building and digital twin via Eclipse Hono/Ditto"
    DTDFVocab:provides RealTimeDataFlow
]

instance ActuationService : DTDFVocab:Service [
    base:desc "Service managing bidirectional communication with building control actuators (lighting/HVAC)"
    DTDFVocab:provides ActuationCommands
]

instance ValidationPipeline : DTDFVocab:Service [
    base:desc "Automated validation framework (ODTE metrics) ensuring fidelity between physical and digital representations"
    DTDFVocab:provides FidelityValidation
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service providing immersive 3D visualization for collaborative decision-making"
    DTDFVocab:provides InteractiveVisualization
]

// C17: Insights/Actions
instance OccupancyMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time occupancy data analysis for space utilization optimization and energy efficiency"
]

instance EnvironmentalMonitoringInsight : DTDFVocab:Insight [
    base:desc "Comprehensive environmental data analysis (temperature, humidity, CO₂) for occupant comfort assessment"
]

instance EnergyConsumptionForecast : DTDFVocab:Insight [
    base:desc "Predictive analytics for energy consumption patterns enabling proactive optimization strategies"
]

instance ComfortPredictions : DTDFVocab:Insight [
    base:desc "Predictive modeling of occupant comfort levels based on environmental parameters and occupancy patterns"
]

instance AdaptiveLightingSchedule : DTDFVocab:Action [
    base:desc "Automated lighting control adjustment based on occupancy and environmental conditions (reinforcement learning optimized)"
    DTDFVocab:IsAutomatic true
]

instance HVACOptimization : DTDFVocab:Action [
    base:desc "Dynamic HVAC system adjustments for energy efficiency while maintaining thermal comfort"
    DTDFVocab:IsAutomatic true
]

instance DesignPhaseAnalysis : DTDFVocab:Action [
    base:desc "Interactive simulation for performance analysis during building design phases"
    DTDFVocab:IsAutomatic false
]

instance OperationalSimulation : DTDFVocab:Action [
    base:desc "Real-time operational simulation for facility management decision support"
    DTDFVocab:IsAutomatic false
]

instance CustomAnalyticsPlugin : DTDFVocab:Action [
    base:desc "Modular analytics extension enabling custom predictive models and data processing"
    DTDFVocab:IsAutomatic false
]

instance DeviceManagementPlugin : DTDFVocab:Action [
    base:desc "IoT device management extension for sensor/actuator configuration and lifecycle management"
    DTDFVocab:IsAutomatic false
]

instance RealTimeDataFlow : DTDFVocab:Action [
    base:desc "Continuous bidirectional data exchange between physical building and digital twin"
    DTDFVocab:IsAutomatic true
]

instance ActuationCommands : DTDFVocab:Action [
    base:desc "Control signals sent to building actuators (lighting/HVAC) based on digital twin decisions"
    DTDFVocab:IsAutomatic true
]

instance FidelityValidation : DTDFVocab:Action [
    base:desc "Automated validation ensuring physical-digital twin alignment via ODTE metrics"
    DTDFVocab:IsAutomatic true
]

instance InteractiveVisualization : DTDFVocab:Action [
    base:desc "Immersive 3D visualization interface for stakeholder collaboration and decision-making"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Facilitates **control signal transmission** from the DT to physical actuators (e.g., lighting, HVAC systems) via **Eclipse Hono** and **Ditto**, enabling automated adjustments to operational parameters. The framework supports dynamic runtime configurations, allowing DT engineers to define control logic directly within BIM models, which are then transformed into deployable artifacts. This ensures bidirectional adaptability for real-time optimization (e.g., energy-efficient lighting control)."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin operates with **real-time synchronization**, ensuring bidirectional data exchange at high frequencies. The **Overall Digital Twin Entanglement (ODTE) metric** is used to validate the fidelity of the DT, though specific frequency details (e.g., 1Hz, 10Hz) are not explicitly quantified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Orchestrates a **modular DT ecosystem** where BIM models serve as the core semantic foundation. The DT constellation includes **centralized runtime interfaces** (via Eclipse Hono/Ditto) for bidirectional communication, **Unreal Engine-based visualization** for stakeholder interaction, and **service-oriented extension points** for integrating custom analytics and IoT devices. The Living Lab case study demonstrates a **scalable, interoperable DT** where components (e.g., lighting, HVAC) are dynamically integrated into a unified virtual representation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the **entire building life cycle**, from **design (ideal representation)** to **manufacturing (as-manufactured accuracy)** to **operation (real-time monitoring and optimization)**. The framework automates the transition from static BIM models to operational DTs, ensuring continuity across phases. The **BIM-centric approach** supports lifecycle-specific adaptations (e.g., post-occupancy data integration for BOREALIS adaptive lighting)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Ensures **high fidelity** via the **Overall Digital Twin Entanglement (ODTE) metric**, which evaluates the alignment between the DT and its physical counterpart. The framework addresses **semantic drift** by automating runtime synchronization (e.g., sensor data updates) and leveraging **BIM’s static-to-dynamic transformation** to maintain consistency. Verification/validation mechanisms include **model-to-model transformations** (e.g., from BIM to runtime interfaces) and **real-time data validation** via middleware (Eclipse Hono/Ditto)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Established via **Eclipse Hono** and **Ditto** protocols for **real-time, low-latency communication** between physical sensors/actuators and the DT. The network architecture supports **bidirectional data flows** (e.g., sensor readings → DT; DT → actuators) with standardized APIs. The framework integrates with **BIM’s spatial data** to define physical-to-virtual interactions, ensuring seamless synchronization."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployed as a **service-oriented platform** with **standardized extension points** for modularity. The DT is hosted on a **scalable infrastructure** supporting real-time operations, leveraging cloud-based middleware (Eclipse Hono/Ditto) and **Unreal Engine** for visualization. The framework automates deployment from BIM models, reducing manual effort while ensuring maintainability and interoperability with existing AECO systems."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Enables **interoperability with external systems** (e.g., IoT platforms, BIM tools) via standardized APIs (Eclipse Hono/Ditto) and **BIM’s semantic backbone**. The modular architecture supports integration with **third-party services** (e.g., analytics platforms) and **cross-DT communication** in larger infrastructure ecosystems. Horizontal integration is facilitated by **extension points** for custom service plugins."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership and privacy are **not explicitly detailed** in the documents. The framework focuses on interoperability and real-time synchronization but does not specify ownership models or privacy compliance mechanisms."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adheres to **AECO-specific standards** (e.g., BIM standards for building components, IoT interoperability protocols like MQTT via Eclipse Hono). The framework leverages **model-driven engineering (MDE)** to enforce standardized metadata extraction from BIM models, ensuring consistency across deployments. Standardized extension points enable **interoperability with existing DT frameworks** (e.g., Eclipse Ditto, Unreal Engine plugins)."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety considerations are **not explicitly detailed** in the documents. The framework emphasizes interoperability, real-time synchronization, and extensibility but does not address authentication, encryption, or safety protocols (e.g., isolated deployment) for remote operations."
]