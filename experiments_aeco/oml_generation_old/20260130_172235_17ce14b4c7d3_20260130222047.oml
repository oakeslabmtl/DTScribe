// ====================================================
// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in the BIM model to provide real‑time temperature measurements to the twin."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in the BIM model to deliver real‑time occupancy counts to the twin."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor defined in the BIM model to stream ambient light levels to the twin."
    DTDFVocab:producedData LightingDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

// C10: Data produced from sensors
instance TemperatureData : DTDFVocab:Data [
    base:desc "Stream of temperature readings originating from TemperatureSensor."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Stream of occupancy counts originating from OccupancySensor."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance LightingData : DTDFVocab:Data [
    base:desc "Stream of ambient light levels originating from LightingSensor."
    DTDFVocab:fromData LightingDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C2: Acting components (actuators & controllers)
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator modeled in BIM to receive control commands from the twin."
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in BIM to receive dimming commands from the twin."
]

instance BuildingController : DTDFVocab:ActingComponent [
    base:desc "Building controller that orchestrates HVAC and lighting actuators based on twin logic."
]

// C10: Models
instance BIMStaticModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing geometry, devices (sensors, actuators, controllers) and metadata – static semantic model of the building."
    DTDFVocab:inputTo EclipseDitto
]

instance PhysicsSimulationModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model used for thermal and energy calculations within the twin."
    DTDFVocab:inputTo UnrealEngine5, EclipseDitto
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware providing secure IoT connectivity and ingestion of sensor streams."
    DTDFVocab:enables MonitoringService, OptimizationService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin platform for state management, rule execution and integration with services."
    DTDFVocab:enables MonitoringService, SimulationService, OptimizationService, VisualizationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 rendering engine delivering immersive 3D visualization of the building twin."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring service aggregating sensor streams and exposing dashboards."
    DTDFVocab:provides MonitoringDashboardInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation service that computes thermal and energy performance."
    DTDFVocab:provides SimulationOutcomeInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Operational optimization service that analyses data and generates actionable recommendations."
    DTDFVocab:provides OptimizationRecommendationInsight, HVACAdjustmentAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D visualization service delivering the building twin within Unreal Engine 5."
    DTDFVocab:provides VisualizationInsight
]

// C17: Insights
instance MonitoringDashboardInsight : DTDFVocab:Insight [
    base:desc "Live dashboards presenting temperature, occupancy, and lighting status to facility managers."
]

instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Simulation results showing predicted energy consumption and thermal comfort metrics."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for HVAC set‑point adjustments to improve energy efficiency."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D view of the building twin enabling spatial analysis and stakeholder walkthroughs."
]

// C17: Actions
instance HVACAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic command to adjust HVAC actuator set‑points based on optimization output."
    DTDFVocab:IsAutomatic true
]

// C9: Environment (optional grouping)
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, OccupancySensor, LightingSensor,
                HVACActuator, LightingActuator, BuildingController,
                BIMStaticModel, PhysicsSimulationModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points, HVAC adjustments) are sent back to the physical devices through the same bidirectional Hono/Ditto communication layer."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization (live data exchange) between physical assets and the twin."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where the enriched BIM model is processed by a model‑driven pipeline, middleware (Hono/Ditto) provides bidirectional data flow, and a Unreal Engine front‑end visualizes the twin; extension points allow additional services to be plugged in."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin spans the design, construction and operational phases of the building, reflecting BIM data from initial design through post‑occupancy operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Entanglement between physical and digital counterparts is quantified using the Overall Digital Twin Entanglement (ODTE) metric to assess fidelity of the twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication is realized through Eclipse Hono and Eclipse Ditto, which handle device identification, tenant information and data exchange between PT and DT."
]