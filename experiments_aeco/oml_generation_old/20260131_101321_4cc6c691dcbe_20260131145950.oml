// C3: Physical sensing components // Return code: 1 | Stderr:
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring external ambient temperature"
    DTDFVocab:producedData TemperatureTelemetry
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor detecting presence of people in rooms"
    DTDFVocab:producedData OccupancyTelemetry
]

instance PowerUsageSensor : DTDFVocab:SensingComponent [
    base:desc "Power usage sensor monitoring electrical consumption of HVAC units"
    DTDFVocab:producedData PowerUsageTelemetry
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor measuring light levels of interior areas"
    DTDFVocab:producedData IlluminationTelemetry
]

// C4: Physical‑to‑virtual interaction
instance TemperatureTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance PowerUsageTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerUsageSensor
]

instance IlluminationTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

// C10: Models / Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature telemetry data transmitted via MQTT broker Hono"
    DTDFVocab:fromData TemperatureTelemetry
    DTDFVocab:inputTo DittoTwinEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy telemetry data transmitted via MQTT broker Hono"
    DTDFVocab:fromData OccupancyTelemetry
    DTDFVocab:inputTo DittoTwinEnabler
]

instance PowerUsageData : DTDFVocab:Data [
    base:desc "Power‑usage telemetry data transmitted via MQTT broker Hono"
    DTDFVocab:fromData PowerUsageTelemetry
    DTDFVocab:inputTo DittoTwinEnabler
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Illumination telemetry data transmitted via MQTT broker Hono"
    DTDFVocab:fromData IlluminationTelemetry
    DTDFVocab:inputTo DittoTwinEnabler
]

instance IfcBIMModel : DTDFVocab:Model [
    base:desc "IFC BIM model of the building infrastructure from Revit"
    DTDFVocab:inputTo BIMTransformationEnabler, DittoTwinEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model defining lighting and HVAC control rules within the BIM"
    DTDFVocab:inputTo DittoTwinEnabler
]

instance ReinforcementLearningPolicy : DTDFVocab:Model [
    base:desc "Reinforcement learning policy for lighting optimization"
    DTDFVocab:inputTo DittoTwinEnabler
]

// C11: Enablers
instance HonoMQTTEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for MQTT-based data ingestion of sensor telemetry"
    DTDFVocab:enables MonitoringDashboardService, PredictiveEnergyAnalyticsService, 
                BuildingPerformanceSimulationService, LightingRLOptimizationService
]

instance DittoTwinEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for twin management and JSON event ingestion"
    DTDFVocab:enables MonitoringDashboardService, PredictiveEnergyAnalyticsService,
                BuildingPerformanceSimulationService, LightingRLOptimizationService,
                UnrealVisualizationService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3D visualization of the building"
    DTDFVocab:enables UnrealVisualizationService
]

instance BIMTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation tool converting BIM to runtime interfaces during twin deployment"
]

instance RevitEditorEnabler : DTDFVocab:Enabler [
    base:desc "Revit BIM editor for creating and editing IFC models"
]

// C6: Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards showing current building performance metrics"
    DTDFVocab:provides RealTimeMonitoringInsight, UpdateControlPolicyAction
]

instance PredictiveEnergyAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive energy management analytics that generate energy‑saving recommendations"
    DTDFVocab:provides PredictiveEnergySavingInsight, UpdateControlPolicyAction
]

instance LightingRLOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement learning based lighting optimization that suggests optimal lighting schedules"
    DTDFVocab:provides LightingRLOptimizationInsight, UpdateControlPolicyAction
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance to predict future conditions"
    DTDFVocab:provides BuildingPerformanceSimulationInsight, NotifyFacilityManagerAction
]

instance UnrealVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization in Unreal Engine 5 providing interactive 3D exploration"
    DTDFVocab:provides UnrealVisualizationInsight
]

// C17: Insights and Actions
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring dashboards display live sensor data and system status"
]

instance PredictiveEnergySavingInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics provide energy‑saving recommendations based on trends"
]

instance LightingRLOptimizationInsight : DTDFVocab:Insight [
    base:desc "RL optimization suggests lighting schedules that reduce energy consumption"
]

instance BuildingPerformanceSimulationInsight : DTDFVocab:Insight [
    base:desc "Performance simulation predicts future building conditions for proactive management"
]

instance UnrealVisualizationInsight : DTDFVocab:Insight [
    base:desc "Unreal Engine visualizes building data in interactive 3 D"
]

instance UpdateControlPolicyAction : DTDFVocab:Action [
    base:desc "Automatically updates control policies for lighting and HVAC based on analytics"
    DTDFVocab:IsAutomatic true
]

instance NotifyFacilityManagerAction : DTDFVocab:Action [
    base:desc "Sends alerts to facility managers when simulation outcomes exceed thresholds"
    DTDFVocab:IsAutomatic true
]

// Acting Components for physical acting
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control actuator used to switch lights on/off via BCS"
]

instance HvacDamperActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC damper actuator controlling airflow in the building"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control command messages sent from the DT to building actuators via Eclipse Ditto (JSON over MQTT/HTTP) to adjust lighting levels, HVAC set‑points, etc."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, real‑time data synchronization between the physical building and the twin; updates are processed as soon as sensor events arrive, without fixed sampling intervals specified"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular service‑oriented architecture where BIM‑derived component twins are exposed through Ditto, orchestrated by a central twin hub, with visualization and analytics services plugged in via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (BIM creation), fabrication/installation (device configuration captured in BIM), and operation (live data exchange), covering the building from ideal design through deployed asset."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Semantic alignment verified by ODM and verified through the ODTE metric; periodic synchronization checks; handling of semantic drift via re‑extraction from updated BIM; confidence intervals for predictive models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Runtime connectivity established through Eclipse Hono (message broker) and Eclipse Ditto (digital twin service) enabling event‑based data flow between the physical building and its twin"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital twin components are deployed on scalable, orchestrated infrastructure (e.g., cloud or on‑premises) that supports micro‑services and can scale horizontally"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability with external platforms through standardized protocols supported by Eclipse Ditto and Hono, facilitating data exchange with other digital twins or legacy systems"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Uses BIM (IFC) as the standard data model and implements standardized integration mechanisms (Hono, Ditto), ensuring consistent semantic alignment across engineering workflows."
]