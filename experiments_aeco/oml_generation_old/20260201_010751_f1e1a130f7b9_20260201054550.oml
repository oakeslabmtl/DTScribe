// C2: Acting Components
instance LightActuator : DTDFVocab:ActingComponent [
    base:desc "Light actuator defined as a LightTwinComponent in the BIM, controlled via MQTT messages over Ditto."
]
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator represented as a LightTwinComponent in the BIM, controlled via MQTT over Ditto."
]

// C3: Physical sensing components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light presence sensor defined in enriched BIM model; provides light on/off state, brightness level, color-temperature in Kelvin."
    DTDFVocab:producedData LightDataTransmitted
]
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in BIM; measures ambient temperature."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in BIM; detects presence of occupants in a zone."
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance AirflowSensor : DTDFVocab:SensingComponent [
    base:desc "Airflow sensor defined in BIM; measures airflow velocity."
    DTDFVocab:producedData AirflowDataTransmitted
]

// C4: Physical-to-virtual interaction
instance LightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance AirflowDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirflowSensor
]

// C6: Services (with INF/Action provisions)
instance MonitoringService : DTDFVocab:Service [
    base:desc "Service providing real‑time telemetry of device states (temperature, airflow, occupancy, consumables) aggregated from BIM‑defined sensor network."
    DTDFVocab:provides DeviceTelemetryInsight
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service providing machine‑learning‑based failure prediction and energy optimisation forecasts."
    DTDFVocab:provides FailurePredictionInsight
]
instance ControlService : DTDFVocab:Service [
    base:desc "Service enabling direct actuation of building equipment through twin interface."
    DTDFVocab:provides ActuateCommand
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Service providing immersive 3D rendering of BIM model with live data overlays."
    DTDFVocab:provides RenderBIMAction
]
instance OptimizationService : DTDFVocab:Service [
    base:desc "Service offering recommendation engines that propose efficient control strategies to meet energy, comfort or operational objectives."
    DTDFVocab:provides ControlStrategyInsight, OptimizationAction
]

// C11: Enablers
instance HonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono enabler that publishes sensor streams and subscribes to actuator commands, maintaining event store."
    DTDFVocab:enables MonitoringService, PredictiveAnalyticsService, OptimizationService
]
instance DittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto enabler that maintains a device registry and event store for twin representation."
    DTDFVocab:enables ControlService
]
instance UE5VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 visualization enabler that renders BIM with live data overlays."
    DTDFVocab:enables VisualizationService
]
instance MDEPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline that validates and converts enriched BIM models into deployable DT artifacts."
    DTDFVocab:enables MonitoringService, PredictiveAnalyticsService, ControlService, VisualizationService, OptimizationService
]

// C7: Data
instance LightTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data stream for light sensor including on/off state, brightness and color‑temperature from the BIM‑defined light sensor."
    DTDFVocab:fromData LightDataTransmitted
    DTDFVocab:inputTo HonoEnabler
]
instance TemperatureTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data stream for temperature sensor from the BIM‑defined temperature sensor."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo HonoEnabler
]
instance OccupancyTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data stream for occupancy sensor from the BIM‑defined occupancy sensor."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo HonoEnabler
]
instance AirflowTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data stream for airflow sensor from the BIM‑defined airflow sensor."
    DTDFVocab:fromData AirflowDataTransmitted
    DTDFVocab:inputTo HonoEnabler
]

// C10: Models/Data
instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing geometric, behavioral, and control‑logic information for building components."
    DTDFVocab:inputTo MDEPipelineEnabler
]

// C17: Insights / Actions
instance DeviceTelemetryInsight : DTDFVocab:Insight [
    base:desc "Real‑time telemetry of device states aggregated from sensor network."
]
instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Insights from predictive analytics for failure prediction."
]
instance ControlStrategyInsight : DTDFVocab:Insight [
    base:desc "Insights from recommendation engine for control optimisation."
]
instance ActuateCommand : DTDFVocab:Action [
    base:desc "Action to send actuating command to building equipment."
    DTDFVocab:IsAutomatic false
]
instance RenderBIMAction : DTDFVocab:Action [
    base:desc "Action to render BIM model with live data overlays."
    DTDFVocab:IsAutomatic false
]
instance OptimizationAction : DTDFVocab:Action [
    base:desc "Action to apply recommended control strategies for optimisation."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional data exchange allows the digital twin to send control commands back to physical building systems, enabling real‑time monitoring and control by facility managers via the central DT framework hub."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange capabilities ensure continuous synchronization between physical buildings and their digital counterparts, with the Digital Twin designed to generate bidirectional data feeds at update intervals driven by operational monitoring requirements; while precise numeric frequencies or latency bounds are not specified in the documents, the architecture supports real‑time monitoring and control with low‑latency update cycles."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular architecture centered around a DT Framework hub that orchestrates data exchange, runtime configuration, and service integration. Standardized extension points enable custom analytics services to be integrated without full redeployment, while component integration is managed through the framework’s runtime configuration management, allowing dynamic resource allocation and coordinated operation across the lifecycle of a building asset."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework follows a six‑stage lifecycle: (1) Enrichment – Building Control Engineers extend BIM with sensors, actuators and controllers; (2) Transformation – Model‑Driven Engineering extracts structured semantic representations; (3) Generation – Deployable DT artifacts (e.g., OPC UA nodes, REST/GraphQL services) are automatically created; (4) Deployment – These artifacts are deployed within a modular runtime that supports real‑time bidirectional data exchange; (5) Extension – DT Engineers add custom analytics or control services through defined extension points; (6) Monitoring and Governance – Facility Managers monitor physical infrastructure via immersive visualisation, while versioned BIM models provide traceability and change management."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation occurs during the deployment pipeline’s validation component, ensuring that BIM models conform to expected schemas prior to code generation. The real‑time data exchange between the physical building and the twin is monitored for consistency, but the document does not detail explicit fault‑tolerance, error quantification, or iterative verification mechanisms beyond the initial deployment validation."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration is achieved through standardized extension points that facilitate interoperability across heterogeneous AECO systems, supporting bidirectional data exchange between enriched BIM models and operational DTs. The framework’s non‑functional requirements emphasize interoperability, scalability, and maintainability, implying the use of common enterprise APIs and data‑exchange protocols, although specific protocols are not enumerated."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework’s primary data model is BIM; it adheres to the semantic structures defined by the BIM ecosystem. Connectivity is handled through open‑source components such as Eclipse Ditto, and the architecture exposes standardized extension points that permit integration of additional services and custom analytics. No further industry certifications or interoperability frameworks are described in the documents."
]