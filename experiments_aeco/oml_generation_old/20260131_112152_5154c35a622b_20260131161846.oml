// C3: Physical Sensing Components
instance EnvironmentalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor deployed in buildings to capture real-time environmental temperature data for Digital Twin monitoring and analysis."
    DTDFVocab:producedData EnvironmentalTemperatureDataTransmitted
]

instance EnvironmentalHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor deployed in buildings to capture real-time environmental humidity data for Digital Twin monitoring and analysis."
    DTDFVocab:producedData EnvironmentalHumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor deployed in buildings to detect real-time occupancy status for Digital Twin operational monitoring."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor deployed in buildings to measure real-time energy consumption data for Digital Twin analysis."
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

instance IoTDevice : DTDFVocab:SensingComponent [
    base:desc "Generic IoT device deployed in buildings to capture additional operational data for Digital Twin integration."
    DTDFVocab:producedData IoTDeviceDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance EnvironmentalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalTemperatureSensor
]

instance EnvironmentalHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalHumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance IoTDeviceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IoTDevice
]

// C10: Models/Data
instance BuildingInformationModel : DTDFVocab:Model [
    base:desc "Foundational BIM model representing building geometry, components, and static properties for Digital Twin deployment."
    DTDFVocab:inputTo BimToDtTransformationEnabler
]

instance BuildingControlSystemRuntimeSemantics : DTDFVocab:Model [
    base:desc "Runtime semantics model for Building Control Systems (BCS) integrated with BIM to enable operational Digital Twin capabilities."
    DTDFVocab:inputTo BimToDtTransformationEnabler
]

instance EnvironmentalTemperatureData : DTDFVocab:Data [
    base:desc "Real-time environmental temperature data collected from sensors for Digital Twin analysis."
    DTDFVocab:fromData EnvironmentalTemperatureDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

instance EnvironmentalHumidityData : DTDFVocab:Data [
    base:desc "Real-time environmental humidity data collected from sensors for Digital Twin analysis."
    DTDFVocab:fromData EnvironmentalHumidityDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy data collected from sensors for Digital Twin operational monitoring."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "Real-time energy consumption data collected from sensors for Digital Twin optimization."
    DTDFVocab:fromData EnergyConsumptionDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

instance IoTDeviceData : DTDFVocab:Data [
    base:desc "Real-time operational data from IoT devices integrated into the Digital Twin."
    DTDFVocab:fromData IoTDeviceDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

instance SimulationModel : DTDFVocab:Model [
    base:desc "Simulation models for predictive analytics and optimization within the Digital Twin framework."
    DTDFVocab:inputTo SimulationEnabler
]

// C11: Enablers
instance BimToDtTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Automated pipeline for transforming BIM models into operational Digital Twin artifacts through model-driven engineering."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, SimulationService
]

instance RealTimeDataExchangeEnabler : DTDFVocab:Enabler [
    base:desc "Middleware platform using Eclipse Hono and Ditto for real-time bidirectional data exchange between physical assets and Digital Twin."
    DTDFVocab:enables RealTimeMonitoringService, OptimizationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Interactive visualization tool using Unreal Engine for Digital Twin representation and user interaction."
    DTDFVocab:enables RealTimeMonitoringService, CustomServiceIntegration
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for running simulation models within the Digital Twin for predictive analytics and optimization."
    DTDFVocab:enables PredictiveAnalyticsService, OptimizationService
]

instance CustomServiceIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Standardized extension points for integrating domain-specific services into the Digital Twin framework."
    DTDFVocab:enables CustomServiceIntegration
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real-time monitoring of building operations through Digital Twin visualization and data analysis."
    DTDFVocab:provides BuildingOperationalInsight, EnergyConsumptionInsight, OccupancyPatternInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service offering predictive analytics capabilities for building performance optimization."
    DTDFVocab:provides PredictiveMaintenanceInsight, EnergyOptimizationStrategy
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service enabling simulation of building operations for scenario testing and optimization."
    DTDFVocab:provides SimulationOptimizationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing building operations including energy efficiency and visual comfort."
    DTDFVocab:provides EnergyEfficiencyOptimizationAction, VisualComfortOptimizationAction
]

instance CustomServiceIntegration : DTDFVocab:Service [
    base:desc "Service enabling integration of domain-specific applications and custom services into the Digital Twin."
    DTDFVocab:provides CustomApplicationInsight
]

// C2: Acting Components
instance LightingSystemActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator embedded in Building Control Systems for lighting system operational control within the Digital Twin."
]

instance HVACSystemActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator embedded in Building Control Systems for HVAC system operational control within the Digital Twin."
]

instance BuildingAutomationController : DTDFVocab:ActingComponent [
    base:desc "Controller integrated into Building Control Systems for automated building operations management within the Digital Twin."
]

// C17: Insights/Actions
instance BuildingOperationalInsight : DTDFVocab:Insight [
    base:desc "Insight providing real-time operational status and performance metrics of building systems."
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight detailing current and historical energy consumption patterns for building optimization."
]

instance OccupancyPatternInsight : DTDFVocab:Insight [
    base:desc "Insight analyzing occupancy patterns to optimize building operations and resource allocation."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Insight providing recommendations for predictive maintenance of building components based on real-time data."
]

instance EnergyOptimizationStrategy : DTDFVocab:Insight [
    base:desc "Insight offering strategies for optimizing energy consumption in building operations."
]

instance SimulationOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulation models to optimize building performance scenarios."
]

instance EnergyEfficiencyOptimizationAction : DTDFVocab:Action [
    base:desc "Automated action to optimize energy efficiency in building operations based on Digital Twin analysis."
    DTDFVocab:IsAutomatic true
]

instance VisualComfortOptimizationAction : DTDFVocab:Action [
    base:desc "Automated action to optimize visual comfort in building spaces based on Digital Twin data."
    DTDFVocab:IsAutomatic true
]

instance CustomApplicationInsight : DTDFVocab:Insight [
    base:desc "Insight generated from domain-specific custom services integrated into the Digital Twin."
]

// C1: Environment
instance BuildingDigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains BuildingInformationModel, BuildingControlSystemRuntimeSemantics, SimulationModel,
                 EnvironmentalTemperatureSensor, EnvironmentalHumiditySensor, OccupancySensor,
                 EnergyConsumptionSensor, IoTDevice, LightingSystemActuator, HVACSystemActuator,
                 BuildingAutomationController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals generated by the DT and transmitted back to the physical building to adjust actuators and controllers (e.g., lighting, HVAC systems). This interaction is facilitated through middleware platforms and ensures real-time operational adjustments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization between the physical and virtual worlds, with continuous data exchange and updates to ensure the DT reflects the current state of the physical asset. The DT services operate at runtime, enabling immediate decision-making and adjustments."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT system is orchestrated as a cohesive platform that integrates BIM models, real-time data streams, control logic, and visualization tools. It enables bidirectional communication between the physical and virtual worlds, supporting a holistic approach to building lifecycle management."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the entire building lifecycle, from initial design and construction to operation, refurbishment, and adaptation. It supports representations of the physical counterpart as designed (ideal), as manufactured, and as operated, ensuring continuous alignment with the evolving physical asset."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The fidelity of the DT is evaluated using the Overall Digital Twin Entanglement (ODTE) metric to measure how well the DT reflects its physical counterpart. Validation mechanisms include real-time synchronization, automated data extraction, and continuous monitoring to ensure accuracy and reliability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT connects to the physical world using middleware platforms (Eclipse Hono and Ditto) for real-time data exchange. Network protocols and architectures support bidirectional communication, ensuring seamless integration between physical sensors/actuators and the DT."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed on a scalable, modular platform with standardized extension points. It leverages cloud-based or on-premise hosting solutions to support real-time operations and interactive visualization, with deployment automation reducing manual effort."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT framework supports integration with external systems, including other DTs, enterprise resource planning (ERP) systems, and IoT platforms. This enables cross-domain data exchange and interoperability, enhancing the overall functionality of the DT ecosystem."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not explicitly detailed in the document. However, the framework emphasizes the importance of data governance and compliance with regulatory standards, suggesting considerations for data ownership and privacy are part of the deployment process."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework adheres to AECO-specific standards such as BIM and integrates with open-source tools like Eclipse Hono and Ditto. It also supports standardized extension points for modular service integration, ensuring interoperability and compliance with industry standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Not explicitly detailed in the document. However, the framework’s emphasis on real-time control and bidirectional communication implies the need for robust security measures to protect against cyber threats and ensure safe operation of physical systems."
]