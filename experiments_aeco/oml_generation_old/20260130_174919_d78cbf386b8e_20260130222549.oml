// C3: Physical sensing components
instance BIMEnrichedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors defined in the enriched BIM model by the Building Control Engineer; the Digital Twin extracts their semantic description and maintains a real‑time data stream for Facility Manager monitoring."
    DTDFVocab:producedData BuildingSensorDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmitted)
instance BuildingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BIMEnrichedSensor
]

// C10: Data generated from sensors
instance BuildingSensorData : DTDFVocab:Data [
    base:desc "Real‑time sensor measurements streamed from physical building sensors into the digital twin."
    DTDFVocab:fromData BuildingSensorDataTransmitted
    DTDFVocab:inputTo RealTimeSyncEnabler
]

// C11: Enabler that processes sensor data
instance RealTimeSyncEnabler : DTDFVocab:Enabler [
    base:desc "Platform component that ingests real‑time sensor streams, synchronizes physical state with the digital twin, and supplies data to higher‑level services."
    DTDFVocab:enables SimulationService, AnalysisService, OptimizationService
]

// C6: Services offered by the DT
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service delivering real‑time insights by modeling building behaviour."
    DTDFVocab:provides RealTimeInsight
]

instance AnalysisService : DTDFVocab:Service [
    base:desc "Analysis service delivering predictive analytics for building operation."
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service offering decision‑support and recommendations to improve building performance."
    DTDFVocab:provides DecisionSupportInsight
]

// C17: Insights provided by services
instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight presenting current sensor values via dashboards and immersive 3D visualizations."
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics insight forecasting future building states to aid proactive management."
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Decision‑support insight delivering actionable recommendations and enabling control commands."
]

// C2: Acting components (actuators)
instance BIMEnrichedActuator : DTDFVocab:ActingComponent [
    base:desc "Actuators modelled by the Building Control Engineer in the BIM environment; represented as executable control points that can be invoked remotely by the Facility Manager."
]

// C10: Model containing device definitions
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model that unifies geometric information with behavioral descriptors of sensors, actuators, and controllers."
    DTDFVocab:inputTo RealTimeSyncEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated in the digital twin are sent back to building actuators through the framework’s bidirectional communication channels. Runtime configuration management validates and applies these commands without requiring full redeployment, and the digital twin receives feedback confirming execution of the physical actions."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports a full DT lifecycle that begins with device modeling inside BIM (defining sensors, actuators, and controllers), proceeds to model‑driven engineering where structured representations are extracted via Model‑Driven Engineering (MDE), then automatic generation of deployable DT artifacts, followed by deployment and runtime operation with real‑time data exchange and interactive visualization, and finally evolution through modular extensions via standardized extension points. Lifecycle governance is implied by the model‑driven approach that maintains a single source of truth from BIM through to the running twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin system is built on a modular, service‑oriented architecture with standardized extension points that expose network interfaces for component interaction. This design supports interoperability across heterogeneous subsystems and scalability from single devices to whole infrastructure, while runtime configuration management allows dynamic adjustment of connections to maintain reliability."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework builds on Building Information Modeling (BIM), an established industry standard for representing building geometry and assets, and extends it by standardising BIM semantics for control system components (sensors, actuators, controllers). It introduces standardized extension points within its modular architecture to enable interoperable integration of custom services, analytics, and external tools. While no external certification schemes or specific interoperability standards (e.g., IFC, ISO 19650) are cited, the approach aligns with industry practice by using BIM as the canonical data source and providing a uniform, standards‑based integration layer for Digital Twin extensions."
]