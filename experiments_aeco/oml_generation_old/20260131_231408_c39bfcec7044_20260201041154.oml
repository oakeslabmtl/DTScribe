// C2: Acting Components
instance LightTwinComponent : DTDFVocab:ActingComponent [
  base:desc "Controls a UE5 light source using Revit photometric metadata; supports on/off toggling, brightness adjustment, and colour temperature changes driven by Ditto messages."
]

instance UnrealTwinController : DTDFVocab:ActingComponent [
  base:desc "Orchestrates actuation commands between the UE5 engine and DittoController via DittoConnection, validating commands against Ditto policy rules."
]

// C3: Physical sensing components (inferred from system)
instance BuildingTemperatureSensor : DTDFVocab:SensingComponent [
  base:desc "Temperature sensor embedded in the building control system for HVAC monitoring."
  DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
  DTDFVocab:producedFrom BuildingTemperatureSensor
]

// C10: Models/Data
instance BIMGeometryModel : DTDFVocab:Model [
  base:desc "Geometric representation extracted from BIM for spatial context."
  DTDFVocab:inputTo MDETransformationEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
  base:desc "Behavioral model of control logic defined by Building Control Engineers in BIM."
  DTDFVocab:inputTo MDETransformationEnabler
]

instance LiveSimulationModelUE5 : DTDFVocab:Model [
  base:desc "Dynamic DT artifacts generated for live simulation in Unreal Engine 5."
  DTDFVocab:inputTo MDETransformationEnabler
]

instance TemperatureData : DTDFVocab:Data [
  base:desc "Ambient temperature data stream processed from BuildingTemperatureSensor."
  DTDFVocab:fromData TemperatureDataTransmitted
  DTDFVocab:inputTo DittoEventStorageEnabler
]

// C11: Enablers
instance DittoEventStorageEnabler : DTDFVocab:Enabler [
  base:desc "Eclipse Ditto event storage and DittoConnection handling for persistent event streams."
  DTDFVocab:enables MonitoringService
]

instance HonoMqttEnabler : DTDFVocab:Enabler [
  base:desc "Eclipse Hono MQTT-like message bus enabling real‑time actuator command ingestion."
  DTDFVocab:enables ControlService
]

instance AnalyticsPluginEnabler : DTDFVocab:Enabler [
  base:desc "Custom analytics plugin enabling data‑driven optimization services."
  DTDFVocab:enables OptimizationService
]

instance PredictionEngineEnabler : DTDFVocab:Enabler [
  base:desc "Prediction engine enabling short‑term forecasting of system behavior."
  DTDFVocab:enables PredictionService
]

instance VisualizationLayerEnabler : DTDFVocab:Enabler [
  base:desc "Interactive visualization layer integrated with BIM for immersive 3D display."
  DTDFVocab:enables VisualizationService
]

instance MDETransformationEnabler : DTDFVocab:Enabler [
  base:desc "MDE tooling that transforms enriched BIM into deployable artifacts."
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
  base:desc "Monitoring service providing continuous real‑time readouts of building states."
  DTDFVocab:provides SystemStatusInsight
]

instance ControlService : DTDFVocab:Service [
  base:desc "Control service issuing closed‑loop commands to actuators and controllers."
  DTDFVocab:provides AdjustThermostatAction
]

instance OptimizationService : DTDFVocab:Service [
  base:desc "Optimization service for data‑driven tuning of HVAC and lighting schedules."
  DTDFVocab:provides HVACScheduleOptimizationInsight
]

instance PredictionService : DTDFVocab:Service [
  base:desc "Prediction service for short‑term forecasting of system behavior and failure modes."
  DTDFVocab:provides FailureModePredictionInsight
]

instance VisualizationService : DTDFVocab:Service [
  base:desc "Visualization service delivering immersive 3D displays of current status and simulation results."
  DTDFVocab:provides Immersive3DVisualizationAction
]

// C17: Insights/Actions
instance SystemStatusInsight : DTDFVocab:Insight [
  base:desc "Real‑time system status visualization for Facility Managers."
]

instance AdjustThermostatAction : DTDFVocab:Action [
  base:desc "Automatically adjust HVAC thermostat based on building temperature readings."
  DTDFVocab:IsAutomatic true
]

instance HVACScheduleOptimizationInsight : DTDFVocab:Insight [
  base:desc "Optimized HVAC scheduling insight derived from data‑driven analysis."
]

instance FailureModePredictionInsight : DTDFVocab:Insight [
  base:desc "Prediction of potential failure modes in building control systems."
]

instance Immersive3DVisualizationAction : DTDFVocab:Action [
  base:desc "Trigger immersive BIM‑based 3D visualization in Unreal Engine 5."
  DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time continuous synchronization between the physical building and its digital twin via continuous data exchange; latency requirements and temporal granularity are not specified in the provided documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is organized around a modular architecture with a central DT framework hub that mediates bidirectional data exchange. Roles such as Building Control Engineers (device modelling and deployment initiation), Facility Managers (real‑time monitoring and control), and DT Engineers (service integration) coordinate through standardized extension points, allowing the framework to incorporate custom services and analytics while maintaining a holistic lifecycle perspective from enriched BIM models to operational DTs."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a Digital‑Twin lifecycle that begins with Building Control Engineers enriching BIM models on which devices (sensors, actuators, controllers) and control logic are defined. Enriched BIM models are processed by a Model‑Driven Engineering (MDE) pipeline that extracts a semantic representation and automatically generates deployable Digital‑Twin artifacts (configuration bundles, runtime services) with minimal manual intervention. These artifacts are deployed into a runtime environment where the twin is synchronized with the physical building via real‑time data exchange. The framework’s modular architecture provides standardized extension points that allow DT Engineers to attach custom services, thereby enabling iterative evolution of the twin. Each lifecycle stage is clearly separated—modeling, transformation, deployment, runtime operation—to support governance and traceability."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validity is ensured by Eclipse Ditto’s policy‑based validation, which enforces sensor data ranges, units, and pre‑execution checks on actuator commands. Fault tolerance and data integrity are achieved through Hono’s at‑least‑once message delivery and Ditto’s persistent event storage, preserving message history across network failures. Validation processes include automatic checks during the conversion phase of enriched BIM models and runtime verification against defined policies, providing continuous assurance of data quality and model consistency."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework aligns with AECO‑centric BIM standards (Revit/IFC‑based BIM) for device and control logic definition. It adopts open telemetry standards for real‑time data exchange and leverages recognized open‑source Digital‑Twin platforms such as Eclipse Ditto and BaSyx to provide connectivity and standard compliance, thereby ensuring interoperability across heterogeneous building assets."
]