// C2: Acting Components
instance LEDLightingUnit : DTDFVocab:ActingComponent [
    base:desc "LED lighting unit with configurable on/off, dimming 0‑100%, and color temperature 2700‑6500 K"
]

instance HVACDamperActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC damper actuator controlling airflow to rooms"
]

instance ValveActuator : DTDFVocab:ActingComponent [
    base:desc "Valve actuator for controlling fluid flow within the building’s HVAC system"
]

// C3: Physical sensing components
instance LightingPhotometricSensor : DTDFVocab:SensingComponent [
    base:desc "Photometric sensors mounted on lighting fixtures measuring light intensity in lux"
    DTDFVocab:producedData LightingPhotometricTelemetry
]

instance OccupancyProbeSensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy probes installed in occupancy beds detecting presence"
    DTDFVocab:producedData OccupancyProbeTelemetry
]

// C4: Physical-to-virtual interaction
instance LightingPhotometricTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingPhotometricSensor
]

instance OccupancyProbeTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyProbeSensor
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing geometric, behavioral, and analytical metadata for the commercial building"
    DTDFVocab:inputTo MDETransformationEngineEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model extracted from BIM annotations describing device cybersecurity and control rules"
    DTDFVocab:inputTo MDETransformationEngineEnabler
]

instance LightingPhotometricData : DTDFVocab:Data [
    base:desc "Structured lux data stored in Ditto after MQTT reception via Eclipse Hono"
    DTDFVocab:inputTo EclipseDittoEnabler
    DTDFVocab:fromData LightingPhotometricTelemetry
]

instance OccupancyProbeData : DTDFVocab:Data [
    base:desc "Occupancy status data stored in Ditto after MQTT reception via Eclipse Hono"
    DTDFVocab:inputTo EclipseDittoEnabler
    DTDFVocab:fromData OccupancyProbeTelemetry
]

// C11: Enablers
instance MDETransformationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering engine validating and transforming enriched BIM into deployable artifacts"
    DTDFVocab:enables EclipseDittoEnabler, AnalyticsPluginSystemEnabler
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Ditto service enabling state persistence, policy validation, and event storage for telemetry data"
    DTDFVocab:enables BuildingMonitoringService, PredictiveAnalyticsService, ControlService, ImmersiveVisualizationService
]

instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT broker routing telemetry from sensors to Ditto"
    DTDFVocab:enables EclipseDittoEnabler
]

instance UE5UnrealTwinEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 module rendering the digital twin geometry via the UE5 TwinComponent"
    DTDFVocab:enables ImmersiveVisualizationService
]

instance AnalyticsPluginSystemEnabler : DTDFVocab:Enabler [
    base:desc "Plugin system hosting custom analytics services that can be injected by DT engineers"
    DTDFVocab:enables AnalyticsExtensionService
]

// C6: Services
instance BuildingMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring service exposing sensor dashboards and alerting facilities operators"
    DTDFVocab:provides LightingControlAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics engine executing classifiers for maintenance and energy optimization"
    DTDFVocab:provides PredictiveMaintenanceInsight, EnergyOptimizationInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Service enabling issuance of commands to HVAC, lighting, and other building actuators via Ditto"
    DTDFVocab:provides HVACControlAction, ActuatorCommandAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization service rendering 3D models and dashboards for situational awareness"
    DTDFVocab:provides RiskQuantificationInsight
]

instance AnalyticsExtensionService : DTDFVocab:Service [
    base:desc "Service that allows DT engineers to add specialized analytics modules to the twin"
    DTDFVocab:provides PredictiveMaintenanceInsight
]

// C17: Insights/Actions
instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Insight predicting maintenance needs with confidence scores derived from classifier performance"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight estimating energy cost savings from control adjustments and predictive actions"
]

instance RiskQuantificationInsight : DTDFVocab:Insight [
    base:desc "Insight providing risk quantification metrics for recommendation execution"
]

instance LightingControlAction : DTDFVocab:Action [
    base:desc "Action to set LED lighting unit on/off, dimming level (0‑100%), and color temperature (2700‑6500 K)"
    DTDFVocab:IsAutomatic true
]

instance HVACControlAction : DTDFVocab:Action [
    base:desc "Action to adjust HVAC dampers and valves based on sensor inputs via Ditto"
    DTDFVocab:IsAutomatic false
]

instance ActuatorCommandAction : DTDFVocab:Action [
    base:desc "Generic actuation command to any device actuator via Ditto, validated against safety policies"
    DTDFVocab:IsAutomatic false
]

// C18: Environment & Components
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains LEDLightingUnit, HVACDamperActuator, ValveActuator, LightingPhotometricSensor, OccupancyProbeSensor, EnrichedBIMModel, ControlLogicModel
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time bi‑directional data exchange is employed to keep the digital twin synchronized with its physical counterpart, enabling real‑time monitoring, control, and predictive analytics. The framework supports runtime re‑configuration of synchronization frequency to adapt to changing operational requirements, though specific latency thresholds or update intervals are not defined in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a modular, service‑oriented architecture centered around a DT Framework that serves as the central hub for bi‑directional data exchange. The framework exposes standardized extension points for integrating custom analytics and services, enabling dynamic scaling from single building components to whole‑infrastructure deployments. Roles such as Building Control Engineers, Facility Managers, and DT Engineers coordinate through this framework to manage device modeling, deployment, monitoring, and continuous configuration, thereby enhancing adaptability without requiring full redeployment."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Development lifecycle of the model‑driven DT framework proceeds in four key phases:
(1) BIM‑enrichment – the Building Control Engineer models sensors, actuators, and controllers within the BIM environment, yielding a semantically rich representation;
(2) MDE extraction – Model‑Driven Engineering principles automatically transform the enriched BIM into a structured digital representation (e.g., graph‑based or JSON schema) that preserves topology, control logic, and data flow;
(3) Artifact generation and deployment – the framework synthesizes deployable DT artefacts such as micro‑services, data pipelines, and visualization dashboards, through a minimal‑manual, template‑based pipeline;
(4) Runtime operation and evolution – real‑time data exchange (e.g., MQTT or WebSocket) synchronizes the twin with the physical building, while the modular architecture and standardized extension points allow the DT Engineer to inject custom analytics or control services.
Governance across these stages is codified by the defined stakeholder roles – Building Control Engineer (modeling), Facility Manager (monitoring & control), and DT Engineer (service extension)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is achieved by enriching BIM with exact device metadata (e.g. photometric values) and by applying Model‑Driven Engineering transformations that preserve semantic relationships between geometry, control logic, and physical capabilities. Verification is performed through Eclipse Ditto’s policy‑based validation layer, which enforces value ranges, units, and schema conformance prior to accepting sensor telemetry or actuator commands. Fault tolerance is provided by Hono’s at‑least‑once message delivery semantics and Ditto’s persistent event store, ensuring that network partitions or failures do not result in data loss. Safety constraints are embedded as pre‑execution checks on actuator command payloads, preventing conflicts or unsafe operations. While explicit uncertainty quantification or sampling‑frequency coverage is not documented, the architecture’s modular extension points allow for integration of analytics that could inject statistical quality‑assurance metrics into the twin’s state."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is accomplished via a set of standardized extension points within the DT Framework, which supports bidirectional data exchange and interoperability across heterogeneous built‑environment technologies. The framework enables modular integration of custom analytics and services, allowing seamless connection to external BIM tools, facility management software, and other Digital Twins or enterprise systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The documents explicitly note the absence of a defined compliance framework; there is no mention of specific industry standards (e.g., IFC, Industry Foundation Classes for BIM, or IIoT interoperability standards).
The framework’s reliance on generic MDE transformations and real‑time data exchange protocols suggests potential alignment with open standards, but the implementation details and certification requirements are not described."
]