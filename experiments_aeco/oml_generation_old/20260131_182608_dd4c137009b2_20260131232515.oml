    base:desc "Service providing decision support capabilities"
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service providing optimization capabilities"
]

instance AlertingService : DTDFVocab:Service [
    base:desc "Service providing alerting capabilities"
]

instance RuntimeArtifactGeneration : DTDFVocab:Service [
    base:desc "Service generating runtime artifacts from models"
]

instance ModelValidation : DTDFVocab:Service [
    base:desc "Service validating models for semantic consistency"
]

instance ServiceGeneration : DTDFVocab:Service [
    base:desc "Service generating service interfaces"
]

instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service handling data ingestion from sensors"
]

instance ControlSignalDistribution : DTDFVocab:Service [
    base:desc "Service distributing control signals to actuators"
]

instance DeviceConfigurationService : DTDFVocab:Service [
    base:desc "Service managing device configurations"
]

