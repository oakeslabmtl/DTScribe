// ======================
// Physical Sensing Components
// ======================

// Illumination sensor embedded in enriched BIM model
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor represented as a semantic object in the BIM extensions, capturing location and type for real‑time measurement of light levels"
    DTDFVocab:producedData IlluminationDataTx
]

// Energy consumption sensor embedded in enriched BIM model
instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Energy consumption sensor modeled in BIM, providing continuous readings of lighting power usage"
    DTDFVocab:producedData EnergyDataTx
]

// Environmental condition sensor embedded in enriched BIM model
instance EnvironmentalConditionSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental condition sensor (temperature, humidity) stored in BIM semantics for monitoring building ambient state"
    DTDFVocab:producedData EnvConditionDataTx
]

// ======================
// Data Transmitted (Physical → Virtual)
// ======================

instance IlluminationDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance EnergyDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance EnvConditionDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalConditionSensor
]

// ======================
// Virtual Data Objects
// ======================

instance IlluminationData : DTDFVocab:Data [
    base:desc "Real‑time illumination measurements streamed from physical sensors"
    DTDFVocab:fromData IlluminationDataTx
    DTDFVocab:inputTo EclipseHono, EclipseDitto, UnrealEngine
]

instance EnergyData : DTDFVocab:Data [
    base:desc "Live energy consumption readings of the lighting system"
    DTDFVocab:fromData EnergyDataTx
    DTDFVocab:inputTo EclipseHono, EclipseDitto, UnrealEngine
]

instance EnvConditionData : DTDFVocab:Data [
    base:desc "Current temperature and humidity values from environmental sensors"
    DTDFVocab:fromData EnvConditionDataTx
    DTDFVocab:inputTo EclipseHono, EclipseDitto, UnrealEngine
]

// ======================
// Acting Component (Physical → Virtual)
// ======================

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator defined in BIM extensions, enabling remote command of building lighting fixtures"
]

// ======================
// Enablers (Tooling & Infrastructure)
// ======================

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides secure, scalable IoT data ingestion from building lighting sensors"
    DTDFVocab:enables DataIngestionService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages the digital twin's state and offers a unified data API for control logic"
    DTDFVocab:enables LightingControlService, StateManagementService
]

instance UnrealEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine renders a photorealistic, interactive 3‑D visualisation of the building and its lighting"
    DTDFVocab:enables RealTimeVisualizationService
]

instance BIMModelingTool : DTDFVocab:Enabler [
    base:desc "Building Information Modeling (BIM) framework that stores geometric and semantic information for assets and devices"
    DTDFVocab:enables ModelTransformationService
]

// ======================
// Models & Data (MDE Transformations)
// ======================

instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM file containing geometry, sensor/actuator definitions, and behavioral extensions"
    DTDFVocab:inputTo EclipseDitto, UnrealEngine, BIMModelingTool
]

instance LightingControlBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model extracted from BIM that encodes control logic for lighting actuators"
    DTDFVocab:inputTo EclipseDitto
]

instance LightingPerformanceAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model derived from BIM used for performance rules, forecasting and optimisation"
    DTDFVocab:inputTo OptimizationService
]

// ======================
// Services (Digital Twin Functionality)
// ======================

instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service that ingests real‑time sensor streams via Eclipse Hono"
    DTDFVocab:provides RealTimeStateInsight
]

instance LightingControlService : DTDFVocab:Service [
    base:desc "Service exposing control APIs through Eclipse Ditto to command lighting actuators"
    DTDFVocab:provides CommandLightingActuator
]

instance StateManagementService : DTDFVocab:Service [
    base:desc "Service that maintains the current digital twin state and synchronises it with physical devices"
    DTDFVocab:provides RealTimeStateInsight
]

instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualisation service powered by Unreal Engine for monitoring and interaction"
    DTDFVocab:provides RealTimeStateInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service that uses the behavioral model to predict lighting behaviour under scenarios"
    DTDFVocab:provides SimulationInsight
]

instance AnalysisService : DTDFVocab:Service [
    base:desc "Analytical service that evaluates performance metrics using the analytical model"
    DTDFVocab:provides PerformanceAnalysisInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that runs algorithms on the analytical model to improve energy efficiency"
    DTDFVocab:provides OptimizationAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service forecasting future lighting performance"
    DTDFVocab:provides PredictivePerformanceInsight
]

instance ModelTransformationService : DTDFVocab:Service [
    base:desc "MDE transformation service that converts enriched BIM semantics into deployable DT artifacts"
    DTDFVocab:provides SimulationInsight, PerformanceAnalysisInsight
]

// ======================
// Insights & Actions (Decision Support)
// ======================

instance RealTimeStateInsight : DTDFVocab:Insight [
    base:desc "Up‑to‑date state information delivered to Facility Managers for monitoring and decision making"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Results of lighting system simulations used for design evaluation"
]

instance PerformanceAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analytical insight on energy consumption and illumination quality"
]

instance PredictivePerformanceInsight : DTDFVocab:Insight [
    base:desc "Forecast of future lighting performance supporting proactive maintenance"
]

instance CommandLightingActuator : DTDFVocab:Action [
    base:desc "Remote command issued by Facility Managers to activate or dim lighting actuators"
    DTDFVocab:IsAutomatic false
]

instance OptimizationAction : DTDFVocab:Action [
    base:desc "Automated adjustment of lighting schedules to optimise energy usage"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Through the same bidirectional data‑exchange hub, the Digital Twin can emit control signals back to the building control systems, enabling Facility Managers to monitor and adjust building operations from the virtual environment. Control commands are sent from the DT to physical actuators or control interfaces, though the document does not detail command formats, validation, or acknowledgment mechanisms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates in a real‑time mode, continuously ingesting sensor streams and updating the virtual model as soon as new measurements arrive. Synchronisation between the physical asset and its digital counterpart is performed with low latency to support live monitoring and fast feedback loops, although exact update frequencies are not quantified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a model‑driven framework that orchestrates a modular, service‑oriented DT platform. Standardised extension points expose reusable services that can be composed to form the full twin, and coordinated roles (e.g., data acquisition, model execution, analytics, and visualisation) are mapped to distinct system components. Resource management is handled centrally within the framework to ensure scalable deployment across heterogeneous infrastructure."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports the full Digital Twin life‑cycle, starting with device‑modeling within the BIM environment where sensors, actuators and controllers are defined (semantic enrichment of BIM). The enriched BIM model is then processed by Model‑Driven Engineering (MDE) transformations that extract a structured representation (domain model) and automatically generate deployable DT artefacts (runtime services, data‑exchange interfaces). After deployment, a runtime phase provides continuous real‑time data exchange and interactive visualisation for operation monitoring and control. Subsequent phases allow the integration of custom services via standardized extension points, enabling evolutionary updates. Transition between phases is orchestrated automatically by the MDE pipeline, and lifecycle governance is enforced by the functional requirement set (F_X) and the modular architecture that prescribes representation types and hand‑off rules."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution addresses the lack of standard integration by defining a modeling methodology that standardises BIM semantics for building control systems and by exposing standardized extension points for custom services. These extension points follow a common interface specification, enabling interoperability between the DT core and third‑party analytics or control plugins. The framework’s modular architecture and functional requirement set (F_X) provide a compliance framework that enforces consistent use of the standardised BIM extensions across the deployment lifecycle."
]