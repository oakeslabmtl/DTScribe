// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in lighting fixture, instrumented via on‑board IoT node"
    DTDFVocab:producedData OccupancySensorData
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor embedded in LED fixture, measuring light intensity using spectrometer"
    DTDFVocab:producedData IlluminanceSensorData
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in HVAC unit, measuring room temperature via thermistor"
    DTDFVocab:producedData TemperatureSensorData
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor embedded in HVAC unit, measuring relative humidity via capacitive sensor"
    DTDFVocab:producedData HumiditySensorData
]

instance PowerMeter : DTDFVocab:SensingComponent [
    base:desc "Power meter embedded in electrical distribution panel, monitoring instantaneous power draw of lighting and HVAC"
    DTDFVocab:producedData PowerMeterData
]

// C2: Acting components
instance LightingDimmer : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator controlling LED fixture brightness, connected via BACnet gateway"
]

instance LEDFixture : DTDFVocab:ActingComponent [
    base:desc "LED lighting fixture with dimmable LEDs, controlled by LightingDimmer"
]

instance HVACVentilationDamper : DTDFVocab:ActingComponent [
    base:desc "Ventilation damper actuator adjusting airflow, controlled by HVACFanSpeedControl"
]

instance HVACFanSpeedControl : DTDFVocab:ActingComponent [
    base:desc "HVAC fan speed controller, variable frequency drive governing fan RPM"
]

instance BACnetGateway : DTDFVocab:ActingComponent [
    base:desc "BACnet gateway translating proprietary protocols to BACnet/IP for building automation"
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance OccupancySensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminanceSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]

instance TemperatureSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumiditySensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance PowerMeterData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerMeter
]

// C5: Data (live sensor streams)
instance OccupancySensorDataStream : DTDFVocab:Data [
    base:desc "Live occupancy telemetry streamed to the platform"
    DTDFVocab:fromData OccupancySensorData
    DTDFVocab:inputTo EclipseHono
]

instance IlluminanceSensorDataStream : DTDFVocab:Data [
    base:desc "Live illuminance telemetry streamed to the platform"
    DTDFVocab:fromData IlluminanceSensorData
    DTDFVocab:inputTo EclipseHono
]

instance TemperatureSensorDataStream : DTDFVocab:Data [
    base:desc "Live temperature telemetry streamed to the platform"
    DTDFVocab:fromData TemperatureSensorData
    DTDFVocab:inputTo EclipseHono
]

instance HumiditySensorDataStream : DTDFVocab:Data [
    base:desc "Live humidity telemetry streamed to the platform"
    DTDFVocab:fromData HumiditySensorData
    DTDFVocab:inputTo EclipseHono
]

instance PowerMeterDataStream : DTDFVocab:Data [
    base:desc "Live power consumption telemetry streamed to the platform"
    DTDFVocab:fromData PowerMeterData
    DTDFVocab:inputTo EclipseHono
]

// C10: Models/Data
instance BIM3DModelIFC : DTDFVocab:Model [
    base:desc "BIM 3D model in IFC format with embedded device metadata (tenant, device ID, Hono endpoint)"
    DTDFVocab:inputTo ModelToModelTransformEngine
]

instance AugmentedControlLogicSemantics : DTDFVocab:Data [
    base:desc "Ontology‑based semantics for control logic, embedded in augmented BIM model"
    DTDFVocab:inputTo EclipseDitto
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT middleware for real‑time telemetry ingestion"
    DTDFVocab:enables EclipseDitto
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin platform that stores and serves twin data"
    DTDFVocab:enables LiveMonitoringDashboard, VisualizationUnrealEngine5, PredictiveAnalyticsLightingRL,
    AutomatedCommissioning, EventDrivenSimulation, RealTimeStatusReporting, FaultDetection
]

instance DittoConfigurator : DTDFVocab:Enabler [
    base:desc "Ditto Configurator used to auto‑generate twin definitions and runtime interfaces"
    DTDFVocab:enables EclipseDitto
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 interactive rendering engine for visualization"
    DTDFVocab:enables VisualizationUnrealEngine5
]

instance ModelToModelTransformEngine : DTDFVocab:Enabler [
    base:desc "Model‑to‑model transformation engine that enriches BIM with device metadata"
    DTDFVocab:enables DittoConfigurator
]

instance BIMAuthoringRevit : DTDFVocab:Enabler [
    base:desc "BIM authoring tool (Revit) used to import and edit IFC models"
    DTDFVocab:inputTo ModelToModelTransformEngine
]

// C6: Services
instance LiveMonitoringDashboard : DTDFVocab:Service [
    base:desc "Live monitoring dashboard displaying real‑time telemetry and fault indicators"
    DTDFVocab:provides OccupancyHeatMap, EnergyUseHeatMap
]

instance VisualizationUnrealEngine5 : DTDFVocab:Service [
    base:desc "Unreal Engine 5 visualization of building model with real‑time data overlay"
    DTDFVocab:provides OccupancyHeatMap
]

instance PredictiveAnalyticsLightingRL : DTDFVocab:Service [
    base:desc "Predictive analytics for lighting optimization using reinforcement learning"
    DTDFVocab:provides LightingScheduleRecommendation, EnergySavingRecommendation
]

instance AutomatedCommissioning : DTDFVocab:Service [
    base:desc "Automated commissioning service that adjusts HVAC and lighting settings based on sensor data"
    DTDFVocab:provides CommissioningPlanRecommendation
]

instance EventDrivenSimulation : DTDFVocab:Service [
    base:desc "Event‑driven simulation of building performance in real time"
    DTDFVocab:provides SimulationResultInsight
]

instance RealTimeStatusReporting : DTDFVocab:Service [
    base:desc "Real‑time status reporting of component health and operational metrics"
    DTDFVocab:provides RealtimeStatusInsight
]

instance FaultDetection : DTDFVocab:Service [
    base:desc "Fault detection service that identifies abnormal patterns in sensor telemetry"
    DTDFVocab:provides FaultDetectionInsight
]

// C17: Insights
instance OccupancyHeatMap : DTDFVocab:Insight [
    base:desc "Heat map visualizing occupancy distribution across the building"
]

instance EnergyUseHeatMap : DTDFVocab:Insight [
    base:desc "Heat map depicting energy usage per zone in real time"
]

instance LightingScheduleRecommendation : DTDFVocab:Insight [
    base:desc "Recommended lighting schedule adjustments for energy savings"
]

instance HVACSetpointRecommendation : DTDFVocab:Insight [
    base:desc "Recommended HVAC setpoint adjustments to improve comfort and efficiency"
]

instance CommissioningPlanRecommendation : DTDFVocab:Insight [
    base:desc "Suggested commissioning plan updates based on current telemetry"
]

instance EnergySavingRecommendation : DTDFVocab:Insight [
    base:desc "Aggregate energy‑saving recommendations derived from predictive analytics"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Insights generated from event‑driven simulation of building performance"
]

instance RealtimeStatusInsight : DTDFVocab:Insight [
    base:desc "Real‑time status insights for building automation components"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detected fault indicators and root cause analysis"
]

// C17: Actions
instance AdjustLightingSchedule : DTDFVocab:Action [
    base:desc "Automatically adjust lighting schedules based on occupancy and RL optimization"
    DTDFVocab:IsAutomatic true
]

instance AdjustHVACSetpoint : DTDFVocab:Action [
    base:desc "Automatically adjust HVAC setpoints to maintain comfort targets"
    DTDFVocab:IsAutomatic true
]

instance AdjustCommissioningPlan : DTDFVocab:Action [
    base:desc "Update commissioning plan to reflect current building performance data"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated from the virtual twin (e.g., dimming level, fan speed) are sent back to devices through Ditto’s event channels over MQTT, routed via Hono to the building control system"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous synchronization with sub‑second to 1 s update intervals; event‑driven changes reflected within milliseconds; historical archival for daily/weekly logs"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Central DT hub orchestrating communication between individual component twins via Ditto; service‑oriented architecture with modular extension points for custom analytics services; integrated visualization console"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design‑time (BIM model), manufactured‑time (as‑built BIM enrichment with device metadata), operational‑time (runtime twin running in the field)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric used to quantify alignment between virtual twin and physical counterpart; semantic drift mitigation via synchronization rules; formal validation of sensor data against BIM constraints"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication via MQTT over TLS, utilizing Eclipse Hono as the MQTT broker and Ditto as the twin data store; Hono routes messages to/from specific device endpoints; Ditto exposes REST and WebSocket APIs for twin state retrieval"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Built upon the IFC/BIM standard for building models, MQTT and JSON for data exchange, and the Open Interconnect Architecture via Eclipse Ditto; framework provides extension points aligned with ISO 16739 for BIM content"
]