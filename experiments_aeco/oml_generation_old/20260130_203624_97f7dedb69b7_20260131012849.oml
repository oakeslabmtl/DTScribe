// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in BIM and exposed to the twin for command execution."
]

instance BuildingControlController : DTDFVocab:ActingComponent [
    base:desc "Building control system controller modeled in BIM and exposed to the twin for command execution."
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM and supplying post‑occupancy data to the twin."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor modeled in BIM and supplying post‑occupancy data to the twin."
    DTDFVocab:producedData IlluminanceDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor (e.g., temperature, humidity) modeled in BIM and supplying post‑occupancy data to the twin."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C10: Data (runtime sensor streams)
instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy data stream from the physical building."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

instance IlluminanceData : DTDFVocab:Data [
    base:desc "Real‑time illuminance data stream from the physical building."
    DTDFVocab:fromData IlluminanceDataTransmitted
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Real‑time environmental data stream (temperature, humidity) from the physical building."
    DTDFVocab:fromData EnvironmentalDataTransmitted
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

// C10: Models (static and generated)
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Static BIM geometry model generated from enriched BIM models."
    DTDFVocab:inputTo BuildingInformationModeling
]

instance BIMSemanticModel : DTDFVocab:Model [
    base:desc "Static BIM semantic data model describing building elements and attributes."
    DTDFVocab:inputTo BuildingInformationModeling
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic model for building automation, produced via model‑to‑text transformations."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance RuntimeArtifactModel : DTDFVocab:Model [
    base:desc "Generated runtime artifacts (code, configuration files) produced via model‑to‑text transformations."
    DTDFVocab:inputTo AutomatedConfigurator
]

// C11: Enablers (tooling & pipelines)
instance BuildingInformationModeling : DTDFVocab:Enabler [
    base:desc "Building Information Modeling (BIM) platform used to enrich and serve static geometry and semantic models."
    DTDFVocab:enables BuildingPerformanceSimulation
]

instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline that transforms models into executable artifacts."
    DTDFVocab:enables EnergyEfficiencyOptimization
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware that streams sensor readings from physical assets to the digital twin."
    DTDFVocab:enables RealTimeMonitoringDashboard
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto service that ingests and represents real‑time data within the digital twin."
    DTDFVocab:enables RealTimeMonitoringDashboard
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 used for high‑fidelity 3D interactive visualization of the building twin."
    DTDFVocab:enables Interactive3DVisualization
]

instance AutomatedConfigurator : DTDFVocab:Enabler [
    base:desc "Automated configurator that scans BIM for twinnable devices and generates runtime configuration files."
    DTDFVocab:enables VisualComfortTaskPlanning, BuildingPerformanceSimulation
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard delivering live status of building systems."
    DTDFVocab:provides RealTimeStatusInsight
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "3D interactive visualization of the building twin within Unreal Engine 5."
    DTDFVocab:provides VisualComfortInsight
]

instance EnergyEfficiencyOptimization : DTDFVocab:Service [
    base:desc "Energy‑efficiency optimization service that analyses sensor data and issues control recommendations."
    DTDFVocab:provides EnergyConsumptionInsight, AutomatedLightingControlAction
]

instance VisualComfortTaskPlanning : DTDFVocab:Service [
    base:desc "Task‑planning service that generates lighting comfort recommendations."
    DTDFVocab:provides LightingComfortInsight
]

instance BuildingPerformanceSimulation : DTDFVocab:Service [
    base:desc "Simulation service that evaluates building performance using static BIM models."
    DTDFVocab:provides PerformanceSimulationInsight
]

// C17: Insights
instance RealTimeStatusInsight : DTDFVocab:Insight [
    base:desc "Provides facility managers with real‑time status of building systems."
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Delivers insights into current energy consumption and potential savings."
]

instance LightingComfortInsight : DTDFVocab:Insight [
    base:desc "Recommends lighting settings to achieve visual comfort while minimizing energy use."
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Shows occupants a visual representation of lighting comfort levels in the 3D environment."
]

instance PerformanceSimulationInsight : DTDFVocab:Insight [
    base:desc "Presents results of building performance simulations for analysis and decision support."
]

// C17: Actions
instance AutomatedLightingControlAction : DTDFVocab:Action [
    base:desc "Executes automated lighting control commands based on optimization recommendations."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points) are sent back through Ditto to Hono, which routes them to the physical actuators, enabling bidirectional communication between virtual and physical layers."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization between physical sensors/actuators and the twin, enabling up‑to‑date state monitoring and immediate actuation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where an enriched BIM model feeds a configurator that produces device metadata, which is consumed by Hono/Ditto for bidirectional communication; the twin state is visualized in Unreal Engine and extended via standardized extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the full building lifecycle: design (BIM authoring), construction (model validation and deployment), and operation (real‑time monitoring, control, and post‑occupancy optimization)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation before deployment and evaluation of twin‑physical alignment using the Overall Digital Twin Entanglement (ODTE) metric to assess fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono acts as the IoT gateway collecting sensor data, while Eclipse Ditto stores the twin state and mediates bidirectional communication, together providing real‑time data exchange between the physical building and its digital counterpart."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Leverages BIM as a standardized data model and conforms to industry‑wide AECO standards; the framework defines standardized extension points for interoperable service integration."
]