// C2: Acting Components
instance LEDLightActuator : DTDFVocab:ActingComponent [
    base:desc "Controls individual LED lighting fixtures defined in the BIM, exposing on/off, 0–100% brightness, and 2700–6500 K color temperature through UE5 delegates."
]
instance HVACFanActuator : DTDFVocab:ActingComponent [
    base:desc "Operates HVAC fan speed and state in accordance with control logic defined in BuildingControlLogicModel and executed via Eclipse Ditto."
]

// C3: Physical sensing components
instance LEDLightStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors the on/off state, brightness level, and color temperature of LED lighting fixtures in real time."
    DTDFVocab:producedData LEDLightStatusData
]
instance HVACTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors ambient temperature within occupied zones to inform HVAC control decisions."
    DTDFVocab:producedData HVACTempData
]

// C4: Physical-to-virtual interaction
instance LEDLightStatusData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LEDLightStatusSensor
]
instance HVACTempData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACTemperatureSensor
]

// C10: Models/Data
instance LEDLightTelemetry : DTDFVocab:Data [
    base:desc "Telemetry stream from LED lighting actuators, containing on/off state, brightness, and color temperature."
    DTDFVocab:fromData LEDLightStatusData
]
instance HVACTemperatureTelemetry : DTDFVocab:Data [
    base:desc "Telemetry data from HVAC temperature sensors for real‑time HVAC control."
    DTDFVocab:fromData HVACTempData
]
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Enriched IFC/BIM representation of building geometry and embedded device metadata."
    DTDFVocab:inputTo DittoEntityEnabler
]
instance BuildingControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model capturing control logic for lighting and HVAC, implemented as UE5 component scripts (LightTwinComponent)."
    DTDFVocab:inputTo UE5ScriptEnabler
]
instance IFCtoTwinConversionModel : DTDFVocab:Model [
    base:desc "Conversion component that validates enriched IFC/BIM data and exposes structured Twin objects via Eclipse Ditto."
    DTDFVocab:inputTo DittoEntityEnabler
]

// C11: Enablers
instance DittoEntityEnabler : DTDFVocab:Enabler [
    base:desc "Enables communication with Eclipse Ditto for persistence, policy validation, and real‑time command routing."
    DTDFVocab:enables RealTimeMonitoringService, DirectControlService
]
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Facilitates bi‑directional message flow for telemetry and command operations via Eclipse Hono."
    DTDFVocab:enables PredictiveAnalyticsService, ControlOptimizationService
]
instance UE5ScriptEnabler : DTDFVocab:Enabler [
    base:desc "Hosts UE5 component scripts (e.g., LightTwinComponent) that consume telemetry and expose control interfaces."
    DTDFVocab:enables ImmersiveVisualizationService
]
instance AnalyticsPluginEnabler : DTDFVocab:Enabler [
    base:desc "Provides extension points for DT Engineers to integrate custom analytics plugins."
    DTDFVocab:enables PredictiveAnalyticsService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building state and immediate VM‑BIM synchronization."
    DTDFVocab:provides RealTimeInsight
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy consumption and fault detection based on synchronized telemetry."
    DTDFVocab:provides FaultPredictionInsight, EnergyEfficiencyInsight
]
instance ControlOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes control strategies for HVAC and lighting schedules to reduce operational cost."
    DTDFVocab:provides OptimizeHVACScheduleAction
]
instance DirectControlService : DTDFVocab:Service [
    base:desc "Direct, policy‑validated control of building subsystems via Eclipse Ditto."
    DTDFVocab:provides ControlActuationAction
]
instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization of current building state and control scenarios within Unreal Engine 5."
    DTDFVocab:provides VisualizationInsight
]

// C17: Insights and Actions
instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Immediate visibility of building state for Facility Managers through dashboards."
]
instance FaultPredictionInsight : DTDFVocab:Insight [
    base:desc "Anticipated faults derived from predictive analytics, prompting proactive maintenance."
]
instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Operational insights that identify energy‑saving opportunities during real‑time monitoring."
]
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time 3D visual representation of building state for stakeholder engagement."
]
instance ControlActuationAction : DTDFVocab:Action [
    base:desc "Remote command to actuators, validated by Ditto policies before execution."
    DTDFVocab:IsAutomatic false
]
instance OptimizeHVACScheduleAction : DTDFVocab:Action [
    base:desc "Automated optimization of HVAC schedules based on predictive models."
    DTDFVocab:IsAutomatic true
]

// Environment and Components
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains BuildingControlLogicModel, BIMGeometricModel
]
instance LEDLightingFixture : DTDFVocab:Component [
    base:desc "Building asset representing a single LED lighting fixture equipped with sensors and actors."
]
instance HVACSystem : DTDFVocab:Component [
    base:desc "HVAC subsystem including actuators, sensors, and control logic modeled in BIM."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time data exchange between physical buildings and their digital counterparts is supported; the architecture is designed to synchronize data in real time, but exact synchronization frequencies, latency limits, or temporal granularity are not specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a modular architecture with a central DT Framework hub that orchestrates bidirectional data exchange.  The framework provides standardized extension points that allow DT engineers to integrate custom services and analytics, supporting runtime configuration management to adapt without full redeployment.  This approach enables low‑overhead updates and scalable resource management across the system."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin life‑cycle is organized into four sequential stages. 1) **Device Modeling Stage** – Building Control Engineers enrich BIM models with detailed definitions of sensors, actuators and controllers to represent Building Control System (BCS) components, producing an enriched BIM representation that encodes both design intent and device attributes. 2) **Transformation & Deployment Stage** – The framework applies Model‑Driven Engineering (MDE) principles to extract structured artefacts from the enriched BIM, automatically generating deployable DT components (data models, configuration files, service definitions) with minimal manual intervention, thereby ensuring coherence between BIM and twin artefacts. 3) **Runtime Synchronization Stage** – Real‑time data exchange protocols continuously synchronize the physical building with the Digital Twin; interactive visualization dashboards provide immersive interfaces for monitoring and control, ensuring up‑to‑date state representation. 4) **Custom Service & Extension Stage** – DT Engineers integrate custom services and analytics through standardized extension points within the modular architecture, allowing incremental evolution of the twin’s functionality. Transition management is effected by the automated MDE pipeline that maps BIM revisions to twin artefacts, while governance is enforced through role‑based access (Building Control Engineer, Facility Manager, DT Engineer) and the modular architecture that preserves lifecycle integrity."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by synchronizing the Digital Twin with the physical building through Eclipse Hono’s at‑least‑once message delivery and Ditto’s persistent event store, guaranteeing that state transitions are eventually reflected in both realms. Verification is performed at several layers: (1) the conversion component validates the BIM syntax and semantically checks device configurations; (2) Ditto policy engine validates incoming telemetry against declared ranges and units, rejecting out‑of‑spec values; (3) pre‑execution checks for actuator commands prevent unsafe or conflicting operations. Uncertainty sources such as sensor noise, transmission latency, and modeling abstraction are mitigated by applying unit validation, bounds enforcement, and event persistence. Fault tolerance is handled by retry mechanisms inherent in Hono’s delivery guarantee and Ditto’s durable storage, ensuring resilience against network disruptions. Quality assurance is baked into the deployment workflow: every enriched model is automatically generated, validated, and archived, providing traceability from BIM to runtime Twin representation."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External integration is achieved through standardized extension points that expose APIs for custom services and analytics, enabling interoperability across heterogeneous enterprise systems.  The architecture supports integration patterns that connect the DT Framework to external data sources and services, facilitating bidirectional communication, though specific protocols or data formats are not detailed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The Digital Twin is grounded in Building Information Modeling (BIM) as the primary data schema, ensuring compliance with BIM standards for device representation. It employs a modular architecture with standardized extension points designed for interoperability with external services, implying alignment with generic interoperability frameworks. The documents reference open‑source DT frameworks such as Eclipse Ditto and BaSyx, which are known to support standard‑compliant connectivity and data schemas, though the specific industry certifications, communication protocols (e.g., OPC UA, MQTT), or compliance frameworks are not enumerated in the provided documents."
]