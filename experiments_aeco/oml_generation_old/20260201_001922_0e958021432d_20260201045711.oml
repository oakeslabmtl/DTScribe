// Acting Components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Bridges a physical lighting device to a UE5 light actor, receiving command events via Ditto to control state (on/off), brightness and colour temperature (Kelvin), with control ranges derived from Revit photometric metadata."
]

instance HVACTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Intended to represent HVAC controllers following a publish/subscribe pattern via Eclipse Hono/Ditto, yet to be instantiated."
]

// Physical Sensing Components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting illumination sensor defined in the enriched BIM model, used to transmit illumination states to the digital twin."
    DTDFVocab:producedData LightingDataTransmitted
]

instance HVACAirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "HVAC air quality sensor defined in the enriched BIM model for monitoring indoor air quality."
    DTDFVocab:producedData HVACAirQualityDataTransmitted
]

// Physical-to-Virtual Interaction (DataTransmission)
instance LightingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance HVACAirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACAirQualitySensor
]

// Telemetry Data
instance LightingData : DTDFVocab:Data [
    base:desc "Illumination telemetry of building lights streamed to Ditto via Eclipse Hono."
    DTDFVocab:fromData LightingDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance HVACAirQualityData : DTDFVocab:Data [
    base:desc "Indoor air quality telemetry for HVAC control streamed to Ditto via Eclipse Hono."
    DTDFVocab:fromData HVACAirQualityDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// Model
instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model embedding devices, sensors, actuators and control logic for the living lab building."
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Allows ingestion of sensor telemetry via Eclipse Hono messaging middleware and forwards to Ditto."
    DTDFVocab:enables DataIngestionService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Enables bidirectional data transport and twin update flows within Ditto, reconciling sensor data with twin models."
    DTDFVocab:enables TwinUpdateService, HostingService, MonitoringService, ControlService, VisualizationService, PredictiveAnalyticsService, OptimizationService
]

// Supporting Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service responsible for ingesting sensor data via Eclipse Hono."
    DTDFVocab:provides DataIngestionInsight
]

instance TwinUpdateService : DTDFVocab:Service [
    base:desc "Reconciles incoming telemetry with digital twin model and persists state."
    DTDFVocab:provides TwinUpdateInsight
]

instance HostingService : DTDFVocab:Service [
    base:desc "Deploys and manages digital twin runtime instances."
    DTDFVocab:provides HostingStatusInsight
]

// Core Digital Twin Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time ingestion and display of sensor telemetry in live dashboards."
    DTDFVocab:provides EnergyConsumptionInsight, ComfortLevelInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Remote actuation of building subsystems such as lights and HVAC through a unified interface."
    DTDFVocab:provides ExecuteLightingCommandAction, ExecuteHVACCommandAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3‑D or dashboard representations of building state and simulation scenarios."
    DTDFVocab:provides VisualRepresentationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Forecasts building energy use, environmental comfort or equipment reliability based on historical data."
    DTDFVocab:provides EnergyForecastInsight, ComfortForecastInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Model‑driven recommendation of operating schedules or retrofit solutions."
    DTDFVocab:provides OperationScheduleInsight, RetrofitRecommendationInsight
]

// Insights
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Displays real‑time building energy usage derived from sensor telemetry."
]

instance ComfortLevelInsight : DTDFVocab:Insight [
    base:desc "Shows indoor comfort metrics derived from sensor data such as temperature and humidity."
]

instance EnergyForecastInsight : DTDFVocab:Insight [
    base:desc "Predicts future energy consumption based on historical telemetry."
]

instance ComfortForecastInsight : DTDFVocab:Insight [
    base:desc "Predicts future indoor comfort levels based on historical data."
]

instance OperationScheduleInsight : DTDFVocab:Insight [
    base:desc "Recommends optimized operating schedules for building subsystems."
]

instance RetrofitRecommendationInsight : DTDFVocab:Insight [
    base:desc "Suggests retrofit solutions to improve performance or cost."
]

instance VisualRepresentationInsight : DTDFVocab:Insight [
    base:desc "Displays 3‑D visual representation of the building state and simulation scenarios."
]

instance TwinUpdateInsight : DTDFVocab:Insight [
    base:desc "Shows status of twin reconciliation process."
]

instance HostingStatusInsight : DTDFVocab:Insight [
    base:desc "Reports health and version of the hosted digital twin instance."
]

instance DataIngestionInsight : DTDFVocab:Insight [
    base:desc "Indicates successful ingestion of sensor telemetry into Ditto."
]

// Actions
instance ExecuteLightingCommandAction : DTDFVocab:Action [
    base:desc "Command to adjust lighting state, brightness and colour temperature via Ditto."
    DTDFVocab:IsAutomatic false
]

instance ExecuteHVACCommandAction : DTDFVocab:Action [
    base:desc "Command to modify HVAC settings such as temperature setpoint or fan speed via Ditto."
    DTDFVocab:IsAutomatic false
]

// Environment
instance LivingLabEnvironment : DTDFVocab:Environment [
    base:contains LightingSensor, HVACAirQualitySensor, LightTwinComponent, HVACTwinComponent, BuildingBIMModel, EclipseHonoEnabler, EclipseDittoEnabler, MonitoringService, ControlService, VisualizationService, PredictiveAnalyticsService, OptimizationService
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin operates on a real‑time data‑exchange loop that continuously synchronises states between the physical building and its virtual counterpart. The framework delivers real‑time monitoring and control, with the data exchange layer guaranteeing immediate propagation of sensor updates and actuator commands across the twin. No fixed periodicity is imposed; the system reacts to incoming messages as they arrive, ensuring tight temporal coupling."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a hub‑and‑spoke design in which a central DT hub orchestrates data flow, state management, and service registration. Enriched BIM models are processed through model‑driven engineering (MDE) to automatically generate deployable DT artefacts. The architecture exposes modular extension points for analytics, control logic, and third‑party services, while runtime configuration management enables adaptation without full redeployment, ensuring coherent system‑wide coordination."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin lifecycle begins with the BIM‑enriched modeling phase in which Building Control Engineers embed sensor, actuator, and controller definitions directly into the BIM model. A model‑driven engineering (MDE) engine then automatically extracts the enriched BIM and transforms it into a semantically annotated, deployable artifact that is immediately pushed to the DT infrastructure. Deployment is automated via a reproducible pipeline (R2), requiring minimal manual intervention and enabling rapid provisioning of the runtime Twin. At runtime the Twin receives continuous real‑time telemetry through the Eclipse Hono/Ditto integration (R3), maintaining a live, synchronized state with the physical building. The Twin is subsequently monitored and visualized through immersive dashboards, with control logic and custom services updated through the modular, extension‑point architecture (R4). The transition between the model and runtime stages is managed by the MDE extraction pipeline, which can re‑run whenever the BIM model changes, ensuring gated governance of changes."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The synchronization quality between the Digital Twin and the physical system is quantified using the Overall Digital Twin Entanglement (ODTE) metric. ODTE is defined as the product of three components: Timeliness, Reliability, and Availability. In the reported living‑lab experiment, Timeliness was 0.997—measured as the delay between a physical change and its Twin update—Reliability was 1.0—the ratio of successfully received state updates to expected updates—and Availability was 1.0, indicating 100% uptime of the physical counterpart. The resulting ODTE score was 0.997, computed over a 12‑minute continuous measurement window with a 1‑second heartbeat cadence. These metrics demonstrate near‑ideal entanglement and are supported by Eclipse Hono’s at‑least‑once delivery semantics and Ditto’s persistent event storage, which mitigate message loss and support fault tolerance."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external enterprise systems is achieved through open, industry‑standard protocols and adapters. The framework exposes Zigbee, OPC‑UA, and MQTT connectors to capture low‑level physical data, while higher‑level events are forwarded to external BIM repositories via 3D IFC/IFC‑XML over HTTPS. Interoperability with other Digital Twins—such as those implemented with Eclipse Ditto—occurs through a shared message bus (Eclipse Hono) that routes event streams using JSON payloads conforming to the OCF/CoAP schema. Corporate enterprise resource planning (ERP) or facility management software can hook into the platform via REST/GraphQL endpoints for analytics or control commands. The integration pattern is primarily a publish/subscribe bus for real‑time data, coupled with RESTful CRUD interfaces for configuration and historical data access."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT framework integrates open‑source component stacks such as Eclipse Ditto and BaSyx, both of which provide standardized data models and connectivity interfaces for device registry and telemetry. The modular architecture exposes well‑defined extension points, enabling interoperability with BIM via generic IFC‑based semantic annotations and allowing custom plugins to conform to industry‑wide data schemas. The documented gaps in standardized data schemas and integration frameworks highlighted in related work underscore the framework’s emphasis on adopting these established standards to achieve cross‑system compatibility."
]