// C3: Physical sensing components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Physical light sensor modeled in the BIM environment, streaming measurements via Eclipse Hono"
    DTDFVocab:producedData LightSensorDataTransmitted
]

instance HVACSensor : DTDFVocab:SensingComponent [
    base:desc "Physical HVAC sensor modeled in the BIM environment, streaming measurements via Eclipse Hono"
    DTDFVocab:producedData HVACSensorDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance LightSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance HVACSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACSensor
]

// C5: Data produced from sensors
instance LightSensorData : DTDFVocab:Data [
    base:desc "Live light measurement data persisted in Eclipse Ditto"
    DTDFVocab:fromData LightSensorDataTransmitted
    DTDFVocab:inputTo HonoDittoMiddlewareEnabler
]

instance HVACSensorData : DTDFVocab:Data [
    base:desc "Live HVAC measurement data persisted in Eclipse Ditto"
    DTDFVocab:fromData HVACSensorDataTransmitted
    DTDFVocab:inputTo HonoDittoMiddlewareEnabler
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched IFC BIM model containing geometry and device metadata"
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral control logic embedded by Building Control Engineers into the BIM model"
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance PredictiveAnalyticsModel : DTDFVocab:Model [
    base:desc "Predictive analytics model derived from sensor data for building optimisation"
    DTDFVocab:inputTo MDEPipelineEnabler
]

// C11: Enablers
instance HonoDittoMiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono and Eclipse Ditto middleware enabling real‑time data exchange and policy‑based validation"
    DTDFVocab:enables RealTimeDataExchangeService, ControlService
]

instance MDEPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline that transforms enriched BIM artifacts into deployable DT components"
    DTDFVocab:enables PredictiveAnalyticsService, CustomExtensionService
]

instance UE5VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 based visualization engine mapping TwinComponents to immersive 3D UI"
    DTDFVocab:enables VisualizationService
]

instance ExtensionFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Modular extension framework allowing DT Engineers to plug in bespoke analytics and optimisation services"
    DTDFVocab:enables CustomExtensionService
]

// C6: Services
instance RealTimeDataExchangeService : DTDFVocab:Service [
    base:desc "Bidirectional real‑time data synchronization between physical building and digital twin"
    DTDFVocab:provides MonitoringInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization of building state for immersive monitoring"
    DTDFVocab:provides MonitoringInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Service exposing control commands to actuators through DittoController"
    DTDFVocab:provides ControlAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service executing predictive analytics for building optimisation"
    DTDFVocab:provides OptimizationInsight, OptimizationAction
]

instance CustomExtensionService : DTDFVocab:Service [
    base:desc "Extension point for DT Engineers to add custom analytics or optimisation logic"
    DTDFVocab:provides OptimizationInsight
]

// C17: Insights/Actions
instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into building performance and sensor status"
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Command to actuate building devices (e.g., adjust HVAC set‑point)"
    DTDFVocab:IsAutomatic false
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommendation for energy‑efficient operation derived from predictive models"
]

instance OptimizationAction : DTDFVocab:Action [
    base:desc "Automated adjustment of building controls to achieve optimization"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance LightActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling lighting, receiving commands via UnrealTwinController - DittoController"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling HVAC systems, receiving commands via UnrealTwinController - DittoController"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT enables Facility Managers to issue control commands to physical building systems via the same bidirectional data exchange, supporting real‑time monitoring and control. The document does not specify command types, message formats, validation/authentication mechanisms, feedback loops, conflict‑resolution strategies, or confirmation of command execution."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real-time data exchange capabilities that ensure continuous synchronization between the physical building and its digital counterpart, implying that updates are propagated as soon as new runtime data are available; the document does not specify exact update frequencies, latency bounds, or temporal granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is organized as a modular framework with a central DT Framework acting as a hub. Roles such as Building Control Engineers, Facility Managers, and DT Engineers interact with the hub, which manages bidirectional data exchange, runtime configuration management, and standardized extension points for integrating custom services and analytics. This architecture supports component integration, resource coordination, and system-wide orchestration within the building life-cycle management process."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports the full Digital Twin life‑cycle: (1) device modeling where Building Control Engineers enrich a BIM model with sensors, actuators and controllers; (2) model‑driven engineering (MDE) that extracts a structured representation from the enriched BIM; (3) automatic generation of deployable DT artefacts with minimal manual effort; (4) deployment of the DT and activation of real‑time bidirectional data exchange to keep physical and virtual assets synchronized; (5) runtime operation where Facility Managers monitor states and control equipment through interactive, immersive visualisations; and (6) evolution through modular extension points that allow DT Engineers to plug in custom services and analytics. Governance is achieved by a modular architecture with clearly defined extension interfaces that guide the transition between stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by enriching static BIM geometry with dynamic device metadata and control logic, then automatically generating DT artifacts through MDE conversion. Validation is performed at multiple layers: Eclipse Ditto applies policy‑based validation to enforce value ranges, units and command safety; pre‑execution checks detect potential conflicts before actuator actuation. Fault tolerance and data consistency are achieved through Eclipse Hono’s at‑least‑once delivery and Ditto’s persistent event storage, providing resilience against network failures. Uncertainty quantification and explicit error correction mechanisms beyond the mentioned validation policies are not described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed through non-functional requirements that target seamless interaction with heterogeneous systems; the framework uses standardized extension points and supports integration of external services and analytics, but the document does not name specific data exchange protocols, standards, or enterprise system integration patterns."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution is built on BIM as the core industry data standard for the AECO domain and uses a modular architecture with standardized extension points to promote interoperability. While open‑source DT frameworks such as Eclipse Ditto and BaSyx are cited for their compliance with generic IoT standards, the described framework itself does not reference additional certification schemes or specific interoperability specifications beyond its reliance on BIM."
]