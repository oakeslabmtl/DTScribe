// Environment containing all building components
instance LivingLabAcademicBuilding : DTDFVocab:Environment [
    base:contains TemperatureSensor, HumiditySensor, CO2Sensor, IlluminanceSensor, MotionSensor, EnergyMeter, LightingFixtureActuator, HVACDamperActuator, MotorizedBlindActuator
]

// Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the building, integrated with BIM, publishing data via MQTT topics to Ditto twin"
    DTDFVocab:producedData TemperatureTopic
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor embedded in the building, integrated with BIM, publishing data via MQTT topics to Ditto twin"
    DTDFVocab:producedData HumidityTopic
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor embedded in the building, integrated with BIM, publishing data via MQTT topics to Ditto twin"
    DTDFVocab:producedData CO2Topic
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor embedded in the building, integrated with BIM, publishing data via MQTT topics to Ditto twin"
    DTDFVocab:producedData IlluminanceTopic
]

instance MotionSensor : DTDFVocab:SensingComponent [
    base:desc "Motion sensor embedded in the building, integrated with BIM, publishing data via MQTT topics to Ditto twin"
    DTDFVocab:producedData MotionTopic
]

instance EnergyMeter : DTDFVocab:SensingComponent [
    base:desc "Energy meter embedded in the building, integrated with BIM, publishing data via MQTT topics to Ditto twin"
    DTDFVocab:producedData EnergyTopic
]

// Physical Acting Components
instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture actuator controlled via MQTT message through Eclipse Hono and Ditto"
]

instance HVACDamperActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC damper actuator controlled via MQTT message through Eclipse Hono and Ditto"
]

instance MotorizedBlindActuator : DTDFVocab:ActingComponent [
    base:desc "Motorized blind actuator controlled via MQTT message through Eclipse Hono and Ditto"
]

// Data Transmitted instances
instance TemperatureTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance CO2Topic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance IlluminanceTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]

instance MotionTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionSensor
]

instance EnergyTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeter
]

// Data instances
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature measurement reading from TemperatureSensor"
    DTDFVocab:inputTo EclipseHonoBroker
    DTDFVocab:fromData TemperatureTopic
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity measurement reading from HumiditySensor"
    DTDFVocab:inputTo EclipseHonoBroker
    DTDFVocab:fromData HumidityTopic
]

instance CO2Data : DTDFVocab:Data [
    base:desc "CO₂ measurement reading from CO2Sensor"
    DTDFVocab:inputTo EclipseHonoBroker
    DTDFVocab:fromData CO2Topic
]

instance IlluminanceData : DTDFVocab:Data [
    base:desc "Illuminance measurement reading from IlluminanceSensor"
    DTDFVocab:inputTo EclipseHonoBroker
    DTDFVocab:fromData IlluminanceTopic
]

instance MotionData : DTDFVocab:Data [
    base:desc "Motion detection data from MotionSensor"
    DTDFVocab:inputTo EclipseHonoBroker
    DTDFVocab:fromData MotionTopic
]

instance EnergyData : DTDFVocab:Data [
    base:desc "Energy consumption data from EnergyMeter"
    DTDFVocab:inputTo EclipseHonoBroker
    DTDFVocab:fromData EnergyTopic
]

// Enablers
instance EclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono message broker facilitating MQTT communication between physical devices and Ditto twins"
    DTDFVocab:enables TelemetryIngestionService, ActuatorCommandService, RLLightingOptimizationService, AnomalyDetectionService, BuildingPerformanceSimulationService, UnrealEngineVisualizationService, TransformationService
]

instance DittoTwinRegistryEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin registry managing the representation of physical components"
    DTDFVocab:enables TelemetryIngestionService, ActuatorCommandService
]

instance MDETransformationToolkit : DTDFVocab:Enabler [
    base:desc "Model‑to‑code and model‑to‑text transformation toolkit generating runtime artifacts"
    DTDFVocab:enables TransformationService
]

// Services & Insights/Actions
instance TelemetryIngestionService : DTDFVocab:Service [
    base:desc "Service ingesting telemetry streams from MQTT topics into Ditto twin registry"
    DTDFVocab:provides RealTimeMonitoringInsight, OccupancyPredictionInsight, EnergyConsumptionPredictionInsight
]

instance ActuatorCommandService : DTDFVocab:Service [
    base:desc "Service dispatching actuator command messages to building automation devices via MQTT"
    DTDFVocab:provides LightingScheduleAdjustmentAction, HVACCommandAdjustmentAction, BlindCommandAdjustmentAction
]

instance RLLightingOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based lighting optimization service using telemetry data"
    DTDFVocab:provides RLLightingOptimizationAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Service detecting and alerting anomalies in building telemetry"
    DTDFVocab:provides AnomalyAlertInsight
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Service simulating building performance using integrated BIM and runtime data"
    DTDFVocab:provides SimulationResultInsight
]

instance UnrealEngineVisualizationService : DTDFVocab:Service [
    base:desc "Service providing immersive visualization of the building twin in Unreal Engine 5"
    DTDFVocab:provides UnrealEngineVisualizationInsight
]

instance TransformationService : DTDFVocab:Service [
    base:desc "Service transforming semantic BIM and runtime artifacts into executable configurations"
    DTDFVocab:provides TransformationQualityInsight
]

// Insights
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring dashboards displaying building telemetry"
]

instance OccupancyPredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive model outputs occupancy forecasts for building spaces"
]

instance EnergyConsumptionPredictionInsight : DTDFVocab:Insight [
    base:desc "Forecast of building energy consumption based on telemetry data"
]

instance AnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Anomaly alerts for abnormal sensor readings or actuator behaviour"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation outputs of building performance used for analysis and planning"
]

instance UnrealEngineVisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive visualization of the digital twin rendered in Unreal Engine 5"
]

instance TransformationQualityInsight : DTDFVocab:Insight [
    base:desc "Quality metrics evaluating the transformation of BIM models into runtime artifacts"
]

// Actions
instance LightingScheduleAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic lighting schedule adjustment generated by reinforcement‑learning model"
    DTDFVocab:IsAutomatic true
]

instance HVACCommandAdjustmentAction : DTDFVocab:Action [
    base:desc "HVAC system command to adjust damper positions based on occupancy predictions"
    DTDFVocab:IsAutomatic true
]

instance BlindCommandAdjustmentAction : DTDFVocab:Action [
    base:desc "Motorized blind command to adjust window blinds in response to daylight analysis"
    DTDFVocab:IsAutomatic true
]

instance RLLightingOptimizationAction : DTDFVocab:Action [
    base:desc "Reinforcement‑learning action for optimizing lighting power consumption and user comfort"
    DTDFVocab:IsAutomatic true
]

// Models & Data
instance SemanticIFCModel : DTDFVocab:Model [
    base:desc "Semantic BIM model imported as IFC file representing the building geometry and component definitions"
    DTDFVocab:inputTo DittoTwinRegistryEnabler
]

instance TransformationArtifactsJSONModel : DTDFVocab:Model [
    base:desc "Model of transformation artifacts generated from semantic BIM into JSON runtime configuration"
    DTDFVocab:inputTo MDETransformationToolkit
]

instance MQTTTopicSchemaModel : DTDFVocab:Model [
    base:desc "Model describing the MQTT topic schema for telemetry streams"
    DTDFVocab:inputTo EclipseHonoBroker
]

instance ControllerCodeModel : DTDFVocab:Model [
    base:desc "Compiled controller code generated from MDE tooling for building automation devices"
    DTDFVocab:inputTo DittoTwinRegistryEnabler
]

instance RLPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning policy model used for lighting optimization"
    DTDFVocab:inputTo ActuatorCommandService
]

instance RuntimeTelemetryData : DTDFVocab:Data [
    base:desc "Aggregated runtime sensor data streams stored in Ditto twin registry"
    DTDFVocab:inputTo DittoTwinRegistryEnabler
    DTDFVocab:fromData TemperatureData, HumidityData, CO2Data, IlluminanceData, MotionData, EnergyData
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., lighting level setpoints, HVAC setpoints) are published as MQTT messages via Ditto and forwarded by Eclipse Hono to the building control system, resulting in actuation of devices."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time synchronization driven by the building automation system; policy‑based polling and message delivery rates typically in the range of seconds to minutes support control loops, while visualization updates at a refresh rate of 1 Hz or higher."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Integrated stack comprising BIM‑based semantic foundation, Ditto twin registry, Hono messaging layer, controller and analytics modules, and Unreal Engine visualization, orchestrated by a central DT framework with defined extension points for modular services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (ideal) – BIM modeling; Manufacture – integration of device metadata into BIM; Operation – live data exchange and continuous testing. The DT spans from designed/ideal (BIM), through manufactured (device configuration), to operated (live operation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model consistency enforced by MDE transformation rules; runtime validation via ODTE metric to quantify entanglement; continuous verification of sensor data against expected ranges and control loop stability; iterative correction of semantic drift."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol over TLS via Eclipse Hono broker; Ditto twin registry exposes JSON‑based REST APIs and WebSocket streams; communication between PT and DT occurs over secure MQTT topics with quality‑of‑service QoS1/2."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Cloud‑hosted containerized deployment of Eclipse Hono broker, Eclipse Ditto registry, controller services, and analytics, with optional edge actors for low‑latency actuation; Unreal Engine visualization runs on a dedicated GPU server or cloud virtual desktop."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability facilitated by MQTT and Ditto’s REST interfaces, enabling integration with external IoT platforms, building information exchange systems, and third‑party analytics services; federation of twin data across organizational boundaries."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to IFC schema for BIM, MQTT standard for messaging, CoAP/REST semantics per Eclipse Ditto, and alignment with AECO domain standards (e.g., ISO 19650) for BIM data management."
]