instance GeometricBIMModel : DTDFVocab:Model [
    base:desc "Building Information Model providing geometric representation of the infrastructure"
    DTDFVocab:inputTo ModelDrivenEngineeringEnabler, InteractiveVisualizationEnabler
]

instance BehavioralControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model containing control logic for building systems"
    DTDFVocab:inputTo ModelDrivenEngineeringEnabler, InteractiveVisualizationEnabler
]

instance AnalyticalComponentModel : DTDFVocab:Model [
    base:desc "Analytical model for performance simulation and optimization"
    DTDFVocab:inputTo ModelDrivenEngineeringEnabler, InteractiveVisualizationEnabler
]

instance ModelDrivenEngineeringEnabler : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering principles for automatic generation of deployable DT artifacts"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, OperationalOptimizationService, EnhancedDecisionMakingService
]

instance InteractiveVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Interactive visualization interfaces for real-time synchronization"
    DTDFVocab:enables RealTimeMonitoringService, EnhancedDecisionMakingService
]

instance ModularArchitectureEnabler : DTDFVocab:Enabler [
    base:desc "Modular architecture with standardized extension points for integrating custom services and analytics"
    DTDFVocab:enables PredictiveAnalyticsService, OperationalOptimizationService, EnhancedDecisionMakingService
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring through data-driven insights"
    DTDFVocab:provides DataDrivenInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for performance forecasting and maintenance"
    DTDFVocab:provides PerformanceForecastingInsight, MaintenancePredictionInsight
]

instance OperationalOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of operational processes to reduce costs"
    DTDFVocab:provides CostReductionInsight
]

instance EnhancedDecisionMakingService : DTDFVocab:Service [
    base:desc "Enhanced decision-making capabilities for infrastructure management"
    DTDFVocab:provides CollaborativeDecisionMakingInsight
]

instance DataDrivenInsight : DTDFVocab:Insight [
    base:desc "Data-driven insights for real-time monitoring"
]

instance PerformanceForecastingInsight : DTDFVocab:Insight [
    base:desc "Performance forecasting for building systems"
]

instance MaintenancePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance alerts"
]

instance CostReductionInsight : DTDFVocab:Insight [
    base:desc "Optimized operational costs through process analysis"
]

instance CollaborativeDecisionMakingInsight : DTDFVocab:Insight [
    base:desc "Enhanced collaboration and data-informed decision-making for stakeholders"
]

instance BuildingInfrastructureEnvironment : DTDFVocab:Environment [
    base:desc "AECO domain infrastructure environment for buildings, integrating static models and real-time data for lifecycle management"
    base:contains GeometricBIMModel, BehavioralControlLogicModel, AnalyticalComponentModel, ModelDrivenEngineeringEnabler, InteractiveVisualizationEnabler, ModularArchitectureEnabler, RealTimeMonitoringService, PredictiveAnalyticsService, OperationalOptimizationService, EnhancedDecisionMakingService, DataDrivenInsight, PerformanceForecastingInsight, MaintenancePredictionInsight, CostReductionInsight, CollaborativeDecisionMakingInsight
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle includes initial device modeling within BIM environment to define sensors, actuators, and controllers; Model-Driven Engineering (MDE) for structured representation extraction and automatic generation of deployable artifacts; real-time data exchange for continuous synchronization between physical and digital counterparts; interactive visualization for monitoring and control; and modular architecture with standardized extension points enabling evolution through custom services integration."
]