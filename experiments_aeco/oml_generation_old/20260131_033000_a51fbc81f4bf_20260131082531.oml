instance IndoorTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for monitoring indoor temperature conditions"
    DTDFVocab:producedData IndoorTemperatureDataTransmitted
]

instance IndoorHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for monitoring indoor humidity levels"
    DTDFVocab:producedData IndoorHumidityDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for monitoring carbon dioxide concentration"
    DTDFVocab:producedData CO2ConcentrationDataTransmitted
]

instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for measuring light intensity"
    DTDFVocab:producedData LightIntensityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for detecting room occupancy"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IndoorTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndoorTemperatureSensor
]

instance IndoorHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndoorHumiditySensor
]

instance CO2ConcentrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance LightIntensityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IndoorTemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature data collected from sensors"
    DTDFVocab:fromData IndoorTemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance IndoorHumidityData : DTDFVocab:Data [
    base:desc "Real-time humidity data collected from sensors"
    DTDFVocab:fromData IndoorHumidityDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance CO2ConcentrationData : DTDFVocab:Data [
    base:desc "Carbon dioxide concentration data from environmental sensors"
    DTDFVocab:fromData CO2ConcentrationDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance LightIntensityData : DTDFVocab:Data [
    base:desc "Light intensity measurements from sensors"
    DTDFVocab:fromData LightIntensityDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Room occupancy data collected via sensors"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "Comprehensive BIM model for building geometry, topology, and component relationships"
    DTDFVocab:inputTo BIMModelingTools
]

instance BIMGeometryData : DTDFVocab:Data [
    base:desc "Geometric data of building components from BIM model"
    DTDFVocab:inputTo BIMModelingTools, EclipseDitto
]

instance BIMTopologyData : DTDFVocab:Data [
    base:desc "Topological relationships of building components from BIM model"
    DTDFVocab:inputTo BIMModelingTools, EclipseDitto
]

instance DeviceSpecificData : DTDFVocab:Data [
    base:desc "Device-specific metadata for sensors, actuators, and controllers in BIM model"
    DTDFVocab:inputTo BIMModelingTools, EclipseDitto
]

instance BIMModelingTools : DTDFVocab:Enabler [
    base:desc "Tools for creating and managing Building Information Models"
    DTDFVocab:enables ModelDrivenDeploymentService
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "IoT connectivity platform for real-time sensor data transmission"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Digital twin management platform for synchronization and state management"
    DTDFVocab:enables RealTimeMonitoringService, SimulationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "High-fidelity interactive visualization engine for digital twin"
    DTDFVocab:enables InteractiveVisualizationService
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of building systems using sensor data"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Dynamic simulation of building performance under various scenarios"
    DTDFVocab:provides SimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for facility management using machine learning"
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance PerformanceAnalysisService : DTDFVocab:Service [
    base:desc "Analysis of building operational performance metrics"
    DTDFVocab:provides PerformanceInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Real-time 3D visualization of building systems and data"
    DTDFVocab:provides VisualizationInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of energy consumption using reinforcement learning"
    DTDFVocab:provides EnergyOptimizationInsight, AdjustHVACAction
]

instance VisualComfortOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of visual comfort conditions in building spaces"
    DTDFVocab:provides VisualComfortInsight, AdjustLightingAction
]

instance HealthEffectsOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of non-visual health effects through environmental control"
    DTDFVocab:provides HealthEffectsInsight
]

instance ModelDrivenDeploymentService : DTDFVocab:Service [
    base:desc "Model-driven automated deployment process extracting semantics from BIM models for runtime interfaces and configuration management"
    DTDFVocab:provides DeploymentConfigurationInsight
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time status of building systems for immediate decision-making"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insights for optimizing energy consumption based on predictive analytics"
]

instance IndoorEnvironmentalOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insights for optimizing indoor environmental conditions such as temperature and humidity"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insights from dynamic building performance simulations"
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive insights for equipment maintenance and failures"
]

instance PerformanceInsight : DTDFVocab:Insight [
    base:desc "Operational performance metrics analysis for facility management"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive visualization insights for building system understanding"
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Insights for optimizing visual comfort in building environments"
]

instance HealthEffectsInsight : DTDFVocab:Insight [
    base:desc "Insights for optimizing non-visual health effects through environmental control"
]

instance DeploymentConfigurationInsight : DTDFVocab:Insight [
    base:desc "Insights for model-driven deployment and runtime configuration management"
]

instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Automated adjustment of HVAC settings for energy optimization"
    DTDFVocab:IsAutomatic true
]

instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automated control of lighting systems for visual comfort"
    DTDFVocab:IsAutomatic true
]

instance AdjustBlindsAction : DTDFVocab:Action [
    base:desc "Automated adjustment of window blinds for thermal and visual comfort"
    DTDFVocab:IsAutomatic true
]

instance ControlValveAction : DTDFVocab:Action [
    base:desc "Automated control of HVAC valves for temperature regulation"
    DTDFVocab:IsAutomatic true
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for controlling HVAC system operations"
]

instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Controller for managing building lighting systems"
]

instance BlindController : DTDFVocab:ActingComponent [
    base:desc "Controller for automated window blinds"
]

instance ValveActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for regulating fluid flow in HVAC systems"
]

instance AECOLivingLabBuildingEnvironment : DTDFVocab:Environment [
    base:desc "Living Lab environment for building infrastructure in AECO domain"
    base:contains IndoorTemperatureSensor, IndoorHumiditySensor, CO2Sensor, LightSensor, OccupancySensor, HVACActuator, LightingController, BlindController, ValveActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Transmission of control signals from the digital twin to Building Control Systems (BCS) actuators for optimization and regulation of building operations."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with continuous data exchange between physical and virtual components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized DT Framework acting as a hub for bidirectional data exchange, with modular services and standardized extension points for integration of roles including Building Control Engineers, Facility Managers, and DT Engineers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the entire building life cycle from initial design through construction, operation, and refurbishments."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Measured using the Overall Digital Twin Entanglement (ODTE) metric to assess interoperability and architectural soundness of the DT."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono and Ditto for real-time data exchange, facilitating bidirectional communication between physical assets and the digital twin."
]