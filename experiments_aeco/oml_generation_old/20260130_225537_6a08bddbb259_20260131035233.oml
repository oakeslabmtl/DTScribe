instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for environmental monitoring of temperature in building infrastructure"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for environmental monitoring of occupancy levels in building infrastructure"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors for environmental monitoring of light levels in building infrastructure"
    DTDFVocab:producedData LightLevelDataTransmitted
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature measurements from environmental sensors"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono, Ditto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy data from environmental sensors"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, Ditto
]

instance LightLevelData : DTDFVocab:Data [
    base:desc "Real-time light level measurements from environmental sensors"
    DTDFVocab:fromData LightLevelDataTransmitted
    DTDFVocab:inputTo EclipseHono, Ditto
]

instance BIMModel : DTDFVocab:Model [
    base:desc "BIM-based model enriched with device metadata and control logic"
    DTDFVocab:inputTo BIMSoftware, EclipseHono, Ditto
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for IoT data ingestion"
    DTDFVocab:enables RealTimeMonitoringService, EnergyOptimizationService
]

instance Ditto : DTDFVocab:Enabler [
    base:desc "Ditto for digital twin management"
    DTDFVocab:enables PredictiveAnalyticsService, RealTimeMonitoringService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for visualization"
    DTDFVocab:enables InteractiveVisualizationService
]

instance BIMSoftware : DTDFVocab:Enabler [
    base:desc "BIM software for modeling"
    DTDFVocab:enables SimulationService, EnergyOptimizationService
]

instance BOREALIS : DTDFVocab:Enabler [
    base:desc "Reinforcement learning framework for adaptive control policies (BOREALIS project)"
    DTDFVocab:enables PredictiveAnalyticsService
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of building systems"
    DTDFVocab:provides PerformanceAnalysisInsight, DecisionSupportInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building operations using BIM models"
    DTDFVocab:provides EnergyConsumptionReductionInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for operational optimization"
    DTDFVocab:provides EnergyConsumptionReductionInsight, MaintenancePlanningInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy consumption optimization through real-time adjustments"
    DTDFVocab:provides AdjustLightingLevelAction, AdjustHVACTemperatureAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization using Unreal Engine 5 for building operations management"
    DTDFVocab:provides PerformanceAnalysisInsight, DecisionSupportInsight
]

instance EnergyConsumptionReductionInsight : DTDFVocab:Insight [
    base:desc "Insight for reducing energy consumption through operational optimization"
]

instance MaintenancePlanningInsight : DTDFVocab:Insight [
    base:desc "Insight for proactive maintenance planning based on predictive analytics"
]

instance PerformanceAnalysisInsight : DTDFVocab:Insight [
    base:desc "Performance analysis of building systems for operational efficiency"
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Decision support for facility managers regarding building operations"
]

instance AdjustLightingLevelAction : DTDFVocab:Action [
    base:desc "Automated adjustment of lighting levels based on occupancy and light levels"
    DTDFVocab:IsAutomatic true
]

instance AdjustHVACTemperatureAction : DTDFVocab:Action [
    base:desc "Automated adjustment of HVAC temperature based on sensor data"
    DTDFVocab:IsAutomatic true
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling lighting systems in building infrastructure"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling HVAC systems in building infrastructure"
]

instance BuildingLivingLab : DTDFVocab:Environment [
    base:desc "Living Lab building infrastructure for real-time monitoring and optimization"
    base:contains TemperatureSensor, OccupancySensor, LightLevelSensor, LightingActuator, HVACActuator, BIMModel, EclipseHono, Ditto, UnrealEngine5, BIMSoftware, BOREALIS, RealTimeMonitoringService, SimulationService, PredictiveAnalyticsService, EnergyOptimizationService, InteractiveVisualizationService, EnergyConsumptionReductionInsight, MaintenancePlanningInsight, PerformanceAnalysisInsight, DecisionSupportInsight, AdjustLightingLevelAction, AdjustHVACTemperatureAction
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the digital twin and sent via Hono/Ditto to actuators in physical building systems, such as adjusting lighting or HVAC settings based on simulation results and optimization algorithms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with continuous data exchange, though specific time intervals (e.g., milliseconds or seconds) are not detailed in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An integrated system comprising BIM models as the semantic foundation, Eclipse Hono and Ditto for real-time data exchange, Unreal Engine for visualization, and modular services connected through standardized extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers all life cycle stages from design through construction, operation, and refurbishment phases, as BIM enables comprehensive representation across the entire building life cycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Evaluated using the Overall Digital Twin Entanglement (ODTE) metric to measure alignment between the digital twin and physical counterpart, though specific verification methods beyond ODTE are not detailed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono and Ditto for bidirectional data exchange; Hono typically utilizes MQTT for IoT communication protocols."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Not specified; open-source tools (Hono, Ditto, Unreal Engine) can be deployed on various infrastructures, but details are not provided in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized extension points support integration with external systems, though specific examples of integrated external systems are not detailed in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM standards for semantic modeling and interoperability, with framework-specific standardized extension points for modular service integration."
]