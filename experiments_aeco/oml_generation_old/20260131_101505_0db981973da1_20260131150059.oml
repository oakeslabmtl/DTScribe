// C2: Acting Components
instance DimmableLightingFixture : DTDFVocab:ActingComponent [
    base:desc "Dimmable lighting fixture operated through controller units embedded in the building automation system, as defined in the BIM model."
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy sensor capturing occupancy parameters, integrated into BIM model and published to the DT."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnvironmentParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy sensor capturing environmental parameters, integrated into BIM model and published to the DT."
    DTDFVocab:producedData EnvironmentDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy sensor capturing energy consumption parameters, integrated into BIM model and published to the DT."
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

// C4: Physical-to-virtual interaction
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnvironmentDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentParameterSensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

// C10: Models/Data
instance BuildingInformationModel : DTDFVocab:Model [
    base:desc "IFC‑based BIM representation enriched with semantic annotations, used as primary model for the DT."
    DTDFVocab:inputTo MDEPipelineEngine, EclipseDittoRegistry
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Structured JSON containing occupancy data stored as twin property updates for OccupancySensor."
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoRegistry
    DTDFVocab:fromData OccupancyDataTransmitted
]

instance EnvironmentParametersData : DTDFVocab:Data [
    base:desc "Structured JSON containing environmental data stored as twin property updates for EnvironmentParameterSensor."
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoRegistry
    DTDFVocab:fromData EnvironmentDataTransmitted
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "Structured JSON containing energy consumption data stored as twin property updates for EnergyConsumptionSensor."
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoRegistry
    DTDFVocab:fromData EnergyConsumptionDataTransmitted
]

// C11: Enablers
instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono (IoT gateway) forwarding device telemetry to Ditto."
    DTDFVocab:enables MonitoringDashboardService, RealTimeEnvelopeSimulationService
]

instance EclipseDittoRegistry : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto (digital twin registry) storing twin metadata and property updates."
    DTDFVocab:enables LightingScheduleOptimizationService, UnrealVisualizationService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 (3D visualization) rendering immersive visualization of building."
    DTDFVocab:enables UnrealVisualizationService
]

instance MDEPipelineEngine : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline translating enriched BIM into executable DT artifacts."
]

instance RLPolicyEngine : DTDFVocab:Enabler [
    base:desc "Reinforcement learning engine (BOREALIS) providing predictive energy consumption analytics."
    DTDFVocab:enables PredictiveEnergyAnalyticsService
]

// C6: Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Continuous monitoring dashboards exposing real‑time occupancy, environmental, and energy data via REST and streaming APIs."
    DTDFVocab:provides EnergyConsumptionProfileInsight, OccupantComfortAnalysisInsight
]

instance RealTimeEnvelopeSimulationService : DTDFVocab:Service [
    base:desc "Real‑time simulation of building envelope exposed through streaming APIs."
    DTDFVocab:provides EnvelopeStateInsight
]

instance PredictiveEnergyAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive energy consumption analytics powered by reinforcement learning."
    DTDFVocab:provides PredictiveEnergyConsumptionProfileInsight, PredictiveMaintenanceAlertInsight, SendPredictiveMaintenanceAlertAction
]

instance LightingScheduleOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of lighting schedules exposing recommendations via REST."
    DTDFVocab:provides LightingScheduleOptimizationRecommendationInsight, UpdateLightingScheduleAction
]

instance UnrealVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization in Unreal Engine 5 exposed via streaming APIs."
    DTDFVocab:provides VisualizedBuildingModelInsight
]

// C17: Insights/Actions
instance EnergyConsumptionProfileInsight : DTDFVocab:Insight [
    base:desc "Real‑time energy consumption profile derived from sensor data."
]

instance OccupantComfortAnalysisInsight : DTDFVocab:Insight [
    base:desc "Occupant comfort analysis derived from occupancy and environmental data."
]

instance LightingScheduleOptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Lighting schedule optimization recommendation."
]

instance PredictiveMaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance alert based on equipment utilization patterns."
]

instance VisualizedBuildingModelInsight : DTDFVocab:Insight [
    base:desc "Visual representation of building model in Unreal Engine 5."
]

instance EnvelopeStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time building envelope state insight from simulation."
]

instance UpdateLightingScheduleAction : DTDFVocab:Action [
    base:desc "Automatically update lighting schedules based on optimization results."
    DTDFVocab:IsAutomatic true
]

instance SendPredictiveMaintenanceAlertAction : DTDFVocab:Action [
    base:desc "Automatically send predictive maintenance alerts."
    DTDFVocab:IsAutomatic true
]

instance FeedBackScheduleToManagementAction : DTDFVocab:Action [
    base:desc "Feed lighting schedule recommendations back into the schedule management system."
    DTDFVocab:IsAutomatic true
]

instance PredictiveEnergyConsumptionProfileInsight : DTDFVocab:Insight [
    base:desc "Predictive energy consumption profile derived from reinforcement learning analytics."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT are written as twin updates in Eclipse Ditto, then propagated via Hono to the target devices. The physical actuators receive the command payloads (e.g., brightness adjustment, HVAC setpoint) and execute the prescribed actions."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Operational data is synchronized in real‑time with low‑latency update cycles; control loops (e.g., lighting, HVAC) execute on minute‑scale intervals while sensor sampling may be faster. The DT processes events as they arrive without batching beyond the Hono middleware limits."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central orchestrator comprising Hono, Ditto, and the synthesized runtime services, linking the virtual twin ecosystem to the physical building. Device twins are exposed via Ditto, analytics services consume these twins, and visualization clients render the model in Unreal Engine."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design‑time BIM modeling, construction‑time as‑built BIM capture, post‑construction operational monitoring, and runtime optimization during building operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric quantifies how closely the virtual state mirrors the physical counterpart. Semantic drift is monitored by comparing model‑derived expectations against live sensor readings; discrepancies trigger re‑validation of the BIM model or retraining of control policies."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical devices publish telemetry and receive commands via Eclipse Hono, which bridges device protocols to the Ditto event bus. Ditto exposes device twins through a RESTful API for the DT’s consumption. The exact transport protocols are encapsulated by Hono and are not explicitly detailed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM (IFC) serves as the canonical modeling standard; Hono/Ditto provide interoperability via IoT‑standard event messaging. The MDE transformation pipeline enforces consistent semantic mapping across the asset life cycle."
]