// C3: Physical sensing components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor embedded in the building, modeled in BIM and streamed to the DT"
    DTDFVocab:producedData LightDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the building, modeled in BIM and streamed to the DT"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the building, modeled in BIM and streamed to the DT"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor (representative of other environmental sensors) modeled in BIM and streamed to the DT"
    DTDFVocab:producedData HumidityDataTransmitted
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance LightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

// C10: Data
instance LightData : DTDFVocab:Data [
    base:desc "Real‑time light level measurements"
    DTDFVocab:fromData LightDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, BIMSemanticBackboneEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy detection events"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, BIMSemanticBackboneEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature readings"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, BIMSemanticBackboneEnabler
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Real‑time humidity measurements"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, BIMSemanticBackboneEnabler
]

// C10: Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Static BIM model enriched with device metadata for the digital twin"
    DTDFVocab:inputTo BIMSemanticBackboneEnabler
]

instance MDEArtefactModel : DTDFVocab:Model [
    base:desc "Automatically generated MDE artefacts (deployment scripts, configuration files) for runtime execution"
    DTDFVocab:inputTo MDEAutomationEnabler
]

// C11: Enablers
instance BIMSemanticBackboneEnabler : DTDFVocab:Enabler [
    base:desc "BIM used as the semantic backbone linking physical assets to their virtual counterparts"
    DTDFVocab:enables ModelIntegrationService
]

instance MDEAutomationEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering tooling that generates artefacts automatically"
    DTDFVocab:enables ArtifactGenerationService
]

instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono broker for ingesting real‑time sensor streams"
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for digital twin state management and command handling"
    DTDFVocab:enables EnergyOptimizationService, PredictiveAnalyticsService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for 3‑D interactive visualization of the twin"
    DTDFVocab:enables Visualization3DService
]

instance ExtensionPointsEnabler : DTDFVocab:Enabler [
    base:desc "Standardised extension points enabling modular services and incremental updates"
    DTDFVocab:enables UpdateManagementService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides dashboards for real‑time monitoring of sensor data"
    DTDFVocab:provides EnergyConsumptionPatternInsight, ComfortLevelAssessmentInsight
]

instance Visualization3DService : DTDFVocab:Service [
    base:desc "Delivers 3‑D interactive visualization using Unreal Engine 5"
    DTDFVocab:provides ComfortLevelAssessmentInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Runs predictive analytics to forecast building performance"
    DTDFVocab:provides EnergyConsumptionPatternInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimises energy consumption by computing optimal set‑points"
    DTDFVocab:provides OptimizedControlSetpointAction
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulates building performance for lifecycle analysis"
    DTDFVocab:provides ComfortLevelAssessmentInsight
]

instance ModelIntegrationService : DTDFVocab:Service [
    base:desc "Integrates enriched BIM models with runtime twin components"
    DTDFVocab:provides EnergyConsumptionPatternInsight
]

instance ArtifactGenerationService : DTDFVocab:Service [
    base:desc "Generates deployment artefacts from MDE models"
    DTDFVocab:provides OptimizedControlSetpointAction
]

instance UpdateManagementService : DTDFVocab:Service [
    base:desc "Manages incremental updates and extension of twin services"
    DTDFVocab:provides EnergyConsumptionPatternInsight
]

// C17: Insights
instance EnergyConsumptionPatternInsight : DTDFVocab:Insight [
    base:desc "Insight into energy consumption patterns derived from sensor streams and analytics"
]

instance ComfortLevelAssessmentInsight : DTDFVocab:Insight [
    base:desc "Assessment of occupant comfort levels based on temperature, humidity, and occupancy data"
]

// C17: Actions
instance OptimizedControlSetpointAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of control set‑points for lighting and HVAC to optimise energy usage"
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture actuator modeled in BIM that receives control commands from the DT"
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve actuator modeled in BIM that receives control commands from the DT"
]

// C1: Environment (building)
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains LightSensor, OccupancySensor, TemperatureSensor, HumiditySensor,
                 LightingFixtureActuator, HVACValveActuator,
                 EnrichedBIMModel, MDEArtefactModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional control commands generated by the DT (e.g., lighting set‑points, HVAC control signals) are sent back through Hono/Ditto to the corresponding actuators in the building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization (sub‑second to second‑level update frequency) between physical sensor streams and the digital twin."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where an enriched BIM model feeds a configurator that generates Hono/Ditto runtime artifacts; the middleware provides bidirectional communication, while visualization and analytics services run on top, forming a cohesive DT ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the full building life‑cycle: design (static BIM), construction (model enrichment), and operation (runtime data integration and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to quantify how accurately the DT reflects its physical counterpart, providing a measure of semantic and data fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono (message broker) and Eclipse Ditto (digital twin platform) constitute the technical bridge, handling protocol translation and state synchronization between physical sensors/actuators and the virtual model."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized extension points allow integration of external services and analytics modules, facilitating horizontal information exchange with other systems in the AECO ecosystem."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach adheres to BIM standards for building information, leverages open‑source standards implemented in Eclipse Hono and Ditto, and utilizes the ODTE metric for interoperability assessment."
]