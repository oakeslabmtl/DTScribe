// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor providing post‑occupancy sensor data for real‑time monitoring and reinforcement‑learning control (BOREALIS)."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance BuildingControlSensor : DTDFVocab:SensingComponent [
    base:desc "Building control sensors whose configurations are embedded in the BIM model, used for real‑time monitoring and control."
    DTDFVocab:producedData ControlSensorDataTransmitted
]

// C4: DataTransmitted
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance ControlSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingControlSensor
]

// C10: Data
instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy measurement data streamed in real time from the physical occupancy sensor."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler, ReinforcementLearningEngineEnabler
]

instance ControlSensorData : DTDFVocab:Data [
    base:desc "Building control sensor measurements (e.g., temperature, humidity) streamed in real time."
    DTDFVocab:fromData ControlSensorDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler, ModelDrivenTransformationEnabler
]

// C2: Acting components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Controllable lighting dimmer device that receives command signals from the twin for lighting adjustment."
]

instance LightingSwitchActuator : DTDFVocab:ActingComponent [
    base:desc "Controllable lighting switch device that receives command signals from the twin for on/off control."
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono streams sensor measurements in real time from physical devices to the twin."
    DTDFVocab:enables RealTimeMonitoringService, ReinforcementLearningControlService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto updates digital twin state from incoming data, providing continuous synchronization."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders 3D interactive visualization of the building twin."
    DTDFVocab:enables InteractiveVisualizationService
]

instance ModelDrivenTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering transformation pipeline auto‑generates runtime artifacts from enriched BIM."
    DTDFVocab:enables SimulationService, EnergyLightingOptimizationService
]

instance ReinforcementLearningEngineEnabler : DTDFVocab:Enabler [
    base:desc "Reinforcement‑learning engine (BOREALIS) adapts control policies using post‑occupancy data."
    DTDFVocab:enables ReinforcementLearningControlService
]

instance EnergyOptimizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Engine performing energy and lighting optimization based on predictive analytics."
    DTDFVocab:enables EnergyLightingOptimizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of occupancy and building control sensor data."
    DTDFVocab:provides RealTimeInsights
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "3D interactive visualization of the building twin using Unreal Engine 5."
    DTDFVocab:provides VisualizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building behavior based on BIM geometry and runtime device models."
    DTDFVocab:provides SimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics generating forecasts of occupancy and energy consumption."
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance EnergyLightingOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of energy usage and lighting levels based on analytics."
    DTDFVocab:provides EnergyOptimizationInsight, RLControlAction
]

instance ReinforcementLearningControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based adaptation of lighting control policies."
    DTDFVocab:provides RLControlAction
]

// C17: Insights / Actions
instance RealTimeInsights : DTDFVocab:Insight [
    base:desc "Real‑time insights delivered to facility managers for immediate operation adjustments."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D visualization insight enabling spatial understanding of building state."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results insight providing scenario analysis for building performance."
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics insight offering forecasts for occupancy and energy usage."
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Energy and lighting optimization recommendations supporting facility‑management decisions."
]

instance RLControlAction : DTDFVocab:Action [
    base:desc "Automatic adaptation of lighting control policy based on reinforcement‑learning outcomes."
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Static BIM geometry and semantics representing the building structure."
    DTDFVocab:inputTo UnrealEngine5Enabler, SimulationService
]

instance EnrichedDeviceModel : DTDFVocab:Model [
    base:desc "Runtime device models (sensors, actuators, control logic) enriched onto BIM."
    DTDFVocab:inputTo ModelDrivenTransformationEnabler, SimulationService
]

instance ReinforcementLearningControlModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning control model (BOREALIS) trained with post‑occupancy data."
    DTDFVocab:inputTo ReinforcementLearningEngineEnabler
]

instance VisualizationMeshModel : DTDFVocab:Model [
    base:desc "Visualization meshes imported into Unreal Engine for 3D rendering."
    DTDFVocab:inputTo UnrealEngine5Enabler
]

// System under study
instance BuildingDigitalTwin : DTDFVocab:Component [
    base:desc "A building Digital Twin (Living Lab) in the AECO domain mirroring a physical building throughout design, construction and operational phases."
]

// Environment composition
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, BuildingControlSensor, LightingDimmerActuator, LightingSwitchActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication enables the DT to issue control commands (e.g., lighting set‑points) back to actuators via the Hono/Ditto integration layer, closing the loop for actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real‑time, continuous synchronization where sensor updates and control commands are exchanged at sub‑second to second intervals, supporting live monitoring and control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A service‑oriented architecture that orchestrates BIM‑derived models, middleware (Hono/Ditto), and visualization components to deliver a unified building twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the entire building lifecycle: design (BIM creation), construction, operation (live data integration), and refurbishment/adaptation phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric is used to quantify the fidelity of the twin to its physical counterpart; semantic drift and verification are acknowledged as concerns."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical devices connect to the twin via Eclipse Hono, which forwards data to Eclipse Ditto for twin state management, providing bidirectional communication between the physical asset and its digital representation."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Uses BIM as an industry‑standard data model; provides standardized extension points and adheres to the Overall Digital Twin Entanglement (ODTE) assessment framework."
]