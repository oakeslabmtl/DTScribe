// C2: Acting Components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Physical HVAC actuator controlling heating, ventilation, and cooling in the Living Lab building."
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Physical lighting actuator managing interior illumination levels."
]

instance WindowShadeActuator : DTDFVocab:ActingComponent [
    base:desc "Physical actuator for motorized window shades, enabling daylight harvesting."
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Physical temperature sensor embedded in the Living Lab building, capturing environmental temperature for live streaming."
    DTDFVocab:producedData TemperatureDataStream
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Physical humidity sensor measuring indoor humidity levels for continuous monitoring."
    DTDFVocab:producedData HumidityDataStream
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Physical CO₂ sensor tracking indoor air quality by measuring carbon dioxide concentration."
    DTDFVocab:producedData CO2DataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Physical occupancy sensor detecting presence of occupants to assess space utilization."
    DTDFVocab:producedData OccupancyDataStream
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance CO2DataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature measurement values streamed from TemperatureSensor."
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Live humidity measurement values streamed from HumiditySensor."
    DTDFVocab:fromData HumidityDataStream
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Live CO₂ concentration values streamed from CO2Sensor."
    DTDFVocab:fromData CO2DataStream
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy status values streamed from OccupancySensor."
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C10: Models
instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "BIM model containing geometry, device definitions, control logic, and middleware metadata for the Living Lab building."
    DTDFVocab:inputTo BIMSemanticBackbone, ModelDrivenEngineeringTool
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Model of building control logic extracted from BIM, used to generate runtime control artifacts."
    DTDFVocab:inputTo ModelDrivenEngineeringTool, EclipseDitto
]

instance MiddlewareMetadataModel : DTDFVocab:Model [
    base:desc "Metadata describing communication protocols and message formats for sensors and actuators."
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C11: Enablers
instance BIMSemanticBackbone : DTDFVocab:Enabler [
    base:desc "BIM model serving as semantic backbone linking physical components to virtual representations."
    DTDFVocab:enables BuildingPerformanceSimulation
]

instance ModelDrivenEngineeringTool : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering tool that generates runtime artifacts from BIM metadata."
    DTDFVocab:enables CustomControlStrategyService
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware that ingests sensor telemetry from the building via MQTT/HTTPS."
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalyticsService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin state store, handling command execution and synchronization."
    DTDFVocab:enables EnergyOptimizationService, CustomControlStrategyService, Interactive3DVisualization
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime providing interactive 3D visualization of the digital twin."
    DTDFVocab:enables Interactive3DVisualization
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Dashboard displaying real‑time building metrics, enabling operators to monitor energy consumption."
    DTDFVocab:provides EnergyConsumptionTrendInsight
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "Interactive 3D visualization of the Living Lab building in Unreal Engine 5."
    DTDFVocab:provides ComfortLevelAssessmentInsight
]

instance BuildingPerformanceSimulation : DTDFVocab:Service [
    base:desc "Simulation engine evaluating building performance under varied conditions."
    DTDFVocab:provides ComfortLevelAssessmentInsight, OptimizationRecommendationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service forecasting energy usage and recommending optimizations."
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that automatically adjusts HVAC setpoints and lighting schedules."
    DTDFVocab:provides AdjustHVACSetpointAction, ReconfigureLightingScheduleAction
]

instance CustomControlStrategyService : DTDFVocab:Service [
    base:desc "Extensible service allowing custom control strategies to be deployed without redeploying the twin."
    DTDFVocab:provides AdjustHVACSetpointAction
]

// C17: Insights
instance EnergyConsumptionTrendInsight : DTDFVocab:Insight [
    base:desc "Insight into energy‑consumption trends derived from live sensor data."
]

instance ComfortLevelAssessmentInsight : DTDFVocab:Insight [
    base:desc "Assessment of occupant comfort levels based on temperature, humidity, CO₂, and occupancy data."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation for energy‑use optimization based on simulation and analytics."
]

// C17: Actions
instance AdjustHVACSetpointAction : DTDFVocab:Action [
    base:desc "Action to modify HVAC setpoints in response to comfort or energy optimization recommendations."
    DTDFVocab:IsAutomatic true
]

instance ReconfigureLightingScheduleAction : DTDFVocab:Action [
    base:desc "Action to adjust lighting schedules to reduce energy consumption while maintaining comfort."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., set‑point adjustments, lighting control signals) are sent back to the physical actuators through the same Hono/Ditto middleware, enabling closed‑loop operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular service‑oriented architecture comprising an enriched BIM model, a Hono/Ditto middleware layer for bidirectional communication, a runtime configurator, and an Unreal Engine visual front‑end, with defined extension points for additional services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the full building lifecycle—design, construction, commissioning, operation, and refurbishment—by leveraging BIM as a semantic backbone throughout."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validity is ensured through a validation step before deployment; fidelity of the twin to its physical counterpart is measured using the Overall Digital Twin Entanglement (ODTE) metric."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time connectivity is realized through Eclipse Hono (messaging) and Eclipse Ditto (digital twin platform), which together provide the communication backbone between physical devices and the virtual twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach follows BIM standards for building data, utilizes open‑source IoT standards implemented by Eclipse Hono and Ditto, and adheres to model‑driven engineering principles for standardized artifact generation."
]