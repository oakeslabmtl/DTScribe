// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Building temperature sensor embedded in the enriched BIM model for runtime data acquisition."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Building illumination sensor embedded in the enriched BIM model for runtime data acquisition."
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Building occupancy sensor embedded in the enriched BIM model for runtime data acquisition."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C2: Acting components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control actuator modeled within the BIM as part of the Building Control System."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC control actuator modeled within the BIM as part of the Building Control System."
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C5: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Streaming temperature measurements from the building."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Streaming illumination (light level) measurements from the building."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Streaming occupancy status measurements from the building."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]

// C11: Enablers
instance HonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono bridges IoT protocols (MQTT/HTTP) and forwards real‑time sensor streams to Eclipse Ditto."
    DTDFVocab:enables MonitoringService
]

instance DittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital‑twin instances, stores state, and triggers analytics."
    DTDFVocab:enables SimulationService, PredictiveAnalyticsService, OptimizationService, VisualizationService
]

instance UnrealEngineEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders immersive 3‑D visualization of the BIM‑based digital twin."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of building sensor streams."
    DTDFVocab:provides RealTimeDashboardInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building physics based on BIM geometry and device semantics."
    DTDFVocab:provides SimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics delivering energy‑usage forecasts."
    DTDFVocab:provides EnergyForecastInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization of energy consumption and occupant comfort."
    DTDFVocab:provides OptimizationRecommendationInsight, LightingAdjustmentAction, ClimateControlAdjustmentAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3‑D visualization of the digital twin via Unreal Engine 5."
    DTDFVocab:provides ImmersiveVisualizationInsight
]

// C17: Insights
instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time status dashboards for facility managers."
]

instance EnergyForecastInsight : DTDFVocab:Insight [
    base:desc "Predictive energy‑usage forecasts generated by analytics."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendations for lighting and climate control."
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive 3‑D visualization of the building model."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results of building performance."
]

// C17: Actions
instance LightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting levels based on optimization recommendations."
    DTDFVocab:IsAutomatic true
]

instance ClimateControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of HVAC settings based on optimization recommendations."
    DTDFVocab:IsAutomatic true
]

// C10: Models/Data
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Base BIM geometry and semantics of the building."
    DTDFVocab:inputTo DittoEnabler, UnrealEngineEnabler
]

instance DeviceMetadataModel : DTDFVocab:Model [
    base:desc "Enriched BIM metadata describing each sensor and actuator."
    DTDFVocab:inputTo DittoEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Auto‑generated control‑logic model for device twins."
    DTDFVocab:inputTo DittoEnabler
]

// C9: Environment (composite twin)
instance BuildingTwinComposite : DTDFVocab:Environment [
    base:contains TemperatureSensor, IlluminationSensor, OccupancySensor,
                LightingActuator, HVACActuator,
                BIMGeometryModel, DeviceMetadataModel, ControlLogicModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control logic generated by the twin emits command messages via Ditto to Eclipse Hono, which forwards them to the physical actuators using the same protocol adapters, enabling bidirectional actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous near‑real‑time synchronization; sensor updates and control commands are exchanged with sub‑second latency as supported by Hono/Ditto."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A service‑oriented architecture where the enriched BIM feeds a configurator, which produces Ditto twin definitions and Hono connection descriptors; Ditto hosts the twin state, Hono streams data, and Unreal Engine visualizes the twin for users."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers design (BIM as the ideal model), deployment (automatic generation of runtime artifacts), operation (real‑time data exchange), and maintenance (runtime configuration updates)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation before deployment and quantitative assessment of twin‑physical alignment using the Overall Digital Twin Entanglement (ODTE) metric; runtime consistency ensured by continuous bidirectional updates."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono provides MQTT, HTTP, and CoAP adapters; Ditto exposes HTTP/REST and WebSocket APIs; communication between Hono and Ditto is over standard internet protocols (TCP/IP)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital twin runtime components (Ditto server and Hono gateway) are hosted on a cloud/edge infrastructure; Unreal Engine runs as a client visualization layer connecting to Ditto via its APIs."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The framework integrates BIM, IoT sensor streams, control middleware (Hono/Ditto), and third‑party analytics services through its standardized extension points, enabling exchange with external enterprise systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Uses BIM industry standards for building data, open IoT standards supported by Eclipse Hono (MQTT, HTTP, CoAP), and Ditto’s adherence to the Eclipse Vorto and Digital Twin Definition Language (DTDL) conventions; ODTE metric provides a standardized fidelity measure."
]