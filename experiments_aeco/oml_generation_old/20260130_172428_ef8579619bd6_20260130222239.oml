// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental temperature sensor that measures indoor temperature for the Living Lab building"
    DTDFVocab:producedData TemperatureDataStream
]

instance LuminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Luminance sensor that measures indoor light levels for adaptive lighting control"
    DTDFVocab:producedData LuminanceDataStream
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor that monitors indoor air quality and occupancy related carbon dioxide concentration"
    DTDFVocab:producedData CO2DataStream
]

instance PresenceSensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy presence sensor that detects whether a space is occupied"
    DTDFVocab:producedData PresenceDataStream
]

instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor that captures ambient lighting conditions for twin state enrichment"
    DTDFVocab:producedData LightingDataStream
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance LuminanceDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LuminanceSensor
]

instance CO2DataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance PresenceDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PresenceSensor
]

instance LightingDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature reading stream from indoor environmental sensor"
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo EclipseHonoDeviceGateway, EclipseDittoTwinManager
]

instance LuminanceData : DTDFVocab:Data [
    base:desc "Luminance reading stream from indoor lighting sensor"
    DTDFVocab:fromData LuminanceDataStream
    DTDFVocab:inputTo EclipseHonoDeviceGateway, EclipseDittoTwinManager
]

instance CO2Data : DTDFVocab:Data [
    base:desc "CO₂ concentration stream reflecting indoor air quality"
    DTDFVocab:fromData CO2DataStream
    DTDFVocab:inputTo EclipseHonoDeviceGateway, EclipseDittoTwinManager
]

instance PresenceData : DTDFVocab:Data [
    base:desc "Occupancy presence indicator stream"
    DTDFVocab:fromData PresenceDataStream
    DTDFVocab:inputTo EclipseHonoDeviceGateway, EclipseDittoTwinManager
]

instance LightingData : DTDFVocab:Data [
    base:desc "Ambient lighting level stream from lighting sensor"
    DTDFVocab:fromData LightingDataStream
    DTDFVocab:inputTo EclipseHonoDeviceGateway, EclipseDittoTwinManager
]

// C2: Acting components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator that receives control commands to adjust indoor illumination levels"
]

instance HVACControlValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC control valve actuator for regulating airflow and temperature in the building"
]

instance BuildingControlSystemActuator : DTDFVocab:ActingComponent [
    base:desc "Generic building control system actuator interfacing with the digital twin for command execution"
]

// C10: Models/Data
instance BIMIfcModel : DTDFVocab:Model [
    base:desc "Static BIM model (IFC‑based) providing geometric and semantic data of the Living Lab building"
    DTDFVocab:inputTo UnrealEngine5Platform, ModelDrivenSimulationEngine
]

instance RuntimeTwinModel : DTDFVocab:Model [
    base:desc "Runtime twin model capturing sensor streams, control logic and state synchronization"
    DTDFVocab:inputTo ReinforcementLearningEngine, PredictiveAnalyticsEngine
]

instance ODTEMetricModel : DTDFVocab:Model [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric model quantifying alignment between physical and virtual models"
    DTDFVocab:inputTo PredictiveAnalyticsEngine
]

// C11: Enablers
instance EclipseHonoDeviceGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono component for secure MQTT telemetry ingestion from building sensors"
    DTDFVocab:enables RealTimeMonitoringDashboardService, BuildingPerformanceSimulationService
]

instance EclipseDittoTwinManager : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto service that stores twin state and provides query APIs"
    DTDFVocab:enables RealTimeMonitoringDashboardService, RLLightingControlOptimizationService, PredictiveFacilityManagementAnalyticsService
]

instance UnrealEngine5Platform : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime for immersive 3D visualization of the digital twin"
    DTDFVocab:enables UnrealEngine5VisualizationService
]

instance ModelDrivenSimulationEngine : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering engine that runs building performance simulations using BIM and runtime models"
    DTDFVocab:enables BuildingPerformanceSimulationService
]

instance ReinforcementLearningEngine : DTDFVocab:Enabler [
    base:desc "Reinforcement‑learning engine that derives lighting control policies from twin data"
    DTDFVocab:enables RLLightingControlOptimizationService
]

instance PredictiveAnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Predictive analytics engine that generates alerts and recommendations for facility management"
    DTDFVocab:enables PredictiveFacilityManagementAnalyticsService
]

// C6: Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards presenting live sensor streams and twin state"
    DTDFVocab:provides PredictiveAlertInsight
]

instance UnrealEngine5VisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D visualization of the Living Lab building in Unreal Engine 5"
    DTDFVocab:provides EnergySavingLightingScheduleRecommendation
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance (thermal, lighting) based on BIM and runtime data"
    DTDFVocab:provides RLDerivedControlPolicyInsight
]

instance RLLightingControlOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based lighting control optimization service"
    DTDFVocab:provides AdjustLightingScheduleAction
]

instance PredictiveFacilityManagementAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for facility management delivering alerts and recommendations"
    DTDFVocab:provides PredictiveAlertInsight, EnergySavingLightingScheduleRecommendation
]

// C17: Insights
instance EnergySavingLightingScheduleRecommendation : DTDFVocab:Insight [
    base:desc "Optimization recommendation for energy‑saving lighting schedules derived from twin analysis"
]

instance PredictiveAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive alert generated from sensor trends indicating potential facility issues"
]

instance RLDerivedControlPolicyInsight : DTDFVocab:Insight [
    base:desc "Reinforcement‑learning derived control policy for lighting that balances energy use and occupant comfort"
]

// C17: Actions
instance AdjustLightingScheduleAction : DTDFVocab:Action [
    base:desc "Suggested adjustment to lighting dimmer setpoints based on optimization recommendations"
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points, HVAC set‑points) are dispatched back to actuators through the Hono/Ditto middleware, enabling live actuation of the physical building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Live, real‑time synchronization (sub‑second to second granularity) between physical sensors/actuators and the Digital Twin via the Hono/Ditto data pipeline."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where enriched BIM models feed a configurator that generates Hono/Ditto runtime artifacts; middleware mediates bidirectional data flow; services and visualisation are plugged in via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the entire building lifecycle: design (BIM model creation), construction (device configuration), operation (runtime monitoring and control), and refurbishment/adaptation phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to evaluate how accurately the twin reflects its physical counterpart, providing a quantitative fidelity assessment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time communication is realized through Eclipse Hono (supporting MQTT/HTTPS protocols) coupled with Eclipse Ditto (HTTP/WebSocket API) for twin state management and command dissemination."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution is built on BIM standards (ISO 19650/IFC) and utilizes open integration protocols provided by Eclipse Hono and Ditto, aligning with industry‑wide interoperability standards."
]