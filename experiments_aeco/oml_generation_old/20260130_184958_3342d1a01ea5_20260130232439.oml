// C3: Physical sensing components
instance BuildingIoTSensor : DTDFVocab:SensingComponent [
    base:desc "IoT sensors distributed throughout the building, defined as first‑class objects in the enriched BIM model, providing measurements that feed the real‑time data exchange layer."
    DTDFVocab:producedData BuildingSensorDataTransmitted
]

// C4: Data transmitted from sensors
instance BuildingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingIoTSensor
]

// C5: Data derived from transmitted streams
instance LiveSensorData : DTDFVocab:Data [
    base:desc "Live sensor data streams received continuously from the physical building sensors."
    DTDFVocab:fromData BuildingSensorDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchangeEngine, AnalyticsEngine, VisualizationEngine
]

// C11: Enablers
instance RealTimeDataExchangeEngine : DTDFVocab:Enabler [
    base:desc "Real‑time data exchange layer that synchronizes sensor and actuator data between the physical building and the digital twin."
    DTDFVocab:enables RealTimeMonitoringService
]

instance AnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Analytics engine that processes live sensor data for predictive analytics and fault detection."
    DTDFVocab:enables PredictiveAnalyticsService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Physics‑based simulation engine using building performance models."
    DTDFVocab:enables PhysicsBasedSimulationService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Immersive 3D visualization engine delivering dashboards and interactive virtual model views."
    DTDFVocab:enables ImmersiveVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of sensor streams, keeping the digital representation aligned with the physical building."
    DTDFVocab:provides LiveBuildingStateInsight
]

instance PhysicsBasedSimulationService : DTDFVocab:Service [
    base:desc "Executes physics‑based simulations of building performance using enriched BIM models."
    DTDFVocab:provides PerformanceSimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Runs predictive analytics for energy forecasting and fault detection, delivering alerts and recommendations."
    DTDFVocab:provides EnergyForecastInsight, FaultDetectionAlert
]

instance LifeCycleOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes life‑cycle HVAC and lighting schedules based on continuous data and analytics."
    DTDFVocab:provides HVACScheduleOptimizationAction, LightingScheduleOptimizationAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Delivers immersive visualization of the virtual model with live state, alarms and control options."
    DTDFVocab:provides ThreeDVisualizationInsight, ControlCommandAction
]

// C17: Insights
instance LiveBuildingStateInsight : DTDFVocab:Insight [
    base:desc "Live view of building state, alarms and sensor values presented to Facility Managers."
]

instance PerformanceSimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results of building performance used for decision support."
]

instance EnergyForecastInsight : DTDFVocab:Insight [
    base:desc "Predictive energy consumption forecasts generated by analytics services."
]

instance FaultDetectionAlert : DTDFVocab:Insight [
    base:desc "Alerts indicating detected faults or anomalies in building systems."
]

instance ThreeDVisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive 3D visual representation of the building, showing live data overlay."
]

// C17: Actions
instance HVACScheduleOptimizationAction : DTDFVocab:Action [
    base:desc "Optimized HVAC scheduling actions derived from life‑cycle analytics."
    DTDFVocab:IsAutomatic true
]

instance LightingScheduleOptimizationAction : DTDFVocab:Action [
    base:desc "Optimized lighting scheduling actions derived from life‑cycle analytics."
    DTDFVocab:IsAutomatic true
]

instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Facility Manager or DT Engineer command to actuators (e.g., adjust HVAC setpoints) issued via the digital twin."
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator defined in the BIM model with a logical control interface remotely invocable through the digital twin."
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator defined in the BIM model with a logical control interface remotely invocable through the digital twin."
]

// C10: Models
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Static BIM geometry model enriched with device definitions."
    DTDFVocab:inputTo SimulationEngine, VisualizationEngine
]

instance DeviceMetadataModel : DTDFVocab:Model [
    base:desc "Metadata model describing sensors, actuators and their logical interfaces."
    DTDFVocab:inputTo RealTimeDataExchangeEngine, SimulationEngine
]

// C5: Data derived from models
instance BIMGeometryData : DTDFVocab:Data [
    base:desc "Geometric data extracted from the BIM model."
    DTDFVocab:fromData BIMGeometryModel
    DTDFVocab:inputTo SimulationEngine, VisualizationEngine
]

instance DeviceMetadataData : DTDFVocab:Data [
    base:desc "Device metadata describing sensing and acting components."
    DTDFVocab:fromData DeviceMetadataModel
    DTDFVocab:inputTo RealTimeDataExchangeEngine, SimulationEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin can issue control commands back to the physical building in real time, enabling facility managers to monitor and control building systems through the DT. Interaction is bidirectional, yet the document does not specify command types, message formats, validation/authentication methods, feedback loops, conflict resolution, or execution confirmation details."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework addresses the complete Digital Twin lifecycle: (1) device modeling within BIM where sensors, actuators, and controllers are defined; (2) enrichment of the BIM model to create a unified semantic foundation; (3) Model‑Driven Engineering (MDE) extraction of structured representations from the enriched BIM; (4) automatic generation of deployable DT artifacts (e.g., service descriptors, configuration files); (5) runtime operation with real‑time data exchange that continuously synchronises the physical building and its twin; (6) evolution and extension through a modular architecture with standardized extension points that allow integration of custom services and analytics. Transitions between these phases are orchestrated by the deployment toolchain, and lifecycle governance is implemented through role‑based responsibilities (Building Control Engineer, Facility Manager, DT Engineer) defined in Table I."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The solution is built on a modular architecture with standardized extension points and runtime configuration management, aimed at supporting interoperability across heterogeneous systems, scalability from component to infrastructure level, maintainability, and accessibility. Specific network protocols, topology, bandwidth, latency, redundancy, or security mechanisms for the underlying communication infrastructure are not provided in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin framework acts as a central hub that integrates enriched BIM models with operational DTs and supports modular extensions and runtime configuration, implying flexibility in deployment (e.g., cloud, edge, or on‑premise). However, the document does not give explicit details on hosting platforms, computational and storage requirements, scalability mechanisms, supported deployment models, or availability/reliability assurances."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is grounded in Building Information Modeling (BIM), which serves as the foundational industry standard for representing building assets. A dedicated modeling methodology is used to standardize BIM semantics, ensuring a consistent semantic basis for the model‑driven transformation pipeline. The Digital Twin architecture provides standardized extension points that define interoperable interfaces for custom services and analytics plugins, facilitating integration across tools and vendors."
]