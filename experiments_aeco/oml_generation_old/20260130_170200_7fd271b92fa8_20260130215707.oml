// C3: Physical sensing components
instance BuildingTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in the enriched BIM and registered as a device in Eclipse Ditto."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance BuildingOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in the enriched BIM and registered as a device in Eclipse Ditto."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance BuildingLightSensor : DTDFVocab:SensingComponent [
    base:desc "Light level sensor modeled in the enriched BIM and registered as a device in Eclipse Ditto."
    DTDFVocab:producedData LightLevelDataTransmitted
]

// C4: Data transmitted from sensors
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingTemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingOccupancySensor
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingLightSensor
]

// C10: Data instances derived from transmissions
instance TemperatureMeasurementData : DTDFVocab:Data [
    base:desc "Real‑time temperature measurements streamed via Eclipse Hono into the twin."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchangeLayer
]

instance OccupancyMeasurementData : DTDFVocab:Data [
    base:desc "Real‑time occupancy counts streamed via Eclipse Hono into the twin."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchangeLayer
]

instance LightLevelMeasurementData : DTDFVocab:Data [
    base:desc "Real‑time light level values streamed via Eclipse Hono into the twin."
    DTDFVocab:fromData LightLevelDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchangeLayer
]

// C10: Models/Data used by the DT
instance EnrichedBIMGeometricModel : DTDFVocab:Model [
    base:desc "Primary geometric model of the building stored in the enriched BIM repository."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance DeviceSemanticModel : DTDFVocab:Model [
    base:desc "Device model encapsulating sensors, actuators and controllers extracted from BIM."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic authored by Building Control Engineers in BIM."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance PolicyValidationModel : DTDFVocab:Model [
    base:desc "Policy‑based validation rules stored in Eclipse Ditto to enforce safety constraints."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

// C11: Enablers (tools & infrastructure)
instance EnrichedBIMRepository : DTDFVocab:Enabler [
    base:desc "Enriched BIM model acting as the base semantic repository for the twin."
    DTDFVocab:enables RealTimeMonitoringService, BuildingControlService, InteractiveVisualizationService
]

instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "MDE framework that extracts structured representations from BIM and auto‑generates deployable DT artifacts."
    DTDFVocab:enables RealTimeMonitoringService, BuildingControlService, InteractiveVisualizationService, SimulationAnalysisService, PredictiveAnalyticsService
]

instance ModularArchitectureExtensionPoints : DTDFVocab:Enabler [
    base:desc "Modular architecture with standardized extension points for plug‑in custom services."
    DTDFVocab:enables SimulationAnalysisService, PredictiveAnalyticsService
]

instance RealTimeDataExchangeLayer : DTDFVocab:Enabler [
    base:desc "Bidirectional communication layer synchronising physical and digital states in real time."
    DTDFVocab:enables RealTimeMonitoringService, BuildingControlService
]

instance InteractiveVisualizationComponent : DTDFVocab:Enabler [
    base:desc "Immersive UE5 visualization component for monitoring and control."
    DTDFVocab:enables InteractiveVisualizationService
]

instance EclipseDittoStorage : DTDFVocab:Enabler [
    base:desc "Persistent event storage and policy‑based validation provided by Eclipse Ditto."
    // No direct services referenced here; used internally by other enablers
]

instance EclipseHonoMessaging : DTDFVocab:Enabler [
    base:desc "At‑least‑once messaging gateway (Eclipse Hono) delivering sensor data to the twin."
    // No direct services; messages flow through RealTimeDataExchangeLayer
]

// C6: Services delivered by the twin
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides continuous real‑time monitoring of building sensor states."
    DTDFVocab:provides FacilityOperationalInsight
]

instance BuildingControlService : DTDFVocab:Service [
    base:desc "Executes control logic to command actuators such as lights, HVAC, etc."
    DTDFVocab:provides ActuationControlAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Delivers immersive visualization of building states for Facility Managers."
    DTDFVocab:provides ImmersiveVisualizationInsight
]

instance SimulationAnalysisService : DTDFVocab:Service [
    base:desc "Supports simulation‑based analysis and optimization of operational performance."
    DTDFVocab:provides SimulationOptimizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Provides predictive analytics for decision‑making based on continuous data streams."
    DTDFVocab:provides PredictiveDecisionInsight
]

// C17: Insights and actions
instance FacilityOperationalInsight : DTDFVocab:Insight [
    base:desc "Operational insight enabling Facility Managers to monitor system states and receive alerts."
]

instance ActuationControlAction : DTDFVocab:Action [
    base:desc "Action to control physical actuators (e.g., turn lights on/off, adjust brightness)."
    DTDFVocab:IsAutomatic false
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight generated by the immersive UE5 visualisation layer for interactive monitoring."
]

instance SimulationOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulation analysis to optimize building performance."
]

instance PredictiveDecisionInsight : DTDFVocab:Insight [
    base:desc "Insight offering predictive decision support for facility management."
]

// C2: Acting components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Twin representation of a lighting actuator materialized in UE5; receives commands via UnrealTwinController."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin supports bidirectional control flows: facility managers interact with the deployed DT for real‑time monitoring and issue control commands that are forwarded to physical building systems via the DT Framework. The framework acts as a central hub for sending commands from the virtual model to physical devices, but the documents do not detail command types, message formats, validation/authentication, feedback loops, conflict resolution, or execution confirmations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT framework adopts a modular, hub‑centric architecture. A central DT Framework component acts as the integration hub, providing standardized extension points for custom services and analytics. It mediates continuous bidirectional data exchange between the physical building and its digital counterpart and supports runtime configuration management, allowing adjustments without full redeployment. Roles such as Building Control Engineers (device modelling and deployment), Facility Managers (real‑time monitoring and control), and DT Engineers (service integration) interact with the hub, enabling coordinated life‑cycle management of the digital twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The proposed model‑driven deployment framework covers the full DT life‑cycle, starting with device modeling within the BIM environment (definition of sensors, actuators and controllers), followed by model‑driven engineering (MDE) that extracts structured representations from the enriched BIM model, automatic generation of deployable DT artefacts, deployment of the twin, and runtime operation where real‑time data exchange keeps the physical building synchronised with its digital counterpart. The framework also supports post‑deployment extension through custom services, representing an evolution from initial modelling to operational monitoring and analytics."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by a multi‑stage validation pipeline: enriched BIM models undergo structural validation, device configurations are checked against Ditto policies for value ranges and units, and actuator commands are subjected to pre‑execution checks to avoid unsafe actions. Synchronization errors are mitigated by Eclipse Hono’s at‑least‑once delivery and Ditto’s persistent event storage, providing fault tolerance. The use of policy‑based validation and persistent storage constitutes the primary quality‑assurance mechanisms; no explicit uncertainty quantification or additional verification methods are described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The proposed solution relies on a modular architecture with standardized extension points that enables interoperability across heterogeneous systems. Connectivity is achieved through a central DT Framework that can integrate services such as those provided by open‑source frameworks like Eclipse Ditto or BaSyx, which claim standard‑compliant communication. However, the documents do not describe the concrete network topology, specific communication protocols, bandwidth or latency requirements, redundancy mechanisms, or security protocols for the network layer."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment is initiated by building control engineers using BIM tools to model devices and trigger the deployment process; the DT Framework then hosts the digital twin as a central hub that can be reconfigured at runtime without full redeployment. While the framework supports modular, runtime‑configurable deployment, the documents do not specify the hosting platform (cloud, edge, on‑premise), computational or storage sizing, scalability strategies, supported deployment models, or availability/reliability guarantees."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution adopts a modular architecture with standardized extension points for integrating custom services, and the related work notes that open‑source DT frameworks such as Eclipse Ditto and BaSyx offer standard compliance and interoperability, although specific industry standards (e.g., IFC, ISO 19650) are not cited in the documents."
]