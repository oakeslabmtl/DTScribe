// Component representing the physical building asset
instance CommercialBuildingAsset : DTDFVocab:Component [
    base:desc "Commercial building asset used as the subject of the digital twin, incorporating structural, HVAC, electrical, lighting, and control subsystems."
]

// Environment encapsulating the building component
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains CommercialBuildingAsset
]

// Sensing component that collects real‑time building state
instance BuildingStateSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real‑time building state from HVAC, electrical, and lighting subsystems for digital twin synchronization."
    DTDFVocab:producedData BuildingStateDataTransmitted
]

// Data transmitted from the sensing component
instance BuildingStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingStateSensor
]

// Structured data stored in the twin platform
instance BuildingStateData : DTDFVocab:Data [
    base:desc "Structured representation of building state stored in Eclipse Ditto, including unit‑validated and range‑checked values."
    DTDFVocab:fromData BuildingStateDataTransmitted
    DTDFVocab:inputTo RealtimeDataExchangeTool
]

// Geometric model derived from enriched BIM
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Enriched BIM mesh rendered by UE5 via LightTwinComponent, capturing geometric layout and photometric values."
    DTDFVocab:inputTo BIMEnrichmentTool
]

// Behavioral twin model implemented in UE5
instance BehavioralTwinModel : DTDFVocab:Model [
    base:desc "UE5 TwinComponents implementing observer pattern to expose device control commands and observe device values."
    DTDFVocab:inputTo MDETransformationTool
]

// Analytical state model managed by Eclipse Ditto
instance AnalyticalStateModel : DTDFVocab:Model [
    base:desc "Runtime state managed by Eclipse Ditto, enforcing user‑defined policies for safety checks and persistence."
    DTDFVocab:inputTo RealtimeDataExchangeTool
]

// Enabler that enriches BIM with semantic annotations
instance BIMEnrichmentTool : DTDFVocab:Enabler [
    base:desc "Tool that enriches BIM models with semantic annotations for sensors, actuators, and controllers."
    DTDFVocab:enables RealTimeMonitoringService
]

// Model‑driven engineering pipeline transforming BIM into twin artefacts
instance MDETransformationTool : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline that transforms enriched BIM into structured twin artefacts."
    DTDFVocab:enables PredictiveAnalyticsService
]

// Eclipse Hono‑based channel for real‑time data exchange
instance RealtimeDataExchangeTool : DTDFVocab:Enabler [
    base:desc "Eclipse Hono‑based channel that provides at‑least‑once message delivery between physical devices and Ditto."
    DTDFVocab:enables RealTimeMonitoringService, AutomaticControlService, Immersive3DVisualizationService
]

// Immersive 3D visualization layer rendering twin in UE5
instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Immersive 3D visualization layer rendering twin in Unreal Engine 5."
    DTDFVocab:enables Immersive3DVisualizationService
]

// Modular architecture framework for extensibility
instance ModularExtensionFramework : DTDFVocab:Enabler [
    base:desc "Modular architecture with standardized extension points for custom services and analytics."
    DTDFVocab:enables EnergyOptimizationService
]

// Service for real‑time monitoring of building state
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building state through continuous data stream."
    DTDFVocab:provides ControlFeedbackInsight
]

// Service for predictive analytics and condition monitoring
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for condition and fault detection using stored state."
    DTDFVocab:provides FaultDetectionInsight
]

// Service for energy and operational optimization
instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes energy and operational performance based on model outputs."
    DTDFVocab:provides EnergySavingsInsight
]

// Service for automatic control command integration
instance AutomaticControlService : DTDFVocab:Service [
    base:desc "Automatic control integration for building systems via command handling."
    DTDFVocab:provides AdjustLightingAction, AdjustHVACAction
]

// Service for immersive 3D visualization of twin
instance Immersive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization for immersive stakeholder engagement."
    DTDFVocab:provides VisualizationInsight
]

// Insight indicating fault detection from analytics
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating detected faults based on predictive analytics."
]

// Insight providing energy‑saving opportunities
instance EnergySavingsInsight : DTDFVocab:Insight [
    base:desc "Insight providing opportunities for energy savings."
]

// Insight offering control feedback in visualization
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight offering feedback on control actions within the immersive 3D view."
]

// Insight offering control feedback from real‑time monitoring
instance ControlFeedbackInsight : DTDFVocab:Insight [
    base:desc "Insight offering feedback on control actions derived from real‑time monitoring."
]

// Automatic action to adjust lighting parameters
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Action to adjust lighting brightness and color temperature via Ditto command."
    DTDFVocab:IsAutomatic true
]

// Automatic action to adjust HVAC setpoints
instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Action to adjust HVAC setpoints through controller."
    DTDFVocab:IsAutomatic true
]

// Manual action to trigger maintenance workflow
instance TriggerMaintenanceAction : DTDFVocab:Action [
    base:desc "Action to trigger maintenance workflow upon fault detection."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital control flows to physical assets are routed through the same bidirectional framework that handles data exchange. Facility Managers can initiate control actions via an interactive visualization interface, and Device Engineers can extend command capabilities through service integration. The documents do not specify the command formats, authentication or validation procedures, feedback mechanisms, conflict resolution strategies, or execution‑confirmation protocols used in the control path."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange capabilities ensure continuous synchronization between the physical building and its digital twin, enabling an up‑to‑date representation of the system state. The architecture supports low‑latency bidirectional communication, suitable for operational control and predictive analytics; however, explicit synchronization frequencies, latency thresholds, and temporal granularity are not specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin system follows a modular, service‑oriented architecture where a central DT Framework hub coordinates enriched BIM models, runtime data, and extensions. Components include device modeling workflows executed by Building Control Engineers, real‑time monitoring interfaces used by Facility Managers, and extensible services added by DT Engineers. Runtime configuration management allows dynamic adaptation of the system without full redeployment, while standardized extension points and a centralized bidirectional data bus facilitate orchestration and resource management across the digital twin ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Device modeling and enrichment within BIM (Defining sensors, actuators, controllers), MDE‑based extraction of structured artefacts, automated generation of deployable Digital Twin components, deployment to runtime with real‑time bidirectional data exchange, immersive visualization, and subsequent customization via modular extension points. Transition management is achieved through automated transformation pipelines, while lifecycle governance is enforced by the framework’s standardized extension points and minimal manual intervention."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through policy‑based validation in Eclipse Ditto, which enforces sensor data to respect predefined value ranges and units, and pre‑execution checks that prevent unsafe actuator commands.  Runtime fault tolerance is provided by Hono’s at‑least‑once message delivery, which guarantees that no event is lost even in the face of network failures, and Ditto’s persistent event storage, which allows state recovery and replay.  Symptom checks for actuator conflicts and safety violations are performed before command execution, thus providing a basic error detection and correction mechanism.  No explicit quantitative uncertainty bounds or verification procedures are detailed in the cited documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT framework is architected to be interoperable with heterogeneous systems, providing real‑time bidirectional communication between physical and digital entities. The documents do not enumerate the underlying network protocols, topology, bandwidth, latency, reliability, redundancy, or security mechanisms, but assert that runtime configuration management allows adaptation of network parameters without full redeployment."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosting specifics are not described; the framework's modular architecture and runtime configuration suggest flexibility for deployment on cloud, edge, or on‑premise platforms. Computational and storage requirements, scalability strategies, supported deployment models, and availability or reliability guarantees are not provided in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The framework achieves interoperability with heterogeneous systems through standardized extension points and real‑time data exchange protocols (details unspecified). It integrates enriched BIM models from conventional Building Information Modeling tools and supports bidirectional communication with external subsystems such as building automation controllers and enterprise resource planning (ERP) systems. The architecture is designed to accommodate additional digital twins and enterprise services via modular interfaces, ensuring seamless data flow across the building lifecycle."
]