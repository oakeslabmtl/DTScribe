// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in the BIM model providing live occupancy data"
    DTDFVocab:producedData OccupancyTelemetry
]

instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor defined in the BIM model providing live illumination level data"
    DTDFVocab:producedData LightingTelemetry
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor (temperature, humidity) defined in the BIM model providing live environmental data"
    DTDFVocab:producedData EnvironmentalTelemetry
]

// C2: Acting components
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control device modeled in the BIM model and addressable by the twin"
]

// C4: Physical-to-virtual interaction (sensor telemetry)
instance OccupancyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightingTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance EnvironmentalTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C4: Physical-to-virtual interaction (actuator state)
instance ActuatorStateTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingControlActuator
]

// C10: Data instances
instance OccupancyData : DTDFVocab:Data [
    base:desc "Continuous occupancy data stream from OccupancyTelemetry"
    DTDFVocab:fromData OccupancyTelemetry
    DTDFVocab:inputTo EclipseHonoConnector
]

instance LightingData : DTDFVocab:Data [
    base:desc "Continuous lighting level data stream from LightingTelemetry"
    DTDFVocab:fromData LightingTelemetry
    DTDFVocab:inputTo EclipseHonoConnector
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Continuous environmental data stream (temperature, humidity) from EnvironmentalTelemetry"
    DTDFVocab:fromData EnvironmentalTelemetry
    DTDFVocab:inputTo EclipseHonoConnector
]

instance ControlStateData : DTDFVocab:Data [
    base:desc "Current state of lighting control actuators"
    DTDFVocab:fromData ActuatorStateTelemetry
    DTDFVocab:inputTo EclipseDittoConnector
]

// C10: Model instances
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with device metadata, control logic, and runtime semantics"
    DTDFVocab:inputTo EclipseDittoConnector, EclipseHonoConnector
]

instance RuntimeArtifactsModel : DTDFVocab:Model [
    base:desc "Generated runtime artifacts for the digital twin deployment"
    DTDFVocab:inputTo EclipseDittoConnector
]

// C11: Enablers
instance EclipseHonoConnector : DTDFVocab:Enabler [
    base:desc "Eclipse Hono connector for ingesting live telemetry from physical sensors"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance EclipseDittoConnector : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto connector for managing twin state, runtime models and control actions"
    DTDFVocab:enables SimulationService, EnergyOptimizationService, UserDrivenControlService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 integration for interactive 3D visualization of the building twin"
    DTDFVocab:enables InteractiveVisualizationService
]

instance BIMModelingTool : DTDFVocab:Enabler [
    base:desc "BIM modeling tools used to create and enrich the building information model"
    DTDFVocab:enables RealTimeMonitoringService
]

instance ModelDrivenEngineeringMethodology : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering methodology that automates generation of runtime artifacts"
    DTDFVocab:enables SimulationService, EnergyOptimizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building performance using live sensor data"
    DTDFVocab:provides RealTimeInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization of the building twin via Unreal Engine 5"
    DTDFVocab:provides VisualizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building behavior based on runtime semantics and control logic"
    DTDFVocab:provides SimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for occupancy patterns and energy consumption"
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of energy use and occupant comfort based on predictive insights"
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance UserDrivenControlService : DTDFVocab:Service [
    base:desc "User‑driven control of building actuators through the digital twin interface"
    DTDFVocab:provides ControlAction
]

// C17: Insights
instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into building occupancy, lighting levels, and environmental conditions"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D view of the current state of the building twin"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation outcome of building performance under various scenarios"
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predicted future occupancy and energy consumption patterns"
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for optimizing energy use and occupant comfort"
]

// C17: Actions
instance ControlAction : DTDFVocab:Action [
    base:desc "Command issued to lighting control actuators to adjust illumination levels"
    DTDFVocab:IsAutomatic false
]

// Environment (optional grouping)
instance BuildingTwinEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, LightingSensor, EnvironmentalSensor, LightingControlActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points) are sent back to physical actuators through the same Hono/Ditto bidirectional communication channel."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time synchronization between physical assets and the digital twin."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture with a central DT framework hub that mediates bidirectional data exchange and allows plug‑in services via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin supports the full building lifecycle: design (BIM creation), construction (device commissioning) and operation (ongoing monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to quantify how accurately the twin reflects its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time data exchange is implemented with Eclipse Hono and Eclipse Ditto, providing bidirectional communication between sensors/actuators and the twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM is used as the semantic backbone following industry modeling standards; the framework provides standardized extension points and model‑driven engineering guidelines for interoperability."
]