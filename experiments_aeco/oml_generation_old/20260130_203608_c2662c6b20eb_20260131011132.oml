// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in the BIM device model, providing continuous temperature readings from the building zones."
    DTDFVocab:producedData TemperatureDataStream
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor modeled in BIM, delivering real‑time relative humidity measurements."
    DTDFVocab:producedData HumidityDataStream
]

instance AirflowSensor : DTDFVocab:SensingComponent [
    base:desc "Airflow sensor integrated in the BIM model, measuring ventilation flow rates."
    DTDFVocab:producedData AirflowDataStream
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance AirflowDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirflowSensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature measurement data streamed in real time from TemperatureSensor."
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo EclipseHonoIngestion
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity measurement data streamed in real time from HumiditySensor."
    DTDFVocab:fromData HumidityDataStream
    DTDFVocab:inputTo EclipseHonoIngestion
]

instance AirflowData : DTDFVocab:Data [
    base:desc "Airflow measurement data streamed in real time from AirflowSensor."
    DTDFVocab:fromData AirflowDataStream
    DTDFVocab:inputTo EclipseHonoIngestion
]

// C11: Enablers
instance EclipseHonoIngestion : DTDFVocab:Enabler [
    base:desc "Eclipse Hono component for secure, scalable ingestion of IoT sensor data via MQTT/HTTPS."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance EclipseDittoStateManagement : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto platform managing the digital twin state and exposing event‑driven APIs."
    DTDFVocab:enables PhysicsSimulationService, EnergyOptimizationService, InteractiveVisualizationService, RealTimeMonitoringService
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine providing high‑fidelity 3‑D interactive visualization of the building twin."
    DTDFVocab:enables InteractiveVisualizationService
]

instance ContainerizedMiddleware : DTDFVocab:Enabler [
    base:desc "Container orchestration middleware (Docker Compose/Kubernetes) linking ingestion, state management and visualisation layers."
    DTDFVocab:enables RealTimeMonitoringService, PhysicsSimulationService, EnergyOptimizationService, PredictiveAnalyticsService, InteractiveVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of sensor streams, keeping the twin synchronized with the physical building."
    DTDFVocab:provides MonitoringInsight, AdjustHVACAction
]

instance PhysicsSimulationService : DTDFVocab:Service [
    base:desc "Physics‑based simulation of building performance using geometric and material data."
    DTDFVocab:provides SimulationInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Life‑cycle wide optimisation of energy consumption and scheduling of maintenance actions."
    DTDFVocab:provides EnergyConsumptionInsight, EnergyOptimizationInsight, ScheduleMaintenanceAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for fault detection and occupancy trend analysis."
    DTDFVocab:provides FaultDetectionInsight, OccupancyTrendInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3‑D visualisation for stakeholders, exposing twin state and enabling manual control."
    DTDFVocab:provides VisualizationInsight, AdjustHVACAction
]

// C17: Insights
instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight showing current temperature, humidity and airflow levels across building zones."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight delivering simulated thermal performance and energy demand under various scenarios."
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight presenting aggregated energy consumption patterns derived from sensor data."
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal set‑points for HVAC to reduce energy usage."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting anomalous sensor behaviour indicating possible equipment faults."
]

instance OccupancyTrendInsight : DTDFVocab:Insight [
    base:desc "Insight revealing occupancy trends extracted from integrated sensor analytics."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight visualising building state in high‑fidelity 3‑D within Unreal Engine."
]

// C17: Actions
instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Action to remotely adjust HVAC actuator set‑points via the digital twin interface."
    DTDFVocab:IsAutomatic false
]

instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Action to schedule preventive maintenance tasks based on lifecycle optimisation results."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance BuildingActuator : DTDFVocab:ActingComponent [
    base:desc "Generic building actuator defined in the BIM model, controllable through the digital twin runtime."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator (e.g., damper or valve) allowing remote control of airflow and temperature."
]

// C10: Models
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Primary geometric representation of the building extracted from the BIM model."
    DTDFVocab:inputTo UnrealEngineVisualization, EclipseDittoStateManagement
]

instance DeviceModel : DTDFVocab:Model [
    base:desc "Device model capturing sensors, actuators and controller definitions embedded in the BIM artifact."
    DTDFVocab:inputTo EclipseDittoStateManagement
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model expressing control logic authored by Building Control Engineers within BIM."
    DTDFVocab:inputTo EclipseDittoStateManagement
]

instance EnergyAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model used by EnergyOptimizationService for life‑cycle energy analysis."
    DTDFVocab:inputTo EclipseDittoStateManagement
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Virtual‑to‑physical interaction is enabled by the DT Framework acting as a central hub that supports bidirectional data exchange. Facility Managers can issue control commands from the Digital Twin to the building’s physical infrastructure for real‑time monitoring and actuation, with the framework handling the propagation of those commands back to the physical assets."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real-time data exchange that maintains continuous synchronization between the physical building and its digital counterpart; synchronization occurs as soon as sensor or system updates are generated, supporting low-latency, ongoing bidirectional updates (no explicit frequency or latency values are specified)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT system follows a modular, service-oriented architecture centered on a DT Framework acting as a hub; standardized extension points allow integration of custom analytics and services, and runtime configuration management enables on-the-fly adjustments without redeployment. Roles (Building Control Engineers, Facility Managers, DT Engineers) interact with the hub to model devices, monitor/control, and extend functionality, resulting in a coordinated orchestration of components."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The proposed model‑driven deployment framework covers the full DT lifecycle: (1) Device modeling – building control engineers enrich BIM models with semantic definitions of sensors, actuators and controllers; (2) Model extraction – MDE techniques automatically transform the enriched BIM into structured DT representations (e.g., service‑oriented component models); (3) Artifact generation – the extracted models are used to generate deployable DT artifacts such as runtime containers and communication adapters; (4) Deployment – the DT is instantiated and linked to the physical building; (5) Operation – continuous real‑time data exchange synchronises the physical and digital twins; (6) Evolution – modular extension points allow insertion of custom services and analytics. Transitions between these stages are managed by automated model‑to‑code pipelines and are governed by role‑based responsibilities (building control engineer, facility manager, DT engineer)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on a modular communication layer that abstracts underlying network protocols, supporting interoperability across heterogeneous systems. The architecture is designed for scalability from individual components to whole infrastructure, with runtime configuration and low‑overhead updates to maintain reliable communication, though specific protocols, topology, bandwidth, latency, or security mechanisms are not detailed in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment follows a model‑driven approach that transforms enriched BIM models into operational Digital Twins. The framework supports scalable deployment through modular components and runtime configuration management, allowing the DT to evolve with changing operational requirements; however, concrete hosting platforms (cloud, edge, on‑premise), computational/storage specifications, and availability mechanisms are not explicitly described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed through standardized extension points and support for heterogeneous external systems such as BIM tools; the framework enables bidirectional data exchange with external services and analytics, fulfilling non-functional requirements for cross-system integration, though specific data exchange protocols or standards are not detailed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach builds on the Building Information Modeling (BIM) standard as the foundational data model, extending it with semantic definitions for sensors and actuators. Internally, the framework enforces standardisation through modular, service‑oriented extension points that define uniform integration interfaces for custom DT services. External interoperability relies on compliance with AECO‑specific BIM specifications, while the modular architecture aims to align with general model‑driven engineering standards, though no additional industry standards (e.g., ISO, IEC) are explicitly cited."
]