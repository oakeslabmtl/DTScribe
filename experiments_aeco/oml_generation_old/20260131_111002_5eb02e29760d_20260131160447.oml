]

instance CommunicationProtocolInsight : DTDFVocab:Insight [
    base:desc "Standardized communication protocols between DT and physical systems"
]

instance TwinInstanceInsight : DTDFVocab:Insight [
    base:desc "Management of digital twin instances and their lifecycle"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D visualization of building performance metrics"
]

instance PerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Real-time building performance metrics and KPIs"
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance alerts based on sensor data analysis"
]

instance ControlPolicyInsight : DTDFVocab:Insight [
    base:desc "Reinforcement learning-based control policies for building systems"
]

instance ControlRuleInsight : DTDFVocab:Insight [
    base:desc "Rule-based control logic for building automation systems"
]

instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Results of what-if analyses for building performance under varying conditions"
]

