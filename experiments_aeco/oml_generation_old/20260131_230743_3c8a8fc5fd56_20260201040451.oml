// === Illumination Sensor Chain ===
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor embedded in BIM, publishes lux values at 1 Hz via Hono MQTT"
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Illumination telemetry (lux) validated by Ditto policy rules"
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo DittoTwinStoreIllumination
]

instance DittoTwinStoreIllumination : DTDFVocab:Enabler [
    base:desc "Ditto twin store ingesting illumination sensor values via Hono MQTT"
    DTDFVocab:enables IlluminationMonitoringService
]

instance IlluminationMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building illumination levels"
    DTDFVocab:provides IlluminationAlertInsight
]

instance IlluminationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert when illumination deviates outside 100–1000 lux range per policy"
]

// === Temperature Sensor Chain ===
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor publishing °C values at 1 Hz via Hono MQTT"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature telemetry (°C) validated by Ditto policy rules"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DittoTwinStoreTemperature
]

instance DittoTwinStoreTemperature : DTDFVocab:Enabler [
    base:desc "Ditto twin store ingesting temperature sensor values via Hono MQTT"
    DTDFVocab:enables TemperatureMonitoringService
]

instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building temperature levels"
    DTDFVocab:provides TemperatureAlertInsight
]

instance TemperatureAlertInsight : DTDFVocab:Insight [
    base:desc "Alert when temperature deviates outside 15–30 °C range per policy"
]

// === Occupancy Sensor Chain ===
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor publishing occupancy flags at 1 Hz via Hono MQTT"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy telemetry (binary) validated by Ditto policy rules"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo DittoTwinStoreOccupancy
]

instance DittoTwinStoreOccupancy : DTDFVocab:Enabler [
    base:desc "Ditto twin store ingesting occupancy sensor values via Hono MQTT"
    DTDFVocab:enables OccupancyMonitoringService
]

instance OccupancyMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of occupancy patterns"
    DTDFVocab:provides OccupancyPatternsInsight
]

instance OccupancyPatternsInsight : DTDFVocab:Insight [
    base:desc "Insight into recurring occupancy patterns for space utilization"
]

// === Light Actuator Chain ===
instance LightActuator : DTDFVocab:ActingComponent [
    base:desc "Light fixture controlled via DittoDevice, accepts power, brightness, and colour‑temperature commands"
]

instance LightCommandData : DTDFVocab:Data [
    base:desc "Command set for a light: power (ON/OFF), brightness (0–100 %), colour‑temperature (2700–6500 K)"
    DTDFVocab:inputTo DittoCommandEnforcer
]

instance DittoCommandEnforcer : DTDFVocab:Enabler [
    base:desc "Enforcer that validates Li****t command ranges before forwarding to Ditto controller"
    DTDFVocab:enables LightingControlService
]

instance LightingControlService : DTDFVocab:Service [
    base:desc "Service that executes light control commands and maintains state"
    DTDFVocab:provides SetLightPowerAction
    DTDFVocab:provides SetLightBrightnessAction
    DTDFVocab:provides SetLightColorTempAction
]

instance SetLightPowerAction : DTDFVocab:Action [
    base:desc "Action to turn lights ON/OFF"
    DTDFVocab:IsAutomatic false
]

instance SetLightBrightnessAction : DTDFVocab:Action [
    base:desc "Action to set light brightness (0–100 %)"
    DTDFVocab:IsAutomatic false
]

instance SetLightColorTempAction : DTDFVocab:Action [
    base:desc "Action to set lamp colour temperature (2700–6500 K)"
    DTDFVocab:IsAutomatic false
]

// === HVAC Actuator Chain (illustrative) ===
instance DittoHVACCommandEnforcer : DTDFVocab:Enabler [
    base:desc "Enforcer that validates HVAC command safety constraints before execution"
    DTDFVocab:enables HVACControlService
]

instance HVACControlService : DTDFVocab:Service [
    base:desc "Service to execute HVAC control rules and schedule adjustments"
    DTDFVocab:provides HVACControlAction
    DTDFVocab:provides HVACScheduleOptimizationInsight
]

instance HVACControlAction : DTDFVocab:Action [
    base:desc "Action to set HVAC set‑point temperature"
    DTDFVocab:IsAutomatic false
]

instance HVACScheduleOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight into optimized HVAC scheduling based on occupancy and temperature data"
]

// === Energy Optimization Service Chain ===
instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Service that performs real‑time energy optimisation using sensor data"
    DTDFVocab:provides EnergySavingsInsight
]

instance EnergySavingsInsight : DTDFVocab:Insight [
    base:desc "Insight into potential energy savings from optimisation strategies"
]

// === 3D Visualization Service ===
instance ThreeDVisualizationService : DTDFVocab:Service [
    base:desc "Service that maps live data onto a UE5 3‑D BIM model"
    DTDFVocab:provides VisualizationInsight
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive visual overlay of real‑time sensor telemetry on BIM"
]

// === Custom Analytics Service ===
instance CustomAnalyticsService : DTDFVocab:Service [
    base:desc "Plug‑in enabled analytics service for custom DT engineer extensions"
    DTDFVocab:provides CustomInsight
]

instance CustomInsight : DTDFVocab:Insight [
    base:desc "Custom analytic result produced by DT engineer plugin"
]

// === Predictive Maintenance Service Chain ===
instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Service that analyzes sensor streams to predict maintenance events"
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Insight into predicted maintenance needs for building equipment"
]

// === Model Chain ===
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Geometric 3‑D representation derived from enriched Revit BIM, includes photometric values and topology"
    DTDFVocab:inputTo ModelProcessor
]

instance DeviceBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model. Control logic and state machines derived from BIM component metadata"
    DTDFVocab:inputTo ModelProcessor
]

instance SensorActuatorMappingModel : DTDFVocab:Model [
    base:desc "Analytical model mapping sensor telemetry to actuator commands"
    DTDFVocab:inputTo ModelProcessor
]

instance ModelProcessor : DTDFVocab:Enabler [
    base:desc "Enabler that processes models and exposes analytical outputs"
    DTDFVocab:enables ModelAnalysisService
]

instance ModelAnalysisService : DTDFVocab:Service [
    base:desc "Service that runs model analysis and generates predictive insights"
    DTDFVocab:provides ModelPredictiveInsight
]

instance ModelPredictiveInsight : DTDFVocab:Insight [
    base:desc "Predictive insight based on BIM models and live sensor data"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework mandates real‑time data exchange capabilities to ensure continuous synchronization between the physical building and its digital counterpart, facilitating bidirectional data flow with minimal latency; however, explicit synchronization frequencies, latency thresholds, or temporal granularity levels are not specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration is built around a modular, extension‑point‑rich DT Framework that acts as a central hub for continuous bidirectional data exchange. It integrates components such as device controllers, visualization services, and custom analytics plugins through standardized APIs, while resource and lifecycle management are handled via runtime configuration, enabling the Digital Twin ecosystem to evolve seamlessly."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a multi‑stage life cycle that begins with device modeling inside Autodesk Revit, where Building Control Engineers create custom families and property sets for lights, HVAC, etc., tagging each instance with a global Instance General UUID and setting the IFC type (e.g., IFCLIGHTFIXTURETYPE). The enriched BIM model is exported to IFC and uploaded to the platform. A BC‑based semantic model extraction (F2) automatically transforms the IFC into a structured domain‑specific representation that can be used by the digital twin engine. One‑click deployment (F3) generates, configures and launches the DT artifacts automatically, exposing the twin through the chosen middleware stack (Eclipse Hono and Ditto). The twin then enters the runtime phase where real‑time, bi‑directional data exchange (F4), interactive 3‑D visualization (F5) and modular service extensions (F6) are employed. Throughout these phases, a runtime configuration management layer (F7) supports dynamic updates, parameter tuning and interface updates, ensuring continuous governance and traceability across the twin’s entire life cycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is quantified by the Overall Digital Twin Entanglement (ODTE) metric, measured over a 12‑minute window during the Living Lab experiment. The ODTE achieved a total score of 0.997, with timeliness 0.997 (≈700 ms delay), reliability 1.0 (no loss) and availability 1.0 (100 % uptime). The deployment pipeline incorporates an upfront model‑checking stage that enforces semantic constraints of enriched BIM, guaranteeing geometric, behavioural and analytical artefacts are valid before code generation. Ditto’s policy validation ensures all sensor telemetry and actuator commands respect defined value ranges and units, while pre‑execution checks prevent unsafe state transitions. Eclipse Hono’s at‑least‑once delivery and Ditto’s persistent event store provide fault tolerance, guaranteeing eventual consistency and resilience against transient network failures. These mechanisms collectively form a comprehensive quality‑assurance process for both models and data, ensuring consistency and traceability across the digital twin lifecycle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono forms the device‑to‑backend transport layer, supporting publish/subscribe over MQTT, CoAP and HTTP, with TLS encryption and optional OAuth2 for identity. Eclipse Ditto acts as the twin state service and exposes a WebSocket‑based real‑time API (alongside REST/HTTP) for subscribing to state transitions. The overall topology is a cloud‑hosted hub that aggregates data from distributed field devices, providing low‑latency, fault‑tolerant communication with in‑built message routing and retry logic. Network bandwidth demands are modest (typical 100 bytes–5 kB per sensor report) but the architecture is designed for scaling to thousands of active devices. Reliability is ensured through Hono’s consumer‑side acknowledgment and Ditto’s transactional state updates. Security is managed via TLS/SSL at the transport layer, per‑device certificates or JWTs for authentication, and role‑based access control enforced by Ditto’s policy engine."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through interoperability across heterogeneous infrastructures, adhering to industry standards. The framework exposes standardized data exchange interfaces and provides extension points for custom analytics, thereby enabling communication with external BIM datasets, IoT middleware, and enterprise applications."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework conforms to the BIM materialization stack and relies on the Industry Foundation Classes (IFC) open interchange format for the initial model representation. Device metadata is specified using IFC property sets and GUIDs, and the service layer is exposed through Eclipse Hono, providing MQTT‑based event transport compliant with industry IoT communication standards, while Eclipse Ditto offers a device twin API compliant with open twin management specifications. Standards such as ISO 19650 for BIM deliverables and ISO 27001 for information security are adhered to. The architecture promotes interoperability across heterogeneous BIM tools, IoT protocols (e.g., MQTT, HTTP/REST), and visualization systems (e.g., Unreal Engine 5). Modular extension points support standard OSGi‑style bundles or REST interfaces, aligning with widely accepted software componentization practices."
]