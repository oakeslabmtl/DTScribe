// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in BIM, streams building temperature measurements"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM, streams presence detection data"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor modeled in BIM, streams indoor light level measurements"
    DTDFVocab:producedData IlluminationDataTransmitted
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature data stream from building sensors"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy data stream from building sensors"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Live illumination data stream from building sensors"
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseDitto
]

// C2: Acting components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in BIM, receives commands to adjust illumination"
]

instance HVACController : DTDFVocab:ActingComponent [
    base:desc "HVAC controller modeled in BIM, receives set‑point commands for temperature regulation"
]

// C10: Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM artefacts containing geometry, topology, and device metadata transformed into runtime artefacts"
    DTDFVocab:inputTo ModelDrivenTransformation, EclipseDitto
]

// C11: Enablers
instance BIMAuthoringTool : DTDFVocab:Enabler [
    base:desc "BIM authoring tools used to create and enrich the building information model"
    DTDFVocab:enables RealTimeMonitoringDashboard
]

instance ModelDrivenTransformation : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering transformations that generate runtime artefacts from enriched BIM"
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalytics, EnergyOptimization, BuildingPerformanceSimulation
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides IoT connectivity, ingesting sensor streams and forwarding them to Ditto"
    DTDFVocab:enables RealTimeMonitoringDashboard
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital twin state, persisting sensor data and exposing it to services"
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalytics, EnergyOptimization, BuildingPerformanceSimulation
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 delivers immersive 3‑D interactive visualization of the building model"
    DTDFVocab:enables Interactive3DVisualization
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard displaying live sensor data and alerts"
    DTDFVocab:provides EnergyConsumptionTrendsInsight, ComfortLevelAlertInsight
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "3‑D interactive visualization in Unreal Engine 5 for immersive building exploration"
    DTDFVocab:provides ComfortLevelAlertInsight
]

instance PredictiveAnalytics : DTDFVocab:Service [
    base:desc "Predictive analytics service forecasting building performance and energy usage"
    DTDFVocab:provides EnergyConsumptionTrendsInsight
]

instance EnergyOptimization : DTDFVocab:Service [
    base:desc "Optimization service that computes energy‑efficient control set‑points"
    DTDFVocab:provides OptimizedControlSetPointAction
]

instance BuildingPerformanceSimulation : DTDFVocab:Service [
    base:desc "Simulation service that evaluates building performance under various scenarios"
    DTDFVocab:provides ComfortLevelAlertInsight
]

// C17: Insights
instance EnergyConsumptionTrendsInsight : DTDFVocab:Insight [
    base:desc "Insight on energy consumption trends derived from live sensor data"
]

instance ComfortLevelAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating discomfort levels based on occupancy and environmental conditions"
]

// C17: Actions
instance OptimizedControlSetPointAction : DTDFVocab:Action [
    base:desc "Action to adjust control set‑points for HVAC and lighting to optimize energy use"
    DTDFVocab:IsAutomatic true
]

instance AutomatedControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated adjustment of building control actuators based on optimization recommendations"
    DTDFVocab:IsAutomatic true
]

// Environment assembling the whole building twin
instance BuildingInfrastructureEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, OccupancySensor, IlluminationSensor,
                  LightingActuator, HVACController, EnrichedBIMModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., lighting dimming, HVAC set‑points) are sent back through Eclipse Ditto to Eclipse Hono, which delivers the commands to the respective actuators in the physical building, enabling bidirectional synchronization."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework is designed for near‑real‑time synchronization, with sensor data and control commands exchanged continuously through the Hono/Ditto middleware."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation consists of the enriched BIM model, an automatic configurator that generates Hono/Ditto device descriptors, the Hono broker, the Ditto twin server, and the Unreal Engine visualization client, all orchestrated by the model‑driven deployment framework."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the building lifecycle phases: design (ideal BIM model), construction/installation (as‑built BIM enriched with device metadata), and operation (runtime‑aware BIM used for monitoring and optimization)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is assessed using the Overall Digital Twin Entanglement (ODTE) metric, which quantifies how closely the digital twin reflects its physical counterpart; the framework aims to maintain semantic coherence between BIM and runtime data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT is realized through Eclipse Hono (supporting standard IoT protocols such as MQTT/HTTPS) feeding data into Eclipse Ditto, which exposes a RESTful API for twin interaction."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach follows BIM standards for building data and introduces standardized extension points for service integration, enforcing consistent semantics across the model‑driven pipeline."
]