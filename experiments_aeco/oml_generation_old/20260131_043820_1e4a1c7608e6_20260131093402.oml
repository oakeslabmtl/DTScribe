// Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded occupancy sensor modeled in BIM schema, real‑time telemetry via Eclipse Hono"
]
instance AmbientLightSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient light sensor embedded in the building control system, modeled in BIM, real‑time telemetry via Eclipse Hono"
]
instance TemperatureHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Combined temperature and humidity sensor, modeled in BIM, feeds data to Eclipse Hono"
]
instance EnergyMeter : DTDFVocab:SensingComponent [
    base:desc "Energy meter for building power consumption, modeled in BIM, real‑time telemetry via Eclipse Hono"
]

// Data Transmitted
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance AmbientLightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientLightSensor
]
instance TemperatureHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureHumiditySensor
]
instance EnergyUsageDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeter
]

// Data
instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy data stream with timestamps"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo HonoBroker, DittoRegistry
]
instance AmbientLightData : DTDFVocab:Data [
    base:desc "Real‑time ambient light level data stream with timestamps"
    DTDFVocab:fromData AmbientLightDataTransmitted
    DTDFVocab:inputTo HonoBroker, DittoRegistry
]
instance TemperatureHumidityData : DTDFVocab:Data [
    base:desc "Real‑time temperature and humidity data stream with timestamps"
    DTDFVocab:fromData TemperatureHumidityDataTransmitted
    DTDFVocab:inputTo HonoBroker, DittoRegistry
]
instance EnergyUsageData : DTDFVocab:Data [
    base:desc "Real‑time energy consumption data stream with timestamps"
    DTDFVocab:fromData EnergyUsageDataTransmitted
    DTDFVocab:inputTo HonoBroker, DittoRegistry
]

// Models
instance SemanticBIMModel : DTDFVocab:Model [
    base:desc "Semantic BIM model of the LEED Platinum academic Living Lab building enriched with device metadata"
    DTDFVocab:inputTo MDETransformationPipeline
]
instance RuntimeConfigurationModel : DTDFVocab:Model [
    base:desc "Runtime configuration artefacts generated by MDE transformation from BIM, deployed via Ditto"
    DTDFVocab:inputTo DittoRegistry
]
instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic models for lighting, HVAC, and building services used to generate optimisation policies"
    DTDFVocab:inputTo DittoRegistry
]
instance HistoricalOperationLogModel : DTDFVocab:Model [
    base:desc "Historical operation logs of building systems used for predictive maintenance analytics"
    DTDFVocab:inputTo DittoRegistry
]

// Enablers
instance HonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono pub/sub broker for real‑time telemetry between sensors and the twin"
    DTDFVocab:enables LiveVisualizationService, EnergyConsumptionAnalyticsService, RLOptimizationService, FacilityDashboardService
]
instance DittoRegistry : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto device registry and twin storage for sensor and twin data"
    DTDFVocab:enables LiveVisualizationService, EnergyConsumptionAnalyticsService, RLOptimizationService, FacilityDashboardService
]
instance UnrealEngineRenderer : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renderer for real‑time 3D visualization of the building model"
    DTDFVocab:enables LiveVisualizationService
]
instance MDETransformationPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation pipeline that extracts device metadata from BIM and produces deployable configuration artefacts"
    DTDFVocab:enables RuntimeConfigurationService
]

// Services
instance LiveVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization service rendering the building model in Unreal Engine 5"
    DTDFVocab:provides LiveVisualizationInsight
]
instance EnergyConsumptionAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service for energy consumption using sensor data streams"
    DTDFVocab:provides EnergyPerformanceReportInsight
]
instance RLOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based optimisation service for lighting and HVAC schedules"
    DTDFVocab:provides OptimizationRecommendationInsight
]
instance FacilityDashboardService : DTDFVocab:Service [
    base:desc "Facility‑management dashboard service presenting operational insights to facility managers"
    DTDFVocab:provides PredictiveMaintenanceAlertInsight
]
instance RuntimeConfigurationService : DTDFVocab:Service [
    base:desc "Service for deploying runtime configuration artefacts into the twin"
    DTDFVocab:provides RuntimeConfigurationInsight
]

// Insights
instance LiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Live visualization of the digital twin rendered in Unreal Engine 5"
]
instance EnergyPerformanceReportInsight : DTDFVocab:Insight [
    base:desc "Energy‑performance report generated from predictive analytics"
]
instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendation produced by reinforcement‑learning based optimisation"
]
instance PredictiveMaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance alert generated by facility‑management dashboard"
]
instance RuntimeConfigurationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful deployment of runtime configuration artefacts"
]

// Acting Components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer switch actuator embedded in the building control system, commanded via Eclipse Ditto"
]
instance HVACFanActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC fan actuator embedded in the building control system, commanded via Eclipse Ditto"
]
instance HVACDamperActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC damper actuator embedded in the building control system, commanded via Eclipse Ditto"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands issued by the digital twin back to the physical subsystem, such as setting lighting levels, HVAC setpoints or fan speeds, transmitted through Ditto’s device registry and delivered over Hono to the physical devices."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization driven by sensor reporting intervals (typically seconds) and periodic optimization cycles (e.g., hourly) that update control policies in the digital twin and propagate them to the physical system."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin constellation consists of the BIM core, the Hono/Ditto middleware layer, individual device twins, the visualization engine, and business‑logic services, all connected through standardized interfaces and orchestrated by the DT framework hub."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Deployment spans the full life‑cycle of the building: design (BIM model creation), construction (device commissioning), commissioning (configuring middleware and verifying mappings), and operation (continuous monitoring, optimization, and iterative learning via reinforcement agents)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The fidelity of the twin is quantified using the Overall Digital Twin Entanglement (ODTE) metric, which measures the degree of alignment between the virtual representation and the physical system, supplemented by model validation checks during the deployment pipeline."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time event and telemetry exchange is facilitated by Eclipse Hono, which uses a lightweight publish/subscribe protocol over secure TCP (TLS) to transport data, while Ditto exposes device twins via RESTful HTTP endpoints that can be queried or updated by the twin services."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin infrastructure is hosted on a cloud‑based container platform that runs Hono, Ditto, and the Unreal Engine rendering service, allowing scalable deployment and remote access for stakeholders."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The twin can exchange data with external information systems such as enterprise asset management (EAM) tools, BIM collaboration portals, and other domain‑specific DTs through standardized interfaces provided by the middleware layer."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Operational data generated by the building devices remains the property of the building owner, while the twin service provider supplies analytics services under a data‑sharing agreement that enforces privacy controls on sensitive data streams."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The engineering of the twin follows BIM IFC for asset semantics, MQTT/TCP‑based Hono protocol, Ditto’s twin‑model schema, and industry‑accepted data formats for sensor telemetry, ensuring interoperability across the AECO domain."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "All communication channels are secured with TLS, authentication is enforced by Hono’s device provisioning mechanism, and safety rules are embedded in the control logic to prevent unsafe actuator commands from being executed on the physical building during operation."
]