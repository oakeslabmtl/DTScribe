// C3: Physical sensing components
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor modeled in BIM to capture post‑occupancy lighting levels"
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector modeled in BIM to capture presence of occupants after use"
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical-to-virtual interaction
instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

// C10: Data artifacts
instance IlluminationData : DTDFVocab:Data [
    base:desc "Streaming illumination measurements (lux) from physical sensors"
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Streaming occupancy states (binary) from physical detectors"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// C2: Acting components
instance DimmableLuminaireActuator : DTDFVocab:ActingComponent [
    base:desc "Dimmable luminaire modeled in BIM, receives dimming commands from the twin"
]

instance LightingSwitchActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting switch modeled in BIM, toggles light groups based on twin commands"
]

// C10: Models/Data
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Static BIM geometry model enriched with sensor and actuator metadata"
    DTDFVocab:inputTo ModelDrivenFrameworkEnabler
]

instance DeviceMetadataModel : DTDFVocab:Model [
    base:desc "Semantic model of building devices (sensors, actuators) derived from BIM"
    DTDFVocab:inputTo ModelDrivenFrameworkEnabler
]

instance SimulationModelUnreal : DTDFVocab:Model [
    base:desc "Simulation model rendered in Unreal Engine 5 for 3‑D interactive visualization"
    DTDFVocab:inputTo UnrealEngineEnabler
]

instance PredictiveAnalyticsModel : DTDFVocab:Model [
    base:desc "Predictive analytics model (e.g., energy consumption forecast) generated by the model‑driven pipeline"
    DTDFVocab:inputTo ModelDrivenFrameworkEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono streams telemetry from physical sensors to the digital twin"
    DTDFVocab:enables RealTimeMonitoringDashboard
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto stores the twin state and provides bidirectional telemetry"
    DTDFVocab:enables RealTimeMonitoringDashboard, EnergyOptimizationService, PredictiveAnalyticsService
]

instance UnrealEngineEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders simulation models for 3‑D interactive visualization"
    DTDFVocab:enables Interactive3DVisualization
]

instance ModelDrivenFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering framework auto‑generates runtime artifacts and orchestrates services"
    DTDFVocab:enables PredictiveAnalyticsService, EnergyOptimizationService, CustomPluginService
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard presenting live sensor streams and twin state"
    DTDFVocab:provides RealTimeOperationalInsight
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "3‑D interactive visualization in Unreal Engine 5 for facility operators"
    DTDFVocab:provides RealTimeOperationalInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service delivering forecasts of energy consumption and occupancy patterns"
    DTDFVocab:provides PredictiveAnalysisInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that generates recommendations and issues commands to lighting actuators"
    DTDFVocab:provides EnergyOptimizationInsight, AdjustLightingAction
]

instance CustomPluginService : DTDFVocab:Service [
    base:desc "Extensible service platform for custom plugins supplied by facility managers"
    DTDFVocab:provides CustomInsight
]

// C17: Insights/Actions
instance RealTimeOperationalInsight : DTDFVocab:Insight [
    base:desc "Real‑time operational insight derived from live sensor data and twin state"
]

instance PredictiveAnalysisInsight : DTDFVocab:Insight [
    base:desc "Predictive analysis insight forecasting future energy usage and occupancy trends"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal lighting schedules to reduce energy consumption"
]

instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automatic command to dim or switch lighting actuators based on optimization recommendations"
    DTDFVocab:IsAutomatic true
]

instance CustomInsight : DTDFVocab:Insight [
    base:desc "Insight generated by user‑provided custom plugin services"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting dimming, HVAC set‑points) transmitted back through Eclipse Ditto to Eclipse Hono and delivered to the corresponding actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data exchange and twin updates occur in real time as sensor measurements arrive, supporting near‑instantaneous synchronization between physical and virtual assets."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where the enriched BIM model feeds a configurator that creates device metadata, which is consumed by Hono/Ditto middleware for bidirectional communication, while Unreal Engine provides the visualization layer; custom services can be added via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers design (BIM creation), construction (device commissioning), and operation/maintenance phases, supporting post‑occupancy adaptation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Entanglement measured with the Overall Digital Twin Entanglement (ODTE) metric to assess how closely the twin mirrors the physical building."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono acts as the IoT gateway handling device communication, while Eclipse Ditto manages the digital twin state; together they provide a bidirectional, protocol‑agnostic connection between physical devices and the twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Built upon BIM standards and uses standardized extension points; integration follows model‑driven engineering conventions and the ODTE metric for evaluation."
]