// =====================
// 1. Sensing Components
// =====================

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled within the BIM environment and linked to its physical location."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor modeled within the BIM environment and linked to its physical location."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor (e.g., post‑occupancy) modeled within the BIM environment and linked to its physical location."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// =====================
// 2. Data Transmitted
// =====================

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// =====================
// 3. Data Objects
// =====================

instance TemperatureMeasurementData : DTDFVocab:Data [
    base:desc "Real‑time temperature measurements streamed from the physical building."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoIngestion
]

instance HumidityMeasurementData : DTDFVocab:Data [
    base:desc "Real‑time humidity measurements streamed from the physical building."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseHonoIngestion
]

instance OccupancyMeasurementData : DTDFVocab:Data [
    base:desc "Real‑time occupancy counts streamed from the physical building."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoIngestion
]

// =====================
// 4. Acting Components
// =====================

instance ValveActuator : DTDFVocab:ActingComponent [
    base:desc "Valve actuator (BIM object) with on/off and set‑point capabilities, addressed via BIM metadata."
]

instance DamperActuator : DTDFVocab:ActingComponent [
    base:desc "Damper actuator (BIM object) with proportional control, addressed via BIM metadata."
]

instance MotorizedBlindActuator : DTDFVocab:ActingComponent [
    base:desc "Motorized blind actuator (BIM object) with on/off control, addressed via BIM metadata."
]

// =====================
// 5. Models
// =====================

instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Static geometric and semantic baseline of the building derived from BIM."
    DTDFVocab:inputTo BIMRepository
]

instance ControlLogicBehaviorModel : DTDFVocab:Model [
    base:desc "Runtime behavioral model generated from control logic defined by the Building Control Engineer."
    DTDFVocab:inputTo DataAdapterEngine
]

instance PredictiveAnalyticsModel : DTDFVocab:Model [
    base:desc "Analytical model for fault detection and energy‑saving predictions."
    DTDFVocab:inputTo PredictiveAnalyticsEngine
]

// =====================
// 6. Enablers
// =====================

instance EclipseHonoIngestion : DTDFVocab:Enabler [
    base:desc "Eclipse Hono component ingesting IoT sensor streams in real‑time."
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital‑twin information broker managing twin state and interactions."
    DTDFVocab:enables ControlActionService, DecisionSupportService
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine delivering high‑fidelity, interactive 3D visualisation of the digital twin."
    DTDFVocab:enables InteractiveVisualizationService
]

instance BIMRepository : DTDFVocab:Enabler [
    base:desc "Repository exposing BIM‑derived geometric models to the digital‑twin platform."
    DTDFVocab:enables BuildingPerformanceSimulationService
]

instance DataAdapterEngine : DTDFVocab:Enabler [
    base:desc "MDE‑generated runtime adapters that translate BIM and control models into DT artifacts."
    DTDFVocab:enables BuildingPerformanceSimulationService, PredictiveAnalyticsService, LifeCycleOptimizationService
]

instance PredictiveAnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Engine executing predictive analytics for fault detection and energy‑saving insights."
    DTDFVocab:enables PredictiveAnalyticsService
]

// =====================
// 7. Services
// =====================

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building sensor streams."
    DTDFVocab:provides FaultDetectionInsight
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance based on BIM geometry and control logic."
    DTDFVocab:provides BuildingPerformanceInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for fault detection and energy‑saving optimisation."
    DTDFVocab:provides EnergySavingInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Rich interactive 3D visualisation for facility managers, designers, and occupants."
    DTDFVocab:provides ScenarioAnalysisAction
]

instance ControlActionService : DTDFVocab:Service [
    base:desc "Remote actuation of physical infrastructure via the digital twin."
    DTDFVocab:provides ControlCommandAction
]

instance LifeCycleOptimizationService : DTDFVocab:Service [
    base:desc "Life‑cycle encompassing optimisation of building operations."
    DTDFVocab:provides LifeCycleOptimizationAction
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Decision‑making support based on aggregated sensor data and analytics."
    DTDFVocab:provides DecisionInsight
]

// =====================
// 8. Insights & Actions
// =====================

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting faults in building systems from abnormal sensor patterns."
]

instance BuildingPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight describing simulated building performance metrics (e.g., thermal comfort, energy use)."
]

instance EnergySavingInsight : DTDFVocab:Insight [
    base:desc "Insight recommending energy‑saving actions derived from predictive analytics."
]

instance ScenarioAnalysisAction : DTDFVocab:Action [
    base:desc "Action enabling users to run what‑if scenario analyses within the 3D twin."
    DTDFVocab:IsAutomatic false
]

instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Action transmitting control commands (on/off, set‑point adjustments) to actuators."
    DTDFVocab:IsAutomatic true
]

instance LifeCycleOptimizationAction : DTDFVocab:Action [
    base:desc "Action proposing life‑cycle optimisation measures (maintenance scheduling, retro‑fit suggestions)."
    DTDFVocab:IsAutomatic false
]

instance DecisionInsight : DTDFVocab:Insight [
    base:desc "Insight supporting facility manager decisions based on aggregated real‑time and historical data."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT supports bidirectional data exchange, allowing control signals generated in the digital environment to be sent back to physical building systems. Facility managers interact with the deployed DT to perform real‑time monitoring and issue control actions, which are propagated to the building control infrastructure. The document does not provide details on command types, message formats, validation, authentication, feedback loops, conflict resolution, or execution confirmation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The document states that DTs provide real‑time insights by integrating runtime data with static models, implying continuous updating of the digital representation, but it does not specify synchronization frequencies, latency requirements, or temporal granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a model‑driven, layered architecture where a central DT Framework acts as a hub orchestrating all components. The lower layer hosts the BIM representation of the asset; the middleware layer integrates Eclipse Hono for device connectivity and Eclipse Ditto for digital‑twin state management; the upper layer uses Unreal Engine for immersive visualization. The framework coordinates resource allocation, component integration, and service composition, providing system‑wide orchestration through the central hub."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a continuous life‑cycle that starts with device modeling inside the BIM environment (definition of sensors, actuators, and controllers), proceeds to extraction of a structured representation through model‑driven engineering (MDE) transformations, automatically generates deployable Digital Twin artifacts, and culminates in runtime operation where real‑time data exchange keeps the physical building and its twin synchronized. Transition between phases is managed by the MDE pipeline that maps enriched BIM models to executable DT components, and the overall lifecycle is guided by the functional requirements (F_X) that prescribe each stage, although explicit governance mechanisms are not detailed in the document."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assured through a validation step that compares the digital twin’s behavior against the physical building using the Overall Digital Twin Entanglement (ODTE) metric, which quantifies how closely the DT reflects its counterpart. Validation includes checking geometric alignment, synchronizing sensor streams, and verifying actuator response against expected control logic. Uncertainty sources such as sensor noise and model abstraction are acknowledged, and the ODTE score is used to guide quality‑assurance activities, including error detection, model refinement, and re‑deployment of updated DT artifacts."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The document mentions integration of static models with runtime data within the DT, but it does not detail any data exchange protocols, interoperability standards, or connections to external systems."
]