// C2: Acting Components
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Physical actuator and controller for building lighting control, modeled in the BIM and driven by the Digital Twin."
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Physical occupancy sensor captured in the BIM, providing runtime occupancy data streams to the Digital Twin."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Physical environmental sensor (e.g., temperature, humidity, CO₂) captured in the BIM, providing runtime environmental data streams to the Digital Twin."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched Building Information Model containing geometry, topology, and device metadata."
    DTDFVocab:inputTo ModelDrivenPipeline
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Runtime model of building control logic generated from the enriched BIM."
    DTDFVocab:inputTo ModelDrivenPipeline
]

instance ReinforcementLearningLightingModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning model for adaptive lighting optimization."
    DTDFVocab:inputTo ModelDrivenPipeline
]

instance OccupancySensorData : DTDFVocab:Data [
    base:desc "Live occupancy data stream originating from the OccupancySensor."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoMiddleware, EclipseDittoTwinManager
]

instance EnvironmentalSensorData : DTDFVocab:Data [
    base:desc "Live environmental data stream (temperature, humidity, CO₂) originating from the EnvironmentalSensor."
    DTDFVocab:fromData EnvironmentalDataTransmitted
    DTDFVocab:inputTo EclipseHonoMiddleware, EclipseDittoTwinManager
]

instance EnergyConsumptionForecastData : DTDFVocab:Data [
    base:desc "Energy‑consumption forecast generated by the ReinforcementLearningLightingModel."
    DTDFVocab:inputTo EclipseDittoTwinManager
]

instance ComfortLevelAssessmentData : DTDFVocab:Data [
    base:desc "Comfort level assessment derived from environmental sensor data and control logic."
    DTDFVocab:inputTo EclipseDittoTwinManager
]

instance OptimizedControlSetpointData : DTDFVocab:Data [
    base:desc "Optimized lighting set‑points produced by the AdaptiveLightingOptimizationService."
    DTDFVocab:inputTo EclipseDittoTwinManager
]

// C11: Enablers
instance EclipseHonoMiddleware : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware for bidirectional, real‑time IoT data ingestion."
    DTDFVocab:enables MonitoringDashboardService, VisualizationService, SimulationAnalyticsService, AdaptiveLightingOptimizationService, DecisionSupportService
]

instance EclipseDittoTwinManager : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for Digital Twin state management and synchronization."
    DTDFVocab:enables MonitoringDashboardService, VisualizationService, SimulationAnalyticsService, AdaptiveLightingOptimizationService, DecisionSupportService
]

instance ModelDrivenPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation pipeline that enriches the BIM, validates models, and generates runtime artifacts."
    DTDFVocab:enables SimulationAnalyticsService, AdaptiveLightingOptimizationService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 platform providing immersive 3D visualization of the Digital Twin."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard delivering operational metrics and alerts."
    DTDFVocab:provides EnergyConsumptionForecastInsight, ComfortLevelAssessmentInsight, DecisionSupportInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D visualization of the building in Unreal Engine 5."
    DTDFVocab:provides ComfortLevelAssessmentInsight
]

instance SimulationAnalyticsService : DTDFVocab:Service [
    base:desc "Simulation and predictive analytics service using runtime models and sensor data."
    DTDFVocab:provides EnergyConsumptionForecastInsight
]

instance AdaptiveLightingOptimizationService : DTDFVocab:Service [
    base:desc "Adaptive lighting optimization using reinforcement learning to minimize energy consumption."
    DTDFVocab:provides AdaptiveLightingAction
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Decision‑support service for facility managers, providing actionable insights."
    DTDFVocab:provides DecisionSupportInsight
]

// C17: Insights
instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of future energy consumption based on current usage patterns and control policies."
]

instance ComfortLevelAssessmentInsight : DTDFVocab:Insight [
    base:desc "Assessment of occupant comfort levels derived from environmental sensor data."
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Insight supporting facility‑manager decisions on building operation strategies."
]

// C17: Actions
instance AdaptiveLightingAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting set‑points based on reinforcement‑learning recommendations."
    DTDFVocab:IsAutomatic true
]

// C14: Environment (optional grouping)
instance LivingLabEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, EnvironmentalSensor, LightingControlActuator
]

// C15: Component (optional generic component)
instance BIMComponent : DTDFVocab:Component [
    base:desc "Core BIM component that holds device metadata and geometric topology."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., lighting set‑points, HVAC adjustments) are transmitted back to the physical actuators through the Ditto platform, enabling closed‑loop operation of the building control systems."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data exchange and model updates occur continuously in real time, providing up‑to‑date virtual representations of the physical building."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture consisting of (1) an enriched BIM model, (2) a configurator that extracts device metadata, (3) Eclipse Hono/Ditto for bidirectional communication, (4) optional custom services (e.g., reinforcement‑learning control), and (5) an Unreal Engine visualization front‑end, all coordinated by standardized extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin spans the full building lifecycle: design (BIM‑based modeling), construction (integration of device metadata), operation (real‑time monitoring and control), and later refurbishment or adaptation phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The fidelity of the DT is evaluated using the Overall Digital Twin Entanglement (ODTE) metric, which quantifies how well the digital representation mirrors the physical counterpart. The approach also acknowledges semantic drift and incorporates verification steps during model validation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed on a modular service‑oriented platform that integrates Eclipse Ditto and Eclipse Hono for runtime services, with Unreal Engine 5 providing the visualization layer; deployment is automated through the model‑driven pipeline."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework introduces a modeling methodology that standardizes BIM semantics for automated transformation, and provides standardized extension points conforming to AECO interoperability goals, ensuring compatibility with BIM standards (e.g., IFC) and service‑oriented DT architectures."
]