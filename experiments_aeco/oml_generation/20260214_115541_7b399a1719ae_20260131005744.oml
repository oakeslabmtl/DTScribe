// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled as a device object inside the BIM model streams post‑occupancy measurements via Eclipse Hono to Eclipse Ditto."
    DTDFVocab:producedData OccupancyDataProduced
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor device object embedded in the BIM model provides continuous temperature readings for real‑time monitoring."
    DTDFVocab:producedData TemperatureDataProduced
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor defined within the BIM environment publishes humidity measurements through the Hono‑Ditto pipeline."
    DTDFVocab:producedData HumidityDataProduced
]

// C4: Physical‑to‑virtual data transmitted
instance OccupancyDataProduced : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataProduced : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataProduced : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

// C10: Data artifacts
instance OccupancyMeasurementData : DTDFVocab:Data [
    base:desc "Real‑time occupancy measurement stream received from the physical occupancy sensor."
    DTDFVocab:fromData OccupancyDataProduced
    DTDFVocab:inputTo RealTimeDataEnabler
]

instance TemperatureMeasurementData : DTDFVocab:Data [
    base:desc "Continuous temperature readings collected from the building’s temperature sensor."
    DTDFVocab:fromData TemperatureDataProduced
    DTDFVocab:inputTo RealTimeDataEnabler
]

instance HumidityMeasurementData : DTDFVocab:Data [
    base:desc "Live humidity data emitted by the BIM‑linked humidity sensor."
    DTDFVocab:fromData HumidityDataProduced
    DTDFVocab:inputTo RealTimeDataEnabler
]

// C10: Models
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Geometric BIM representation of the building serving as the structural foundation of the Digital Twin."
    DTDFVocab:inputTo RealTimeDataEnabler
]

instance DeviceModel : DTDFVocab:Model [
    base:desc "Semantic model that enriches the BIM geometry with definitions of sensors, actuators, and controllers."
    DTDFVocab:inputTo RealTimeDataEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Executable control‑logic model generated from the enriched BIM governs actuator behavior."
    DTDFVocab:inputTo RealTimeDataEnabler
]

// C11: Enablers
instance RealTimeDataEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering (MDE) engine that processes incoming sensor data, links it to BIM models, and triggers DT services."
    DTDFVocab:enables RealTimeInsightService, SimulationAnalysisService, PredictiveAnalyticsService, OptimisationSupportService
]

// C6: Services
instance RealTimeInsightService : DTDFVocab:Service [
    base:desc "Generates real‑time operational insights from streamed sensor data."
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance SimulationAnalysisService : DTDFVocab:Service [
    base:desc "Performs simulation‑based analysis using the BIM geometry and control‑logic models."
    DTDFVocab:provides SimulationBasedInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Applies predictive analytics on historical and live data to anticipate maintenance needs."
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance OptimisationSupportService : DTDFVocab:Service [
    base:desc "Provides optimisation recommendations and can issue control commands to improve energy efficiency."
    DTDFVocab:provides EnergyOptimisationInsight, RemoteControlAction
]

// C17: Insights
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Live monitoring insight showing current occupancy, temperature, and humidity states."
]

instance SimulationBasedInsight : DTDFVocab:Insight [
    base:desc "Insight derived from simulation runs that evaluate design alternatives and operational scenarios."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Forecasted maintenance insight highlighting components at risk of failure based on sensor trends."
]

instance EnergyOptimisationInsight : DTDFVocab:Insight [
    base:desc "Recommendation insight for reducing operational costs by optimizing HVAC and lighting schedules."
]

// C17: Actions
instance RemoteControlAction : DTDFVocab:Action [
    base:desc "Action allowing Facility Managers to issue remote commands to physical actuators via the DT UI."
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator defined as a device object in the BIM model receives control commands from the Digital Twin."
]

// C1: Environment (the building)
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, TemperatureSensor, HumiditySensor, HVACActuator, BIMGeometryModel, DeviceModel, ControlLogicModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional control is realized by the Digital Twin issuing actuation commands back to the building control systems through the Ditto platform, which routes the commands via Eclipse Hono to the physical actuators. Command types include set‑point adjustments, on/off switches, and schedule updates. Messages follow the Ditto command format (JSON‑based) and are validated by the runtime configuration management layer before transmission. Authentication and integrity checks are enforced by the middleware’s built‑in security mechanisms. Feedback from the physical layer (acknowledgments and status reports) is sent back to the twin, providing execution confirmation and enabling conflict resolution when multiple control requests occur."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange, meaning sensor and actuator information from the physical building is streamed continuously to the digital twin and vice‑versa. Synchronization is described as continuous with near‑instantaneous latency, supporting real‑time monitoring and control; no explicit numerical frequencies or granularity are specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, service‑oriented constellation: a central DT Framework provides standardized extension points, runtime configuration management, and integrates custom services and analytics. Roles such as Building Control Engineers, Facility Managers, and DT Engineers interact with the framework, which orchestrates data flow between enriched BIM models and operational twins across the building life‑cycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The workflow includes a validation step after the MDE transformation, where the generated twin is checked for semantic correctness. Quality assurance is addressed through the Overall Digital Twin Entanglement (ODTE) metric, which quantifies the alignment between the physical building and its digital counterpart. The model‑driven approach promotes compliance, reuse, and systematic verification, but the document does not describe specific uncertainty quantification, error‑detection, or correction mechanisms beyond the ODTE evaluation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical backbone consists of a central DT Framework that connects physical devices and the digital twin via Eclipse Hono and Eclipse Ditto. Hono provides protocol support (e.g., MQTT/HTTP) for IoT device connectivity, while Ditto offers REST/WebSocket interfaces for twin interaction. The network topology follows a hub‑spoke model with the DT Framework as the hub, ensuring low‑latency, high‑throughput data exchange suitable for real‑time synchronization. Redundancy is achieved through the modular architecture’s standardized extension points, allowing fail‑over components. Security protocols are applied at the middleware layer to protect data in transit."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment follows a model‑driven approach where enriched BIM models are used to instantiate operational digital twins. The framework’s modular design and runtime configuration management allow components to be deployed and adjusted without full redeployment, supporting scalability and maintainability. However, the document does not provide details on hosting platforms (cloud, edge, on‑premise), computational or storage specifications, explicit scalability mechanisms, supported deployment models, or availability/reliability guarantees."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration is addressed through generic interoperability requirements, standardized extension points, and the use of BIM tools as data sources. While the document emphasizes interoperability across heterogeneous systems and integration of custom services, it does not specify concrete protocols or standards (e.g., MQTT, OPC-UA). Integration relies on the framework’s modular APIs and runtime configuration to interoperate with external systems and enterprise services."
]