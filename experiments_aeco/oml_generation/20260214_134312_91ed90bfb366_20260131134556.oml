// Sensing Components
instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector embedded in the building, modeled in BIM and transmitting telemetry via Eclipse Hono (MQTT)."
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance AmbientLightSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient light sensor embedded in the building, modeled in BIM and transmitting telemetry via Eclipse Hono (MQTT)."
    DTDFVocab:producedData AmbientLightDataTransmitted
]
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the building, modeled in BIM and transmitting telemetry via Eclipse Hono (MQTT)."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// Data Transmitted
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]
instance AmbientLightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientLightSensor
]
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// Telemetry Data
instance OccupancyTelemetry : DTDFVocab:Data [
    base:desc "Real‑time occupancy telemetry collected from occupancy detectors."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoMQTTTransport
]
instance AmbientLightTelemetry : DTDFVocab:Data [
    base:desc "Real‑time ambient light telemetry collected from light sensors."
    DTDFVocab:fromData AmbientLightDataTransmitted
    DTDFVocab:inputTo EclipseHonoMQTTTransport
]
instance TemperatureTelemetry : DTDFVocab:Data [
    base:desc "Real‑time temperature telemetry collected from temperature sensors."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoMQTTTransport
]

// 3‑D BIM Model
instance BIM3DModel : DTDFVocab:Model [
    base:desc "3‑D Building Information Model (BIM) enriched with sensor and actuator metadata and control logic."
    DTDFVocab:inputTo BIMToTwinTransformationPipeline, EclipseDittoTwinManagement
]

// Enablers
instance BIMToTwinTransformationPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation pipeline that converts BIM artefacts into Digital Twin representations."
    DTDFVocab:enables TwinTwinManagementService
]
instance EclipseHonoMQTTTransport : DTDFVocab:Enabler [
    base:desc "Eclipse Hono service responsible for MQTT‑based data transport from physical devices to the Digital Twin."
    DTDFVocab:enables HonoDataIngestionService
]
instance EclipseDittoTwinManagement : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for twin management, facilitating the storage and lifecycle of the Digital Twin."
    DTDFVocab:enables RealTimeMonitoringDashboardService, PredictiveEnergyAnalyticsService, ReinforcementLearningLightingOptimisationService, BuildingPerformanceSimulationService, TwinTwinManagementService
]
instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3‑D visualization of the Digital Twin."
    DTDFVocab:enables UnrealEngine5RenderingService
]
instance InternalDeploymentScripts : DTDFVocab:Enabler [
    base:desc "Internal scripts that automate the deployment of the Digital Twin artifacts through Eclipse Hono and Ditto."
    DTDFVocab:enables DeploymentAutomationService
]

// Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards consuming Twin data to inform facility managers about operational status."
    DTDFVocab:provides EnergySavingsInsight, OccupancyComfortInsight, ControlPolicyAdjustmentInsight
]
instance PredictiveEnergyAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive energy‑usage analytics that forecast consumption and recommend savings."
    DTDFVocab:provides EnergySavingsInsight
]
instance ReinforcementLearningLightingOptimisationService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning‑based lighting optimisation recommending optimal lighting schedules."
    DTDFVocab:provides LightingScheduleOptimizationInsight, AdjustLightingAction
]
instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance for scenario analysis."
    DTDFVocab:provides ControlPolicyAdjustmentInsight
]
instance UnrealEngine5RenderingService : DTDFVocab:Service [
    base:desc "3‑D visualization service using Unreal Engine 5 for immersive view."
    DTDFVocab:provides OccupancyComfortInsight, AdjustBlindsAction
]
instance HonoDataIngestionService : DTDFVocab:Service [
    base:desc "Service handling ingestion of telemetry via Eclipse Hono."
    DTDFVocab:provides DataIngestionInsight, IngestDataAction
]
instance TwinTwinManagementService : DTDFVocab:Service [
    base:desc "Service managing twin lifecycle, updates, and versioning."
    DTDFVocab:provides AdjustHVACAction, AdjustVentilationValveAction
]
instance DeploymentAutomationService : DTDFVocab:Service [
    base:desc "Automated deployment service for twin artefacts."
    DTDFVocab:provides IngestDataAction
]

// Insights
instance EnergySavingsInsight : DTDFVocab:Insight [
    base:desc "Insight indicating potential energy savings derived from predictive analytics."
]
instance OccupancyComfortInsight : DTDFVocab:Insight [
    base:desc "Insight on occupancy comfort levels based on sensor telemetry."
]
instance ControlPolicyAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Insight recommending adjustments to control policies to optimise building performance."
]
instance LightingScheduleOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal lighting schedules from reinforcement‑learning agents."
]
instance DataIngestionInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful ingestion of telemetry into the Digital Twin."
]

// Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust dimmable LED lighting fixtures."
    DTDFVocab:IsAutomatic true
]
instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust HVAC valves for temperature control."
    DTDFVocab:IsAutomatic true
]
instance AdjustBlindsAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust blinds for optimal lighting and thermal performance."
    DTDFVocab:IsAutomatic true
]
instance AdjustVentilationValveAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust ventilation valves for air quality optimisation."
    DTDFVocab:IsAutomatic true
]
instance IngestDataAction : DTDFVocab:Action [
    base:desc "Automatic action to ingest telemetry data via Eclipse Hono into the Digital Twin."
    DTDFVocab:IsAutomatic true
]

// Actuators
instance DimmableLEDLightingFixture : DTDFVocab:ActingComponent [
    base:desc "Controllable lighting fixture (dimmable LED) represented in BIM and actuated via Digital Twin."
]
instance HVACValve : DTDFVocab:ActingComponent [
    base:desc "Actuator representing an HVAC valve modeled in BIM and controlled through the Digital Twin."
]
instance BlindsActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator representing blinds in BIM, actuated to adjust shading and airflow."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control messages generated by the twin (e.g., light dimming, HVAC set‑point adjustments) are transmitted via Ditto to Eclipse Hono and delivered to the physical actuators"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (continuous) synchronization; sensor data is streamed and commands are transmitted with round‑trip latency in the order of seconds or less, maintaining live alignment between physical and virtual models."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "BIM model → Ditto twin registry → Hono MQTT broker → physical devices and sensors; complemented by visualization in Unreal and RL optimisation services"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "All major lifecycle phases: design (BIM creation), construction (device modelling), commissioning (middleware configuration), and operation (runtime monitoring and optimisation)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Evaluation of twin fidelity using the Overall Digital Twin Entanglement (ODTE) metric; management of semantic drift through bi‑directional synchronization and adherence to BIM semantics"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with building automation middleware (Eclipse Hono), external analytics pipelines (reinforcement‑learning modules), and potentially other DTs via Ditto’s messaging fabric"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Built upon the BIM semantic ecosystem; the framework adheres to industry‑level integration practices but does not specify additional external standards such as IFC or MQTT."
]