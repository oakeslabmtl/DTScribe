// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled sensor measuring real-time temperature readings for HVAC control and occupancy monitoring within building environments"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled sensor capturing humidity levels to support environmental control and predictive maintenance algorithms"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "BLE/WiFi-based sensor detecting occupancy patterns for space utilization analysis and energy optimization"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Smart meter interface capturing real-time energy consumption metrics for building systems"
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

instance StructuralStressSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded sensor monitoring structural elements for safety and maintenance planning"
    DTDFVocab:producedData StructuralStressDataTransmitted
]

instance HVACPerformanceSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor suite measuring HVAC system performance parameters including airflow, pressure, and efficiency metrics"
    DTDFVocab:producedData HVACPerformanceDataTransmitted
]

// C4: Physical-to-Virtual Data Transmission
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance StructuralStressDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralStressSensor
]

instance HVACPerformanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACPerformanceSensor
]

// C10: Models/Data
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "Enriched Building Information Model containing BCS components with semantic annotations for sensors, actuators, and controllers"
    DTDFVocab:inputTo BIMToDTTransformationPipeline
]

instance OperationalStateModel : DTDFVocab:Model [
    base:desc "Real-time behavioral model representing current operational state of building systems with dynamic control logic"
    DTDFVocab:inputTo ControlLogicDeploymentService
]

instance EnergyOptimizationModel : DTDFVocab:Model [
    base:desc "Multi-objective optimization model for HVAC control using NSGA-II algorithm with simulation-to-reality validation"
    DTDFVocab:inputTo EnergyOptimizationService
]

instance AnomalyDetectionModel : DTDFVocab:Model [
    base:desc "Unsupervised learning model using Isolation Forest for detecting deviations in BCS parameters with Bayesian uncertainty estimation"
    DTDFVocab:inputTo RealTimeDataProcessingEngine
]

instance OccupancyPatternModel : DTDFVocab:Model [
    base:desc "Graph-based clustering model using Louvain algorithm to analyze WiFi/BLE geolocation data for space utilization"
    DTDFVocab:inputTo SpaceUtilizationService
]

instance DigitalShadowSimulationModel : DTDFVocab:Model [
    base:desc "Scenario testing model using AnyLogic for what-if analysis with counterfactual reasoning via causal graphs"
    DTDFVocab:inputTo ScenarioTestingService
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Continuous time-series data stream of temperature readings synchronized with physical sensors"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo RealTimeDataProcessingEngine
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Time-series humidity measurements used for environmental control and predictive maintenance"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo RealTimeDataProcessingEngine
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy patterns captured via BLE/WiFi sensors for space utilization analysis and energy optimization"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo SpaceUtilizationService
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "Real-time energy consumption metrics for building systems enabling optimization and cost analysis"
    DTDFVocab:fromData EnergyConsumptionDataTransmitted
    DTDFVocab:inputTo EnergyOptimizationService
]

instance StructuralData : DTDFVocab:Data [
    base:desc "Structural stress measurements for safety monitoring and maintenance planning"
    DTDFVocab:fromData StructuralStressDataTransmitted
    DTDFVocab:inputTo PredictiveMaintenanceService
]

instance HVACPerformanceData : DTDFVocab:Data [
    base:desc "Comprehensive HVAC system performance metrics including airflow, pressure, and efficiency parameters"
    DTDFVocab:fromData HVACPerformanceDataTransmitted
    DTDFVocab:inputTo ControlLogicDeploymentService
]

// C11: Enablers
instance BIMToDTTransformationPipeline : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering pipeline converting enriched BIM models into deployable DT artifacts using meta-modeling and code generation"
    DTDFVocab:enables ModelDrivenArtifactGenerationService
]

instance RealTimeDataProcessingEngine : DTDFVocab:Enabler [
    base:desc "Apache Flink/Spark Streaming engine processing MQTT/Kafka streams with windowed aggregations for real-time analytics"
    DTDFVocab:enables AnomalyDetectionService
    DTDFVocab:enables PredictiveMaintenanceService
]

instance EdgeAnalyticsGateway : DTDFVocab:Enabler [
    base:desc "TensorFlow Lite/ONNX Runtime enabled edge gateway for on-device inference with 100ms latency for IoT devices"
    DTDFVocab:enables EdgePredictiveAnalytics
]

instance KnowledgeGraphEngine : DTDFVocab:Enabler [
    base:desc "RDF/Sparql knowledge graph enabling semantic querying of DT relationships and component dependencies"
    DTDFVocab:enables ScenarioTestingService
]

instance ControlLogicDeploymentService : DTDFVocab:Enabler [
    base:desc "Framework enabling Building Control Engineers to define and deploy PID controllers and scheduling algorithms directly in DT"
    DTDFVocab:enables AutomatedControlLogicService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "BIM-compatible visualization tool using WebGL/Three.js or Unity for immersive 3D/4D DT interfaces with VR/AR support"
    DTDFVocab:enables ImmersiveVisualizationService
]

instance DataSyncProtocol : DTDFVocab:Enabler [
    base:desc "Standardized real-time data synchronization protocol supporting OPC UA and MQTT for bidirectional communication"
    DTDFVocab:enables RealTimeStateVisualizationService
]

instance PluginMarketplace : DTDFVocab:Enabler [
    base:desc "Standardized extension points allowing DT Engineers to develop and integrate custom services via SDKs/APIs"
    DTDFVocab:enables CustomServiceIntegrationService
]

instance ModelTrainingService : DTDFVocab:Enabler [
    base:desc "Online learning service using TensorFlow Serving for adaptive DT models with canonical model checkpoints"
    DTDFVocab:enables AdaptiveLearningService
]

