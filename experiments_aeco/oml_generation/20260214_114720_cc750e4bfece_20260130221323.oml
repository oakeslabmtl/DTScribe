import "DTDFVocab" as DTDFVocab

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor deployed in the building, annotated in the BIM model and connected via Eclipse Hono for data acquisition.",
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor measuring light levels, annotated in the BIM model and connected via Eclipse Hono.",
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring indoor temperature, annotated in the BIM model and connected via Eclipse Hono.",
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C10: Data
instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy measurements streamed from the physical building.",
    DTDFVocab:fromData OccupancyDataTransmitted,
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Live illumination measurements streamed from the physical building.",
    DTDFVocab:fromData IlluminationDataTransmitted,
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature measurements streamed from the physical building.",
    DTDFVocab:fromData TemperatureDataTransmitted,
    DTDFVocab:inputTo HonoEnabler, DittoEnabler
]

// C10: Models/Data (Model)
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "The core BIM artifact enriched with device metadata and middleware configuration, representing the physical building and its control infrastructure.",
    DTDFVocab:inputTo ModelDrivenEngineeringEnabler, ModelValidatorEnabler
]

// C11: Enablers (Tooling and Enablers)
instance BIMAuthoringToolEnabler : DTDFVocab:Enabler [
    base:desc "BIM authoring tools used to create and edit the building information model.",
    DTDFVocab:enables ModelingService
]

instance ModelDrivenEngineeringEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering techniques that transform the enriched BIM model into executable twin configurations.",
    DTDFVocab:enables TwinGenerationService
]

instance HonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides MQTT/HTTP connectivity for streaming sensor measurements to the twin platform.",
    DTDFVocab:enables RealTimeMonitoringService
]

instance DittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital‑twin state, persisting incoming data and exposing CRUD APIs.",
    DTDFVocab:enables TwinStateManagementService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders interactive 3D visualizations of the twin.",
    DTDFVocab:enables InteractiveVisualizationService
]

instance ModelValidatorEnabler : DTDFVocab:Enabler [
    base:desc "Model validator/configurator checks consistency of the enriched BIM model before deployment.",
    DTDFVocab:enables ModelValidationService
]

// C6: Services (DT Services)
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Dashboard service providing real‑time monitoring of occupancy, illumination, and temperature.",
    DTDFVocab:provides RealTimeInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Service delivering interactive 3D visualization of the building twin using Unreal Engine 5.",
    DTDFVocab:provides SpatialInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Engine that simulates building operation scenarios for what‑if analysis.",
    DTDFVocab:provides SimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service applying machine‑learning models to predict future occupancy and energy consumption.",
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that computes optimal lighting and HVAC set‑points to improve energy efficiency.",
    DTDFVocab:provides OptimizationAction
]

instance TwinGenerationService : DTDFVocab:Service [
    base:desc "Service that generates per‑device digital twins from the enriched BIM model.",
    DTDFVocab:provides TwinGenerationInsight
]

instance TwinStateManagementService : DTDFVocab:Service [
    base:desc "Service that persists twin state and handles runtime configuration updates.",
    DTDFVocab:provides StateManagementInsight
]

instance ModelingService : DTDFVocab:Service [
    base:desc "Service that supports creation and editing of BIM artifacts.",
    DTDFVocab:provides ModelingInsight
]

instance ModelValidationService : DTDFVocab:Service [
    base:desc "Service that validates model consistency before deployment.",
    DTDFVocab:provides ValidationInsight
]

// C17: Insights
instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Provides real‑time insight into current building occupancy, illumination, and temperature."
]

instance SpatialInsight : DTDFVocab:Insight [
    base:desc "Gives spatially contextualized visualization of building state in 3D."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Shows simulated outcomes of alternative control strategies."
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Delivers forecasts of future occupancy patterns and energy usage."
]

instance TwinGenerationInsight : DTDFVocab:Insight [
    base:desc "Reports successful creation of per‑device digital twins."
]

instance StateManagementInsight : DTDFVocab:Insight [
    base:desc "Indicates successful persistence and update of twin state."
]

instance ModelingInsight : DTDFVocab:Insight [
    base:desc "Confirms BIM model editing operations."
]

instance ValidationInsight : DTDFVocab:Insight [
    base:desc "Shows model validation results."
]

// C17: Actions
instance OptimizationAction : DTDFVocab:Action [
    base:desc "Automatically adjusts lighting and HVAC set‑points based on optimization results.",
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in BIM and exposed through the twin framework for dimming control."
]

instance BuildingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Building control system component that receives commands from the digital twin to regulate HVAC."
]

// C5: Environment (System Under Study)
instance BuildingDigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, IlluminationSensor, TemperatureSensor, LightingActuator, BuildingControlActuator, EnrichedBIMModel
]

// C7: Component (DT Framework)
instance TwinFrameworkComponent : DTDFVocab:Component [
    base:desc "DT Framework that centrally manages all per‑device twins and handles runtime configuration updates."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (e.g., lighting set‑points) generated by the digital twin are transmitted back to the physical actuators via the same Hono/Ditto bidirectional communication pipeline."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Operates in real‑time, continuously synchronising sensor streams and control actions between the physical asset and its twin (exact update frequency not specified)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central DT Framework hub that interconnects BIM‑derived device twins, the Hono/Ditto middleware, and the Unreal Engine visualization layer, with standardized extension points for additional services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Supports the design stage (BIM authoring), deployment stage (automated generation of runtime artifacts), and operation stage (runtime monitoring, control, and analytics)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation is performed before deployment, and the Overall Digital Twin Entanglement (ODTE) metric is used to quantify the fidelity between the physical building and its digital twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication is realized via Eclipse Hono (device protocol layer, typically MQTT/AMQP) and Eclipse Ditto (HTTP/WebSocket twin API), enabling real‑time data exchange between PT and DT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework is built on BIM standards as the semantic backbone for model interoperability; it leverages standard open‑source components such as Eclipse Hono and Ditto."
]