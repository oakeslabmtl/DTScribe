// C3: Physical sensing components
instance BuildingTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in BIM to capture real-time building climate"
    DTDFVocab:producedData TemperatureDataStream
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Energy consumption sensor defined in BIM for monitoring power usage"
    DTDFVocab:producedData EnergyDataStream
]

instance FaultDetectionSensor : DTDFVocab:SensingComponent [
    base:desc "Fault detection sensor modeled in BIM to identify equipment anomalies"
    DTDFVocab:producedData FaultEventStream
]

// C4: Physical-to-virtual interaction
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingTemperatureSensor
]

instance EnergyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance FaultEventStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FaultDetectionSensor
]

// C10: Models/Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature measurements from BuildingTemperatureSensor"
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo CentralDTFrameworkEnabler
]

instance EnergyData : DTDFVocab:Data [
    base:desc "Real-time energy consumption readings from EnergyConsumptionSensor"
    DTDFVocab:fromData EnergyDataStream
    DTDFVocab:inputTo CentralDTFrameworkEnabler
]

instance FaultEventData : DTDFVocab:Data [
    base:desc "Fault event records generated by FaultDetectionSensor"
    DTDFVocab:fromData FaultEventStream
    DTDFVocab:inputTo CentralDTFrameworkEnabler
]

instance BIMSemanticModel : DTDFVocab:Model [
    base:desc "Unified BIM-based semantic model capturing sensors, actuators, and control logic"
    DTDFVocab:inputTo CentralDTFrameworkEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral control logic derived from the BIM model for building automation"
    DTDFVocab:inputTo CentralDTFrameworkEnabler
]

// C11: Enablers
instance CentralDTFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Central DT Framework hub that manages device models, runtime data, and provides standardized extension points"
    DTDFVocab:enables DecisionSupportService
]

// C6: Services
instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Provides decision support through continuous real-time data sync, interactive visualisation, and extensible analytics"
    DTDFVocab:provides EnergyOptimizationInsight, FaultDetectionInsight, FacilityControlAction
]

// C17: Insights/Actions
instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Higher‑level insight for energy optimisation generated by analytics services"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting faults in building systems based on sensor streams"
]

instance FacilityControlAction : DTDFVocab:Action [
    base:desc "Control command issued by facility managers via the immersive visual interface"
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides continuous, real-time data exchange between the physical building and its digital counterpart, implying synchronization at the granularity of incoming sensor streams; no explicit latency or frequency values are given, but the intent is sub-second, real-time updates for monitoring and control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, service-oriented constellation: a central DT Framework integrates enriched BIM models, provides bidirectional data exchange, supports standardized extension points for custom services, and enables runtime configuration management, allowing components to be added or updated without redeployment."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a five‑stage life‑cycle for a building digital twin: (1) **Device modeling** – building control engineers enrich the BIM model with explicit sensor, actuator and controller entities; (2) **Model transformation** – model‑driven engineering (MDE) extracts a structured, platform‑independent representation from the enriched BIM; (3) **Artifact generation & deployment** – the structured model is automatically compiled into deployable DT artefacts (services, data bindings) and instantiated in the runtime environment; (4) **Operational runtime** – real‑time data exchange synchronises physical building state with the twin, enabling monitoring, visualization and control; (5) **Evolution & maintenance** – standardized extension points allow DT engineers to inject custom services, analytics or updates, with the lifecycle governed by role‑based responsibilities (engineer, facility manager, DT engineer). Transitions between stages are managed by automated pipelines that trigger on model changes, ensuring traceability and governance."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is achieved through standardized extension points and non-functional requirements (NF_X) that address heterogeneous system integration; the DT exchanges data with BIM tools and other enterprise systems via generic, protocol-agnostic interfaces, though specific protocols are not listed."
]