    base:desc "Real-time CO2 data transmitted from physical sensors via Eclipse Hono and Ditto"
]

instance LightDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Real-time light data transmitted from physical sensors via Eclipse Hono and Ditto"
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
