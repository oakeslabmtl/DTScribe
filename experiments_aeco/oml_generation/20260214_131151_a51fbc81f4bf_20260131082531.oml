instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for controlling HVAC systems in building infrastructure"
]

instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Controller for managing lighting systems in building infrastructure"
]

instance ValveController : DTDFVocab:ActingComponent [
    base:desc "Controller for regulating valves in building control systems"
]

instance BIMTools : DTDFVocab:Enabler [
    base:desc "BIM tools for modeling and model-driven automated deployment process that extracts semantics from BIM models to generate runtime interfaces, with runtime configuration management for adjustments without full redeployment, supporting service-oriented evolution."
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for IoT connectivity"
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for digital twin management"
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for interactive visualization"
]

instance BIMModel : DTDFVocab:Model [
    base:desc "Building Information Modeling (BIM) based models providing comprehensive representation of building geometry, topology, component relationships, and device-specific data for sensors, actuators, and controllers."
]

instance RealTimeMonitoring : DTDFVocab:Service [
    base:desc "Real-time monitoring of building systems for continuous synchronization"
]

instance Simulation : DTDFVocab:Service [
    base:desc "Simulation of building operations for life cycle-encompassing optimization"
]

instance PredictiveAnalytics : DTDFVocab:Service [
    base:desc "Predictive analytics for enhanced decision-making in facility management"
]

instance PerformanceAnalysis : DTDFVocab:Service [
    base:desc "Performance analysis of building systems for operational efficiency"
]

instance InteractiveVisualization : DTDFVocab:Service [
    base:desc "Interactive visualization of building data for facility management"
]

instance Optimization : DTDFVocab:Service [
    base:desc "Optimization of energy consumption, visual comfort, and non-visual health effects through reinforcement learning"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization of energy consumption for improved sustainability"
]

instance IndoorEnvironmentalInsight : DTDFVocab:Insight [
    base:desc "Insights for maintaining optimal indoor environmental conditions"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insights from simulation of building operations"
]

instance PerformanceAnalysisInsight : DTDFVocab:Insight [
    base:desc "Insights from performance analysis of building systems"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insights from interactive visualization of building data"
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time insights for facility management decision-making"
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Insights related to visual comfort optimization"
]

instance NonVisualHealthInsight : DTDFVocab:Insight [
    base:desc "Insights related to non-visual health effects optimization"
]

instance BuildingEnvironment : DTDFVocab:Environment [
    base:desc "Building infrastructure in the AECO domain, specifically demonstrated in a Living Lab case study for real-time monitoring, simulation, and life cycle-encompassing optimization of building operations."
    base:contains TemperatureSensor, HumiditySensor, CO2Sensor, LightSensor, OccupancySensor, HVACActuator, LightingController, ValveController, BIMModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Transmission of control signals from the digital twin to Building Control Systems (BCS) actuators for optimization and regulation of building operations."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with continuous data exchange between physical and virtual components."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized DT Framework acting as a hub for bidirectional data exchange, with modular services and standardized extension points for integration of roles including Building Control Engineers, Facility Managers, and DT Engineers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the entire building life cycle from initial design through construction, operation, and refurbishments."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Measured using the Overall Digital Twin Entanglement (ODTE) metric to assess interoperability and architectural soundness of the DT."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono and Ditto for real-time data exchange, facilitating bidirectional communication between physical assets and the digital twin."
]