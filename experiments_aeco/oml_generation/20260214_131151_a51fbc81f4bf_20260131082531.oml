    base:desc "CO2 sensor for monitoring indoor air quality"
]

instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor for monitoring visual comfort conditions"
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor for monitoring operational data in building systems"
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Real-time temperature data transmitted from physical sensors via Eclipse Hono and Ditto"
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Real-time humidity data transmitted from physical sensors via Eclipse Hono and Ditto"
]

