// Environment
instance LivingLabBuilding : DTDFVocab:Environment [
    base:desc "LEED Platinum certified academic building serving as the physical twin."
]

// Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the LivingLab building, part of the BIM model."
    DTDFVocab:producedData TemperatureTopic
]
instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor embedded in the LivingLab building, part of the BIM model."
    DTDFVocab:producedData HumidityTopic
]
instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor embedded in the LivingLab building, part of the BIM model."
    DTDFVocab:producedData CO2Topic
]
instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor embedded in the LivingLab building, part of the BIM model."
    DTDFVocab:producedData IlluminanceTopic
]
instance MotionSensor : DTDFVocab:SensingComponent [
    base:desc "Motion sensor embedded in the LivingLab building, part of the BIM model."
    DTDFVocab:producedData MotionTopic
]
instance EnergyMeter : DTDFVocab:SensingComponent [
    base:desc "Energy meter embedded in the LivingLab building, part of the BIM model."
    DTDFVocab:producedData EnergyTopic
]

// Data Transmitted (MQTT Topics)
instance TemperatureTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance HumidityTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]
instance CO2Topic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]
instance IlluminanceTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]
instance MotionTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionSensor
]
instance EnergyTopic : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeter
]

// Runtime Sensor Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Runtime temperature data stream published over MQTT."
    DTDFVocab:inputTo EclipseDittoRegistry
    DTDFVocab:fromData TemperatureTopic
]
instance HumidityData : DTDFVocab:Data [
    base:desc "Runtime humidity data stream published over MQTT."
    DTDFVocab:inputTo EclipseDittoRegistry
    DTDFVocab:fromData HumidityTopic
]
instance CO2Data : DTDFVocab:Data [
    base:desc "Runtime CO₂ data stream published over MQTT."
    DTDFVocab:inputTo EclipseDittoRegistry
    DTDFVocab:fromData CO2Topic
]
instance IlluminanceData : DTDFVocab:Data [
    base:desc "Runtime illuminance data stream published over MQTT."
    DTDFVocab:inputTo EclipseDittoRegistry
    DTDFVocab:fromData IlluminanceTopic
]
instance MotionData : DTDFVocab:Data [
    base:desc "Runtime motion data stream published over MQTT."
    DTDFVocab:inputTo EclipseDittoRegistry
    DTDFVocab:fromData MotionTopic
]
instance EnergyData : DTDFVocab:Data [
    base:desc "Runtime energy consumption data stream published over MQTT."
    DTDFVocab:inputTo EclipseDittoRegistry
    DTDFVocab:fromData EnergyTopic
]

// Models and Transformation Artifacts
instance SemanticBIMModel : DTDFVocab:Model [
    base:desc "Semantic BIM model in IFC format representing the building’s geometry and component metadata."
    DTDFVocab:inputTo IFCBIMTools
]
instance MQTTTopicSchema : DTDFVocab:Model [
    base:desc "JSON schema defining the MQTT topic structure for sensor telemetry."
    DTDFVocab:inputTo EclipseDittoRegistry
]
instance LightingRLPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning policy model for lighting optimization."
    DTDFVocab:inputTo MDETransformationToolkit
]
instance EnergyConsumptionForecastModel : DTDFVocab:Model [
    base:desc "Predictive model forecasting energy consumption."
    DTDFVocab:inputTo MDETransformationToolkit
]
instance OccupancyPredictionModel : DTDFVocab:Model [
    base:desc "Occupancy prediction model for lighting scheduling."
    DTDFVocab:inputTo MDETransformationToolkit
]

// Enablers
instance EclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono message broker routing MQTT data to Ditto twin entities."
    DTDFVocab:enables RealTimeMonitoringDashboard, OccupancyBasedLightingOptimization
]
instance EclipseDittoRegistry : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin registry ingesting telemetry data from MQTT topics."
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveEnergyAnalytics, OccupancyBasedLightingOptimization, BuildingPerformanceSimulation, ImmersiveVisualization, RecommendationDashboard
]
instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 used for immersive visualization of twin data streams."
    DTDFVocab:enables ImmersiveVisualization
]
instance MDETransformationToolkit : DTDFVocab:Enabler [
    base:desc "Model‑to‑code/text transformation toolkit generating runtime artifacts."
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveEnergyAnalytics, OccupancyBasedLightingOptimization, BuildingPerformanceSimulation
]
instance IFCBIMTools : DTDFVocab:Enabler [
    base:desc "IFC‑based BIM tooling for device modeling and validation."
    DTDFVocab:enables RealTimeMonitoringDashboard, BuildingPerformanceSimulation
]
instance ValidationScripts : DTDFVocab:Enabler [
    base:desc "Validation scripts ensuring model and data consistency."
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveEnergyAnalytics
]
instance CICDPipeline : DTDFVocab:Enabler [
    base:desc "CI/CD pipelines for automated deployment of twin artifacts."
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveEnergyAnalytics, OccupancyBasedLightingOptimization, BuildingPerformanceSimulation
]

// Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Dashboard that displays real‑time telemetry and emits anomaly alerts."
    DTDFVocab:provides AnomalyAlert, DiagnosticReport
]
instance PredictiveEnergyAnalytics : DTDFVocab:Service [
    base:desc "Service performing predictive forecasting of energy consumption."
    DTDFVocab:provides PredictiveEnergyConsumptionForecast
]
instance OccupancyBasedLightingOptimization : DTDFVocab:Service [
    base:desc "Service optimizing lighting controls using occupancy predictions and RL policies."
    DTDFVocab:provides OccupancyAwareLightingSchedule, LightingControlAction
]
instance BuildingPerformanceSimulation : DTDFVocab:Service [
    base:desc "Simulation service computing building performance metrics using the BIM model."
    DTDFVocab:provides SimulationResultInsight
]
instance ImmersiveVisualization : DTDFVocab:Service [
    base:desc "Service delivering immersive twin state in Unreal Engine 5."
    DTDFVocab:provides VisualImmersionInsight
]
instance RecommendationDashboard : DTDFVocab:Service [
    base:desc "Dashboard aggregating analytics to recommend maintenance actions."
    DTDFVocab:provides RecommendationDashboardInsight
]
instance HVACDampersControlService : DTDFVocab:Service [
    base:desc "Service controlling HVAC dampers via MQTT based on sensor data."
    DTDFVocab:provides HVACDampersControlAction
]

// Insights
instance AnomalyAlert : DTDFVocab:Insight [
    base:desc "Alert notifying facility staff of anomalous telemetry readings."
]
instance DiagnosticReport : DTDFVocab:Insight [
    base:desc "Report summarizing diagnostics of building systems."
]
instance PredictiveEnergyConsumptionForecast : DTDFVocab:Insight [
    base:desc "Forecast of upcoming energy consumption for occupancy planning."
]
instance OccupancyAwareLightingSchedule : DTDFVocab:Insight [
    base:desc "Lighting schedule optimized for predicted occupancy patterns."
]
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Resulting evaluation of building performance from simulation."
]
instance VisualImmersionInsight : DTDFVocab:Insight [
    base:desc "Visual representation of twin state in Unreal Engine 5."
]
instance RecommendationDashboardInsight : DTDFVocab:Insight [
    base:desc "Recommendations for facility managers on maintenance actions."
]

// Actions
instance LightingControlAction : DTDFVocab:Action [
    base:desc "Command to adjust lighting levels via MQTT message to lighting fixtures."
    DTDFVocab:IsAutomatic true
]
instance HVACDampersControlAction : DTDFVocab:Action [
    base:desc "Command to actuate HVAC damper positions via MQTT."
    DTDFVocab:IsAutomatic true
]
instance BlindsActuationCommand : DTDFVocab:Action [
    base:desc "Command to control motorized blinds positioning."
    DTDFVocab:IsAutomatic false
]

// Acting Components
instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture actuator controlled via MQTT by the LT system."
]
instance HVACDamperActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC damper actuator controlled via MQTT messages."
]
instance BlindActuator : DTDFVocab:ActingComponent [
    base:desc "Motorized blind actuator controlled via MQTT."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., lighting level setpoints, HVAC setpoints) are published as MQTT messages via Ditto and forwarded by Eclipse Hono to the building control system, resulting in actuation of devices."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time synchronization driven by the building automation system; policy‑based polling and message delivery rates typically in the range of seconds to minutes support control loops, while visualization updates at a refresh rate of 1 Hz or higher."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Integrated stack comprising BIM‑based semantic foundation, Ditto twin registry, Hono messaging layer, controller and analytics modules, and Unreal Engine visualization, orchestrated by a central DT framework with defined extension points for modular services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (ideal) – BIM modeling; Manufacture – integration of device metadata into BIM; Operation – live data exchange and continuous testing. The DT spans from designed/ideal (BIM), through manufactured (device configuration), to operated (live operation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model consistency enforced by MDE transformation rules; runtime validation via ODTE metric to quantify entanglement; continuous verification of sensor data against expected ranges and control loop stability; iterative correction of semantic drift."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol over TLS via Eclipse Hono broker; Ditto twin registry exposes JSON‑based REST APIs and WebSocket streams; communication between PT and DT occurs over secure MQTT topics with quality‑of‑service QoS1/2."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Cloud‑hosted containerized deployment of Eclipse Hono broker, Eclipse Ditto registry, controller services, and analytics, with optional edge actors for low‑latency actuation; Unreal Engine visualization runs on a dedicated GPU server or cloud virtual desktop."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability facilitated by MQTT and Ditto’s REST interfaces, enabling integration with external IoT platforms, building information exchange systems, and third‑party analytics services; federation of twin data across organizational boundaries."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to IFC schema for BIM, MQTT standard for messaging, CoAP/REST semantics per Eclipse Ditto, and alignment with AECO domain standards (e.g., ISO 19650) for BIM data management."
]