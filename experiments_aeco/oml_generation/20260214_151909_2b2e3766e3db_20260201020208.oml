// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Embedded actuator within Building Control System (BCS) for dynamic lighting control, modeled in BIM with bidirectional communication via Eclipse Ditto middleware for runtime adjustments based on DT insights."
    base:isContainedIn BuildingInfrastructureEnvironment
]

instance HVACController : DTDFVocab:ActingComponent [
    base:desc "Building automation controller for HVAC systems, integrated with BIM metadata and Eclipse Hono/Ditto for real-time operational adjustments and energy optimization."
    base:isContainedIn BuildingInfrastructureEnvironment
]

// C3: Physical Sensing Components
instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "IoT sensor deployed in operational buildings capturing real-time environmental conditions (temperature, humidity, light levels) via Eclipse Hono integration."
    DTDFVocab:producedData EnvironmentalDataTransmitted
    base:isContainedIn BuildingInfrastructureEnvironment
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "IoT-based occupancy sensor tracking real-time building occupancy patterns, integrated with BIM tenant metadata and Eclipse Ditto for data ingestion."
    DTDFVocab:producedData OccupancyDataTransmitted
    base:isContainedIn BuildingInfrastructureEnvironment
]

instance EnergyMonitor : DTDFVocab:SensingComponent [
    base:desc "Building energy consumption meter capturing real-time energy usage metrics, connected via Eclipse Hono for DT synchronization."
    DTDFVocab:producedData EnergyDataTransmitted
    base:isContainedIn BuildingInfrastructureEnvironment
]

// C4: Physical-to-Virtual Interaction
instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMonitor
]

// C10: Models/Data
instance BIMCoreModel : DTDFVocab:Model [
    base:desc "Semantic Industry Foundation Classes (IfcSchema) representation of building geometry, spatial relationships, and component hierarchies serving as the DT's foundational data model."
    DTDFVocab:inputTo ModelDrivenEngine
    base:isContainedIn BIMModelingEnvironment
]

instance RuntimeMetadataModel : DTDFVocab:Model [
    base:desc "BIM extensions containing device configurations (sensor/actuator endpoints) and middleware metadata (Eclipse Hono/Ditto tenant IDs) for runtime synchronization."
    DTDFVocab:inputTo EclipseDitto, EclipseHono
    base:isContainedIn BIMModelingEnvironment
]

instance OperationalDataStream : DTDFVocab:Data [
    base:desc "Real-time IoT sensor data streams (temperature, humidity, occupancy) ingested via Eclipse Hono and processed for DT analysis."
    DTDFVocab:fromData EnvironmentalDataTransmitted, OccupancyDataTransmitted, EnergyDataTransmitted
    DTDFVocab:inputTo ReinforcementLearningFramework, UnrealEngine5
]

instance ControlPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement learning-based optimization policies (BOREALIS project) embedded within the DT for dynamic building operation adjustments."
    DTDFVocab:inputTo ReinforcementLearningFramework
]

instance VisualizationModel : DTDFVocab:Model [
    base:desc "Unreal Engine 5 interactive 3D representation of building infrastructure with real-time operational overlays for immersive monitoring."
    DTDFVocab:inputTo UnrealEngine5
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "IoT connectivity platform enabling secure, scalable data ingestion from physical sensors to the DT via MQTT protocol."
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Middleware for bidirectional communication between DT and physical systems, supporting device management and control logic deployment."
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "High-fidelity 3D visualization platform providing immersive real-time monitoring dashboards for stakeholders."
]

instance ModelDrivenEngine : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering tools automating transformations from BIM models to runtime artifacts (Ditto configurations, Unreal Engine plugins)."
]

instance ReinforcementLearningFramework : DTDFVocab:Enabler [
    base:desc "Adaptive control policy framework (BOREALIS project) optimizing energy efficiency and occupant comfort through real-time learning."
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous visualization and analysis of operational data (energy consumption, environmental conditions) via Unreal Engine 5."
    DTDFVocab:provides OperationalStatusInsight, EnergyConsumptionAlert
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Reinforcement learning-based optimization of building operations including adaptive lighting and HVAC control."
    DTDFVocab:provides EnergyEfficiencyRecommendation, OccupantComfortOptimization
]

instance BidirectionalControlService : DTDFVocab:Service [
    base:desc "Seamless synchronization between virtual and physical systems for device configuration and control logic deployment."
    DTDFVocab:provides DeviceConfigurationAction, ControlSignalAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D representation of building infrastructure with real-time operational overlays for immersive monitoring."
    DTDFVocab:provides OccupancyTrendVisualization, EnvironmentalConditionDashboard
]

// C17: Insights/Actions
instance OperationalStatusInsight : DTDFVocab:Insight [
    base:desc "Real-time status updates of building systems including occupancy patterns and environmental conditions for facility managers."
]

instance EnergyConsumptionAlert : DTDFVocab:Insight [
    base:desc "Predictive maintenance alerts triggered by anomalies in energy consumption patterns indicating potential equipment degradation."
]

instance EnergyEfficiencyRecommendation : DTDFVocab:Insight [
    base:desc "Actionable insights for dynamic control adjustments to optimize energy efficiency based on reinforcement learning predictions."
]

instance OccupantComfortOptimization : DTDFVocab:Insight [
    base:desc "Recommendations for maintaining optimal occupant comfort through adaptive building control systems."
]

instance DeviceConfigurationAction : DTDFVocab:Action [
    base:desc "Automated deployment of device configurations (sensor/actuator endpoints) from BIM metadata to physical systems."
    DTDFVocab:IsAutomatic true
]

instance ControlSignalAction : DTDFVocab:Action [
    base:desc "Execution of control commands (e.g., lighting intensity adjustments) from DT to physical actuators via Ditto middleware."
    DTDFVocab:IsAutomatic true
]

instance OccupancyTrendVisualization : DTDFVocab:Insight [
    base:desc "Visual representation of occupancy patterns over time for space utilization analysis in Unreal Engine 5 dashboards."
]

instance EnvironmentalConditionDashboard : DTDFVocab:Insight [
    base:desc "Interactive dashboard showing real-time environmental conditions (temperature, humidity, light levels) with historical comparisons."
]

// C1: Environment
instance BuildingInfrastructureEnvironment : DTDFVocab:Environment [
    base:desc "Unified virtual representation of physical building infrastructure including BCS components and IoT sensors."
    base:contains LightingActuator, HVACController, EnvironmentalSensor, OccupancySensor, EnergyMonitor
]

instance BIMModelingEnvironment : DTDFVocab:Environment [
    base:desc "Authoring environment for initial BIM modeling and device configuration using tools like Revit and ArchiCAD."
    base:contains BIMCoreModel, RuntimeMetadataModel
]

instance BuildingInfrastructure : DTDFVocab:SystemUnderStudy [
    base:desc "Building Information Model (BIM)-based Digital Twin for infrastructure in the Architecture, Engineering, Construction, and Operations (AECO) domain."
    DTDFVocab:hasEnvironment BuildingInfrastructureEnvironment, BIMModelingEnvironment
]

// Relationships between Enablers and Services
instance EclipseHono : DTDFVocab:Enabler [
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDitto : DTDFVocab:Enabler [
    DTDFVocab:enables BidirectionalControlService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    DTDFVocab:enables VisualizationService
]

instance ModelDrivenEngine : DTDFVocab:Enabler [
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance ReinforcementLearningFramework : DTDFVocab:Enabler [
    DTDFVocab:enables PredictiveAnalyticsService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Virtual-to-physical interaction occurs via **runtime control signals** generated by the DT and transmitted to physical actuators through middleware (Eclipse Ditto). The DT processes data (e.g., predictive analytics, optimization algorithms) and sends commands (e.g., adjust lighting, trigger HVAC adjustments) back to the physical system. This interaction is enabled by **standardized extension points** in the framework, allowing seamless integration of control logic derived from BIM models and runtime data."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The **twinning time scale** in this Digital Twin system is **real-time and continuous**, with synchronization occurring at **millisecond to second intervals** to ensure low-latency interaction between the Physical Twin and Digital Twin. The framework supports **event-driven data processing** for immediate responses (e.g., sensor alerts, control adjustments) and **time-series data aggregation** for long-term analytics (e.g., energy consumption trends, occupancy patterns). The **Eclipse Hono/Ditto middleware** enables high-frequency data exchange, while the **Unreal Engine visualization** updates dynamically to reflect real-time changes in the physical infrastructure. This time scale is critical for **predictive maintenance**, **energy optimization**, and **occupant comfort adjustments** in operational buildings."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated as a **service-oriented architecture** with the following components:
   - **Core DT Framework**: Central hub integrating BIM semantics, runtime data, and control logic.
   - **Middleware Layer**: Eclipse Hono/Ditto for **real-time data exchange** and device management.
   - **Visualization Layer**: Unreal Engine 5 for **immersive 3D interaction** with the DT.
   - **Extension Points**: Modular interfaces for integrating **custom services** (e.g., AI analytics, stakeholder dashboards) without disrupting core functionality.
   - **Runtime Configuration Manager**: Enables **dynamic adjustments** to the DT (e.g., updating control policies) without full redeployment. The constellation supports **scalability** from single-device DTs to entire building infrastructures via standardized BIM-based semantics."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT operates across **all life-cycle stages** of the building, from **design (as-designed)** to **construction (as-manufactured)** and **operation (as-operated)**. During design, the BIM model serves as the foundational representation. During construction, the DT integrates **as-built data** (e.g., sensor placements, device configurations) to refine the virtual model. In operation, the DT continuously synchronizes with **real-time operational data** (e.g., occupancy, energy usage) to enable dynamic optimization and predictive maintenance. The framework also supports **post-occupancy adjustments** (e.g., reinforcement learning updates in BOREALIS) to adapt the DT to evolving operational needs."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through:
   - **Overall Digital Twin Entanglement (ODTE) Metric**: Quantifies the alignment between the DT and its physical counterpart, validating synchronization accuracy.
   - **Verification and Validation (V&V)**: Automated checks for **semantic consistency** between BIM models and runtime artifacts (e.g., ensuring device configurations match physical deployments).
   - **Uncertainty Modeling**: Incorporation of **sensor noise, latency, and environmental variability** into DT simulations to assess robustness.
   - **Post-Occupancy Evaluation**: Continuous comparison of DT predictions (e.g., energy consumption forecasts) with actual operational data to refine models. The framework also addresses **semantic drift** (as discussed in Abbasi et al.) by ensuring periodic synchronization between BIM and runtime data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT system employs **Eclipse Hono and Ditto middleware** for technical connectivity, facilitating **real-time data exchange** between physical sensors/actuators and the virtual twin. While specific protocols like **MQTT** are implied by the middleware’s design (e.g., Ditto’s support for MQTT-based communication), the documents do not explicitly mention MQTT. The connection architecture includes:
   - **Bidirectional communication channels**: Enabling sensor data ingestion and control signal transmission.
   - **Standardized interfaces**: For integrating with Building Control Systems (BCS) and other operational devices. The middleware abstracts lower-level protocols, ensuring interoperability across heterogeneous systems."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT system is deployed in a **scalable, cloud-based environment** to support large-scale infrastructure monitoring and optimization. The framework does not specify exact hosting technologies (e.g., Docker/Kubernetes), but emphasizes **scalable deployment** capabilities to accommodate growing data volumes and service integrations. The middleware (Hono/Ditto) is designed for **distributed deployment**, enabling horizontal scaling of DT components as needed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The DT system adheres to **AECO-specific standards**, primarily **Building Information Modeling (BIM)** as the foundational modeling paradigm. While the documents do not explicitly mention industry-specific standards like **IFC (Industry Foundation Classes)** or **COBie (Construction Operations Building Information Exchange)**, BIM is recognized as the standard solution for the construction sector. The middleware (Hono/Ditto) aligns with **open-source and standardized IoT protocols**, though specific protocols (e.g., MQTT, BACnet, KNX) are not detailed in the provided context."
]