// C3: Physical Sensing Components
instance EnvironmentalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors deployed in buildings to capture real-time operational data, specifically measuring environmental temperature for monitoring and analysis."
    DTDFVocab:producedData EnvironmentalTemperatureDataTransmitted
]

instance EnvironmentalHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors deployed in buildings to capture real-time operational data, specifically measuring environmental humidity for monitoring and analysis."
    DTDFVocab:producedData EnvironmentalHumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors deployed in buildings to capture real-time occupancy data for monitoring and analysis of space utilization."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors deployed in buildings to capture real-time energy consumption data for operational optimization."
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

instance LightingLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors deployed in buildings to capture real-time lighting level data for visual comfort optimization."
    DTDFVocab:producedData LightingLevelDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance EnvironmentalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalTemperatureSensor
]

instance EnvironmentalHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalHumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance LightingLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingLevelSensor
]

// C10: Models/Data
instance BuildingInformationModel : DTDFVocab:Model [
    base:desc "Building Information Modeling (BIM) as the foundational model, enriched with runtime semantics for Building Control Systems (BCS)."
    DTDFVocab:inputTo EclipseHonoMiddleware, UnrealEngineVisualization
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Real-time operational data from sensors and IoT devices integrated into the Digital Twin for monitoring and analysis."
    DTDFVocab:fromData EnvironmentalTemperatureDataTransmitted, EnvironmentalHumidityDataTransmitted, OccupancyDataTransmitted, EnergyConsumptionDataTransmitted, LightingLevelDataTransmitted
    DTDFVocab:inputTo EclipseHonoMiddleware, DittoMiddleware
]

instance SimulationModels : DTDFVocab:Model [
    base:desc "Simulation models for predictive analytics and optimization of building operations."
    DTDFVocab:inputTo UnrealEngineVisualization, EclipseHonoMiddleware
]

// C11: Enablers
instance EclipseHonoMiddleware : DTDFVocab:Enabler [
    base:desc "Middleware platform for real-time data exchange from physical assets to the Digital Twin via Eclipse Hono."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, OptimizationService
]

instance DittoMiddleware : DTDFVocab:Enabler [
    base:desc "Middleware platform for bidirectional communication protocols ensuring continuous synchronization of data between physical building and Digital Twin."
    DTDFVocab:enables RealTimeMonitoringService, CustomServiceIntegration
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Interactive visualization tool using Unreal Engine for immersive building operation monitoring."
    DTDFVocab:enables InteractiveVisualizationService
]

instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model-driven engineering principles for automating the deployment of Digital Twins from BIM models."
    DTDFVocab:enables DeploymentService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real-time monitoring of building operations using sensor data and simulation models."
    DTDFVocab:provides BuildingOperationalMetricsInsight, PredictiveMaintenanceRecommendationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service providing predictive analytics for energy optimization and operational performance forecasting."
    DTDFVocab:provides EnergyOptimizationStrategyInsight, OperationalPerformanceMetricsInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing building operations such as energy efficiency and visual comfort."
    DTDFVocab:provides EnergyEfficiencyOptimizationAction, VisualComfortOptimizationAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Service providing interactive visualization of building operations using Unreal Engine."
    DTDFVocab:provides ImmersiveBuildingVisualizationInsight
]

instance CustomServiceIntegration : DTDFVocab:Service [
    base:desc "Service supporting custom integration of domain-specific applications into the Digital Twin framework."
    DTDFVocab:provides DomainSpecificApplicationInsight
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Service handling validation, configuration, and deployment of runtime interfaces for Digital Twin artifacts."
    DTDFVocab:provides DeploymentValidationInsight
]

// C2: Acting Components
instance LightingSystemActuator : DTDFVocab:ActingComponent [
    base:desc "Actuators embedded in Building Control Systems (BCS) for operational control of lighting systems."
]

instance HVACSystemActuator : DTDFVocab:ActingComponent [
    base:desc "Actuators embedded in Building Control Systems (BCS) for operational control of HVAC systems."
]

instance BuildingAutomationController : DTDFVocab:ActingComponent [
    base:desc "Controllers embedded in Building Control Systems (BCS) for integrated building automation."
]

// C17: Insights/Actions
instance BuildingOperationalMetricsInsight : DTDFVocab:Insight [
    base:desc "Operational performance metrics for facility managers and stakeholders."
]

instance PredictiveMaintenanceRecommendationInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance recommendations based on real-time and historical data analysis."
]

instance EnergyOptimizationStrategyInsight : DTDFVocab:Insight [
    base:desc "Energy optimization strategies derived from predictive analytics and simulation models."
]

instance OperationalPerformanceMetricsInsight : DTDFVocab:Insight [
    base:desc "Comprehensive operational performance metrics supporting data-driven improvements in building operations."
]

instance EnergyEfficiencyOptimizationAction : DTDFVocab:Action [
    base:desc "Automated optimization of energy consumption based on real-time data and predictive models."
    DTDFVocab:IsAutomatic true
]

instance VisualComfortOptimizationAction : DTDFVocab:Action [
    base:desc "Automated optimization of visual comfort through lighting and environmental control."
    DTDFVocab:IsAutomatic true
]

instance ImmersiveBuildingVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive visualization of building operations using Unreal Engine for enhanced decision-making."
]

instance DomainSpecificApplicationInsight : DTDFVocab:Insight [
    base:desc "Integration points for domain-specific applications and custom services within the Digital Twin framework."
]

instance DeploymentValidationInsight : DTDFVocab:Insight [
    base:desc "Validation results and configuration status of deployed Digital Twin artifacts."
]

// C1: Environment
instance BuildingControlSystemEnvironment : DTDFVocab:Environment [
    base:desc "Centralized environment containing all Building Control System components and their interactions."
    base:contains LightingSystemActuator, HVACSystemActuator, BuildingAutomationController
]

instance DigitalTwinFrameworkEnvironment : DTDFVocab:Environment [
    base:desc "Modular and service-oriented Digital Twin framework environment supporting both centralized and decentralized implementations."
    base:contains BuildingInformationModel, RealTimeOperationalData, SimulationModels, EclipseHonoMiddleware, DittoMiddleware, UnrealEngineVisualization, ModelDrivenEngineeringPipeline
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals generated by the DT and transmitted back to the physical building to adjust actuators and controllers (e.g., lighting, HVAC systems). This interaction is facilitated through middleware platforms and ensures real-time operational adjustments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization between the physical and virtual worlds, with continuous data exchange and updates to ensure the DT reflects the current state of the physical asset. The DT services operate at runtime, enabling immediate decision-making and adjustments."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT system is orchestrated as a cohesive platform that integrates BIM models, real-time data streams, control logic, and visualization tools. It enables bidirectional communication between the physical and virtual worlds, supporting a holistic approach to building lifecycle management."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the entire building lifecycle, from initial design and construction to operation, refurbishment, and adaptation. It supports representations of the physical counterpart as designed (ideal), as manufactured, and as operated, ensuring continuous alignment with the evolving physical asset."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The fidelity of the DT is evaluated using the Overall Digital Twin Entanglement (ODTE) metric to measure how well the DT reflects its physical counterpart. Validation mechanisms include real-time synchronization, automated data extraction, and continuous monitoring to ensure accuracy and reliability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT connects to the physical world using middleware platforms (Eclipse Hono and Ditto) for real-time data exchange. Network protocols and architectures support bidirectional communication, ensuring seamless integration between physical sensors/actuators and the DT."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed on a scalable, modular platform with standardized extension points. It leverages cloud-based or on-premise hosting solutions to support real-time operations and interactive visualization, with deployment automation reducing manual effort."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT framework supports integration with external systems, including other DTs, enterprise resource planning (ERP) systems, and IoT platforms. This enables cross-domain data exchange and interoperability, enhancing the overall functionality of the DT ecosystem."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not explicitly detailed in the document. However, the framework emphasizes the importance of data governance and compliance with regulatory standards, suggesting considerations for data ownership and privacy are part of the deployment process."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework adheres to AECO-specific standards such as BIM and integrates with open-source tools like Eclipse Hono and Ditto. It also supports standardized extension points for modular service integration, ensuring interoperability and compliance with industry standards."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Not explicitly detailed in the document. However, the framework’s emphasis on real-time control and bidirectional communication implies the need for robust security measures to protect against cyber threats and ensure safe operation of physical systems."
]