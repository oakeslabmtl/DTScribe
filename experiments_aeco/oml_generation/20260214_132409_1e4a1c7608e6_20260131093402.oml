// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the building control system, modeled in BIM, transmitting live occupancy events via Eclipse Hono."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance AmbientLightSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient light sensor embedded in the building control system, modeled in BIM, transmitting live light level data via Eclipse Hono."
    DTDFVocab:producedData AmbientLightDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the building control system, modeled in BIM, transmitting live temperature data via Eclipse Hono."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor embedded in the building control system, modeled in BIM, transmitting live humidity data via Eclipse Hono."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance EnergyMeter : DTDFVocab:SensingComponent [
    base:desc "Energy meter embedded in the building control system, modeled in BIM, transmitting live energy consumption data via Eclipse Hono."
    DTDFVocab:producedData EnergyDataTransmitted
]

// C4: Physical-to-virtual interaction
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance AmbientLightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientLightSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeter
]

// C10: Models/Data
instance BIMSemanticModel : DTDFVocab:Model [
    base:desc "Semantic BIM model enriched with device metadata used for runtime configuration."
    DTDFVocab:inputTo MDETransformationPipeline, UnrealEngine5Renderer
]

instance RuntimeConfigModel : DTDFVocab:Model [
    base:desc "Runtime configuration artifacts generated by the MDE transformation pipeline."
    DTDFVocab:inputTo MDETransformationPipeline
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic models that drive HVAC and lighting automation."
    DTDFVocab:inputTo MDETransformationPipeline, UnrealEngine5Renderer
]

instance OccupancyTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑stamped occupancy data stream received from the occupancy sensor."
    DTDFVocab:inputTo EclipseHonoBroker, EclipseDittoRegistry
    DTDFVocab:fromData OccupancyDataTransmitted
]

instance AmbientLightTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑stamped ambient light data stream received from the ambient light sensor."
    DTDFVocab:inputTo EclipseHonoBroker, EclipseDittoRegistry
    DTDFVocab:fromData AmbientLightDataTransmitted
]

instance TemperatureTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature data stream received from the temperature sensor."
    DTDFVocab:inputTo EclipseHonoBroker, EclipseDittoRegistry
    DTDFVocab:fromData TemperatureDataTransmitted
]

instance HumidityTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑stamped humidity data stream received from the humidity sensor."
    DTDFVocab:inputTo EclipseHonoBroker, EclipseDittoRegistry
    DTDFVocab:fromData HumidityDataTransmitted
]

instance EnergyTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑stamped energy consumption data stream received from the energy meter."
    DTDFVocab:inputTo EclipseHonoBroker, EclipseDittoRegistry
    DTDFVocab:fromData EnergyDataTransmitted
]

// C11: Enablers
instance EclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono as the pub/sub message broker for real‑time telemetry."
    DTDFVocab:enables UnrealVisualizationService, EnergyConsumptionAnalyticsService, LightingHVACOptimizationService, FacilityManagementDashboardService
]

instance EclipseDittoRegistry : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto as the device registry and twin storage."
    DTDFVocab:enables UnrealVisualizationService, EnergyConsumptionAnalyticsService, LightingHVACOptimizationService, FacilityManagementDashboardService
]

instance UnrealEngine5Renderer : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for interactive 3D rendering of the digital twin."
    DTDFVocab:enables UnrealVisualizationService
]

instance MDETransformationPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation pipeline that extracts device metadata from BIM and produces deployable configuration files."
    DTDFVocab:enables UnrealVisualizationService, EnergyConsumptionAnalyticsService, LightingHVACOptimizationService, FacilityManagementDashboardService
]

// C6: Services
instance UnrealVisualizationService : DTDFVocab:Service [
    base:desc "Service providing real‑time visualization in Unreal Engine 5."
    DTDFVocab:provides VisualizationInsight, DashboardRefreshAction
]

instance EnergyConsumptionAnalyticsService : DTDFVocab:Service [
    base:desc "Service performing predictive analytics for energy consumption."
    DTDFVocab:provides EnergyPerformanceReportInsight, PredictiveMaintenanceAlertInsight
]

instance LightingHVACOptimizationService : DTDFVocab:Service [
    base:desc "Service performing reinforcement‑learning based optimization of lighting and HVAC schedules."
    DTDFVocab:provides OptimizationRecommendationInsight, LightingScheduleUpdateAction, HVACScheduleUpdateAction
]

instance FacilityManagementDashboardService : DTDFVocab:Service [
    base:desc "Service powering facility‑management dashboards for facility managers."
    DTDFVocab:provides DashboardRefreshAction
]

// C17: Insights/Actions
instance EnergyPerformanceReportInsight : DTDFVocab:Insight [
    base:desc "Energy performance report generated by the analytics service."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendation generated by the reinforcement‑learning service."
]

instance PredictiveMaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance alert generated by the analytics service."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization insight provided by UnrealVisualizationService."
]

instance LightingScheduleUpdateAction : DTDFVocab:Action [
    base:desc "Automatic action updating lighting schedules based on reinforcement‑learning recommendations."
    DTDFVocab:IsAutomatic true
]

instance HVACScheduleUpdateAction : DTDFVocab:Action [
    base:desc "Automatic action updating HVAC schedules based on reinforcement‑learning recommendations."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceCommandAction : DTDFVocab:Action [
    base:desc "Automatic action commanding maintenance activities in response to predictive maintenance alerts."
    DTDFVocab:IsAutomatic true
]

instance DashboardRefreshAction : DTDFVocab:Action [
    base:desc "Action to refresh facility management dashboards."
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance DimmerSwitch : DTDFVocab:ActingComponent [
    base:desc "Dimmer switch acting component for lighting fixtures, controlled via Eclipse Ditto."
]

instance HVAFan : DTDFVocab:ActingComponent [
    base:desc "HVAC fan acting component, controlled via Eclipse Ditto."
]

instance HVACDamper : DTDFVocab:ActingComponent [
    base:desc "HVAC damper acting component, controlled via Eclipse Ditto."
]

instance BuildingServiceDevice : DTDFVocab:ActingComponent [
    base:desc "Generic building service device, controlled via Eclipse Ditto."
]

// C10: Components
instance LightingSubTwin : DTDFVocab:Component [
    base:desc "Sub‑twin component dedicated to lighting operations."
]

instance HVACSubTwin : DTDFVocab:Component [
    base:desc "Sub‑twin component dedicated to HVAC operations."
]

instance MonitoringSubTwin : DTDFVocab:Component [
    base:desc "Sub‑twin component dedicated to monitoring service."
]

instance LivingLabBuildingTwin : DTDFVocab:Component [
    base:desc "Digital twin of the LEED Platinum academic Living Lab building."
]

// C15: Environment
instance BuildingDigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains LightingSubTwin, HVACSubTwin, MonitoringSubTwin, LivingLabBuildingTwin
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands issued by the digital twin back to the physical subsystem, such as setting lighting levels, HVAC setpoints or fan speeds, transmitted through Ditto’s device registry and delivered over Hono to the physical devices."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization driven by sensor reporting intervals (typically seconds) and periodic optimization cycles (e.g., hourly) that update control policies in the digital twin and propagate them to the physical system."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin constellation consists of the BIM core, the Hono/Ditto middleware layer, individual device twins, the visualization engine, and business‑logic services, all connected through standardized interfaces and orchestrated by the DT framework hub."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Deployment spans the full life‑cycle of the building: design (BIM model creation), construction (device commissioning), commissioning (configuring middleware and verifying mappings), and operation (continuous monitoring, optimization, and iterative learning via reinforcement agents)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The fidelity of the twin is quantified using the Overall Digital Twin Entanglement (ODTE) metric, which measures the degree of alignment between the virtual representation and the physical system, supplemented by model validation checks during the deployment pipeline."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time event and telemetry exchange is facilitated by Eclipse Hono, which uses a lightweight publish/subscribe protocol over secure TCP (TLS) to transport data, while Ditto exposes device twins via RESTful HTTP endpoints that can be queried or updated by the twin services."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin infrastructure is hosted on a cloud‑based container platform that runs Hono, Ditto, and the Unreal Engine rendering service, allowing scalable deployment and remote access for stakeholders."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The twin can exchange data with external information systems such as enterprise asset management (EAM) tools, BIM collaboration portals, and other domain‑specific DTs through standardized interfaces provided by the middleware layer."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Operational data generated by the building devices remains the property of the building owner, while the twin service provider supplies analytics services under a data‑sharing agreement that enforces privacy controls on sensitive data streams."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The engineering of the twin follows BIM IFC for asset semantics, MQTT/TCP‑based Hono protocol, Ditto’s twin‑model schema, and industry‑accepted data formats for sensor telemetry, ensuring interoperability across the AECO domain."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "All communication channels are secured with TLS, authentication is enforced by Hono’s device provisioning mechanism, and safety rules are embedded in the control logic to prevent unsafe actuator commands from being executed on the physical building during operation."
]