// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in the BIM environment"
    DTDFVocab:producedData OccupancyDataTransmission
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor modeled in the BIM environment"
    DTDFVocab:producedData IlluminationDataTransmission
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in the BIM environment"
    DTDFVocab:producedData TemperatureDataTransmission
]

// C4: Physical‑to‑virtual interaction (data transmitted)
instance OccupancyDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance TemperatureDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C10: Data generated from transmissions
instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy measurements"
    DTDFVocab:fromData OccupancyDataTransmission
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Real‑time illumination level measurements"
    DTDFVocab:fromData IlluminationDataTransmission
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature measurements"
    DTDFVocab:fromData TemperatureDataTransmission
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// C11: Enablers (tooling and platform)
instance BIMEnabler : DTDFVocab:Enabler [
    base:desc "Building Information Modeling (BIM) as the semantic backbone"
    DTDFVocab:enables RealTimeMonitoringService, Interactive3DVisualizationService
]

instance ModelDrivenEngineeringEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering for automated artifact generation"
    DTDFVocab:enables BuildingPerformanceSimulationService, LifeCycleOptimizationService
]

instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for device ingestion and real‑time streaming"
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for digital twin representation and event handling"
    DTDFVocab:enables RealTimeMonitoringService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3‑D visualization"
    DTDFVocab:enables Interactive3DVisualizationService
]

instance ExtensionPointsEnabler : DTDFVocab:Enabler [
    base:desc "Standardized extension points for modular service integration"
    DTDFVocab:enables RealTimeMonitoringService, Interactive3DVisualizationService, BuildingPerformanceSimulationService, LifeCycleOptimizationService
]

// C10: Models / data sources
instance BaseBIMModel : DTDFVocab:Model [
    base:desc "Base BIM model supplying geometric, spatial and functional data"
    DTDFVocab:inputTo BIMEnabler
]

instance RuntimeEnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with sensor configurations and control logic"
    DTDFVocab:inputTo ModelDrivenEngineeringEnabler, BIMEnabler
]

instance BuildingPerformanceSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model used for building performance analysis"
    DTDFVocab:inputTo ModelDrivenEngineeringEnabler
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building conditions"
    DTDFVocab:provides RealTimeInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3‑D visualization via Unreal Engine 5"
    DTDFVocab:provides VisualInsight
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance for predictive analysis"
    DTDFVocab:provides EnergySavingInsight, ComfortAdjustmentInsight
]

instance LifeCycleOptimizationService : DTDFVocab:Service [
    base:desc "Life‑cycle optimisation (energy minimisation, comfort optimisation)"
    DTDFVocab:provides EnergySavingInsight, ComfortAdjustmentInsight
]

// C17: Insights / Actions
instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight derived from live sensor streams"
]

instance VisualInsight : DTDFVocab:Insight [
    base:desc "Insight presented through immersive 3‑D visualization"
]

instance EnergySavingInsight : DTDFVocab:Insight [
    base:desc "Insight recommending actions to minimise energy consumption"
]

instance ComfortAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Insight recommending adjustments to improve occupant comfort"
]

instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Command to modify lighting levels based on optimisation recommendations"
    DTDFVocab:IsAutomatic true
]

instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Command to adjust HVAC settings for energy saving and comfort"
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control device defined in the BIM model capable of receiving command signals"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command transmission from the Digital Twin to physical actuators/controllers through the same Hono/Ditto middleware, enabling runtime control actions such as lighting adjustments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (continuous) synchronization between physical sensors/actuators and the Digital Twin, supporting immediate feedback loops for monitoring and control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized DT framework that aggregates enriched BIM data, connects physical devices via Hono/Ditto, hosts simulation and optimisation services, and delivers visualization through Unreal Engine, orchestrating the full set of twins and services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin spans the building life‑cycle phases addressed in the paper: design (BIM authoring), construction, and operation (runtime monitoring and optimisation)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is employed to assess how well the Digital Twin reflects its physical counterpart, providing a quantitative measure of interoperability and architectural soundness."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time connectivity is achieved through Eclipse Hono (device ingestion) coupled with Eclipse Ditto (digital twin representation), forming the communication backbone between physical assets and the Digital Twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is grounded in BIM standards for building data representation and leverages the ODTE metric for standardized evaluation of twin fidelity."
]