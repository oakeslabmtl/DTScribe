// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in BIM, publishes measurements via Eclipse Hono to Ditto"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor modeled in BIM, publishes measurements via Eclipse Hono to Ditto"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM, publishes measurements via Eclipse Hono to Ditto"
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Models/Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Continuous temperature measurements transmitted from building temperature sensor"
    DTDFVocab:inputTo HonoDittoDataEnabler
    DTDFVocab:fromData TemperatureDataTransmitted
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Continuous humidity measurements transmitted from building humidity sensor"
    DTDFVocab:inputTo HonoDittoDataEnabler
    DTDFVocab:fromData HumidityDataTransmitted
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Continuous occupancy measurements transmitted from building occupancy sensor"
    DTDFVocab:inputTo HonoDittoDataEnabler
    DTDFVocab:fromData OccupancyDataTransmitted
]

instance BIMGeometryTopologyModel : DTDFVocab:Model [
    base:desc "BIM geometry and topology information derived from the building design"
    DTDFVocab:inputTo SimulationModelEnabler
]

instance RuntimeControlLogicModel : DTDFVocab:Model [
    base:desc "Runtime control logic generated during MDE pipeline to drive actuators"
    DTDFVocab:inputTo SimulationModelEnabler
]

// C11: Enablers
instance HonoDittoDataEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono and Ditto middleware for real‑time data ingestion and twin management"
    DTDFVocab:enables SimulationAnalyticsService, ReinforcementLearningLightingOptimisationService, EnergyConsumptionAnalyticsService, Immersive3DVisualisationService, MDEPipelineService
]

instance SimulationModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler providing BIM models and runtime control logic to simulation and analytics services"
    DTDFVocab:enables SimulationAnalyticsService
]

// C6: Services
instance SimulationAnalyticsService : DTDFVocab:Service [
    base:desc "Provides simulation and predictive analytics running on BIM geometry and sensor data"
    DTDFVocab:provides RealTimeOperationalInsight
]

instance ReinforcementLearningLightingOptimisationService : DTDFVocab:Service [
    base:desc "Reinforcement learning based lighting optimization using live sensor data"
    DTDFVocab:provides LightingOptimizationInsight
]

instance EnergyConsumptionAnalyticsService : DTDFVocab:Service [
    base:desc "Analyzes energy consumption based on sensor data and runtime logic to provide actionable insights"
    DTDFVocab:provides EnergyConsumptionInsight
]

instance Immersive3DVisualisationService : DTDFVocab:Service [
    base:desc "Renders immersive 3D visualization using Unreal Engine 5"
    DTDFVocab:provides ThreeDVisualisationAction
]

instance MDEPipelineService : DTDFVocab:Service [
    base:desc "Automated MDE pipeline that extracts metadata, generates runtime artefacts, and iteratively refines control policies"
    DTDFVocab:provides DeployRuntimeArtefactsAction
]

// C17: Insights
instance RealTimeOperationalInsight : DTDFVocab:Insight [
    base:desc "Provides real‑time operational insights derived from sensor data and simulations"
]

instance LightingOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight generated by reinforcement learning for optimal lighting control"
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight into building energy consumption extracted from analytics"
]

// C17: Actions
instance ThreeDVisualisationAction : DTDFVocab:Action [
    base:desc "Action to provide immersive 3D visualization rendered via Unreal Engine 5"
    DTDFVocab:IsAutomatic true
]

instance DeployRuntimeArtefactsAction : DTDFVocab:Action [
    base:desc "Automated action to deploy runtime control artefacts to building control systems"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator device controlling lighting dimming and switching, managed via Ditto"
]

instance BuildingControlSystemComponent : DTDFVocab:ActingComponent [
    base:desc "Building control system component configured by engineers to execute physical actions"
]

// C17: Environment
instance CentralDTFrameworkHub : DTDFVocab:Environment [
    base:contains LightingControlActuator, BuildingControlSystemComponent, TemperatureSensor, HumiditySensor, OccupancySensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin forwards control commands to the building control system through Eclipse Hono/Ditto, influencing actuators such as lighting or other controlled devices."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time synchronization between physical and virtual entities; updates occur as sensor data streams are transmitted, with no specific time granularity defined in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central service hub composed of the Ditto twin registry, Hono messaging layer, MDE transformation engine, and visualization front‑end, collectively managing device twins and runtime services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans all lifecycle phases: design‑time BIM models (idealised), as‑built models captured during construction, and operated models reflecting live sensor data during facility operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Entanglement measured by the Overall Digital Twin Entanglement (ODTE) metric; consistency checks between BIM models and runtime state; verification of control logic against design specifications; validation of sensor data streams against physical measurements."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between physical assets and the Digital Twin is mediated through Eclipse Hono and Ditto services, facilitating bidirectional transmission of sensor data and control commands."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to AECO‑specific standards such as BIM for building information; use of Eclipse Hono and Ditto as standard middleware for messaging and twin management; no further standards are specified."
]