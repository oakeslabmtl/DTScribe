// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator that can be addressed via the digital twin to adjust illumination levels."
]

instance HVACValveController : DTDFVocab:ActingComponent [
    base:desc "HVAC valve controller enabling modulation of heating/cooling flow."
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the building, configuration stored in BIM and streams live data via Eclipse Hono."
    DTDFVocab:producedData TemperatureDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the building, configuration stored in BIM and streams live data via Eclipse Hono."
    DTDFVocab:producedData OccupancyDataStream
]

instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor embedded in the building, configuration stored in BIM and streams live data via Eclipse Hono."
    DTDFVocab:producedData LightingDataStream
]

// C4: Physical-to-virtual interaction
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightingDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature readings used for monitoring and analytics."
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo EclipseHonoConnector, EclipseDittoStateManager
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy counts used for space utilization analytics."
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo EclipseHonoConnector, EclipseDittoStateManager
]

instance LightingData : DTDFVocab:Data [
    base:desc "Live lighting level measurements used for energy optimization."
    DTDFVocab:fromData LightingDataStream
    DTDFVocab:inputTo EclipseHonoConnector, EclipseDittoStateManager
]

// C10: Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM containing geometry, spatial information, and sensor/actuator metadata."
    DTDFVocab:inputTo BIMModelEnricher, EclipseDittoStateManager
]

instance RuntimeDataModel : DTDFVocab:Model [
    base:desc "Model representing live sensor streams and twin state for runtime analysis."
    DTDFVocab:inputTo EclipseHonoConnector, EclipseDittoStateManager
]

// C11: Enablers
instance EclipseHonoConnector : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides device connectivity and streams sensor data to the twin."
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoStateManager : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital‑twin state and synchronizes data."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, EnergyOptimizationService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders immersive 3D visualization of the building twin."
    DTDFVocab:enables InteractiveVisualizationService
]

instance BOREALISEnergyRL : DTDFVocab:Enabler [
    base:desc "BOREALIS implements reinforcement learning to adapt lighting and HVAC control policies."
    DTDFVocab:enables EnergyOptimizationService
]

instance BIMModelEnricher : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering enriches the BIM with device metadata and runtime semantics."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, SimulationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of building conditions."
    DTDFVocab:provides EnergyConsumptionForecastInsight, PredictiveAlertInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Runs predictive analytics to forecast energy consumption and detect anomalies."
    DTDFVocab:provides EnergyConsumptionForecastInsight, PredictiveAlertInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes energy usage by generating adaptive lighting schedules and HVAC setpoints."
    DTDFVocab:provides LightingScheduleRecommendationInsight, AdaptiveLightingAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Delivers immersive 3D visualization via Unreal Engine 5."
    DTDFVocab:provides VisualAnalyticsReportInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates building performance for what‑if analysis."
    DTDFVocab:provides EnergyConsumptionForecastInsight
]

// C17: Insights
instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of building energy consumption derived from sensor data and predictive models."
]

instance LightingScheduleRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation for optimal lighting schedules to reduce energy usage."
]

instance PredictiveAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive alerts for abnormal temperature or occupancy patterns."
]

instance VisualAnalyticsReportInsight : DTDFVocab:Insight [
    base:desc "Visual analytics report displayed in the 3D twin."
]

// C17: Actions
instance AdaptiveLightingAction : DTDFVocab:Action [
    base:desc "Automatically adjusts lighting actuators based on RL policy."
    DTDFVocab:IsAutomatic true
]

// Environment (system under study)
instance LivingLabBuilding : DTDFVocab:Environment [
    base:desc "Physical building – the Living Lab academic building – modeled in BIM across design, construction, and operation."
    base:contains TemperatureSensor, OccupancySensor, LightingSensor, LightingActuator, HVACValveController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points, HVAC adjustments) are sent back to actuators via the same Hono/Ditto middleware, enabling bidirectional actuation of the physical building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework operates at real‑time scale, delivering continuous, low‑latency synchronization between physical sensors/actuators and the virtual twin; data exchange occurs as soon as new measurements are available."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized DT framework that ingests enriched BIM models, uses a Hono/Ditto configurator to generate runtime interfaces, connects physical devices to the twin, and visualizes the twin in Unreal Engine 5; custom services can be added through defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin spans the full building life‑cycle: design (BIM creation), construction (model enrichment with device metadata), operation (live data integration), and post‑occupancy adaptation (e.g., reinforcement‑learning based control refinement)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric quantifies how closely the twin reflects its physical counterpart, addressing semantic drift and ensuring continuous verification of model‑data consistency."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Integration of Eclipse Hono and Eclipse Ditto provides the technical link: devices transmit telemetry to Hono, which routes it to Ditto where the twin’s digital representation is updated; Ditto exposes APIs for command issuance that are relayed back through Hono to the devices, enabling real‑time bidirectional communication."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is built on the BIM standard as the semantic backbone and follows standardized extension points to ensure interoperability across tools and services."
]