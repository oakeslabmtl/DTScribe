// C2: Acting Components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator embedded in the building control system, addressable by the DT for state changes."
]

instance HVACValveController : DTDFVocab:ActingComponent [
    base:desc "HVAC valve controller used to regulate airflow, can be instructed by the DT to modify physical states."
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modelled in BIM, detects presence of occupants in building zones.",
    DTDFVocab:producedData OccupancyDataStream
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor modelled in BIM, measures light levels for each space.",
    DTDFVocab:producedData IlluminationDataStream
]

instance TemperatureHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Combined temperature and humidity sensor modelled in BIM, provides climate data.",
    DTDFVocab:producedData TempHumDataStream
]

instance PostOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy sensor used by the BOREALIS project to assess actual space utilisation.",
    DTDFVocab:producedData PostOccupancyDataStream
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance TempHumDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureHumiditySensor
]

instance PostOccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PostOccupancySensor
]

instance SimulationResultDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingPerformanceSimulationModel
]

// C10: Data
instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy measurements streamed from physical occupancy sensors.",
    DTDFVocab:fromData OccupancyDataStream,
    DTDFVocab:inputTo EclipseDittoStateManager, ModelDrivenPipelineEngine
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Real‑time illumination levels reported by BIM‑linked illumination sensors.",
    DTDFVocab:fromData IlluminationDataStream,
    DTDFVocab:inputTo EclipseDittoStateManager, ModelDrivenPipelineEngine
]

instance TempHumData : DTDFVocab:Data [
    base:desc "Current temperature and relative humidity values collected by integrated sensors.",
    DTDFVocab:fromData TempHumDataStream,
    DTDFVocab:inputTo EclipseDittoStateManager, ModelDrivenPipelineEngine
]

instance PostOccupancyData : DTDFVocab:Data [
    base:desc "Post‑occupancy evaluation metrics gathered after space usage.",
    DTDFVocab:fromData PostOccupancyDataStream,
    DTDFVocab:inputTo EclipseDittoStateManager, ModelDrivenPipelineEngine
]

instance SimulationResultData : DTDFVocab:Data [
    base:desc "Resulting performance metrics from building performance simulations.",
    DTDFVocab:fromData SimulationResultDataStream,
    DTDFVocab:inputTo EnergyOptimizationEngine, UnrealEngine5VisualizationEngine
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Static BIM model enriched with metadata for all sensors, actuators and control logic.",
    DTDFVocab:inputTo BIMAuthoringTool, EclipseDittoStateManager
]

instance RuntimeTwinModel : DTDFVocab:Model [
    base:desc "Runtime model stored in Eclipse Ditto, representing live twin state, policies and simulations.",
    DTDFVocab:inputTo EclipseDittoStateManager, ModelDrivenPipelineEngine
]

instance BuildingPerformanceSimulationModel : DTDFVocab:Model [
    base:desc "Simulation model used for predictive analytics and energy‑optimization algorithms.",
    DTDFVocab:inputTo EnergyOptimizationEngine, UnrealEngine5VisualizationEngine
]

// C11: Enablers
instance BIMAuthoringTool : DTDFVocab:Enabler [
    base:desc "BIM authoring tools (e.g., Revit, ArchiCAD) used to create and enrich the static building model.",
    DTDFVocab:enables CustomExtensionService
]

instance EclipseHonoConnector : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides MQTT/AMQP connectivity for continuous sensor streaming to the twin.",
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalyticsService
]

instance EclipseDittoStateManager : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages the digital twin's runtime state, persisting data and executing policies.",
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalyticsService, EnergyOptimizationService, BuildingPerformanceSimulationService
]

instance UnrealEngine5VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders the 3‑D interactive visualization of the twin for immersive stakeholder interaction.",
    DTDFVocab:enables Interactive3DVisualizationService, BuildingPerformanceSimulationService
]

instance ModelDrivenPipelineEngine : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline automatically generates deployment descriptors and artefacts.",
    DTDFVocab:enables CustomExtensionService, EnergyOptimizationService
]

instance EnergyOptimizationEngine : DTDFVocab:Enabler [
    base:desc "Algorithmic engine executing energy‑optimization calculations and generating set‑point recommendations.",
    DTDFVocab:enables EnergyOptimizationService
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards displaying live sensor streams, KPIs and alerts.",
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "3‑D interactive visualization service in Unreal Engine 5 for spatial exploration of twin data.",
    DTDFVocab:provides VisualizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service that forecasts building performance and detects anomalies.",
    DTDFVocab:provides PredictiveAlertInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy‑optimization service that computes energy‑saving set‑points and recommendations.",
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation service that runs building performance scenarios and feeds results back to the twin.",
    DTDFVocab:provides UpdatedControlParametersAction
]

instance CustomExtensionService : DTDFVocab:Service [
    base:desc "Extensible custom service integrated via defined extension points for specialised analytics.",
    DTDFVocab:provides CustomExtensionInsight
]

// C17: Insights/Actions
instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendations (energy‑saving set‑points) derived from analytics for facility‑manager decisions."
]

instance PredictiveAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive alerts signalling potential issues before they materialise, based on sensor trends."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "3‑D interactive visualization insight providing spatial context of building states in Unreal Engine 5."
]

instance CustomExtensionInsight : DTDFVocab:Insight [
    base:desc "Insight generated by custom extensible services via the twin's extension points."
]

instance UpdatedControlParametersAction : DTDFVocab:Action [
    base:desc "Updates control parameters sent to actuators to improve performance, presented as a recommendation (non‑automatic).",
    DTDFVocab:IsAutomatic false
]

// C15: Sub‑twins as Components
instance LightingTwinComponent : DTDFVocab:Component [
    base:desc "Logical sub‑twin responsible for lighting control, sensors and actuators.",
    base:isContainedIn BuildingDigitalTwinEnvironment
]

instance HVACTwinComponent : DTDFVocab:Component [
    base:desc "Logical sub‑twin responsible for HVAC control, climate sensors and valve actuators.",
    base:isContainedIn BuildingDigitalTwinEnvironment
]

instance OccupancyTwinComponent : DTDFVocab:Component [
    base:desc "Logical sub‑twin handling occupancy detection, usage analytics and space‑utilisation models.",
    base:isContainedIn BuildingDigitalTwinEnvironment
]

// C16: Environment (overall digital twin)
instance BuildingDigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains LightingTwinComponent, HVACTwinComponent, OccupancyTwinComponent, EnrichedBIMModel, RuntimeTwinModel, BuildingPerformanceSimulationModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command flow from the DT to the building control system through the Ditto middleware, issuing control set‑points (e.g., lighting levels, HVAC set‑points) that are executed by the physical actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near‑real‑time synchronization; sensor updates and control commands are exchanged continuously with latencies in the order of seconds, enabling live monitoring and immediate actuation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture where the DT framework acts as a hub linking the enriched BIM model, Hono/Ditto middleware, visualization client and custom analytics services into a coherent twin ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Supports the design stage (static BIM geometry), commissioning stage (enriched BIM with device metadata), operational stage (runtime data exchange and control) and can be extended to renovation or retro‑fit phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation before deployment and quantitative assessment of twin‑physical alignment using the Overall Digital Twin Entanglement (ODTE) metric to ensure semantic and state fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "IoT connectivity handled by Eclipse Hono using standard protocols (MQTT/AMQP over TLS) feeding data into Eclipse Ditto, which exposes a REST/WS API for the DT services and visualisation layer."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT components (Ditto services, Hono broker, transformation pipeline) are deployed as containerised micro‑services on a cloud or on‑premise platform; the Unreal Engine client runs on workstation hardware for interactive use."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Leverages BIM standards (e.g., IFC) for geometric and semantic data and uses open IoT standards (MQTT/AMQP, REST) through Eclipse Hono and Ditto to ensure interoperable integration."
]