import DTDFVocab

// C2: Acting Components
instance BIMIntegratedActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator defined in BIM, synthesized into a runtime component for remote control of building systems."
]

instance BIMIntegratedController : DTDFVocab:ActingComponent [
    base:desc "Controller defined in BIM, encapsulating control logic for integrated building automation."
]

// C3: Physical sensing components
instance BuildingTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled directly in BIM, providing measurement type and location.",
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance BuildingOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled directly in BIM, providing measurement type and location.",
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingTemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingOccupancySensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature readings streamed from the BIM‑integrated temperature sensor.",
    DTDFVocab:fromData TemperatureDataTransmitted,
    DTDFVocab:inputTo RealTimeDataExchangeEnabler, ModelProcessingEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy readings streamed from the BIM‑integrated occupancy sensor.",
    DTDFVocab:fromData OccupancyDataTransmitted,
    DTDFVocab:inputTo RealTimeDataExchangeEnabler, ModelProcessingEnabler
]

instance BIMAssetData : DTDFVocab:Data [
    base:desc "Static asset information extracted from the original BIM model.",
    DTDFVocab:inputTo ModelProcessingEnabler
]

// C10: Models
instance GeometricBIMModel : DTDFVocab:Model [
    base:desc "Geometric model extracted from enriched BIM representing building geometry.",
    DTDFVocab:inputTo ModelProcessingEnabler
]

instance BehavioralControlModel : DTDFVocab:Model [
    base:desc "Behavioral model embodying control logic defined by the Building Control Engineer.",
    DTDFVocab:inputTo ModelProcessingEnabler
]

instance AnalyticalSemanticModel : DTDFVocab:Model [
    base:desc "Analytical semantic model derived from relationships among sensors, actuators, and controllers.",
    DTDFVocab:inputTo ModelProcessingEnabler
]

// C11: Enablers
instance RealTimeDataExchangeEnabler : DTDFVocab:Enabler [
    base:desc "Provides real‑time data exchange capabilities that continuously synchronize physical building sensors with the digital twin.",
    DTDFVocab:enables RealTimeMonitoringService
]

instance ModelProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Processes incoming sensor data to feed geometric, behavioral, and analytical models.",
    DTDFVocab:enables SimulationAnalysisService, OperationalOptimizationService, PredictiveAnalyticsService
]

instance ServiceExecutionEnabler : DTDFVocab:Enabler [
    base:desc "Executes higher‑level services to generate insights and actionable recommendations for decision support.",
    DTDFVocab:enables DecisionSupportService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring that yields live building state visualizations.",
    DTDFVocab:provides RealTimeBuildingStateInsight
]

instance SimulationAnalysisService : DTDFVocab:Service [
    base:desc "Performs simulation and analysis of building behaviour based on models and live data.",
    DTDFVocab:provides SimulationOutcomeInsight, PredictivePerformanceInsight
]

instance OperationalOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes operational parameters using analytical models and sensor data.",
    DTDFVocab:provides OptimizationRecommendationInsight, AdjustOperationalParametersAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Conducts predictive analytics to forecast future building performance.",
    DTDFVocab:provides PredictivePerformanceInsight
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Delivers decision‑support capabilities, presenting insights and actionable recommendations.",
    DTDFVocab:provides DecisionSupportInsight, ActuateCommandAction
]

// C17: Insights
instance RealTimeBuildingStateInsight : DTDFVocab:Insight [
    base:desc "Live insight into current building states derived from continuous sensor streams."
]

instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Insight generated from simulation results describing predicted building behaviour."
]

instance PredictivePerformanceInsight : DTDFVocab:Insight [
    base:desc "Forecast of future building performance based on predictive analytics."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation for energy or operational optimization derived from analytical models."
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Aggregated decision‑support insight combining real‑time data, predictions, and recommendations."
]

// C17: Actions
instance ActuateCommandAction : DTDFVocab:Action [
    base:desc "Command sent from the digital twin to physical actuators to open/close, start/stop building systems.",
    DTDFVocab:IsAutomatic false
]

instance AdjustOperationalParametersAction : DTDFVocab:Action [
    base:desc "Automated adjustment of operational parameters (e.g., HVAC setpoints) based on optimization recommendations.",
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Through the same central hub, the Digital Twin issues control commands back to the building control systems, enabling Facility Managers to affect physical equipment in real time; the bidirectional exchange supports monitoring‑to‑control loops where the DT’s analytics generate actions that are enacted on the physical assets."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a full DT life‑cycle composed of (1) Device‑Modeling stage where building control engineers enrich BIM models with explicit sensor, actuator and controller entities; (2) Model‑Transformation stage that applies Model‑Driven Engineering (MDE) to extract a structured semantic representation and generate executable DT artifacts; (3) Deployment stage in which the generated artifacts are instantiated on the runtime platform; (4) Operation stage characterized by continuous real‑time data exchange between the physical building and its digital counterpart and interactive, immersive visualization for monitoring and control; and (5) Evolution stage where modular extension points allow DT engineers to plug in custom services, analytics or updated control logic. Transition between stages is automated by the MDE pipeline, and governance is expressed through the same pipeline, ensuring that each artefact is traceable to its originating BIM model."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection is realized via a modular architecture with standardized extension points and runtime configuration management, allowing heterogeneous components to interoperate; the network design emphasizes scalability, reliability, and low‑overhead updates, meeting non‑functional requirements for interoperability and maintainable communication across the DT infrastructure."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment follows a model‑driven approach where enriched BIM models are automatically transformed into operational Digital Twins; the DT Framework supports automated creation, configuration, and deployment on scalable infrastructure, with runtime configuration enabling adjustments without full redeployment and ensuring continuous availability across the building lifecycle."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution is built on the Building Information Modeling (BIM) standard, ensuring compatibility with established AECO‑specific standards. It adopts standardized extension points within its modular architecture to promote interoperability and to allow third‑party services to be integrated without breaking compliance. By grounding the entire twin lifecycle in BIM‑derived semantics, the framework aligns with industry‑wide specifications for data exchange and model representation."
]