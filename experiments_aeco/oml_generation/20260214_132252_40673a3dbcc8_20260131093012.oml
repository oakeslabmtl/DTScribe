// C12: Environment: Living Lab building environment
instance LivingLabBuildingEnvironment : DTDFVocab:Environment [
    base:contains IlluminationSensor, OccupancyDetector, TemperatureSensor,
    HumiditySensor, CO2Sensor, EnergyMeter, LightingDimmingModule,
    HVACValveActuator, ElectricalActuatorDevice
]

// New service definition for analytics
instance AnalyticsService : DTDFVocab:Service [
    base:desc "Service that performs analytics on historical sensor data."
    DTDFVocab:provides EnergySavingRecommendation, MaintenanceSchedule, AdaptiveLightingSchedule, EnergyMarketParticipationDecision
]

// New service definition for deployment
instance DeploymentService : DTDFVocab:Service [
    base:desc "Service that deploys configuration artifacts from the Model Driven Engineering pipeline."
    DTDFVocab:provides EnergySavingRecommendation
]

// C3: Physical sensing components
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor measuring ambient light with photodiodes, reporting values via MQTT to the Hono broker."
    DTDFVocab:producedData IlluminationDataTransmitted
]
instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector using passive infrared (PIR) technology to report presence via MQTT to the Hono broker."
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor (e.g., RTD or thermistor) publishing indoor temperature readings through MQTT to the Hono broker."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor measuring relative humidity, sending values to the Hono broker via MQTT."
    DTDFVocab:producedData HumidityDataTransmitted
]
instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor measuring indoor CO₂ concentration, transmitting data in JSON format over MQTT to the Hono broker."
    DTDFVocab:producedData CO2DataTransmitted
]
instance EnergyMeter : DTDFVocab:SensingComponent [
    base:desc "Energy meter measuring electrical consumption, publishing instantaneous and cumulative power data through MQTT to the Hono broker."
    DTDFVocab:producedData EnergyDataTransmitted
]

// C4: Data transmitted by sensors
instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]
instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]
instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeter
]

// C10: Data objects
instance IlluminationData : DTDFVocab:Data [
    base:desc "JSON payload containing illumination level readings published by IlluminationSensor."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseHonoBroker, TimeseriesDatabase
]
instance OccupancyData : DTDFVocab:Data [
    base:desc "JSON payload containing occupancy status reported by OccupancyDetector."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoBroker, TimeseriesDatabase
]
instance TemperatureData : DTDFVocab:Data [
    base:desc "JSON payload with temperature measurements from TemperatureSensor."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoBroker, TimeseriesDatabase
]
instance HumidityData : DTDFVocab:Data [
    base:desc "JSON payload with humidity readings from HumiditySensor."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseHonoBroker, TimeseriesDatabase
]
instance CO2Data : DTDFVocab:Data [
    base:desc "JSON payload carrying CO₂ concentration data from CO2Sensor."
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseHonoBroker, TimeseriesDatabase
]
instance EnergyData : DTDFVocab:Data [
    base:desc "JSON payload containing energy consumption metrics from EnergyMeter."
    DTDFVocab:fromData EnergyDataTransmitted
    DTDFVocab:inputTo EclipseHonoBroker, TimeseriesDatabase
]

// C3: Physical acting components
instance LightingDimmingModule : DTDFVocab:ActingComponent [
    base:desc "Lighting dimming module controlling LED fixtures, receiving dimming commands via Ditto."
]
instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "Valve actuator for HVAC ducts, adjusts flow based on building control commands."
]
instance ElectricalActuatorDevice : DTDFVocab:ActingComponent [
    base:desc "Generic electrical actuator device integrated into the building control system."
]

// C11: Enablers
instance EclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT broker that ingests sensor data and routes messages to Ditto and downstream services."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveOptimizationService
]
instance EclipseDittoService : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto service storing digital twin state and exposing REST interfaces for control commands."
    DTDFVocab:enables ReinforcementLearningControlService, TaskPlanningService, VisualizationService
]
instance TimeseriesDatabase : DTDFVocab:Enabler [
    base:desc "Time‑series database (e.g., InfluxDB) that archives historical sensor data for analytics."
    DTDFVocab:enables AnalyticsService
]
instance ModelDrivenTransformationTool : DTDFVocab:Enabler [
    base:desc "Model‑driven tooling that transforms enriched BIM models into JSON deployment descriptors for Hono/Ditto."
    DTDFVocab:enables DeploymentService
]

// C10: Model
instance BIMIFCModel : DTDFVocab:Model [
    base:desc "IFC BIM model of the Living Lab building that includes geometry, topology, and semantic annotations for devices."
    DTDFVocab:inputTo ModelDrivenTransformationTool
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors sensor streams in real time, performing analytics and generating energy‑saving recommendations."
    DTDFVocab:provides EnergySavingRecommendation, SendAlertAction
]
instance PredictiveOptimizationService : DTDFVocab:Service [
    base:desc "Service that predicts and optimizes energy consumption by adjusting HVAC and lighting based on forecasts."
    DTDFVocab:provides AdaptiveLightingSchedule, EnergyMarketParticipationDecision
]
instance ReinforcementLearningControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based control policy refinement service that updates building control policies."
    DTDFVocab:provides AutomatedPolicyUpdateAction
]
instance TaskPlanningService : DTDFVocab:Service [
    base:desc "Service that plans maintenance tasks and schedules based on sensor analytics and predictive modeling."
    DTDFVocab:provides MaintenanceSchedule
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that delivers immersive 3D visualization of the building in Unreal Engine 5 via REST APIs."
    DTDFVocab:provides PublishDashboardAction
]

// C17: Insights
instance EnergySavingRecommendation : DTDFVocab:Insight [
    base:desc "Insight recommending energy‑saving actions such as dimming lights when not needed."
]
instance MaintenanceSchedule : DTDFVocab:Insight [
    base:desc "Insight providing a schedule for scheduled maintenance tasks based on sensor trends."
]
instance AdaptiveLightingSchedule : DTDFVocab:Insight [
    base:desc "Insight suggesting adaptive lighting schedules to optimize comfort and energy use."
]
instance EnergyMarketParticipationDecision : DTDFVocab:Insight [
    base:desc "Insight deciding when to participate in energy market based on demand forecasts and price signals."
]

// C17: Actions
instance AutomatedPolicyUpdateAction : DTDFVocab:Action [
    base:desc "Automated action that updates building control policies in Ditto twins."
    DTDFVocab:IsAutomatic true
]
instance SendAlertAction : DTDFVocab:Action [
    base:desc "Action that triggers alerts in dashboards when sensor values exceed thresholds."
    DTDFVocab:IsAutomatic false
]
instance PublishDashboardAction : DTDFVocab:Action [
    base:desc "Action that publishes updated dashboards to the visualization service."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT issues control commands (e.g., setpoint adjustments, lighting schedules) as JSON messages that are routed through Hono to the target device’s endpoint; the devices subscribe to specific Hono topics to consume the commands and actuate the physical system."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization with sub‑second latency; the DT processes incoming sensor data and state changes immediately and updates virtual state accordingly, while actuations are dispatched within milliseconds of command issuance."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A coordinated orchestration of device Digital Twins, a building‑level Twin, a reinforcement‑learning controller, a predictive analytics engine, and a visualization layer; all components are linked via Ditto’s topic‑based routing and share a common data schema based on the BIM metamodel."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the operation phase of the building life‑cycle; it interfaces with the BIM during design (ideal) to generate the model, is instantiated during construction (manufactured) by provisioning device metadata, and is active during operation for real‑time monitoring and control."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The system employs the Overall Digital Twin Entanglement (ODTE) metric to quantify alignment between the physical and virtual states; semantic drift detection routines compare BIM metadata against runtime data; formal verification of control logic is performed on the generated MDE code; uncertainty is countered with sensor fusion and data validation checks."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT occurs over MQTT (TLS‑encrypted) through the Eclipse Hono broker; Ditto exposes a JSON‑over‑HTTP REST API and an MQTT bridge; the building network typically uses Ethernet or Wi‑Fi, and all messages are signed with device certificates."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin services are containerized (Docker) and orchestrated in a Kubernetes cluster, with the Ditto instances running in stateful pods; Hono leverages a clustered Vert.x deployment; visualization runs on a dedicated UE5 server instance; the entire stack can be deployed on a private cloud or edge gateway based on latency requirements."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The architecture exposes REST endpoints and MQTT bridges for integration with external Building Management Systems (BMS), energy market platforms, and other Digital Twins (e.g., utility grid Twin), enabling bi‑directional data exchange beyond the DT ecosystem."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership remains with the PT owner; sensor data is anonymized where required, and privacy policies are enforced via Hono’s role‑based ACLs; all data transfers are authenticated and encrypted to comply with GDPR guidelines."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adheres to IFC standards for BIM modeling, MQTT + TLS for secure messaging, Ditto’s open API, and ISO 15288 for life‑cycle modeling; the MDE pipeline follows OMG‑M2M and UML/P standards for model transformations."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Secured communication via TLS and device certificate authentication; Hono enforces access control lists; control commands are throttled and validation is performed on the DT side before being forwarded to prevent unsafe actions; a device safety monitor monitors for anomalies and triggers emergency shut‑off where necessary."
]