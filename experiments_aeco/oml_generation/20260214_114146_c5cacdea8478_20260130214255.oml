// C1: System Under Study
instance UniversityLibraryBuilding : DTDFVocab:Environment [
    base:desc "Academic library building with structural elements, HVAC, lighting, and other services equipped with sensors, actuators and controllers across the full AECO lifecycle."
    base:contains OccupancySensor, EnergyMeterSensor, LightingFixtureActuator, HVACActuator
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in BIM, streamed via Eclipse Hono every 1 s heartbeat."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnergyMeterSensor : DTDFVocab:SensingComponent [
    base:desc "Energy meter sensor defined in BIM, streamed via Eclipse Hono with 1 s heartbeat."
    DTDFVocab:producedData EnergyDataTransmitted
]

// C2: Acting components
instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture actuator with binary on/off, dimming levels and colour‑temperature adjustment, addressed by unique DittoDevice identifier."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator modeled in BIM, controllable via Ditto with policy‑based validation of command ranges."
]

// C4: Physical‑to‑virtual interaction (Data transmission)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
    base:desc "Live occupancy measurements streamed from physical sensor to Ditto via Eclipse Hono."
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeterSensor
    base:desc "Live energy consumption measurements streamed from physical sensor to Ditto via Eclipse Hono."
]

instance HonoToDittoTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor, EnergyMeterSensor
    base:desc "Sensor measurements transferred through Eclipse Hono to Eclipse Ditto using MQTT‑like protocol with at‑least‑once delivery."
]

// C5: Data artifacts
instance OccupancyData : DTDFVocab:Data [
    DTDFVocab:fromData OccupancyDataTransmitted
    base:desc "Occupancy state values persisted in Ditto."
    DTDFVocab:inputTo AnalyticsEngine, VisualizationEngine
]

instance EnergyData : DTDFVocab:Data [
    DTDFVocab:fromData EnergyDataTransmitted
    base:desc "Energy usage values persisted in Ditto."
    DTDFVocab:inputTo AnalyticsEngine, OptimizationEngine
]

// C10: Models/Data
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Enriched Revit BIM model providing geometric foundation of the building."
    DTDFVocab:inputTo ModelDrivenEngine
]

instance BuildingControlModel : DTDFVocab:Model [
    base:desc "Model‑driven engineering representation of building control logic extracted from BIM."
    DTDFVocab:inputTo ModelDrivenEngine
]

instance EnergyPredictionModel : DTDFVocab:Model [
    base:desc "Predictive analytics model for energy consumption and indoor‑condition forecasting."
    DTDFVocab:inputTo AnalyticsEngine
]

// C11: Enablers
instance EclipseHonoIngestion : DTDFVocab:Enabler [
    base:desc "Eclipse Hono gateway that ingests sensor streams, performs protocol translation and basic validation."
    DTDFVocab:enables RealTimeMonitoringService, DataIngestionService
]

instance EclipseDittoStore : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto state store providing policy‑based validation, persistent event storage and addressable DittoDevice objects."
    DTDFVocab:enables ControlExecutionService, DataPersistenceService
]

instance ModelDrivenEngine : DTDFVocab:Enabler [
    base:desc "Automated extraction pipeline that converts BIM definitions into ontology‑based DT artefacts."
    DTDFVocab:enables DeploymentAutomationService
]

instance AnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Custom analytics plug‑in framework processing live streams to generate operational insights."
    DTDFVocab:enables PredictiveAnalyticsService, CustomAnalyticsService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Interactive 3‑D visualization framework rendering BIM model for facility managers."
    DTDFVocab:enables InteractiveVisualizationService
]

instance OptimizationEngine : DTDFVocab:Enabler [
    base:desc "Optimization service computing cost‑effective operational set‑points."
    DTDFVocab:enables OptimizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of sensor streams and device states."
    DTDFVocab:provides OccupancyInsight, EnergyUsageInsight
]

instance ControlExecutionService : DTDFVocab:Service [
    base:desc "Execution of control commands defined by building control engineers, sent via Ditto to actuators."
    DTDFVocab:provides LightingControlAction, HVACControlAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics and simulation for energy consumption and indoor condition forecasting."
    DTDFVocab:provides EnergyForecastInsight, FaultDetectionInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Computes cost‑effective operational set‑points and recommends adjustments."
    DTDFVocab:provides EnergyOptimizationAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3‑D visualization of BIM‑derived model for facility managers."
    DTDFVocab:provides VisualizationInsight
]

instance CustomAnalyticsService : DTDFVocab:Service [
    base:desc "Custom analytics added through modular extension points."
    DTDFVocab:provides CustomInsight
]

instance DeploymentAutomationService : DTDFVocab:Service [
    base:desc "Automated deployment of generated DT artefacts reducing manual configuration (R2)."
    DTDFVocab:provides DeploymentInsight
]

instance DataIngestionService : DTDFVocab:Service [
    base:desc "Handles ingestion of sensor data via Hono into Ditto."
    DTDFVocab:provides IngestionInsight
]

instance DataPersistenceService : DTDFVocab:Service [
    base:desc "Manages persistent storage of device state in Ditto."
    DTDFVocab:provides PersistenceInsight
]

// C17: Insights
instance OccupancyInsight : DTDFVocab:Insight [
    base:desc "Live occupancy information derived from sensor streams."
]

instance EnergyUsageInsight : DTDFVocab:Insight [
    base:desc "Current energy consumption levels reported by energy meters."
]

instance EnergyForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of future energy usage based on predictive model."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of faults or anomalies in building systems."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of building state in the 3‑D interface."
]

instance CustomInsight : DTDFVocab:Insight [
    base:desc "Insight generated by user‑added analytics modules."
]

instance DeploymentInsight : DTDFVocab:Insight [
    base:desc "Information about successful deployment of DT artefacts."
]

instance IngestionInsight : DTDFVocab:Insight [
    base:desc "Status of data ingestion pipeline."
]

instance PersistenceInsight : DTDFVocab:Insight [
    base:desc "Confirmation of data persistence in Ditto."
]

// C17: Actions
instance LightingControlAction : DTDFVocab:Action [
    base:desc "Command to adjust lighting on/off, dimming level or colour temperature."
    DTDFVocab:IsAutomatic false
]

instance HVACControlAction : DTDFVocab:Action [
    base:desc "Command to modify HVAC set‑points."
    DTDFVocab:IsAutomatic false
]

instance EnergyOptimizationAction : DTDFVocab:Action [
    base:desc "Recommended adjustment of operational set‑points to reduce energy cost."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional data exchange is enabled by the DT framework, allowing the digital twin to issue control commands back to the building control systems. Control logic defined by Building Control Engineers is executed in the twin and the resulting commands (e.g., actuator set‑points, HVAC overrides) are transmitted to the physical devices through the same communication path used for sensor data, ensuring immediate feedback. The framework validates and authenticates each command before dispatch, and the physical system acknowledges execution, closing the loop."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides continuous, real-time data exchange between the physical building and its digital counterpart, aiming for synchronous updates without specified frequency, latency or granularity; the exact synchronization interval is not detailed in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a model-driven, service-oriented constellation where enriched BIM models are transformed into deployable DT artifacts; a modular architecture with standardized extension points enables integration of custom services, runtime configuration management, and bidirectional data exchange, orchestrated by the central DT Framework."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a DT life‑cycle that starts with design‑time device modelling where building control engineers enrich BIM models with semantic definitions of sensors, actuators and controllers. A model‑driven engineering (MDE) step then extracts a structured representation from the enriched BIM and automatically generates deployable DT artefacts. An automated deployment process (R2) instantiates the twin with minimal manual intervention, establishing runtime operation. In the operation stage continuous real‑time data exchange (R3) synchronises the physical asset and its digital counterpart, while interactive visualisation supports monitoring and control. Transition between stages is orchestrated by the model‑driven automation engine and governance is enforced through the defined actor roles (building control engineer, facility manager, DT engineer)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assured by a two‑stage verification pipeline: model checking (5.53 s) and model parsing (8.7 s) prior to DT initialization. Eclipse Ditto applies policy‑based validation to detect out‑of‑range values and performs pre‑execution checks on actuator commands. Fault tolerance is provided by Eclipse Hono’s at‑least‑once message delivery and Ditto’s persistent event storage, enabling recovery from network failures. Synchronisation quality is quantified by the Overall Digital Twin Entanglement (ODTE) metric, comprising timeliness (0.997), reliability (1.0) and availability (1.0), measured over a 12‑minute window with a 1‑second heartbeat."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical network consists of a modular, service‑oriented architecture built on Eclipse Hono and Eclipse Ditto. Hono provides a scalable gateway that aggregates heterogeneous sensor streams and forwards them over standard IoT protocols to the Ditto digital‑twin engine, which stores and exposes the twin state via REST and WebSocket interfaces. The topology supports horizontal scaling of both gateway and twin components, and the use of standardized protocols ensures interoperability across heterogeneous systems as required by the NF_X non‑functional requirements."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through BIM model enrichment and standardized extension points that allow custom services and analytics to be plugged in; however, specific data exchange protocols, interoperability standards or external enterprise system dependencies are not detailed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach builds on BIM as the primary modelling standard in the AECO sector and reuses open‑source frameworks noted for standard compliance. Connectivity relies on Eclipse Hono and Eclipse Ditto, which are referenced as providing robust, standards‑based communication in DT implementations. While specific industry certification requirements are not enumerated, the modular architecture and standardized extension points are intended to ensure interoperability with existing AECO standards and other DT platforms."
]