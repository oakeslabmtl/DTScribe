// C2: Acting Components
instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Adaptive lighting controller system in BOREALIS project implementing reinforcement learning for dynamic control based on occupancy and environmental conditions"
]

instance HVACController : DTDFVocab:ActingComponent [
    base:desc "Building Heating, Ventilation, and Air Conditioning (HVAC) system controller managing temperature, humidity, and air quality parameters"
    DTDFVocab:producedData HVACDataStream
]

instance OccupancyActuator : DTDFVocab:ActingComponent [
    base:desc "Automated occupancy detection system that triggers lighting/HVAC adjustments based on real-time presence data"
    DTDFVocab:producedData OccupancyControlStream
]

instance HVACDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACController
]

instance OccupancyControlStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals and commands generated by the DT (e.g., adaptive lighting adjustments, energy optimization policies) are transmitted back to physical building control systems (BCS) for real-time adjustments."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twinning time scale operates at **real-time granularity**, with synchronization between physical and virtual assets occurring via **Eclipse Hono/Ditto middleware**. While the documents do not specify exact latency metrics, the emphasis is on **sub-second latency** for live data exchange to ensure seamless bidirectional communication. The DT’s services and synchronization processes are designed to handle operational demands across the entire building lifecycle, from design to post-occupancy phases."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized DT architecture with a layered system architecture that integrates BIM, middleware (Hono/Ditto), and visualization tools (Unreal Engine). The constellation includes multiple internal twins (e.g., lighting, HVAC) managed through a unified framework for real-time synchronization and service orchestration."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "['Design phase: BIM models serve as foundational representations.', 'Construction phase: Integration of BIM with physical devices and sensor configurations.', 'Operational phase: Real-time monitoring, optimization, and adaptive control via DT services.']"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "['Overall Digital Twin Entanglement (ODTE) metric to measure alignment between physical and virtual representations.', 'Verification and validation through automated model-to-text transformations and real-time synchronization checks.', 'Addressing semantic drift via standardized extension points and runtime configuration management.', 'Ensuring data accuracy and consistency through automated data extraction from BIM and middleware integration.']"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "['Network protocols: Real-time data exchange via Eclipse Hono and Ditto middleware for bidirectional communication.', 'Architecture: Layered system architecture coupling BIM, middleware, and visualization tools for seamless integration.']"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT deployment process is automated and model-driven, focusing on **runtime interface generation** and **middleware configuration** (Eclipse Hono/Ditto) without explicit details on hosting infrastructure (e.g., cloud/edge deployment). The framework emphasizes **scalable deployment** via standardized extension points, enabling modular integration of services without redeployment. Hosting specifics (e.g., cloud platforms, local HPC) are not detailed in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "['Integration with external BIM standards (e.g., IFC) for interoperability with other AECO systems.', 'Seamless communication with IoT platforms and sensor networks for broader operational data integration.', 'Modular extension points for integrating third-party analytics and service providers.']"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "['Building Information Modeling (BIM) standards (e.g., IFC) for semantic consistency and interoperability.', 'Industry-specific standards for DT deployment (e.g., TwinLight and BOREALIS project frameworks).', 'Middleware standards (Eclipse Hono, Ditto) for real-time data exchange.', 'Modular extension points for service integration adhering to open standards (e.g., RESTful APIs).']"
]