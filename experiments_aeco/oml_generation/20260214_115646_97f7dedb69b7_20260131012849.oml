// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM, providing post‑occupancy occupancy data via middleware"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor modeled in BIM, streaming light level measurements to the twin"
    DTDFVocab:producedData IlluminanceDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Generic environmental sensor (e.g., temperature, CO₂) modeled in BIM and feeding data streams"
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// C4: Physical‑to‑virtual interaction (data transmission)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C10: Models/Data
instance OccupancyData : DTDFVocab:Data [
    base:desc "Post‑occupancy occupancy count data stream"
    DTDFVocab:fromData OccupancyDataTransmitted
]

instance IlluminanceData : DTDFVocab:Data [
    base:desc "Real‑time illuminance measurements in lux"
    DTDFVocab:fromData IlluminanceDataTransmitted
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Environmental measurements such as temperature and CO₂ levels"
    DTDFVocab:fromData EnvironmentalDataTransmitted
]

instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Static BIM geometry and spatial data exported from the enriched BIM model"
]

instance BIMSemanticModel : DTDFVocab:Model [
    base:desc "Semantic BIM data (asset types, relationships) used for reasoning"
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control‑logic models (e.g., reinforcement‑learning policies) generated for lighting optimization"
]

instance RuntimeArtifactModel : DTDFVocab:Model [
    base:desc "Generated runtime artifacts (code, configuration files) produced via model‑to‑text transformations"
]

// C2: Acting components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in BIM and controllable through the digital twin"
]

// C11: Enablers (tooling and pipelines)
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware that streams sensor readings and device status to the twin"
    DTDFVocab:enables RealTimeMonitoringDashboard
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital‑twin service ingesting data and exposing twin APIs"
    DTDFVocab:enables RealTimeMonitoringDashboard, Interactive3DVisualization
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 engine rendering the 3D interactive visualization of the building"
    DTDFVocab:enables Interactive3DVisualization
]

instance AutomatedConfigurator : DTDFVocab:Enabler [
    base:desc "Automated configurator that extracts device metadata and generates runtime artifacts"
    DTDFVocab:enables EnergyEfficiencyOptimization, VisualComfortTaskPlanning
]

instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline that orchestrates model enrichment, validation and artifact generation"
    DTDFVocab:enables EnergyEfficiencyOptimization, VisualComfortTaskPlanning
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard presenting live status of sensors and actuators"
    DTDFVocab:provides RealTimeStatusInsight
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "3D interactive visualization in Unreal Engine 5 for facility managers"
    DTDFVocab:provides LightingComfortInsight
]

instance EnergyEfficiencyOptimization : DTDFVocab:Service [
    base:desc "Energy‑efficiency optimization service applying reinforcement‑learning control policies"
    DTDFVocab:provides EnergyConsumptionInsight, LightingControlRecommendationAction
]

instance VisualComfortTaskPlanning : DTDFVocab:Service [
    base:desc "Visual‑comfort task planning service recommending lighting settings"
    DTDFVocab:provides LightingComfortInsight, AutomatedLightingControlAction
]

instance BuildingPerformanceSimulation : DTDFVocab:Service [
    base:desc "Simulation service for evaluating building performance under different scenarios"
    DTDFVocab:provides EnergyConsumptionInsight
]

// C17: Insights
instance RealTimeStatusInsight : DTDFVocab:Insight [
    base:desc "Provides facility managers with real‑time status of occupancy and environmental conditions"
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Delivers insights on current energy consumption of lighting systems"
]

instance LightingComfortInsight : DTDFVocab:Insight [
    base:desc "Shows visual‑comfort metrics such as illuminance levels relative to standards"
]

// C17: Actions
instance LightingControlRecommendationAction : DTDFVocab:Action [
    base:desc "Control recommendation for adjusting lighting to improve comfort and efficiency"
    DTDFVocab:IsAutomatic false
]

instance AutomatedLightingControlAction : DTDFVocab:Action [
    base:desc "Automatic execution of lighting set‑points based on optimization policies"
    DTDFVocab:IsAutomatic true
]

// C1: System under study (environment)
instance LivingLabTwinEnvironment : DTDFVocab:Environment [
    base:desc "BIM‑based Digital Twin of a Living Lab building, synchronised in real time with the physical asset"
    base:contains OccupancySensor, IlluminanceSensor, EnvironmentalSensor, LightingActuator,
                RealTimeMonitoringDashboard, Interactive3DVisualization,
                EnergyEfficiencyOptimization, VisualComfortTaskPlanning,
                BuildingPerformanceSimulation, BIMGeometryModel, BIMSemanticModel,
                ControlLogicModel, RuntimeArtifactModel
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points) are sent back through Ditto to Hono, which routes them to the physical actuators, enabling bidirectional communication between virtual and physical layers."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization between physical sensors/actuators and the twin, enabling up‑to‑date state monitoring and immediate actuation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where an enriched BIM model feeds a configurator that produces device metadata, which is consumed by Hono/Ditto for bidirectional communication; the twin state is visualized in Unreal Engine and extended via standardized extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the full building lifecycle: design (BIM authoring), construction (model validation and deployment), and operation (real‑time monitoring, control, and post‑occupancy optimization)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation before deployment and evaluation of twin‑physical alignment using the Overall Digital Twin Entanglement (ODTE) metric to assess fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono acts as the IoT gateway collecting sensor data, while Eclipse Ditto stores the twin state and mediates bidirectional communication, together providing real‑time data exchange between the physical building and its digital counterpart."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Leverages BIM as a standardized data model and conforms to industry‑wide AECO standards; the framework defines standardized extension points for interoperable service integration."
]