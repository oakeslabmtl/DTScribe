// C2: Acting Components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Actuator representing a single light fixture driven by DittoDevice; accepts power on/off, brightness (0‑100%), colour-temperature (2700–6500 K) commands routed via Eclipse Hono MQTT to a DittoController enforcing pre‑execution safety checks."
]

// C3: Physical sensing components
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor integrated in BIM as a DittoDevice, publishing lux values at 1 Hz via Hono."
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor integrated in BIM as a DittoDevice, publishing °C values at 1 Hz via Hono."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor integrated in BIM as a DittoDevice, publishing binary occupancy indicators at 1 Hz via Hono."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: DataTransmitted
instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C4: Data
instance IlluminationData : DTDFVocab:Data [
    base:desc "Illumination measurement data (lux) received from IlluminationDataTransmitted."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler, EclipseBasyxEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature measurement data (°C) received from TemperatureDataTransmitted."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler, EclipseBasyxEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy status data (binary) received from OccupancyDataTransmitted."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDittoEnabler, EclipseBasyxEnabler
]

// C10: Models/Data
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "UE5 3‑D scene derived from enriched BIM, containing photometric values, control logic and topology."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance BehaviorControlModel : DTDFVocab:Model [
    base:desc "Control logic and state machine extracted from BIM for each device; used by Ditto for command validation."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance AnalyticalMappingModel : DTDFVocab:Model [
    base:desc "Mapping schema between sensors and actuators derived from BIM; used by Basyx for analytics."
    DTDFVocab:inputTo EclipseBasyxEnabler
]

// C11: Enablers
instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto registrar and event store; persists twin state, provides WebSocket changefeed, validates commands."
    DTDFVocab:enables RealTimeMonitoringService, ControlExecutionService
]

instance EclipseBasyxEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Basyx integration for industrial IoT data collection and analytics."
    DTDFVocab:enables PredictiveAnalyticsService, HVACOptimizationService, CustomAnalyticsService
]

instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT gateway; handles device authentication, at-least-once delivery, forwards telemetry to Ditto."
    DTDFVocab:enables ControlExecutionService
]

instance ITwinjsEnabler : DTDFVocab:Enabler [
    base:desc "Itwin.js library for immersive visualization of 3‑D BIM with live sensor overlay."
    DTDFVocab:enables ImmersiveVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of building state using data from Ditto."
    DTDFVocab:provides BuildingStateInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Performs predictive analytics for maintenance and energy optimization based on analytical model."
    DTDFVocab:provides MaintenanceInsight
]

instance ControlExecutionService : DTDFVocab:Service [
    base:desc "Implements control logic from BIM for actuators, executing commands via Ditto and Hono."
    DTDFVocab:provides TurnOnLightAction, SetBrightnessAction, SetColourTemperatureAction
]

instance HVACOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes HVAC schedules in real time using analytics and sensor data."
    DTDFVocab:provides OptimizeHVACAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Maps live sensor data onto UE5 3‑D BIM model for immersive visualization."
    DTDFVocab:provides VisualizationInsight
]

instance CustomAnalyticsService : DTDFVocab:Service [
    base:desc "Extensible analytics plugin point for DT Engineers to add custom analytics."
    DTDFVocab:provides CustomInsight
]

// C17: Insights / Actions
instance BuildingStateInsight : DTDFVocab:Insight [
    base:desc "Insight derived from live sensor data reflecting overall building operational state such as thermal comfort, energy consumption, occupancy."
]

instance MaintenanceInsight : DTDFVocab:Insight [
    base:desc "Maintenance recommendation based on predictive analytics model, indicating when preventive maintenance should be scheduled."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization status indicating successful overlay of live data onto BIM model."
]

instance CustomInsight : DTDFVocab:Insight [
    base:desc "Placeholder for custom insight generated by DT Engineer extensions."
]

instance TurnOnLightAction : DTDFVocab:Action [
    base:desc "Command to turn on the light fixture controlled by LightTwinComponent."
    DTDFVocab:IsAutomatic false
]

instance SetBrightnessAction : DTDFVocab:Action [
    base:desc "Command to set the brightness of the light fixture (0‑100%) as defined in the BIM photometric metadata."
    DTDFVocab:IsAutomatic false
]

instance SetColourTemperatureAction : DTDFVocab:Action [
    base:desc "Command to set the colour temperature of the light fixture (2700–6500 K) as defined in BIM."
    DTDFVocab:IsAutomatic false
]

instance OptimizeHVACAction : DTDFVocab:Action [
    base:desc "Command to adjust HVAC operation parameters for energy optimization based on analytics."
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework mandates real‑time data exchange capabilities to ensure continuous synchronization between the physical building and its digital counterpart, facilitating bidirectional data flow with minimal latency; however, explicit synchronization frequencies, latency thresholds, or temporal granularity levels are not specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The overall orchestration is built around a modular, extension‑point‑rich DT Framework that acts as a central hub for continuous bidirectional data exchange. It integrates components such as device controllers, visualization services, and custom analytics plugins through standardized APIs, while resource and lifecycle management are handled via runtime configuration, enabling the Digital Twin ecosystem to evolve seamlessly."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a multi‑stage life cycle that begins with device modeling inside Autodesk Revit, where Building Control Engineers create custom families and property sets for lights, HVAC, etc., tagging each instance with a global Instance General UUID and setting the IFC type (e.g., IFCLIGHTFIXTURETYPE). The enriched BIM model is exported to IFC and uploaded to the platform. A BC‑based semantic model extraction (F2) automatically transforms the IFC into a structured domain‑specific representation that can be used by the digital twin engine. One‑click deployment (F3) generates, configures and launches the DT artifacts automatically, exposing the twin through the chosen middleware stack (Eclipse Hono and Ditto). The twin then enters the runtime phase where real‑time, bi‑directional data exchange (F4), interactive 3‑D visualization (F5) and modular service extensions (F6) are employed. Throughout these phases, a runtime configuration management layer (F7) supports dynamic updates, parameter tuning and interface updates, ensuring continuous governance and traceability across the twin’s entire life cycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is quantified by the Overall Digital Twin Entanglement (ODTE) metric, measured over a 12‑minute window during the Living Lab experiment. The ODTE achieved a total score of 0.997, with timeliness 0.997 (≈700 ms delay), reliability 1.0 (no loss) and availability 1.0 (100 % uptime). The deployment pipeline incorporates an upfront model‑checking stage that enforces semantic constraints of enriched BIM, guaranteeing geometric, behavioural and analytical artefacts are valid before code generation. Ditto’s policy validation ensures all sensor telemetry and actuator commands respect defined value ranges and units, while pre‑execution checks prevent unsafe state transitions. Eclipse Hono’s at‑least‑once delivery and Ditto’s persistent event store provide fault tolerance, guaranteeing eventual consistency and resilience against transient network failures. These mechanisms collectively form a comprehensive quality‑assurance process for both models and data, ensuring consistency and traceability across the digital twin lifecycle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono forms the device‑to‑backend transport layer, supporting publish/subscribe over MQTT, CoAP and HTTP, with TLS encryption and optional OAuth2 for identity. Eclipse Ditto acts as the twin state service and exposes a WebSocket‑based real‑time API (alongside REST/HTTP) for subscribing to state transitions. The overall topology is a cloud‑hosted hub that aggregates data from distributed field devices, providing low‑latency, fault‑tolerant communication with in‑built message routing and retry logic. Network bandwidth demands are modest (typical 100 bytes–5 kB per sensor report) but the architecture is designed for scaling to thousands of active devices. Reliability is ensured through Hono’s consumer‑side acknowledgment and Ditto’s transactional state updates. Security is managed via TLS/SSL at the transport layer, per‑device certificates or JWTs for authentication, and role‑based access control enforced by Ditto’s policy engine."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through interoperability across heterogeneous infrastructures, adhering to industry standards. The framework exposes standardized data exchange interfaces and provides extension points for custom analytics, thereby enabling communication with external BIM datasets, IoT middleware, and enterprise applications."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework conforms to the BIM materialization stack and relies on the Industry Foundation Classes (IFC) open interchange format for the initial model representation. Device metadata is specified using IFC property sets and GUIDs, and the service layer is exposed through Eclipse Hono, providing MQTT‑based event transport compliant with industry IoT communication standards, while Eclipse Ditto offers a device twin API compliant with open twin management specifications. Standards such as ISO 19650 for BIM deliverables and ISO 27001 for information security are adhered to. The architecture promotes interoperability across heterogeneous BIM tools, IoT protocols (e.g., MQTT, HTTP/REST), and visualization systems (e.g., Unreal Engine 5). Modular extension points support standard OSGi‑style bundles or REST interfaces, aligning with widely accepted software componentization practices."
]