    DTDFVocab:IsAutomatic true
]

instance AutonomousActuationAction : DTDFVocab:Action [
    base:desc "Autonomous adjustment of physical systems (lighting, HVAC) based on digital twin control policies."
    DTDFVocab:IsAutomatic true
]

instance SystemControlInsight : DTDFVocab:Insight [
    base:desc "Real-time control status and performance metrics for building automation systems."
]

instance DeploymentStatusInsight : DTDFVocab:Insight [
