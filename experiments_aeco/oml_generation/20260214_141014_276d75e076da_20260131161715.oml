]

instance ComfortOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insights on thermal and visual comfort optimization based on real-time sensor data and predictive models."
]

instance AdaptiveLightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Autonomous adjustment of lighting levels based on reinforcement learning policies (BOREALIS project)."
    DTDFVocab:IsAutomatic true
]

instance VisualComfortInsight : DTDFVocab:Insight [
