// C3: Physical sensing (derived from control command generation)
instance ControlCommandSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor abstraction that captures control commands issued from the Digital Twin via the UnrealTwinController and forwards them to the Ditto twin platform."
    DTDFVocab:producedData ControlCommandDataTransmitted
]

// C4: Data transmitted from sensing component
instance ControlCommandDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ControlCommandSensor
]

// C5: Data derived from transmitted data
instance ControlCommandData : DTDFVocab:Data [
    base:desc "Structured representation of lighting control commands (on/off, brightness, color‑temperature) flowing into the Ditto twin."
    DTDFVocab:fromData ControlCommandDataTransmitted
    DTDFVocab:inputTo EclipseDittoTwinPlatform, EclipseHonoGateway
]

// C10: Models/Data – enriched BIM and IFC device description
instance EnrichedBimModel : DTDFVocab:Model [
    base:desc "BIM file enriched with semantic definitions of sensors, actuators and controllers that serves as the geometric‑semantic foundation of the twin."
    DTDFVocab:inputTo EclipseBasyxPlatform, iTwinJsFramework
]

instance IfcDeviceDescriptionModel : DTDFVocab:Model [
    base:desc "IFC‑based device description model automatically generated from the enriched BIM, containing metadata such as Revit photometric values."
    DTDFVocab:inputTo EclipseBasyxPlatform, iTwinJsFramework
]

// C11: Enablers
instance EclipseBasyxPlatform : DTDFVocab:Enabler [
    base:desc "Open‑source BaSyx runtime platform providing APIs for device state management and model access."
    DTDFVocab:enables RealTimeDataExchangeService, DeviceStateMonitoringService, ActuatorControlExecutionService
]

instance iTwinJsFramework : DTDFVocab:Enabler [
    base:desc "iTwin.js framework delivering web‑based visualization and analytics capabilities for digital twins."
    DTDFVocab:enables Immersive3DVisualizationService, PredictiveAnalyticsService
]

instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono data‑ingestion gateway that streams sensor measurements and command data into the twin platform."
    DTDFVocab:enables RealTimeDataExchangeService
]

instance EclipseDittoTwinPlatform : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin platform (R3) that stores and synchronizes the operational twin model in real time."
    DTDFVocab:enables RealTimeDataExchangeService, DeviceStateMonitoringService, ActuatorControlExecutionService
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 (UE5) runtime providing immersive 3‑D visualization and operator interaction."
    DTDFVocab:enables Immersive3DVisualizationService
]

// C6: Services
instance RealTimeDataExchangeService : DTDFVocab:Service [
    base:desc "Bidirectional real‑time data exchange service synchronizing physical building states with the virtual twin."
    DTDFVocab:provides AdjustBrightnessAction, ChangeColorTemperatureAction
]

instance DeviceStateMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring service that tracks device states (on/off, brightness, color‑temperature) and raises alerts."
]

instance ActuatorControlExecutionService : DTDFVocab:Service [
    base:desc "Execution service that dispatches validated control commands to physical lighting fixtures via Ditto."
]

instance Immersive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3‑D/immersive visualization service for operators using Unreal Engine 5."
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Analytics service that predicts optimal lighting settings for energy efficiency and comfort."
    DTDFVocab:provides AdjustBrightnessAction, ChangeColorTemperatureAction
]

instance ExtensionMechanismService : DTDFVocab:Service [
    base:desc "Modular extension mechanism allowing DT Engineers to plug in custom services, analytics or logic."
]

// C17: Actions (provided by services)
instance AdjustBrightnessAction : DTDFVocab:Action [
    base:desc "Action to adjust the brightness level of a lighting fixture."
    DTDFVocab:IsAutomatic false
]

instance ChangeColorTemperatureAction : DTDFVocab:Action [
    base:desc "Action to change the color‑temperature (Kelvin) of a lighting fixture."
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components (physical actuators)
instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Physical lighting fixture actuator controlling on/off state, brightness level and color‑temperature."
]

// C12: Controllers
instance UnrealTwinController : DTDFVocab:Component [
    base:desc "Unreal Engine controller that brokers command messages to the Ditto twin platform."
]

instance DittoController : DTDFVocab:Component [
    base:desc "Ditto controller responsible for translating incoming commands into DittoDevice actions."
]

instance DittoConnection : DTDFVocab:Component [
    base:desc "Established connection between the UnrealTwinController, DittoController and the Ditto twin platform."
]

// C13: Twin Component
instance LightTwinComponent : DTDFVocab:Component [
    base:desc "Component that encapsulates lighting twin logic, consuming BIM metadata and device state from Ditto."
]

// C14: Environment (logical grouping)
instance BuildingTwinEnvironment : DTDFVocab:Environment [
    base:contains LightingFixtureActuator, ControlCommandSensor, LightTwinComponent, UnrealTwinController, DittoController, DittoConnection
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional data exchange is supported by the DT Framework that not only receives sensor data but also feeds control commands back to the Building Control System (Document 1). The digital twin can issue runtime control signals to physical devices, enabling Facility Managers to operate the infrastructure through the twin as described in the use‑case roles (Document 4). Specific command formats or authentication mechanisms are not detailed in the provided texts."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange that continuously synchronizes the physical building with its digital counterpart, implying an ongoing low‑latency data flow; however, the documents do not specify concrete synchronization frequencies, latency bounds, or temporal granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The proposed system follows a modular architecture centred on a DT Framework that acts as a central hub for bidirectional data exchange. It exposes standardized extension points for custom services and analytics, supports runtime configuration management to adjust behaviour without redeployment, and leverages a model‑driven pipeline that transforms enriched BIM models into deployable DT artifacts, orchestrating device modelling, data ingestion, and control logic across the twin lifecycle."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The proposed framework supports the full DT life‑cycle, beginning with device modeling directly in the BIM environment (sensors, actuators, controllers), followed by model‑driven engineering (MDE) that extracts structured representations and automatically generates deployable DT artifacts. An automated deployment step (R2) provisions the twin with minimal manual effort. Once deployed, the twin operates in a runtime phase with continuous real‑time data exchange (R3) and interactive visualization for monitoring and control. The architecture further allows post‑deployment evolution through custom services and analytics added via defined extension points (R4). Governance of the life‑cycle is assigned to three actor roles – Building Control Engineer (modeling and control‑logic definition), Facility Manager (operational monitoring and interaction), and DT Engineer (service extension)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is measured using the Overall Digital Twin Entanglement (ODTE) metric, composed of timeliness (0.997), reliability (1.0) and availability (1.0). Validation is performed by Eclipse Ditto’s policy‑based validation, which checks sensor value ranges and units, and by pre‑execution checks on actuator commands. Uncertainty due to network latency is quantified by the timeliness score (≈3 % delay). Error detection is provided by Ditto’s persistent event storage and Hono’s at‑least‑once delivery guarantee, enabling replay of lost messages. Quality assurance includes automated model checking (5.53 s), parsing (8.7 s) and a 1 Hz heartbeat mechanism used during experiments to verify bidirectional synchronization."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connectivity relies on a modular architecture with defined extension points (R4, Document 3) that integrates Eclipse Hono and Eclipse Ditto (R3, Document 3). Hono provides protocol handling for incoming IoT data, while Ditto manages the twin state and exposes APIs for interaction. This combination satisfies the real‑time connectivity and extensibility requirements (Document 3) and conforms to the non‑functional interoperability and scalability goals (Document 1). No explicit network topology, bandwidth, latency, or security protocol specifications are given."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment is model‑driven and automated, reducing manual effort and enabling reproducible DT setups (R2, Document 3). The framework supports runtime configuration management that allows adjustments without full redeployment (Document 1). While the hosting environment (cloud, edge, on‑premise) and resource sizing are not specified, the modular architecture and automated deployment process provide a scalable foundation for deploying operational control twins in the AECO domain."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The approach targets interoperability across heterogeneous systems by using standardized extension points and runtime configuration, and it integrates BIM models, sensor networks, and AI services. It references existing open‑source DT frameworks such as Eclipse Ditto and BaSyx, which are built on established industry standards, to enable connectivity and data exchange with external enterprise systems, although specific data exchange protocols (e.g., OPC‑UA, MQTT) are not detailed in the documents."
]