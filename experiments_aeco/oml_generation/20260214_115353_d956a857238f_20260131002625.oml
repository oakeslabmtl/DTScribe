// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Heterogeneous temperature sensor deployed in the Living Lab building for real‑time monitoring of thermal conditions."
    DTDFVocab:producedData TemperatureDataTx
    base:isContainedIn DigitalTwinHub
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Heterogeneous humidity sensor deployed in the Living Lab building for real‑time monitoring of moisture levels."
    DTDFVocab:producedData HumidityDataTx
    base:isContainedIn DigitalTwinHub
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Heterogeneous occupancy sensor deployed in the Living Lab building for real‑time monitoring of space usage."
    DTDFVocab:producedData OccupancyDataTx
    base:isContainedIn DigitalTwinHub
]

// C4: Physical‑to‑virtual interaction – Data transmitted
instance TemperatureDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Data artifacts
instance TemperatureTelemetry : DTDFVocab:Data [
    base:desc "Live temperature telemetry stream ingested from TemperatureSensor."
    DTDFVocab:fromData TemperatureDataTx
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance HumidityTelemetry : DTDFVocab:Data [
    base:desc "Live humidity telemetry stream ingested from HumiditySensor."
    DTDFVocab:fromData HumidityDataTx
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyTelemetry : DTDFVocab:Data [
    base:desc "Live occupancy telemetry stream ingested from OccupancySensor."
    DTDFVocab:fromData OccupancyDataTx
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides real‑time data ingestion and protocol translation between field devices and the DT hub."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
    base:isContainedIn DigitalTwinHub
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital‑twin state synchronization and receives control commands from the DT hub."
    DTDFVocab:enables ControlCommandService, SynchronizationService
    base:isContainedIn DigitalTwinHub
]

instance ModelDrivenFramework : DTDFVocab:Enabler [
    base:desc "Model‑driven framework extracts BIM‑based device definitions and generates behavioral and analytical models."
    DTDFVocab:enables SimulationService, OptimizationService
    base:isContainedIn DigitalTwinHub
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders high‑fidelity 3‑D visualizations and supports immersive interaction."
    DTDFVocab:enables VisualizationService
    base:isContainedIn DigitalTwinHub
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time‑series database stores historical telemetry for analysis and optimization."
    DTDFVocab:enables OptimizationService, PredictiveAnalyticsService
    base:isContainedIn DigitalTwinHub
]

instance MicroserviceOrchestrator : DTDFVocab:Enabler [
    base:desc "Micro‑service orchestration layer routes data flow and triggers service execution."
    DTDFVocab:enables RealTimeMonitoringService, SimulationService, OptimizationService, VisualizationService, PredictiveAnalyticsService, ControlCommandService
    base:isContainedIn DigitalTwinHub
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of system states via continuous telemetry ingestion."
    DTDFVocab:provides MonitoringInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Executes what‑if analysis and scenario simulations based on BIM‑derived behavioral models."
    DTDFVocab:provides SimulationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimizes energy and operational performance throughout the building lifecycle."
    DTDFVocab:provides OptimizationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Delivers rich, interactive 3‑D visualization of the twin using Unreal Engine 5."
    DTDFVocab:provides VisualizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Generates predictive analytics for facility managers based on live and historical telemetry."
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance ControlCommandService : DTDFVocab:Service [
    base:desc "Allows stakeholders to issue control commands to actuators in the physical building."
    DTDFVocab:provides ControlAction
]

instance SynchronizationService : DTDFVocab:Service [
    base:desc "Keeps the digital twin synchronized with the physical asset state."
    DTDFVocab:provides SynchronizationInsight
]

// C17: Insights
instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight into current building conditions derived from live sensor streams."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from simulated what‑if scenarios based on BIM behavioral models."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal energy and operational settings."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight presented through immersive 3‑D visual contexts."
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Insight forecasting future building performance and potential issues."
]

instance SynchronizationInsight : DTDFVocab:Insight [
    base:desc "Insight confirming consistency between physical and virtual states."
]

// C17: Actions
instance ControlAction : DTDFVocab:Action [
    base:desc "Action to command actuators (e.g., HVAC, lighting) based on manager decisions."
    DTDFVocab:IsAutomatic false
]

// C2: Acting components (placeholder for future actuators)
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator controlled via the ControlCommandService."
    base:isContainedIn DigitalTwinHub
]

// C1: Environment (Digital Twin hub)
instance DigitalTwinHub : DTDFVocab:DigitalTwin [
    base:contains TemperatureSensor, HumiditySensor, OccupancySensor, HVACActuator, EclipseHono, EclipseDitto, ModelDrivenFramework, UnrealEngine5, TimeSeriesDatabase, MicroserviceOrchestrator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are issued from the digital twin to physical building devices via the same central hub, allowing Facility Managers to perform real‑time monitoring and control actions. The interaction is described as bidirectional, but the document does not detail command formats, validation/authentication methods, feedback loops, conflict‑resolution strategies, or execution confirmations."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange that continuously synchronizes the physical building with its digital counterpart, implying an ongoing, sub‑second update loop; however, explicit synchronization frequencies, latency targets, or temporal granularity levels are not detailed in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is orchestrated as a modular, service‑oriented platform where the DT Framework acts as a central hub coordinating bidirectional data exchange among BIM‑derived models, custom analytics services, and user interfaces. Runtime configuration management enables dynamic adaptation without redeployment, and standardized extension points support integration of additional services, reflecting a component‑based orchestration pattern."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a six‑step life‑cycle for a Digital Twin: (1) device modeling inside the BIM environment where Building Control Engineers define sensors, actuators and controllers; (2) semantic enrichment of the BIM model to create a unified representation; (3) model‑driven engineering (MDE) extraction that transforms the enriched BIM into structured DT representations; (4) automated generation of deployable DT artifacts with minimal manual effort; (5) runtime operation where real‑time data exchange synchronises the physical building and its twin and interactive visualisation supports monitoring and control; (6) evolution through modular extension points that allow DT Engineers to add custom services or plugins. Transition between phases is managed by automated transformation pipelines and role‑based governance (Building Control Engineer, Facility Manager, DT Engineer)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The solution adopts a modular architecture with standardized extension points and runtime configuration management to integrate custom services and analytics. Communication between components occurs over the framework’s central hub, but the document does not provide explicit information on the underlying network protocols, topology, bandwidth or latency requirements, reliability/redundancy mechanisms, or security protocols for network communication."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed through standardized extension points and support for heterogeneous systems, enabling bidirectional data exchange with external BIM tools, analytics services, and enterprise applications. Specific data exchange protocols or standards are not enumerated in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework leverages Building Information Modeling (BIM) as the core semantic standard, aligning with BIM’s status as the de‑facto standard in the construction industry (e.g., implicit use of IFC‑based exchange). It adopts a model‑driven engineering approach that enforces consistent artifact generation across the lifecycle. Moreover, the architecture defines standardized extension points to ensure that custom services and analytics can interoperate within the twin ecosystem, providing a systematic interoperability strategy even though specific external standards (e.g., ISO 19650) are not explicitly cited."
]