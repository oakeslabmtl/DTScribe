instance PostOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy sensors providing data for reinforcement learning-based control policy optimization in BOREALIS"
    DTDFVocab:producedData PostOccupancySensorDataTransmitted
]

instance PostOccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PostOccupancySensor
]

instance PostOccupancySensorData : DTDFVocab:Data [
    base:desc "Real-time post-occupancy sensor data for building operations"
    DTDFVocab:fromData PostOccupancySensorDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Actuators for lighting controls in Building Control Systems (BCS)"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuators for HVAC components in Building Control Systems (BCS)"
]

instance SemanticBIMModel : DTDFVocab:Model [
    base:desc "BIM models enriched with domain semantics for Building Control Systems (BCS), providing a semantic backbone for spatial, geometric, and functional data"
    DTDFVocab:inputTo ModelDrivenEngineeringTools
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for IoT connectivity"
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for digital twin management"
    DTDFVocab:enables PredictiveAnalyticsService, SimulationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for rich interactive visualization"
    DTDFVocab:enables InteractiveVisualizationService
]

instance ModelDrivenEngineeringTools : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering (MDE) tools for automated transformation of BIM models"
    DTDFVocab:enables SimulationService, PredictiveAnalyticsService
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring service for building operations"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service for building operations"
    DTDFVocab:provides SimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service for energy, visual comfort, and health effects"
    DTDFVocab:provides EnergyOptimizationInsight, VisualComfortInsight, HealthEffectsInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of energy consumption service"
    DTDFVocab:provides EnergyOptimizationInsight
]

instance VisualComfortOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of visual comfort service"
    DTDFVocab:provides VisualComfortInsight
]

instance HealthEffectsOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of non-visual health effects service"
    DTDFVocab:provides HealthEffectsInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization service using Unreal Engine 5"
    DTDFVocab:provides InteractiveVisualizationInsight
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time operational data insights for facility management"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation-based insights for building performance"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Predictive insights for energy consumption optimization"
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Predictive insights for visual comfort optimization"
]

instance HealthEffectsInsight : DTDFVocab:Insight [
    base:desc "Predictive insights for non-visual health effects optimization"
]

instance InteractiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive visualization insights for building operations"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands from the digital twin to physical actuators via Eclipse Hono and Ditto, facilitating bidirectional communication for building automation and optimization of energy, comfort, and health effects."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized framework with modular, service-oriented architecture featuring standardized extension points for integrating custom services, facilitating bidirectional data exchange and holistic building life cycle management."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the entire building life cycle from initial design to construction, operation, refurbishments, and adaptations, as stated in 'complete building life cycle, from initial design to refurbishments and adaptations during operation' for AECO domain applications."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Evaluated using the Overall Digital Twin Entanglement (ODTE) metric to measure interoperability and architectural soundness, addressing semantic drift through synchronization techniques to ensure alignment between digital models and physical counterparts."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono and Ditto middleware for bidirectional data exchange between physical assets and digital twin, enabling real-time synchronization."
]