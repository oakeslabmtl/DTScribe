import DTDFVocab

// C17: Insights
instance RealTimeOperationalInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into current building system states for facility managers."
]

instance PredictivePerformanceInsight : DTDFVocab:Insight [
    base:desc "Forecast of future performance metrics enabling proactive decision‑making."
]

instance ScenarioSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from simulated scenarios to evaluate alternative operational strategies."
]

instance OptimizationRecommendation : DTDFVocab:Insight [
    base:desc "Recommendation for operational optimisation derived from analytics and lifecycle models."
]

// C17: Actions
instance ActuationCommandAction : DTDFVocab:Action [
    base:desc "Command issued from the Digital Twin to remote actuators/controllers for corrective actions.",
    DTDFVocab:IsAutomatic false
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of operational data from the building.",
    DTDFVocab:provides RealTimeOperationalInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Executes predictive modeling of future building performance based on streamed sensor data.",
    DTDFVocab:provides PredictivePerformanceInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs scenario simulations of building operation and lifecycle using the enriched BIM model.",
    DTDFVocab:provides ScenarioSimulationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimizes building operations across its life‑cycle, generating actionable recommendations.",
    DTDFVocab:provides OptimizationRecommendation, ActuationCommandAction
]

// C11: Enablers
instance RealTimeIntegrationHub : DTDFVocab:Enabler [
    base:desc "Central hub that streams sensor measurements and actuator states in real‑time, acting as the integration point between physical devices and the Digital Twin.",
    DTDFVocab:enables MonitoringService, PredictiveAnalyticsService, SimulationService, OptimizationService
]

// C4: Physical-to-virtual interaction – sensor data stream
instance SensorDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BIMEmbeddedSensor
]

// C4: Physical-to-virtual interaction – actuator state stream
instance ActuatorStateStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BIMEmbeddedActuator
]

// C4: Data transmission for model extraction
instance ModelExtractionStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DeviceDefinitionExtractor
]

// C3: Physical sensing components
instance BIMEmbeddedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors are defined as devices in the enriched BIM model, providing real‑time data exchange to keep the twin synchronized with the physical building.",
    DTDFVocab:producedData SensorDataStream
]

// C2: Acting components (physical actuators/controllers)
instance BIMEmbeddedActuator : DTDFVocab:ActingComponent [
    base:desc "Physical actuators and controllers modeled within the BIM environment and exposed through the Digital Twin for remote operation by facility managers."
]

// C5: Data produced from sensors
instance OperationalSensorData : DTDFVocab:Data [
    base:desc "Continuous operational measurements streamed from building sensors, used for monitoring, analytics, and simulation.",
    DTDFVocab:fromData SensorDataStream,
    DTDFVocab:inputTo RealTimeIntegrationHub
]

// C5: Data produced from actuators
instance ActuatorStateData : DTDFVocab:Data [
    base:desc "Current states of actuators and controllers streamed to the Digital Twin.",
    DTDFVocab:fromData ActuatorStateStream,
    DTDFVocab:inputTo RealTimeIntegrationHub
]

// C5: Extracted device definition data
instance ExtractedDeviceData : DTDFVocab:Data [
    base:desc "Extracted device definitions (sensors, actuators, controllers) used to instantiate digital twins.",
    DTDFVocab:fromData ModelExtractionStream,
    DTDFVocab:inputTo RealTimeIntegrationHub
]

// C10: Models / Data (semantic foundation)
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model that serves as the semantic foundation, containing geometry, device definitions, and control logic.",
    DTDFVocab:inputTo RealTimeIntegrationHub
]

instance DeviceBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral descriptions of sensors, actuators, and controllers extracted from the BIM model for simulation and control.",
    DTDFVocab:inputTo SimulationService, PredictiveAnalyticsService
]

// C9: Component that extracts device definitions (MDE tool)
instance DeviceDefinitionExtractor : DTDFVocab:Component [
    base:desc "Model‑driven engineering tool that extracts device definitions from the enriched BIM model to generate DT artefacts."
]

// C1: System under study – the building asset
instance BuildingAsset : DTDFVocab:Component [
    base:desc "Physical building considered as a cyber‑physical asset throughout its whole life‑cycle from design to refurbishment."
]

// C8: Environment containing the building and its components
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains BuildingAsset, BIMEmbeddedSensor, BIMEmbeddedActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Through the DT, Facility Managers can issue control actions that are sent back to physical equipment for real‑time monitoring and control. The central hub forwards command messages from the digital twin to the building’s devices, supporting immediate feedback. The document does not detail command formats, validation, authentication, conflict resolution, or execution confirmation mechanisms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin operates with continuous, real-time synchronization between the physical building and its virtual replica, ingesting runtime sensor data as it is produced to provide real-time monitoring, predictive analytics, and optimization throughout the building lifecycle; the document does not specify exact update frequencies, latency limits, or temporal granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system is orchestrated as a model‑driven framework that automates the deployment of a Digital Twin for a building. A BIM model is processed by a configurator that generates artefacts for Eclipse Hono (IoT connectivity layer) and Eclipse Ditto (digital‑twin state management). Hono collects sensor data and forwards it to Ditto, which maintains the twin’s semantic representation. Visualization is provided by Unreal Engine, which consumes the twin state for interactive 3D rendering. This composition establishes a microservice‑style architecture where Hono, Ditto and the visualisation component are coordinated by the configurator, enabling scalable, automated provisioning and resource management across the DT ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a four‑stage lifecycle: (1) device and control‑logic modeling inside the BIM environment where sensors, actuators and controllers are added to the building information model; (2) model‑driven transformation using model‑driven engineering (MDE) to extract structured representations and automatically generate deployable Digital Twin artifacts; (3) deployment and runtime operation where the generated twin is instantiated, kept in continuous sync with the physical plant through real‑time data exchange, and visualised for monitoring and control; (4) evolution stage in which modular extension points allow custom services, analytics or plug‑ins to be added, enabling the twin to adapt to new operational requirements. Transition between stages is managed by the automated generation pipeline and governed by the roles defined (Building Control Engineer, Facility Manager, DT Engineer)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The architecture is modular with standardized extension points and is designed to interoperate across heterogeneous systems, supporting scalability from individual components to whole‑infrastructure deployments. Runtime configuration management allows adjustments without full redeployment. Specific network protocols, topology, bandwidth, latency, reliability, redundancy, or security protocol details are not provided in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin framework is deployable on a runtime‑configurable infrastructure that can host custom services and analytics, supporting scalability and low‑overhead updates. While the modular design permits deployment on various platforms (cloud, edge, on‑premise), the document does not name particular hosting environments, computational or storage specifications, nor explicit availability or reliability guarantees."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture is modular with standardized extension points that define how custom services and analytics are plugged into the twin. These extension points constitute the explicit standard referenced; no external industry standards (e.g., IFC, ISO 19650, MQTT) or certification requirements are mentioned in the document."
]