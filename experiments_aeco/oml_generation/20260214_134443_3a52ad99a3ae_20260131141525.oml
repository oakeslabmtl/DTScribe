// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting system actuators defined within BIM, including dimming controllers and LED drivers mapped to the virtual twin for executing control commands."
]

// C3: Physical sensing components
instance PostOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensors collecting post‑occupancy data via the building’s IoT infrastructure, streamed through Eclipse Hono to the DT."
    DTDFVocab:producedData PostOccupancyTelemetryTransmitted
]

// C4: Physical‑to‑virtual interaction
instance PostOccupancyTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PostOccupancySensor
]

// C10: Models/Data
instance BIMModel : DTDFVocab:Model [
    base:desc "IFC‑based BIM model enriched with runtime semantics."
    DTDFVocab:inputTo BIMAuthoringTool, ModelDrivenEngineeringTool
]

instance PostOccupancyTelemetryData : DTDFVocab:Data [
    base:desc "Continuous stream of sensor telemetry collected via Hono."
    DTDFVocab:inputTo EclipseHono, EclipseDitto
    DTDFVocab:fromData PostOccupancyTelemetryTransmitted
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono supports MQTT‑based IoT messaging for sensor telemetry and control command routing."
    DTDFVocab:enables RealTimeMonitoringService, PerformanceSimulationByBIMService, PredictiveAnalyticsService, AutomatedCommissioningService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages device twin state and exposes REST/WS interfaces."
    DTDFVocab:enables InteractiveVisualizationService, AdaptiveLightingControlService, RealTimeMonitoringService, PerformanceSimulationByBIMService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 delivers real‑time 3D visualization of the digital twin."
    DTDFVocab:enables InteractiveVisualizationService
]

instance BIMAuthoringTool : DTDFVocab:Enabler [
    base:desc "BIM authoring tools model the building and embed control semantics."
]

instance ModelDrivenEngineeringTool : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering tools auto‑generate runtime artifacts from the BIM model."
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of environmental metrics via continuous sensor telemetry."
    DTDFVocab:provides AnomalyDetectionInsight
]

instance PerformanceSimulationByBIMService : DTDFVocab:Service [
    base:desc "Performance simulation via BIM for energy usage and structural assessment."
    DTDFVocab:provides EnergyConsumptionForecastInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization of the building and twin status through UE5."
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy optimization based on telemetry."
    DTDFVocab:provides EnergyConsumptionForecastInsight
]

instance AdaptiveLightingControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning‑based adaptive lighting control."
    DTDFVocab:provides AutomatedLightingAdjustmentAction
]

instance AutomatedCommissioningService : DTDFVocab:Service [
    base:desc "Automated commissioning workflows for building systems."
    DTDFVocab:provides ManualControlRecommendationAction
]

// C17: Insights/Actions
instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasts energy consumption based on predictive analytics."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects anomalies in building performance metrics."
]

instance AutomatedLightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatically adjusts lighting levels using RL‑based adaptive control."
    DTDFVocab:IsAutomatic true
]

instance ManualControlRecommendationAction : DTDFVocab:Action [
    base:desc "Recommends manual control adjustments to facility managers."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., light intensity adjustments) are transmitted back to the Building Control System (BCS) through Ditto messages, enabling bidirectional actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Synchronisation operates in real time with data throughput in the millisecond to sub‑second range, as dictated by Eclipse Hono’s event‑driven messaging and Ditto’s twin update mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A cohesive orchestration comprising a central Ditto hub, Hono middleware, device twins representing physical assets, simulation modules for BIM-based performance, and a visualization subsystem built on Unreal Engine, all connected via standardized APIs."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (BIM creation), Construction (device installation and metadata enrichment), Operation (runtime monitoring and control), and Adaptation (continuous evolution through reinforcement learning)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Assessment of twin fidelity via the ODTE metric, monitoring of semantic drift, and synchronization integrity checks between physical and virtual states."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to BIM IFC standards for model representation, use of open protocols (MQTT, JSON, HTTP) through Hono/Ditto, and alignment with AECO industry best practices for data integration."
]