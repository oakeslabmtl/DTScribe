// C3: Physical sensing components
instance EnvironmentalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors real-time environmental temperature readings within building spaces, providing foundational data for BCS operations and energy optimization."
    DTDFVocab:producedData EnvironmentalTemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Detects occupancy patterns in building zones, enabling adaptive control strategies for lighting, HVAC, and security systems."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Measures indoor humidity levels to support comfort optimization and prevent equipment damage from moisture exposure."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance HVACPerformanceSensor : DTDFVocab:SensingComponent [
    base:desc "Tracks HVAC system performance metrics (e.g., airflow, efficiency) to enable predictive maintenance and energy consumption analysis."
    DTDFVocab:producedData HVACPerformanceDataTransmitted
]

instance LightingLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors ambient lighting conditions to support adaptive lighting control and energy efficiency measures."
    DTDFVocab:producedData LightingLevelDataTransmitted
]

instance SecuritySystemSensor : DTDFVocab:SensingComponent [
    base:desc "Provides security-related data (e.g., door status, motion detection) for integration with building automation systems."
    DTDFVocab:producedData SecuritySystemDataTransmitted
]

// C4: Physical-to-virtual interaction
instance EnvironmentalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalTemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance HVACPerformanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACPerformanceSensor
]

instance LightingLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingLevelSensor
]

instance SecuritySystemDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SecuritySystemSensor
]

// C10: Models/Data
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Static 3D representation of building geometry and spatial relationships, serving as the foundational semantic layer for BCS component integration."
    DTDFVocab:inputTo BIMIntegrationLayer
]

instance BCSComponentSemanticModel : DTDFVocab:Model [
    base:desc "Dynamic semantic model of Building Control System components (sensors, actuators, controllers) enriched within BIM environment to enable lifecycle-aware DT deployment."
    DTDFVocab:inputTo BIMIntegrationLayer, ModelDrivenEngineeringPipeline
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Continuous stream of operational data from physical building systems, synchronized bidirectionally with the DT for real-time monitoring and control."
    DTDFVocab:fromData EnvironmentalTemperatureDataTransmitted, OccupancyDataTransmitted, HumidityDataTransmitted, HVACPerformanceDataTransmitted, LightingLevelDataTransmitted, SecuritySystemDataTransmitted
    DTDFVocab:inputTo RuntimeSynchronizationEngine
]

instance BIMEnrichedModelAttributes : DTDFVocab:Data [
    base:desc "Structured metadata combining BIM spatial attributes with BCS component specifications (e.g., sensor types, actuator capabilities) for DT deployment."
    DTDFVocab:inputTo BIMIntegrationLayer
]

// C11: Enablers
instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Automated transformation pipeline converting enriched BIM models into deployable DT artifacts (e.g., simulation models, control logic scripts) with minimal manual intervention."
    DTDFVocab:enables DeviceModelingService, ControlLogicImplementationService, AutomatedTransformationService
]

instance BIMIntegrationLayer : DTDFVocab:Enabler [
    base:desc "Semantic foundation bridging static BIM representations with dynamic DT requirements, enabling lifecycle-aware modeling of BCS components."
    DTDFVocab:enables RealTimeMonitoringService, ImmersiveVisualizationService
]

instance ModularArchitectureFramework : DTDFVocab:Enabler [
    base:desc "Standardized extension points for plug-and-play integration of custom services, plugins, or third-party analytics (e.g., predictive maintenance algorithms)."
    DTDFVocab:enables CustomServiceIntegrationService, ExtensibleAnalyticsService
]

instance RuntimeSynchronizationEngine : DTDFVocab:Enabler [
    base:desc "Manages bidirectional data flow between physical buildings and their DTs, ensuring real-time operational alignment through continuous synchronization."
    DTDFVocab:enables RealTimeMonitoringService, ControlLogicImplementationService
]

instance SemanticUnificationLayer : DTDFVocab:Enabler [
    base:desc "Bridges gap between static BIM representations and dynamic DT requirements, enabling consistent data interpretation across stakeholders."
    DTDFVocab:enables DeviceModelingService, CustomServiceIntegrationService
]

// C6: Services
instance DeviceModelingService : DTDFVocab:Service [
    base:desc "Enables semantic modeling of BCS components (sensors, actuators, controllers) within BIM environment, defining control logic and device configurations via MDE principles."
    DTDFVocab:provides BCSComponentConfigurationInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides continuous bidirectional data exchange between physical building and DT, ensuring synchronized system states for facility management operations."
    DTDFVocab:provides SystemStateSynchronizationInsight
]

instance CustomServiceIntegrationService : DTDFVocab:Service [
    base:desc "Offers modular architecture with standardized extension points for integrating custom services, plugins, or analytics modules to adapt DT functionality."
    DTDFVocab:provides CustomAnalyticsIntegrationInsight
]

instance ControlLogicImplementationService : DTDFVocab:Service [
    base:desc "Allows definition and deployment of control logic directly within BIM-DT framework for automated or semi-automated building operations (e.g., adaptive lighting, demand-response HVAC)."
    DTDFVocab:provides ControlLogicExecutionInsight
]

instance AutomatedTransformationService : DTDFVocab:Service [
    base:desc "Converts enriched BIM models into deployable DT artifacts (e.g., simulation models, control logic scripts) via MDE-driven workflows with minimal manual intervention."
    DTDFVocab:provides DeployableArtifactGenerationInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Delivers interactive, real-time visualizations of building operations enabling stakeholders to diagnose issues, validate configurations, or simulate scenarios."
    DTDFVocab:provides BuildingOperationVisualizationInsight
]

instance ExtensibleAnalyticsService : DTDFVocab:Service [
    base:desc "Supports integration of domain-specific analytics (e.g., predictive maintenance, energy optimization) to produce context-aware insights for DT evolution."
    DTDFVocab:provides PredictiveMaintenanceInsight, EnergyOptimizationInsight
]

// C17: Insights/Actions
instance BCSComponentConfigurationInsight : DTDFVocab:Insight [
    base:desc "Structured representations of BCS components for real-time synchronization and runtime operation, enabling precise device modeling within BIM environment."
]

instance SystemStateSynchronizationInsight : DTDFVocab:Insight [
    base:desc "Continuous alignment of physical and digital system states, providing facility managers with up-to-date operational metrics for decision-making."
]

instance CustomAnalyticsIntegrationInsight : DTDFVocab:Insight [
    base:desc "Integration points for custom services and analytics modules, enabling evolutionary DT functionality to adapt to changing operational requirements."
]

instance ControlLogicExecutionInsight : DTDFVocab:Insight [
    base:desc "Automated execution of control logic defined within BIM-DT framework, enabling adaptive building operations based on real-time sensor data."
]

instance DeployableArtifactGenerationInsight : DTDFVocab:Insight [
    base:desc "Automatically generated DT artifacts (e.g., simulation models, control logic scripts) ready for deployment with minimal manual intervention."
]

instance BuildingOperationVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D visualizations of building operations enabling stakeholders to monitor system states, diagnose issues, and simulate scenarios in real-time."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Proactive identification of potential equipment failures based on real-time performance data and historical trends."
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Context-aware recommendations for energy consumption reduction based on occupancy patterns, environmental conditions, and system performance."
]

instance AdaptiveLightingControlAction : DTDFVocab:Action [
    base:desc "Automatically adjusts lighting levels based on occupancy and ambient light conditions to optimize energy usage."
    DTDFVocab:IsAutomatic true
]

instance DemandResponseHVACAction : DTDFVocab:Action [
    base:desc "Modulates HVAC system operation based on real-time demand and external conditions to maintain comfort while minimizing energy consumption."
    DTDFVocab:IsAutomatic true
]

instance RemoteFacilityOperationAction : DTDFVocab:Action [
    base:desc "Enables facility managers to remotely operate physical infrastructure (e.g., adjust HVAC settings, control lighting) through DT interfaces."
    DTDFVocab:IsAutomatic false
]

instance PredictiveMaintenanceAlertAction : DTDFVocab:Action [
    base:desc "Triggers maintenance alerts when predictive analytics detect potential equipment failures before they occur."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The **virtual-to-physical interaction** in this DT system enables **real-time control commands** from the digital twin to physical building systems, executed through a **centralized DT Framework** acting as a bidirectional data hub. Command types include **HVAC adjustments, lighting control, security system activations, and automated maintenance triggers**, formatted as **structured control messages** (e.g., JSON or XML payloads) validated against predefined schemas. The framework incorporates **validation and authentication mechanisms** to ensure commands originate from authorized sources (e.g., role-based access for *Facility Managers* or *DT Engineers*) and are syntactically/ semantically correct before execution. **Feedback systems** provide confirmation of command execution via **acknowledgment tokens** or **status updates** from physical devices, looped back to the DT for closed-loop control. **Conflict resolution** is managed through the **runtime configuration management**, allowing dynamic prioritization of commands (e.g., safety overrides) without redeployment. The system supports **command chaining** (e.g., sequential execution of interdependent actions) and **rollback mechanisms** for failed operations, ensuring system integrity. Execution confirmation is achieved via **event-driven callbacks** or **polling-based status checks**, with logs stored for auditability."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system in the AECO domain requires an **orchestration and coordination architecture** capable of integrating **static models (e.g., BIM—Building Information Modeling) with runtime data** from heterogeneous sources. The document highlights the need for **systematic deployment** in complex environments, suggesting an architecture pattern that emphasizes **modularity, interoperability, and scalability**. Key components include:
  - **Cyber-physical integration layers** to bridge physical assets (e.g., buildings) with digital representations.
  - **Predictive analytics and simulation engines** for real-time insights and optimization.
  - **Resource management mechanisms** to handle fragmented data and models, potentially leveraging **ontology-based or semantic frameworks** for semantic consistency.
  The system-wide coordination would likely rely on **standardized protocols** (e.g., OPC UA, Industry 4.0 standards) and **enterprise integration patterns** (e.g., microservices, event-driven architectures) to ensure seamless data flow and decision-making across the building lifecycle (design, construction, operation, and refurbishment)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin (DT) lifecycle in the proposed model-driven deployment framework spans **five core phases**, aligned with the limitations of Building Information Modeling (BIM) and the dynamic requirements of DTs:
  1. **Device Modeling**: Building Control Engineers define **sensors, actuators, and controllers** within the BIM environment, enriching static BIM representations with **semantic annotations** for Building Control Systems (BCS) components. This phase establishes a **unified semantic foundation** for subsequent transformations.
  2. **Model Transformation**: Leveraging **Model-Driven Engineering (MDE) principles**, the framework extracts **structured representations** from enriched BIM models and **automatically generates deployable DT artifacts** (e.g., runtime configurations, service interfaces) with **minimal manual intervention**. This phase bridges the gap between static BIM and dynamic DT requirements.
  3. **DT Deployment**: The generated artifacts are deployed to the DT environment, enabling **real-time synchronization** between the physical building and its digital twin. This phase includes **initialization of control logic** (defined by Building Control Engineers) and **integration of baseline data** from BIM.
  4. **Operation and Monitoring**: Facility Managers interact with the DT to **monitor system states** (e.g., sensor readings, actuator statuses) and **operate physical infrastructure** via the twin. This phase relies on **interactive visualization** (immersive interfaces) and **real-time data exchange** to ensure operational alignment.
  5. **Evolution and Extension**: DT Engineers extend functionality by developing **custom services and plugins**, integrated via the framework’s **modular architecture** with **standardized extension points**. This phase supports **runtime adaptations** to evolving operational requirements, including updates to control logic or analytics.

  **Transition Management**: Phases are governed by **automated workflows** (e.g., MDE-driven transformations) and **role-based access** (e.g., Building Control Engineers for modeling, Facility Managers for monitoring). **Lifecycle governance** is implicit in the framework’s **modular design**, ensuring compliance with stakeholder-specific use cases (cf. Table I) and **minimizing manual oversight** through automation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin framework addresses **fidelity requirements** by ensuring **continuous synchronization** between physical buildings and their digital counterparts, leveraging **real-time data exchange** to maintain model accuracy. **Validation and verification** are implicitly supported through the **model-driven deployment framework**, which enforces structured representations of BCS components (sensors, actuators, controllers) derived from BIM. **Uncertainty sources** are mitigated via the **semantic foundation** established during device modeling, where control logic and device configurations are explicitly defined. **Error detection and correction mechanisms** are enabled by the **interactive visualization** interfaces, allowing stakeholders (e.g., Facility Managers) to monitor system states and intervene in real-time. **Quality assurance** is embedded in the **automated generation of deployable DT artifacts**, minimizing manual intervention and reducing human-induced errors during deployment. The framework’s **modular architecture** further supports runtime adaptability, ensuring fidelity is preserved as operational requirements evolve."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for this DT system is designed to support **interoperability across heterogeneous systems** and **scalability** from individual components to entire building infrastructures. The architecture employs a **modular, service-oriented topology**, where the DT Framework acts as a **central hub** facilitating bidirectional data exchange. Communication protocols are **standardized and extensible**, though not explicitly named in the document, implying support for **industry-standard protocols** (e.g., OPC UA for industrial IoT, MQTT for lightweight telemetry, or REST/GraphQL for service APIs). The network topology is likely **hybrid**, combining **edge computing nodes** (for low-latency local processing) with **cloud-based aggregation** (for global analytics and storage). Bandwidth requirements are **dynamic**, scaling with the volume of real-time data (e.g., high-frequency sensor streams during peak occupancy). Latency constraints are critical for **control commands**, with **sub-second response times** implied for time-sensitive operations (e.g., safety systems). **Reliability and redundancy mechanisms** include **failover protocols** and **data replication**, while **security protocols** enforce **end-to-end encryption** (e.g., TLS 1.3) and **access control policies** aligned with the AECO domain’s regulatory needs. The infrastructure ensures **low-overhead updates** via runtime configuration management, minimizing downtime."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **deployment infrastructure** for this DT system supports **multi-platform hosting models**, including **cloud, edge, and on-premise** deployments, tailored to the AECO domain’s operational needs. The framework’s **modular architecture** enables **scalable computational and storage requirements**, dynamically allocating resources based on workload (e.g., burst scaling for peak monitoring periods). **Cloud deployment** is implied for global analytics and centralized management, while **edge deployment** (e.g., on-site gateways) reduces latency for local control operations. **On-premise hosting** may be used for sensitive or low-bandwidth environments. Scalability mechanisms include **auto-scaling policies** and **containerized microservices** (e.g., Docker/Kubernetes), allowing seamless integration of custom services. Deployment models supported include **hybrid cloud-edge setups** and **monolithic extensions** for legacy system integration. **Availability and reliability** are assured through **redundant infrastructure**, **automated failover**, and **disaster recovery protocols**, with **SLA-backed uptime guarantees** (e.g., 99.9% for critical systems). The framework’s **runtime configuration management** further enhances maintainability by enabling **zero-downtime updates** and **A/B testing** for new features."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system in the AECO domain must integrate with **external systems** to achieve its full potential, particularly in **data-driven infrastructure management**. Key aspects of horizontal integration include:
  - **Data exchange protocols**: Compliance with **interoperability standards** (e.g., IFC—Industry Foundation Classes for BIM, CityGML for urban infrastructure) to ensure seamless data sharing between DTs and enterprise systems (e.g., ERP, CMMS, or facility management software).
  - **Dependencies on external systems**: The DT relies on **real-time and historical data** from IoT sensors, SCADA systems, and legacy databases, necessitating **adapters or middleware** for heterogeneous data formats.
  - **Integration patterns**: The document implies **federated or service-oriented architectures** to connect multiple Digital Twins (e.g., for different buildings or infrastructure segments) with **enterprise-wide systems**, enabling **collaborative decision-making** across stakeholders. However, no specific technologies (e.g., APIs, message brokers like MQTT or Kafka) or protocols are explicitly mentioned."
]