// -----------------------------------------------------------------------------
// C3: Physical sensing components
// -----------------------------------------------------------------------------
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in the enriched BIM model and instantiated as a DittoThing for real‑time measurement."
    DTDFVocab:producedData TemperatureDataStream
]

instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light level sensor defined in the enriched BIM model and instantiated as a DittoThing for real‑time illumination measurement."
    DTDFVocab:producedData LightDataStream
]

// -----------------------------------------------------------------------------
// C4: Physical‑to‑virtual data transmission
// -----------------------------------------------------------------------------
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance LightDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

// -----------------------------------------------------------------------------
// C10: Data objects
// -----------------------------------------------------------------------------
instance TemperatureData : DTDFVocab:Data [
    base:desc "Validated temperature readings after policy‑based checks performed by Eclipse Ditto."
    DTDFVocab:fromData TemperatureDataStream
]

instance LightData : DTDFVocab:Data [
    base:desc "Validated illumination readings after policy‑based checks performed by Eclipse Ditto."
    DTDFVocab:fromData LightDataStream
]

// -----------------------------------------------------------------------------
// C2: Acting components (actuators)
// -----------------------------------------------------------------------------
instance HVACTwinComponent : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator modelled in BIM as a controller device represented in the twin by a TwinComponent."
]

instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modelled in BIM as a controller device represented in the twin by a TwinComponent."
]

// -----------------------------------------------------------------------------
// C10: Models / Data sources
// -----------------------------------------------------------------------------
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with explicit device definitions (sensors, actuators, controllers) and embedded control logic."
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model extracted from the enriched BIM containing control logic for automated building operation."
]

instance PredictiveAnalyticsModel : DTDFVocab:Model [
    base:desc "Predictive analytics and optimization model (e.g., energy use forecasting) generated by MDE techniques."
]

// -----------------------------------------------------------------------------
// C11: Enablers (platforms, frameworks, controllers)
// -----------------------------------------------------------------------------
instance EclipseDittoPlatform : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto hosts digital‑twin Things, provides policy‑based validation and a persistent event store."
]

instance EclipseHonoMessaging : DTDFVocab:Enabler [
    base:desc "Eclipse Hono transports real‑time sensor streams with at‑least‑once delivery to Ditto."
]

instance UnrealTwinController : DTDFVocab:Enabler [
    base:desc "Unreal Twin Controller routes commands from the digital twin to DittoController and visualises components in UE5."
]

instance DittoController : DTDFVocab:Enabler [
    base:desc "DittoController uses DittoDevice and DittoConnection objects to address physical field devices and enforces safety checks in Ditto policies."
]

instance TwinLightFramework : DTDFVocab:Enabler [
    base:desc "Research initiative TwinLight provides standardized extension points for custom analytics and visualization plugins."
]

instance BOREALISFramework : DTDFVocab:Enabler [
    base:desc "Research initiative BOREALIS underpins the model‑driven deployment workflow that auto‑generates digital‑twin artifacts."
]

// -----------------------------------------------------------------------------
// C6: Services
// -----------------------------------------------------------------------------
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides continuous monitoring of sensor states and publishes live building status."
]

instance AutomatedControlService : DTDFVocab:Service [
    base:desc "Executes embedded control logic to automatically adjust actuators (HVAC, lighting)."
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Runs predictive analytics models to forecast energy consumption and suggest optimisations."
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Offers immersive UE5 visualization for facility managers to monitor and control the building."
]

// -----------------------------------------------------------------------------
// C17: Insights and Actions
// -----------------------------------------------------------------------------
instance EnergyUsageInsight : DTDFVocab:Insight [
    base:desc "Insight describing current energy consumption trends derived from sensor data."
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight proposing optimal set‑points for HVAC and lighting to reduce energy use."
]

instance AdjustHVACTemperatureAction : DTDFVocab:Action [
    base:desc "Automatic action that changes HVAC set‑point based on control logic decisions."
    DTDFVocab:IsAutomatic true
]

instance VisualAlertAction : DTDFVocab:Action [
    base:desc "Visual alert shown in the UE5 interface when abnormal sensor values are detected."
    DTDFVocab:IsAutomatic false
]

// -----------------------------------------------------------------------------
// C5: Environment (stakeholder roles) and central hub
// -----------------------------------------------------------------------------
instance BuildingDigitalTwinHub : DTDFVocab:Environment [
    base:desc "Central Digital Twin instance acting as a hub for Building Control Engineers, Facility Managers, and DT Engineers."
    base:contains TemperatureSensor, LightSensor, HVACTwinComponent, LightTwinComponent,
                 RealTimeMonitoringService, AutomatedControlService,
                 PredictiveAnalyticsService, InteractiveVisualizationService
]

instance BuildingDigitalTwin : DTDFVocab:DigitalTwin [
    base:desc "Core digital‑twin representation referenced by DTComponent instances."
]

instance BuildingControlEngineer : DTDFVocab:DTComponent [
    base:desc "Engineer who enriches the BIM model with device specifications and embeds control logic."
    base:isContainedIn StakeholderEnvironment
]

instance FacilityManager : DTDFVocab:DTComponent [
    base:desc "Manager who monitors and operates the physical infrastructure via the twin."
    base:isContainedIn StakeholderEnvironment
]

instance DTEngineer : DTDFVocab:DTComponent [
    base:desc "Engineer who develops and integrates custom analytics and control plugins into the twin."
    base:isContainedIn StakeholderEnvironment
]

instance StakeholderEnvironment : DTDFVocab:Environment [
    base:desc "Aggregates the three stakeholder roles interacting with the central Digital Twin hub."
    base:contains BuildingControlEngineer, FacilityManager, DTEngineer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Virtual‑to‑physical interaction is provided by the digital twin’s ability to issue monitoring and control commands back to the building. Facility managers interact with the deployed DT for real‑time control, and the framework’s bidirectional exchange mechanism conveys control messages to physical devices. Details on command formats, validation, authentication, or execution acknowledgments are not specified in the source material."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange that keeps the physical building and its digital counterpart continuously synchronized; synchronization is performed at runtime with low‑latency updates sufficient for real‑time monitoring and control, though exact frequencies are not quantified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular architecture with standardized extension points and runtime configuration management, enabling integration of custom services and analytics. A central DT Framework component orchestrates bidirectional data flow between enriched BIM models and operational services, supporting scalability from individual components to the whole infrastructure."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by embedding device metadata (e.g., Revit photometric values) directly in the BIM model and by generating TwinComponents that faithfully render these parameters in the UE5 scene. Validation is performed at three stages: (i) model conversion validation in the DT framework, (ii) Eclipse Ditto policy‑based validation of sensor values and actuator commands (value ranges, units), and (iii) pre‑execution checks for actuator safety. Uncertainty sources such as mismatched units or out‑of‑range values are detected by Ditto policies and rejected. Fault tolerance is achieved through Eclipse Hono’s at‑least‑once delivery and Ditto’s persistent event storage, ensuring resilience against network failures and enabling replay for error correction. Quality assurance relies on these runtime checks and the modular extension points that allow additional verification services to be plugged in."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on the framework’s modular architecture and standardized extension points, enabling interoperability and scalability across heterogeneous systems. The documents reference robust connectivity components such as Eclipse Ditto and BaSyx that supply standard‑compliant communication protocols and connectivity infrastructure. Precise network topology, bandwidth, latency, redundancy, or security protocol specifications are not described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The solution emphasizes interoperability across heterogeneous systems through real‑time data exchange, standardized extension points, and BIM integration. It supports bidirectional data exchange with external BIM tools and other enterprise services, addressing non‑functional requirements such as interoperability, scalability, maintainability, and accessibility."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution is anchored on BIM as the primary semantic model, aiming to align with AECO‑industry data standards. It references open‑source DT frameworks such as Eclipse Ditto and BaSyx that provide standard‑compliant connectivity and interoperability, indicating an intent to adopt established interoperability protocols. However, the documents do not list specific standards, certifications, or compliance frameworks beyond the generic BIM alignment."
]