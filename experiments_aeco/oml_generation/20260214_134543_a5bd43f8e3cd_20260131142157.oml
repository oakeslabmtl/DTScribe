// C3: Physical sensing components
instance LightIntensitySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded light intensity sensor modeled in BIM, providing real‑time telemetry via MQTT topics to the DT"
    DTDFVocab:producedData LightTelemetry
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded temperature sensor modeled in BIM, providing real‑time telemetry via MQTT topics to the DT"
    DTDFVocab:producedData TempTelemetry
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded humidity sensor modeled in BIM, providing real‑time telemetry via MQTT topics to the DT"
    DTDFVocab:producedData HumidityTelemetry
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Embedded occupancy detector modeled in BIM, providing real‑time telemetry via MQTT topics to the DT"
    DTDFVocab:producedData OccupancyTelemetry
]

// C4: Physical‑to‑virtual interaction
instance LightTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightIntensitySensor
]

instance TempTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

// C (Data)
instance LightData : DTDFVocab:Data [
    base:desc "Real‑time light intensity data streamed from LightIntensitySensor"
    DTDFVocab:inputTo HonoDittoForwarder
    DTDFVocab:fromData LightTelemetry
]

instance TempData : DTDFVocab:Data [
    base:desc "Real‑time temperature data streamed from TemperatureSensor"
    DTDFVocab:inputTo HonoDittoForwarder
    DTDFVocab:fromData TempTelemetry
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Real‑time humidity data streamed from HumiditySensor"
    DTDFVocab:inputTo HonoDittoForwarder
    DTDFVocab:fromData HumidityTelemetry
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy data streamed from OccupancyDetector"
    DTDFVocab:inputTo HonoDittoForwarder
    DTDFVocab:fromData OccupancyTelemetry
]

// C11: Enablers
instance HonoDittoForwarder : DTDFVocab:Enabler [
    base:desc "A forwarder that takes MQTT topics managed by Eclipse Hono and forwards telemetry to Ditto entities"
    DTDFVocab:enables RealTimeMonitoringDashboardService, SimulationEngineService, OptimisationAlgorithmService, PredictiveMaintenanceService, EnergyConsumptionAnalyticsService, ImmersiveVisualizationService, ControlPolicyOptimizationService, ModelConfigurationService
]

// C6: Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Service that aggregates real‑time KPIs such as energy usage and occupancy heat maps for facility managers"
    DTDFVocab:provides EnergyUsageInsight, OccupancyHeatMapInsight
]

instance SimulationEngineService : DTDFVocab:Service [
    base:desc "Service that runs simulation engines on BIM models to forecast building performance"
    DTDFVocab:provides SimulationResultInsight
]

instance OptimisationAlgorithmService : DTDFVocab:Service [
    base:desc "Service that runs optimisation algorithms (e.g., reinforcement learning for lighting control) to generate actionable control strategies"
    DTDFVocab:provides LightingControlAction, HVACControlAction, BlindControlAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Service that analyzes telemetry to generate predictive maintenance alerts"
    DTDFVocab:provides PredMaintenanceAlert
]

instance EnergyConsumptionAnalyticsService : DTDFVocab:Service [
    base:desc "Service that provides analytics on energy consumption and efficiency"
    DTDFVocab:provides EnergyEfficiencyInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Service that renders immersive visualization of the building model in Unreal Engine 5"
    DTDFVocab:provides VRVisualizationInsight
]

instance ControlPolicyOptimizationService : DTDFVocab:Service [
    base:desc "Service that hosts the BOREALIS reinforcement learning controller iterating on control policies based on post‑occupancy data"
    DTDFVocab:provides RLControlPolicyInsight
]

instance ModelConfigurationService : DTDFVocab:Service [
    base:desc "Service that deploys enriched BIM IFC models and Ditto entity definitions into the DT platform"
    DTDFVocab:provides ModelSetupInsight
]

// C17: Insights
instance EnergyUsageInsight : DTDFVocab:Insight [
    base:desc "Real‑time dashboard KPI showing current and historical energy usage"
]

instance OccupancyHeatMapInsight : DTDFVocab:Insight [
    base:desc "Heat map visualisation of occupancy data across the building"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulation outputs predicting thermal performance and energy consumption"
]

instance PredMaintenanceAlert : DTDFVocab:Insight [
    base:desc "Alert generated when predictive analytics detect potential maintenance issues"
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight summarising energy efficiency metrics and opportunities"
]

instance VRVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight detailing immersive visual output in Unreal Engine 5"
]

instance RLControlPolicyInsight : DTDFVocab:Insight [
    base:desc "Insight describing the latest reinforcement learning control policy"
]

instance ModelSetupInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful deployment of enriched BIM and Ditto entity definitions"
]

// C17: Actions
instance LightingControlAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting dimmers to optimise energy usage while maintaining illumination levels"
    DTDFVocab:IsAutomatic true
]

instance HVACControlAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of HVAC dampers and temperature setpoints to optimise thermal comfort and energy usage"
    DTDFVocab:IsAutomatic true
]

instance BlindControlAction : DTDFVocab:Action [
    base:desc "Automatic positioning of motorised blinds based on occupancy and daylight levels"
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance BIMIFCModel : DTDFVocab:Model [
    base:desc "BIM IFC model enriched with control and sensor metadata for the Living Lab academic building"
    DTDFVocab:inputTo HonoDittoForwarder
]

instance DittoEntityDefinitionModel : DTDFVocab:Model [
    base:desc "Ditto entity definitions derived from enriched BIM for virtual twin entities"
    DTDFVocab:inputTo HonoDittoForwarder
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., dimming levels, HVAC set‑points) are published by Ditto to MQTT topics subscribed by physical controllers; these messages are then executed on the building’s physical components."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization with low‑latency (sub‑second) data exchange, alongside periodic batch simulations (daily or hourly) for optimisation; overall system designed for real‑time operational support."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A coordinated system of BIM (semantic backbone), Eclipse Hono (data ingestion), Eclipse Ditto (entity management and pub/sub), and Unreal Engine 5 (visualisation), forming a modular architecture that supports extension by DT engineers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Encompasses all building life‑cycle phases: design (as‑designed BIM), manufacturing (as‑manufactured verification), construction (as‑constructed BIM alignments), and operation (real‑time monitored)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Verification of BIM semantic consistency via model validation tools; runtime alignment measured by the Overall Digital Twin Entanglement (ODTE) metric; continuous synchronization checks to detect semantic drift."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical devices communicate over MQTT (TLS) or HTTP to Hono; Hono distributes messages to Ditto over MQTT/REST; Ditto brokers expose WebSocket and REST interfaces to the virtual client; network topology includes edge gateways and cloud broker."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Containerised deployment of Eclipse Hono and Ditto on Kubernetes (or Docker Swarm), hosted on a cloud platform (e.g., AWS, GCP) or on‑premises edge infrastructure; Unreal Engine 5 runs on a dedicated workstation or VR rig."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Employs standardized integration frameworks aligned with AECO practices; BIM serves as the semantic backbone, adhering to industry‑wide building information modeling standards."
]