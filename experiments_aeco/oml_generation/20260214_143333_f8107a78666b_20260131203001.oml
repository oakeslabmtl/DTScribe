// C2: Acting Components
instance LightingActuatorSystem : DTDFVocab:ActingComponent [
    base:desc "Adaptive lighting system with reinforcement learning-based optimization for energy efficiency in BOREALIS project"
]

instance HVACController : DTDFVocab:ActuatingComponent [
    base:desc "Building Control System component managing HVAC operations with bidirectional communication capabilities"
]

instance OccupancyActuator : DTDFVocab:ActuatingComponent [
    base:desc "Automated occupancy-based lighting and HVAC control system for dynamic building operation"
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy sensor embedded in building infrastructure for occupancy detection monitoring"
    DTDFVocab:producedData OccupancyDataStream
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental temperature sensor monitoring indoor environmental quality in the LEED Platinum Living Lab"
    DTDFVocab:producedData TemperatureDataStream
]

instance LightingLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting intensity sensor measuring energy consumption and occupant comfort metrics"
    DTDFVocab:producedData LightingIntensityDataStream
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Real-time energy consumption monitoring device for operational cost optimization"
    DTDFVocab:producedData EnergyConsumptionDataStream
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "Indoor environmental quality sensor tracking CO₂ levels for occupant comfort monitoring"
    DTDFVocab:producedData CO2DataStream
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Structural health monitoring sensor for predictive maintenance of building infrastructure"
    DTDFVocab:producedData VibrationDataStream
]

// C4: Physical-to-virtual interaction
instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance LightingIntensityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingLevelSensor
]

instance EnergyConsumptionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance CO2DataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance VibrationDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
]

// C10: Models/Data
instance BIMBuildingModel : DTDFVocab:Model [
    base:desc "Semantic BIM model serving as the geometric and topological backbone for the Living Lab building infrastructure"
]

instance RuntimeMetadataModel : DTDFVocab:Model [
    base:desc "Runtime metadata extracted from BIM for device configurations, sensor/actuator mappings, and control logic definitions"
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy data streams processed for adaptive control system operations"
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo EclipseHono
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Environmental temperature data processed for energy optimization and comfort monitoring"
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo EclipseHono
]

instance LightingData : DTDFVocab:Data [
    base:desc "Lighting intensity data processed for adaptive lighting optimization and energy savings"
    DTDFVocab:fromData LightingIntensityDataStream
    DTDFVocab:inputTo EclipseHono
]

instance EnergyData : DTDFVocab:Data [
    base:desc "Real-time energy consumption metrics processed for operational cost reduction and efficiency optimization"
    DTDFVocab:fromData EnergyConsumptionDataStream
    DTDFVocab:inputTo EclipseHono
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Indoor environmental quality data processed for occupant comfort optimization"
    DTDFVocab:fromData CO2DataStream
    DTDFVocab:inputTo EclipseHono
]

instance StructuralHealthData : DTDFVocab:Data [
    base:desc "Structural vibration data processed for predictive maintenance and infrastructure monitoring"
    DTDFVocab:fromData VibrationDataStream
    DTDFVocab:inputTo EclipseHono
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware enabling real-time IoT data exchange and bidirectional communication between physical and virtual assets"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, AutomatedCommissioningService
]

instance UnrealEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine platform providing immersive 3D visualization and interactive monitoring capabilities for the Digital Twin"
    DTDFVocab:enables ImmersiveVisualizationService, InteractiveDashboardService
]

instance ModelDrivenEngineering : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering principles automating the transformation of BIM models into Digital Twin artifacts"
]

instance StandardizedExtensionPoints : DTDFVocab:Enabler [
    base:desc "Modular extension points for scalable service integration and evolving analytics control strategies"
    DTDFVocab:enables CustomServiceIntegrationService
]

instance RevitBIMTool : DTDFVocab:Enabler [
    base:desc "BIM tool (Revit) used for device modeling and control logic definition within the AECO workflow"
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring and visualization using Unreal Engine for immersive 3D interaction of building performance metrics"
    DTDFVocab:provides RealTimeBuildingMetricsInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics and optimization for operational cost reduction, energy efficiency, and occupant comfort"
    DTDFVocab:provides PredictiveMaintenanceInsight, EnergyOptimizationAction
]

instance AutomatedCommissioningService : DTDFVocab:Service [
    base:desc "Automated commissioning with bidirectional communication between virtual and physical assets"
    DTDFVocab:provides CommissioningVerificationAction
]

instance CustomServiceIntegrationService : DTDFVocab:Service [
    base:desc "Custom service integration via standardized extension points for modular analytics and control strategies"
    DTDFVocab:provides ModularAnalyticsService
]

instance AdaptiveControlService : DTDFVocab:Service [
    base:desc "Adaptive control systems (e.g., reinforcement learning-based lighting optimization in BOREALIS project)"
    DTDFVocab:provides DynamicLightingAdjustmentAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D visualization component for interactive building monitoring"
    DTDFVocab:provides 3DVisualizationInsight
]

instance InteractiveDashboardService : DTDFVocab:Service [
    base:desc "Interactive visualization dashboard for decision support in facility management"
    DTDFVocab:provides FacilityManagerDashboard
]

// C17: Insights/Actions
instance RealTimeBuildingMetricsInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of building performance metrics including energy consumption and occupant comfort"
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics for proactive maintenance and optimization of building systems"
]

instance EnergyOptimizationAction : DTDFVocab:Action [
    base:desc "Optimization actions for reducing operational costs and improving energy efficiency"
    DTDFVocab:IsAutomatic true
]

instance CommissioningVerificationAction : DTDFVocab:Action [
    base:desc "Verification actions during automated commissioning of building systems"
    DTDFVocab:IsAutomatic true
]

instance ModularAnalyticsService : DTDFVocab:Action [
    base:desc "Modular analytics service enabling scalable integration of new analytics capabilities"
    DTDFVocab:IsAutomatic true
]

instance DynamicLightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Reinforcement learning-based dynamic lighting adjustments based on occupancy and environmental conditions"
    DTDFVocab:IsAutomatic true
]

instance 3DVisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive 3D visualization of building infrastructure and operational metrics"
]

instance FacilityManagerDashboard : DTDFVocab:Insight [
    base:desc "Interactive dashboard providing decision support for facility managers and control engineers"
]

// C12: Environment
instance LivingLabEnvironment : DTDFVocab:Environment [
    base:contains BIMBuildingModel, OccupancySensor, LightingActuatorSystem, HVACController, TemperatureSensor
]

instance BuildingControlSystemEnvironment : DTDFVocab:Environment [
    base:contains OccupancyActuator, HVACController, LightingActuatorSystem, EnergyConsumptionSensor, CO2Sensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals and commands generated by the DT to adjust physical building systems, such as lighting control logic, energy optimization policies, and adaptive adjustments based on reinforcement learning models. Enables closed-loop control for operational improvements."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization with sub-second latency for critical operational data (e.g., sensor readings, control commands). The framework supports continuous, dynamic updates throughout the building lifecycle, including post-occupancy phases."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "['Centralized DT platform with BIM as the core semantic model.', 'Modular integration of middleware (Hono/Ditto) for real-time data synchronization.', 'Interoperable ecosystem with standardized extension points for third-party services and analytics.', 'Orchestration of physical sensors, actuators, and control logic within a unified digital representation.']"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "['Design phase: Enriched BIM models with device configurations and control logic.', 'Construction phase: Integration of IoT devices and middleware (Hono/Ditto) for real-time data exchange.', 'Operation phase: Continuous monitoring, optimization, and adaptation via DT services (e.g., reinforcement learning for dynamic control).']"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "['Overall Digital Twin Entanglement (ODTE) metric to measure alignment between physical and virtual representations.', 'Verification of BIM model accuracy and completeness during enrichment.', 'Validation through real-world Living Lab case study and iterative refinement of control logic.', 'Uncertainty management via real-time data synchronization and adaptive learning (e.g., reinforcement learning).']"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "['Middleware-based architecture (Eclipse Hono/Ditto) for real-time data exchange between physical sensors and DT.', 'Bidirectional communication protocols for live synchronization (e.g., MQTT, WebSocket).', 'Cloud/edge deployment for scalability and low-latency processing.']"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "['Cloud-based deployment for centralized management and scalability.', 'Edge computing for low-latency processing of real-time sensor data.', 'Unreal Engine for interactive visualization hosted on dedicated servers or cloud platforms.']"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "['Integration with BIM tools (e.g., Revit) for unified modeling and device configuration.', 'Interoperability with external IoT platforms and building management systems (BMS).', 'Standardized APIs for third-party service integration (e.g., analytics, AI models).']"
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "['Physical asset owner retains primary ownership of sensor data and building systems.', 'DT service providers manage derived insights and analytics (e.g., energy optimization recommendations).', 'Compliance with AECO-specific standards (e.g., BIM protocols) and data privacy regulations (e.g., GDPR).']"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "['BIM as the semantic backbone for consistent modeling across AECO stakeholders.', 'Standardized extension points for modular service integration (e.g., IoT protocols, analytics frameworks).', 'Eclipse Hono/Ditto for interoperable real-time data exchange.', 'ODTE metric for validating DT fidelity and interoperability.']"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "['Encrypted communication protocols (e.g., TLS) for secure data transmission.', 'Remote operation capabilities for facility managers and engineers, with safeguards against unauthorized access.', 'Automated anomaly detection and fault management to prevent accidents in physical systems.', 'Compliance with safety standards for building automation (e.g., ISO 27001 for cybersecurity).']"
]