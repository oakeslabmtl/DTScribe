// C3: Physical sensing components
instance BIMEnrichedSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors modelled in the enriched BIM step, registered as devices in Eclipse Ditto and streamed in real time via Eclipse Hono."
    DTDFVocab:producedData SensorDataStream
]

// C4: Data Transmitted
instance SensorDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BIMEnrichedSensor
]

// C10: Data
instance BuildingSensorData : DTDFVocab:Data [
    base:desc "Continuous sensor measurements (e.g., temperature, humidity, status) transmitted at‑least‑once through Eclipse Hono into Ditto."
    DTDFVocab:fromData SensorDataStream
    DTDFVocab:inputTo EclipseHonoGateway, DittoPolicyValidator
]

// C11: Enablers
instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Real‑time data exchange layer (Eclipse Hono) delivering at‑least‑once messages from physical devices to Eclipse Ditto."
    DTDFVocab:enables RealTimeMonitoringService, ControlExecutionService
]

instance DittoPolicyValidator : DTDFVocab:Enabler [
    base:desc "Policy‑based validation in Eclipse Ditto that checks sensor ranges, units and command safety before persisting."
    DTDFVocab:enables ControlExecutionService, PredictiveAnalyticsService
]

instance UnrealVisualizationEngine : DTDFVocab:Enabler [
    base:desc "Interactive visualization component built on UE5 that renders TwinComponents and allows immersive monitoring and control."
    DTDFVocab:enables InteractiveVisualizationService, SimulationAnalysisService
]

instance MDEPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline that extracts semantics from enriched BIM models and auto‑generates DT artifacts."
    DTDFVocab:enables SimulationAnalysisService, PredictiveAnalyticsService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides continuous real‑time monitoring of building states through synchronized sensor data."
    DTDFVocab:provides LiveOperationalInsight
]

instance ControlExecutionService : DTDFVocab:Service [
    base:desc "Executes control logic defined by Building Control Engineers on physical actuators via Ditto and Hono."
    DTDFVocab:provides ExecuteControlLogic, GenerateAlertAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Delivers immersive, interactive visualization of building states for Facility Managers."
    DTDFVocab:provides ImmersiveVisualizationInsight
]

instance SimulationAnalysisService : DTDFVocab:Service [
    base:desc "Supports simulation‑based analysis and optimization of operational performance."
    DTDFVocab:provides SimulationBasedOptimizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Offers predictive analytics to aid decision‑making based on historical and real‑time data."
    DTDFVocab:provides PredictiveDecisionSupportInsight
]

// C17: Insights
instance LiveOperationalInsight : DTDFVocab:Insight [
    base:desc "Live operational insight derived from continuous sensor streams, enabling Facility Managers to monitor system states."
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight from the UE5 visualization layer that aggregates sensor data into an immersive view."
]

instance SimulationBasedOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight generated by simulation models to suggest performance optimizations."
]

instance PredictiveDecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Insight providing forecasts and recommendations for future building operation decisions."
]

// C17: Actions
instance ExecuteControlLogic : DTDFVocab:Action [
    base:desc "Action that triggers execution of control logic on physical actuators."
    DTDFVocab:IsAutomatic false
]

instance GenerateAlertAction : DTDFVocab:Action [
    base:desc "Action that generates alerts for Facility Managers when abnormal conditions are detected."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuating element materialized as a TwinComponent (LightTwinComponent) in UE5; commands routed via UnrealTwinController → DittoController → Eclipse Hono."
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched Building Information Model serving as the primary geometric and semantic repository."
    DTDFVocab:inputTo MDEPipeline, EclipseHonoGateway
]

instance DeviceModel : DTDFVocab:Model [
    base:desc "Model encapsulating sensors, actuators, and controllers extracted from the enriched BIM."
    DTDFVocab:inputTo MDEPipeline, EclipseHonoGateway
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model representing control logic defined by Building Control Engineers."
    DTDFVocab:inputTo MDEPipeline, DittoPolicyValidator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin supports bidirectional control flows: facility managers interact with the deployed DT for real‑time monitoring and issue control commands that are forwarded to physical building systems via the DT Framework. The framework acts as a central hub for sending commands from the virtual model to physical devices, but the documents do not detail command types, message formats, validation/authentication, feedback loops, conflict resolution, or execution confirmations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT framework adopts a modular, hub‑centric architecture. A central DT Framework component acts as the integration hub, providing standardized extension points for custom services and analytics. It mediates continuous bidirectional data exchange between the physical building and its digital counterpart and supports runtime configuration management, allowing adjustments without full redeployment. Roles such as Building Control Engineers (device modelling and deployment), Facility Managers (real‑time monitoring and control), and DT Engineers (service integration) interact with the hub, enabling coordinated life‑cycle management of the digital twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The proposed model‑driven deployment framework covers the full DT life‑cycle, starting with device modeling within the BIM environment (definition of sensors, actuators and controllers), followed by model‑driven engineering (MDE) that extracts structured representations from the enriched BIM model, automatic generation of deployable DT artefacts, deployment of the twin, and runtime operation where real‑time data exchange keeps the physical building synchronised with its digital counterpart. The framework also supports post‑deployment extension through custom services, representing an evolution from initial modelling to operational monitoring and analytics."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by a multi‑stage validation pipeline: enriched BIM models undergo structural validation, device configurations are checked against Ditto policies for value ranges and units, and actuator commands are subjected to pre‑execution checks to avoid unsafe actions. Synchronization errors are mitigated by Eclipse Hono’s at‑least‑once delivery and Ditto’s persistent event storage, providing fault tolerance. The use of policy‑based validation and persistent storage constitutes the primary quality‑assurance mechanisms; no explicit uncertainty quantification or additional verification methods are described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The proposed solution relies on a modular architecture with standardized extension points that enables interoperability across heterogeneous systems. Connectivity is achieved through a central DT Framework that can integrate services such as those provided by open‑source frameworks like Eclipse Ditto or BaSyx, which claim standard‑compliant communication. However, the documents do not describe the concrete network topology, specific communication protocols, bandwidth or latency requirements, redundancy mechanisms, or security protocols for the network layer."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment is initiated by building control engineers using BIM tools to model devices and trigger the deployment process; the DT Framework then hosts the digital twin as a central hub that can be reconfigured at runtime without full redeployment. While the framework supports modular, runtime‑configurable deployment, the documents do not specify the hosting platform (cloud, edge, on‑premise), computational or storage sizing, scalability strategies, supported deployment models, or availability/reliability guarantees."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution adopts a modular architecture with standardized extension points for integrating custom services, and the related work notes that open‑source DT frameworks such as Eclipse Ditto and BaSyx offer standard compliance and interoperability, although specific industry standards (e.g., IFC, ISO 19650) are not cited in the documents."
]