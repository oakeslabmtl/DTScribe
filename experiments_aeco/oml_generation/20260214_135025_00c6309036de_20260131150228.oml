// Digital Twin - Academic Building Lighting Control

// C2: Acting Components
instance DimmableLEDLampActuator : DTDFVocab:ActingComponent [
    base:desc "Dimmable LED lamp embedded in the BIM model and driven via Eclipse Hono/Ditto messaging."
]
instance LightingSwitchActuator : DTDFVocab:ActingComponent [
    base:desc "Control switch for lighting fixtures, modeled in BIM and activated through Hono/Ditto."
]

// C3: Physical sensing components
instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient light level sensor modeled in BIM, data streamed through Hono/Ditto."
    DTDFVocab:producedData LightLevelDataTransmitted
]
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor for presence detection, modeled in BIM."
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor providing ambient temperature data in the building."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Physical-to-virtual interaction – Data transmitted
instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C10: Models/Data
instance SemanticBIMModel : DTDFVocab:Model [
    base:desc "Semantic BIM model augmented with device metadata."
]
instance RuntimeConfigModel : DTDFVocab:Model [
    base:desc "Runtime device configuration generated by the Ditto configurator."
]
instance ControlLogicScripts : DTDFVocab:Model [
    base:desc "Control logic scripts governing lighting behavior."
]
instance SimulationModel : DTDFVocab:Model [
    base:desc "Building energy consumption simulation model."
]
instance RLPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement learning policy model for lighting control optimization."
]

// Instances of actual data streams
instance LightLevelData : DTDFVocab:Data [
    base:desc "Real‑time ambient light level data stream."
    DTDFVocab:fromData LightLevelDataTransmitted
    DTDFVocab:inputTo DittoConfigurator
]
instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy status data stream."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo DittoConfigurator
]
instance TemperatureData : DTDFVocab:Data [
    base:desc "Ambient temperature data stream."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DittoConfigurator
]

// C11: Enablers
instance DittoConfigurator : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto Configurator that processes sensor data streams and deploys twin instances."
    DTDFVocab:enables LiveMonitoringDashboardService,
                PredictiveAnalyticsService,
                RLPolicyOptimizationService,
                ImmersiveVisualizationService
]

// C6: Services
instance LiveMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Live monitoring dashboard that visualizes real‑time sensor data."
    DTDFVocab:provides RealTimeSensorDataInsight
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service for lighting control and energy savings."
    DTDFVocab:provides EnergySavingsProjectionInsight,
                OptimalLightingScheduleInsight
]
instance RLPolicyOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement learning based policy optimization service for lighting control."
    DTDFVocab:provides RecommendedActuatorSetpointAction
]
instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization service through Unreal Engine 5."
    DTDFVocab:provides VisualExperienceInsight
]

// C17: Insights/Actions
instance RealTimeSensorDataInsight : DTDFVocab:Insight [
    base:desc "Insight displaying real‑time sensor data in the dashboard."
]
instance EnergySavingsProjectionInsight : DTDFVocab:Insight [
    base:desc "Estimated energy savings projections based on predictive analytics."
]
instance OptimalLightingScheduleInsight : DTDFVocab:Insight [
    base:desc "Recommended optimal lighting schedule derived from analytics."
]
instance VisualExperienceInsight : DTDFVocab:Insight [
    base:desc "Immersive visual experience of building lighting."
]
instance RecommendedActuatorSetpointAction : DTDFVocab:Action [
    base:desc "Recommended actuator setpoints to achieve optimal lighting levels."
    DTDFVocab:IsAutomatic false
]

// C12: Environment and Components
instance AcademicBuildingEnvironment : DTDFVocab:Environment [
    base:contains AcademicBuildingComponent
]
instance AcademicBuildingComponent : DTDFVocab:Component [
    base:desc "BIM modeled academic building structure containing sensors and actuators."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., light level adjustments) are transmitted back to physical lighting devices via Hono/Ditto, enabling closed‑loop operation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time, continuous synchronization with latency typically in the order of seconds, enabling near‑instantaneous updates between the DT and the physical building."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated stack comprising the BIM‑derived semantic layer, the Hono/Ditto middleware for bi‑directional data exchange, runtime control logic engines, simulation modules, and the Unreal Engine visualization layer, all tied together through defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin supports the full life‑cycle of the building—from designed (BIM model), through construction (manufactured data integration), to operation (live sensor data and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Verification of BIM semantics through model validation, runtime synchronization assessed with the Overall Digital Twin Entanglement (ODTE) metric, and continuous synchronization to mitigate semantic drift."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono serving as the message broker and Eclipse Ditto as the device twin registry, facilitating bidirectional messaging of sensor data and control commands between the DT and the physical building."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Building Information Modeling (BIM) standards as the semantic backbone; adherence to Model‑Driven Engineering practices; no explicit industry‑wide standard for twin interfaces noted."
]