// C3: Physical sensing components
instance BIMDefinedBuildingSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors are defined within the BIM model by the Building Control Engineer, establishing a semantic link between physical measurement devices and their digital counterparts."
    DTDFVocab:producedData SensorDataStream
]

// C4: Physical-to-virtual interaction - Data transmitted
instance SensorDataStream : DTDFVocab:DataTransmitted [
    base:desc "Real‑time data exchange mechanisms keep sensor readings synchronized with the twin, providing continuous state updates for monitoring and control."
    DTDFVocab:producedFrom BIMDefinedBuildingSensor
]

// C5: Data object
instance BuildingSensorData : DTDFVocab:Data [
    base:desc "Data originating from physical devices is injected into the DT through a central hub and merged with enriched BIM information."
    DTDFVocab:fromData SensorDataStream
    DTDFVocab:inputTo RealTimeSyncHub
]

// C11: Enabler for real‑time synchronization
instance RealTimeSyncHub : DTDFVocab:Enabler [
    base:desc "Central hub that continuously synchronises physical building sensors and device models with their digital counterparts (bidirectional, continuous)."
    DTDFVocab:enables TwinSynchronizationService
]

// C6: Service for twin synchronization
instance TwinSynchronizationService : DTDFVocab:Service [
    base:desc "Service that orchestrates the continuous bidirectional synchronization between physical devices and the digital twin."
    DTDFVocab:provides TwinStateInsight, TwinUpdateAction
]

// C17: Insight about twin state
instance TwinStateInsight : DTDFVocab:Insight [
    base:desc "Provides insight into the current synchronized state of the building twin, indicating successful real‑time updates."
]

// C17: Action to update twin
instance TwinUpdateAction : DTDFVocab:Action [
    base:desc "Automatically applies incoming sensor data to update the digital twin representation."
    DTDFVocab:IsAutomatic true
]

// C3: Physical acting components
instance BIMDefinedActuator : DTDFVocab:ActingComponent [
    base:desc "Actuators are modeled as BIM components by the Building Control Engineer and integrated into the digital twin for remote invocation."
]

instance BIMDefinedController : DTDFVocab:ActingComponent [
    base:desc "Controllers are modeled as BIM components, enabling execution of control logic defined in the BIM model."
]

// C10: Models/Data (DT models and data)
instance DeviceDefinitionModel : DTDFVocab:Model [
    base:desc "Model extending BIM with device definitions, providing geometric representations of sensors, actuators and controllers."
    DTDFVocab:inputTo RealTimeSyncHub, MDETransformationEngine
]

instance BehavioralRepresentationModel : DTDFVocab:Model [
    base:desc "Model providing behavioral representations of BIM‑defined devices for simulation and analysis."
    DTDFVocab:inputTo RealTimeSyncHub, MDETransformationEngine
]

// C11: Enabler for model‑driven engineering transformations
instance MDETransformationEngine : DTDFVocab:Enabler [
    base:desc "Applies Model‑Driven Engineering transformations to enriched BIM artifacts, generating deployable digital twin artifacts."
    DTDFVocab:enables ModelDrivenTransformationService
]

// C6: Service for model‑driven transformation
instance ModelDrivenTransformationService : DTDFVocab:Service [
    base:desc "Creates DT services from enriched BIM models via automated MDE transformations."
    DTDFVocab:provides TransformationInsight
]

// C17: Insight about transformation process
instance TransformationInsight : DTDFVocab:Insight [
    base:desc "Indicates successful generation of digital twin artifacts from BIM models through MDE transformations."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are issued from the deployed Digital Twin to the physical building via the same central hub. Facility managers use the DT interface for real‑time monitoring and to send control actions that are propagated to field devices. The documents state that the DT framework enables bidirectional data exchange and command propagation, yet they do not detail command formats, validation, authentication, feedback loops, or execution confirmations."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides continuous real-time data exchange, keeping the physical building and its digital counterpart synchronised at runtime; updates are performed continuously with no explicit fixed interval, implying a latency‑sensitive, fine‑grained temporal granularity suitable for real‑time monitoring and control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a modular, hub‑centric architecture: a central DT Framework acts as a hub enabling bidirectional data exchange between components, while standardized extension points allow DT Engineers to plug in custom services and analytics. Runtime configuration management permits on‑the‑fly adjustments without redeployment. Roles (Building Control Engineers, Facility Managers, DT Engineers) interact with the hub, establishing coordinated orchestration of services across the building lifecycle."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports the full DT life‑cycle, starting with device modeling inside the BIM environment (defining sensors, actuators, and controllers), followed by Model‑Driven Engineering (MDE) extraction of structured representations, automatic generation of deployable DT artifacts, deployment to the runtime environment, continuous real‑time data exchange for synchronization, and runtime operation with interactive visualization. Transition between stages is managed automatically by the MDE transformation chain; governance is implied through the role‑based responsibilities (Building Control Engineer, Facility Manager, DT Engineer) but no explicit governance model is described."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin framework is described as a modular architecture with standardized extension points that supports interoperability across heterogeneous systems and ensures scalability from individual components to whole infrastructure. It relies on a central hub that mediates communication, but the specific network protocols, topology, bandwidth, latency, redundancy or security mechanisms are not enumerated in the provided material."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT solution is deployed as a central framework that can be configured at runtime without full redeployment, suggesting support for cloud, edge or on‑premise hosting environments. The modular design and runtime configuration management imply that computational and storage resources can be scaled as needed, although the documents do not give explicit details on hosting platforms, resource sizing, deployment models, or availability guarantees."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration is achieved through interoperability requirements that target heterogeneous systems; the framework exposes standardized extension points and supports bidirectional data exchange, allowing external enterprise systems or other Digital Twins to connect using compatible protocols, though no specific protocol is identified in the document."
]