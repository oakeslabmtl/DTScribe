// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Real‑time temperature sensor data ingested via Eclipse Hono and linked to BIM attributes."
    DTDFVocab:producedData BuildingSensorDataStream
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Real‑time humidity sensor data ingested via Eclipse Hono and mapped to BIM attributes."
    DTDFVocab:producedData BuildingSensorDataStream
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Real‑time energy consumption sensor data ingested via Eclipse Hono and associated with BIM entities."
    DTDFVocab:producedData BuildingSensorDataStream
]

// C4: Physical‑to‑virtual interaction
instance BuildingSensorDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor, HumiditySensor, EnergyConsumptionSensor
    base:desc "Continuous data stream aggregating temperature, humidity, and energy consumption readings, forwarded from Eclipse Hono to Eclipse Ditto."
]

// C10: Data
instance SensorLiveData : DTDFVocab:Data [
    DTDFVocab:fromData BuildingSensorDataStream
    DTDFVocab:inputTo DittoTwinState
    base:desc "Live sensor data unified representation used by the twin for monitoring, analytics, and control."
]

// C10: Models
instance GeometricBIMModel : DTDFVocab:Model [
    base:desc "Geometric BIM model enriched with semantic definitions of sensors, actuators, and controllers."
    DTDFVocab:inputTo DittoTwinState
]

instance BehavioralControlModel : DTDFVocab:Model [
    base:desc "Behavioral model describing control strategies encoded in BIM for building automation."
    DTDFVocab:inputTo DittoTwinState
]

instance AnalyticPluginModel : DTDFVocab:Model [
    base:desc "Analytic service model defining plug‑in interfaces for performance dashboards and optimisation algorithms."
    DTDFVocab:inputTo DittoTwinState
]

// C11: Enablers
instance HonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono gateway ingests real‑time sensor data and maps it to BIM‑linked attributes."
    DTDFVocab:enables RealTimeDecisionSupportService
]

instance DittoTwinState : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto holds the digital twin state and synchronizes live sensor data for interactive visualization."
    DTDFVocab:enables ImmersiveVisualizationService, AnalyticsPluginService
]

// C6: Services
instance RealTimeDecisionSupportService : DTDFVocab:Service [
    base:desc "Provides real‑time decision support through continuous data exchange, analytics plug‑ins, and actionable recommendations."
    DTDFVocab:provides EnergyUsageTrendInsight, FaultDetectionAlertInsight, TriggerBuildingControlAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Offers immersive visualization and interactive control interfaces for facility managers to monitor system states and run simulations."
    DTDFVocab:provides SystemStateInsight
]

instance AnalyticsPluginService : DTDFVocab:Service [
    base:desc "Enables integration of custom analytics plug‑ins such as performance dashboards and optimisation algorithms."
    DTDFVocab:provides PerformanceDashboardInsight
]

// C17: Insights
instance EnergyUsageTrendInsight : DTDFVocab:Insight [
    base:desc "Insight into energy‑usage trends derived from live sensor data."
]

instance FaultDetectionAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating detected faults based on sensor anomalies."
]

instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Visual representation of the current building system state."
]

instance PerformanceDashboardInsight : DTDFVocab:Insight [
    base:desc "Dashboard displaying performance metrics from analytical plug‑ins."
]

// C17: Actions
instance TriggerBuildingControlAction : DTDFVocab:Action [
    base:desc "Action to trigger building control actions directly via the digital twin."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Through the central DT Framework hub, Facility Managers can issue control commands from the digital twin back to the physical building control system. The framework supports bidirectional data exchange, allowing the DT to transmit operational directives (e.g., HVAC set‑points, lighting control) to the building infrastructure. Validation, authentication and feedback mechanisms are mentioned only in general terms as part of the framework’s runtime configuration management, without concrete technical specifications."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports a complete Digital Twin lifecycle that starts with device modeling inside the BIM environment, where Building Control Engineers define sensors, actuators and controllers. The enriched BIM model is then processed by Model‑Driven Engineering (MDE) transformations to extract a structured representation and automatically generate deployable DT artefacts. These artefacts are deployed to the runtime environment, establishing real‑time data exchange that continuously synchronises the physical building and its digital counterpart. During operation the twin offers interactive visualisation for monitoring and control. Evolution is handled by adding custom services or plugins (via the DT Engineer role) and re‑generating artefacts as needed, thus moving the twin from a static deployment to an extensible, operational state."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution builds on Building Information Modelling (BIM), the de‑facto industry standard for construction data exchange, and extends it with a unified semantic layer for control components. The framework’s architecture defines standardized extension points (e.g., plug‑in APIs) to ensure interoperability of custom services. While specific standards such as IFC or ISO 19650 are not named, the reliance on BIM and the use of standardized APIs imply compliance with established construction and software integration standards, facilitating exchange with other BIM‑based tools and third‑party analytics platforms."
]