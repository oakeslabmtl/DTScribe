// C3: Physical sensing components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor component defined in the BIM model that publishes measurements (e.g., illumination level) through Eclipse Hono to Eclipse Ditto."
    DTDFVocab:producedData BuildingSensorDataTransmitted
]

// C4: Physical-to-virtual interaction
instance BuildingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

// C5: Data
instance BuildingSensorData : DTDFVocab:Data [
    base:desc "Real‑time sensor measurement data (e.g., illumination level, unit lux) transmitted from the physical sensor to the digital twin."
    DTDFVocab:fromData BuildingSensorDataTransmitted
    DTDFVocab:inputTo EclipseDittoStore
]

// C11: Enablers
instance EclipseDittoStore : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto persistence layer that stores incoming sensor events and applies policy‑based validation."
    DTDFVocab:enables RealTimeSynchronizationService
    DTDFVocab:enables FacilityMonitoringService
    DTDFVocab:enables LightingControlService
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 based visualization layer that renders the 3‑D building model and updates visual state from twin data."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance RealTimeSynchronizationService : DTDFVocab:Service [
    base:desc "Continuously synchronizes the digital twin state with real‑time sensor data via Ditto."
    DTDFVocab:provides FacilityStateInsight
]

instance FacilityMonitoringService : DTDFVocab:Service [
    base:desc "Provides facility managers with monitoring of system states through the UE5 visualization."
    DTDFVocab:provides FacilityStateInsight
]

instance LightingControlService : DTDFVocab:Service [
    base:desc "Processes control commands for lighting actuators (on/off, brightness, color‑temperature) and forwards them via Ditto to the physical devices."
    DTDFVocab:provides LightingAdjustmentAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Delivers interactive 3‑D visualization of building performance to facility managers."
    DTDFVocab:provides FacilityStateInsight
]

// C17: Insights/Actions
instance FacilityStateInsight : DTDFVocab:Insight [
    base:desc "Real‑time overview of building component states for facility managers."
]

instance LightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjusts a lighting device (turn on/off, set brightness, set color temperature) as issued by a facility manager."
    DTDFVocab:IsAutomatic false
]

// C10: Models/Data
instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing geometry, sensor, and actuator definitions used as source for 3‑D rendering in Unreal Engine 5."
    DTDFVocab:inputTo UnrealEngineVisualization
    DTDFVocab:inputTo EclipseDittoStore
]

instance LightingBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model defined by LightTwinComponent and LightFeatureParser that reacts to on/off, brightness, and color‑temperature values."
    DTDFVocab:inputTo EclipseDittoStore   // Corrected to reference an Enabler
]

// C2: Acting Components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Twin component representing a lighting actuator linked to the corresponding DittoDevice and DittoConnection to receive control commands."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange capabilities that keep the physical building and its digital counterpart continuously synchronized; however, specific update frequencies, latency limits, or temporal granularity are not detailed in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, service‑oriented architecture with standardized extension points and runtime configuration management; the DT Framework serves as the central orchestration component, mediating bidirectional data exchange between BIM models, sensors, and custom analytics services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The proposed model‑driven DT deployment framework supports a full DT lifecycle composed of (1) device modeling where Building Control Engineers enrich BIM models with explicit sensor, actuator, and controller definitions; (2) model transformation using Model‑Driven Engineering (MDE) to extract a structured representation from the enriched BIM; (3) automatic generation of deployable DT artifacts (code, configuration, and service descriptors); (4) deployment and runtime operation during which real‑time data exchange synchronises the physical building and its digital counterpart; (5) interactive, immersive visualization for monitoring and control; and (6) post‑deployment evolution through the integration of custom services and analytics via standardized extension points. Governance is enforced by the modular architecture and its extension‑point contracts, which define how artifacts are versioned, validated and evolved across stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by enriching BIM models with device metadata and by using validation, conversion, and configuration components before deployment. Quality assurance includes Eclipse Ditto’s policy‑based validation (checking sensor value ranges, units, and actuator command safety), pre‑execution checks for commands, and fault tolerance via Hono’s at‑least‑once message delivery combined with Ditto’s persistent event storage. These mechanisms provide error detection, correction, and uncertainty mitigation throughout the twin’s lifecycle."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external and heterogeneous systems is achieved via interoperable interfaces and standardized extension points, supporting custom service integration and analytics; the documents do not specify concrete data exchange protocols or standards such as OPC UA or MQTT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Interoperability is achieved via a modular architecture with standardized extension points for plug‑in integration. The approach aligns with the connectivity and standard‑compliance strategies of open‑source DT frameworks such as Eclipse Ditto and BaSyx, which implement common IoT standards (e.g., NGSI‑LD, MQTT, OPC‑UA), although the documents do not list explicit industry standards (such as IFC, ISO 19650) or certification requirements."
]