// C3: Physical Sensing Components
instance IndoorTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Real-time temperature sensor integrated into Building Control System components for academic buildings and libraries. Part of IoT sensor network for environmental monitoring."
    DTDFVocab:producedData IndoorTemperatureDataTransmitted
]

instance IndoorHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Real-time humidity sensor integrated into Building Control System components for environmental monitoring in academic buildings and libraries."
    DTDFVocab:producedData IndoorHumidityDataTransmitted
]

instance AirQualitySensor : DTDFVocab:SensingComponent [
    base:desc "CO2, VOC, and particulate matter sensor for indoor air quality monitoring in academic buildings and libraries."
    DTDFVocab:producedData AirQualityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Real-time occupancy tracking sensor for space utilization optimization in academic buildings and libraries."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Energy consumption monitoring sensor for HVAC and lighting systems in academic buildings."
    DTDFVocab:producedData EnergyConsumptionDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance IndoorTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndoorTemperatureSensor
]

instance IndoorHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndoorHumiditySensor
]

instance AirQualityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirQualitySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

// C10: Models/Data
instance BimEnrichedModel : DTDFVocab:Model [
    base:desc "Building Information Model enriched with Building Control System components (sensors, actuators, controllers) to enable dynamic digital twin representations."
    DTDFVocab:inputTo EclipseBasyxEnabler, ModelDrivenEngineeringEnabler
]

instance RealTimeEnvironmentalData : DTDFVocab:Data [
    base:desc "Aggregated real-time data from indoor environmental sensors (temperature, humidity, air quality, occupancy) for digital twin synchronization."
    DTDFVocab:fromData IndoorTemperatureDataTransmitted, IndoorHumidityDataTransmitted, AirQualityDataTransmitted, OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseBasyxEnabler, SimulationEngineEnabler
]

instance EnergyPerformanceData : DTDFVocab:Data [
    base:desc "Historical and real-time energy consumption data from building systems for optimization and predictive analytics."
    DTDFVocab:fromData EnergyConsumptionDataTransmitted
    DTDFVocab:inputTo EclipseBasyxEnabler, ModelDrivenEngineeringEnabler
]

instance BuildingControlSystemModel : DTDFVocab:Model [
    base:desc "Behavioral model representing Building Control System components (HVAC, lighting, occupancy sensors) with semantic foundations for digital twin integration."
    DTDFVocab:inputTo ModelDrivenEngineeringEnabler, ImpromptuFrameworkEnabler
]

// C11: Enablers
instance EclipseBasyxEnabler : DTDFVocab:Enabler [
    base:desc "Modular and extensible Industry 4.0 platform providing components for data acquisition, processing, and interoperability. Supports IoT and edge computing for digital twin implementations."
    DTDFVocab:enables IndoorEnvironmentMonitoringService, EnergyOptimizationService, PredictiveMaintenanceService, BuildingControlService, DigitalTwinVisualizationService
]

instance ItwinJsEnabler : DTDFVocab:Enabler [
    base:desc "JavaScript library for developing infrastructure digital twin applications with 3D visualization and collaborative workflows."
    DTDFVocab:enables DigitalTwinVisualizationService
]

instance ModelDrivenEngineeringEnabler : DTDFVocab:Enabler [
    base:desc "Development paradigm using models as primary artifacts for abstraction, automation, and consistency in digital twin implementations."
    DTDFVocab:enables IndoorEnvironmentMonitoringService, EnergyOptimizationService, PredictiveMaintenanceService, BuildingControlService, ResearchValidationService
]

instance ImpromptuFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Framework combining model-driven engineering with prompt engineering for automated AI/ML prompt generation in digital twins."
    DTDFVocab:enables PredictiveMaintenanceService, EnergyOptimizationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Software for executing predictive models and simulations to validate digital twin behaviors under different scenarios."
    DTDFVocab:enables PredictiveMaintenanceService, EnergyOptimizationService, ResearchValidationService
]

instance TimeSeriesDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Database infrastructure for storing real-time and historical sensor data with support for large-scale data processing and analytics."
    DTDFVocab:enables IndoorEnvironmentMonitoringService, EnergyOptimizationService, PredictiveMaintenanceService
]

// C6: Services
instance IndoorEnvironmentMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of indoor environmental parameters (temperature, humidity, air quality, occupancy) for analysis and decision-making."
    DTDFVocab:provides IndoorEnvironmentInsight, EnvironmentalAlertAction
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of HVAC, lighting, and energy systems based on real-time data and predictive models to reduce energy consumption while maintaining occupant comfort."
    DTDFVocab:provides EnergyEfficiencyInsight, EnergyControlAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive analytics for forecasting indoor conditions and potential system failures to support proactive maintenance and planning."
    DTDFVocab:provides SystemFailurePredictionInsight, MaintenanceAlertAction
]

instance BuildingControlService : DTDFVocab:Service [
    base:desc "Automated control of building systems (HVAC, lighting) based on digital twin insights for closed-loop operations."
    DTDFVocab:provides SystemStateInsight, AutomatedControlAction
]

instance DigitalTwinVisualizationService : DTDFVocab:Service [
    base:desc "Interactive dashboards and 3D models for visualizing digital twin data, system states, and performance metrics."
    DTDFVocab:provides VisualizationInsight
]

instance ResearchValidationService : DTDFVocab:Service [
    base:desc "Framework for developing and validating digital twin technologies in controlled environments (living labs)."
    DTDFVocab:provides ResearchInsight, ValidationAction
]

// C17: Insights/Actions
instance IndoorEnvironmentInsight : DTDFVocab:Insight [
    base:desc "Real-time dashboard visualization of indoor environmental metrics (temperature, humidity, air quality, occupancy) for facility management."
]

instance EnvironmentalAlertAction : DTDFVocab:Action [
    base:desc "Automated alerts for threshold breaches (e.g., high CO2 levels, extreme temperatures)."
    DTDFVocab:IsAutomatic true
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Analytics and reporting on energy consumption patterns and optimization opportunities for building systems."
]

instance EnergyControlAction : DTDFVocab:Action [
    base:desc "Automated adjustments to HVAC and lighting systems based on energy optimization algorithms."
    DTDFVocab:IsAutomatic true
]

instance SystemFailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics identifying potential system failures and maintenance requirements based on sensor data trends."
]

instance MaintenanceAlertAction : DTDFVocab:Action [
    base:desc "Proactive maintenance alerts generated by predictive models for system failures."
    DTDFVocab:IsAutomatic true
]

instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of building system states (HVAC, lighting, occupancy) for operational oversight."
]

instance AutomatedControlAction : DTDFVocab:Action [
    base:desc "Closed-loop control of building systems based on digital twin insights and real-time data."
    DTDFVocab:IsAutomatic true
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D models and heatmaps for visualizing digital twin data and performance metrics."
]

instance ResearchInsight : DTDFVocab:Insight [
    base:desc "Benchmarking and validation results from controlled digital twin experiments in living labs."
]

instance ValidationAction : DTDFVocab:Action [
    base:desc "Integration of new monitoring and control strategies into the digital twin framework for validation."
    DTDFVocab:IsAutomatic false
]

// C1: Physical Twin Systems
instance AcademicBuildingEnvironment : DTDFVocab:Environment [
    base:desc "Research-oriented academic building with LEED Platinum certification focusing on sustainability, energy efficiency, and occupant comfort."
]

instance UniversityLibraryEnvironment : DTDFVocab:Environment [
    base:desc "Library environment equipped with sensors for monitoring indoor conditions (air quality, temperature, humidity, occupancy) as part of a living lab."
]

instance HVACSystemComponent : DTDFVocab:Component [
    base:desc "Heating, ventilation, and air conditioning system regulating temperature, humidity, and air quality in academic buildings."
    base:isContainedIn AcademicBuildingEnvironment
]

instance LightingSystemComponent : DTDFVocab:Component [
    base:desc "Automated lighting control system based on occupancy and natural light levels for energy efficiency."
    base:isContainedIn AcademicBuildingEnvironment
]

instance OccupancySensorComponent : DTDFVocab:Component [
    base:desc "Real-time occupancy tracking system for space utilization optimization in academic buildings and libraries."
]

instance EnergyManagementSystemComponent : DTDFVocab:Component [
    base:desc "Centralized system for monitoring and optimizing energy consumption across building systems."
    base:isContainedIn AcademicBuildingEnvironment
]

instance AirQualitySensorComponent : DTDFVocab:Component [
    base:desc "Specialized sensor network monitoring CO2, VOCs, and particulate matter levels in library environments."
    base:isContainedIn UniversityLibraryEnvironment
]

instance TemperatureHumiditySensorComponent : DTDFVocab:Component [
    base:desc "Dedicated sensors tracking environmental comfort parameters (temperature and humidity) in library spaces."
    base:isContainedIn UniversityLibraryEnvironment
]

instance IoTGatewayComponent : DTDFVocab:Component [
    base:desc "Data aggregation and communication interface between IoT sensors and the digital twin system."
    base:isContainedIn UniversityLibraryEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The **virtual-to-physical interaction** in this DT system involves **control commands** generated by the digital twin and transmitted to physical building systems for execution. **Command types** include **adjustment signals (e.g., HVAC setpoints, lighting schedules), alerts (e.g., maintenance triggers), and automated responses (e.g., emergency shutdowns)**. The framework enforces **structured control message formats** (e.g., JSON/XML) to ensure compatibility with integrated systems. **Validation and authentication** mechanisms are implied to be embedded within the **runtime configuration management** system, ensuring only authorized commands are executed. **Feedback systems** provide **closed-loop confirmation** via **acknowledgment signals** from physical devices, which are relayed back to the DT for real-time monitoring. **Conflict resolution** is handled through **priority-based arbitration** (e.g., safety overrides preempting comfort adjustments) and **consistency checks** against operational constraints. **Command execution confirmation** is achieved via **bidirectional handshakes** between the DT and physical actuators, ensuring atomicity and traceability of control actions."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin constellation** in the AECO domain requires an **orchestration architecture** capable of integrating **static models** (e.g., BIM, CAD, or simulation models) with **runtime data** (e.g., IoT sensor feeds, operational logs, or environmental metrics) to enable **data-driven infrastructure management**. The system likely follows a **cyber-physical system (CPS) architecture**, where **component integration** is achieved through **standardized interfaces** (though not explicitly named in the document). **Resource management** would prioritize **real-time analytics** and **predictive capabilities**, with coordination mechanisms ensuring **consistent state synchronization** across the twin’s lifecycle (design, construction, operation, and refurbishment). The **system-wide coordination** would rely on **modular service-oriented patterns**, allowing dynamic adaptation to **heterogeneous data sources** and **domain-specific requirements** (e.g., energy optimization, structural health monitoring)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin (DT) lifecycle in the proposed model-driven deployment framework spans from **initial device modeling** to **runtime operation**, addressing the gap between static Building Information Modeling (BIM) representations and dynamic DT requirements. Key phases include:
  1. **Device Modeling and Configuration**: Building Control Engineers define **sensors, actuators, and controllers** within the BIM environment, enriching static BIM models with **semantic foundations** for Building Control Systems (BCS) components. This phase leverages **Model-Driven Engineering (MDE)** principles to create structured representations.
  2. **Transformation and Artifact Generation**: The framework extracts structured data from enriched BIM models and **automatically generates deployable DT artifacts** (e.g., executable models, service configurations) with **minimal manual intervention**, ensuring alignment between physical and digital representations.
  3. **Deployment and Synchronization**: The DT is deployed, enabling **real-time data exchange** between the physical building and its digital twin via continuous synchronization mechanisms. This phase supports **immersive visualization** for monitoring and control.
  4. **Runtime Operation and Extension**: The DT operates dynamically, with **modular architecture** and **standardized extension points** allowing Facility Managers to monitor system states and DT Engineers to integrate **custom services, plugins, or analytics** to evolve functionality. Governance is implicit through **role-based access** (e.g., Building Control Engineers, Facility Managers, DT Engineers) and **modular service integration** to ensure operational consistency and adaptability.
  Transition management between phases is facilitated by **MDE-driven transformations**, ensuring seamless progression from static BIM models to dynamic DT artifacts while maintaining traceability and interoperability."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin framework addresses **model fidelity** by bridging the gap between **static BIM representations** and **dynamic DT requirements**, ensuring that enriched BIM models (with BCS components) serve as a **semantic foundation** for accurate digital replicas. **Validation and verification** are implicit in the **automated generation of deployable DT artifacts**, which minimizes manual intervention and reduces human-induced errors. **Uncertainty sources** are mitigated through the framework’s **real-time synchronization** between physical and digital systems, though explicit quantification methods (e.g., statistical error modeling) are not specified. **Quality assurance** is embedded in the **modular architecture**, where standardized extension points allow for **custom services and analytics** to validate and refine model accuracy. The framework’s reliance on **MDE principles** ensures structured representations, while **interactive visualization** interfaces enable stakeholders (e.g., Facility Managers) to cross-validate physical and digital states."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for this DT system is designed to support **interoperability across heterogeneous systems** (as per NFRs) and leverages a **modular, service-oriented architecture**. The **communication protocols** are not explicitly specified but are implied to include **industry-standard protocols** such as **MQTT (for IoT telemetry), OPC UA (for industrial interoperability), and REST/GraphQL (for service integration)**. The **network topology** follows a **hybrid architecture**, combining **edge computing nodes** (for low-latency local processing) and a **central cloud/on-premise hub** (for global coordination). **Bandwidth requirements** are optimized for **real-time data streams**, with **latency constraints** enforced to ensure sub-second synchronization for critical operations (e.g., safety systems). **Reliability and redundancy** are achieved through **failover mechanisms** and **redundant data paths**, while **security protocols** include **encryption (TLS), access control (RBAC), and anomaly detection** to mitigate cyber threats. The infrastructure is designed to accommodate **scalable, plug-and-play integration** of new devices or services without disrupting existing operations."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **deployment infrastructure** for this DT system supports **multi-modal hosting platforms**, including **cloud (scalable, centralized), edge (low-latency, localized), and on-premise (secure, proprietary)** environments. **Computational requirements** are dynamically allocated based on workload demands, with **scalability mechanisms** enabling horizontal scaling (e.g., Kubernetes clusters) and vertical scaling (e.g., auto-scaling VMs) to handle peak loads. **Storage requirements** are optimized for **high-velocity data ingestion** (e.g., time-series databases for sensor data) and **long-term archival** (e.g., object storage for BIM models). The framework supports **containerized deployment models** (e.g., Docker, Kubernetes) for **modular service integration** and **runtime configuration management**, allowing adjustments without full redeployment. **Availability and reliability** are assured through **high-uptime SLAs**, **automated failover**, and **disaster recovery protocols**, ensuring continuous operation even during partial infrastructure failures. The deployment is tailored to the **AECO domain**, bridging static BIM representations with dynamic operational needs."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system in the AECO domain must support **horizontal integration** with **external systems** through **interoperability standards** to address the **fragmented nature of models and data**. While no specific protocols (e.g., IFC, CityGML, or OPC UA) are mentioned, the document implies reliance on **data exchange frameworks** to enable seamless communication between **Digital Twins and enterprise systems** (e.g., ERP, CMMS, or PLM). **Dependencies on external systems** would include **real-time data feeds** (e.g., from IoT sensors, weather APIs, or utility grids) and **legacy infrastructure models** (e.g., BIM or GIS data). Integration patterns would likely involve **hybrid architectures**, combining **cloud-based services** for scalability with **edge computing** for low-latency processing. The system may also require **federated Digital Twin constellations**, where multiple twins (e.g., for different buildings or subsystems) **collaborate** via **standardized APIs** or **event-driven architectures** to support **cross-domain optimization** (e.g., smart city initiatives)."
]