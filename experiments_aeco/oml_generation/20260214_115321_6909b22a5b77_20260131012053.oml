// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in the enriched BIM model for measuring indoor temperature"
    DTDFVocab:producedData TemperatureDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in the enriched BIM model for detecting space utilization"
    DTDFVocab:producedData OccupancyDataStream
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM geometry providing building layout and component placement"
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic attached to device definitions for actuators and controllers"
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature measurements synchronized from the physical sensor"
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy information synchronized from the physical sensor"
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

// C2: Acting components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator defined in the enriched BIM model, addressable through the DT runtime for remote control of heating, ventilation and air‑conditioning"
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator defined in the enriched BIM model, addressable through the DT runtime for remote control of building illumination"
]

instance HVACController : DTDFVocab:ActingComponent [
    base:desc "Controller logic that coordinates HVACActuator actions according to the building control engineer's specifications"
]

// C11: Enablers
instance RealTimeDataExchangeEnabler : DTDFVocab:Enabler [
    base:desc "Real‑time data exchange layer that continuously synchronizes sensor streams with the digital twin"
    DTDFVocab:enables VisualizationService, DecisionSupportService
]

instance MDEPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline that extracts enriched BIM, validates it, and generates deployable DT artifacts"
    DTDFVocab:enables SimulationService, AnalysisService, OptimizationService
]

instance ExtensionPointEnabler : DTDFVocab:Enabler [
    base:desc "Standardized extension points allowing custom analytics and plug‑in services to be added without redeploying the twin"
    DTDFVocab:enables PredictiveAnalyticsService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation capability that runs virtual models of building behavior for scenario testing"
    DTDFVocab:provides PredictiveInsight
]

instance AnalysisService : DTDFVocab:Service [
    base:desc "Analysis service that processes real‑time data for monitoring building states"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that evaluates control strategies to improve energy efficiency"
    DTDFVocab:provides OptimizationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization service that presents real‑time sensor and actuator data to facility managers"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics plug‑in that generates forecasts and risk assessments from historical data streams"
    DTDFVocab:provides PredictiveInsight
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Decision‑support service that enables operators to issue control commands based on up‑to‑date insights"
    DTDFVocab:provides IssueControlCommandAction, DecisionSupportInsight
]

// C17: Insights
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight providing up‑to‑date status of temperature and occupancy for facility managers"
]

instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Insight delivering forecasts of building performance derived from predictive analytics"
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal actuator settings to reduce energy consumption"
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Insight guiding operators in choosing appropriate control actions"
]

// C17: Actions
instance IssueControlCommandAction : DTDFVocab:Action [
    base:desc "Action allowing facility managers to remotely invoke actuator control logic via the DT interface"
    DTDFVocab:IsAutomatic false
]

// Environment (optional for completeness)
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, OccupancySensor, HVACActuator, LightingActuator, HVACController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Virtual‑to‑physical interaction is supported by the DT Framework’s bidirectional data exchange, allowing Facility Managers or DT Engineers to issue control actions to the physical building in real time. The document provides no details on command types, message formats, validation, authentication, feedback loops, conflict resolution, or execution confirmation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange that continuously synchronises the physical building with its digital counterpart; synchronization occurs as soon as sensor or device updates are available, implying an always‑on, low‑latency (sub‑second) data flow, though exact frequency or latency values are not specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture underpins the DT system. Standardised extension points allow custom services and analytics to be plugged in, while runtime configuration management enables on‑the‑fly adjustments without redeployment. The central DT Framework acts as the orchestrator, handling resource allocation, coordinating the flow from enriched BIM models to operational twins, and managing the lifecycle of data streams and services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a complete DT lifecycle starting with device modeling directly in the BIM environment (definition of sensors, actuators, controllers), followed by model‑driven engineering (MDE) transformations that extract structured representations and automatically generate deployable DT artifacts (services, plugins). Next, the generated artifacts are deployed to the runtime environment where real‑time data exchange synchronises the physical building and its digital counterpart. During operation, facility managers interact through immersive visualization, while the modular architecture’s standardized extension points allow post‑deployment evolution (addition of custom services). Transition between stages is automated by the MDE pipeline with minimal manual intervention, and governance is enforced through role‑based responsibilities (building control engineer, facility manager, DT engineer) defined in the deployment framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The framework’s functional requirements call for continuous synchronization between the physical building and its digital counterpart, implying an ongoing validation of data freshness. Model generation follows MDE principles to ensure structural correctness, and the unified semantic foundation is intended to provide consistency across geometric and behavioral aspects. However, the documents do not describe explicit fidelity metrics, validation or verification procedures, uncertainty quantification, or quality‑assurance processes for the models and data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on a modular architecture with standardized extension points and a central DT Framework hub that mediates communication across heterogeneous systems, addressing interoperability and scalability. No explicit network protocols, topology, bandwidth, latency, redundancy, or security protocols are described in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed as a non‑functional requirement, targeting seamless integration with heterogeneous external systems. The framework supports bidirectional real‑time data exchange and leverages generic interoperability standards (unspecified) to connect BIM tools, building devices, and enterprise applications, though specific protocols or APIs are not enumerated in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The proposed framework explicitly addresses the lack of standardized integration frameworks by defining standardized extension points for plug‑ins and services. It builds on BIM, which the document notes is becoming the de‑facto standard solution in the construction industry, thereby aligning the twin’s data model with the widely‑adopted BIM standard. Although no specific industry standards (e.g., ISO 19650, IFC) or certification schemes are cited, the architecture is designed to be interoperable through these standardized BIM‑based data schemas and the uniform extension mechanism."
]