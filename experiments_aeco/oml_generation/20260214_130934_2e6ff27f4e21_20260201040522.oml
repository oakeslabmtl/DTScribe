// Acting Component
instance LEDDriverActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture (LED driver) exposed as a DittoDevice entity, controlled by the UnrealTwinController via DittoController."
]

// Sensing Components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor modeled as a BIM component, reports on/off status, luminance (lux) and color temperature (K)."
    DTDFVocab:producedData LightDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled as a BIM component, reports room temperature in degrees Celsius."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor modeled as a BIM component, reports relative humidity."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled as a BIM component, reports presence count."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// Data Transmitted
instance LightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// Data Instances
instance LightMeasuredData : DTDFVocab:Data [
    base:desc "JSON payload of light measurement, including on/off, luminance (lux) and color temperature (K), updated at 1 s heartbeat."
    DTDFVocab:fromData LightDataTransmitted
    DTDFVocab:inputTo DittoStorage
]

instance TemperatureMeasuredData : DTDFVocab:Data [
    base:desc "JSON payload of temperature measurement in °C, updated at 1 s heartbeat."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DittoStorage
]

instance HumidityMeasuredData : DTDFVocab:Data [
    base:desc "JSON payload of humidity measurement (%RH), updated at 1 s heartbeat."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo DittoStorage
]

instance OccupancyMeasuredData : DTDFVocab:Data [
    base:desc "JSON payload of occupancy count, updated at 1 s heartbeat."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo DittoStorage
]

// Enablers
instance DittoStorage : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto entity storing twin state of each device, performs validation per policy, and triggers services."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveMaintenanceService, EnergyAnalyticsService, HVACControlService, LightingControlService
]

instance DittoBridge : DTDFVocab:Enabler [
    base:desc "Bridge that consumes twin state from Ditto and renders it in UnrealEngine via UnrealTwinController."
    DTDFVocab:enables ImmersiveVisualizationService
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing continuous monitoring of sensor streams, delivering live updates via Ditto events."
    DTDFVocab:provides LiveSensorDataInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Service providing predictive analytics for maintenance based on sensor data."
    DTDFVocab:provides MaintenanceRecommendationInsight, MaintenanceRecommendationAction
]

instance EnergyAnalyticsService : DTDFVocab:Service [
    base:desc "Service providing predictive analytics to reduce energy consumption using historical sensor data."
    DTDFVocab:provides EnergyConsumptionOptimizationInsight
]

instance HVACControlService : DTDFVocab:Service [
    base:desc "Service that controls HVAC system by issuing commands to Ditto."
    DTDFVocab:provides HVACStatusInsight, HVACAdjustmentAction
]

instance LightingControlService : DTDFVocab:Service [
    base:desc "Service that issues control commands to lighting fixtures (LED drivers) through Ditto."
    DTDFVocab:provides LightingControlAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Service that consumes twin data from DittoBridge and renders immersive dashboards in UE5."
    DTDFVocab:provides VisualizationInsight
]

// Insights
instance LiveSensorDataInsight : DTDFVocab:Insight [
    base:desc "Insight representing real‑time snapshot of sensor streams, updated every second via Ditto events."
]

instance MaintenanceRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending maintenance actions based on predictive analytics of sensor streams."
]

instance EnergyConsumptionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing recommendations to reduce energy consumption using historical sensor data."
]

instance HVACStatusInsight : DTDFVocab:Insight [
    base:desc "Insight showing real‑time HVAC system status and performance metrics."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight representing visual rendering of twin state in the 3D environment."
]

// Actions
instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Action to trigger maintenance workflow based on predictions."
    DTDFVocab:IsAutomatic true
]

instance HVACAdjustmentAction : DTDFVocab:Action [
    base:desc "Action to adjust HVAC setpoints or schedules to optimize performance."
    DTDFVocab:IsAutomatic true
]

instance LightingControlAction : DTDFVocab:Action [
    base:desc "Action to modify lighting power state, brightness or color temperature of LED drivers."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized framework hub orchestrating the Digital Twin lifecycle: an MDE pipeline extracts structured representations from enriched BIM models, automatically generating deployable DT artifacts. The hub exposes modular, standardized extension points for custom services, analytics, and visualisations, and manages bidirectional, real‑time data exchange between physical sensors/actuators and the virtual model. Runtime configuration management enables adjustment of control logic without full redeployment. The architecture follows a modular, service‑oriented pattern that decouples device modelling, data ingestion, control logic, and visualization while ensuring coordinated synchronization across the building life cycle."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design and device modeling occurs in the enriched BIM environment where sensors, actuators and controllers are defined as semantically rich elements (Table I role). The model‑driven framework extracts structured representations via Model‑Driven Engineering (MDE) techniques, automatically generating deployable digital‑twin artifacts with minimal manual intervention (R2 C2). Deployment is fully automated and reproducible; transition from design to runtime is handled by the same artifacts, which expose real‑time data exchange interfaces. At runtime, continuous synchronization with the physical building is achieved using Eclipse Hono (MQTT/HTTP gateway) and Eclipse Ditto, enabling live bidirectional data flow (R3 C3). Governance of the life‑cycle is facilitated by a modular architecture with standardized extension points, allowing versioned plug‑ins and a scalable, service‑oriented evolution path (R4 C4)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained through a modular validation pipeline. The BIM‑based models are first model‑checked (5.53 s) and parsed (8.7 s) before initialization (0.3 s). Semantic validation is provided by Eclipse Ditto’s policy engine, which guarantees that sensor values stay within defined ranges and that actuator commands meet safety constraints. Fault tolerance is achieved by Eclipse Hono’s at‑least‑once delivery and Ditto’s persistent event store. The bidirectional entanglement quality is quantified by the Overall Digital Twin Entanglement (ODTE) metric, achieving scores of 0.997 (timeliness), 1.0 (reliability), and 1.0 (availability) over a 12‑minute window, yielding a total ODTE of 0.997. The 1‑s heartbeat ensures timely updates. These metrics provide quantitative assurance of model‑data fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT’s technical connectivity is based on Eclipse Hono for secure, standardized device communication and Eclipse Ditto for twin management. Hono provides a broker‑centric architecture that supports industry protocols such as MQTT, HTTP, and AMQP, enabling devices to publish telemetry and receive control commands. Ditto exposes a REST/JSON API and event streams for twin state and command handling. The combination delivers a scalable, low‑latency communication path implemented on edge gateways, cloud, or on‑premise hosts, with authentication and access control supplied by Hono and Ditto to ensure secure data transmission."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is realised through seamless data exchange between the BIM authoring environment (e.g., Revit), field‑level sensor networks, and analytical AI services. The framework offers standardized extension points that support plug‑in adapters for legacy building control systems and enterprise platforms. Custom services can be integrated via the modular architecture, allowing the Digital Twin to consume sensor telemetry, device configuration, and operational metrics from heterogeneous systems and expose its own state for downstream consumption."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution adheres to AECO industry standards by utilizing BIM as the foundational modelling paradigm, including the use of Industry Foundation Classes (IFC) to capture object‑based 3‑D semantics. Real‑time integration relies on Eclipse Hono (which implements MQTT or HTTP gateways conforming to OMA ONE‑M‑M and OGC protocols) and Eclipse Ditto, both adhering to open‑standards for device‑to‑cloud data interchange. The framework’s modular architecture and defined extension points enforce interoperability, enabling the integration of third‑party services and analytics while maintaining compliance with standard data schemas and communication protocols common in the AECO domain."
]