// C2: Acting Component
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control devices modeled in the BIM and addressable by the Digital Twin for actuation."
]

// C3: Physical sensing components
instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensors (e.g., temperature, humidity, CO₂) encoded in the BIM model and providing runtime data to the Digital Twin."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensors encoded in the BIM model and providing runtime data to the Digital Twin."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical-to-virtual interaction – Data transmitted
instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C5: Data generated from sensors
instance LiveEnvironmentalData : DTDFVocab:Data [
    base:desc "Live environmental data stream derived from EnvironmentalSensor measurements."
    DTDFVocab:fromData EnvironmentalDataTransmitted
    DTDFVocab:inputTo EclipseHonoIngestion, EclipseDittoStateManagement
]

instance LiveOccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy data stream derived from OccupancySensor measurements."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoIngestion, EclipseDittoStateManagement
]

// C11: Enablers
instance EclipseHonoIngestion : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for MQTT‑style ingestion of sensor measurements."
    DTDFVocab:enables RealTimeMonitoringDashboard
]

instance EclipseDittoStateManagement : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for digital twin state management and bidirectional synchronization."
    DTDFVocab:enables Interactive3DVisualization
]

instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline that orchestrates model enrichment, validation and artifact generation."
    DTDFVocab:enables PredictiveAnalyticsEnergyComfort, LightingControlOptimizationRL
]

instance BIMSemanticBackbone : DTDFVocab:Enabler [
    base:desc "BIM used as the semantic backbone linking physical components to their virtual representations."
    DTDFVocab:enables WhatIfScenarioSimulation
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3‑D interactive visualization of the twin."
    DTDFVocab:enables Interactive3DVisualization
]

instance AutomatedModelToTextTransformation : DTDFVocab:Enabler [
    base:desc "Automated model‑to‑text transformations generating configuration files and device twins."
    DTDFVocab:enables PredictiveAnalyticsEnergyComfort
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards presenting live status of building systems."
    DTDFVocab:provides LiveStatusViewInsight
]

instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "3‑D interactive visualization in Unreal Engine 5."
    DTDFVocab:provides ComfortAssessmentInsight
]

instance PredictiveAnalyticsEnergyComfort : DTDFVocab:Service [
    base:desc "Predictive analytics for energy consumption and occupant comfort."
    DTDFVocab:provides EnergyConsumptionAnalyticsInsight, ComfortAssessmentInsight
]

instance LightingControlOptimizationRL : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based optimization of lighting control policies."
    DTDFVocab:provides AdaptiveLightingRecommendationInsight, AdaptiveLightingSetpointAdjustmentAction
]

instance WhatIfScenarioSimulation : DTDFVocab:Service [
    base:desc "Simulation of what‑if scenarios for facility‑management planning."
    DTDFVocab:provides AdaptiveLightingRecommendationInsight
]

// C17: Insights
instance LiveStatusViewInsight : DTDFVocab:Insight [
    base:desc "Live status view of building systems for facility managers."
]

instance EnergyConsumptionAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Analytics of energy consumption patterns derived from sensor data."
]

instance ComfortAssessmentInsight : DTDFVocab:Insight [
    base:desc "Assessment of occupant comfort based on environmental and occupancy data."
]

instance AdaptiveLightingRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendations such as adaptive lighting set‑points."
]

// C17: Action
instance AdaptiveLightingSetpointAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting set‑points based on optimization recommendations."
    DTDFVocab:IsAutomatic true
]

// C10: Model
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with runtime semantics, device metadata and control logic."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline, BIMSemanticBackbone
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Transmission of control signals from the digital twin back to physical actuators via the same Hono/Ditto stack, allowing the twin to command lighting, HVAC or other building‑control devices in near real‑time."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real‑time synchronization; sensor streams are ingested and processed continuously, enabling the twin to reflect physical state changes with latency suitable for live monitoring and control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture comprising a central DT framework, standardized extension points, Hono/Ditto middleware for data exchange, and Unreal Engine visualization; components can be added or replaced without re‑architecting the whole system."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the full building lifecycle – from design (ideal BIM model) through construction (as‑built model) to operation and refurbishment, supporting both static semantic information and dynamic runtime data."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Entanglement quality is measured with the Overall Digital Twin Entanglement (ODTE) metric; the approach addresses semantic drift by continuously synchronizing BIM‑derived semantics with live data, ensuring model fidelity over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between physical assets and the Digital Twin is mediated by Eclipse Hono and Eclipse Ditto; specific network protocols are not detailed in the document."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach relies on BIM as the underlying industry standard and defines standardized extension points to ensure interoperable integration of services and components."
]