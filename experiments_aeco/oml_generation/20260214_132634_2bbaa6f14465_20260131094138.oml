//=== C3: Physical sensing components ===
instance AmbientLightSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient light sensor embedded in the building to monitor light levels."
    DTDFVocab:producedData AmbientLightDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the building to detect presence."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the building to monitor ambient temperature."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor embedded in the building to measure indoor air quality."
    DTDFVocab:producedData CO2DataTransmitted
]

//=== C4: Physical-to-virtual interaction ===
instance AmbientLightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientLightSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

//=== C10: Models/Data ===
instance AmbientLightTelemetry : DTDFVocab:Data [
    base:desc "Real-time telemetry data of ambient light levels used for monitoring and optimization."
    DTDFVocab:fromData AmbientLightDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance OccupancyTelemetry : DTDFVocab:Data [
    base:desc "Real-time telemetry data of occupancy used for monitoring and scheduling."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance TemperatureTelemetry : DTDFVocab:Data [
    base:desc "Real-time telemetry data of temperature used for monitoring and predictive analytics."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance CO2Telemetry : DTDFVocab:Data [
    base:desc "Real-time telemetry data of CO₂ concentration used for air quality monitoring."
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance DittoTwinConfigs : DTDFVocab:Data [
    base:desc "Ditto twin configuration files generated from BIM model, representing device twins."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance JSONSchemas : DTDFVocab:Data [
    base:desc "JSON schemas generated via Model-Driven Engineering, used for configuring device twins."
    DTDFVocab:inputTo EGLTransformationEnabler
]

instance NoSQLRepository : DTDFVocab:Data [
    base:desc "NoSQL repository storing simulation models and reinforcement-learning policy models."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance IFCBIMModel : DTDFVocab:Model [
    base:desc "IFC-based BIM model enriched with control semantics of Master Living Lab building."
    DTDFVocab:inputTo EGLTransformationEnabler
]

instance SimulationModelLightDistribution : DTDFVocab:Model [
    base:desc "Light distribution simulation model for rendering lighting scenarios in Unreal Engine 5."
    DTDFVocab:inputTo EGLTransformationEnabler
]

instance SimulationModelHVACAirflow : DTDFVocab:Model [
    base:desc "HVAC airflow simulation model used for environmental condition simulation."
    DTDFVocab:inputTo EGLTransformationEnabler
]

instance RLPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement learning policy model for control policy synthesis in BOREALIS."
    DTDFVocab:inputTo EGLTransformationEnabler
]

//=== C2: Acting Components ===
instance LEDDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "LED dimmer driver actuator for lighting fixtures, enabling dimming control."
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve actuator controlling airflow regulation."
]

instance FanSpeedActuator : DTDFVocab:ActingComponent [
    base:desc "Fan speed actuator controlling HVAC fan speed."
]

//=== C11: Enablers ===
instance RevitEnabler : DTDFVocab:Enabler [
    base:desc "Revit BIM authoring tool used to create and enrich building models."
    DTDFVocab:enables EnvironmentalSimulationService
]

instance EGLTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse GL model‑driven transformation pipeline that converts BIM models into runtime artifacts."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, LightingHVacsOptimizationService, ControlPolicySynthesisService, VisualAnalyticsUE5Service
]

instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT messaging platform used to transmit sensor telemetry over TLS."
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto device registry and twin management platform for device lifecycle."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, LightingHVacsOptimizationService, ControlPolicySynthesisService, VisualAnalyticsUE5Service
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 rendering environment for visual analytics and simulations."
    DTDFVocab:enables VisualAnalyticsUE5Service
]

//=== C6: Services ===
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real‑time monitoring of building telemetry, such as ambient light, occupancy, temperature and CO₂."
    DTDFVocab:provides RealTimeTelemetryInsight
]

instance EnvironmentalSimulationService : DTDFVocab:Service [
    base:desc "Service delivering simulation of environmental conditions (light distribution, HVAC airflow)."
    DTDFVocab:provides SimulationVisualizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service offering predictive analytics for energy consumption based on sensor data."
    DTDFVocab:provides EnergyConsumptionForecastInsight
]

instance LightingHVacsOptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing lighting and HVAC schedules based on predictive models."
    DTDFVocab:provides LightingHVacsOptimizationRecommendationAction
]

instance VisualAnalyticsUE5Service : DTDFVocab:Service [
    base:desc "Service rendering visual analytics in Unreal Engine 5."
    DTDFVocab:provides VisualAnalyticsInsight
]

instance ControlPolicySynthesisService : DTDFVocab:Service [
    base:desc "Service synthesizing data‑driven control policies, e.g., reinforcement‑learning policies in BOREALIS."
    DTDFVocab:provides ReinforcementLearningPolicyDeploymentAction
]

//=== C17: Insights/Actions ===
instance RealTimeTelemetryInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing real‑time telemetry data for facility managers."
]

instance SimulationVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight presenting simulation results visualized in UE5."
]

instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Insight forecasting future energy consumption for planning."
]

instance VisualAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Insight providing visual analytics derived from UE5 rendering."
]

instance LightingHVacsOptimizationRecommendationAction : DTDFVocab:Action [
    base:desc "Action offering scheduling recommendations for lights and HVAC to improve efficiency."
    DTDFVocab:IsAutomatic false
]

instance ReinforcementLearningPolicyDeploymentAction : DTDFVocab:Action [
    base:desc "Action deploying updated reinforcement‑learning control policies."
    DTDFVocab:IsAutomatic true
]

//=== Environment ===
instance MasterLivingLabBuilding : DTDFVocab:Environment [
    base:contains AmbientLightSensor, OccupancySensor, TemperatureSensor, CO2Sensor,
                  LEDDimmerActuator, HVACValveActuator, FanSpeedActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "After processing and optimization, the DT publishes control messages (e.g., dimming level, HVAC setpoint) to MQTT topics via Hono/Ditto, which are consumed by the building automation system to actuate the physical devices."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All sensor observations are streamed continuously with sub‑second granularity, and control cycles are executed in real‑time (latency < 200 ms). The DT processes updates and publishes commands at a continuous rate, maintaining near‑instantaneous synchronization between PT and DT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is organized into three layers: (1) the BIM layer (design and semantic layer), (2) the middleware layer (Eclipse Hono/Ditto, handling bidirectional data flow), and (3) the application layer (Unreal Engine 5 visual interface and custom analytics services)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle encompasses the design phase (BIM modeling), construction and commissioning (sensor/actuator deployment), operation (real‑time monitoring, control, predictive analytics), and refurbishment phases where the twin is updated to reflect changes to physical infrastructure."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by validating the BIM against industry checklists, synchronizing sensor data with twin state via consistency checks, and quantifying entanglement using the Overall Digital Twin Entanglement (ODTE) metric. Uncertainty and errors are mitigated through regular data quality checks and outlier detection in sensor streams."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical-to-virtual data exchange uses MQTT 5 over TLS through Eclipse Hono, which routes messages to Ditto twins. Virtual-to-physical commands follow the same MQTT path. The system architecture supports a broker‑oriented publish/subscribe model with secure topic routing and tenant isolation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components are deployed in a containerized Kubernetes cluster on a private cloud. Hono and Ditto services run as stateful sets, while Unreal Engine instances are hosted on a dedicated render node with GPU acceleration. The deployment pipeline uses Helm charts for reproducible updates."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT interconnects with external Building Information Exchange (BIE) systems using Hono connectors, exposes APIs compliant with the Open Connectivity Foundation’s IoTDA specification, and shares data with stakeholder portals and BIM coordination tools."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution adheres to IFC for BIM data exchange, MQTT 5 for messaging, Eclipse Hono’s open‑source architecture, and Ditto’s conformance to the OCF IoTDA standard. Modeling conventions are based on MDE best practices and industry guidelines."
]