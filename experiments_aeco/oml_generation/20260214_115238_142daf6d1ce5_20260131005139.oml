// C3: Physical sensing components
instance IndoorEnvironmentSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor represented as a BIM entity that captures indoor environmental conditions and streams readings continuously to the DT."
    DTDFVocab:producedData IndoorEnvDataTx
]

instance PostOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor represented as a BIM entity that captures post‑occupancy data and streams readings continuously to the DT."
    DTDFVocab:producedData PostOccupancyDataTx
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance IndoorEnvDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndoorEnvironmentSensor
]

instance PostOccupancyDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PostOccupancySensor
]

// C10: Data
instance IndoorEnvData : DTDFVocab:Data [
    base:desc "Continuous stream of indoor environmental measurements (temperature, humidity, CO₂, etc.)."
    DTDFVocab:fromData IndoorEnvDataTx
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

instance PostOccupancyData : DTDFVocab:Data [
    base:desc "Continuous stream of post‑occupancy measurements (occupancy count, usage patterns, etc.)."
    DTDFVocab:fromData PostOccupancyDataTx
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

// C2: Acting components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "BIM‑modeled actuator that can be addressed through the real‑time data‑exchange channel to control lighting (dimmers, switches)."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "BIM‑modeled actuator that can be addressed through the real‑time data‑exchange channel to control HVAC services."
]

// C10: Models/Data
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Geometric backbone derived from the enriched BIM repository, providing spatial representation of the building."
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model expressed as control‑logic scripts attached to sensors and actuators."
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

instance PredictiveAnalyticsModel : DTDFVocab:Model [
    base:desc "Analytical model generated downstream for predictive analytics (e.g., equipment degradation, occupancy‑driven lighting demand)."
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

// C11: Enablers
instance RealTimeDataExchangeEnabler : DTDFVocab:Enabler [
    base:desc "Standardized, bidirectional real‑time data‑exchange channel that synchronizes physical sensors/actuators with their digital twins and enables custom services via extension points."
    DTDFVocab:enables RealTimeMonitoringService,
                      EnergySimulationService,
                      LightingOptimizationService,
                      PredictiveAnalyticsService,
                      ClosedLoopControlService,
                      ImmersiveVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of lighting and environmental parameters delivered to Facility Managers."
    DTDFVocab:provides KPIInsight
]

instance EnergySimulationService : DTDFVocab:Service [
    base:desc "High‑fidelity simulation of energy usage and illumination scenarios."
    DTDFVocab:provides EnergyUsageForecastInsight
]

instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of lighting schedules and set‑points to minimise energy consumption."
    DTDFVocab:provides EnergySavingInsight,
                     AdjustLightingSetpointAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics that forecast equipment degradation and occupancy‑driven lighting demand."
    DTDFVocab:provides AnomalyDetectionInsight,
                     EquipmentDegradationInsight,
                     PredictiveMaintenanceAction
]

instance ClosedLoopControlService : DTDFVocab:Service [
    base:desc "Closed‑loop control that actuates dimmers and switches based on simulation outcomes."
    DTDFVocab:provides ControlFeedbackInsight,
                     ActuateDimmerAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D visualisation of the building state, enabling operators to interact directly with the twin."
    DTDFVocab:provides VisualContextInsight,
                     InteractWithDTAction
]

// C17: Insights
instance KPIInsight : DTDFVocab:Insight [
    base:desc "Continuous insight into key performance indicators (KPI) for lighting and environmental conditions."
]

instance EnergyUsageForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of future energy usage derived from simulation results."
]

instance EnergySavingInsight : DTDFVocab:Insight [
    base:desc "Identification of lighting set‑point adjustments that reduce energy consumption."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of abnormal patterns in sensor streams indicating potential faults."
]

instance EquipmentDegradationInsight : DTDFVocab:Insight [
    base:desc "Prediction of equipment degradation timelines based on historical and real‑time data."
]

instance ControlFeedbackInsight : DTDFVocab:Insight [
    base:desc "Feedback on the effectiveness of closed‑loop control actions."
]

instance VisualContextInsight : DTDFVocab:Insight [
    base:desc "Contextual visual cues presented in the immersive 3D environment to aid decision‑making."
]

// C17: Actions
instance AdjustLightingSetpointAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting set‑points to achieve optimized energy usage."
    DTDFVocab:IsAutomatic true
]

instance PredictiveMaintenanceAction : DTDFVocab:Action [
    base:desc "Scheduling of maintenance activities based on predicted equipment degradation."
    DTDFVocab:IsAutomatic false
]

instance ActuateDimmerAction : DTDFVocab:Action [
    base:desc "Remote command to dimmer actuators for real‑time lighting control."
    DTDFVocab:IsAutomatic true
]

instance InteractWithDTAction : DTDFVocab:Action [
    base:desc "Operator interaction within the immersive visualisation to trigger control commands."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication is supported by the DT Framework, which acts as a central hub. Facility Managers and DT Engineers can issue control signals from the Digital Twin to physical devices for real‑time monitoring and control. The document mentions runtime interfaces and control signals but provides no detail on command types, message formats, validation, authentication, feedback loops, conflict resolution, or execution confirmation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange that keeps the physical building and its digital counterpart continuously synchronized. Synchronization is performed continuously (i.e., as soon as sensor updates are available) and supports near‑zero latency required for live monitoring and control. The temporal granularity is tied to the frequency of incoming building‑automation data streams, and runtime configuration management allows these frequencies to be adjusted without redeploying the twin."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, service‑oriented architecture with standardized extension points that enable integration of custom services and analytics. Runtime configuration management permits on‑the‑fly adaptation of services. The DT Engine orchestrates bidirectional data exchange between enriched BIM models and the operational twin, orchestrating the flow of data through defined roles (Building Control Engineer, Facility Manager, DT Engineer) and acting as the central coordination component."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a four‑stage lifecycle for a building Digital Twin: (1) Device Modeling – Building Control Engineers enrich BIM models with explicit sensor, actuator and controller definitions, creating a unified semantic base; (2) Model‑Driven Transformation – Model‑Driven Engineering (MDE) tools extract structured representations from the enriched BIM and automatically generate deployable DT artefacts; (3) Deployment & Activation – The generated artefacts are instantiated in the runtime environment, establishing real‑time data exchange links that keep the physical devices synchronised with their digital counterparts; (4) Operational Use & Evolution – Facility Managers interact with the Twin via immersive visualisation for monitoring and control, while the modular architecture’s standardized extension points allow DT Engineers to integrate custom services and analytics, supporting ongoing evolution of the Twin. Transition between stages is managed automatically by the MDE pipeline, and governance is implicit in the role‑based responsibilities (Control Engineer, Facility Manager, DT Engineer) defined in the model‑driven deployment framework."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT Framework is described as having a modular architecture with standardized extension points and a central hub that mediates bidirectional data exchange between physical assets and the digital twin. Non‑functional requirements such as interoperability and scalability are highlighted, yet the document does not disclose specific network protocols, topology, bandwidth or latency targets, redundancy mechanisms, or security protocols for the underlying communication infrastructure."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed by non‑functional requirements targeting heterogeneous systems. The framework exposes standardized interfaces for bidirectional data exchange, allowing BIM tools, building‑automation devices and external analytics services to connect via a plug‑in pattern using the defined extension points. Specific data exchange protocols are not enumerated, but the architecture is designed for integration with external systems through these standardized interfaces."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is built on the Building Information Modeling (BIM) standard as the core semantic foundation. All device definitions, control logic and generated artefacts conform to BIM‑based schemas, ensuring compatibility with existing BIM tools. The framework’s modular architecture defines standardized extension points that follow a common interface contract, enabling interoperability of custom services and analytics across different implementations."
]