// Environment grouping the building’s digital twin components
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, HumiditySensor, LightLevelSensor, CO2Sensor, OccupancySensor, LightActuator, HVACActuator
]

// Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in BIM, measuring °C located in the HVAC bay, transmitting via Hono MQTT broker"
    DTDFVocab:producedData TempSensorDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor defined in BIM, measuring %RH at corridor entrance, transmitting via Hono"
    DTDFVocab:producedData HumiditySensorDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor, measuring lux in office space, transmitted through Hono"
    DTDFVocab:producedData LightLevelSensorDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ concentration sensor, reporting ppm from the conference room, via Hono MQTT"
    DTDFVocab:producedData CO2SensorDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "People-counting sensor, installed at lobby entrance, data forwarded by Hono"
    DTDFVocab:producedData OccupancySensorDataTransmitted
]

// Acting Components
instance LightActuator : DTDFVocab:ActingComponent [
    base:desc "LightTwinComponent mapping a UE5 light to a physical fixture, controllable on/off, brightness, colour‑temperature (Kelvin)"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVACTwinComponent connecting HVAC system controls, configurable set‑point, flow rate and safety limits enforced by Ditto policy"
]

// Data Transmitted instances
instance TempSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumiditySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance LightLevelSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance CO2SensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance OccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// Data instances stored in Ditto
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature reading event from Hono MQTT broker, validated against policy bounds"
    DTDFVocab:inputTo DittoEnabler
    DTDFVocab:fromData TempSensorDataTransmitted
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity reading event, validated and persisted in Ditto"
    DTDFVocab:inputTo DittoEnabler
    DTDFVocab:fromData HumiditySensorDataTransmitted
]

instance LightLevelData : DTDFVocab:Data [
    base:desc "Illuminance data, validated and stored by Ditto"
    DTDFVocab:inputTo DittoEnabler
    DTDFVocab:fromData LightLevelSensorDataTransmitted
]

instance CO2Data : DTDFVocab:Data [
    base:desc "CO₂ concentration event, validated, persisted via Ditto"
    DTDFVocab:inputTo DittoEnabler
    DTDFVocab:fromData CO2SensorDataTransmitted
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy event, policy‑checked and stored in Ditto"
    DTDFVocab:inputTo DittoEnabler
    DTDFVocab:fromData OccupancySensorDataTransmitted
]

// Enabler exposing data and enabling services
instance DittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto service that stores device states, validates sensor values and actuator commands via policy enforcement"
    DTDFVocab:enables MonitoringService, VisualizationService, PredictiveAnalyticsService, ControlService, AnalyticsPluginService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous data ingestion and diagnostics of building states"
    DTDFVocab:provides TemperatureInsight, HumidityInsight, LightLevelInsight, CO2Insight, OccupancyInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Real‑time immersive visualization of structural and operational metrics via UE5"
    DTDFVocab:provides VisualizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Generates alerts and optimization suggestions for HVAC, lighting, and energy usage via predictive models"
    DTDFVocab:provides PredictiveInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Allows Facility Managers to trigger actuators and adjust controller parameters directly from the twin"
    DTDFVocab:provides LightActuationAction, HVACActuationAction
]

instance AnalyticsPluginService : DTDFVocab:Service [
    base:desc "Extensible analytics plugin point for DT Engineers to develop domain‑specific analytic modules"
    DTDFVocab:provides CustomAnalyticsInsight
]

// Insights
instance TemperatureInsight : DTDFVocab:Insight [
    base:desc "Live temperature monitoring; highlights deviations from set‑points"
]

instance HumidityInsight : DTDFVocab:Insight [
    base:desc "Real‑time humidity trend analysis; triggers alerts if exceeding thresholds"
]

instance LightLevelInsight : DTDFVocab:Insight [
    base:desc "Illuminance status; supports adaptive lighting control"
]

instance CO2Insight : DTDFVocab:Insight [
    base:desc "CO₂ concentration monitoring for indoor air quality management"
]

instance OccupancyInsight : DTDFVocab:Insight [
    base:desc "Occupancy status used for dynamic HVAC scheduling"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive rendering of sensor data within UE5 scene, enabling operator interaction"
]

instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Predictive alerts and optimization suggestions for building systems"
]

instance CustomAnalyticsInsight : DTDFVocab:Insight [
    base:desc "KPI dashboards and alerts generated by custom analytics plugins"
]

// Actions
instance LightActuationAction : DTDFVocab:Action [
    base:desc "Command to LightActuator controlling on/off, brightness, and colour‑temperature via DittoController over Hono MQTT"
    DTDFVocab:IsAutomatic false
]

instance HVACActuationAction : DTDFVocab:Action [
    base:desc "Command to HVACActuator adjusting set‑points and flow rate, routed through DittoController over Hono MQTT"
    DTDFVocab:IsAutomatic false
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange enables continuous synchronization between the physical building and its digital counterpart; the system operates in a real‑time, continuous mode without explicitly defined polling intervals, aligning with the real‑time monitoring and control requirements outlined in the framework."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated through a modular architecture featuring a central DT Hub that manages component integration via standardized extension points. Runtime configuration management allows dynamic adjustments of services and analytics without redeployment, while resource management is coordinated centrally to support scalability from individual components up to complete infrastructure systems. The hub mediates all data exchange, maintaining system-wide coordination and ensuring consistent lifecycle management from enriched BIM inputs to operational control."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework follows a multi‑stage lifecycle starting from enrichment of the Building Information Model (BIM) with detailed device, sensor, actuator and controller definitions performed by the Building Control Engineer. In the Design + Generation stage, a Model‑Driven Engineering (MDE) engine parses the enriched BIM and generates Structured Representation Models (SRMs) that map directly to runtime digital objects. The Deploy stage automatically materialises these SRMs into deployable DT artifacts (containers, services and publish/subscribe interfaces) with minimal human intervention. Continuous Operations are maintained through real‑time data exchange layers that keep the physical hardware states in sync with their digital twins, while an interactive visualization portal provides immersive monitoring and control for Facility Managers. Governance is split by stakeholder role: the Building Control Engineer validates model integrity, the Facility Manager governs day‑to‑day operation, and the DT Engineer oversees extension points and versioning of custom plugins. Transition management is achieved through the MDE transform pipeline and a modular extension registry that facilitates rollback or progressive upgrade of deployed artifacts."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through a combination of enriched BIM semantics, MDE‑generated twin artifacts, and runtime validation. Eclipse Ditto’s policy‑based validation enforces numerical ranges and unit consistency for all sensor readings before they reach the application layer. Pre‑execution checks on actuator commands prevent violations of safe operating limits. Fault tolerance is achieved via Hono’s at‑least‑once message delivery, guaranteeing that measurement or command events are not lost even in transient network failures; Ditto’s persistent event storage captures all events for eventual consistency and replay. The modular architecture allows developers to inject additional validation layers (e.g., FeatureParser to interpret domain‑specific features) and analytics services, thereby supporting continuous quality assurance throughout the twin’s life cycle."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The framework achieves interoperability across heterogeneous systems through standardized extension points and support for custom services and analytics. Bidirectional data exchange facilitates integration with external platforms and enterprise systems, and the modular design allows seamless incorporation of additional Digital Twins or third‑party services, ensuring cohesive horizontal integration within the broader AECO ecosystem."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework is grounded in the AECO‑specific BIM standard, using BIM models as the primary semantic foundation for device and control definitions. It leverages Model‑Driven Engineering principles that integrate with standard data modeling practices. Additionally, the framework references open‑source DT connectivity solutions such as Eclipse Ditto and BaSyx, both of which have been noted in the literature for providing robust connectivity and compliance with industry‑wide standards, thereby addressing the previously identified lack of standardized data schemas and bidirectional communication protocols. The use of these interoperable components and the explicit alignment with BIM signify adherence to recognized AECO and general IoT interoperability standards."
]