// C2: Acting Components
instance LightingDimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting dimmer actuator defined in the enriched BIM model and addressable by the DT for actuation."
]

instance HVACControlValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC control valve actuator defined in the enriched BIM model and addressable by the DT for actuation."
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in BIM; measurements ingested via Eclipse Hono."
    DTDFVocab:producedData TemperatureDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM; measurements ingested via Eclipse Hono."
    DTDFVocab:producedData OccupancyDataStream
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor modeled in BIM; measurements ingested via Eclipse Hono."
    DTDFVocab:producedData IlluminationDataStream
]

// C4: Physical-to-virtual interaction
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

// C5: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature measurements from the building's HVAC zones."
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo HonoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy counts for rooms and zones."
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo HonoEnabler
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Live illumination levels from lighting zones."
    DTDFVocab:fromData IlluminationDataStream
    DTDFVocab:inputTo HonoEnabler
]

// C10: Models/Data
instance BIMModel : DTDFVocab:Model [
    base:desc "BIM model supplies geometric, spatial, and semantic information for the building."
    DTDFVocab:inputTo ModelDrivenEngineEnabler
]

instance DeviceMetadataModel : DTDFVocab:Model [
    base:desc "Model‑driven transformation generates device metadata required by Hono and Ditto."
    DTDFVocab:inputTo ModelDrivenEngineEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Model‑driven transformation generates control logic for actuators and predictive analytics."
    DTDFVocab:inputTo ModelDrivenEngineEnabler
]

// C11: Enablers
instance HonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono acts as protocol gateway, ingesting sensor streams and forwarding to Ditto."
    DTDFVocab:enables RealTimeMonitoringService
]

instance DittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto stores the evolving twin state and mediates command execution."
    DTDFVocab:enables RealTimeMonitoringService
    DTDFVocab:enables EnergyOptimizationService
    DTDFVocab:enables TaskPlanningService
]

instance ModelDrivenEngineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering tools automatically generate runtime artifacts from BIM."
    DTDFVocab:enables SimulationPredictiveAnalyticsService
    DTDFVocab:enables EnergyOptimizationService
    DTDFVocab:enables TaskPlanningService
]

instance UnrealEngineEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 provides immersive 3D visualization of the twin."
    DTDFVocab:enables Visualization3DService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of sensor streams and twin state."
    DTDFVocab:provides RealTimeInsight
]

instance Visualization3DService : DTDFVocab:Service [
    base:desc "3D interactive visualization using Unreal Engine 5."
    DTDFVocab:provides VisualizationInsight
]

instance SimulationPredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Simulation and predictive analytics based on control‑logic model."
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy‑optimization service recommending heating/cooling and lighting adjustments."
    DTDFVocab:provides EnergyOptimizationInsight
    DTDFVocab:provides LightingDimmerActuationAction
]

instance TaskPlanningService : DTDFVocab:Service [
    base:desc "Task‑planning service delivering operational recommendations for facility managers."
    DTDFVocab:provides TaskPlanningInsight
    DTDFVocab:provides HVACValveAdjustmentAction
]

// C17: Insights/Actions
instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into current temperature, occupancy, and illumination conditions."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight through immersive 3D view of the building twin."
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics insight forecasting energy consumption and comfort levels."
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendation to reduce energy usage while maintaining comfort."
]

instance TaskPlanningInsight : DTDFVocab:Insight [
    base:desc "Actionable task‑planning insight for facility manager decision making."
]

instance LightingDimmerActuationAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting dimmers based on illumination insight."
    DTDFVocab:IsAutomatic true
]

instance HVACValveAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated tuning of HVAC control valves to achieve predicted optimal temperature setpoints."
    DTDFVocab:IsAutomatic true
]

// C13: Environment
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains BuildingInfrastructureComponent,
               TemperatureSensor,
               OccupancySensor,
               IlluminationSensor,
               LightingDimmerActuator,
               HVACControlValveActuator
]

// C14: System Under Study (Physical Counterpart)
instance BuildingInfrastructureComponent : DTDFVocab:Component [
    base:desc "Physical building infrastructure modeled in BIM serving as the counterpart of the Digital Twin."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication that sends control commands from Ditto back through Hono to the physical actuators, enabling the DT to influence building operations."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real‑time synchronization; data exchange occurs continuously with latency suitable for operational control (no explicit numeric rate provided)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central DT framework that orchestrates the enriched BIM model, Hono/Ditto middleware, and Unreal Engine visualizer, with standardized extension points for adding further services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Supports the design stage (BIM authoring), construction/commissioning stage (device configuration), and operation stage (runtime monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is employed to quantify how faithfully the digital twin reflects its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time connectivity is achieved through Eclipse Hono, which handles device protocol translation (e.g., MQTT/HTTP) and forwards messages to Eclipse Ditto, which maintains the digital twin state."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized extension points allow integration with external analytics, services, or other DT platforms, supporting a service‑oriented architecture."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Relies on industry‑standard BIM for building data, and on the standardized APIs of Eclipse Hono and Eclipse Ditto; the overall approach follows Model‑Driven Engineering best practices for interoperability."
]