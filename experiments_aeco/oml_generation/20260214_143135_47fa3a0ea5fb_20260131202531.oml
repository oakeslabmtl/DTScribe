// C17: Environment/Component
instance AcademicBuildingEnvironment : DTDFVocab:Environment [
    base:contains IndoorTemperatureSensor, HumiditySensor, CO2Sensor, OccupancySensor, EnergyMeter, StructuralVibrationSensor, SmartThermostat
]

instance HVACSystemEnvironment : DTDFVocab:Environment [
    base:contains ThermalFlowSensor, EnergyConsumptionDataStream
]

instance ResearchLabEnvironment : DTDFVocab:Environment [
    base:contains ResearchLabVentilationActuator, CO2Sensor, OccupancySensor, EnergyMeter
]

