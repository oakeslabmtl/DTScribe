// C2: Acting Components
instance AcademicBuildingHVACActuator : DTDFVocab:Actuator [
    base:desc "Automated actuator controlling HVAC system in LEED Platinum academic building for energy efficiency optimization"
]

instance LibraryLightingActuator : DTDFVocab:Actuator [
    base:desc "Smart lighting actuator in library zones for demand-based occupancy control"
]

instance ResearchLabVentilationActuator : DTDFVocab:Actuator [
    base:desc "High-performance ventilation actuator for research labs with CO₂ monitoring integration"
]

// C3: Physical sensing components
instance IndoorTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Real-time temperature sensor network embedded in building walls/ceiling panels for indoor environmental monitoring"
    DTDFVocab:producedData TemperatureDataStream
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "High-precision humidity sensor array distributed across building zones for IAQ monitoring"
    DTDFVocab:producedData HumidityDataStream
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ concentration sensor with sub-second sampling for occupant comfort validation"
    DTDFVocab:producedData CO2DataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Motion/presence sensors in lecture halls and research labs for space utilization optimization"
    DTDFVocab:producedData OccupancyDataStream
]

instance EnergyMeter : DTDFVocab:SensingComponent [
    base:desc "Smart energy meter with per-zone HVAC system granularity for LEED compliance audits"
    DTDFVocab:producedData EnergyConsumptionDataStream
]

instance StructuralVibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Structural health monitoring sensor for fatigue analysis of building materials"
    DTDFVocab:producedData StructuralDataStream
]

instance ThermalFlowSensor : DTDFVocab:SensingComponent [
    base:desc "Airflow measurement sensors in HVAC ducts for energy efficiency validation"
    DTDFVocab:producedData AirflowDataStream
]

instance SmartThermostat : DTDFVocab:SensingComponent [
    base:desc "Smart thermostat with predictive control for dynamic HVAC system optimization"
]

// C4: Physical-to-virtual interaction
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndoorTemperatureSensor
    DTDFVocab:producedFrequency subSecond
    DTDFVocab:dataType float
    DTDFVocab:unit Celsius
]

instance HumidityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
    DTDFVocab:producedFrequency subSecond
    DTDFVocab:dataType float
    DTDFVocab:unit percentage
]

instance CO2DataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
    DTDFVocab:producedFrequency subSecond
    DTDFVocab:dataType int
    DTDFVocab:unit ppm
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
    DTDFVocab:producedFrequency 100ms
    DTDFVocab:dataType boolean
]

instance EnergyConsumptionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyMeter
    DTDFVocab:producedFrequency 1second
    DTDFVocab:dataType float
    DTDFVocab:unit kWh
]

instance StructuralDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralVibrationSensor
    DTDFVocab:producedFrequency 100ms
    DTDFVocab:dataType float
    DTDFVocab:unit microstrain
]

instance AirflowDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ThermalFlowSensor
    DTDFVocab:producedFrequency 1second
    DTDFVocab:dataType float
    DTDFVocab:unit m³/s
]

instance ThermalControlData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SmartThermostat
    DTDFVocab:producedFrequency 500ms
    DTDFVocab:dataType string
    DTDFVocab:unit HVACCommand
]

// C10: Models/Data
instance BuildingEnergySimulationModel : DTDFVocab:Model [
    base:desc "Physics-based energy simulation model (EnergyPlus/OpenStudio) for thermal/hydraulic performance validation"
    DTDFVocab:inputTo EnergyPlusSimulationEngine
]

instance OccupantBehaviorModel : DTDFVocab:Model [
    base:desc "Agent-based simulation model for occupant behavior patterns (demand-based space utilization)"
    DTDFVocab:inputTo AgentBasedModeler
]

instance StructuralIntegrityModel : DTDFVocab:Model [
    base:desc "Physics-based structural analysis model for fatigue monitoring of building materials"
    DTDFVocab:inputTo StructuralSimulationEngine
]

instance IndoorEnvironmentModel : DTDFVocab:Model [
    base:desc "Comprehensive indoor environmental quality model integrating temperature, humidity, CO₂, and airflow"
    DTDFVocab:inputTo IndoorEnvironmentSimulator
]

instance LEEDComplianceModel : DTDFVocab:Model [
    base:desc "LEED Platinum compliance validation model tracking energy efficiency metrics against certification requirements"
    DTDFVocab:inputTo EnergyPerformanceDashboard
]

instance BIMBuildingModel : DTDFVocab:Model [
    base:desc "High-fidelity 3D BIM model of LEED Platinum academic building with spatial and functional attributes"
    DTDFVocab:inputTo BIMIntegrationPlatform
]

instance DataAggregationModel : DTDFVocab:Model [
    base:desc "Time-series database model for high-frequency sensor data aggregation (InfluxDB/TimescaleDB)"
    DTDFVocab:inputTo InfluxDB
]

instance GraphRelationshipModel : DTDFVocab:Model [
    base:desc "Graph database model for building component relationships (Neo4j) linking HVAC units to rooms to occupants"
    DTDFVocab:inputTo Neo4j
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono IoT protocol stack for real-time low-latency data synchronization between physical sensors and digital models"
    DTDFVocab:enables TemperatureDataStream, HumidityDataStream, CO2DataStream, OccupancyDataStream, EnergyConsumptionDataStream, StructuralDataStream, AirflowDataStream
]

instance BasyxEdgePlatform : DTDFVocab:Enabler [
    base:desc "Open-source edge computing platform for lightweight digital twin orchestration and low-latency processing"
    DTDFVocab:enables SmartThermostat
]

instance ITwinJS : DTDFVocab:Enabler [
    base:desc "Bentley Systems JavaScript library for interactive 3D/4D model visualization of building infrastructure"
    DTDFVocab:enables BuildingEnergySimulationModel, IndoorEnvironmentModel
]

instance EnergyPlusSimulationEngine : DTDFVocab:Enabler [
    base:desc "Physics-based thermal/hydraulic simulation engine for energy performance validation"
    DTDFVocab:enables BuildingEnergySimulationModel
]

instance AgentBasedModeler : DTDFVocab:Enabler [
    base:desc "Agent-based modeling framework for occupant behavior simulation and space utilization optimization"
    DTDFVocab:enables OccupantBehaviorModel
]

instance InfluxDB : DTDFVocab:Enabler [
    base:desc "Time-series database for high-frequency sensor data storage (1-second intervals for HVAC logs)"
    DTDFVocab:enables DataAggregationModel
]

instance Neo4jGraphDB : DTDFVocab:Enabler [
    base:desc "Graph database for building component relationship modeling (HVAC units → rooms → occupants)"
    DTDFVocab:enables GraphRelationshipModel
]

instance ModelDrivenEngineeringTools : DTDFVocab:Enabler [
    base:desc "OMG MOF/MDO frameworks for system-level modeling and digital twin architecture design"
    DTDFVocab:enables BIMIntegrationPlatform
]

// C6: Services
instance RealTimeIndoorMonitoring : DTDFVocab:Service [
    base:desc "Continuous real-time monitoring of indoor environmental conditions (temperature, humidity, CO₂)"
    DTDFVocab:provides TemperatureComfortInsight, HumidityComfortInsight, IAQHealthInsight
]

