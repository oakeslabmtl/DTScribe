// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled as a device in the BIM model, capable of receiving control commands from the twin."
]

instance BCSController : DTDFVocab:ActingComponent [
    base:desc "Building control system controller that orchestrates actuators based on twin‑generated set‑points."
]

// C3: Physical sensing components
instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor (temperature, humidity) embedded in the BIM model, providing live measurements to the twin."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the BIM model, detecting presence of occupants for comfort and energy analysis."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor embedded in the BIM model, measuring illuminance levels to support lighting optimization."
    DTDFVocab:producedData LightingDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

// C10: Models/Data
instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Live environmental measurement stream (temperature, humidity) ingested via Eclipse Hono and stored in Eclipse Ditto."
    DTDFVocab:fromData EnvironmentalDataTransmitted
    DTDFVocab:inputTo EclipseDittoPlatform
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy measurement stream ingested via Eclipse Hono and stored in Eclipse Ditto."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDittoPlatform
]

instance LightingData : DTDFVocab:Data [
    base:desc "Live illuminance measurement stream ingested via Eclipse Hono and stored in Eclipse Ditto."
    DTDFVocab:fromData LightingDataTransmitted
    DTDFVocab:inputTo EclipseDittoPlatform
]

instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Static BIM geometry model containing spatial relationships of the Living Lab academic building."
    DTDFVocab:inputTo ModelDrivenTransformationPipeline
]

instance DeviceMetadataModel : DTDFVocab:Model [
    base:desc "Generated device metadata model describing sensors and actuators derived from the enriched BIM model."
    DTDFVocab:inputTo EclipseDittoPlatform
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control‑logic model generated from the model‑driven pipeline, defining policies for energy optimization."
    DTDFVocab:inputTo EclipseDittoPlatform
]

// C11: Enablers
instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "Eclipse Hono protocol gateway that streams sensor measurements from physical devices to Eclipse Ditto."
]

instance EclipseDittoPlatform : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital‑twin platform that stores live sensor streams and executes control logic."
    DTDFVocab:enables RealTimeMonitoringDashboard,
                     PredictiveAnalytics,
                     EnergyOptimization,
                     DecisionSupport
]

instance ModelDrivenTransformationPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation pipeline that enriches the BIM model, extracts device metadata, and generates runtime artifacts."
]

instance UnrealEngine5VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime providing immersive 3‑D interactive visualization of the building twin."
    DTDFVocab:enables UnrealEngine5Visualization
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards displaying live environmental, occupancy, and lighting data."
    DTDFVocab:provides EnergyConsumptionTrendInsight
]

instance UnrealEngine5Visualization : DTDFVocab:Service [
    base:desc "3‑D interactive visualization in Unreal Engine 5 for immersive facility exploration."
    DTDFVocab:provides ComfortLevelEvaluationInsight
]

instance PredictiveAnalytics : DTDFVocab:Service [
    base:desc "Predictive analytics engine forecasting energy usage and occupancy patterns."
    DTDFVocab:provides OptimizedLightingSetpointInsight
]

instance EnergyOptimization : DTDFVocab:Service [
    base:desc "Energy‑optimization service delivering set‑point recommendations (decision support, not automatic actuation)."
    DTDFVocab:provides EnergyConsumptionTrendInsight
]

instance DecisionSupport : DTDFVocab:Service [
    base:desc "Decision‑support service delivering actionable insights to facility managers."
    DTDFVocab:provides EnergyConsumptionTrendInsight,
                     ComfortLevelEvaluationInsight,
                     OptimizedLightingSetpointInsight
]

// C17: Insights
instance EnergyConsumptionTrendInsight : DTDFVocab:Insight [
    base:desc "Insight on energy consumption trends derived from sensor streams and analytics."
]

instance ComfortLevelEvaluationInsight : DTDFVocab:Insight [
    base:desc "Insight evaluating occupant comfort levels based on temperature, humidity, and occupancy data."
]

instance OptimizedLightingSetpointInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimized lighting control set‑points for energy savings and comfort."
]

// Environment containing all components
instance LivingLabAcademicBuilding : DTDFVocab:Environment [
    base:contains EnvironmentalSensor,
                     OccupancySensor,
                     LightingSensor,
                     LightingActuator,
                     BCSController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command flow from the twin to physical actuators through the same Hono/Ditto integration, allowing the twin to issue control set-points or actuation commands to the building control system."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real-time synchronization (sub-second to second-scale) between physical sensor updates and twin state updates, as enabled by the Hono/Ditto real-time data pipeline."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service-oriented architecture where the DT framework acts as a central hub linking enriched BIM models, the Hono/Ditto middleware, visualization components, and custom services; components communicate through defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin spans the design, construction, and operational phases of the building lifecycle, supporting scenarios from as-designed (BIM) through as-built to as-operated representations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed using the Overall Digital Twin Entanglement (ODTE) metric; model validation is performed before deployment; continuous synchronization mitigates semantic drift between the BIM model and the physical asset."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Technical connectivity is achieved using Eclipse Hono for inbound device telemetry and command channels and Eclipse Ditto for twin state storage and bidirectional synchronization, forming the real‑time communication backbone."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework standardizes BIM semantics through a modeling methodology, uses standardized extension points, and aligns with established BIM and model-driven engineering standards for interoperability."
]