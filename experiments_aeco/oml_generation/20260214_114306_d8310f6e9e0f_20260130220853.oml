// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded temperature sensor defined in the BIM model, streaming measurements to the twin."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded occupancy sensor defined in the BIM model, publishing occupancy counts."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded illumination (light level) sensor defined in the BIM model, providing real‑time lumen data."
    DTDFVocab:producedData IlluminationDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature measurement stream (°C) arriving via Eclipse Hono."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy count stream (persons) arriving via Eclipse Hono."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Illumination level stream (lux) arriving via Eclipse Hono."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C10: Models/Data (model instances are also treated as DTDFVocab:Model)
instance BaseBIMModel : DTDFVocab:Model [
    base:desc "Base BIM model containing geometry, spatial relationships and device metadata."
    DTDFVocab:inputTo ModelTransformationPipeline
]

instance RuntimeControlModel : DTDFVocab:Model [
    base:desc "Runtime control model that maps sensor states to actuator commands."
    DTDFVocab:inputTo EclipseDitto
]

instance PredictiveAnalyticsModel : DTDFVocab:Model [
    base:desc "Predictive analytics model (e.g., energy consumption forecast) used for recommendations."
    DTDFVocab:inputTo EclipseDitto
]

instance UnrealEngineVisualizationAssets : DTDFVocab:Model [
    base:desc "Unreal Engine 5 assets (meshes, materials, interaction scripts) for 3D visualization."
    DTDFVocab:inputTo UnrealEngine5
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono IoT data ingestion platform (MQTT/HTTP) receiving sensor streams."
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin platform managing twin state and providing REST/WS APIs."
    DTDFVocab:enables PredictiveAnalyticsService, LightingOptimizationService, BuildingPerformanceSimulationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime delivering interactive 3D visualisation of the building twin."
    DTDFVocab:enables Interactive3DVisualizationService
]

instance ModelTransformationPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation pipeline that extracts semantics from the BIM model and generates Hono/Ditto configurations."
    DTDFVocab:enables DeploymentAutomationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards showing live sensor values and twin state."
    DTDFVocab:provides OccupantComfortInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualisation in Unreal Engine 5 for spatial exploration of the digital twin."
    DTDFVocab:provides OccupantComfortInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics engine delivering energy consumption forecasts and anomaly detection."
    DTDFVocab:provides EnergyEfficiencyInsight
]

instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based lighting control optimisation recommending set‑points."
    DTDFVocab:provides RecommendLightingSetpoints
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation service evaluating HVAC and lighting performance under varying scenarios."
    DTDFVocab:provides UpdateControlPolicy
]

instance DeploymentAutomationService : DTDFVocab:Service [
    base:desc "Automated deployment of twin artefacts (configurations, models) via the transformation pipeline."
    DTDFVocab:provides DeploymentInsight
]

// C17: Insights
instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight recommending actions to improve energy efficiency based on predictive analytics."
]

instance OccupantComfortInsight : DTDFVocab:Insight [
    base:desc "Insight indicating current occupant comfort levels derived from temperature, occupancy and illumination data."
]

instance DeploymentInsight : DTDFVocab:Insight [
    base:desc "Insight about deployment health and configuration consistency generated after each pipeline run."
]

// C17: Actions
instance RecommendLightingSetpoints : DTDFVocab:Action [
    base:desc "Action recommending optimal lighting set‑points for each zone."
    DTDFVocab:IsAutomatic false
]

instance UpdateControlPolicy : DTDFVocab:Action [
    base:desc "Action updating the control policy of HVAC and lighting systems based on simulation results."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components (Physical actuators)
instance LightingControlDevice : DTDFVocab:ActingComponent [
    base:desc "Lighting control device defined in the enriched BIM model, receives set‑point commands via Ditto."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator defined in the enriched BIM model, receives temperature control commands via Ditto."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin are sent from Eclipse Ditto through Eclipse Hono to the corresponding actuator endpoints, effecting changes in the physical building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization (sub‑second to second latency) enabled by the Eclipse Hono/Ditto data‑exchange layer."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular service‑oriented architecture where an enriched BIM model feeds a configurator that generates Hono/Ditto runtime artifacts; the twin core (Ditto) maintains state, Hono handles bi‑directional messaging, and visualization/analytics services plug in via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the design/as‑built phase (BIM), commissioning/deployment, and operational phase where runtime data are consumed and control actions are issued."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric is used to quantify how closely the twin reflects the physical counterpart, providing a quantitative fidelity assessment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono provides MQTT/HTTP (and optionally AMQP) gateways; Eclipse Ditto exposes HTTP/REST and WebSocket APIs for twin state access and command issuance."
]