// C17: Insights
instance FacilityMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time monitoring of system states and device statuses."
]

instance SafetyValidationInsight : DTDFVocab:Insight [
    base:desc "Insight reporting results of policy‑based safety validation checks."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight derived from custom analytics plugins for performance optimisation."
]

instance ModelGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight describing successful generation of deployable DT artifacts from enriched BIM."
]

// C17: Actions
instance LightControlAction : DTDFVocab:Action [
    base:desc "Action to command the lighting fixture (on/off, brightness, colour‑temperature) via the TwinComponent stack.",
    DTDFVocab:IsAutomatic false
]

instance SafetyCheckAction : DTDFVocab:Action [
    base:desc "Automatic safety check performed before issuing actuator commands.",
    DTDFVocab:IsAutomatic true
]

// C6: Services
instance RealTimeDataExchangeService : DTDFVocab:Service [
    base:desc "Provides continuous synchronization between physical assets and the digital twin via Hono and Ditto.",
    DTDFVocab:provides FacilityMonitoringInsight, LightControlAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Provides immersive 3‑D visualisation and monitoring of building and device status in UE5.",
    DTDFVocab:provides FacilityMonitoringInsight
]

instance TwinComponentExecutionService : DTDFVocab:Service [
    base:desc "Executes TwinComponents reacting to incoming device telemetry.",
    DTDFVocab:provides LightControlAction
]

instance PolicyValidationService : DTDFVocab:Service [
    base:desc "Enforces safety constraints through policy‑based validation before actuator commands are issued.",
    DTDFVocab:provides SafetyValidationInsight, SafetyCheckAction
]

instance DataAnalyticsService : DTDFVocab:Service [
    base:desc "Hosts custom analytics plugins extending twin capabilities via standardized extension points.",
    DTDFVocab:provides OptimizationInsight
]

instance ModelGenerationService : DTDFVocab:Service [
    base:desc "Generates code and configuration artifacts (UE5 TwinComponents, middleware configs) from enriched BIM models.",
    DTDFVocab:provides ModelGenerationInsight
]

// C11: Enablers
instance UnrealEngineRuntime : DTDFVocab:Enabler [
    base:desc "UE5 runtime that visualises IFC geometry and executes TwinComponents.",
    DTDFVocab:enables InteractiveVisualizationService, TwinComponentExecutionService
]

instance EclipseHonoGateway : DTDFVocab:Enabler [
    base:desc "IoT ingestion gateway using MQTT/AMQP with at‑least‑once delivery.",
    DTDFVocab:enables RealTimeDataExchangeService
]

instance EclipseDittoRuntime : DTDFVocab:Enabler [
    base:desc "Digital Twin runtime hosting models, policies and state storage.",
    DTDFVocab:enables PolicyValidationService, DataAnalyticsService, TwinComponentExecutionService, RealTimeDataExchangeService
]

instance MDEPipeline : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline that extracts enriched BIM and generates deployable DT artifacts.",
    DTDFVocab:enables ModelGenerationService
]

// C10: Models/Data
instance IfcGeometricModel : DTDFVocab:Model [
    base:desc "3‑D IFC geometry of the building rendered in Unreal Engine.",
    DTDFVocab:inputTo UnrealEngineRuntime
]

instance TwinComponentBehaviorModel : DTDFVocab:Model [
    base:desc "Behavioral model encoded in UE5 TwinComponents that react to device values.",
    DTDFVocab:inputTo UnrealEngineRuntime, EclipseDittoRuntime
]

instance DittoPolicyValidationModel : DTDFVocab:Model [
    base:desc "Analytical model realised by policy‑based validation rules in Eclipse Ditto for safety constraints.",
    DTDFVocab:inputTo EclipseDittoRuntime
]

instance LightTelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    // Optional: DTDFVocab:producedFrom LightTelemetrySensor
]

instance LightTelemetryData : DTDFVocab:Data [
    base:desc "Real‑time telemetry values (on/off state, brightness level, color‑temperature) of the lighting fixture.",
    DTDFVocab:fromData LightTelemetryDataTransmitted,
    DTDFVocab:inputTo EclipseHonoGateway, EclipseDittoRuntime
]

// C3: Physical sensing components
instance LightTelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Virtual sensor extracting on/off, brightness, and color‑temperature telemetry from the lighting fixture via real‑time IoT streams.",
    DTDFVocab:producedData LightTelemetryDataTransmitted
]

// C2: Acting Components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "TwinComponent that controls a lighting fixture with on/off, brightness (0‑100 %) and color‑temperature (2700‑6500 K) parameters."
]

// C12: Component (optional generic component representation)
instance LightTwinComponentComponent : DTDFVocab:Component [
    base:desc "Component representation of the LightTwinComponent acting component."
]

// C1: Environment
instance DigitalTwinEnvironment : DTDFVocab:Environment [
    base:contains LightTwinComponent, LightTelemetrySensor, UnrealEngineRuntime, EclipseHonoGateway, EclipseDittoRuntime, MDEPipeline
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange capabilities that ensure continuous synchronization between the physical building and its digital counterpart, described as ongoing real‑time updates without a specified frequency or latency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular hub‑and‑spoke constellation: a central DT Framework orchestrates bidirectional data exchange between enriched BIM models and operational digital twins, enables runtime configuration management, and offers standardized extension points for adding custom analytics and services, supporting scalable component coordination."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports the complete Digital Twin lifecycle: (1) device modeling in the BIM environment where sensors, actuators, and controllers are defined; (2) model‑driven engineering (MDE) extraction of structured representations from the enriched BIM model; (3) automatic generation of deployable DT artifacts; (4) deployment of these artifacts to the runtime environment; and (5) continuous operation with real‑time data exchange and interactive visualization. Transitions between phases are managed by the model‑driven pipeline, and lifecycle governance is expressed through the functional requirements (F_X) that prescribe modeling, transformation, deployment and runtime management."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by enriching the BIM model with precise device metadata (photometric values for lights) and by applying Eclipse Ditto policy‑based validation that checks sensor data against defined ranges and units. The framework validates the enriched BIM during the conversion phase (validation component) and enforces runtime checks on incoming sensor updates and outgoing actuator commands. Uncertainty is limited by the deterministic mapping of Revit photometric parameters to UE5 lighting, and by the at‑least‑once delivery guarantee of Eclipse Hono which avoids lost updates. Errors are detected by Ditto’s persistent event store and corrected through policy re‑evaluation; fault tolerance is provided by Hono’s message reliability and Ditto’s storage, ensuring synchronization between physical assets and the twin."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed through non‑functional requirements emphasizing cross‑system compatibility; the framework relies on standardized extension points and bidirectional data exchange to integrate external services and enterprise systems, though no specific communication protocols or standards are named in the documents."
]