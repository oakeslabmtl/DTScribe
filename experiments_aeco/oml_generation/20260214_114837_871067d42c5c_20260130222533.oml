// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in BIM providing continuous temperature measurements for the building."
    DTDFVocab:producedData TemperatureDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM providing real‑time occupancy counts for the building."
    DTDFVocab:producedData OccupancyDataStream
]

// C4: Physical-to-virtual interaction
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Data instances
instance TemperatureMeasurement : DTDFVocab:Data [
    base:desc "Real‑time temperature measurement streamed from the physical sensor."
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo RealTimeDataExchangeLayer
]

instance OccupancyMeasurement : DTDFVocab:Data [
    base:desc "Real‑time occupancy measurement streamed from the physical sensor."
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo RealTimeDataExchangeLayer
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with device definitions, providing geometric and semantic representation of building components."
    DTDFVocab:inputTo RealTimeDataExchangeLayer
]

instance BehavioralControlModel : DTDFVocab:Model [
    base:desc "Behavioral model encoding control logic for sensors, actuators, and controllers derived via MDE transformations."
    DTDFVocab:inputTo ModelDrivenTransformationEngine
]

// C11: Enablers
instance RealTimeDataExchangeLayer : DTDFVocab:Enabler [
    base:desc "Framework's real‑time data exchange layer that continuously synchronises physical building assets with their digital twin."
    DTDFVocab:enables VisualizationService, DecisionSupportService, ControlCommandService, AnalyticsIntegrationService
]

instance ModelDrivenTransformationEngine : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering transformation engine that derives executable DT models from the enriched BIM."
    DTDFVocab:enables DeploymentService
]

// C6: Services
instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive interactive visualization enabling Facility Managers to monitor system states."
    DTDFVocab:provides OperationalInsight
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Decision‑support service delivering real‑time operational insights for building management."
    DTDFVocab:provides OperationalInsight
]

instance ControlCommandService : DTDFVocab:Service [
    base:desc "Service allowing Facility Managers to issue control commands to actuators via the digital twin."
    DTDFVocab:provides ControlAction
]

instance AnalyticsIntegrationService : DTDFVocab:Service [
    base:desc "Integration point for custom analytics services providing advanced operational insights."
    DTDFVocab:provides AnalyticalInsight
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Automated deployment service that packages and deploys DT artifacts generated by the MDE engine."
    DTDFVocab:provides DeploymentAction
]

// C17: Insights
instance OperationalInsight : DTDFVocab:Insight [
    base:desc "Real‑time operational insight derived from synchronized sensor data to support building‑management decisions."
]

instance AnalyticalInsight : DTDFVocab:Insight [
    base:desc "Insight generated by custom analytics services applied to real‑time building data."
]

// C17: Actions
instance ControlAction : DTDFVocab:Action [
    base:desc "Facility Manager command to adjust actuator settings, e.g., on/off state or set‑point values."
    DTDFVocab:IsAutomatic false
]

instance DeploymentAction : DTDFVocab:Action [
    base:desc "Action to automatically package and deploy executable digital‑twin models."
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator defined in BIM, exposed for remote operation to control heating, ventilation, and air‑conditioning."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication is supported so that the Digital Twin can issue control commands back to the physical building. Facility managers interact with the DT’s visualisation interface to trigger actions; these commands are transmitted through the same standardized extension points to the building control system, where they are validated and enacted on the physical devices. The framework’s runtime configuration capability allows modification of command handling policies on‑the‑fly, ensuring that control flows remain consistent with the current deployment state."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The digital twin is kept synchronized with the physical asset in real time using Eclipse Hono for device connectivity and Eclipse Ditto for twin state management. The document does not provide explicit synchronization frequencies, latency requirements, or temporal granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system architecture combines Eclipse Hono for inbound data acquisition, Eclipse Ditto for digital twin lifecycle and state handling, and the Unreal Engine for immersive 3‑D visualization. These components are integrated in a model‑driven fashion to provide simulation, analysis, and optimization capabilities. No further orchestration mechanisms are described."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The proposed model‑driven DT deployment framework defines a full lifecycle that starts with device modeling inside the BIM environment (definition of sensors, actuators, and controllers), proceeds to model‑driven engineering (MDE) extraction of structured representations, automatic generation and deployment of DT artifacts, runtime operation with continuous real‑time data exchange for state synchronization, interactive visualization for monitoring and control, and a modular extension phase where custom services and analytics are integrated via standardized extension points. Governance is embodied in role‑based responsibilities (Building Control Engineer, Facility Manager, DT Engineer) that guide each phase."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed through an explicit validation step that evaluates the alignment between the physical asset and its digital counterpart using the Overall Digital Twin Entanglement (ODTE) metric. The ODTE metric quantifies the degree of entanglement, serving as a verification criterion during deployment. Validation ensures that the automatically generated DT artifacts faithfully reflect the enriched BIM device definitions. Continuous runtime synchronization mitigates uncertainties arising from BIM's static nature, and the metric‑based assessment forms part of the quality‑assurance process for both models and live data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on a modular architecture with standardized extension points that enable interoperable communication between heterogeneous subsystems. The framework abstracts the underlying network protocols, allowing integration of diverse data sources and control endpoints while meeting non‑functional requirements for scalability (from single components to whole infrastructure) and maintainability (low‑overhead updates). Security and reliability are addressed through the framework’s runtime configuration management, which can adjust security policies and redundancy settings without redeployment."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration between the physical environment and the digital twin is performed via Eclipse Hono, which ingests data from sensors/actuators, and Eclipse Ditto, which exposes the twin state. The document does not specify particular communication protocols, external enterprise systems, or interoperability standards beyond these components."
]