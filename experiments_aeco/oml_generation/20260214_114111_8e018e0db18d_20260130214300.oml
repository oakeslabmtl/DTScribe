// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Physical lighting actuator (on/off, brightness, colour temperature) controlled via the UnrealTwinController→DittoController chain with policy‑based validation."
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in enriched BIM, streams presence detection via Eclipse Hono with at‑least‑once guarantee."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor (light level) defined in enriched BIM, feeds photometric values to the LightTwinComponent."
    DTDFVocab:producedData IlluminationDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

// C5: Data (processed / persisted)
instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy state persisted in Eclipse Ditto event store, refreshed each second."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDitto, UE5Visualization
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Live illumination measurements used for UE5 lighting rendering and analytics."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseDitto, UE5Visualization, LightTwinComponent
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with device definitions (sensors, actuators, controllers) exported from Revit/IFC."
    DTDFVocab:inputTo EclipseDitto, UE5Visualization
]

instance LightTwinModel : DTDFVocab:Model [
    base:desc "Model containing photometric values (Revit luminaires) used by LightTwinComponent for accurate UE5 lighting."
    DTDFVocab:inputTo LightTwinComponent
]

instance DeviceConfigurationModel : DTDFVocab:Model [
    base:desc "Configuration files generated by MDE pipeline that map BIM device metadata to Ditto thing definitions."
    DTDFVocab:inputTo EclipseDitto
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Open‑source MQTT/HTTP gateway that ingests sensor telemetry with at‑least‑once delivery."
    DTDFVocab:enables RealTimeDataExchangeService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Digital twin state manager that stores thing properties, validates policies, and exposes CRUD APIs."
    DTDFVocab:enables RealTimeDataExchangeService, MonitoringDashboardService, ControlInterfaceService
]

instance UE5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 immersive 3‑D visualization synchronised each second with Ditto state."
    DTDFVocab:enables Interactive3DVisualizationService, MonitoringDashboardService
]

instance LightTwinComponent : DTDFVocab:Enabler [
    base:desc "Component that consumes illumination data and photometric model to render realistic lighting; also supplies inputs to analytics."
    DTDFVocab:enables AnalyticsOptimizationService
]

// C6: Services
instance RealTimeDataExchangeService : DTDFVocab:Service [
    base:desc "Bidirectional, at‑least‑once data exchange between physical sensors/actuators and the digital twin."
    DTDFVocab:provides FacilityStateInsight
]

instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Web‑based dashboards that display live twin state, raise alerts and support operator awareness."
    DTDFVocab:provides AlertInsight, VisualInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3‑D view of the enriched BIM model updated in near‑real‑time."
    DTDFVocab:provides VisualInsight
]

instance ControlInterfaceService : DTDFVocab:Service [
    base:desc "User‑driven command interface allowing facility managers to issue actuator commands through the twin."
    DTDFVocab:provides ControlCommandAction
]

instance AnalyticsOptimizationService : DTDFVocab:Service [
    base:desc "Custom analytics pipeline offering predictive maintenance and energy‑efficiency recommendations."
    DTDFVocab:provides PredictiveMaintenanceInsight, EnergyEfficiencyInsight, CustomAnalyticsInsight
]

instance CustomExtensionService : DTDFVocab:Service [
    base:desc "Standardised extension point for domain‑specific analytics or decision‑support modules."
    DTDFVocab:provides CustomAnalyticsInsight
]

// C17: Insights/Actions
instance FacilityStateInsight : DTDFVocab:Insight [
    base:desc "Current state of building systems (occupancy, illumination, HVAC) derived from live sensor feeds."
]

instance AlertInsight : DTDFVocab:Insight [
    base:desc "Automatic alerts generated when sensor values violate policy‑defined ranges."
]

instance VisualInsight : DTDFVocab:Insight [
    base:desc "Real‑time visual representation of building state within the UE5 environment."
]

instance ControlCommandAction : DTDFVocab:Action [
    base:desc "Command issued from twin UI to turn lighting actuators on/off, adjust brightness or colour temperature."
    DTDFVocab:IsAutomatic false
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Forecasted equipment degradation derived from historical telemetry and analytics."
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Recommendations for reducing energy consumption based on usage patterns."
]

instance CustomAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Domain‑specific analytic result provided by a custom extension module."
]

// Optional: Environment & Components
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains BuildingEnvelope, LightingSystem, OccupancyZone
]

instance BuildingEnvelope : DTDFVocab:Component [
    base:desc "Structural envelope of the building captured in the BIM model."
]

instance LightingSystem : DTDFVocab:Component [
    base:desc "Network of lighting actuators and illumination sensors."
]

instance OccupancyZone : DTDFVocab:Component [
    base:desc "Spatial zones where occupancy sensors are deployed."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control and monitoring commands originate from the digital twin via Eclipse Ditto and are delivered to physical building systems, enabling Facility Managers to interact with the twin for real‑time monitoring and control (Doc 1). The bidirectional communication supported by Ditto allows the twin to issue control messages, but the documents do not detail command formats, validation, authentication, feedback mechanisms, or execution confirmation procedures."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides continuous real‑time data exchange that keeps the physical building and its digital counterpart synchronized; synchronization is described as real‑time with no explicit period or latency values, implying a need for low latency but the exact granularity is not detailed in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT system follows a modular, hub‑and‑spoke architecture where a central DT Framework acts as a hub enabling bidirectional data exchange between devices, BIM models and custom services. Standardized extension points allow plug‑in of analytics or services, and runtime configuration management permits on‑the‑fly adaptation without redeployment. Coordination is achieved through the framework’s central hub which orchestrates device models, control logic and visualization."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports the full Digital Twin life‑cycle, starting with device modeling within enriched BIM models where sensors, actuators and controllers are defined (functional requirement F_X). Model‑Driven Engineering (MDE) extracts structured representations from these BIM models and automatically generates deployable DT artifacts (code, configuration). An automated deployment process (R2) reduces manual steps and ensures reproducible set‑up. At runtime the twin operates with continuous real‑time data exchange (R3) using Eclipse Hono for ingestion and Eclipse Ditto for state synchronization, providing live bidirectional sync between physical assets and the digital copy. The modular architecture with standardized extension points (R4) allows the integration of custom analytics services and supports iterative evolution of the twin post‑deployment. Governance is implicit in the minimal‑manual, reproducible pipeline and the defined extension points that enforce consistent integration practices."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assured through a three‑stage deployment pipeline: model checking (5.53 s), model parsing (8.7 s) and rapid initialization (0.3 s). Eclipse Ditto enforces policy‑based validation of sensor values and actuator commands, providing error detection and automatic rejection of out‑of‑range data. Fault tolerance is achieved by Hono’s at‑least‑once delivery and Ditto’s persistent event storage, guaranteeing that no updates are lost. The overall synchronization quality is quantified with the Overall Digital Twin Entanglement (ODTE) metric, which combines timeliness (0.997), reliability (1.0) and availability (1.0) measured over a 12‑minute window using a 1 s heartbeat. These mechanisms constitute the validation and quality‑assurance process for the DT models and data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical networking layer comprises Eclipse Hono for device data ingestion and Eclipse Ditto for digital twin services, embedded within a modular architecture with standardized extension points that promotes interoperability across heterogeneous systems (Doc 1, Doc 3). While the framework emphasizes scalability, maintainability, and low‑overhead updates (NF_X), the documents do not provide explicit specifications on network topology, bandwidth, latency, redundancy, or security protocols."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed through standardized extension points that allow integration with heterogeneous systems such as BIM tools, sensor networks and external analytics platforms. The framework emphasizes compliance with interoperability requirements (NF_X) and supports data exchange with external systems, although specific protocols or standards are not enumerated in the documents."
]