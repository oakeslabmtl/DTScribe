instance IndoorTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor configured in BIM environment by Building Control Engineers for real-time monitoring"
    DTDFVocab:producedData IndoorTemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor configured in BIM environment by Building Control Engineers for real-time monitoring"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance AirFlowSensor : DTDFVocab:SensingComponent [
    base:desc "Airflow sensor configured in BIM environment by Building Control Engineers for real-time monitoring"
    DTDFVocab:producedData AirFlowDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO2 sensor configured in BIM environment by Building Control Engineers for real-time monitoring"
    DTDFVocab:producedData CO2DataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor configured in BIM environment by Building Control Engineers for real-time monitoring"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IndoorTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IndoorTemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance AirFlowDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirFlowSensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IndoorTemperatureData : DTDFVocab:Data [
    base:desc "Real-time indoor temperature data from physical sensors"
    DTDFVocab:fromData IndoorTemperatureDataTransmitted
    DTDFVocab:inputTo BIM, EclipseHono, Ditto
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Real-time humidity data from physical sensors"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo BIM, EclipseHono, Ditto
]

instance AirFlowData : DTDFVocab:Data [
    base:desc "Real-time airflow data from physical sensors"
    DTDFVocab:fromData AirFlowDataTransmitted
    DTDFVocab:inputTo BIM, EclipseHono, Ditto
]

instance CO2Data : DTDFVocab:Data [
    base:desc "Real-time CO2 concentration data from physical sensors"
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo BIM, EclipseHono, Ditto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy data from physical sensors"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo BIM, EclipseHono, Ditto
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator configured in BIM environment by Building Control Engineers for precise temperature control"
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator configured in BIM environment by Building Control Engineers for automated lighting control"
]

instance WindowController : DTDFVocab:ActingComponent [
    base:desc "Window controller configured in BIM environment by Building Control Engineers for natural ventilation control"
]

instance DoorController : DTDFVocab:ActingComponent [
    base:desc "Door controller configured in BIM environment by Building Control Engineers for access control"
]

instance BIM : DTDFVocab:Enabler [
    base:desc "Building Information Modeling for structured data management of geometric and semantic models"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for real-time IoT data exchange and device management"
    DTDFVocab:enables RealTimeMonitoringService
]

instance Ditto : DTDFVocab:Enabler [
    base:desc "Ditto for IoT device management and data exchange"
    DTDFVocab:enables RealTimeMonitoringService
]

instance UnrealEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine for high-fidelity interactive visualization and simulation environments"
    DTDFVocab:enables RealTimeMonitoringService
]

instance DTFramework : DTDFVocab:Enabler [
    base:desc "Centralized framework managing multiple DT instances and bidirectional data exchange"
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, InfrastructureOptimizationService
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of operational data with interactive visualization for continuous infrastructure control"
    DTDFVocab:provides RealTimeMonitoringInsight, VisualizationInsight, AdjustHVACTemperature, AdjustLighting, AdjustWindowPosition
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for maintenance and performance forecasting"
    DTDFVocab:provides PredictiveMaintenanceInsight, PredictiveFailureAction
]

instance InfrastructureOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of infrastructure management for data-driven decision-making"
    DTDFVocab:provides EnergyOptimizationInsight, ResourceAllocationAction
]

instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "BIM-based geometric and semantic models for Building Control System components"
    DTDFVocab:inputTo BIM
]

instance MDEModel : DTDFVocab:Model [
    base:desc "Structured representations generated from enriched BIM models using Model-Driven Engineering"
    DTDFVocab:inputTo DTFramework
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time operational status of building systems for continuous monitoring"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive visualization of building data for enhanced situational awareness"
]

instance AdjustHVACTemperature : DTDFVocab:Action [
    base:desc "Automated adjustment of HVAC temperature based on sensor data"
    DTDFVocab:IsAutomatic true
]

instance AdjustLighting : DTDFVocab:Action [
    base:desc "Automated adjustment of lighting levels based on occupancy and ambient light"
    DTDFVocab:IsAutomatic true
]

instance AdjustWindowPosition : DTDFVocab:Action [
    base:desc "Automated adjustment of window positions for optimal ventilation"
    DTDFVocab:IsAutomatic true
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive insights on equipment maintenance needs to prevent failures"
]

instance PredictiveFailureAction : DTDFVocab:Action [
    base:desc "Automated scheduling of maintenance tasks based on predictive analytics"
    DTDFVocab:IsAutomatic true
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insights for optimizing energy consumption and reducing operational costs"
]

instance ResourceAllocationAction : DTDFVocab:Action [
    base:desc "Automated resource allocation for efficient infrastructure management"
    DTDFVocab:IsAutomatic true
]

instance BuildingControlEngineer : DTDFVocab:Component [
    base:desc "Role responsible for configuring sensors and actuators in BIM environment"
]

instance FacilityManager : DTDFVocab:Component [
    base:desc "Role responsible for real-time monitoring and control of building systems"
]

instance DTEngineer : DTDFVocab:Component [
    base:desc "Role responsible for integrating custom services and analytics into the DT framework"
]

instance BuildingEnvironment : DTDFVocab:Environment [
    base:desc "AECO building integrating static design models with real-time operational data for lifecycle management"
    base:contains IndoorTemperatureSensor, HumiditySensor, AirFlowSensor, CO2Sensor, OccupancySensor, HVACActuator, LightingActuator, WindowController, DoorController, IndoorTemperatureDataTransmitted, HumidityDataTransmitted, AirFlowDataTransmitted, CO2DataTransmitted, OccupancyDataTransmitted, IndoorTemperatureData, HumidityData, AirFlowData, CO2Data, OccupancyData, BuildingControlEngineer, FacilityManager, DTEngineer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands from the digital twin are sent to Building Control Systems (BCS) via Eclipse Hono and Ditto, allowing facility managers to operate physical infrastructure with bidirectional feedback mechanisms."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time data exchange capabilities ensure continuous synchronization between physical buildings and their digital counterparts"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Modular architecture with standardized extension points supports integration of custom services and analytics, runtime configuration management enables adjustments without full redeployment, and the DT Framework acts as a central hub coordinating roles for holistic building lifecycle management."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle comprises initial device modeling within BIM environments by Building Control Engineers, automated transformation via Model-Driven Engineering (MDE) to generate deployable artifacts, real-time operational synchronization through continuous data exchange and interactive visualization for Facility Managers, and evolution via modular extension points supporting custom services developed by DT Engineers to address changing operational needs."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is quantified using the Overall Digital Twin Entanglement (ODTE) metric to assess alignment between the digital twin and physical counterpart. Validation processes include systematic checks during model transformation from BIM and runtime operations, with error detection and correction mechanisms ensuring continuous accuracy and reliability of the twin's representations."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM is established as a standard solution in the construction industry, yet the absence of standardized integration frameworks for Digital Twins necessitates our framework's development. The solution implements standardized extension points to ensure modular interoperability of custom services and analytics, addressing critical gaps in DT standardization."
]