// C3: Physical sensing components
instance BuildingEnergySensor : DTDFVocab:SensingComponent [
    base:desc "Sensor defined within the BIM model by the Building Control Engineer to monitor energy consumption; linked to real‑time data exchange for continuous synchronization."
    DTDFVocab:producedData EnergyDataStream
]

instance BuildingFaultSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor defined within the BIM model by the Building Control Engineer to detect equipment faults; streamed continuously via the real‑time data layer."
    DTDFVocab:producedData FaultDataStream
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance EnergyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingEnergySensor
]

instance FaultDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingFaultSensor
]

// C11: Data artifacts
instance EnergyMeasurementData : DTDFVocab:Data [
    base:desc "Continuous energy consumption measurements streamed from the physical building sensors."
    DTDFVocab:fromData EnergyDataStream
    DTDFVocab:inputTo AnalyticsEngine
]

instance FaultMeasurementData : DTDFVocab:Data [
    base:desc "Real‑time fault detection measurements generated by building fault sensors."
    DTDFVocab:fromData FaultDataStream
    DTDFVocab:inputTo AnalyticsEngine
]

// C10: Models/Data
instance EnrichedBIMGeometricModel : DTDFVocab:Model [
    base:desc "3‑D building geometry enriched in the BIM environment, combined with spatial semantics."
    DTDFVocab:inputTo AnalyticsEngine
]

instance EnrichedBIMFunctionalModel : DTDFVocab:Model [
    base:desc "Functional semantics of building systems (HVAC, lighting) captured in the BIM model."
    DTDFVocab:inputTo AnalyticsEngine
]

instance DeviceCapabilityModel : DTDFVocab:Model [
    base:desc "Behavioral sub‑model describing sensor and actuator capabilities and control logic."
    DTDFVocab:inputTo AnalyticsEngine
]

// C2: Acting Components
instance HVACActuatorComponent : DTDFVocab:ActingComponent [
    base:desc "Actuator modeled in the BIM model for HVAC control, addressable via the twin for remote commands."
]

instance BuildingControllerComponent : DTDFVocab:ActingComponent [
    base:desc "Controller component defined in the BIM model, enabling the facility manager to issue control actions."
]

// C11: Enablers
instance EclipseHonoConnector : DTDFVocab:Enabler [
    base:desc "Eclipse Hono component providing MQTT/AMQP device connectivity for real‑time sensor ingestion."
    DTDFVocab:enables DataAcquisitionService
]

instance EclipseDittoStateManager : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto service managing digital‑twin state synchronization between physical assets and their virtual representations."
    DTDFVocab:enables TwinStateService
]

instance AnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Analytics plug‑in platform that processes incoming sensor data to compute operational insights such as energy trends and fault detection."
    DTDFVocab:enables EnergyAnalyticsService, FaultAnalyticsService
]

// C6: Services
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Service that ingests real‑time sensor streams via Eclipse Hono and forwards them to downstream analytics."
    DTDFVocab:provides RawSensorDataInsight
]

instance TwinStateService : DTDFVocab:Service [
    base:desc "Service that manages digital‑twin state synchronization using Eclipse Ditto."
    DTDFVocab:provides TwinStateInsight
]

instance EnergyAnalyticsService : DTDFVocab:Service [
    base:desc "Analytics service that processes energy measurement data to compute consumption trends."
    DTDFVocab:provides EnergyConsumptionInsight
]

instance FaultAnalyticsService : DTDFVocab:Service [
    base:desc "Analytics service that analyzes fault detection data to identify equipment anomalies."
    DTDFVocab:provides FaultDetectionInsight
]

// C17: Insights
instance RawSensorDataInsight : DTDFVocab:Insight [
    base:desc "Baseline insight representing the availability of raw sensor data for downstream processing."
]

instance TwinStateInsight : DTDFVocab:Insight [
    base:desc "Insight representing the current synchronized state of the building digital twin."
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight derived from energy measurements, showing consumption trends across the facility."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating detected faults or anomalies in building equipment based on sensor data."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Through the bidirectional data exchange hub, the digital twin can issue control commands back to the physical building, enabling Facility Managers to perform real‑time monitoring and control. The description mentions control flows from the DT to the physical system but does not detail command formats, validation/authentication mechanisms, conflict resolution, or execution confirmations."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a complete DT life‑cycle that starts with device modeling directly in the BIM environment (definition of sensors, actuators and controllers), proceeds to a model‑driven engineering (MDE) step that extracts a structured representation and automatically generates deployable DT artefacts, continues with runtime operation where real‑time data exchange keeps the physical building and its digital counterpart synchronised, and ends with interactive visualisation and modular extension points that allow facility managers and DT engineers to monitor, control and evolve the twin. Transition between stages is managed by the model‑driven deployment pipeline that governs the transformation from enriched BIM models to executable DT services, and governance is enforced through the framework’s modular architecture and standardized extension points."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system integrates Eclipse Hono and Eclipse Ditto for real‑time, bidirectional data exchange with physical assets. It leverages standardized integration frameworks and interoperability standards to connect external enterprise systems and other Digital Twins, enabling seamless incorporation of user‑centered control strategies."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework is built on the BIM standard as the core data model and employs standardized extension points within its modular architecture to promote interoperability across heterogeneous building automation components. It aims for compliance with BIM‑related specifications and supports integration with other systems through these generic, standards‑based interfaces, but no specific certification requirements or additional industry standards are cited."
]