// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Continuous temperature monitoring sensor integrated into BIM environment for real-time environmental condition tracking"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy detection sensor for real-time space utilization monitoring within building infrastructure"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance StructuralIntegritySensor : DTDFVocab:SensingComponent [
    base:desc "Structural health monitoring sensor for continuous assessment of building material integrity and load-bearing capacity"
    DTDFVocab:producedData StructuralDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Energy monitoring sensor tracking real-time consumption across building systems and equipment"
    DTDFVocab:producedData EnergyDataTransmitted
]

instance EnvironmentalConditionSensor : DTDFVocab:SensingComponent [
    base:desc "Comprehensive environmental monitoring sensor capturing humidity, air quality, and other operational parameters"
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance StructuralDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralIntegritySensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalConditionSensor
]

// C10: Models/Data
instance BuildingInformationModel : DTDFVocab:Model [
    base:desc "Foundational BIM model containing geometric, semantic, and lifecycle data of the physical building infrastructure"
    DTDFVocab:inputTo BimToDigitalTwinTransformationEnabler
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Aggregated runtime data from all sensor networks and operational systems synchronized with physical building state"
    DTDFVocab:fromData TemperatureDataTransmitted, OccupancyDataTransmitted, StructuralDataTransmitted, EnergyDataTransmitted, EnvironmentalDataTransmitted
    DTDFVocab:inputTo TimeSeriesDatabaseEnabler, GraphDatabaseEnabler
]

instance HistoricalPerformanceData : DTDFVocab:Data [
    base:desc "Longitudinal dataset containing asset degradation patterns, maintenance records, and operational history"
    DTDFVocab:inputTo PredictiveAnalyticsEnabler, OptimizationEnabler
]

instance SensorCalibrationData : DTDFVocab:Data [
    base:desc "Metadata and calibration parameters for all physical sensing components ensuring data accuracy"
    DTDFVocab:inputTo DataValidationEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Lightweight M2M service for secure protocol-agnostic data ingestion from heterogeneous IoT devices and legacy systems"
    DTDFVocab:enables RealTimeDataIngestionService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Digital twin framework providing device abstraction, state management, and real-time synchronization between physical and virtual assets"
    DTDFVocab:enables DigitalTwinSynchronizationService
]

instance BimToDigitalTwinTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Model-driven engineering solution converting enriched BIM models into deployable digital twin artifacts"
    DTDFVocab:enables DigitalTwinDeploymentService
]

instance TimeSeriesDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "High-performance database for storing and querying high-velocity operational data from sensor telemetry"
    DTDFVocab:enables RealTimeMonitoringService
]

instance GraphDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Graph database for maintaining semantic relationships between assets, stakeholders, and lifecycle events"
    DTDFVocab:enables DecisionSupportService
]

instance PredictiveAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "AI/ML framework implementing predictive maintenance algorithms and failure probability modeling"
    DTDFVocab:enables PredictiveMaintenanceService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimization solver platform applying data-driven algorithms for resource allocation and cost-efficiency scenarios"
    DTDFVocab:enables EnergyOptimizationService, SpaceUtilizationService
]

instance DataValidationEnabler : DTDFVocab:Enabler [
    base:desc "Data quality assurance module performing normalization, validation, and preprocessing of sensor data"
    DTDFVocab:enables AnomalyDetectionService
]

instance UnrealEngineEnabler : DTDFVocab:Enabler [
    base:desc "High-fidelity 3D/4D visualization engine enabling immersive digital twin experiences with physics-based simulations"
    DTDFVocab:enables VisualizationService
]

instance IndustryFoundationClassesEnabler : DTDFVocab:Enabler [
    base:desc "Standardized data exchange framework ensuring semantic interoperability between BIM and digital twin components"
    DTDFVocab:enables DataIntegrationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous data-driven observation of physical asset performance with anomaly detection and threshold-based alerts"
    DTDFVocab:provides RealTimePerformanceInsight, CriticalDeviationAlertAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Forecasting of asset degradation and maintenance needs using historical and real-time data"
    DTDFVocab:provides MaintenanceScheduleInsight, FailureProbabilityInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Data-driven optimization of energy consumption through HVAC system tuning and adaptive controls"
    DTDFVocab:provides EnergyEfficiencyInsight, CostReductionAction
]

instance SpaceUtilizationService : DTDFVocab:Service [
    base:desc "Optimization of space utilization through adaptive workflow planning and occupancy-based adjustments"
    DTDFVocab:provides SpaceEfficiencyInsight, WorkflowOptimizationAction
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Consolidation of disparate data sources into unified digital environment for multi-stakeholder collaboration"
    DTDFVocab:provides ConsolidatedDataInsight, EvidenceBasedRecommendationAction
]

instance SimulationAndAnalysisService : DTDFVocab:Service [
    base:desc "Virtual testing of design changes, operational strategies, and failure scenarios before physical implementation"
    DTDFVocab:provides ScenarioOutcomeInsight, RiskMitigationAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive interactive representations of physical asset with real-time sensor data visualization"
    DTDFVocab:provides ImmersiveVisualizationInsight, InteractiveControlAction
]

instance DigitalTwinSynchronizationService : DTDFVocab:Service [
    base:desc "Continuous bidirectional synchronization between physical building and digital representation"
    DTDFVocab:provides SynchronizationStatusInsight, DataAlignmentAction
]

instance RealTimeDataIngestionService : DTDFVocab:Service [
    base:desc "Secure protocol-agnostic ingestion of data from heterogeneous IoT devices and legacy systems"
    DTDFVocab:provides DataIngestionStatusInsight, ProtocolTranslationAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Identification of critical deviations from normal operational patterns"
    DTDFVocab:provides AnomalyDetectionInsight, AlertTriggerAction
]

instance DigitalTwinDeploymentService : DTDFVocab:Service [
    base:desc "Automated generation and deployment of digital twin artifacts from enriched BIM models"
    DTDFVocab:provides DeploymentStatusInsight, ArtifactValidationAction
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Standardized integration of heterogeneous data sources into unified digital twin environment"
    DTDFVocab:provides IntegrationStatusInsight, DataMappingAction
]

// C17: Insights/Actions
instance RealTimePerformanceInsight : DTDFVocab:Insight [
    base:desc "Continuous assessment of current building performance metrics against operational thresholds"
]

