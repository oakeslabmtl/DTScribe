// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor measuring presence of occupants in the living‑lab building"
    DTDFVocab:producedData MqttTelemetryPayload
]

instance AmbientLightSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient light sensor measuring illumination levels across corridors and rooms"
    DTDFVocab:producedData MqttTelemetryPayload
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring indoor temperature for HVAC control"
    DTDFVocab:producedData MqttTelemetryPayload
]

instance EnergyMeter : DTDFVocab:SensingComponent [
    base:desc "Energy meter tracking power consumption of lighting and HVAC systems"
    DTDFVocab:producedData MqttTelemetryPayload
]

// C4: Physical‑to‑virtual interaction
instance MqttTelemetryPayload : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor, AmbientLightSensor, TemperatureSensor, EnergyMeter
]

// C10: Models/Data
instance OccupancyData : DTDFVocab:Data [
    base:desc "Telemetry stream of occupancy counts from the living‑lab building"
    DTDFVocab:fromData MqttTelemetryPayload
    DTDFVocab:inputTo EclipseDitto
]

instance AmbientLightData : DTDFVocab:Data [
    base:desc "Telemetry stream of illumination levels from corridor LED panels"
    DTDFVocab:fromData MqttTelemetryPayload
    DTDFVocab:inputTo EclipseDitto
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Telemetry stream of indoor temperatures for HVAC zoning"
    DTDFVocab:fromData MqttTelemetryPayload
    DTDFVocab:inputTo EclipseDitto
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "Telemetry stream of power consumption from the energy meters"
    DTDFVocab:fromData MqttTelemetryPayload
    DTDFVocab:inputTo EclipseDitto
]

instance BIMModelIFC : DTDFVocab:Model [
    base:desc "Enriched IFC model including device definitions, middleware metadata, and building geometry"
    DTDFVocab:inputTo MDEPipeline
]

instance RuntimeAssetModelDitto : DTDFVocab:Model [
    base:desc "Ditto entity representations for runtime synchronization of devices"
    DTDFVocab:inputTo EclipseDitto
]

instance LightingControlLogicModel : DTDFVocab:Model [
    base:desc "Lighting curves and set‑point logic for corridor LED panels"
    DTDFVocab:inputTo MDEPipeline
]

instance HVACControlLogicModel : DTDFVocab:Model [
    base:desc "HVAC scheduling logic for zone vents and dampers"
    DTDFVocab:inputTo MDEPipeline
]

instance EnrichedMetadataModel : DTDFVocab:Model [
    base:desc "Device IDs, tenant IDs, and enriched metadata assembled into a unified digital twin"
    DTDFVocab:inputTo MDEPipeline
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "MQTT/HTTP‑based device connectivity controlled by Eclipse Hono broker"
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Device provisioning and property update engine for Ditto"
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalyticsEnergy, LightingOptimizationService, HVACSchedulingService, DesignScenarioSimulation, Immersive3DVisualizationUnreal
]

instance MDEPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven pipeline for transforming enriched IFC models into runtime artifacts"
    DTDFVocab:enables RealTimeMonitoringDashboard, PredictiveAnalyticsEnergy, LightingOptimizationService, HVACSchedulingService, DesignScenarioSimulation, Immersive3DVisualizationUnreal
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3‑D visualization of the building"
    DTDFVocab:enables Immersive3DVisualizationUnreal
]

instance GitRepository : DTDFVocab:Enabler [
    base:desc "Version‑control system for storing and managing model artifacts"
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard displaying occupancy, lighting, temperature, and energy data"
    DTDFVocab:provides OccupancyInsight, LightLevelInsight, TemperatureInsight, EnergyConsumptionInsight
]

instance PredictiveAnalyticsEnergy : DTDFVocab:Service [
    base:desc "Predictive analytics service forecasting future energy usage"
    DTDFVocab:provides EnergyConsumptionForecastInsight
]

instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Service recommending lighting optimization based on illumination data"
    DTDFVocab:provides LightingOptimizationRecommendationInsight
]

instance HVACSchedulingService : DTDFVocab:Service [
    base:desc "Service adjusting HVAC schedules to reduce load while maintaining comfort"
    DTDFVocab:provides HVACScheduleAdjustmentInsight
]

instance DesignScenarioSimulation : DTDFVocab:Service [
    base:desc "Simulation service for evaluating design iterations of the building envelope and internal layout"
    DTDFVocab:provides DesignIterationSuggestionInsight
]

instance Immersive3DVisualizationUnreal : DTDFVocab:Service [
    base:desc "Service delivering a live 3‑D rendering of the building in Unreal Engine 5"
    DTDFVocab:provides VisualizationInsight
]

// C17: Insights
instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of future energy usage derived from predictive analytics"
]

instance LightingOptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation for optimal lighting set‑points and usage patterns"
]

instance HVACScheduleAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Recommendation for adjusting HVAC zone schedules to improve efficiency"
]

instance MaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating maintenance needs for lighting fixtures and HVAC actuators"
]

instance DesignIterationSuggestionInsight : DTDFVocab:Insight [
    base:desc "Suggestion for design changes based on simulation outcomes"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight delivered through live 3‑D visualization in Unreal Engine"
]

instance OccupancyInsight : DTDFVocab:Insight [
    base:desc "Real‑time occupancy levels in each zone of the building"
]

instance LightLevelInsight : DTDFVocab:Insight [
    base:desc "Real‑time illumination levels measured by ambient light sensors"
]

instance TemperatureInsight : DTDFVocab:Insight [
    base:desc "Real‑time indoor temperature readings"
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Real‑time energy consumption data from meters"
]

// C2: Acting Components
instance CorridorLEDPanel : DTDFVocab:ActingComponent [
    base:desc "Corridor LED lighting fixture controlled via the building automation system"
]

instance ArchitecturalLightingFixture : DTDFVocab:ActingComponent [
    base:desc "Architectural lighting fixture integrated into the BIM model"
]

instance ZoneVent : DTDFVocab:ActingComponent [
    base:desc "HVAC zone vent actuator for airflow control"
]

instance ZoneDamper : DTDFVocab:ActingComponent [
    base:desc "HVAC dampers actuator regulating airflow between zones"
]

// C5: Environment
instance LivingLabBuilding : DTDFVocab:Environment [
    base:contains CorridorLEDPanel, ArchitecturalLightingFixture, ZoneVent, ZoneDamper
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (e.g., dimming levels for lighting, set‑point adjustments for HVAC) generated by the DT services and pushed back to the physical devices via Ditto topics, transmitted over MQTT through Hono to the device endpoints."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near‑real‑time synchronization with sub‑second telemetry updates and real‑time control loops; the DT operates continuously at a consistent data rate (≈ 1 Hz sensor reporting, immediate command propagation)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A unified DT ecosystem where individual system twins (lighting, HVAC, building envelope) are provisioned and managed via the Hono/Ditto middleware, coordinated by a central DT framework that exposes APIs for stakeholder interaction and service extensibility."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans all life‑cycle stages: (i) As‑designed phase captured in the BIM model, (ii) As‑manufactured phase during construction where data is mapped to physical assets, and (iii) As‑operated phase where real‑time data and control maintain the operational twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Consistency checks during model validation, OEQ‑simulated validation against physical measurements, monitoring of semantic drift via consecutive ODTE metrics, and the use of formal model checks to ensure that the digital twin remains valid over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Devices connect over MQTT with TLS encryption through the Eclipse Hono broker; Ditto exposes a JSON‑based REST interface (for provisioning) and an MQTT topic space; the DT framework acts as a middleware gateway between the physical devices and the virtual representation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT components (Hono, Ditto, Unreal Engine instance) are deployed on a containerized Kubernetes cluster hosted on a public cloud provider (e.g., AWS EKS or Azure AKS), with persistent storage for sensor logs and configuration artifacts."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standard IoT protocols (MQTT, REST) enable the twin to exchange data with external building management systems, energy trading platforms, and other DTs within an ecosystem, allowing cross‑building analytics and federated simulations."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to IFC 4.0 for BIM representation, MQTT as the underlying communication protocol, Ditto's JSON schema for device properties, and general industry best‑practice guidelines for model‑driven engineering."
]