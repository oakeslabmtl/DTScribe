// Acting Component
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Light fixture managed via LightTwinComponent, exposing power (on/off), brightness, and colour temperature (Kelvin) derived from photometric metadata."
]

// Sensing Components
instance HVACTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor for the HVAC system, measuring ambient room temperature in the office building."
    DTDFVocab:producedData HVACTempDataTransmitted
]

instance LightingIlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor for lighting control, measuring lux levels in occupied zones."
    DTDFVocab:producedData LightingIlluminanceDataTransmitted
]

instance StructuralIntegritySensor : DTDFVocab:SensingComponent [
    base:desc "Structural sensor measuring strain and vibration metrics to monitor building integrity."
    DTDFVocab:producedData StructuralIntegrityDataTransmitted
]

// Data Transmitted Instances
instance HVACTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACTemperatureSensor
]

instance LightingIlluminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingIlluminanceSensor
]

instance StructuralIntegrityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralIntegritySensor
]

// Data Instances
instance HVACTemperatureData : DTDFVocab:Data [
    base:desc "Temperature measurement data from HVACTemperatureSensor, persisted in Eclipse Ditto."
    DTDFVocab:fromData HVACTempDataTransmitted
    DTDFVocab:inputTo EclipseDittoStorage
]

instance LightingIlluminanceData : DTDFVocab:Data [
    base:desc "Illuminance measurement data from LightingIlluminanceSensor, persisted in Eclipse Ditto."
    DTDFVocab:fromData LightingIlluminanceDataTransmitted
    DTDFVocab:inputTo EclipseDittoStorage
]

instance StructuralIntegrityData : DTDFVocab:Data [
    base:desc "Structural measurement data from StructuralIntegritySensor, persisted in Eclipse Ditto."
    DTDFVocab:fromData StructuralIntegrityDataTransmitted
    DTDFVocab:inputTo EclipseDittoStorage
]

// Model Instances
instance BuildingGeometricModel : DTDFVocab:Model [
    base:desc "Geometric representation of the multi‑storey office building derived from BIM geometry."
    DTDFVocab:inputTo EclipseDittoStorage
]

instance BuildingBehaviouralModel : DTDFVocab:Model [
    base:desc "Behavioural model encoding control logic via custom twin components such as LightTwinComponent."
    DTDFVocab:inputTo EclipseDittoStorage
]

instance BuildingAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model capturing photometric data for lighting control."
    DTDFVocab:inputTo EclipseDittoStorage
]

// Enabler Instances
instance EclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT broker delivering telemetry at least‑once, bridging physical assets to the twin."
    DTDFVocab:enables RealTimeMonitoringService, DirectControlService
]

instance EclipseDittoStorage : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto persistence service storing twin state and incoming telemetry."
    DTDFVocab:enables PredictiveAnalyticsService, OptimizationService, VisualizationDashboardService
]

// Service Instances
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building subsystems, ingesting live telemetry from sensors."
    DTDFVocab:provides RealTimeOperationalInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy consumption and fault detection using historical and real‑time data."
    DTDFVocab:provides EnergyConsumptionPredictionInsight, FaultDetectionAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization routines balancing comfort versus cost across building operations."
    DTDFVocab:provides ComfortCostTradeoffInsight
]

instance DirectControlService : DTDFVocab:Service [
    base:desc "Direct control over HVAC and lighting actuators via Eclipse Ditto commands."
    DTDFVocab:provides DirectHVACControlAction
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Immersive visualization dashboards presenting facility managers with real‑time building states."
    DTDFVocab:provides VisualInteractionInsight
]

// Insight Instances
instance RealTimeOperationalInsight : DTDFVocab:Insight [
    base:desc "Insight reporting live operational status of building subsystems."
]

instance EnergyConsumptionPredictionInsight : DTDFVocab:Insight [
    base:desc "Insight predicting future energy consumption patterns based on predictive analytics."
]

instance ComfortCostTradeoffInsight : DTDFVocab:Insight [
    base:desc "Insight illustrating trade‑offs between occupant comfort and energy cost."
]

instance VisualInteractionInsight : DTDFVocab:Insight [
    base:desc "Insight enabling interactive exploration of the building model in Unreal Engine 5."
]

// Action Instances
instance FaultDetectionAction : DTDFVocab:Action [
    base:desc "Action triggering alerts and remediation procedures upon fault detection."
    DTDFVocab:IsAutomatic false
]

instance DirectHVACControlAction : DTDFVocab:Action [
    base:desc "Action issuing HVAC control commands directly via Ditto commands."
    DTDFVocab:IsAutomatic false
]

// Component Instances
instance LightTwinActuatorComponent : DTDFVocab:Component [
    base:desc "Light fixture actuator component controlled by LightTwinComponent, exposing power, brightness, and colour temperature."
]

instance HVACActuatorComponent : DTDFVocab:Component [
    base:desc "HVAC unit actuator component controllable through Ditto commands."
]

instance HVACTemperatureSensorComponent : DTDFVocab:Component [
    base:desc "Component representing the HVAC temperature sensor."
]

instance LightingIlluminanceSensorComponent : DTDFVocab:Component [
    base:desc "Component representing the lighting illuminance sensor."
]

instance StructuralIntegritySensorComponent : DTDFVocab:Component [
    base:desc "Component representing the structural integrity sensor."
]

// Environment Instance
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains LightTwinActuatorComponent, HVACActuatorComponent, HVACTemperatureSensorComponent, LightingIlluminanceSensorComponent, StructuralIntegritySensorComponent
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design and BIM enrichment: building control engineers model devices, sensors, actuators, and controllers directly within BIM, creating an object‑based 3D model enriched with functional attributes (BCS components). Transformation step: an MDE engine extracts structured representations from the enriched BIM and automatically generates deployable DT artifacts, minimizing manual intervention. Deployment stage: an automated deployment process (R2) produces reproducible DT setups, provisioning service instances and configuration files. Runtime operation: real‑time data exchange via Eclipse Hono (IoT messaging) and Eclipse Ditto (asset registry) keeps the DT synchronized with physical assets. Evolution and governance: a modular architecture (R4) defines extension points that allow adding custom services and analysis plugins, enabling a service‑oriented evolution. The entire process is governed by semantic integration, real‑time connectivity, and extensibility requirements."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The twin’s fidelity is ensured through multiple layers of validation.  Eclipse Ditto’s policy engine continuously checks sensor values against declared units and range constraints, rejecting invalid data to maintain consistency.  Pre‑execution validation for actuator commands guarantees that commands do not conflict with physical constraints.  Fault tolerance is provided by Eclipse Hono’s at‑least‑once delivery guarantee and Ditto’s persistent event storage, ensuring resilience against network failures.  Synchronisation quality is quantified by the Overall Digital Twin Entanglement (ODTE) metric, calculated as the product of timeliness (0.997 over a 12‑minute window, measured with a 1‑second heartbeat), reliability (1.0, no lost messages), and availability (1.0, full uptime), yielding an overall score of 0.997.  These metrics, combined with policy‑based validation and pre‑execution checks, serve as the primary quality assurance processes for models and data, ensuring a high‑fidelity relationship between the digital and physical systems."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Configured around a message‑oriented middleware stack that combines Eclipse Hono as the connectivity broker and Eclipse Ditto as the device twin abstraction layer. The architecture enables real‑time, bi‑directional communication between edge devices (building controls) and the central server, supporting scalability through modular extension points. Specific details about protocol versions, bandwidth, latency, redundancy, and security mechanisms are not specified in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The framework is designed for model‑driven deployment that allows automated installation and configuration across a range of hosting environments, from on‑premise servers to cloud or edge platforms. It incorporates runtime configuration management for dynamic adjustment, and a modular architecture encourages deployment of custom services. Exact computational, storage, and scalability requirements, as well as deployment models and availability guarantees, are not detailed in the documents."
]