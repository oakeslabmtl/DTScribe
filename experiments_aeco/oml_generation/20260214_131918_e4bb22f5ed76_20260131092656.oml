// SensingComponents
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM, streaming occupancy data to DT."
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance PhotopicLightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Photopic light level sensor modeled in BIM, publishing light intensity readings."
    DTDFVocab:producedData LightLevelDataTransmitted
]
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in BIM, transmitting ambient temperature readings."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance CO2ConcentrationSensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ concentration sensor modeled in BIM, sending CO₂ level data."
    DTDFVocab:producedData CO2DataTransmitted
]

// DataTransmitted
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhotopicLightLevelSensor
]
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2ConcentrationSensor
]

// Data
instance OccupancyTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data of occupancy readings stored in Ditto twin store."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo DittoTwinStoreEnabler, HonoDittoMiddlewareEnabler
]
instance LightLevelTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data of light level readings stored in Ditto twin store."
    DTDFVocab:fromData LightLevelDataTransmitted
    DTDFVocab:inputTo DittoTwinStoreEnabler, HonoDittoMiddlewareEnabler
]
instance TemperatureTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data of temperature readings stored in Ditto twin store."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DittoTwinStoreEnabler, HonoDittoMiddlewareEnabler
]
instance CO2TelemetryData : DTDFVocab:Data [
    base:desc "Telemetry data of CO₂ concentration readings stored in Ditto twin store."
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo DittoTwinStoreEnabler, HonoDittoMiddlewareEnabler
]

// Enablers
instance DittoTwinStoreEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that enables persistence of DT data in the Ditto twin store."
    DTDFVocab:enables DataPersistService
]
instance HonoDittoMiddlewareEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that integrates Eclipse Hono and Ditto middleware for data ingestion."
    DTDFVocab:enables RealTimeMonitoringDashboardService, LightingControlOptimizationEngineService,
                PredictiveAnalyticsService, EnvironmentalPerformanceSimulationService,
                FacilityOperationalAnalyticsService
]
instance RevitBIMExtractionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that uses Revit to extract BIM data for DT modeling."
    DTDFVocab:enables RevitBIMExtractionService
]
instance CustomMetamodelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that applies the custom metamodel for BCS devices."
    DTDFVocab:enables CustomMetamodelService
]
instance UnrealEngine5VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that provides interactive 3D visualization via Unreal Engine 5."
    DTDFVocab:enables Unreal3DVisualizationService
]
instance HonoDittoConfiguratorEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that auto-generates deployment artefacts via Hono/Ditto Configurator."
    DTDFVocab:enables ConfiguratorService
]

// Services
instance DataPersistService : DTDFVocab:Service [
    base:desc "Service that persists DT telemetry data into Ditto twin store."
    DTDFVocab:provides DataRetentionInsight
]
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Service that aggregates live telemetry for real‑time monitoring dashboards."
    DTDFVocab:provides RealTimeMonitoringInsight
]
instance LightingControlOptimizationEngineService : DTDFVocab:Service [
    base:desc "Service that optimizes lighting via reinforcement‑learning from BOREALIS."
    DTDFVocab:provides OptimalLightingScheduleInsight, LightingControlAction
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service that generates predictive maintenance alerts and energy forecasts."
    DTDFVocab:provides PredictiveMaintenanceAlertInsight, EnergyConsumptionForecastInsight
]
instance EnvironmentalPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Service that simulates environmental performance of the building."
    DTDFVocab:provides SimulationInsight
]
instance FacilityOperationalAnalyticsService : DTDFVocab:Service [
    base:desc "Service that provides operational analytics for facility management."
    DTDFVocab:provides DecisionSupportDashboardInsight, HVACControlAction
]
instance RevitBIMExtractionService : DTDFVocab:Service [
    base:desc "Service that extracts enriched BIM data from Revit."
    DTDFVocab:provides BIMExtractionInsight
]
instance CustomMetamodelService : DTDFVocab:Service [
    base:desc "Service that applies the custom BCS device metamodel."
    DTDFVocab:provides MetamodelInsight
]
instance Unreal3DVisualizationService : DTDFVocab:Service [
    base:desc "Service that delivers 3‑D visualization using Unreal Engine 5."
    DTDFVocab:provides ThreeDVisualizationInsight
]
instance ConfiguratorService : DTDFVocab:Service [
    base:desc "Service that auto‑generates deployment artefacts from enriched BIM."
    DTDFVocab:provides ConfiguratorInsight
]

// Insights
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight that visualizes real‑time telemetry for facility managers."
]
instance OptimalLightingScheduleInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal lighting schedules based on occupancy and daylight."
]
instance HVACSetpointAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting HVAC setpoint adjustments for energy balance."
]
instance PredictiveMaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Insight alerting facility managers to predictive maintenance needs."
]
instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Insight forecasting future energy consumption patterns."
]
instance DecisionSupportDashboardInsight : DTDFVocab:Insight [
    base:desc "Insight presented in decision‑support dashboards for facility managers."
]
instance DataRetentionInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful retention of telemetry data."
]
instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from simulation of environmental performance."
]
instance BIMExtractionInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful extraction of enriched BIM data."
]
instance MetamodelInsight : DTDFVocab:Insight [
    base:desc "Insight confirming application of custom BCS device metamodel."
]
instance ThreeDVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing interactive 3‑D visualization of the building."
]
instance ConfiguratorInsight : DTDFVocab:Insight [
    base:desc "Insight confirming auto‑generation of deployment artefacts."
]

// Actions
instance LightingControlAction : DTDFVocab:Action [
    base:desc "Action that sends dimming commands to LED lighting fixtures via Hono/Ditto."
    DTDFVocab:IsAutomatic true
]
instance HVACControlAction : DTDFVocab:Action [
    base:desc "Action that sends valve/damper commands to HVAC actuators via Hono/Ditto."
    DTDFVocab:IsAutomatic true
]

// Acting Components (Actuators)
instance LEDLightingActuator : DTDFVocab:ActingComponent [
    base:desc "Dimmable LED lighting fixture represented in the enriched BIM model."
]
instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve actuator represented in the enriched BIM model."
]

// Models
instance IFCEnrichedBIMModel : DTDFVocab:Model [
    base:desc "Core DT model: IFC-based BIM enriched with control semantics."
    DTDFVocab:inputTo RevitBIMExtractionEnabler, CustomMetamodelEnabler
]
instance StateMachineModelOfBCS : DTDFVocab:Model [
    base:desc "State machine model of Building Control System for runtime integration."
    DTDFVocab:inputTo CustomMetamodelEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control directives generated by the DT—e.g., lighting dimming levels, HVAC setpoints, or schedule adjustments—are transmitted back to the physical system through Ditto’s command channel over Hono, enabling bidirectional interaction."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time data streaming at millisecond‑level update rates for telemetry, with higher‑level optimization and scenario simulation executed on a continuous or event‑driven basis; synchronization between PT and DT is maintained via Hono/Ditto in near‑real‑time."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated ecosystem consisting of the enriched BIM, Hono/Ditto middleware, 3D real‑time rendering in UE5, microservice‑based actuators, and extension points for custom analytics services; all components communicate through defined MQTT topics and APIs."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin covers the full building life‑cycle: (1) Design—modeling of ideal as‑designed BIM; (2) Construction—mapping of as‑built BIM and device configuration; (3) Operation—runtime monitoring, optimization and data‑driven maintenance."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validity is verified by comparing BIM topology against as‑built measurements; synchronization fidelity is monitored via the Overall Digital Twin Entanglement (ODTE) metric; semantic drift is mitigated using runtime metadata checking; uncertainty from sensor noise is filtered by pre‑processing pipelines."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional MQTT communication over TLS, using Eclipse Hono endpoints to route telemetry and command messages to Ditto twin topics; data flows via REST/HTTP for configuration and via CoAP for lightweight control where needed."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin is deployed in a containerised microservices stack, orchestrated by Kubernetes on a cloud or on‑premises edge gateway; Ditto twin store and Hono broker run in separate pods, with Unreal Engine rendering service accessible via WebSocket."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external BMS, building analytics platforms, and external data sources via standard MQTT/HTTP APIs, enabling data exchange with other Digital Twins or enterprise systems; the platform supports cross‑domain interoperability through open standards."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Sensor data originates from the building operators and is owned by the PT owner; the DT service provider stores and processes data in compliance with GDPR, ensuring privacy controls and access governance."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The engineering workflow follows BIM IFC standards for geometry, uses the Ditto data schema, and conforms to MQTT and REST communication standards; the model‑driven approach applies MDE best practices and leverages the ODTE metric for interoperability assessment."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Secure communication is enforced via TLS encryption and fine‑grained access control in Hono and Ditto; operation safety is ensured by implementing fail‑safe controls, redundancy and runtime validation before pushing commands to physical devices."
]