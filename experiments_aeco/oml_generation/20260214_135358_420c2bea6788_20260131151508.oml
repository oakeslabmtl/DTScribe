// C2: Acting Components
instance IlluminanceControlActuator : DTDFVocab:ActingComponent [
    base:desc "Dimming control actuator embedded in the BIM, capable of adjusting light levels based on DT commands."
]
instance OnOffSwitchActuator : DTDFVocab:ActingComponent [
    base:desc "On/Off switch actuator for lighting fixtures, controlled by the DT’s control logic to power lighting devices."
]
instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture actuator that receives brightness and on/off commands from the DT’s lighting control policy."
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor integrated into the building, used for detecting presence and generating occupancy data streams."
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring room temperature for heating and cooling control, contributing data streams to the DT."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor measuring indoor air quality, providing CO₂ concentration data streams to the DT."
    DTDFVocab:producedData CO2DataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

// C10: Models/Data (Data instances)
instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy data stream captured by the DT for predictive analytics and reinforcement learning control loops."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature data stream captured by the DT for heating/cooling control and predictive analytics."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]
instance CO2Data : DTDFVocab:Data [
    base:desc "CO₂ data stream captured by the DT for indoor air quality monitoring and control."
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// C10: Models/Data (Model instances)
instance BIMtoMMDEModel : DTDFVocab:Model [
    base:desc "BIM model transformed via model-to-model MDE pipeline for runtime artifact generation."
    DTDFVocab:inputTo MDEEnabler
]
instance DittoDeviceModel : DTDFVocab:Model [
    base:desc "Ditto device model representing individual sensors and actuators in the digital twin."
    DTDFVocab:inputTo EclipseDittoEnabler
]
instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Object-oriented control logic model defining lighting and HVAC control policies."
    DTDFVocab:inputTo EclipseDittoEnabler
]
instance ReinforcementLearningPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement learning policy model used to update control decisions based on post-occupancy data."
    DTDFVocab:inputTo MDEEnabler
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for secure IoT messaging, ingesting telemetry data into the DT."
    DTDFVocab:enables DataIngestionService
]
instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for device twin management, storing sensor and actuator metadata."
    DTDFVocab:enables TwinManagementService
]
instance MDEEnabler : DTDFVocab:Enabler [
    base:desc "MDE tools for model extraction and code generation, converting enriched BIM into runtime artifacts."
    DTDFVocab:enables ModelConversionService
]
instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3D visualization of building performance."
    DTDFVocab:enables ImmersiveVisualizationService
]
instance HonoDittoConfiguratorEnabler : DTDFVocab:Enabler [
    base:desc "Hono/Ditto Configurator for automated deployment of device twins and communication configurations."
    DTDFVocab:enables ConfiguratorDeploymentService
]

// C6: Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service responsible for ingesting real-time telemetry data from Eclipse Hono."
    DTDFVocab:provides RealtimeMonitoringInsight
]
instance TwinManagementService : DTDFVocab:Service [
    base:desc "Service managing device twins within Eclipse Ditto."
    DTDFVocab:provides TwinStatusInsight
]
instance ModelConversionService : DTDFVocab:Service [
    base:desc "Service converting validated BIM models into runtime artifacts via MDE pipelines."
    DTDFVocab:provides ModelConversionInsight
]
instance ConfiguratorDeploymentService : DTDFVocab:Service [
    base:desc "Service that automates deployment of device twins and configurations through Hono/Ditto."
    DTDFVocab:provides DeploymentStatusInsight
]
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real-time monitoring of building conditions."
    DTDFVocab:provides RealtimeBuildingStatusInsight
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service delivering predictive analytics for occupancy, energy consumption, and indoor comfort."
    DTDFVocab:provides OccupancyPatternInsight, EnergyConsumptionForecastInsight, IndoorComfortImprovementInsight
]
instance EnergyLightingOptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing energy use and lighting schedules based on predictive analytics."
    DTDFVocab:provides LightingScheduleAdjustmentAction, EnergyConsumptionAdjustmentAction
]
instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Service rendering immersive 3D visualizations of building performance in Unreal Engine 5."
    DTDFVocab:provides VisualizationInsight
]

// C17: Insights
instance RealtimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight into current building occupancy and environmental conditions."
]
instance TwinStatusInsight : DTDFVocab:Insight [
    base:desc "Insight into the status of device twins within Ditto."
]
instance ModelConversionInsight : DTDFVocab:Insight [
    base:desc "Insight on the success of BIM to runtime artifact conversion via MDE."
]
instance DeploymentStatusInsight : DTDFVocab:Insight [
    base:desc "Insight into the deployment status of device twins and communication configurations."
]
instance RealtimeBuildingStatusInsight : DTDFVocab:Insight [
    base:desc "Insight summarizing real-time building status for stakeholders."
]
instance OccupancyPatternInsight : DTDFVocab:Insight [
    base:desc "Predicted occupancy patterns used for scheduling and control."
]
instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasted energy consumption for optimal budgeting and scheduling."
]
instance IndoorComfortImprovementInsight : DTDFVocab:Insight [
    base:desc "Recommendations to improve indoor comfort based on temperature and CO₂ data."
]
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of building performance in Unreal Engine 5."
]

// C17: Actions
instance LightingScheduleAdjustmentAction : DTDFVocab:Action [
    base:desc "Action adjusting lighting schedules based on predictive analytics and RL policies."
    DTDFVocab:IsAutomatic true
]
instance EnergyConsumptionAdjustmentAction : DTDFVocab:Action [
    base:desc "Action reducing energy consumption by optimizing HVAC and lighting control."
    DTDFVocab:IsAutomatic true
]
instance ComfortLevelAdjustmentAction : DTDFVocab:Action [
    base:desc "Action adjusting HVAC setpoints to improve indoor comfort."
    DTDFVocab:IsAutomatic true
]
instance ReinforcementLearningPolicyUpdateAction : DTDFVocab:Action [
    base:desc "Action deploying updated reinforcement learning control policies into the DT."
    DTDFVocab:IsAutomatic true
]

// C17: Environment and Components
instance LivingLabEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, TemperatureSensor, CO2Sensor, IlluminanceControlActuator, OnOffSwitchActuator, LightingFixtureActuator
]
instance BuildingComponent : DTDFVocab:Component [
    base:desc "Main building structure represented within the digital twin."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT emits control signals back to the building automation system via Ditto to Hono forwarding, using MQTT to deliver actuator commands to the physical hardware, enabling bidirectional, low‑latency interaction."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization, with sensor data and control feedback exchanged online as part of the DT’s operational loop."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture comprising the Hono/Ditto Configurator, a BIM metadata extractor, a simulation engine, an analytics service, and a visualization gateway, orchestrated to provide end‑to‑end DT functionality."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin encapsulates design‑time BIM data, construction (manufactured) metadata, and operational data streams, thus operating across all lifecycle stages from ideal design, through installation, to ongoing operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric used to quantify physical‑digital alignment; simulation models validated against measured energy consumption; uncertainty propagated through sensor fusion."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT mediated by Eclipse Hono and Ditto middleware, enabling secure, standardized data exchange without specifying lower‑level protocols."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Utilizes BIM (IFC/ISO 16739) as the underlying data model; adherence to AECO sector practices is implied but no explicit standardization beyond BIM is described."
]