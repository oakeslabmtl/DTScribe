// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in the enriched BIM model, publishing measurements via Eclipse Hono"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light level sensor defined in the enriched BIM model, publishing measurements via Eclipse Hono"
    DTDFVocab:producedData LightDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance LightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature telemetry from the building"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo HonoDittoMiddleware
]

instance LightLevelData : DTDFVocab:Data [
    base:desc "Real‑time light level telemetry from the building"
    DTDFVocab:fromData LightDataTransmitted
    DTDFVocab:inputTo HonoDittoMiddleware
]

// C11: Enablers
instance HonoDittoMiddleware : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for at‑least‑once MQTT/HTTP ingestion and Eclipse Ditto for persistent storage and policy‑based validation"
    DTDFVocab:enables DataSynchronizationService, RealTimeMonitoringService, DeviceControlService
]

instance TwinComponentEngine : DTDFVocab:Enabler [
    base:desc "Framework that hosts TwinComponents (e.g., LightTwinComponent) and maps device metadata to UE5 visual entities"
    DTDFVocab:enables RealTimeMonitoringService, DeviceControlService
]

instance UE5VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 based interactive 3D visualization platform for operator interaction"
    DTDFVocab:enables InteractiveVisualizationService, ExtensiblePlatformService
]

// C6: Services
instance DataSynchronizationService : DTDFVocab:Service [
    base:desc "Continuous bidirectional synchronization between physical building sensors/actuators and their digital twin representations"
    DTDFVocab:provides SynchronizationInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of system states derived from sensor streams"
    DTDFVocab:provides OperationalStateInsight
]

instance DeviceControlService : DTDFVocab:Service [
    base:desc "Control of physical actuators (e.g., lighting fixtures) via commands routed through UE5, UnrealTwinController, DittoController, and Eclipse Hono"
    DTDFVocab:provides SwitchLightAction, AdjustBrightnessAction, AdjustColorTempAction, OperateDeviceAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization allowing facility managers to inspect and operate building infrastructure in UE5"
    DTDFVocab:provides OperationalStateInsight
]

instance ExtensiblePlatformService : DTDFVocab:Service [
    base:desc "Extensible platform for adding custom analytics and services through defined extension points (TwinComponent, FeatureParser)"
    // No explicit insight/action required by the source document
]

// C17: Insights
instance OperationalStateInsight : DTDFVocab:Insight [
    base:desc "Provides operational insight for facility managers to monitor system states and make decisions"
]

instance SynchronizationInsight : DTDFVocab:Insight [
    base:desc "Indicates synchronization status between the physical building and its digital twin"
]

// C17: Actions
instance SwitchLightAction : DTDFVocab:Action [
    base:desc "Turn a lighting fixture on or off"
    DTDFVocab:IsAutomatic false
]

instance AdjustBrightnessAction : DTDFVocab:Action [
    base:desc "Adjust the brightness level of a lighting fixture"
    DTDFVocab:IsAutomatic false
]

instance AdjustColorTempAction : DTDFVocab:Action [
    base:desc "Adjust the colour‑temperature (Kelvin) of a lighting fixture"
    DTDFVocab:IsAutomatic false
]

instance OperateDeviceAction : DTDFVocab:Action [
    base:desc "Send a generic control command to any actuator device"
    DTDFVocab:IsAutomatic false
]

// C10: Models/Data (semantic backbone)
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched Building Information Model containing geometric, semantic, sensor and actuator definitions"
    DTDFVocab:inputTo HonoDittoMiddleware, TwinComponentEngine
]

instance TwinComponentModel : DTDFVocab:Model [
    base:desc "Model describing TwinComponents that map device metadata (e.g., photometric values) to UE5 visual entities"
    DTDFVocab:inputTo TwinComponentEngine, UE5VisualizationEngine
]

instance DeviceDefinitionModel : DTDFVocab:Model [
    base:desc "Model generated by the MDE pipeline embedding sensor, actuator, and controller definitions into the BIM"
    DTDFVocab:inputTo HonoDittoMiddleware, TwinComponentEngine
]

// C2: Acting components (example actuator)
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "TwinComponent representing a lighting fixture, supporting on/off, dimming (brightness) and colour‑temperature adjustments; commands flow through UnrealTwinController → DittoController → DittoDevice → Eclipse Hono"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Interactive visualisation interfaces allow Facility Managers to monitor and issue control commands to physical building assets through the digital twin. Real‑time monitoring and control are supported, but the documents do not describe command formats, validation/authentication mechanisms, feedback loops, conflict resolution, or execution confirmations."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange capabilities provide continuous synchronization between the physical building and its digital twin; the framework operates in a real‑time mode, but the documents do not specify exact synchronization frequencies, latency bounds, or temporal granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, service‑oriented constellation where the DT Framework acts as a central hub orchestrating bidirectional data exchange, integrating custom analytics services via standardized extension points, and allowing runtime re‑configuration without full redeployment."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Supports the complete DT lifecycle from initial device modeling within BIM (defining sensors, actuators, controllers), model extraction via model‑driven engineering (MDE), automatic generation of deployable DT artifacts, deployment, runtime operation with continuous real‑time data exchange, interactive visualization for monitoring/control, and modular extension through standardized plug‑in points, all governed by the model‑driven deployment framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity and data quality are maintained by a multi‑layer validation pipeline. During the conversion stage, the framework validates enriched BIM models against schema constraints. Eclipse Ditto enforces policy‑based validation on both incoming sensor streams (checking ranges, units) and outgoing actuator commands (pre‑execution safety checks). Fault tolerance is achieved through Eclipse Hono’s at‑least‑once message delivery and Ditto’s persistent event storage, which together guarantee synchronization despite network interruptions. The use of the Observable pattern in the UnrealTwinController and FeatureParserControllers facilitates runtime error detection and corrective propagation. These mechanisms collectively provide verification, uncertainty mitigation and quality assurance for the DT’s geometric, behavioural and analytical models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The solution adopts a modular architecture with standardized extension points to achieve interoperability across heterogeneous systems and supports scalability from component level to whole‑infrastructure level. Specific network protocols, topology, bandwidth, latency, redundancy, or security details are not disclosed in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability across heterogeneous systems is addressed through standardized extension points that enable integration of external services and enterprise systems, supporting scalability and low‑overhead updates; specific data‑exchange protocols or standards are not detailed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The documents note that many AECO DT solutions lack standardized data schemas and rely on generic IoT standards; existing open‑source frameworks such as Eclipse Ditto and BaSyx provide standard‑compliant connectivity, while Bentley’s iTwin.js uses proprietary APIs. The proposed framework aims to bridge BIM with DT but does not specify adherence to particular industry standards, certifications, or interoperability specifications."
]