// Enablers
instance HonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT broker handling telemetry routing."
    DTDFVocab:enables DittoService
]

instance DittoService : DTDFVocab:Service [
    base:desc "Eclipse Ditto device twin service storing twin states."
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine⁵ enabling immersive 3D visualization."
    DTDFVocab:enables Immersive3DVisualizationService
]

instance MDETransformationTools : DTDFVocab:Enabler [
    base:desc "MDE transformation tools converting enriched BIM into Ditto twin definitions."
]

instance ModelValidationAPI : DTDFVocab:Enabler [
    base:desc "Standard APIs validating models within ~5% tolerance."
]

instance ReinforcementLearningBorealis : DTDFVocab:Enabler [
    base:desc "Reinforcement learning engine in BOREALIS refining control policies."
    DTDFVocab:enables ControlPolicyRefinementService
]

// Sensors
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in each zone, publishes data to Eclipse Hono."
    DTDFVocab:producedData TemperatureDataPacket
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor embedded in each zone, publishes data to Eclipse Hono."
    DTDFVocab:producedData HumidityDataPacket
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor embedded in each zone, publishes data to Eclipse Hono."
    DTDFVocab:producedData IlluminanceDataPacket
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor embedded in each zone, publishes data to Eclipse Hono."
    DTDFVocab:producedData CO2DataPacket
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in each zone, publishes data to Eclipse Hono."
    DTDFVocab:producedData OccupancyDataPacket
]

// Data transmitted
instance TemperatureDataPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance IlluminanceDataPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]

instance CO2DataPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance OccupancyDataPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature measurement received as JSON from Eclipse Hono."
    DTDFVocab:fromData TemperatureDataPacket
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity measurement received as JSON from Eclipse Hono."
    DTDFVocab:fromData HumidityDataPacket
]

instance IlluminanceData : DTDFVocab:Data [
    base:desc "Illuminance measurement received as JSON from Eclipse Hono."
    DTDFVocab:fromData IlluminanceDataPacket
]

instance CO2Data : DTDFVocab:Data [
    base:desc "CO₂ measurement received as JSON from Eclipse Hono."
    DTDFVocab:fromData CO2DataPacket
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy measurement received as JSON from Eclipse Hono."
    DTDFVocab:fromData OccupancyDataPacket
]

// Models / Data definitions
instance IFCBIMModel : DTDFVocab:Model [
    base:desc "BIM IFC model of the Living Lab building."
]

instance RuntimeConfigModel : DTDFVocab:Model [
    base:desc "Runtime configuration model generated by MDE pipeline."
]

instance ThermalDynamicsModel : DTDFVocab:Model [
    base:desc "Simulation model for thermal dynamics."
]

instance SensorDataStream : DTDFVocab:Model [
    base:desc "Continuous sensor data streams stored in Ditto registry."
]

// Acting components
instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture mapped to device twin for remote actuation."
]

instance HVACUnitActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC unit mapped to device twin for remote actuation."
]

instance AutomatedBlindsActuator : DTDFVocab:ActingComponent [
    base:desc "Automated blinds mapped to device twin for remote actuation."
]

// Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards displaying live sensor states."
    DTDFVocab:provides EnergyReportInsight, AnomalyAlertInsight
]

instance PredictiveEnergyAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy forecasting."
    DTDFVocab:provides EnergyForecastInsight
]

instance LightingScheduleOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes lighting schedules based on occupancy and illuminance."
    DTDFVocab:provides OptimizationRecommendationInsight, AdjustLightingAction
]

instance HVACSetpointSchedulingService : DTDFVocab:Service [
    base:desc "Schedules HVAC setpoints to balance comfort and energy efficiency."
    DTDFVocab:provides SetHVACScheduleAction
]

instance RuntimeThermalSimulationService : DTDFVocab:Service [
    base:desc "Runtime thermal simulation for predictive maintenance."
    DTDFVocab:provides ThermodynamicSimulationInsight
]

instance Immersive3DVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D visualization using Unreal Engine⁵."
    DTDFVocab:provides ImmersiveVisualizationInsight
]

instance ControlPolicyRefinementService : DTDFVocab:Service [
    base:desc "Refines control policies via reinforcement learning in BOREALIS."
    DTDFVocab:provides RefineControlPolicyAction
]

// Insights
instance EnergyReportInsight : DTDFVocab:Insight [
    base:desc "Dashboard summary of energy consumption."
]

instance EnergyForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasted energy usage based on predictive analytics."
]

instance AnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Alerts for anomalous patterns in sensor data."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendations for lighting and HVAC."
]

instance ThermodynamicSimulationInsight : DTDFVocab:Insight [
    base:desc "Insights from runtime thermal simulation."
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive visualization representation of building state."
]

// Actions
instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Automatically adjusts lighting levels based on occupancy and illuminance."
    DTDFVocab:IsAutomatic true
]

instance SetHVACScheduleAction : DTDFVocab:Action [
    base:desc "Sets HVAC setpoints according to optimized schedule."
    DTDFVocab:IsAutomatic true
]

instance OperateBlindsAction : DTDFVocab:Action [
    base:desc "Operates automated blinds to manage daylight."
    DTDFVocab:IsAutomatic false
]

instance RefineControlPolicyAction : DTDFVocab:Action [
    base:desc "Refines control policies using reinforcement learning."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands to Ditto device twins; these commands are transmitted via Hono to the building automation controllers, enabling remote actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data exchange occurs continuously with microsecond latency over MQTT; control loops run at ≈1‑second intervals; simulations run in real time matching the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of a central twin orchestration service, a set of component twins, an MQTT broker, and a 3D visualization front‑end; all are interconnected via standardized JSON over HTTP/MQTT following the Ditto and Hono specifications."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the design (BIM creation), construction (device configuration), commissioning (validation), operation (continuous monitoring and optimization), and eventual decommissioning of the building, thereby aligning with the physical counterpart’s lifecycle stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity assessed using the Overall Digital Twin Entanglement (ODTE) metric; validation performed through model checks (e.g., IFC constraints) and sensor data consistency; uncertainty handled by sensor fusion and error bounds embedded in simulation models."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical devices communicate using MQTT over Hono, employing TLS 1.3; Ditto exposes both REST and MQTT endpoints; data payloads are JSON formatted; authentication occurs using X.509 certificates."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components are containerised; Ditto and Hono run in Docker containers orchestrated by Kubernetes; Unreal Engine 5 deployment on a dedicated workstation or cloud instance; data storage utilizes PostgreSQL for persistence."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems such as enterprise BIM servers (Revit API), building control systems (BACnet), and third‑party analytics platforms via RESTful web services."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership resides with the building owner; DT provider stores anonymised aggregates; privacy compliance achieved via GDPR, encryption at rest and in transit, and selective data sharing policies."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Standards followed include IFC 4.3 for BIM, MQTT 3.1.1 for messaging, Ditto Open Connectivity Foundation specification, ISO 19650 for BIM asset management, and ISO 14001 for energy management frameworks."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security implemented with TLS 1.3, OAuth2 or client certificates for authentication, role‑based access control; safety measures include fail‑safe operation, runtime watchdog, and isolation of critical control paths to prevent accidental harm."
]