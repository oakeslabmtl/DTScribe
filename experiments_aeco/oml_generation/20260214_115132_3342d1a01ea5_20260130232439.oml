// C3: Physical sensing components
instance BuildingIoTSensor : DTDFVocab:SensingComponent [
    base:desc "First‑class sensor object defined in the enriched BIM model it provides measurements that are streamed to the digital twin."
    DTDFVocab:producedData BuildingSensorDataStream
]

// C4: DataTransmitted
instance BuildingSensorDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingIoTSensor
]

// C10: Data
instance LiveBuildingSensorData : DTDFVocab:Data [
    base:desc "Live runtime data generated by the BuildingIoTSensor data stream."
    DTDFVocab:fromData BuildingSensorDataStream
    DTDFVocab:inputTo RealTimeDataExchangeLayer
]

// C11: Enablers (real‑time data exchange)
instance RealTimeDataExchangeLayer : DTDFVocab:Enabler [
    base:desc "Continuous bidirectional real‑time data exchange layer that synchronizes sensor and actuator data between the physical building and its digital twin."
    DTDFVocab:enables RealTimeMonitoringService, PhysicsSimulationService, PredictiveAnalyticsService, VisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides continuous monitoring of live sensor streams for the building twin."
    DTDFVocab:provides LiveStateInsight, AlarmInsight
]

instance PhysicsSimulationService : DTDFVocab:Service [
    base:desc "Runs physics‑based simulation of building performance using BIM geometry and sensor data."
    DTDFVocab:provides SimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Executes custom analytics plug‑ins for energy forecasting and fault detection, producing alerts and recommendations."
    DTDFVocab:provides FaultDetectionInsight, RecommendationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Delivers immersive 3D visualisation panels that display live state, alarms and enable control actions."
    DTDFVocab:provides VisualisationInsight, ControlAction
]

// C17: Insights
instance LiveStateInsight : DTDFVocab:Insight [
    base:desc "Shows the current live state of building systems on the visualisation panel."
]

instance AlarmInsight : DTDFVocab:Insight [
    base:desc "Generates alarms when sensor readings exceed defined thresholds."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Provides results of physics‑based building performance simulations."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects faults in HVAC, lighting or other systems based on predictive analytics."
]

instance RecommendationInsight : DTDFVocab:Insight [
    base:desc "Offers energy‑saving or maintenance recommendations derived from analytics."
]

instance VisualisationInsight : DTDFVocab:Insight [
    base:desc "Renders immersive 3D view of the virtual model synchronized with live data."
]

// C17: Actions
instance ControlAction : DTDFVocab:Action [
    base:desc "Allows facility managers to issue control commands to actuators (e.g., adjust HVAC setpoints)."
    DTDFVocab:IsAutomatic false
]

// C2: Physical acting components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator entity defined in the BIM model with a logical control interface that can be invoked remotely via the digital twin."
]

// C5: Models
instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "Static BIM geometry model enriched with device definitions for sensors and actuators."
    DTDFVocab:inputTo RealTimeDataExchangeLayer
]

instance DeviceMetadataModel : DTDFVocab:Model [
    base:desc "Semantic model containing metadata of instantiated sensors, actuators and controllers extracted from BIM."
    DTDFVocab:inputTo RealTimeDataExchangeLayer
]

// Additional Data derived from the sensor stream
instance SensorStreamData : DTDFVocab:Data [
    base:desc "Structured representation (e.g., RDF/JSON) of live sensor streams used by services."
    DTDFVocab:fromData BuildingSensorDataStream
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin can issue control commands back to the physical building in real time, enabling facility managers to monitor and control building systems through the DT. Interaction is bidirectional, yet the document does not specify command types, message formats, validation/authentication methods, feedback loops, conflict resolution, or execution confirmation details."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework addresses the complete Digital Twin lifecycle: (1) device modeling within BIM where sensors, actuators, and controllers are defined; (2) enrichment of the BIM model to create a unified semantic foundation; (3) Model‑Driven Engineering (MDE) extraction of structured representations from the enriched BIM; (4) automatic generation of deployable DT artifacts (e.g., service descriptors, configuration files); (5) runtime operation with real‑time data exchange that continuously synchronises the physical building and its twin; (6) evolution and extension through a modular architecture with standardized extension points that allow integration of custom services and analytics. Transitions between these phases are orchestrated by the deployment toolchain, and lifecycle governance is implemented through role‑based responsibilities (Building Control Engineer, Facility Manager, DT Engineer) defined in Table I."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The solution is built on a modular architecture with standardized extension points and runtime configuration management, aimed at supporting interoperability across heterogeneous systems, scalability from component to infrastructure level, maintainability, and accessibility. Specific network protocols, topology, bandwidth, latency, redundancy, or security mechanisms for the underlying communication infrastructure are not provided in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin framework acts as a central hub that integrates enriched BIM models with operational DTs and supports modular extensions and runtime configuration, implying flexibility in deployment (e.g., cloud, edge, or on‑premise). However, the document does not give explicit details on hosting platforms, computational and storage requirements, scalability mechanisms, supported deployment models, or availability/reliability assurances."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is grounded in Building Information Modeling (BIM), which serves as the foundational industry standard for representing building assets. A dedicated modeling methodology is used to standardize BIM semantics, ensuring a consistent semantic basis for the model‑driven transformation pipeline. The Digital Twin architecture provides standardized extension points that define interoperable interfaces for custom services and analytics plugins, facilitating integration across tools and vendors."
]