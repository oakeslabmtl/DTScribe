instance SystemStateMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time insights into system states and environmental parameters for Facility Managers."
]

instance EnvironmentalDataInsight : DTDFVocab:Insight [
    base:desc "Continuous monitoring of indoor environmental parameters for operational awareness."
]

instance MaintenanceSchedulingInsight : DTDFVocab:Insight [
    base:desc "Predictive insights for maintenance scheduling based on equipment condition analysis."
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insights for optimizing energy consumption through analytics."
]

instance SystemStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive visualization of system states for Facility Managers."
]

instance InfrastructureControlAction : DTDFVocab:Action [
    base:desc "Remote control of physical infrastructure components via interactive visualization interfaces."
    DTDFVocab:IsAutomatic false
]

instance LightingControlAction : DTDFVocab:Action [
    base:desc "Control of lighting parameters (on/off, brightness, color temperature) with safety constraints applied during command validation."
    DTDFVocab:IsAutomatic false
]

instance OperationalDataSyncInsight : DTDFVocab:Insight [
    base:desc "Continuous synchronization of operational data for real-time monitoring."
]

instance DecisionSupportReportInsight : DTDFVocab:Insight [
    base:desc "Automated reports providing insights for decision-making support."
]

instance BIMModelDeploymentInsight : DTDFVocab:Insight [
    base:desc "Insight related to BIM model deployment status and configuration."
]

instance DataIntegrationInsight : DTDFVocab:Insight [
    base:desc "Insight related to integrated data quality and completeness."
]

instance BIMModelingInsight : DTDFVocab:Insight [
    base:desc "Insight related to BIM model structure and spatial data."
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of indoor environmental parameters and building systems for continuous operational insights."
    DTDFVocab:provides SystemStateMonitoringInsight, EnvironmentalDataInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for maintenance scheduling and energy consumption optimization using custom analytics services integrated via modular extension points."
    DTDFVocab:provides MaintenanceSchedulingInsight, EnergyOptimizationInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization interfaces for Facility Managers to control physical infrastructure and monitor system states."
    DTDFVocab:provides SystemStateVisualizationInsight, InfrastructureControlAction
]

instance ContinuousDataSynchronizationService : DTDFVocab:Service [
    base:desc "Continuous data synchronization between physical assets and the digital twin via Eclipse Hono and Ditto middleware."
    DTDFVocab:provides OperationalDataSyncInsight
]

instance ActuationControlService : DTDFVocab:Service [
    base:desc "Manages actuation commands with policy-based validation to ensure safe operation within defined ranges."
    DTDFVocab:provides LightingControlAction
]

instance AutomatedReportingService : DTDFVocab:Service [
    base:desc "Automated reporting for decision-making support based on analyzed data."
    DTDFVocab:provides DecisionSupportReportInsight
]

instance BIMModelDeploymentService : DTDFVocab:Service [
    base:desc "Service responsible for deploying BIM models into the Digital Twin environment."
    DTDFVocab:provides BIMModelDeploymentInsight
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Service for integrating data from various sources into the Digital Twin."
    DTDFVocab:provides DataIntegrationInsight
]

instance BIMModelingService : DTDFVocab:Service [
    base:desc "Service for creating and managing BIM models within the Digital Twin."
    DTDFVocab:provides BIMModelingInsight
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Manages policy-based validation of sensor values and actuator commands, DittoDevice instances, and DittoConnection configurations."
    DTDFVocab:enables ActuationControlService
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Handles message delivery for sensor data and actuator commands via standardized protocols."
    DTDFVocab:enables RealTimeMonitoringService, ContinuousDataSynchronizationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Provides immersive interactive visualization interfaces for Facility Managers to monitor and control physical infrastructure."
    DTDFVocab:enables InteractiveVisualizationService
]

instance EclipseBasyx : DTDFVocab:Enabler [
    base:desc "Open-source Industry 4.0 platform for digital twin integration and data management."
    DTDFVocab:enables DataIntegrationService
]

instance itwinjs : DTDFVocab:Enabler [
    base:desc "Library for infrastructure digital twin applications, supporting BIM and spatial data representation."
    DTDFVocab:enables BIMModelingService
]

instance RevitBIMTool : DTDFVocab:Enabler [
    base:desc "Used for device modeling and spatial data representation in Building Information Modeling (BIM) environment."
    DTDFVocab:enables BIMModelingService
]

instance ModelDrivenEngineeringFramework : DTDFVocab:Enabler [
    base:desc "Automates generation of deployable DT artifacts from enriched BIM models using Model-Driven Engineering (MDE)."
    DTDFVocab:enables BIMModelDeploymentService
]

instance EnvironmentalSensors : DTDFVocab:SensingComponent [
    base:desc "Various sensors deployed across a 22 m² office space with two working areas, utilizing a 1-second heartbeat mechanism for data collection via Eclipse Hono and Ditto middleware."
    DTDFVocab:producedData EnvironmentalSensorDataTransmitted
]

instance EnvironmentalSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensors
]

instance EnvironmentalSensorData : DTDFVocab:Data [
    base:desc "Real-time sensor data from physical Building Control Systems (BCS) integrated via Eclipse Hono and Ditto for continuous synchronization between physical assets and the digital twin."
    DTDFVocab:fromData EnvironmentalSensorDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance RevitBIMModel : DTDFVocab:Model [
    base:desc "Enriched Building Information Modeling (BIM) data from Revit as the geometric foundation for the Digital Twin."
    DTDFVocab:inputTo ModelDrivenEngineeringFramework, UnrealEngine5
]

instance LightFeatureParser : DTDFVocab:Model [
    base:desc "Behavioral model extension for processing lighting parameters using TwinComponent and FeatureParser architecture."
    DTDFVocab:inputTo ModelDrivenEngineeringFramework
]

instance ODTEAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model derived from Overall Digital Twin Entanglement (ODTE) metric components for system analysis."
    DTDFVocab:inputTo EclipseBasyx
]

instance CentralizedFrameworkHub : DTDFVocab:Component [
    base:desc "Centralized framework hub managing multiple DT instances with modular architecture and standardized extension points for custom services and analytics."
]

instance AcademicBuilding : DTDFVocab:Environment [
    base:desc "LEED Platinum academic building operating as a living lab for AECO sector operations."
    base:contains EnvironmentalSensors, LightingSystemActuator, UnrealTwinController
]

instance LightingSystemActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting system actuators controlled via UnrealTwinController using UE5 Delegates and Observable pattern commands validated by Ditto's policy-based checks for on/off state, brightness, and color temperature."
]

instance UnrealTwinController : DTDFVocab:Component [
    base:desc "Controller managing actuator commands via UE5 Delegates and Observable pattern for safe actuation."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals are transmitted from the digital twin to Building Control Systems (BCS) for operational adjustments, as described in Document 4. Specific command types, message formats, validation mechanisms, feedback systems, conflict resolution, and execution confirmation details are not provided in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time data exchange capabilities ensure continuous synchronization between physical buildings and their digital counterparts."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT Framework serves as a central hub coordinating Building Control Engineers, Facility Managers, and DT Engineers to facilitate bidirectional data exchange and holistic building life cycle management through a modular architecture with standardized extension points for service integration."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle encompasses design-time modeling in BIM (Building Control Engineers define sensors, actuators, and controllers), automated deployment via Model-Driven Engineering (MDE) to generate deployable artifacts with minimal manual intervention (R2), and runtime operations involving real-time data synchronization using Eclipse Hono and Ditto (R3), interactive visualization for monitoring/control by Facility Managers, and extensibility through custom services via modular architecture (R4). Stakeholder roles govern each phase: Building Control Engineers handle initial modeling, Facility Managers operate physical infrastructure via the DT, and DT Engineers extend functionality."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is validated using the Overall Digital Twin Entanglement (ODTE) metric, comprising timeliness (0.997), reliability (1.0), and availability (1.0), measured via a 1-second heartbeat mechanism over 12 minutes. Data integrity is ensured through Eclipse Ditto’s policy-based validation for sensor value ranges and units, and pre-execution checks for actuator commands. Fault tolerance mechanisms include Eclipse Hono’s at-least-once delivery and Ditto’s persistent event storage, maintaining synchronization and operational safety. Bidirectional communication is verified by confirming state updates in both directions between physical and digital twins."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono and Ditto facilitate communication between physical and digital components for real-time data exchange, but specific network protocols, topology, bandwidth requirements, latency specifications, redundancy mechanisms, and security protocols are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "A modular architecture with standardized extension points supports scalable, service-oriented deployment and runtime configuration management for digital twins, enabling adjustments without full redeployment. Specific hosting platforms, computational requirements, storage specifications, and deployment models are not detailed in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability across heterogeneous systems via standardized data schemas and bidirectional communication protocols, with BIM integration enabling unified semantic foundation and automated artifact generation through model-driven engineering principles."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework adheres to Building Information Modeling (BIM) standards as the AECO industry standard. Real-time data integration employs Eclipse Ditto and Hono, which comply with IoT communication protocols like MQTT. Modular architecture includes standardized extension points for interoperability, addressing fragmented deployments by ensuring semantic integration and consistent data schemas."
]