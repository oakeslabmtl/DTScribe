// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled within the BIM environment and addressable via generated runtime interfaces"
]

instance HVACControlActuator : DTDFVocab:ActingComponent [
    base:desc "Building control hardware (e.g., HVAC actuator) modeled in BIM and controllable through the central DT platform"
]

// C3: Physical sensing components
instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor (temperature, humidity, CO₂) whose metadata are embedded in the BIM model"
    DTDFVocab:producedData EnvironmentalDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in BIM to detect presence and usage patterns"
    DTDFVocab:producedData OccupancyDataStream
]

instance EnergySensor : DTDFVocab:SensingComponent [
    base:desc "Energy sensor providing power consumption measurements, metadata stored in the BIM model"
    DTDFVocab:producedData EnergyDataStream
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance EnvironmentalDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergySensor
]

// C10: Data
instance EnvironmentalTimeSeriesData : DTDFVocab:Data [
    base:desc "Real‑time environmental time‑series streamed via Eclipse Hono (MQTT) to the twin"
    DTDFVocab:fromData EnvironmentalDataStream
    DTDFVocab:inputTo EclipseDitto
]

instance OccupancyTimeSeriesData : DTDFVocab:Data [
    base:desc "Occupancy time‑series data ingested by Eclipse Hono and synchronized with the digital twin"
    DTDFVocab:fromData OccupancyDataStream
    DTDFVocab:inputTo EclipseDitto
]

instance EnergyTimeSeriesData : DTDFVocab:Data [
    base:desc "Energy consumption time‑series streamed through Eclipse Hono to the twin for analytics"
    DTDFVocab:fromData EnergyDataStream
    DTDFVocab:inputTo EclipseDitto
]

// C10: Models
instance BIMSemanticModel : DTDFVocab:Model [
    base:desc "Static BIM geometry and semantic model enriched with device metadata"
    DTDFVocab:inputTo ModelDrivenTransformationPipeline
]

instance UnrealVisualizationModel : DTDFVocab:Model [
    base:desc "Visual model exported for Unreal Engine 5 to enable interactive 3D visualization"
    DTDFVocab:inputTo UnrealEngine5
]

// C11: Enablers
instance BIMAuthoringTool : DTDFVocab:Enabler [
    base:desc "Authoring tools used to create and enrich the BIM model with device metadata"
    DTDFVocab:enables RuntimeConfigurationManagementService
]

instance ModelDrivenTransformationPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven pipeline that validates, generates Ditto twin definitions and runtime artifacts"
    DTDFVocab:enables PredictiveAnalyticsService
    DTDFVocab:enables OptimizationService
    DTDFVocab:enables RuntimeConfigurationManagementService
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono instance ingesting sensor streams via MQTT adapters"
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto synchronizes data into digital twin state representations"
    DTDFVocab:enables RealTimeMonitoringService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime providing interactive 3D visualizations of the building twin"
    DTDFVocab:enables Interactive3DVisualizationService
]

instance StandardizedExtensionPoints : DTDFVocab:Enabler [
    base:desc "Standardized extension points allowing modular runtime configuration updates"
    DTDFVocab:enables RuntimeConfigurationManagementService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service delivering real‑time monitoring of building sensor data"
    DTDFVocab:provides RealTimeInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service offering predictive analytics based on historical and streaming sensor data"
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that optimizes building operation and control strategies using twin insights"
    DTDFVocab:provides DecisionSupportInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Service delivering interactive 3D visualization via Unreal Engine 5"
    DTDFVocab:provides VisualizationUpdateAction
]

instance RuntimeConfigurationManagementService : DTDFVocab:Service [
    base:desc "Service managing runtime configuration updates of devices and twin artifacts"
    DTDFVocab:provides ConfigurationUpdateAction
]

// C17: Insights
instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into environmental, occupancy and energy conditions for facility managers"
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive insight forecasting future building performance and occupancy trends"
]

instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Decision‑support insight enabling optimization of control strategies and energy usage"
]

// C17: Actions
instance VisualizationUpdateAction : DTDFVocab:Action [
    base:desc "Automatic action to update the 3D visualization when twin state changes"
    DTDFVocab:IsAutomatic true
]

instance ConfigurationUpdateAction : DTDFVocab:Action [
    base:desc "Automatic action to push configuration changes to physical actuators via the twin"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin’s logic (e.g., lighting control setpoints) are sent back through Ditto/Hono to the corresponding actuators in the building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization between physical assets and the twin (no discrete batch rates are specified)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture where a central DT framework connects BIM, Hono, Ditto, and Unreal Engine, with standardized extension points for adding custom services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the full building lifecycle: design (BIM creation), construction (device modeling and metadata enrichment), and operation (runtime data integration and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "A model validation step is performed before generation; the Overall Digital Twin Entanglement (ODTE) metric is used to quantify the fidelity between the physical building and its twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional communication mediated by Eclipse Hono (protocol adapters such as MQTT for sensor ingestion) and Eclipse Ditto (HTTP/WS APIs for twin state management)."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The architecture’s standardized extension points permit integration of external services and analytics platforms, facilitating horizontal information exchange beyond the core twin."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach follows BIM standards for building data, provides standardized extension points for interoperability, and employs the ODTE metric as a common assessment standard."
]