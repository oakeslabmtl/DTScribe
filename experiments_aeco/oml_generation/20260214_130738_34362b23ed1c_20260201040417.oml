instance LightFacadeActuator : DTDFVocab:ActingComponent [
    base:desc "LED luminaires mapped to physical LED fixtures, controlled via LightTwinComponent and exposed through DittoDevice instances"
]

instance HVACUnitActuator : DTDFVocab:ActingComponent [
    base:desc "Air‑handling units operated through HVAC controllers, receiving commands via the DittoController and processed by the UnrealTwinController"
]

instance TemperatureSensor500ms : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor sampling at 500 ms, publishing via Eclipse Hono using MQTT"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor publishing updates over Eclipse Hono"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor emitting readings through the Hono broker"
    DTDFVocab:producedData CO2DataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor relaying presence information via Eclipse Hono"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance AirflowSensor : DTDFVocab:SensingComponent [
    base:desc "Airflow sensor sending telemetry through Hono"
    DTDFVocab:producedData AirflowDataTransmitted
]

instance PowerConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Power consumption sensor streaming energy usage to Hono"
    DTDFVocab:producedData PowerDataTransmitted
]

instance HVACStatusSensor : DTDFVocab:SensingComponent [
    base:desc "HVAC status sensor reporting unit state to Ditto via Hono"
    DTDFVocab:producedData HVACStatusDataTransmitted
]

instance LightingStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting status sensor conveying on/off and brightness to the twin"
    DTDFVocab:producedData LightingStatusDataTransmitted
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor500ms
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance AirflowDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirflowSensor
]

instance PowerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerConsumptionSensor
]

instance HVACStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HVACStatusSensor
]

instance LightingStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingStatusSensor
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature measurements transmitted as JSON payloads via Ditto"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo HonoMessagingEngine
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity readings received in real‑time from Hono"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo HonoMessagingEngine
]

instance CO2Data : DTDFVocab:Data [
    base:desc "CO₂ concentration data forwarded by the Hono broker"
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo HonoMessagingEngine
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy status updates streamed to the twin via Hono"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo HonoMessagingEngine
]

instance AirflowData : DTDFVocab:Data [
    base:desc "Airflow telemetry received in near‑real‑time from Hono"
    DTDFVocab:fromData AirflowDataTransmitted
    DTDFVocab:inputTo HonoMessagingEngine
]

instance PowerData : DTDFVocab:Data [
    base:desc "Power consumption figures obtained through Hono MQTT streams"
    DTDFVocab:fromData PowerDataTransmitted
    DTDFVocab:inputTo HonoMessagingEngine
]

instance HVACStatusData : DTDFVocab:Data [
    base:desc "HVAC unit state information delivered via Ditto"
    DTDFVocab:fromData HVACStatusDataTransmitted
    DTDFVocab:inputTo HonoMessagingEngine
]

instance LightingStatusData : DTDFVocab:Data [
    base:desc "Lighting status telemetry transmitted over the Hono broker"
    DTDFVocab:fromData LightingStatusDataTransmitted
    DTDFVocab:inputTo HonoMessagingEngine
]

instance HonoMessagingEngine : DTDFVocab:Enabler [
    base:desc "Eclipse Hono message broker providing at‑least‑once delivery via MQTT/HTTP, handling telemetry routing to Ditto and the twin devices"
    DTDFVocab:enables MonitoringService, PredictiveAnalyticsService, OptimizationService, ControlService
]

instance DittoTwinEngine : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin engine orchestrating device management, event storage, and policy validation for the Digital Twin"
    DTDFVocab:enables ControlService, MonitoringService
]

instance iTwinJSUI : DTDFVocab:Enabler [
    base:desc "iTwin.js web‑based UI enabling immersive 3D visualization of the UE5 geometric model and dashboard controls"
    DTDFVocab:enables VisualizationService
]

instance ModelDrivenAutomator : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline that transforms enriched BIM into deployable twin artifacts"
    DTDFVocab:enables DeploymentService
]

instance AnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Analytics engine processing historical and real‑time data streams for predictive analytics and optimization"
    DTDFVocab:enables PredictiveAnalyticsService, OptimizationService
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of sensor readings and actuator states, providing alerts for anomalies and status changes"
    DTDFVocab:provides TemperatureAnomalyInsight, HumidityAnomalyInsight, CO2AnomalyInsight, OccupancyLevelInsight, AirflowAnomalyInsight, PowerConsumptionTrendInsight, HVACStatusInsight, LightingStatusInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Forecasting occupant comfort and energy consumption based on historical data streams"
    DTDFVocab:provides EnergyConsumptionForecastInsight, ComfortPredictionInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Recommends HVAC set‑point adjustments and lighting optimizations to reduce energy use while maintaining comfort"
    DTDFVocab:provides HVACSetpointRecommendationInsight, LightingEnergySavingsInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Allows facility managers to send control commands to HVAC and lighting controllers via the twin"
    DTDFVocab:provides SendHVACCommandAction, SetLightingLevelAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides immersive 3D views and dashboards built on iTwin.js for interactive exploration of building performance"
    DTDFVocab:provides Immersive3DViewInsight
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Handles deployment of the twin from model artifacts to runtime environments"
    DTDFVocab:provides DeploymentStatusInsight
]

