{
    instance Building : DTDFVocab:SystemUnderStudy [
        DTDFVocab:hasEnvironment BuildingEnvironment
    ]
    instance BuildingEnvironment : DTDFVocab:Environment [
        base:contains Sensor1, Actuator1, DataTransmitted1, Data1, Model1, Enabler1, Service1, Insight1, Action1
    ]
    instance Sensor1 : DTDFVocab:SensingComponent [
        base:desc "Sensors providing real-time operational data, including sensor configurations and post-occupancy sensor data, for monitoring building conditions."
    ]
    instance Actuator1 : DTDFVocab:ActingComponent [
        base:desc "Actuators and controllers within Building Control Systems (BCS), including adaptive lighting systems as referenced in the BOREALIS project, for managing building operations."
    ]
    instance DataTransmitted1 : DTDFVocab:DataTransmitted [
        DTDFVocab:producedFrom Sensor1
    ]
    instance Data1 : DTDFVocab:Data [
        base:desc "Building Information Modeling (BIM) data enriched with runtime semantics for Building Control Systems (BCS), including device metadata, sensor configurations, and control logic, transformed via model-to-model and model-to-text processes into runtime artifacts.",
        DTDFVocab:inputTo Model1,
        DTDFVocab:fromData DataTransmitted1
    ]
    instance Model1 : DTDFVocab:Model [
        base:desc "Building Information Modeling (BIM) models transformed via model-to-model and model-to-text processes into runtime artifacts.",
        DTDFVocab:inputTo Enabler1
    ]
    instance Enabler1 : DTDFVocab:Enabler [
        base:desc "Eclipse Hono, Ditto, Unreal Engine 5, and Model-Driven Engineering (MDE) tools for automated deployment, data exchange, visualization, and transformation of BIM models into digital twin artifacts.",
        DTDFVocab:enables Service1
    ]
    instance Service1 : DTDFVocab:Service [
        base:desc "Real-time monitoring, predictive analytics for energy optimization, visual comfort assessment, non-visual health effect analysis, interactive 3D visualization using Unreal Engine 5, and simulation of building performance scenarios.",
        DTDFVocab:provides Insight1, Action1
    ]
    instance Insight1 : DTDFVocab:Insight [
        base:desc "Predictive analytics outputs for energy consumption optimization, visual comfort adjustments, and non-visual health effect mitigation, informing facility managers' operational decisions without direct physical control."
    ]
    instance Action1 : DTDFVocab:Action [
        base:desc "Adaptive lighting control based on sensor data",
        DTDFVocab:IsAutomatic true
    ]
}