// Sensing Components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor capturing real‑time presence data"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Light level sensor measuring illumination intensity"
    DTDFVocab:producedData LightLevelDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor recording ambient temperature"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor collecting CO₂, humidity, and air quality data"
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

// Actuating Components
instance LightFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Smart light fixture capable of dimming and color adjustment"
]

instance DimmerActuator : DTDFVocab:ActingComponent [
    base:desc "Dimmer actuator controlling brightness levels of lighting systems"
]

instance VentilationUnitActuator : DTDFVocab:ActingComponent [
    base:desc "Ventilation unit actuator modulating airflow rates"
]

// Data Transmitted Instances
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightLevelDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// Runtime Data Instances
instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy data stream"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

instance LightLevelData : DTDFVocab:Data [
    base:desc "Real‑time light level data stream"
    DTDFVocab:fromData LightLevelDataTransmitted
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real‑time temperature data stream"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Real‑time environmental data stream"
    DTDFVocab:fromData EnvironmentalDataTransmitted
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

// Model Instance
instance BIMIFCModel : DTDFVocab:Model [
    base:desc "BIM geometry (IFC) enriched with semantic annotations for devices and control logic"
    DTDFVocab:inputTo TransformationTool
]

// Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware for connectivity and data routing"
    DTDFVocab:enables DataIngestionService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for device registry, telemetry, and persistence"
    DTDFVocab:enables TelemetryService
]

instance TransformationTool : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation tool mapping BIM to runtime artifacts"
    DTDFVocab:enables ModelTransformationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for 3D visualization of the building twin"
    DTDFVocab:enables VisualizationService
]

instance Configurator : DTDFVocab:Enabler [
    base:desc "Custom Hono/Ditto configurator for automated deployment"
    DTDFVocab:enables DeploymentService
]

// Service Instances
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service ingesting raw sensor data from Hono into Ditto"
    DTDFVocab:provides DataIngestionInsight
]

instance TelemetryService : DTDFVocab:Service [
    base:desc "Service handling telemetry data streams in Ditto"
    DTDFVocab:provides RealTimeTelemetryInsight
]

instance ModelTransformationService : DTDFVocab:Service [
    base:desc "Service performing model validation and runtime artifact generation"
    DTDFVocab:provides BIMModelValidationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service rendering 3D visualizations in Unreal Engine 5"
    DTDFVocab:provides ThreeDVisualizationInsight
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Service managing automated deployment of DT artifacts"
    DTDFVocab:provides DeploymentStatusInsight
]

instance MonitoringVisualizationService : DTDFVocab:Service [
    base:desc "Service combining telemetry and visualization for real‑time monitoring"
    DTDFVocab:provides RealTimeMonitoringDashboard
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service generating predictive analytics for lighting and HVAC optimization"
    DTDFVocab:provides EnergySavingsProjection, OptimalLightingSchedule
]

instance ReinforcementLearningService : DTDFVocab:Service [
    base:desc "Service refining control policies through reinforcement learning"
    DTDFVocab:provides UpdateControlPolicy
]

instance InteractiveUIService : DTDFVocab:Service [
    base:desc "Service offering an interactive user interface for facility managers"
    DTDFVocab:provides FacilityManagementDashboard
]

// Insight Instances
instance DataIngestionInsight : DTDFVocab:Insight [
    base:desc "Insight detailing the status of data ingestion from sensor streams"
]

instance RealTimeTelemetryInsight : DTDFVocab:Insight [
    base:desc "Insight providing real‑time telemetry monitoring of building systems"
]

instance BIMModelValidationInsight : DTDFVocab:Insight [
    base:desc "Insight confirming validity of BIM geometry and semantic annotations"
]

instance ThreeDVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight showing 3D visualization state within Unreal Engine 5"
]

instance DeploymentStatusInsight : DTDFVocab:Insight [
    base:desc "Insight indicating deployment and synchronization status of DT artifacts"
]

instance RealTimeMonitoringDashboard : DTDFVocab:Insight [
    base:desc "Dashboard insight summarizing real‑time monitoring of building conditions"
]

instance EnergySavingsProjection : DTDFVocab:Insight [
    base:desc "Analytics insight projecting potential energy savings from optimized lighting"
]

instance OptimalLightingSchedule : DTDFVocab:Insight [
    base:desc "Recommended lighting schedule derived from predictive analytics"
]

instance FacilityManagementDashboard : DTDFVocab:Insight [
    base:desc "Interactive dashboard providing facility managers with operational metrics"
]

// Action Instances
instance UpdateControlPolicy : DTDFVocab:Action [
    base:desc "Action to update lighting and HVAC control policies based on RL optimization"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin (e.g., lighting setpoints, HVAC adjustments) are sent via Ditto messages through Hono back to the physical actuators, enabling bidirectional synchronization."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates in real‑time, continuously ingesting sensor streams and propagating control signals with minimal latency, enabling instantaneous synchronization between the physical and virtual worlds."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized orchestration layer comprising the BIM‑based device model, the Hono/Ditto micro‑services handling communication, the Unreal Engine rendering engine, and optional reinforcement‑learning modules that refine control policies."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (BIM modeling), Construction (deployment of devices and connectivity configuration), Commissioning (validation of connectivity and control logic), and Operation (ongoing monitoring, optimization, and iterative policy updates during occupancy)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is evaluated using the Overall Digital Twin Entanglement (ODTE) metric; semantic drift is mitigated through continuous synchronisation; validation covers data consistency checks between BIM annotations and live telemetry."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication relies on MQTT (via Hono) and CoAP protocols over TCP/IP, with Ditto providing the device registry and command/telemetry channels."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin stack is hosted in a cloud or on‑premises environment orchestrated by Kubernetes, with Ditto services deployed in containers and Unreal Engine running as a rendering service."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of BIM (IFC) for semantic modeling, MQTT/CoAP protocols for connectivity, and open‑source standards provided by Eclipse Hono and Ditto."
]