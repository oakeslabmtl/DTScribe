// C3: Physical sensing components
instance PhotometricSensor : DTDFVocab:SensingComponent [
    base:desc "Photometric sensor in the BIM model, annotated with unique Device ID routes telemetry via Eclipse Hono using MQTT."
    DTDFVocab:producedData PhotometricData
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy/presence detector annotated in BIM publishes JSON via Eclipse Hono."
    DTDFVocab:producedData OccupancyData
]

instance TempHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Temperature and humidity sensor with BIM annotation routes telemetry through Eclipse Hono."
    DTDFVocab:producedData TempHumidityData
]

instance MotionSensor : DTDFVocab:SensingComponent [
    base:desc "Motion sensor embedded in the building, annotated in BIM emits data via Eclipse Hono MQTT."
    DTDFVocab:producedData MotionData
]

instance PowerMeterSensor : DTDFVocab:SensingComponent [
    base:desc "Power meter sensor annotated in BIM streams energy consumption data through Eclipse Hono."
    DTDFVocab:producedData PowerMeterData
]

// C4: Physical-to-virtual interaction (data transmitted)
instance PhotometricData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhotometricSensor
]

instance OccupancyData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance TempHumidityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TempHumiditySensor
]

instance MotionData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionSensor
]

instance PowerMeterData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerMeterSensor
]

// C10: Models/Data (runtime sensor time‑series and semantic BIM)
// Data instances
instance PhotometricMeasurement : DTDFVocab:Data [
    base:desc "Received photometric measurement stream, stored in InfluxDB."
    DTDFVocab:inputTo EclipseHono
    DTDFVocab:fromData PhotometricData
]

instance OccupancyMeasurement : DTDFVocab:Data [
    base:desc "Occupancy detection measurement stored in InfluxDB."
    DTDFVocab:inputTo EclipseHono
    DTDFVocab:fromData OccupancyData
]

instance TempHumidityMeasurement : DTDFVocab:Data [
    base:desc "Temperature and humidity measurement stream, persisted in InfluxDB."
    DTDFVocab:inputTo EclipseHono
    DTDFVocab:fromData TempHumidityData
]

instance MotionMeasurement : DTDFVocab:Data [
    base:desc "Motion detection measurement stream, saved to InfluxDB."
    DTDFVocab:inputTo EclipseHono
    DTDFVocab:fromData MotionData
]

instance PowerConsumptionMeasurement : DTDFVocab:Data [
    base:desc "Power consumption data stream, stored in InfluxDB."
    DTDFVocab:inputTo EclipseHono
    DTDFVocab:fromData PowerMeterData
]

// Model instances
instance SemanticBIMDescriptorModel : DTDFVocab:Model [
    base:desc "Semantically annotated IFC model with custom extensions, output of BIM authoring tools."
    DTDFVocab:inputTo RevitArchiCAD, ModelDrivenPipeline
]

instance InfluxDBTimeSeriesModel : DTDFVocab:Model [
    base:desc "Time‑series model of sensor data stored in InfluxDB, transformed by the MDE pipeline."
    DTDFVocab:inputTo ModelDrivenPipeline
]

instance ControlPolicyModel : DTDFVocab:Model [
    base:desc "Control policies expressed in JavaScript/Python for lighting and HVAC, applied by the predictive analytics microservice."
    DTDFVocab:inputTo ReinforcementLearningFramework
]

instance Unreal3DSceneAssetModel : DTDFVocab:Model [
    base:desc "3D scene assets for immersive visualization in Unreal Engine 5."
    DTDFVocab:inputTo UnrealEngine5
]

// C11: Enablers
instance RevitArchiCAD : DTDFVocab:Enabler [
    base:desc "BIM authoring tools (Revit/ArchiCAD) used to annotate building assets and create semantic models."
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono routes telemetry streams from sensors via MQTT/HTTP to Ditto."
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto acts as the twin registry and real‑time data bus, updating twin entities with live sensor data."
    DTDFVocab:enables LightingOptimizationService, HvacSchedulingService, PredictiveAnalyticsService, RuntimeConfigurationService
]

instance ModelDrivenPipeline : DTDFVocab:Enabler [
    base:desc "Custom Model‑Driven Engineering pipeline transforming augmented BIM into Ditto twin descriptors."
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 provides immersive 3D visualization of building twins."
]

instance DockerKubernetes : DTDFVocab:Enabler [
    base:desc "Docker/Kubernetes orchestrates containerised deployment of twin services and edge gateways."
]

instance ReinforcementLearningFramework : DTDFVocab:Enabler [
    base:desc "Reinforcement learning framework (OpenAI Gym, TensorFlow) integrated into BOREALIS service for policy updates."
]

// C6: Services
instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Lease‑based lighting optimization service that predicts energy savings using reinforcement learning."
    DTDFVocab:provides EnergyConsumptionForecastInsight, LightingSetpointRecommendationInsight, SetLightingSetpointAction
]

instance HvacSchedulingService : DTDFVocab:Service [
    base:desc "Scheduling service for HVAC load balancing, providing load schedules and adjustment actions."
    DTDFVocab:provides HvacLoadScheduleInsight, AdjustHvacLoadAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "3D immersive visualization service built on Unreal Engine 5."
    DTDFVocab:provides LightingSetpointRecommendationInsight, HvacLoadScheduleInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics microservice in Python/Node.js that ingests sensor time‑series and outputs anomaly alerts."
    DTDFVocab:provides EquipmentAnomalyAlertInsight, MaintenanceBacklogSuggestionInsight
]

instance RuntimeConfigurationService : DTDFVocab:Service [
    base:desc "Runtime configuration service that updates device metadata dynamically via Ditto twin registry."
    DTDFVocab:provides MaintenanceBacklogSuggestionInsight, ScheduleMaintenanceAction
]

// C17: Insights
instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of future energy consumption used for monitoring and decision support."
]

instance LightingSetpointRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommended lighting setpoints to optimize energy savings."
]

instance HvacLoadScheduleInsight : DTDFVocab:Insight [
    base:desc "Recommended HVAC load schedules for efficient building climate control."
]

instance EquipmentAnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Anomaly alert for equipment failure detected by predictive analytics."
]

instance MaintenanceBacklogSuggestionInsight : DTDFVocab:Insight [
    base:desc "Suggestion of maintenance backlog to facility managers."
]

// C17: Actions
instance SetLightingSetpointAction : DTDFVocab:Action [
    base:desc "Automatically sets lighting setpoints through Ditto command messages."
    DTDFVocab:IsAutomatic true
]

instance AdjustHvacLoadAction : DTDFVocab:Action [
    base:desc "Automatically adjusts HVAC load based on scheduling service."
    DTDFVocab:IsAutomatic true
]

instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Schedules maintenance tasks based on backlog suggestion."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control logic, formulated in either deterministic rule sets or reinforcement‑learning policies, emits actuator commands (e.g., setpoint adjustments, on/off signals) which are serialized as JSON, routed through the Ditto twin registry, and delivered to the building’s BCS via Hono’s outbound MQTT topics, effecting real‑time device state changes."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous live synchronization with sub‑second latency, leveraging Hono’s low‑latency MQTT transport; service APIs are invoked via REST/HTTP with JSON payloads at configurable polling intervals (default 1 s) and can be stretched to higher rates (down to 10 ms for sensor bursts) when required."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The twin constellation consists of the BIM‑derived central building twin, the Ditto ecosystem hosting twin entities, Hono gateways acting as device proxies, Unreal Engine visualization front‑end, and specialized micro‑services (light optimizer, HVAC scheduler, analytics) all orchestrated through a lightweight message broker and orchestrated via Kubernetes deployments."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the full asset lifecycle— (a) design‑time, where the IFC/BIM model represents the ideal building geometry and asset catalog; (b) construction‑time, wherein the as‑built BIM model is augmented with fabrication data and device coordinates; and (c) operation‑time, where live telemetry populates the twin, allowing simulation and optimization of the operating configuration."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validity is enforced through BIM schema conformance checks, runtime data type validation in Ditto, and ODTE metric calculations to quantify twin entanglement; semantic drift is mitigated by periodic synchronization checkpoints that compare BIM attributes against live device metadata; error handling is performed by Hono’s persistence queues and Ditto’s delta monitoring."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The physical–virtual communication stack comprises: (a) device firmware publishing to MQTT topics via Eclipse Hono; (b) Hono’s gateway extracting payloads and routing to Ditto twin registry over HTTP; (c) Ditto managing twin state in a distributed database (e.g., Cassandra) and exposing a REST/CoAP API; (d) Unreal Engine consuming reference coordinates via WebSocket for real‑time visualization; all secured using TLS 1.3 and mutual authentication."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire architecture is deployed in a containerised micro‑service ecosystem orchestrated by Kubernetes; Hono, Ditto, InfluxDB, and the reinforcement‑learning service run in Docker containers on a private cloud; the Unreal Engine front‑end is hosted on a Windows/UE5 dedicated instance with a GPU; scalability is achieved via horizontal pod autoscaling."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework adheres to open interoperability standards: IFC for building data, MQTT for message transport, HTTP/REST for APIs, and JSON for payloads; in addition, unidirectional control logic follows the one‑time pad standards for device identity protocols."
]