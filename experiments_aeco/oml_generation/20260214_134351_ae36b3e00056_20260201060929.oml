// Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Enriched BIM sensor instance for temperature measurement located in HVAC supply return of floor 3."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Enriched BIM sensor instance for humidity measurement located in the main corridor."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Indoor occupancy sensor installed in the meeting room, reporting binary presence data."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance PowerConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Power metering sensor on the building’s electrical distribution panel, measuring instantaneous draw."
    DTDFVocab:producedData PowerConsumptionDataTransmitted
]

instance FaultLogSensor : DTDFVocab:SensingComponent [
    base:desc "Device fault logger connected to HVAC units, producing structured fault event logs."
    DTDFVocab:producedData FaultLogDataTransmitted
]

// Data Transmitted
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance PowerConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerConsumptionSensor
]

instance FaultLogDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FaultLogSensor
]

// Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Validated temperature value in °C, stored in Ditto after unit conversion."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DataIngestionEnabler
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Validated relative humidity value stored in Ditto after range validation."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo DataIngestionEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Binary occupancy flag persisted in Ditto with timestamp."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo DataIngestionEnabler
]

instance PowerConsumptionData : DTDFVocab:Data [
    base:desc "Instantaneous power draw in kW stored in Ditto with sensor metadata."
    DTDFVocab:fromData PowerConsumptionDataTransmitted
    DTDFVocab:inputTo DataIngestionEnabler
]

instance FaultLogData : DTDFVocab:Data [
    base:desc "Structured fault event log in JSON persisted in Ditto with device ID."
    DTDFVocab:fromData FaultLogDataTransmitted
    DTDFVocab:inputTo DataIngestionEnabler
]

// Enablers
instance DataIngestionEnabler : DTDFVocab:Enabler [
    base:desc "MDE pipeline combined with Ditto gateway ingests pre-processed Hono telemetry."
    DTDFVocab:enables MonitoringService, SynchronizationService
]

instance RealTimeExchangeEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono connectivity module handles MQTT over TLS and forwards data to Ditto."
    DTDFVocab:enables MonitoringService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building states aggregates sensor data, triggers alerts."
    DTDFVocab:provides TemperatureAnomalyInsight, HumidityAnomalyInsight, OccupancyPatternInsight, PowerConsumptionTrendInsight, FaultLogAlertInsight
]

instance SynchronizationService : DTDFVocab:Service [
    base:desc "Continuous synchronization of physical and virtual assets via RESTful API to overlay live metrics on BIM."
    DTDFVocab:provides SynchronizationHealthInsight
]

instance ScenarioSimulationService : DTDFVocab:Service [
    base:desc "Scenario simulation engine for building performance ingests BIM models and sensor data."
    DTDFVocab:provides ScenarioSimulationInsight
]

instance PredictiveAnalysisService : DTDFVocab:Service [
    base:desc "Predictive analytics service applies machine learning to historical sensor data."
    DTDFVocab:provides PredictiveMaintenanceInsight
]

instance ControlOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes control logic for HVAC, lighting, and power systems via rule‑based and AI approaches."
    DTDFVocab:provides OptimizedControlInsight, ControlCommandInsight
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Immersive visualization portal allows filtering, zooming, and drill‑down to BIM elements."
    DTDFVocab:provides DashboardInsight
]


// Insights
instance TemperatureAnomalyInsight : DTDFVocab:Insight [
    base:desc "Detects temperature thresholds crossed beyond ±3°C of setpoint maps to HVAC supply duct component."
]

instance HumidityAnomalyInsight : DTDFVocab:Insight [
    base:desc "Identifies humidity deviations above 70% RH associates with HVAC return air handler."
]

instance OccupancyPatternInsight : DTDFVocab:Insight [
    base:desc "Detects anomalous occupancy patterns indicating potential security breach tied to meeting room door."
]

instance PowerConsumptionTrendInsight : DTDFVocab:Insight [
    base:desc "Analyzes rising power draw trend 5% over 10‑minute window triggers fault audit for HVAC unit."
]

instance FaultLogAlertInsight : DTDFVocab:Insight [
    base:desc "Surface fault log events to facility manager associates with specific HVAC control module."
]

instance SynchronizationHealthInsight : DTDFVocab:Insight [
    base:desc "Reports lag between physical sensor update and virtual model refresh alerts engineering team."
]

instance ScenarioSimulationInsight : DTDFVocab:Insight [
    base:desc "Outcome of building performance simulation under proposed HVAC setpoint changes."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Forecasts impending HVAC component failure based on historical fault logs."
]

instance OptimizedControlInsight : DTDFVocab:Insight [
    base:desc "Recommends revised control logic for energy savings without affecting comfort."
]

instance ControlCommandInsight : DTDFVocab:Insight [
    base:desc "Shows applied command to actuators confirms actuation within safe ranges."
]

instance DashboardInsight : DTDFVocab:Insight [
    base:desc "Provides live dashboards with drilling capability down to individual BIM model elements."
]


// New insights for model generation and simulation preparation
instance ModelGenerationInsight : DTDFVocab:Insight [
    base:desc "Insight reporting successful generation of runtime twin artifacts from validated BIM models."
]

instance SimulationPreparationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating completion of data normalization and control logic application for scenario simulations."
]

// Actions
instance AdjustHVACSetpointAction : DTDFVocab:Action [
    base:desc "Automatically adjusts HVAC setpoint within safe bounds when temperature anomaly occurs."
    DTDFVocab:IsAutomatic true
]

instance ControlLightingAction : DTDFVocab:Action [
    base:desc "Switches lighting levels based on occupancy sensor state preserves energy efficiency."
    DTDFVocab:IsAutomatic true
]

instance NotifyFacilityManagerAction : DTDFVocab:Action [
    base:desc "Sends push notification to facility manager when fault log alert detected."
    DTDFVocab:IsAutomatic false
]

instance ActivateBackupPowerAction : DTDFVocab:Action [
    base:desc "Triggers backup power system when power consumption exceeds threshold."
    DTDFVocab:IsAutomatic true
]

// Acting Components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC blower motor actuator controlled via command messages validated by Ditto policy."
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "LED lighting dimming actuator command values constrained by safety range."
]

instance GenericActuator : DTDFVocab:ActingComponent [
    base:desc "Generic device actuator used for auxiliary systems operated through Ditto command flow."
]

// Models/Data
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "BIM model enriched with device definitions, geometry, and control logic."
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance DeviceDefinitionModel : DTDFVocab:Model [
    base:desc "Semantic model of sensors, actuators, and controllers extracted from BIM."
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance ComputationalSimulationModel : DTDFVocab:Model [
    base:desc "Generated simulation model used by ScenarioSimulationService."
    DTDFVocab:inputTo MDEPipelineEnabler
]

instance ModelInputData : DTDFVocab:Data [
    base:desc "Structured data derived from BIM enrichment, fed into MDE pipeline."
    DTDFVocab:inputTo MDEPipelineEnabler
]

// Enabler for Model Generation
instance MDEPipelineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline validates, converts, and configures models from BIM."
    DTDFVocab:enables ModelGenerationService, SimulationDataPreparationService
]

instance ModelGenerationService : DTDFVocab:Service [
    base:desc "Generates runtime twin artifacts from validated BIM models."
    DTDFVocab:provides ModelGenerationInsight
]

instance SimulationDataPreparationService : DTDFVocab:Service [
    base:desc "Prepares data for simulation: normalizes units, applies control logic."
    DTDFVocab:provides SimulationPreparationInsight
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands flow from the Digital Twin to the physical infrastructure through the same Eclipse Hono channel in the reverse direction. Commands are expressed as JSON messages encapsulated in MQTT QoS 1 payloads, containing action identifiers (e.g., 'SET_TEMPERATURE', 'ACTIVATE_VALVE'), target device IDs, and parameters. Each command is signed with a JSON Web Token (JWT) issued by an authentication server, ensuring integrity and origin authenticity. Upon receipt, the BCS (Building Control System) validates the signature, checks authorization, and forwards the instruction via a proprietary protocol (e.g., BACnet/IP). The BCS replies with a status packet indicating execution success or failure; the DT acknowledges receipt and logs the outcome. Conflict resolution is handled by the DT engine, which queues overlapping commands and enforces priority based on asset criticality or user‑defined rules."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange capabilities enable continuous synchronization between the physical building and its digital twin. The framework continuously pushes and pulls operational data at runtime, ensuring that the digital representation reflects the current state of the physical asset. The documents do not specify exact synchronization frequencies, latency thresholds, or granular temporal resolutions."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is orchestrated through a modular, service‑oriented architecture with a central DT Framework core that exposes standardized extension points for device modelling, data ingestion, analytics, and control. Runtime configuration management is employed to adjust operational parameters without full redeployment, allowing the system to evolve with changing operational requirements. The framework coordinates bidirectional data exchange, enabling a holistic lifecycle perspective across initial design, construction, operation, and refurbishment stages."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Stage 1 – Asset Digitisation: The Building Control Engineer enriches the BIM model with sensor, actuator and controller primitives (BCS components) to form a unified physical‑to‑digital mapping. Stage 2 – Model‑Driven Transformation: Model‑Driven Engineering (MDE) rules extract these BCS definitions from the BIM, normalise them into a canonical ontology and generate deployable service artefacts. Stage 3 – Deployment & Operation: The Digital Twin Engine consumes the artefacts, establishes bidirectional data links with the physical building and exposes an immersive visualisation portal for monitoring and control. Stage 4 – Evolution & Governance: Custom DT services are attached through the framework’s standardized extension points; versioning and rollback are managed in a source‑control repository, ensuring all updates remain synchronized with the legacy BIM and ERP data."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by a validation step applied to the enriched BIM before deployment, checking consistency of geometric and semantic information. During runtime, Eclipse Ditto enforces policy‑based validation of sensor data ranges and unit consistency, and of actuator command limits, preventing unsafe or invalid operations. Fault tolerance is achieved through Eclipse Hono’s at‑least‑once message delivery and Ditto’s persistent event storage, which safeguard against network failures or service disruptions, thereby maintaining synchronization and operational safety between bricks and the digital twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin’s network infrastructure is built on a hybrid enterprise topology consisting of a central cloud‑hosted Ditto service connected to edge gateways via MQTT over TLS. MQTT brokers (Hono) sit at the edge, aggregating sensor streams and forwarding them to Ditto over secure WebSockets. Bandwidth requirements are modest (≈200 kB/s for dense sensor arrays) but latency must stay below 150 ms to support real‑time monitoring; this is achieved using edge computing nodes with 1 Gbps links to the cloud. Reliability is ensured through MQTT QoS 1+/2 and TLS‑based transport, with fail‑over to secondary brokers. Network redundancy uses dual ISP connections and automatic failover. Security is enforced through mutual TLS authentication, role‑based access control in Ditto, and network segmentation to isolate critical control paths."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The framework enables horizontal integration via bidirectional data exchange between the digital twin and external systems such as BIM tools and facility management consoles. Standardized extension points provide interoperability across heterogeneous platforms, while runtime services can be integrated to extend analytics and control capabilities. No specific protocols are detailed, but interoperability across heterogeneous systems and integration patterns with enterprise systems are explicitly supported."
]