// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in enriched BIM model, publishing readings via Eclipse Hono to Eclipse Ditto.",
    producedData TemperatureDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in BIM, publishing presence data through Eclipse Hono.",
    producedData OccupancyDataStream
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor defined in BIM, publishing humidity readings via Eclipse Hono.",
    producedData HumidityDataStream
]

// C4: Data transmitted from sensors
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    producedFrom TemperatureSensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    producedFrom OccupancySensor
]

instance HumidityDataStream : DTDFVocab:DataTransmitted [
    producedFrom HumiditySensor
]

// C10: Data objects derived from transmitted streams
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature measurements from physical building sensors.",
    fromData TemperatureDataStream,
    inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy status from building zones.",
    fromData OccupancyDataStream,
    inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Real-time humidity measurements from building environment.",
    fromData HumidityDataStream,
    inputTo EclipseHonoEnabler, EclipseDittoEnabler
]

// C2: Acting components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator modeled in BIM, represented in digital twin as TwinComponent, receiving commands via Ditto."
]

instance LightActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in BIM, represented in digital twin as TwinComponent, controllable through UE5 delegate."
]

// C11: Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware for messaging and real‑time data ingestion from physical sensors.",
    enables RealTimeSyncService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin service for state management and policy enforcement.",
    enables RealTimeSyncService, ControlExecutionService
]

instance ModelDrivenEngineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering engine that extracts models from BIM and generates DT artifacts.",
    enables CustomAnalyticsService
]

instance UE5VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 visualization layer that materializes TwinComponent objects.",
    enables InteractiveVisualizationService
]

instance ExtensionFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Standardized extension framework allowing DT Engineers to plug custom analytics and optimization services.",
    enables CustomAnalyticsService
]

// C6: Services
instance RealTimeSyncService : DTDFVocab:Service [
    base:desc "Real‑time data exchange service providing continuous synchronization between physical sensors and digital twin.",
    provides BuildingStateInsight
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization service for immersive monitoring and control within UE5.",
    provides VisualizationInsight
]

instance ControlExecutionService : DTDFVocab:Service [
    base:desc "Execution of control logic defined by building control engineers, issuing commands to actuators.",
    provides AdjustHVACAction, AdjustLightingAction
]

instance CustomAnalyticsService : DTDFVocab:Service [
    base:desc "Modular custom analytics, optimization and predictive services added by DT Engineers.",
    provides RunPredictiveAnalyticsAction
]

// C17: Insights
instance BuildingStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current building operational state derived from live sensor data."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight provided through immersive UE5 visual representation of the building twin."
]

// C17: Actions
instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Command to adjust HVAC setpoints based on control logic.",
    IsAutomatic true
]

instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Command to change lighting levels, brightness or color temperature.",
    IsAutomatic true
]

instance RunPredictiveAnalyticsAction : DTDFVocab:Action [
    base:desc "Trigger predictive analytics to forecast energy usage or detect faults.",
    IsAutomatic false
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing geometric building information and behavioral device specifications.",
    inputTo ModelDrivenEngineEnabler, UE5VisualizationEnabler
]

instance DeviceSpecificationModel : DTDFVocab:Model [
    base:desc "Device specification model extracted from BIM defining sensors, actuators, and controllers.",
    inputTo ModelDrivenEngineEnabler
]

instance BehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model encoding control logic such as on/off, brightness and temperature handling.",
    inputTo ModelDrivenEngineEnabler
]

instance GeometricModel : DTDFVocab:Model [
    base:desc "Geometric model representing building geometry for UE5 visualization.",
    inputTo UE5VisualizationEnabler
]

// C6: Physical‑to‑Virtual Interaction
instance RealTimeDataIntegration : DTDFVocab:DTComponent [
    base:desc "Physical‑to‑virtual interaction achieved through real‑time data integration using Eclipse Hono and Eclipse Ditto, providing live synchronization of physical state with its digital twin."
]

// C17: Environment
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, OccupancySensor, HumiditySensor, HVACActuator, LightActuator, EnrichedBIMModel
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real‑time data exchange capabilities that keep the digital twin continuously synchronized with the physical building; updates are streamed continuously to achieve instantaneous alignment, but the documents do not state specific synchronization frequencies, latency targets, or temporal granularity levels."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a modular, service‑oriented constellation where the DT Framework serves as the central coordination point. Standardized extension points allow custom services and analytics to be plugged in, and runtime configuration management enables on‑the‑fly adaptation without redeployment. The flow originates from enriched BIM models, passes through the DT Framework for bidirectional data exchange, and supports the full building life‑cycle through the coordinated roles of engineers and managers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The proposed framework supports the complete Digital Twin life‑cycle. In the initial stage, Building Control Engineers model devices (sensors, actuators, controllers) directly within BIM, enriching the static BIM representation with semantic control logic. Through Model‑Driven Engineering (MDE) principles, these enriched BIM models are automatically transformed into structured DT representations and deployable artifacts (deployment stage). Runtime operation follows, with real‑time data exchange keeping the physical building and its twin continuously synchronized and providing interactive visualization for monitoring and control. The architecture includes modular, standardized extension points that enable a later evolution stage where DT Engineers integrate custom services and analytics. Governance is expressed through role‑based responsibilities (Building Control Engineer, Facility Manager, DT Engineer) covering modeling, operation, and extension phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by augmenting static BIM geometry with dynamic device models and by using MDE to automatically generate DT artifacts that reflect both structural and behavioral aspects. Validation is performed at multiple layers: Eclipse Ditto’s policy‑based validation checks sensor data units and ranges; pre‑execution checks verify actuator command safety; and Eclipse Hono provides at‑least‑once delivery with persistent event storage in Ditto to detect and recover from network failures. These mechanisms together constitute the quality‑assurance process, quantifying uncertainty through policy constraints and correcting errors via validation feedback and fault‑tolerant messaging."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration is addressed through non‑functional requirements targeting interoperability across heterogeneous systems and scalability. The modular architecture offers standardized extension points for connecting external services, and the framework is designed to interoperate with other enterprise systems, although the documents do not specify concrete data exchange protocols (e.g., OPC‑UA, MQTT) or explicit standards used."
]