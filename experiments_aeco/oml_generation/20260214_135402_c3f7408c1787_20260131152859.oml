// C3: Physical Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors environmental temperature within building zones for real-time operational data synchronization with the Digital Twin, supporting HVAC control and energy optimization."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Detects occupancy levels in building spaces to enable dynamic lighting, HVAC adjustments, and space utilization analytics in the Digital Twin."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnergyMeter : DTDFVocab:SensingComponent [
    base:desc "Measures real-time energy consumption across building systems to provide data for demand-response algorithms and energy efficiency insights in the Digital Twin."
    DTDFVocab:producedData EnergyDataTransmitted
]

instance StructuralHealthSensor : DTDFVocab:SensingComponent [
    base:desc "Monitors structural integrity parameters (e.g., vibration, strain) to enable predictive maintenance and structural health monitoring within the Digital Twin."
    DTDFVocab:producedData StructuralDataTransmitted
]

instance HVACPerformanceSensor : DTDFVocab:SensingComponent [
    base:desc "Tracks HVAC system performance metrics (e.g., airflow, pressure) to validate control logic and optimize operational efficiency in the Digital Twin."
    DTDFVocab:producedData HVACPerformanceDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Real-time temperature readings from building zones transmitted via OPC UA or MQTT protocols for synchronization with the Digital Twin."
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Occupancy status updates transmitted at high frequency (sub-second intervals) to enable dynamic building control in the Digital Twin."
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Energy consumption data streamed continuously to the Digital Twin for real-time analytics and demand-response optimization."
    DTDFVocab:producedFrom EnergyMeter
]

instance StructuralDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Structural health monitoring data transmitted via OPC UA for predictive maintenance and safety validation in the Digital Twin."
    DTDFVocab:producedFrom StructuralHealthSensor
]

instance HVACPerformanceDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "High-frequency HVAC performance metrics transmitted to validate control logic and optimize system efficiency in the Digital Twin."
    DTDFVocab:producedFrom HVACPerformanceSensor
]

// C10: Models/Data
instance BimGeometricModel : DTDFVocab:Model [
    base:desc "Static Building Information Model (BIM) representing geometric and spatial relationships of building components, enriched with IFC-based semantics."
    DTDFVocab:inputTo BimEnrichmentLayer, AutomatedTransformationEngine
]

instance BimBehavioralModel : DTDFVocab:Model [
    base:desc "Dynamic BIM extension layer defining device-specific configurations (sensors, actuators, controllers) and control logic mappings."
    DTDFVocab:inputTo BimEnrichmentLayer, AutomatedTransformationEngine
]

instance BimAnalyticalModel : DTDFVocab:Model [
    base:desc "Model-Driven Engineering (MDE)-derived analytical representation enabling simulation and optimization of building operations."
    DTDFVocab:inputTo AutomatedTransformationEngine
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Continuously synchronized operational data from physical building systems (sensors, actuators) for real-time Digital Twin updates."
    DTDFVocab:fromData TemperatureDataTransmitted, OccupancyDataTransmitted, EnergyDataTransmitted, StructuralDataTransmitted, HVACPerformanceDataTransmitted
    DTDFVocab:inputTo DataHarmonizationLayer, RealTimeSynchronizationProtocol
]

instance StaticDeviceMetadata : DTDFVocab:Data [
    base:desc "Static device specifications (e.g., sensor/actuator capabilities, spatial relationships) derived from enriched BIM models."
    DTDFVocab:inputTo BimEnrichmentLayer, AutomatedTransformationEngine
]

instance ControlLogicDefinitions : DTDFVocab:Data [
    base:desc "Device-specific control algorithms (PID controllers, rule-based logic) defined within BIM and automatically deployed to the Digital Twin."
    DTDFVocab:inputTo AutomatedTransformationEngine
]

// C11: Enablers
instance BimEnrichmentLayer : DTDFVocab:Enabler [
    base:desc "Extends static BIM models with dynamic operational metadata (sensor/actuator mappings, control logic) to bridge static representations and real-time Digital Twin requirements."
    DTDFVocab:enables DeviceModelingService, ControlLogicImplementationService
]

instance AutomatedTransformationEngine : DTDFVocab:Enabler [
    base:desc "Uses MDE tools (ATL, QVT) to extract structured representations from enriched BIM models and generate deployable Digital Twin artifacts (OPC UA configurations, REST APIs)."
    DTDFVocab:enables ArtifactGenerationService
]

instance DataHarmonizationLayer : DTDFVocab:Enabler [
    base:desc "Ensures semantic consistency between heterogeneous data sources (BIM, IoT sensors, ERP systems) via ontology-based mappings and schema validation."
    DTDFVocab:enables RealTimeMonitoringService
]

instance RealTimeSynchronizationProtocol : DTDFVocab:Enabler [
    base:desc "Bidirectional synchronization mechanism using OPC UA for industrial IoT data exchange and MQTT/CoAP for lightweight sensor updates."
    DTDFVocab:enables RealTimeMonitoringService, OperationalControlService
]

instance PhysicsBasedSimulationEngine : DTDFVocab:Enabler [
    base:desc "Integrates building performance simulation tools (EnergyPlus, IES VE) to validate control logic and predict energy consumption under varying conditions."
    DTDFVocab:enables ScenarioSimulationService, EnergyOptimizationService
]

instance AiAnalyticsModule : DTDFVocab:Enabler [
    base:desc "Embeds Python/R-based machine learning (scikit-learn, TensorFlow) for predictive maintenance, anomaly detection, and adaptive control via service-oriented architecture."
    DTDFVocab:enables PredictiveFailureAnalysisService
]

instance VisualizationRenderer : DTDFVocab:Enabler [
    base:desc "Uses Unity3D/Unreal Engine/WebGL to render interactive 3D/4D visualizations with real-time data overlays (temperature maps, occupancy heatmaps)."
    DTDFVocab:enables ImmersiveVisualizationService
]

instance CustomServiceDevelopmentKit : DTDFVocab:Enabler [
    base:desc "Provides SDKs for Digital Twin engineers to develop plugins using standardized interfaces (RESTful APIs, WebSocket streams, message queues)."
    DTDFVocab:enables PluginDevelopmentService
]

// C6: Services
instance DeviceModelingService : DTDFVocab:Service [
    base:desc "Enables semantic modeling of sensors, actuators, and controllers within BIM to create a unified foundation for Digital Twin artifacts."
    DTDFVocab:provides DeviceConfigurationInsight, ControlLogicDefinitionAction
]

instance ControlLogicImplementationService : DTDFVocab:Service [
    base:desc "Supports definition of control algorithms (PID, rule-based) linked to physical devices with bidirectional BIM-Digital Twin synchronization."
    DTDFVocab:provides ControlAlgorithmInsight, LogicValidationAction
]

instance ArtifactGenerationService : DTDFVocab:Service [
    base:desc "Automatically generates deployable Digital Twin components (simulation models, API endpoints) from enriched BIM models using MDE principles."
    DTDFVocab:provides DeploymentArtifactInsight, AutomatedDeploymentAction
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Facilitates continuous bidirectional synchronization between physical building and Digital Twin via structured data pipelines."
    DTDFVocab:provides SystemStateInsight, DataSynchronizationAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Provides interactive 3D/4D dashboards for real-time monitoring of building operations, system health, and anomaly detection."
    DTDFVocab:provides VisualizationInsight, InteractiveNavigationAction
]

instance OperationalControlService : DTDFVocab:Service [
    base:desc "Enables remote operation of physical infrastructure (HVAC, lighting) through Digital Twin-mediated commands with audit trails."
    DTDFVocab:provides ControlCommandInsight, RemoteOperationAction
]

instance PredictiveFailureAnalysisService : DTDFVocab:Service [
    base:desc "Uses historical sensor data and ML models to predict equipment failures and recommend maintenance actions."
    DTDFVocab:provides FailurePredictionInsight, MaintenanceRecommendationAction
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Implements real-time demand-response algorithms to optimize energy consumption based on occupancy patterns and weather data."
    DTDFVocab:provides EnergyEfficiencyInsight, DemandResponseAction
]

instance ScenarioSimulationService : DTDFVocab:Service [
    base:desc "Provides what-if analysis tools to test control logic changes or infrastructure modifications before physical deployment."
    DTDFVocab:provides SimulationResultInsight, ScenarioTestingAction
]

instance PluginDevelopmentService : DTDFVocab:Service [
    base:desc "Offers standardized extension points for integrating third-party services (predictive maintenance, energy optimization) via plugins."
    DTDFVocab:provides PluginIntegrationInsight, CustomServiceDeploymentAction
]

// C2: Acting Components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Adjusts HVAC system parameters (airflow, temperature) based on control logic derived from Digital Twin simulations and real-time sensor data."
]

instance LightingSystemActuator : DTDFVocab:ActingComponent [
    base:desc "Controls lighting intensity and distribution dynamically based on occupancy and ambient light conditions from Digital Twin analytics."
]

instance DamperActuator : DTDFVocab:ActingComponent [
    base:desc "Regulates airflow through building ducts in response to HVAC control commands generated by the Digital Twin."
]

instance ValveActuator : DTDFVocab:ActingComponent [
    base:desc "Adjusts water flow in plumbing systems according to Digital Twin-validated control logic for efficiency and safety."
]

// C17: Insights/Actions
instance DeviceConfigurationInsight : DTDFVocab:Insight [
    base:desc "Semantic configuration of sensors, actuators, and controllers within the Digital Twin framework for operational readiness."
]

instance ControlAlgorithmInsight : DTDFVocab:Insight [
    base:desc "Definition and validation of control algorithms (PID, rule-based) for building automation systems within the Digital Twin."
]

instance DeploymentArtifactInsight : DTDFVocab:Insight [
    base:desc "Structured representations of Digital Twin components (simulation models, API configurations) automatically generated from BIM."
]

instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Real-time operational state of building systems (HVAC, lighting, structural) synchronized between physical and Digital Twin environments."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D/4D representations of building operations with real-time data overlays (temperature, occupancy) for facility management."
]

instance ControlCommandInsight : DTDFVocab:Insight [
    base:desc "Remote control commands issued to physical actuators via the Digital Twin interface for building automation."
]

instance FailurePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics identifying potential equipment failures based on historical sensor data and machine learning models."
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Optimized energy consumption patterns derived from real-time demand-response algorithms within the Digital Twin."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Validation results from scenario simulations testing control logic changes or infrastructure modifications before deployment."
]

instance PluginIntegrationInsight : DTDFVocab:Insight [
    base:desc "Integration status of third-party services (predictive maintenance, energy optimization) as Digital Twin plugins."
]

instance ControlLogicDefinitionAction : DTDFVocab:Action [
    base:desc "Definition of control logic (PID controllers, rule-based systems) within the Digital Twin framework."
    DTDFVocab:IsAutomatic false
]

instance LogicValidationAction : DTDFVocab:Action [
    base:desc "Validation of control logic against real-time operational data to ensure system performance."
    DTDFVocab:IsAutomatic true
]

instance AutomatedDeploymentAction : DTDFVocab:Action [
    base:desc "Automated generation and deployment of Digital Twin artifacts from enriched BIM models."
    DTDFVocab:IsAutomatic true
]

instance DataSynchronizationAction : DTDFVocab:Action [
    base:desc "Continuous bidirectional synchronization of data between physical building and Digital Twin."
    DTDFVocab:IsAutomatic true
]

instance InteractiveNavigationAction : DTDFVocab:Action [
    base:desc "User interaction with 3D/4D visualizations to explore building operations and system states."
    DTDFVocab:IsAutomatic false
]

instance RemoteOperationAction : DTDFVocab:Action [
    base:desc "Remote adjustment of physical building systems (HVAC, lighting) via Digital Twin interface."
    DTDFVocab:IsAutomatic false
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Automated recommendations for predictive maintenance based on failure prediction analytics."
    DTDFVocab:IsAutomatic true
]

instance DemandResponseAction : DTDFVocab:Action [
    base:desc "Dynamic adjustment of energy consumption in response to real-time demand and occupancy patterns."
    DTDFVocab:IsAutomatic true
]

instance ScenarioTestingAction : DTDFVocab:Action [
    base:desc "Execution of what-if scenarios to test control logic changes or infrastructure modifications."
    DTDFVocab:IsAutomatic true
]

instance CustomServiceDeploymentAction : DTDFVocab:Action [
    base:desc "Deployment of custom services or plugins to extend Digital Twin functionality."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The **virtual-to-physical interaction** in this DT system involves **control flows** initiated by **Facility Managers** or **DT Engineers** through the deployed DT interface. Command types include **real-time monitoring directives, operational adjustments, and device control signals**, formatted as structured messages compliant with the framework’s **modular architecture**. Validation and authentication mechanisms are implied to be embedded within the **runtime configuration management** system, ensuring secure command execution. Feedback systems provide **bidirectional confirmation** of command execution, while **conflict resolution** is managed through the framework’s **holistic life cycle management** approach, which coordinates roles (e.g., Building Control Engineers, Facility Managers) and system components. The framework’s **standardized extension points** allow for dynamic integration of validation logic, ensuring commands are authenticated and executed only after confirmation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **Digital Twin constellation** in the AECO domain is designed to orchestrate **cyber-physical integration** through a **systematic architecture** that combines **static models** (e.g., BIM, CAD, or simulation models) with **runtime data** (e.g., IoT sensor feeds, operational logs, or environmental metrics) to create a **unified virtual representation** of physical assets. The orchestration relies on **carefully designed integration patterns**, though the document does not specify exact **architecture patterns** (e.g., microservices, event-driven, or service-oriented). **Resource management** is implied to be critical due to the **complex and heterogeneous** nature of infrastructure environments, requiring **efficient data fusion, conflict resolution, and real-time analytics** to support predictive maintenance, optimization, and decision-making. **System-wide coordination mechanisms** are necessary to ensure **consistency across lifecycle stages** (design to operation), but the document lacks details on **specific protocols, middleware, or governance models** for this coordination."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin (DT) lifecycle in the proposed model-driven deployment framework spans from **initial device modeling** to **custom DT service development**, addressing the gap between static Building Information Modeling (BIM) representations and dynamic DT requirements. Key phases include:
  1. **Device Modeling**: Building Control Engineers define **sensors, actuators, and controllers** directly within the BIM environment, enriching static BIM models with **semantic representations** of Building Control System (BCS) components (e.g., functional attributes, connectivity, and control logic). This phase establishes a **unified semantic foundation** for subsequent transformations.
  2. **Model Transformation**: Leveraging **Model-Driven Engineering (MDE) principles**, the framework extracts **structured representations** from enriched BIM models and **automatically generates deployable DT artifacts** (e.g., executable models, configuration files) with **minimal manual intervention**. This ensures alignment between physical and digital representations.
  3. **DT Deployment**: The generated artifacts are deployed to the DT environment, enabling **real-time synchronization** between the physical building and its digital twin via **continuous data exchange capabilities**.
  4. **Operation and Monitoring**: Facility Managers interact with the DT to **monitor system states**, visualize operational data through **immersive interfaces**, and **control physical infrastructure** via the twin. This phase emphasizes **interactive visualization** for real-time decision-making.
  5. **Custom Service Integration**: DT Engineers extend functionality by developing and integrating **custom services and plugins** through standardized extension points in the framework’s **modular architecture**, allowing the DT to evolve with operational needs.
  **Transition Management**: The framework supports seamless transitions between phases via **automated model transformations** and **modular deployment pipelines**, ensuring consistency across the lifecycle. **Lifecycle Governance** is implied through role-based access (e.g., Building Control Engineers, Facility Managers, DT Engineers) and **version control** for DT artifacts, though explicit governance frameworks (e.g., ISO standards) are not detailed in the document."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin framework prioritizes **model fidelity** by addressing BIM’s static limitations through **dynamic behavioral and analytical models**, ensuring alignment with physical system states. **Validation and verification** are implicit in the **real-time synchronization** requirement, where discrepancies between physical and digital systems trigger corrective actions (e.g., recalibration of control logic). **Uncertainty sources** include sensor inaccuracies, model simplifications, and latency in data transmission, though **quantification methods** are not specified. **Error detection** relies on **runtime monitoring** by **Facility Managers**, while **correction mechanisms** are automated via the framework’s **modular architecture** (e.g., plugin-based analytics). **Quality assurance** is embedded in the **life-cycle deployment process**, where **DT Engineers** extend functionality to mitigate fidelity gaps, and **Building Control Engineers** validate device configurations against operational requirements."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for this DT system is designed to support **interoperability across heterogeneous systems**, with a **modular architecture** enabling seamless integration of custom services. While specific protocols are not detailed, the framework prioritizes **low-latency, high-bandwidth communication** to facilitate real-time data exchange between physical and digital components. The network topology is implied to be **hybrid**, accommodating cloud, edge, or on-premise deployment models, with **redundancy mechanisms** ensuring reliability. Security protocols are aligned with the **non-functional requirements (NF_X)**, emphasizing **accessibility for users with varying technical expertise** and **low-overhead maintainability**, though exact encryption or authentication methods are unspecified."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **deployment infrastructure** for this DT system supports **multi-model hosting**, including **cloud, edge, and on-premise platforms**, tailored to the operational needs of the AECO (Architecture, Engineering, Construction, and Operations) domain. Computational and storage requirements are optimized for **scalability**, from individual components to entire infrastructure systems, with **runtime configuration management** enabling dynamic adjustments without full redeployment. The framework’s **modular architecture** and **standardized extension points** facilitate **scalable deployment models**, while **availability and reliability** are assured through the non-functional requirements (NF_X), which address **maintainability and interoperability**. The deployment process is initiated by **Building Control Engineers** using BIM tools, with **Facility Managers** interacting with the deployed DT for real-time operations."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The Digital Twin system in the AECO domain must achieve **horizontal integration** with **external systems** to address the **fragmented nature of models and data**, leveraging **interoperability standards** (e.g., IFC for BIM, OPC UA for IoT, or Industry 4.0 protocols) to enable seamless **data exchange** between the DT and **enterprise systems, legacy infrastructure, or other Digital Twins**. Dependencies on external systems are **critical**, as the DT’s value proposition hinges on **real-time, cross-domain insights** (e.g., linking building performance data with energy grids, supply chains, or regulatory databases). Integration patterns may include **API-based connectivity, event-driven architectures, or federated data lakes**, though the document does not specify exact **protocols, technologies, or latency requirements**. The DT’s ability to **collaborate with stakeholders** (e.g., architects, operators, regulators) across the **building lifecycle** implies a need for **standardized interfaces** and **semantic interoperability** to avoid silos, but no concrete examples (e.g., specific APIs, ontologies, or middleware) are provided."
]