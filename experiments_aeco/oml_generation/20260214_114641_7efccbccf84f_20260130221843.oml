// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modelled in BIM, receives control commands from the twin"
]

instance HVACController : DTDFVocab:ActingComponent [
    base:desc "HVAC controller modelled in BIM, receives control commands from the twin"
]

instance BCSActuator : DTDFVocab:ActingComponent [
    base:desc "Other building control system actuators modelled in BIM, receive commands from the twin"
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modelled in BIM, streams detection events to the twin"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modelled in BIM, streams ambient temperature measurements to the twin"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor modelled in BIM, streams light level measurements to the twin"
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor modelled in BIM, streams CO₂ concentration measurements to the twin"
    DTDFVocab:producedData CO2DataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

// C10: Data instances
instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy status stream derived from OccupancySensor"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Ambient temperature measurements derived from TemperatureSensor"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Illuminance measurements derived from IlluminationSensor"
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance CO2Data : DTDFVocab:Data [
    base:desc "CO₂ concentration readings derived from CO2Sensor"
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C10: Models
instance BIMGeometricSemanticModel : DTDFVocab:Model [
    base:desc "BIM geometric and semantic model of the Living Lab building"
    DTDFVocab:inputTo EclipseDitto, ModelDrivenEngineeringEngine
]

instance BuildingControlSystemRuntimeModel : DTDFVocab:Model [
    base:desc "Enriched runtime model of building control systems derived from BIM"
    DTDFVocab:inputTo EclipseDitto, ModelDrivenEngineeringEngine
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Model of control logic governing lighting and HVAC"
    DTDFVocab:inputTo EclipseDitto, ModelDrivenEngineeringEngine
]

instance ReinforcementLearningPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning policies for adaptive lighting control in the BOREALIS scenario"
    DTDFVocab:inputTo EclipseDitto, ModelDrivenEngineeringEngine
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware for protocol adaptation and ingestion of sensor streams"
    DTDFVocab:enables RealTimeMonitoringService, EnergyUsageOptimizationService, RLBasedLightingControlService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for digital twin state management and runtime artifact hosting"
    DTDFVocab:enables RealTimeMonitoringService, EnergyUsageOptimizationService, RLBasedLightingControlService, SimulationService, ModularServiceIntegrationPlatform
]

instance UnrealEngine5VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 providing immersive 3‑D interactive visualization"
    DTDFVocab:enables Interactive3DVisualizationService
]

instance ModelDrivenEngineeringEngine : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering toolchain that transforms enriched BIM into deployable artifacts"
    DTDFVocab:enables SimulationService, ModularServiceIntegrationPlatform
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of sensor streams and actuator states"
    DTDFVocab:provides EnergyConsumptionTrendInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "3‑D interactive visualization of the building in Unreal Engine 5"
    DTDFVocab:provides LightingComfortEvaluationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building performance based on BIM and control models"
    DTDFVocab:provides OptimizedControlSetpointInsight
]

instance EnergyUsageOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes energy usage by analyzing consumption trends and adjusting set‑points"
    DTDFVocab:provides EnergyConsumptionTrendInsight, OptimizedControlSetpointInsight
]

instance RLBasedLightingControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning based lighting control adapting to occupancy and illumination"
    DTDFVocab:provides LightingComfortEvaluationInsight, AdjustLightingControlAction
]

instance ModularServiceIntegrationPlatform : DTDFVocab:Service [
    base:desc "Platform for integrating additional modular services into the twin"
]

// C17: Insights
instance EnergyConsumptionTrendInsight : DTDFVocab:Insight [
    base:desc "Insight delivering energy‑consumption trends for facility managers"
]

instance LightingComfortEvaluationInsight : DTDFVocab:Insight [
    base:desc "Insight evaluating lighting comfort based on occupancy and illumination data"
]

instance OptimizedControlSetpointInsight : DTDFVocab:Insight [
    base:desc "Insight providing optimized control set‑points for building systems"
]

// C17: Actions
instance AdjustLightingControlAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting control set‑points based on RL policy"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command flow from the twin to the physical actuators using the same Hono/Ditto middleware, allowing the twin to issue lighting, HVAC or other control signals to the building."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time (continuous) synchronization between physical sensors and the digital twin, with data exchange occurring as soon as measurements are available."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where the enriched BIM model is processed by a configurator that generates device metadata for Hono/Ditto, a central digital‑twin framework mediates bidirectional communication, and services are added through standardized extension points; the whole system forms the digital twin constellation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports the design, construction and operational stages of the building life‑cycle, enabling the twin to evolve from a design‑time BIM model to an operational model enriched with runtime data."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation is performed before deployment, and the Overall Digital Twin Entanglement (ODTE) metric is used to quantify how closely the twin reflects its physical counterpart, providing a measure of fidelity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional data exchange is realized through the Eclipse Hono middleware (device ingress) coupled with Eclipse Ditto (digital‑twin state management), forming the technical link between physical devices and the virtual model."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach leverages BIM as an established industry standard for building data and defines standardized extension points for modular services, ensuring interoperability across tools and platforms."
]