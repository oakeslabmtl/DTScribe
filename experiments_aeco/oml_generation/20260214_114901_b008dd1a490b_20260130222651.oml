// ---------------------------------------------------
// C3: Physical sensing components
// ---------------------------------------------------
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in the enriched BIM model, measures ambient temperature in building zones."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor modeled in the enriched BIM model, measures relative humidity."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in the enriched BIM model, detects presence of occupants."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// ---------------------------------------------------
// C4: Physical-to-virtual interaction – DataTransmitted
// ---------------------------------------------------
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// ---------------------------------------------------
// C10: Data streams
// ---------------------------------------------------
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature readings streamed to the digital twin."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Real-time humidity readings streamed to the digital twin."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy status streamed to the digital twin."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
]

// ---------------------------------------------------
// C2: Acting components (actuators)
// ---------------------------------------------------
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator modeled in BIM, receives commands to adjust heating, ventilation and air‑conditioning."
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in BIM, controls lighting levels throughout spaces."
]

instance ShadingActuator : DTDFVocab:ActingComponent [
    base:desc "Shading device actuator modeled in BIM, adjusts blinds or shades for daylight control."
]

// ---------------------------------------------------
// C10: Models / Data
// ---------------------------------------------------
instance GeometricModel : DTDFVocab:Model [
    base:desc "Geometric model inherited from the BIM representation of building spaces and elements."
    DTDFVocab:inputTo VisualizationEngineEnabler
]

instance BehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model encoding sensor, actuator and controller logic defined directly in the enriched BIM."
    DTDFVocab:inputTo RealTimeDataExchangeEnabler
    DTDFVocab:inputTo ControlLoopEnabler
]

instance EnergyAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model used for predictive energy and climate performance simulation, introduced as a custom service plugin."
    DTDFVocab:inputTo PredictiveSimulationEnabler
]

// ---------------------------------------------------
// C11: Enablers
// ---------------------------------------------------
instance RealTimeDataExchangeEnabler : DTDFVocab:Enabler [
    base:desc "Real‑time data exchange layer that continuously synchronises sensor streams with the digital twin."
    DTDFVocab:enables RealTimeMonitoringService, ClosedLoopControlService, PredictiveEnergySimulationService
]

instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine based 3D visualization engine delivering an immersive dashboard."
    DTDFVocab:enables Interactive3DVisualizationService
]

instance ControlLoopEnabler : DTDFVocab:Enabler [
    base:desc "Closed‑loop control engine that processes monitoring data and issues commands to physical actuators."
    DTDFVocab:enables ClosedLoopControlService
]

instance PredictiveSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that executes predictive energy and climate performance models."
    DTDFVocab:enables PredictiveEnergySimulationService
]

// ---------------------------------------------------
// C6: Services
// ---------------------------------------------------
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of all sensor streams."
    DTDFVocab:provides LiveStatusInsight, AnomalyAlertInsight
]

instance PredictiveEnergySimulationService : DTDFVocab:Service [
    base:desc "Runs predictive simulation of energy and climate performance and supports what‑if scenario analysis."
    DTDFVocab:provides EnergyPerformanceInsight, WhatIfScenarioInsight
]

instance LifecycleOptimizationService : DTDFVocab:Service [
    base:desc "Optimises HVAC and lighting set‑points across the building lifecycle."
    DTDFVocab:provides AdjustSetpointAction
]

instance ClosedLoopControlService : DTDFVocab:Service [
    base:desc "Issues closed‑loop control commands to actuators based on monitoring data."
    DTDFVocab:provides IssueControlCommandAction
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Displays an immersive 3D dashboard using Unreal Engine for decision support."
    DTDFVocab:provides VisualizationInsight
]

// ---------------------------------------------------
// C17: Insights
// ---------------------------------------------------
instance LiveStatusInsight : DTDFVocab:Insight [
    base:desc "Live status of sensor readings, actuator states and controller outputs presented via immersive visualisation."
]

instance AnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Anomaly alerts generated when sensor data deviate from expected operating ranges."
]

instance EnergyPerformanceInsight : DTDFVocab:Insight [
    base:desc "Predictive energy and climate performance results derived from simulation models."
]

instance WhatIfScenarioInsight : DTDFVocab:Insight [
    base:desc "Results of what‑if scenario simulations to support facility‑manager decision making."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D visual representation of the building state within the Unreal Engine dashboard."
]

// ---------------------------------------------------
// C17: Actions
// ---------------------------------------------------
instance IssueControlCommandAction : DTDFVocab:Action [
    base:desc "Facility Manager issues control commands to physical actuators through the interactive visualization."
    DTDFVocab:IsAutomatic false
]

instance AdjustSetpointAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of HVAC and lighting set‑points based on optimisation recommendations."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Through the same bidirectional data exchange, the DT Framework forwards control actions issued by Facility Managers or automated control logic to the physical building. Commands are routed via the framework’s central hub to the addressed devices, enabling real-time monitoring and control of building systems."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system employs a model‑driven framework that defines a modular architecture with explicit extension points. Core components include a BIM‑based static model, a real‑time data ingestion layer built on Eclipse Hono, a digital‑twin state management service provided by Eclipse Ditto, and a 3‑D visualization front‑end realised with Unreal Engine. Orchestration is achieved by coupling Hono’s MQTT/HTTP gateways to Ditto’s twin management APIs, while the framework automatically generates runtime interfaces from domain semantics. Resource management is handled through the modular plug‑in mechanism, allowing independent deployment of each component and coordinated lifecycle via a central configuration service."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a four‑stage life‑cycle: (1) Device Modeling – Building Control Engineers enrich BIM with sensor, actuator and controller entities; (2) Model Extraction – Model‑Driven Engineering (MDE) transforms the enriched BIM into a structured meta‑model; (3) Artifact Generation & Deployment – the meta‑model is automatically compiled into deployable DT services and runtime containers; (4) Operation & Maintenance – real‑time data exchange synchronises the physical building with the deployed twin, while facility managers monitor and control via interactive visualisation. Transitions are managed by automated model‑to‑code pipelines and governed by role‑based responsibilities (engineer, manager, DT engineer) as defined in Table I."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by extending static BIM geometry with behavioral definitions for sensors, actuators, and control logic, thereby reducing the semantic gap between the physical building and its digital replica. Validation is implied through the MDE workflow that automatically extracts structured representations from the enriched BIM and generates deployable DT artifacts, minimizing manual errors. Continuous real‑time data exchange serves as an implicit verification mechanism, ensuring that the digital state reflects the physical reality. No explicit procedures for uncertainty quantification, error correction, or formal quality‑assurance processes are described in the provided documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The solution adopts a modular architecture with standardized extension points that support interoperability among heterogeneous building systems. Real-time data exchange is achieved over the network infrastructure managed by the DT Framework, whose non‑functional requirements include scalability, maintainability and accessibility; the framework can be reconfigured at runtime to adapt to changing network conditions."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is realised through the Eclipse Hono connector, which supports MQTT, HTTP and CoAP for IoT device ingestion, and through Eclipse Ditto, which exposes a REST/WebSocket API adhering to the Ditto Twin Model for interoperability. The framework adopts standard integration patterns (e.g., publish‑subscribe via MQTT, twin synchronization via Ditto’s twin‑update streams) to interoperate with enterprise ERP, BIM repositories, and other digital twins. Unreal Engine consumes the twin state via Ditto’s WebSocket interface, enabling real‑time visualization. This architecture enables loose coupling and protocol‑agnostic data exchange across heterogeneous platforms."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The solution is built on Building Information Modeling (BIM) as the core standards backbone and exposes standardized extension points defined by the framework for plug‑in integration. It targets compatibility with existing AECO‑specific systems and standards that rely on BIM representations. No additional industry standards (e.g., IFC, ISO 19443) are explicitly mentioned in the document."
]