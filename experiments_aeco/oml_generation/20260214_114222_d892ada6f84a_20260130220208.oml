// Acting Component
instance LightActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator representing a light, modeled in the BIM model and represented in UE5 as LightTwinComponent, supports on/off, brightness and colour temperature."
]

// Sensing Components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in the enriched BIM model, provides room temperature readings."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in the enriched BIM model, detects presence of occupants."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Energy consumption sensor defined in the enriched BIM model, measures building energy usage."
    DTDFVocab:producedData EnergyDataTransmitted
]

// DataTransmitted instances
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

// Data instances
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature reading values transmitted via Eclipse Hono with at-least-once delivery."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy status values transmitted via Eclipse Hono with at-least-once delivery."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance EnergyData : DTDFVocab:Data [
    base:desc "Energy consumption measurements transmitted via Eclipse Hono with at-least-once delivery."
    DTDFVocab:fromData EnergyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

// Models
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing geometric building data and explicit device definitions (sensors, actuators, controllers)."
    DTDFVocab:inputTo EclipseDittoEnabler
]

instance LightFeatureParserModel : DTDFVocab:Model [
    base:desc "FeatureParser service model (LightFeatureParser) that maps light device states to actions."
    DTDFVocab:inputTo EclipseDittoEnabler
]

// Enablers
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware providing at-least-once message delivery from sensors to the twin."
    DTDFVocab:enables RealTimeDataIngestionService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto platform storing twin state, enforcing policy‑based validation and persisting events."
    DTDFVocab:enables TwinStateManagementService, ControlLogicService, CustomAnalyticsService
]

// Services
instance RealTimeDataIngestionService : DTDFVocab:Service [
    base:desc "Service that ingests sensor data streams in real time via Eclipse Hono."
    DTDFVocab:provides BuildingPerformanceInsight
]

instance TwinStateManagementService : DTDFVocab:Service [
    base:desc "Service that manages digital twin state, applies policy‑based validation and synchronises with physical devices."
    DTDFVocab:provides LightingControlAction
]

instance ControlLogicService : DTDFVocab:Service [
    base:desc "Service executing control logic defined by Building Control Engineers, using FeatureParser components."
    DTDFVocab:provides LightingControlAction
]

instance CustomAnalyticsService : DTDFVocab:Service [
    base:desc "Extensible analytics service hosting custom plugins for optimisation, predictive maintenance and what‑if scenario analysis."
    DTDFVocab:provides EnergyOptimizationInsight, PredictiveMaintenanceInsight
]

// Insights and Actions
instance BuildingPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight presenting up‑to‑date sensor data and building performance metrics to facility managers."
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight offering recommendations for energy savings based on analytics."
]

instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Insight alerting to potential equipment failures predicted by analytics."
]

instance LightingControlAction : DTDFVocab:Action [
    base:desc "Action to turn lights on/off, adjust brightness or colour temperature via the twin."
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The framework adopts a modular architecture centred on a central DT Framework that acts as a hub for bidirectional data exchange between the physical building and its digital counterpart. Standardised extension points allow DT Engineers to plug in custom services and analytics, while runtime configuration management enables on‑the‑fly adjustments without redeployment. The architecture coordinates distinct roles—Building Control Engineers model devices via BIM tools, Facility Managers interact with the deployed twin for real-time monitoring and control, and DT Engineers extend functionality—ensuring systematic orchestration of the Digital Twin lifecycle."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework supports the full DT life‑cycle from initial device modeling within the BIM environment (definition of sensors, actuators, controllers), model‑driven extraction of structured representations using MDE principles, automatic generation of deployable DT artifacts, deployment and real‑time operation with continuous data synchronization, runtime monitoring and interactive visualization, and subsequent evolution through modular extension points that allow integration of custom services and analytics."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is achieved by importing accurate geometric data from BIM and photometric parameters from Revit for realistic UE5 rendering. Validation occurs at multiple stages: the DT framework’s validation component checks model consistency, Eclipse Ditto applies policy‑based validation of sensor data and actuator commands, and pre‑execution checks prevent unsafe operations. Fault tolerance is provided by Hono’s at‑least‑once delivery and Ditto’s persistent event storage, ensuring synchronization despite network failures. The documents do not detail quantitative uncertainty quantification or formal verification methods."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The solution emphasizes interoperability across heterogeneous systems through non‑functional requirements that address scalability and maintainability. Integration is achieved via standardized extension points and bidirectional data exchange mechanisms, allowing external services, analytics, and other enterprise systems to be incorporated without a full system redesign. While specific protocols are not enumerated, the architecture is designed to support generic data exchange standards and to facilitate seamless horizontal integration with other Digital Twins and enterprise applications."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The proposed solution is built on the BIM standard as the core AECO data model and references industry‑wide DT frameworks (Eclipse Ditto, BaSyx) that comply with established interoperability specifications. However, the documents do not list additional certifications, compliance frameworks, or detailed data‑schema standards beyond BIM and the mentioned open‑source framework standards."
]