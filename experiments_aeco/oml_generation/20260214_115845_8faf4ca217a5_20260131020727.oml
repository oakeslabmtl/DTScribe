// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modelled in the BIM that generates post‑occupancy sensor data for the TwinLight and BOREALIS use cases."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination (lighting) sensor modelled in the BIM that measures ambient light levels."
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental temperature sensor modelled in the BIM for monitoring indoor climate."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Environmental humidity sensor modelled in the BIM for monitoring indoor climate."
    DTDFVocab:producedData HumidityDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

// C10: Data
instance OccupancyData : DTDFVocab:Data [
    base:desc "Post‑occupancy sensor data stream used for real‑time monitoring and reinforcement‑learning policies."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Illumination measurements streamed for visual comfort analysis."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature measurements streamed for climate control and predictive analytics."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Humidity measurements streamed for climate control and predictive analytics."
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modelled in the BIM and controllable by the twin."
]

instance HVACController : DTDFVocab:ActingComponent [
    base:desc "HVAC controller modelled in the BIM and controllable by the twin."
]

// C10: Models/Data
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Static BIM geometry providing the foundational 3D representation of the building."
    DTDFVocab:inputTo ModelDrivenTransformationPipeline, BIMAuthoringTools
]

instance BIMSemanticModel : DTDFVocab:Model [
    base:desc "Static BIM semantic data describing assets, spaces and system relationships."
    DTDFVocab:inputTo ModelDrivenTransformationPipeline, BIMAuthoringTools
]

instance DeviceInterfaceModel : DTDFVocab:Model [
    base:desc "Generated device interface descriptors for sensors and actuators."
    DTDFVocab:inputTo EclipseDitto
]

instance SensorDataStreamModel : DTDFVocab:Model [
    base:desc "Model of sensor data streams used by the twin for real‑time monitoring."
    DTDFVocab:inputTo EclipseDitto
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control logic models defining automated strategies for lighting and HVAC."
    DTDFVocab:inputTo EclipseDitto
]

instance ReinforcementLearningPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning policies derived from post‑occupancy data for the BOREALIS project."
    DTDFVocab:inputTo EclipseDitto
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware that ingests sensor streams from physical devices and forwards them to the digital twin."
    DTDFVocab:enables VisualizationService, PredictiveAnalyticsService, EnergyOptimizationService, ControlStrategySimulationService, InteractiveMonitoringService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin platform that stores twin state and executes control commands."
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders real‑time 3D visualizations of the building twin."
    DTDFVocab:enables VisualizationService
]

instance ModelDrivenTransformationPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation pipeline that generates device descriptors, control logic models and reinforcement‑learning policies."
    DTDFVocab:enables PredictiveAnalyticsService, EnergyOptimizationService, ControlStrategySimulationService
]

instance BIMAuthoringTools : DTDFVocab:Enabler [
    base:desc "BIM authoring tools used to enrich the BIM with device and middleware metadata."
]

instance HonoDittoConfigurator : DTDFVocab:Enabler [
    base:desc "Configurator that extracts device metadata from enriched BIM and creates Hono/Ditto descriptors."
]

// C6: Services
instance VisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of the building twin using Unreal Engine 5."
    DTDFVocab:provides RealTimeDashboardInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics that forecast building performance and generate insights."
    DTDFVocab:provides PredictivePerformanceInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Energy‑optimization calculations that recommend set‑point adjustments."
    DTDFVocab:provides OptimizationRecommendationInsight, AdjustControlSetpointAction
]

instance ControlStrategySimulationService : DTDFVocab:Service [
    base:desc "Simulation of control strategies for lighting, HVAC and other systems."
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance InteractiveMonitoringService : DTDFVocab:Service [
    base:desc "Interactive monitoring dashboards for facility managers."
    DTDFVocab:provides RealTimeDashboardInsight
]

// C17: Insights
instance RealTimeDashboardInsight : DTDFVocab:Insight [
    base:desc "Real‑time state dashboards informing facility‑manager decisions."
]

instance PredictivePerformanceInsight : DTDFVocab:Insight [
    base:desc "Predictive performance analytics supporting proactive maintenance."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendations that guide energy‑saving actions and control set‑points."
]

// C17: Actions
instance AdjustControlSetpointAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of control set‑points for lighting or HVAC based on optimization recommendations."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points, HVAC adjustments) are sent back to the physical actuators through the same Hono/Ditto bidirectional channel."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where an enriched BIM model feeds a configurator that provisions devices in Hono/Ditto, a runtime twin service layer, and a UE5 visualization front‑end; extension points allow integration of custom services and analytics."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin spans design (BIM authoring), construction (deployment of runtime interfaces), and operation (continuous data exchange and optimization) phases of the building life‑cycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to quantify how well the twin reflects its physical counterpart; model validation is performed before deployment to ensure semantic correctness."
]