// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator defined in the BIM model, receives control commands from the DT via middleware."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator defined in the BIM model, receives control commands from the DT for temperature regulation."
]

instance BCSOutputDevice : DTDFVocab:ActingComponent [
    base:desc "General building control system output device for miscellaneous control signals."
]

// C3: Physical sensing components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor defined in the BIM model, measures ambient illumination levels.",
    producedData LightSensorTelemetry
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in the BIM model, detects presence of occupants.",
    producedData OccupancySensorTelemetry
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in the BIM model, measures indoor air temperature.",
    producedData TemperatureSensorTelemetry
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor defined in the BIM model, measures indoor relative humidity.",
    producedData HumiditySensorTelemetry
]

// C4: Physical-to-virtual interaction
instance LightSensorTelemetry : DTDFVocab:DataTransmitted [
    producedFrom LightSensor
]

instance OccupancySensorTelemetry : DTDFVocab:DataTransmitted [
    producedFrom OccupancySensor
]

instance TemperatureSensorTelemetry : DTDFVocab:DataTransmitted [
    producedFrom TemperatureSensor
]

instance HumiditySensorTelemetry : DTDFVocab:DataTransmitted [
    producedFrom HumiditySensor
]

// C5: Data instances
instance LightLevelData : DTDFVocab:Data [
    base:desc "Telemetry stream of light intensity values from LightSensor.",
    fromData LightSensorTelemetry,
    inputTo EclipseDittoTwin, EclipseHonoIngestion
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Telemetry stream indicating occupancy status from OccupancySensor.",
    fromData OccupancySensorTelemetry,
    inputTo EclipseDittoTwin, EclipseHonoIngestion
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Telemetry stream of indoor temperature readings from TemperatureSensor.",
    fromData TemperatureSensorTelemetry,
    inputTo EclipseDittoTwin, EclipseHonoIngestion
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Telemetry stream of indoor humidity readings from HumiditySensor.",
    fromData HumiditySensorTelemetry,
    inputTo EclipseDittoTwin, EclipseHonoIngestion
]

// C10: Models/Data
instance BuildingInformationModel : DTDFVocab:Model [
    base:desc "Static BIM model providing geometry, topology and component relationships and runtime semantics (sensor/actuator definitions, control logic).",
    inputTo UnrealEngine5Visualization, HonoDittoConfigurator
]

// C11: Enablers
instance EclipseHonoIngestion : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware for real‑time data ingestion via MQTT/HTTP.",
    enables LightMonitoringService, OccupancyMonitoringService, TemperatureMonitoringService, HumidityMonitoringService
]

instance EclipseDittoTwin : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto representing the digital twin, receives data from Hono and stores twin state.",
    enables LightMonitoringService, OccupancyMonitoringService, TemperatureMonitoringService, HumidityMonitoringService, EnergyOptimizationService
]

instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 used for immersive 3‑D visualization of the BIM model and live sensor data.",
    enables Interactive3DVisualizationService
]

instance HonoDittoConfigurator : DTDFVocab:Enabler [
    base:desc "Configurator that extracts device metadata from the BIM model and generates Ditto twin definitions.",
    enables EnergyOptimizationService
]

instance ReinforcementLearningEngine : DTDFVocab:Enabler [
    base:desc "Reinforcement‑learning engine for automated lighting and HVAC control policy optimization.",
    enables EnergyOptimizationService
]

// C6: Services
instance LightMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of illumination levels and automatic lighting adjustments.",
    provides LightingQualityInsight, AutomatedLightingControlAction
]

instance OccupancyMonitoringService : DTDFVocab:Service [
    base:desc "Monitoring occupancy to optimize lighting and HVAC usage.",
    provides OccupantComfortInsight, AutomatedLightingControlAction
]

instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Monitoring indoor temperature for occupant comfort and energy optimisation.",
    provides TemperatureComfortInsight, EnergyOptimizationAction
]

instance HumidityMonitoringService : DTDFVocab:Service [
    base:desc "Monitoring indoor humidity to maintain comfort and prevent condensation.",
    provides HumidityComfortInsight, EnergyOptimizationAction
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Applies reinforcement‑learning based lighting and HVAC strategies to minimise energy consumption.",
    provides EnergyConsumptionInsight, EnergyOptimizationAction
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3‑D visualization of the building twin in Unreal Engine 5.",
    provides LightingQualityInsight
]

// C17: Insights
instance LightingQualityInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight on lighting quality and illumination uniformity."
]

instance OccupantComfortInsight : DTDFVocab:Insight [
    base:desc "Insight on occupant comfort derived from occupancy and environmental conditions."
]

instance TemperatureComfortInsight : DTDFVocab:Insight [
    base:desc "Insight on thermal comfort based on temperature measurements."
]

instance HumidityComfortInsight : DTDFVocab:Insight [
    base:desc "Insight on humidity comfort levels for occupants."
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight on real‑time energy consumption of lighting and HVAC systems."
]

// C17: Actions
instance AutomatedLightingControlAction : DTDFVocab:Action [
    base:desc "Automatically adjust lighting levels based on sensor data and defined policies.",
    DTDFVocab:IsAutomatic true
]

instance EnergyOptimizationAction : DTDFVocab:Action [
    base:desc "Apply optimized control set‑points to HVAC and lighting actuators.",
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., lighting set‑points, HVAC set‑points) are sent back to the physical devices via Ditto’s command API and forwarded through Eclipse Hono to the actuators, enabling bidirectional, closed‑loop operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where the BIM‑derived model, the Hono/Ditto middleware and the Unreal Engine visualizer are orchestrated by a central DT framework that provides standardized extension points for additional services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the design stage (BIM model creation), construction stage (model validation and device mapping) and the operational stage where live sensor data synchronizes the virtual model with the physical building."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to quantify how well the virtual twin reflects the physical building; model validation steps ensure semantic consistency before deployment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono supplies the network protocol layer (MQTT/HTTP) to connect physical sensors/actuators to the cloud, while Eclipse Ditto provides the digital‑twin API (NGSI‑LD style) for data exchange and command handling."
]