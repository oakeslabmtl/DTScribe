//=== Sensors ===========================================================
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the living lab building, hierarchically linked in BIM, measuring ambient temperature."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance LuminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Luminance sensor measuring light levels for lighting control, hierarchically linked in BIM."
    DTDFVocab:producedData LuminanceDataTransmitted
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector using infrared proximity to detect presence in rooms."
    DTDFVocab:producedData OccupancyDataTransmitted
]

//=== Data Transmitted ==================================================
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance LuminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LuminanceSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

//=== Data ==============================================================
instance TemperatureTelemetryData : DTDFVocab:Data [
    base:desc "Live temperature telemetry stream received via MQTT from the building automation network."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance LuminanceTelemetryData : DTDFVocab:Data [
    base:desc "Live luminance telemetry stream received via MQTT from the building automation network."
    DTDFVocab:fromData LuminanceDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

instance OccupancyTelemetryData : DTDFVocab:Data [
    base:desc "Live occupancy telemetry stream received via MQTT from the building automation network."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler
]

//=== Acting Components =================================================
instance LightingDimmingControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator controlling LED strip dimming, exposed via Ditto twin for remote adjustment."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for HVAC system control (fans, dampers) exposed via Ditto twin."
]

instance MotorisedShadingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator for motorised shading blinds, exposed via Ditto twin for integration with lighting control."
]

//=== Enablers ===========================================================
instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT gateway, facilitating real‑time streaming of sensor telemetry to Ditto twins."
    DTDFVocab:enables MQTTGatewayService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin registry, managing twin entities and processing state changes."
    DTDFVocab:enables EnergyForecastService,
        OccupancyComfortOptimisationService,
        MaintenanceAlertService,
        AutomatedParameterUpdateService,
        RealTimeDashboardService,
        LightingOptimizationService,
        HVACOptimizationService
]

instance UnrealEngine5Enabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5, providing immersive 3D rendering of the building’s virtual replica."
    DTDFVocab:enables Immersive3DRenderingService
]

instance RevitExporterEnabler : DTDFVocab:Enabler [
    base:desc "BIM authoring tool (Revit/IFC export), converting enriched BIM models for runtime use."
    DTDFVocab:enables BIMExportService
]

instance BIMExportService : DTDFVocab:Service [
    base:desc "Service exporting enriched BIM via IFC for runtime transformation."
]

instance ModelDrivenEngineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering tool transforming enriched BIM into runtime artefacts."
    DTDFVocab:enables SimulationWorkflowService
]

//=== Services ==========================================================
instance MQTTGatewayService : DTDFVocab:Service [
    base:desc "MQTT gateway service that aggregates raw sensor telemetry streams."
    DTDFVocab:provides TelemetryProcessingInsight
]

instance EnergyForecastService : DTDFVocab:Service [
    base:desc "Service computing energy consumption forecasts from telemetry data."
    DTDFVocab:provides EnergyConsumptionForecastInsight
]

instance OccupancyComfortOptimisationService : DTDFVocab:Service [
    base:desc "Service optimizing occupant comfort based on occupancy and environmental telemetry."
    DTDFVocab:provides OccupantComfortOptimisationInsight
]

instance MaintenanceAlertService : DTDFVocab:Service [
    base:desc "Service generating maintenance alerts from sensor anomalies."
    DTDFVocab:provides MaintenanceAlertInsight
]

instance AutomatedParameterUpdateService : DTDFVocab:Service [
    base:desc "Service automatically updating system parameters in Ditto twins."
    DTDFVocab:provides AutomatedParameterUpdateAction
]

instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Service delivering real‑time monitoring dashboards to facility managers."
    DTDFVocab:provides ActionableDashboardInsight
]

instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing lighting levels and energy use based on sensor data."
    DTDFVocab:provides LightingOptimisationInsight
]

instance HVACOptimizationService : DTDFVocab:Service [
    base:desc "Service optimizing HVAC operation for energy savings and comfort."
    DTDFVocab:provides HVACOptimisationInsight
]

instance SimulationWorkflowService : DTDFVocab:Service [
    base:desc "Service running simulation workflows on transformed runtime artefacts."
    DTDFVocab:provides SimulationResultInsight
]

instance Immersive3DRenderingService : DTDFVocab:Service [
    base:desc "Service rendering immersive 3D visualisation via Unreal Engine 5."
    DTDFVocab:provides Rendering3DInsight
]

//=== Insights =========================================================
instance TelemetryProcessingInsight : DTDFVocab:Insight [
    base:desc "Aggregated sensor telemetry ready for higher‑level analysis."
]

instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasts of building energy consumption based on historical and live telemetry."
]

instance OccupantComfortOptimisationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for occupant comfort optimisation derived from environmental data."
]

instance MaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Alerts indicating maintenance needs detected by anomaly detection algorithms."
]

instance ActionableDashboardInsight : DTDFVocab:Insight [
    base:desc "Visual dashboards presenting actionable metrics to facility managers."
]

instance LightingOptimisationInsight : DTDFVocab:Insight [
    base:desc "Optimisation opportunities for lighting energy savings and daylighting."
]

instance HVACOptimisationInsight : DTDFVocab:Insight [
    base:desc "Opportunities for HVAC energy reduction while maintaining thermal comfort."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Results from simulation workflows applied to the building model."
]

instance Rendering3DInsight : DTDFVocab:Insight [
    base:desc "Immersive 3D rendering of building interior and occupant activities."
]

//=== Actions =========================================================
instance AutomatedParameterUpdateAction : DTDFVocab:Action [
    base:desc "Automated updates of actuator parameters in Ditto twins based on optimisation algorithms."
    DTDFVocab:IsAutomatic true
]

//=== Data (additional) ==============================================
instance BIMEnrichedModelData : DTDFVocab:Data [
    base:desc "Semantically enriched BIM model including device and control definitions."
    DTDFVocab:inputTo RevitExporterEnabler
]

instance RevitExportData : DTDFVocab:Data [
    base:desc "IFC export of the enriched BIM model for runtime transformation."
    DTDFVocab:inputTo ModelDrivenEngineEnabler
]

instance Unreal3DAssetData : DTDFVocab:Data [
    base:desc "Unreal Engine 5 3D assets representing the building’s virtual replica."
    DTDFVocab:inputTo UnrealEngine5Enabler
]

instance DittoConfigData : DTDFVocab:Data [
    base:desc "Configuration metadata for Eclipse Hono and Ditto integration."
    DTDFVocab:inputTo EclipseDittoEnabler
]

//=== Models ===========================================================
instance BIMSemanticallyEnrichedModel : DTDFVocab:Model [
    base:desc "BIM model enriched with semantic annotations for devices and controls."
    DTDFVocab:inputTo RevitExporterEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (e.g., dimming setpoints, HVAC setpoints) published from Ditto twin entities over MQTT through Eclipse Hono to the physical controllers, enabling real‑time actuation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralised twin middleware orchestrating sensor telemetry, control logic, and visualisation modules via Ditto; all components integrated within a modular, service‑oriented platform with defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (ideal), Construction (manufacturing), and Operations (field operation) – the DT spans all three life‑cycle phases of the building."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric to quantify structural‑semantic alignment; periodic synchronization checks between live sensor data and BIM‑extracted model attributes; monitoring of semantic drift; validation against on‑site measurements."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT protocol over TLS via Eclipse Hono; Ditto’s MQTT event bus; HTTP/REST for configuration; underlying network may use WebSocket connections; all traffic authenticated and encrypted."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adheres to Industry Foundation Classes (IFC) for BIM; uses MQTT and REST protocols defined by Eclipse Hono; follows ISO 19650 for BIM information management; leverages open‑source standards of Eclipse Ditto."
]