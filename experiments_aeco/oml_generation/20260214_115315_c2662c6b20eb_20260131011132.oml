// C3: Physical sensing components
instance BuildingTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in the enriched BIM model, providing continuous real‑time temperature readings from the building."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance BuildingOccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM, delivering real‑time occupancy status streams for the building zones."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance BuildingPowerSensor : DTDFVocab:SensingComponent [
    base:desc "Power/energy consumption sensor captured in the BIM device model, emitting continuous power usage data."
    DTDFVocab:producedData PowerDataTransmitted
]

// C4: Physical‑to‑virtual interaction – Data transmitted
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingTemperatureSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingOccupancySensor
]

instance PowerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingPowerSensor
]

// C10: Data objects
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature data stream originating from the building temperature sensor."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoIngestionEnabler, EclipseDittoStateEnabler
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy status data stream generated by the occupancy sensor."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoIngestionEnabler, EclipseDittoStateEnabler
]

instance PowerData : DTDFVocab:Data [
    base:desc "Power consumption data stream supplied by the building power sensor."
    DTDFVocab:fromData PowerDataTransmitted
    DTDFVocab:inputTo EclipseHonoIngestionEnabler, EclipseDittoStateEnabler
]

// C11: Enablers (tooling and middleware)
instance EclipseHonoIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides secure, scalable ingestion of IoT sensor data streams."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance EclipseDittoStateEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital‑twin state and offers event‑driven APIs for downstream services."
    DTDFVocab:enables PhysicsBasedSimulationService, LifecycleOptimizationService, PredictiveAnalyticsService, Interactive3DVisualizationService, FacilityControlService
]

instance UnrealEngineVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unreal Engine renders high‑fidelity, interactive 3‑D visualisations of the twin."
    DTDFVocab:enables Interactive3DVisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides continuous monitoring of sensor streams, keeping the digital replica synchronised with the physical building."
    DTDFVocab:provides RealTimeStateInsight
]

instance PhysicsBasedSimulationService : DTDFVocab:Service [
    base:desc "Executes physics‑based simulation of building performance using the simulation model."
    DTDFVocab:provides PerformanceSimulationInsight
]

instance LifecycleOptimizationService : DTDFVocab:Service [
    base:desc "Optimises energy consumption and schedules maintenance across the whole building lifecycle."
    DTDFVocab:provides EnergyOptimizationInsight, MaintenanceSchedulingInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Runs custom analytics such as fault detection, occupancy trend extraction and energy consumption pattern analysis."
    DTDFVocab:provides FaultDetectionInsight, OccupancyTrendInsight, EnergyConsumptionPatternInsight, RecommendationInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Delivers immersive 3‑D visualisation and interactive UI for facility managers to observe and control the twin."
    DTDFVocab:provides VisualizationInsight, ManualControlAction
]

instance FacilityControlService : DTDFVocab:Service [
    base:desc "Enables remote invocation of actuators (dampers, valves, lighting) through the twin interface."
    DTDFVocab:provides AdjustDamperAction, AdjustValveAction, ToggleLightingAction
]

// C17: Insights
instance RealTimeStateInsight : DTDFVocab:Insight [
    base:desc "Insight into the current real‑time state of building systems derived from live sensor data."
]

instance PerformanceSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from physics‑based simulation showing projected building performance metrics."
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending energy‑saving strategies based on optimisation calculations."
]

instance MaintenanceSchedulingInsight : DTDFVocab:Insight [
    base:desc "Insight providing optimal maintenance schedules to reduce downtime and cost."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight identifying potential faults in equipment before failure occurs."
]

instance OccupancyTrendInsight : DTDFVocab:Insight [
    base:desc "Insight revealing occupancy patterns and trends extracted from occupancy sensor data."
]

instance EnergyConsumptionPatternInsight : DTDFVocab:Insight [
    base:desc "Insight highlighting patterns in energy consumption across building zones."
]

instance RecommendationInsight : DTDFVocab:Insight [
    base:desc "Actionable recommendations presented to facility managers for operational decisions."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight generated by the 3‑D visualisation layer, reflecting the synchronized twin state."
]

// C17: Actions
instance ManualControlAction : DTDFVocab:Action [
    base:desc "Allows facility managers to manually control building devices via the immersive UI."
    DTDFVocab:IsAutomatic false
]

instance AdjustDamperAction : DTDFVocab:Action [
    base:desc "Command to adjust HVAC damper positions remotely."
    DTDFVocab:IsAutomatic false
]

instance AdjustValveAction : DTDFVocab:Action [
    base:desc "Command to open or close a valve in the building's fluid systems."
    DTDFVocab:IsAutomatic false
]

instance ToggleLightingAction : DTDFVocab:Action [
    base:desc "Command to switch lighting fixtures on or off."
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance DamperActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator representing a controllable damper, modeled in the BIM device model."
]

instance ValveActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator representing a valve for fluid flow, defined within the BIM model."
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Actuator representing a lighting fixture, included in the BIM device description."
]

// C10: Models / Data artifacts
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Primary geometric representation of the building derived from the BIM model."
    DTDFVocab:inputTo UnrealEngineVisualizationEnabler
]

instance DeviceModelExtension : DTDFVocab:Model [
    base:desc "Extended BIM model component that captures sensor, actuator and controller definitions."
    DTDFVocab:inputTo EclipseDittoStateEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model encoding control logic authored by building control engineers within BIM."
    DTDFVocab:inputTo EclipseDittoStateEnabler
]

instance SimulationPhysicsModel : DTDFVocab:Model [
    base:desc "Physics‑based simulation model used by the PhysicsBasedSimulationService."
    DTDFVocab:inputTo EclipseDittoStateEnabler
]

// C17: Environment
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains BuildingTemperatureSensor, BuildingOccupancySensor, BuildingPowerSensor,
                  DamperActuator, ValveActuator, LightingActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Virtual‑to‑physical interaction is enabled by the DT Framework acting as a central hub that supports bidirectional data exchange. Facility Managers can issue control commands from the Digital Twin to the building’s physical infrastructure for real‑time monitoring and actuation, with the framework handling the propagation of those commands back to the physical assets."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework provides real-time data exchange that maintains continuous synchronization between the physical building and its digital counterpart; synchronization occurs as soon as sensor or system updates are generated, supporting low-latency, ongoing bidirectional updates (no explicit frequency or latency values are specified)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT system follows a modular, service-oriented architecture centered on a DT Framework acting as a hub; standardized extension points allow integration of custom analytics and services, and runtime configuration management enables on-the-fly adjustments without redeployment. Roles (Building Control Engineers, Facility Managers, DT Engineers) interact with the hub to model devices, monitor/control, and extend functionality, resulting in a coordinated orchestration of components."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The proposed model‑driven deployment framework covers the full DT lifecycle: (1) Device modeling – building control engineers enrich BIM models with semantic definitions of sensors, actuators and controllers; (2) Model extraction – MDE techniques automatically transform the enriched BIM into structured DT representations (e.g., service‑oriented component models); (3) Artifact generation – the extracted models are used to generate deployable DT artifacts such as runtime containers and communication adapters; (4) Deployment – the DT is instantiated and linked to the physical building; (5) Operation – continuous real‑time data exchange synchronises the physical and digital twins; (6) Evolution – modular extension points allow insertion of custom services and analytics. Transitions between these stages are managed by automated model‑to‑code pipelines and are governed by role‑based responsibilities (building control engineer, facility manager, DT engineer)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on a modular communication layer that abstracts underlying network protocols, supporting interoperability across heterogeneous systems. The architecture is designed for scalability from individual components to whole infrastructure, with runtime configuration and low‑overhead updates to maintain reliable communication, though specific protocols, topology, bandwidth, latency, or security mechanisms are not detailed in the document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment follows a model‑driven approach that transforms enriched BIM models into operational Digital Twins. The framework supports scalable deployment through modular components and runtime configuration management, allowing the DT to evolve with changing operational requirements; however, concrete hosting platforms (cloud, edge, on‑premise), computational/storage specifications, and availability mechanisms are not explicitly described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Interoperability is addressed through standardized extension points and support for heterogeneous external systems such as BIM tools; the framework enables bidirectional data exchange with external services and analytics, fulfilling non-functional requirements for cross-system integration, though specific data exchange protocols or standards are not detailed."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach builds on the Building Information Modeling (BIM) standard as the foundational data model, extending it with semantic definitions for sensors and actuators. Internally, the framework enforces standardisation through modular, service‑oriented extension points that define uniform integration interfaces for custom DT services. External interoperability relies on compliance with AECO‑specific BIM specifications, while the modular architecture aims to align with general model‑driven engineering standards, though no additional industry standards (e.g., ISO, IEC) are explicitly cited."
]