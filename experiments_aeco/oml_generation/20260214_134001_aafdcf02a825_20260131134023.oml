// C1: Environment
instance BuildingALivingLabDT : DTDFVocab:Environment [
    base:desc "Model-driven digital twin of the Living Lab academic building developed within the TwinLight and BOREALIS projects, integrating BIM-based description with runtime systems."
    base:contains FixtureLEDDimmer, OccupancySensor, LuminanceSensor, TemperatureSensor, BuildingALivingLabDT_Hub
]

// C2: Acting Components
instance FixtureLEDDimmer : DTDFVocab:ActingComponent [
    base:desc "LED lighting fixture equipped with dimmer controller integrated into a BIM-controlled lighting system."
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded in the building, modeled in BIM and reporting presence data."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance LuminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Luminance sensor embedded in the building, modeled in BIM and reporting light level data."
    DTDFVocab:producedData LuminanceDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the building, modeled in BIM and reporting ambient temperature data."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LuminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LuminanceSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C10: Models/Data
instance IFCBIMModel : DTDFVocab:Model [
    base:desc "BIM IFC model providing geometry, topology, and functional attributes."
    DTDFVocab:inputTo BIMtoDTOArtifactGenerator
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Embedded control logic and device metadata extracted from enriched BIM."
    DTDFVocab:inputTo BIMtoDTOArtifactGenerator
]

instance RuntimeDataStreamsModel : DTDFVocab:Model [
    base:desc "Runtime data streams from sensors and system state information."
    DTDFVocab:inputTo BIMtoDTOArtifactGenerator
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real-time occupancy information reported from occupancy sensors."
    DTDFVocab:inputTo DittoEnabler
    DTDFVocab:fromData OccupancyDataTransmitted
]

instance LuminanceData : DTDFVocab:Data [
    base:desc "Real-time luminance (light level) information reported from luminance sensors."
    DTDFVocab:inputTo DittoEnabler
    DTDFVocab:fromData LuminanceDataTransmitted
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature information reported from temperature sensors."
    DTDFVocab:inputTo DittoEnabler
    DTDFVocab:fromData TemperatureDataTransmitted
]

// C11: Enablers
instance BIMtoDTOArtifactGenerator : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation pipeline that extracts device metadata from enriched BIM and generates runtime configuration artifacts."
]

instance DittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto middleware for real‑time data exchange between physical devices and digital twin."
    DTDFVocab:enables RealTimeMonitoringDashboardService, UnrealEngine5VisualizationService, PredictiveAnalyticsService, RLAdaptiveLightingControlService, FacilityOperationsTaskPlanningService
]

// C6: Services
instance RealTimeMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard providing facility managers with live analytics on lighting scheduling, energy consumption, and comfort levels."
    DTDFVocab:provides LightingSchedInsight, EnergyConsumptionInsight, ComfortOptimizationInsight
]

instance UnrealEngine5VisualizationService : DTDFVocab:Service [
    base:desc "Immersive visualization of the building and its systems using Unreal Engine 5."
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service forecasting light level and occupancy to support proactive control."
    DTDFVocab:provides LuminanceForecastInsight, OccupancyForecastInsight
]

instance RLAdaptiveLightingControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning driven adaptive lighting control service that adjusts lighting schedules automatically."
    DTDFVocab:provides AdjustLightingScheduleAction
]

instance FacilityOperationsTaskPlanningService : DTDFVocab:Service [
    base:desc "Task‑planning service for facility operation scheduling and maintenance."
]

// C17: Insights / Actions
instance LightingSchedInsight : DTDFVocab:Insight [
    base:desc "Insight into optimal lighting schedules based on occupancy and luminance data."
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight into current and projected energy consumption of the building lighting system."
]

instance ComfortOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight into comfort optimization opportunities balancing lighting levels and occupant comfort."
]

instance LuminanceForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasted luminance levels to pre‑emptively adjust lighting."
]

instance OccupancyForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasted occupancy patterns to inform lighting and HVAC controls."
]

instance AdjustLightingScheduleAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting schedules based on reinforcement learning policies."
    DTDFVocab:IsAutomatic true
]

// C5: Components (Hub)
instance BuildingALivingLabDT_Hub : DTDFVocab:Component [
    base:desc "Central hub coordinating multiple device twins and orchestrating communication between components."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., lighting dimming, HVAC setpoints) are published via Ditto to the building’s actuator middleware, providing bidirectional, real‑time interaction between virtual and physical domains."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin operates on a real‑time continuous synchronization loop; updates are event‑driven through Hono/Ditto without a predefined time bucket, enabling instantaneous reflection of physical changes."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestration architecture where the BIM-based digital twin acts as a central hub, exposing virtual representations via Ditto endpoints, receiving sensor data from Hono, and interfacing with external service plugins through modular extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT supports all lifecycle phases—design (BIM), fabrication (metadata mapping to device IDs), and operation (runtime data integration), thereby aligning as‑designed, as‑manufactured, and as‑operated representations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Alignment quantified with the Overall Digital Twin Entanglement (ODTE) metric, monitoring semantic drift, and employing automated validation from model transformation and runtime data consistency checks."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Bidirectional data flow established through Eclipse Hono and Ditto middleware, enabling real‑time synchronization between IoT devices and the Digital Twin services."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of Building Information Modeling (BIM) standards for data representation; integration with industry‑standard interfacing components such as Hono and Ditto, ensuring semantic interoperability."
]