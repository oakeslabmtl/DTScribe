// C3: Physical sensing components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Lighting sensor modelled in BIM and provisioned through TwinLight project, providing real-time illumination level data."
    DTDFVocab:producedData LightingSensorDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modelled in BIM, reporting space usage counts to the twin."
    DTDFVocab:producedData OccupancySensorDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modelled in BIM, streaming ambient temperature readings."
    DTDFVocab:producedData TemperatureSensorDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor modelled in BIM, delivering relative humidity data."
    DTDFVocab:producedData HumiditySensorDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance LightingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance OccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumiditySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

// C10: Data (Telemetry)
instance LightingTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry stream of illumination levels emitted by LightingSensor."
    DTDFVocab:fromData LightingSensorDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance OccupancyTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry stream of occupancy counts emitted by OccupancySensor."
    DTDFVocab:fromData OccupancySensorDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance TemperatureTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry stream of ambient temperature emitted by TemperatureSensor."
    DTDFVocab:fromData TemperatureSensorDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance HumidityTelemetryData : DTDFVocab:Data [
    base:desc "Telemetry stream of relative humidity emitted by HumiditySensor."
    DTDFVocab:fromData HumiditySensorDataTransmitted
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono provides MQTT/HTTP connectivity for ingesting device telemetry."
    DTDFVocab:enables RealTimeMonitoringService, Interactive3DVisualizationService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto manages digital‑twin state, aggregates telemetry and forwards it to downstream services."
    DTDFVocab:enables RealTimeMonitoringService, LightingOptimizationService, PredictiveAnalyticsService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renders immersive 3D visualization of the BIM geometry."
    DTDFVocab:enables Interactive3DVisualizationService
]

instance ReinforcementLearningEngine : DTDFVocab:Enabler [
    base:desc "Reinforcement‑learning engine (BOREALIS) learns control policies for lighting and predictive maintenance."
    DTDFVocab:enables LightingOptimizationService, PredictiveAnalyticsService
]

instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline transforms enriched BIM into runtime twin artifacts."
    DTDFVocab:enables SimulationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of sensor telemetry and building energy consumption."
    DTDFVocab:provides EnergyConsumptionOptimizationInsight
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Delivers interactive 3D visualization of building status via Unreal Engine 5."
    DTDFVocab:provides VisualizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Runs predictive analytics to generate maintenance recommendations."
    DTDFVocab:provides PredictiveMaintenanceRecommendationInsight
]

instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes lighting control using RL policies, balancing comfort and energy use."
    DTDFVocab:provides LightingComfortBalancingInsight, LightingControlAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Executes scenario simulations for facility‑management decision support."
    DTDFVocab:provides SimulationInsight
]

// C17: Insights
instance EnergyConsumptionOptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight for optimizing building energy consumption based on aggregated sensor data."
]

instance LightingComfortBalancingInsight : DTDFVocab:Insight [
    base:desc "Insight that balances lighting comfort with energy efficiency."
]

instance PredictiveMaintenanceRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation for predictive maintenance of building systems derived from anomaly detection."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Spatial awareness insight delivered through immersive 3D visualization."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from simulation runs supporting scenario analysis for facility managers."
]

// C17: Actions
instance LightingControlAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting actuators based on reinforcement‑learning policy."
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modelled in BIM, receives commands from the twin to adjust illumination."
]

instance BCSController : DTDFVocab:ActingComponent [
    base:desc "Building Control System controller orchestrates multiple actuators according to twin decisions."
]

// C10: Models
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "BIM geometry model representing 3D building shapes and spaces."
    DTDFVocab:inputTo UnrealEngine5
]

instance SpatialTopologyModel : DTDFVocab:Model [
    base:desc "Spatial topology model capturing adjacency and hierarchy of building zones."
    DTDFVocab:inputTo UnrealEngine5
]

instance DeviceMetadataModel : DTDFVocab:Model [
    base:desc "Metadata model linking BIM components to device identifiers for sensors and actuators."
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance RuntimeTwinModel : DTDFVocab:Model [
    base:desc "Runtime twin model generated by model‑driven transformation, representing live state."
    DTDFVocab:inputTo EclipseDitto
]

instance ReinforcementLearningPolicyModel : DTDFVocab:Model [
    base:desc "RL policy model for lighting control and predictive maintenance generated by BOREALIS."
    DTDFVocab:inputTo ReinforcementLearningEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional control commands generated by the twin are sent back through the same Hono/Ditto middleware to the actuators, enabling live actuation of building services."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous, event‑driven real‑time synchronization: sensor data are ingested and made available to the twin as soon as they are generated, enabling near‑instantaneous updates between physical and virtual worlds."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture where the DT Framework acts as a central hub linking enriched BIM models, the Hono/Ditto configurator, and visualization components, with defined extension points for custom services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin spans the design stage (BIM model), construction/commissioning (device configuration), and operational stage (runtime sensor data and control), thus covering as‑designed and as‑operated representations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Entanglement quality is measured with the Overall Digital Twin Entanglement (ODTE) metric to assess how faithfully the twin reflects its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time data exchange is realized through Eclipse Hono (device gateway) and Eclipse Ditto (digital twin server), which handle bidirectional communication between physical devices and the virtual model."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework leverages BIM standards as the semantic basis and provides standardized extension points; it also follows industry‑wide DT integration practices through Hono and Ditto."
]