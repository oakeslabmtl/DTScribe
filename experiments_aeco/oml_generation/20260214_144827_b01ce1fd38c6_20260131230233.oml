// C2: Acting Components
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Configurable HVAC actuator defined within BIM environment enabling remote control of heating/cooling systems through Building Control Engineers' logic"
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator configured in BIM model allowing Facility Managers to remotely adjust lighting systems via DT interface"
]

instance SecurityActuator : DTDFVocab:ActingComponent [
    base:desc "Security system actuator integrated through BIM-enriched models supporting emergency protocols and access control"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Building temperature sensor implicitly referenced in BIM-enriched models for real-time environmental monitoring"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor configured within BIM framework to support indoor air quality monitoring and HVAC control"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor integrated in BIM models for space utilization tracking and energy optimization"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance StructuralStressSensor : DTDFVocab:SensingComponent [
    base:desc "Structural stress sensor embedded in building infrastructure for safety monitoring and predictive maintenance"
    DTDFVocab:producedData StructuralDataTransmitted
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Energy consumption sensor capturing real-time building energy performance data for optimization services"
    DTDFVocab:producedData EnergyDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance StructuralDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralStressSensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

// C10: Models/Data
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "Semantically enriched BIM model incorporating BCS components (sensors, actuators, controllers) serving as single source of truth for DT deployment"
    DTDFVocab:inputTo BIMIntegrationEnabler, ModelTransformationEnabler
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model defining dynamic control logic for BCS components configured by Building Control Engineers within BIM environment"
    DTDFVocab:inputTo ControlServiceEnabler, SimulationEnabler
]

instance HistoricalPerformanceData : DTDFVocab:Data [
    base:desc "Aggregated historical data from building operations including energy consumption patterns and environmental trends"
    DTDFVocab:fromData EnergyDataTransmitted, TemperatureDataTransmitted, HumidityDataTransmitted
    DTDFVocab:inputTo AnalyticsEnabler
]

instance RealTimeTelemetryData : DTDFVocab:Data [
    base:desc "Continuous stream of real-time sensor data synchronized between physical infrastructure and digital twin"
    DTDFVocab:fromData TemperatureDataTransmitted, OccupancyDataTransmitted, StructuralDataTransmitted
    DTDFVocab:inputTo MonitoringEnabler, ControlServiceEnabler
]

instance DeviceConfigurationData : DTDFVocab:Data [
    base:desc "Metadata and configuration parameters for all BCS devices including calibration logs and operational status"
    DTDFVocab:fromData DeviceMetadataTransmitted
    DTDFVocab:inputTo DeploymentEnabler
]

// C11: Enablers
instance BIMIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Commercial BIM software (e.g., Revit) extended with custom plugins enabling modeling of BCS devices and control logic within BIM environment"
    DTDFVocab:enables DeviceConfigurationService, ControlConfigurationService
]

instance ModelTransformationEnabler : DTDFVocab:Enabler [
    base:desc "Model-driven engineering framework implementing M2M and M2T transformations converting enriched BIM models to deployable DT artifacts"
    DTDFVocab:enables DeploymentService, SimulationService
]

instance ControlServiceEnabler : DTDFVocab:Enabler [
    base:desc "Microservices architecture hosting control logic modules and actuation services for real-time building system management"
    DTDFVocab:enables AutomatedActuationService, RemoteOperationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Real-time data processing pipeline synchronizing physical sensor data with digital twin visualization interfaces"
    DTDFVocab:enables StateVisualizationService, AlertingService
]

instance AnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Custom service integration platform enabling DT Engineers to deploy predictive analytics and optimization algorithms"
    DTDFVocab:enables PredictiveAnalyticsService, OptimizationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Embedded simulation engine (e.g., TwinLight/BOREALIS) validating control strategies and testing custom services in virtual environment"
    DTDFVocab:enables ScenarioTestingService, ValidationService
]

instance DeploymentEnabler : DTDFVocab:Enabler [
    base:desc "Automated artifact generation system creating deployable DT components from enriched BIM models with minimal manual intervention"
    DTDFVocab:enables CustomPluginService, ModelDrivenDeploymentService
]

instance DataExchangeEnabler : DTDFVocab:Enabler [
    base:desc "Standardized communication middleware facilitating bidirectional real-time data exchange between physical infrastructure and digital twin"
    DTDFVocab:enables DataSynchronizationService, EventProcessingService
]

// C6: Services
instance StateVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D/4D visualization interface enabling Facility Managers to observe real-time building states and environmental conditions"
    DTDFVocab:provides BuildingStateInsight, EnvironmentalConditionInsight
]

instance AlertingService : DTDFVocab:Service [
    base:desc "Automated anomaly detection system triggering alerts for equipment failures or efficiency deviations based on predefined thresholds"
    DTDFVocab:provides FailureAlertInsight, EfficiencyAlertInsight
]

instance AutomatedActuationService : DTDFVocab:Service [
    base:desc "Direct control service executing Building Control Engineers' logic to adjust HVAC, lighting, and security systems automatically"
    DTDFVocab:provides HVACAdjustmentAction, LightingControlAction
    DTDFVocab:IsAutomatic true
]

instance RemoteOperationService : DTDFVocab:Service [
    base:desc "Facility Manager interface enabling remote intervention in physical infrastructure through digital twin commands"
    DTDFVocab:provides EmergencyProtocolAction, SetpointAdjustmentAction
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Custom analytics service predicting energy consumption patterns and maintenance requirements using historical and real-time data"
    DTDFVocab:provides EnergyForecastInsight, MaintenanceRecommendationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Dynamic reconfiguration service adapting control logic based on operational feedback for optimal building performance"
    DTDFVocab:provides PerformanceOptimizationInsight, ResourceAllocationAction
]

instance CustomPluginService : DTDFVocab:Service [
    base:desc "Extension platform allowing DT Engineers to integrate third-party analytics and domain-specific tools via standardized interfaces"
    DTDFVocab:provides PluginIntegrationInsight, ServiceExtensionAction
]

instance ScenarioTestingService : DTDFVocab:Service [
    base:desc "Virtual environment service validating control strategies and testing custom services before physical deployment"
    DTDFVocab:provides TestResultInsight, ValidationReportAction
]

instance ModelDrivenDeploymentService : DTDFVocab:Service [
    base:desc "Automated deployment service generating deployable DT components from enriched BIM models with quality assurance checks"
    DTDFVocab:provides DeploymentValidationInsight, ArtifactGenerationAction
]

instance DeploymentService : DTDFVocab:Service [
    base:desc "Service responsible for deploying DT components and managing their lifecycle"
    DTDFVocab:provides DeploymentValidationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service providing simulation capabilities for testing control strategies"
    DTDFVocab:provides TestResultInsight
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Service validating control logic and DT components before deployment"
    DTDFVocab:provides ValidationReportAction
]

instance DataSynchronizationService : DTDFVocab:Service [
    base:desc "Service ensuring real-time synchronization between physical and digital components"
    DTDFVocab:provides RealTimeSynchronizationInsight
]

instance EventProcessingService : DTDFVocab:Service [
    base:desc "Service handling event-based processing and triggering actions"
    DTDFVocab:provides EventTriggerAction
]

instance DeviceConfigurationService : DTDFVocab:Service [
    base:desc "Service for configuring and managing BCS device parameters"
    DTDFVocab:provides DeviceConfigurationInsight
]

instance ControlConfigurationService : DTDFVocab:Service [
    base:desc "Service for configuring control logic and parameters"
    DTDFVocab:provides ControlConfigurationInsight
]

