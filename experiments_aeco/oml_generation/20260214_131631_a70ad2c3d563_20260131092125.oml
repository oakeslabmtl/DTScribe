// C2: Acting Components
instance SmartLightingFixture : DTDFVocab:ActingComponent [
    base:desc "Smart lighting fixture modeled in BIM with a unique device ID, enabling bidirectional communication via Eclipse Hono and Ditto."
]
instance HVACDamperValve : DTDFVocab:ActingComponent [
    base:desc "HVAC damper valve modeled in BIM with a unique device ID, enabling bidirectional communication via Eclipse Hono and Ditto."
]
instance HVACFanDrive : DTDFVocab:ActingComponent [
    base:desc "HVAC fan drive modeled in BIM with a unique device ID, enabling bidirectional communication via Eclipse Hono and Ditto."
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor integrated into BIM; telemetry collected by the building's BMS."
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy (presence) sensor integrated into BIM; telemetry collected by the building's BMS."
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor integrated into BIM; telemetry collected by the building's BMS."
    DTDFVocab:producedData IlluminationDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
    base:desc "Temperature data transmitted via Eclipse Hono MQTT broker, persisted in Eclipse Ditto."
]
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
    base:desc "Occupancy data transmitted via Eclipse Hono MQTT broker, persisted in Eclipse Ditto."
]
instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
    base:desc "Illumination data transmitted via Eclipse Hono MQTT broker, persisted in Eclipse Ditto."
]

// C10: Models/Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Batch of temperature readings ingested from Ditto entity, stored in time‑series database."
    DTDFVocab:inputTo EclipseHonoBroker
    DTDFVocab:fromData TemperatureDataTransmitted
]
instance OccupancyData : DTDFVocab:Data [
    base:desc "Batch of occupancy readings ingested from Ditto entity, stored in time‑series database."
    DTDFVocab:inputTo EclipseHonoBroker
    DTDFVocab:fromData OccupancyDataTransmitted
]
instance IlluminationData : DTDFVocab:Data [
    base:desc "Batch of illumination readings ingested from Ditto entity, stored in time‑series database."
    DTDFVocab:inputTo EclipseHonoBroker
    DTDFVocab:fromData IlluminationDataTransmitted
]
instance IFC_BIM_Model : DTDFVocab:Model [
    base:desc "IFC‑based BIM model enriched with device semantic annotations."
    DTDFVocab:inputTo MDETooling
]
instance RuntimeConfigModel : DTDFVocab:Model [
    base:desc "Runtime configuration model derived by MDE transformations from enriched IFC model."
    DTDFVocab:inputTo MDETooling
]

// C11: Enablers
instance EclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono broker for secure MQTT communication."
    DTDFVocab:enables MonitoringDashboardService, PredictiveAnalyticsService
]
instance EclipseDittoRegistry : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto registry and entity management."
    DTDFVocab:enables SimulationService
]
instance UnrealEngine5Renderer : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for immersive 3D visualization."
    DTDFVocab:enables UnrealVisualizationService
]
instance MDETooling : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering tooling for model‑to‑model and model‑to‑text transformations."
    DTDFVocab:enables PredictiveAnalyticsService
]
instance RevitAuthoringTool : DTDFVocab:Enabler [
    base:desc "Revit for BIM authoring and data extraction."
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Provides simulation and optimization services such as energy‑efficiency scenario analysis."
    DTDFVocab:provides EnergyConsumptionHotspotInsight, OptimizeEnergyUsageAction
]
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards."
    DTDFVocab:provides PredictiveMaintenanceAlertInsight, OptimalLightingScheduleInsight
]
instance UnrealVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization via Unreal Engine 5."
    DTDFVocab:provides EnergyConsumptionHotspotInsight
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics through reinforcement‑learning driven control policy generation."
    DTDFVocab:provides EvidenceBasedControlPolicyAdjustmentInsight, AdjustControlPolicyAction
]
instance TaskPlanningService : DTDFVocab:Service [
    base:desc "Task‑planning utilities for facility management."
    DTDFVocab:provides ScheduleLightingAction, TriggerMaintenanceAlertAction
]

// C17: Insights/Actions
instance EnergyConsumptionHotspotInsight : DTDFVocab:Insight [
    base:desc "Energy consumption hotspots identified by simulation."
]
instance PredictiveMaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance alerts surfaced by analytics."
]
instance OptimalLightingScheduleInsight : DTDFVocab:Insight [
    base:desc "Optimal lighting schedules derived from data."
]
instance EvidenceBasedControlPolicyAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Evidence‑based control policy adjustments surfaced by analytics."
]
instance AdjustControlPolicyAction : DTDFVocab:Action [
    base:desc "Adjusts control policy automatically based on evidence."
    DTDFVocab:IsAutomatic true
]
instance OptimizeEnergyUsageAction : DTDFVocab:Action [
    base:desc "Optimizes energy usage automatically."
    DTDFVocab:IsAutomatic true
]
instance TriggerMaintenanceAlertAction : DTDFVocab:Action [
    base:desc "Triggers maintenance alert automatically."
    DTDFVocab:IsAutomatic true
]
instance ScheduleLightingAction : DTDFVocab:Action [
    base:desc "Schedules lighting operations."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., light dimming, HVAC set‑point adjustment) are published via Eclipse Hono and delivered to the building’s actuators via Ditto’s device service interfaces, enabling live actuation of the physical premises."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Bidirectional communication is performed in real time with sub‑second latency underpinning the synchronization cycle; simulation responses are rendered at millisecond to second granularity, while long‑term policy updates occur on a minute‑scale."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A service‑oriented constellation comprising the BIM‐based modeling engine, the Hono middleware layer, the Ditto runtime registry, a reinforcement learning controller (BOREALIS), and the Unreal visualizer, all orchestrated through a Docker‑based deployment stack."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the design (ideal BIM model), the construction/manufacture (as‑built IFC with device metadata), and the operation stage (runtime state, telemetry, and control), enabling continuous lifecycle adaptation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is assessed using the Overall Digital Twin Entanglement (ODTE) metric applied to the ITS‑BIM mapping; validation involves schema validation of IFC elements, consistency checks of device metadata, and statistical uncertainty quantification of sensor noise."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication is performed using MQTT over TCP/IP, secured with TLS, with Hono acting as a bridge to the Ditto entity data store; HTTP/REST endpoints are exposed for management and configuration."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "External integration is achieved via Hono’s protocol adapters, allowing the DT to expose data to larger building management systems, facility management software, and potentially other DTs for cross‑building analytics."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adheres to IFC4 BIM standards for geometric and semantic data, MQTT and TLS for secure messaging, and Eclipse Ditto’s REST and WebSocket interfaces for device interaction; model transformation follows MDE best practices."
]