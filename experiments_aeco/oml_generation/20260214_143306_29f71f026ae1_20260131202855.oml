// C2: Acting Components
instance OccupancyLightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control device for occupancy-based adjustments within the LEED Platinum academic building's Living Lab"
]

instance HVACSystemActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC system actuator for real-time temperature and humidity control in building zones, integrated with BOREALIS reinforcement learning policies"
]

instance SmartLightingControlDevice : DTDFVocab:ActingComponent [
    base:desc "Smart lighting control device implementing adaptive lighting via BOREALIS for energy optimization in the building's operational phase"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy temperature sensor integrated into BIM model for real-time monitoring of indoor environmental conditions"
    DTDFVocab:producedData TemperatureDataStream
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy humidity sensor integrated into BIM model for real-time monitoring of indoor air quality metrics"
    DTDFVocab:producedData HumidityDataStream
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor integrated into BIM model for tracking building zone occupancy levels and enabling data-driven controls"
    DTDFVocab:producedData OccupancyDataStream
]

instance LightLevelSensor : DTDFVocab:SensingComponent [
    base:desc "Light level sensor integrated into BIM model for monitoring natural and artificial lighting conditions in building zones"
    DTDFVocab:producedData LightLevelDataStream
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Energy consumption sensor integrated into BIM model for real-time monitoring of building operational energy metrics"
    DTDFVocab:producedData EnergyConsumptionDataStream
]

// C4: Data Transmitted
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightLevelDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightLevelSensor
]

instance EnergyConsumptionDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

// C10: Models/Data
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "Enriched BIM model containing static geometry, topology, and functional attributes (component relationships) with dynamic runtime semantics (sensor configurations, control logic)"
    DTDFVocab:inputTo BIMSoftwareRevit
]

instance RuntimeArtifactModel : DTDFVocab:Model [
    base:desc "Automatically generated runtime artifacts from BIM enrichment, including device configurations and control logic for Eclipse Hono/Ditto integration"
    DTDFVocab:inputTo EclipseHonoConfigurator
]

instance SensorConfigurationMetadata : DTDFVocab:Data [
    base:desc "Metadata extracted from BIM for device IDs and endpoint addresses to generate runtime interfaces via Eclipse Hono/Ditto"
    DTDFVocab:fromData TemperatureDataStream, HumidityDataStream,
                          OccupancyDataStream, LightLevelDataStream, EnergyConsumptionDataStream
]

instance OperationalDataStream : DTDFVocab:Data [
    base:desc "Real-time operational data stream combining sensor inputs for building performance analysis and predictive analytics"
    DTDFVocab:fromData TemperatureDataStream, HumidityDataStream,
                          OccupancyDataStream, LightLevelDataStream, EnergyConsumptionDataStream
]

// C11: Enablers
instance BIMSoftwareRevit : DTDFVocab:Enabler [
    base:desc "BIM software platform (Revit) used for model creation, enrichment with sensor configurations, and integration with runtime artifacts"
]

instance ModelDrivenEngineeringFramework : DTDFVocab:Enabler [
    base:desc "Model-driven engineering methodologies for automated transformations between BIM and runtime artifacts using M2M/M2T approaches"
    DTDFVocab:enables BIMEnrichedModel, RuntimeArtifactModel
]

instance EclipseHonoMiddleware : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware facilitating real-time bidirectional data exchange between physical building systems and digital twin runtime"
]

instance EclipseHonoConfigurator : DTDFVocab:Enabler [
    base:desc "Eclipse Hono configurator automating the generation of runtime interfaces from BIM-enriched models for sensor/actuator integration"
    DTDFVocab:enables RuntimeArtifactModel
]

instance ModelToModelTransformer : DTDFVocab:Enabler [
    base:desc "Model-to-model transformation tool for converting BIM data into runtime artifacts compatible with Eclipse Hono/Ditto protocols"
    DTDFVocab:enables BIMEnrichedModel, RuntimeArtifactModel
]

instance UnrealEngineVisualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine platform for immersive 3D visualization of the digital twin with interactive building components"
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring and visualization service providing live data feeds from building sensors via Unreal Engine visualization"
    DTDFVocab:provides RealTimeDataDashboard
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service implementing reinforcement learning in BOREALIS for energy optimization and control policy adjustments"
    DTDFVocab:provides EnergyOptimizationRecommendations, ControlPolicyUpdates
]

instance ControlLogicAutomationService : DTDFVocab:Service [
    base:desc "Bidirectional control logic automation service enabling real-time synchronization between digital twin and physical building systems"
    DTDFVocab:provides OccupancyBasedLightingControl, HVACAdaptiveSettings
]

instance CustomServiceIntegrationService : DTDFVocab:Service [
    base:desc "Framework extension service for domain-specific plugins (e.g., DT Engineers' custom services) for specialized building management tasks"
    DTDFVocab:provides DomainSpecificControlPlugins, CustomAnalyticsModules
]

// C17: Insights/Actions
instance RealTimeDataDashboard : DTDFVocab:Insight [
    base:desc "Real-time dashboard visualization of building performance metrics (temperature, humidity, occupancy, energy) for operational monitoring"
]

instance Immersive3DVisualization : DTDFVocab:Insight [
    base:desc "Immersive 3D visualization of the building's digital twin with interactive components for immersive building performance analysis"
]

instance EnergyOptimizationRecommendations : DTDFVocab:Insight [
    base:desc "Predictive analytics insights recommending energy optimization strategies based on occupancy patterns and environmental conditions"
]

instance ControlPolicyUpdates : DTDFVocab:Insight [
    base:desc "Reinforcement learning-based control policy updates for adaptive HVAC and lighting systems in response to real-time operational data"
]

instance OccupancyBasedLightingControl : DTDFVocab:Action [
    base:desc "Automated lighting control action adjusting artificial lighting levels based on occupancy sensor data from building zones"
    DTDFVocab:IsAutomatic true
]

instance HVACAdaptiveSettings : DTDFVocab:Action [
    base:desc "Automated HVAC system settings adjustment using real-time temperature and humidity data for energy-efficient building operation"
    DTDFVocab:IsAutomatic true
]

instance DomainSpecificControlPlugins : DTDFVocab:Action [
    base:desc "Custom control plugins for domain-specific building management tasks (e.g., specialized occupancy-based control algorithms)"
    DTDFVocab:IsAutomatic true
]

instance CustomAnalyticsModules : DTDFVocab:Action [
    base:desc "Domain-specific analytics modules for specialized facility management insights derived from building operational data"
    DTDFVocab:IsAutomatic true
]

// C17: Environment and Components
instance DataTransmissionPipeline : DTDFVocab:Model [
    base:desc "Pipeline for real-time data transmission between sensors, middleware, and digital twin components"
    DTDFVocab:inputTo EclipseHonoMiddleware
]

instance BuildingLivingLabEnvironment : DTDFVocab:Environment [
    base:contains OccupancyLightingActuator, HVACSystemActuator, SmartLightingControlDevice,
                 TemperatureSensor, HumiditySensor, OccupancySensor,
                 LightLevelSensor, EnergyConsumptionSensor,
                 BIMEnrichedModel, RuntimeArtifactModel
]

instance ZoneLightingControlEnvironment : DTDFVocab:Environment [
    base:contains OccupancyLightingActuator, LightLevelSensor,
                 OccupancyDataStream, LightLevelDataStream,
                 OccupancyBasedLightingControl
]

instance HVACZoneControlEnvironment : DTDFVocab:Environment [
    base:contains HVACSystemActuator, TemperatureSensor, HumiditySensor,
                 TemperatureDataStream, HumidityDataStream,
                 HVACAdaptiveSettings
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Virtual-to-physical interaction is enabled through **control signals and commands** generated by the DT to adjust physical building systems. The framework uses standardized extension points to integrate custom services (e.g., reinforcement learning-based lighting control in BOREALIS) and middleware (Eclipse Hono/Ditto) to transmit optimized control logic back to sensors and actuators, ensuring real-time adjustments to operational parameters."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twinning time scale is **real-time and near-real-time**, with synchronization rates determined by sensor data acquisition frequencies (e.g., milliseconds to seconds for lighting/HVAC control) and middleware latency (e.g., Eclipse Hono/Ditto protocols). The framework supports adaptive time scales for different services (e.g., high-frequency sensor data vs. low-frequency analytics)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is orchestrated via a **centralized DT framework** that couples BIM with middleware (Eclipse Hono/Ditto) for bidirectional communication. The architecture supports modular service integration (e.g., custom DT services by DT Engineers) and real-time synchronization between physical assets and their digital twins, enabling a unified ecosystem for AECO life-cycle management."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT operates across all life-cycle stages: **design (BIM-based modeling)**, **construction (device configuration)**, and **operation (real-time monitoring and optimization)**. It supports representations of the physical counterpart as **as-designed (ideal)**, **as-manufactured**, and **as-operated**, with automated transformations from BIM to runtime artifacts to ensure consistency across phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are ensured through **Overall Digital Twin Entanglement (ODTE) metric evaluation**, which measures the alignment between the DT and its physical counterpart. The framework automates data synchronization (e.g., sensor-to-DT data flow) and addresses semantic drift via standardized BIM semantics and real-time middleware (Eclipse Hono/Ditto). Verification/validation mechanisms include model validation steps and iterative refinement of control logic (e.g., BOREALIS’ post-occupancy data-driven optimization)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT technical connection relies on **network protocols** (e.g., MQTT via Eclipse Hono/Ditto) for real-time data exchange between physical sensors/actuators and the DT. The architecture supports scalable deployment with standardized extension points, ensuring interoperability across heterogeneous systems (e.g., IoT devices, BCS)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted/deployed via **cloud-based or edge computing environments**, leveraging middleware (Eclipse Hono/Ditto) for distributed runtime artifacts. The framework supports modular deployment with extensibility for custom services (e.g., DT Engineers’ plugins), ensuring scalability from individual components to entire infrastructure systems."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Horizontal integration occurs via **standardized extension points** that enable seamless communication with external systems (e.g., BIM tools, IoT platforms, analytics services). The framework supports interoperability with AECO-specific standards (e.g., BIM) and middleware protocols (Eclipse Hono/Ditto), facilitating data exchange across siloed systems."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data ownership is managed through **BIM-centric control configurations** (e.g., TwinLight project), where device metadata and operational data are embedded within BIM models. Privacy is addressed via middleware security protocols (e.g., Ditto’s data encryption) and compliance with AECO standards (e.g., regulatory mandates for data protection)."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Standardization is achieved through **BIM as the semantic backbone**, leveraging AECO-specific standards (e.g., IFC, COBie) for model enrichment and middleware protocols (Eclipse Hono/Ditto) for interoperability. The framework supports modular service integration and extensibility, ensuring compliance with industry-wide best practices for DT deployment."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety are addressed via **middleware security (Eclipse Hono/Ditto)** for encrypted data exchange, **role-based access control (RBAC)** for DT Engineer/Facility Manager interactions, and **remote operation safeguards** to prevent unintended physical interventions (e.g., critical system overrides). The framework ensures safe DT execution by validating control logic and data integrity before transmission to physical systems."
]