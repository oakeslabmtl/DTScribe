// C3: Physical sensing components
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental light sensor modeled in BIM, connected via Eclipse Hono, provides illumination telemetry."
    DTDFVocab:producedData LightTelemetryTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental temperature sensor modeled in BIM, connected via Eclipse Hono, provides thermal telemetry."
    DTDFVocab:producedData TemperatureTelemetryTransmitted
]

instance MotionSensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy motion sensor modeled in BIM, connected via Eclipse Hono, provides occupancy telemetry."
    DTDFVocab:producedData MotionTelemetryTransmitted
]

// C4: Physical-to-virtual interaction
instance LightTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance TemperatureTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance MotionTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionSensor
]

// C10: Data artifacts (runtime twin data)
instance LightTelemetryData : DTDFVocab:Data [
    base:desc "Live light level values streamed from the physical light sensor to the twin."
    DTDFVocab:fromData LightTelemetryTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance TemperatureTelemetryData : DTDFVocab:Data [
    base:desc "Live temperature values streamed from the physical temperature sensor to the twin."
    DTDFVocab:fromData TemperatureTelemetryTransmitted
    DTDFVocab:inputTo EclipseDitto
]

instance MotionTelemetryData : DTDFVocab:Data [
    base:desc "Live occupancy/motion values streamed from the physical motion sensor to the twin."
    DTDFVocab:fromData MotionTelemetryTransmitted
    DTDFVocab:inputTo EclipseDitto
]

// C2: Acting components
instance LightingControlActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control actuator modeled in BIM, receives commands from the twin to adjust illumination."
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve actuator modeled in BIM, receives commands from the twin to modify airflow."
]

// C11: Enablers
instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital‑twin management platform storing live twin state."
    DTDFVocab:enables RealTimeMonitoringDashboard,
                  BuildingPerformanceSimulation,
                  PredictiveAnalytics,
                  AutomatedOptimization
]

instance ModelDrivenEngineering : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering toolchain for automatic generation of configurations, simulation models and optimizations."
    DTDFVocab:enables BuildingPerformanceSimulation,
                  PredictiveAnalytics,
                  AutomatedOptimization
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 engine for immersive 3‑D interactive visualization."
    DTDFVocab:enables UnrealEngine5Visualization
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT‑based data ingestion middleware."
    // No direct service enablement; acts upstream of Ditto.
]

instance ODTEValidationMetric : DTDFVocab:Enabler [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric used for validation of twin fidelity."
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboards delivering live sensor data visualizations."
    DTDFVocab:provides EnergyConsumptionInsight,
                  ComfortLevelInsight
]

instance UnrealEngine5Visualization : DTDFVocab:Service [
    base:desc "3‑D interactive visualization of the building in Unreal Engine 5."
    DTDFVocab:provides EnergyConsumptionInsight
]

instance BuildingPerformanceSimulation : DTDFVocab:Service [
    base:desc "Simulation of building performance based on enriched BIM and live sensor data."
    DTDFVocab:provides EnergyConsumptionInsight
]

instance PredictiveAnalytics : DTDFVocab:Service [
    base:desc "Predictive analytics generating forecasts of energy use and occupant comfort."
    DTDFVocab:provides EnergyConsumptionInsight,
                  ComfortLevelInsight
]

instance AutomatedOptimization : DTDFVocab:Service [
    base:desc "Automated optimization adjusting control set‑points to improve energy efficiency."
    DTDFVocab:provides AdjustControlSetpointAction
]

// C17: Insights
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight on building energy consumption derived from sensor telemetry."
]

instance ComfortLevelInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight on occupant comfort levels derived from temperature and motion data."
]

// C17: Actions
instance AdjustControlSetpointAction : DTDFVocab:Action [
    base:desc "Automatically adjusts HVAC and lighting set‑points to optimize energy efficiency."
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance BIMEnrichedModel : DTDFVocab:Model [
    base:desc "BIM model enriched with device metadata (sensor/actuator IDs, tenant information) serving as the canonical static model."
    DTDFVocab:inputTo EclipseDitto,
                  ModelDrivenEngineering
]

instance TwinRuntimeModel : DTDFVocab:Model [
    base:desc "Runtime twin artifacts stored in Eclipse Ditto holding live property values and event streams."
    DTDFVocab:inputTo EclipseDitto
]

// C11: Additional Data linking multiple telemetry streams
instance TwinAggregatedTelemetryData : DTDFVocab:Data [
    base:desc "Aggregated live telemetry (light, temperature, motion) stored in Eclipse Ditto for downstream analytics."
    DTDFVocab:fromData LightTelemetryTransmitted,
                  TemperatureTelemetryTransmitted,
                  MotionTelemetryTransmitted
    DTDFVocab:inputTo ModelDrivenEngineering,
                  UnrealEngine5
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional command messages generated by the twin (e.g., set‑point changes) sent through Eclipse Ditto to the middleware, which forwards them to actuators via Eclipse Hono, enabling closed‑loop control."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Near real‑time synchronization; sensor data is ingested and twin state updated continuously (sub‑second latency typical of MQTT‑based Hono streams)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture where the enriched BIM model feeds a Hono/Ditto configurator, which discovers “twinnable” devices, establishes bidirectional connectivity, and exposes the twin to visualization and custom services via defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers the design stage (BIM model creation), deployment stage (automatic generation of runtime artefacts) and operation stage (continuous runtime monitoring and control)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Entanglement quality measured with the Overall Digital Twin Entanglement (ODTE) metric, indicating the degree of synchronization and semantic alignment between physical building and its twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time data transport using Eclipse Hono (typically MQTT) and twin management via Eclipse Ditto (HTTP/REST or WebSocket APIs)."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Relies on BIM standards for building data, adopts standardized extension points in the framework, and uses the ODTE metric as a common evaluation standard."
]