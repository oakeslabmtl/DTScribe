import DTDFVocab from "http://example.org/DTDFVocab"

// C2: Acting Components
instance DimmableLightFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Dimable light fixture actuator modeled in BIM and addressed by TwinLight and BOREALIS"
]

instance HVACControlActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator for building climate control modeled in BIM and addressed by TwinLight and BOREALIS"
]

instance BuildingControlSystemController : DTDFVocab:ActingComponent [
    base:desc "Controller orchestrating lighting and HVAC actuators within the building control system"
]

// C3: Physical sensing components
instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded lighting sensor whose configuration is stored in BIM and used by TwinLight and BOREALIS",
    DTDFVocab:producedData LightingSensorDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Embedded occupancy sensor configured in BIM and consumed by TwinLight for space usage detection",
    DTDFVocab:producedData OccupancySensorDataTransmitted
]

instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded environmental sensor (temperature, humidity, CO₂) configured in BIM and used by BOREALIS",
    DTDFVocab:producedData EnvironmentalSensorDataTransmitted
]

// C4: Physical-to-virtual interaction (Data Transmitted)
instance LightingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

instance OccupancySensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnvironmentalSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

// C10: Data
instance LightingLevelData : DTDFVocab:Data [
    base:desc "Real‑time illumination level stream from LightingSensor",
    DTDFVocab:fromData LightingSensorDataTransmitted,
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Real‑time occupancy status stream from OccupancySensor",
    DTDFVocab:fromData OccupancySensorDataTransmitted,
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Real‑time temperature, humidity, and CO₂ stream from EnvironmentalSensor",
    DTDFVocab:fromData EnvironmentalSensorDataTransmitted,
    DTDFVocab:inputTo EclipseDitto, EclipseHono
]

// C10: Models/Data
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Static BIM geometry model automatically transformed into runtime artifacts",
    DTDFVocab:inputTo ModelDrivenTransformationPipeline
]

instance SemanticBuildingModel : DTDFVocab:Model [
    base:desc "Semantic building model derived from enriched BIM, exposing component relationships",
    DTDFVocab:inputTo ModelDrivenTransformationPipeline
]

instance ControlPolicyModel : DTDFVocab:Model [
    base:desc "Dynamic model defining lighting and HVAC control policies",
    DTDFVocab:inputTo ModelDrivenTransformationPipeline, EclipseDitto
]

instance ReinforcementLearningControlModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning model for visual‑comfort optimized lighting control",
    DTDFVocab:inputTo ModelDrivenTransformationPipeline, EclipseDitto
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono gateway (MQTT/AMQP) streaming sensor data from the physical building",
    DTDFVocab:enables Live3DVisualizationService, BuildingPerformanceSimulationService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital‑twin state store synchronizing device twins and managing configurations",
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService, EnergyConsumptionOptimizationService, VisualComfortReinforcementLearningControlService
]

instance ModelDrivenTransformationPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline that converts enriched BIM models into Hono/Ditto configurations",
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 consuming twin state for live 3‑D visualization",
    DTDFVocab:enables Live3DVisualizationService
]

instance StandardizedExtensionPoints : DTDFVocab:Enabler [
    base:desc "Framework‑defined extension points allowing modular service addition and artifact re‑generation",
    DTDFVocab:enables BuildingPerformanceSimulationService, EnergyConsumptionOptimizationService
]

// C6: Services
instance Live3DVisualizationService : DTDFVocab:Service [
    base:desc "Live 3‑D visualization of the building twin in Unreal Engine 5",
    DTDFVocab:provides VisualComfortAssessmentInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of sensor streams and device twin states",
    DTDFVocab:provides OptimizedLightingSetpointsInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics generating energy‑saving recommendations",
    DTDFVocab:provides EnergySavingRecommendationsInsight
]

instance EnergyConsumptionOptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that computes set‑points to reduce building energy consumption",
    DTDFVocab:provides EnergySavingRecommendationsInsight, ApplyEnergySavingRecommendationAction
]

instance VisualComfortReinforcementLearningControlService : DTDFVocab:Service [
    base:desc "Reinforcement‑learning control service for visual‑comfort optimization",
    DTDFVocab:provides VisualComfortAssessmentInsight, AdjustLightingSetpointAction, AdjustVisualComfortParametersAction
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Simulation service assessing building performance and suggesting optimized set‑points",
    DTDFVocab:provides OptimizedLightingSetpointsInsight, AdjustLightingSetpointAction
]

// C17: Insights
instance OptimizedLightingSetpointsInsight : DTDFVocab:Insight [
    base:desc "Optimized lighting control set‑points derived from sensor data and RL model"
]

instance EnergySavingRecommendationsInsight : DTDFVocab:Insight [
    base:desc "Energy‑saving recommendations based on predictive analytics of usage patterns"
]

instance VisualComfortAssessmentInsight : DTDFVocab:Insight [
    base:desc "Assessment of visual‑comfort levels using lighting and occupancy data"
]

// C17: Actions
instance AdjustLightingSetpointAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of lighting brightness to achieve optimal set‑points",
    DTDFVocab:IsAutomatic true
]

instance ApplyEnergySavingRecommendationAction : DTDFVocab:Action [
    base:desc "Manual action to apply suggested energy‑saving changes to control policies",
    DTDFVocab:IsAutomatic false
]

instance AdjustVisualComfortParametersAction : DTDFVocab:Action [
    base:desc "Automatic tuning of lighting parameters to maintain visual comfort",
    DTDFVocab:IsAutomatic true
]

// C18: Environment (optional aggregation)
instance BuildingTwinEnvironment : DTDFVocab:Environment [
    base:contains DimmableLightFixtureActuator, HVACControlActuator, BuildingControlSystemController, LightingSensor, OccupancySensor, EnvironmentalSensor, BIMGeometryModel, SemanticBuildingModel, ControlPolicyModel, ReinforcementLearningControlModel, Live3DVisualizationService, RealTimeMonitoringService, PredictiveAnalyticsService, EnergyConsumptionOptimizationService, VisualComfortReinforcementLearningControlService, BuildingPerformanceSimulationService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points, reinforcement‑learning policies) are sent back to the physical actuators through the same Hono/Ditto middleware, enabling bidirectional actuation"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous near‑real‑time synchronization; data exchange occurs at the rate required by sensor update frequencies (typically sub‑second to seconds)"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A service‑oriented architecture consisting of a BIM‑derived model repository, a Hono/Ditto configurator, bidirectional middleware, a visualization layer (Unreal Engine), and plug‑in extension points for custom services"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers design (BIM model creation), construction (device commissioning), and operation (runtime monitoring and control)"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation step before deployment and quantitative evaluation of twin‑physical alignment using the Overall Digital Twin Entanglement (ODTE) metric"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "IoT messaging via Eclipse Hono (supports MQTT and AMQP) linked to Eclipse Ditto digital‑twin server; communication uses tenant and device IDs extracted from BIM metadata"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized extension points enable integration with external building‑management systems and analytics services, though specific systems are not enumerated"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Relies on BIM as the standard modelling language for the construction domain and uses standardized extension points; integration with Eclipse Ditto follows open‑source IoT standards"
]