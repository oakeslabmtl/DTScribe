// C3: Physical sensing components
instance TemperatureSensorBIM : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in the BIM model capturing indoor air temperature (°C)"
    DTDFVocab:producedData TempDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorBIM
]

// C5: Data produced from sensor
instance TempData : DTDFVocab:Data [
    base:desc "Numeric temperature reading in °C streamed from the building sensor"
    DTDFVocab:fromData TempDataTransmitted
    DTDFVocab:inputTo ModelValidationComponent
    DTDFVocab:inputTo HonoIngestionEnabler
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM model enriched with device metadata, including temperature sensor definition"
    DTDFVocab:inputTo ModelValidationComponent
    DTDFVocab:inputTo DataConversionEnabler
]

// C11: Enablers
instance ModelValidationComponent : DTDFVocab:Enabler [
    base:desc "Validates unit and value range of sensor data before forwarding to downstream services"
    DTDFVocab:enables MonitoringService, PredictiveAnalyticsService, ControlService, VisualizationService
]

instance DataConversionEnabler : DTDFVocab:Enabler [
    base:desc "Converts validated BIM data into a format consumable by Eclipse Hono and Ditto"
    DTDFVocab:enables DataIngestionService
]

instance HonoIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Handles ingestion of sensor data streams from Eclipse Hono into Ditto"
    DTDFVocab:enables DataIngestionService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of building performance via continuous data exchange"
    DTDFVocab:provides TemperatureInsight, EfficiencyInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Offers predictive analytics for condition‑based maintenance of building systems"
    DTDFVocab:provides ConditionBasedMaintenanceInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Controls actuators such as lights and HVAC units based on user‑defined logic"
    DTDFVocab:provides SystemControlAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Enables immersive interactive visualization of building status and analytics dashboards"
    DTDFVocab:provides VisualDashboardInsight
]

instance DataIngestionService : DTDFVocab:Service [
    base:desc "Ingests processed data into Eclipse Ditto for real‑time state replication"
]

// C17: Insights/Actions
instance TemperatureInsight : DTDFVocab:Insight [
    base:desc "Current indoor temperature trend compared to historical baselines"
]

instance ConditionBasedMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive alert for lighting failures or HVAC maintenance based on sensor data"
]

instance EfficiencyInsight : DTDFVocab:Insight [
    base:desc "Real‑time energy consumption efficiency metrics relative to design targets"
]

instance VisualDashboardInsight : DTDFVocab:Insight [
    base:desc "Interactive dashboard visualizing multiple building performance metrics"
]

instance SystemControlAction : DTDFVocab:Action [
    base:desc "Adjusts light actuator brightness, color temperature, and HVAC setpoints in response to sensor triggers"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Physical LED light actor exposed as a controllable element API supports on/off, brightness, and color temperature commands"
]

// C: Environment
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains LightTwinComponent, TemperatureSensorBIM
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The twin framework supports bidirectional communication; control messages originating from the DT (e.g., HVAC setpoint adjustments or lighting commands) are sent back to the Building Control System (BCS) via the same Eclipse Hono/ Ditto integration, allowing the physical building to be actuated in response to DT decisions. While specific message formats and authentication mechanisms are not detailed in the documents, the architecture guarantees that command flows are routed through the established Hono/ditto channels and that the physical asset receives acknowledgement of command execution."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The framework guarantees real‑time, continuous bi‑directional data exchange that synchronises the physical building and its Digital Twin at runtime.  Synchronisation is event‑driven and is designed to minimise latency to the point of real‑time operation, as described in the real‑time data exchange capabilities highlighted in the document.  The architecture supports continuous monitoring and control with explicit emphasis on maintaining low temporal latency and fine‑grained granularity, enabling instant reflection of sensor data and command execution across the twin without full redeployment."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is orchestrated through a modular, component‑centric architecture that centres on a DT Framework acting as a central hub.  This hub exposes standardized extension points, enabling the seamless integration of custom services, analytics modules, and monitoring interfaces.  The design follows a pattern of loose coupling and runtime configuration management, allowing components to be added, re‑configured or removed on demand without full system redeployment.  Resource management is achieved through dynamic allocation of services and data pipelines, while system‑wide coordination is handled by the hub which routes bidirectional data streams between BIM models, sensor networks and user interfaces, thereby sustaining a holistic life‑cycle management flow."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "the digital twin life‑cycle envisioned by the model‑driven deployment framework consists of four key stages. in the concept‑and‑modeling phase building‑control engineers enrich a BIM model with device semantics, explicitly encoding the spatial layout of sensors, actuators, and controllers as BIM elements. the mde stage applies model‑driven engineering to transform the enriched BIM into structured, machine‑interpretable representations, from which deployable digital‑twin artefacts (including data adapters, command handlers, and persistency stores) are automatically generated. the deployment stage provisions these artefacts onto the target edge or cloud infrastructure, a minimal‑manual, auto‑configuration procedure aligns physical device identifiers with the twin’s runtime entities. the final operation stage real‑time synchronises the physical building and the twin over bidirectional data‑exchange channels, while interactive visualisations expose the twin to facility managers for monitoring and control. governance is enforced through dedicated stakeholder roles—building‑control engineers, facility managers, and dt engineers—each responsible for a lifecycle slice; the framework’s modular architecture and standardised extension points provide maintainable boundaries that facilitate version control and systematic rollback in case of mis‑alignment between bim and runtime models."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained through a traceable validation pipeline: BIM models are checked against semantic constraints, whereas runtime data undergoes policy‑based validation in Eclipse Ditto to enforce value ranges and unit consistency. Pre‑execution checks on actuator commands further safeguard operational safety. Fault tolerance is ensured by Eclipse Hono’s at‑least‑once message delivery and Ditto’s persistent event storage, preserving telemetry in the event of network or service interruptions. The bidirectional integration between the twin and physical assets, governed by observable patterns in the UnrealTwinController, enables continuous verification of state consistency. Extension points in the modular architecture permit the addition of custom analytics or verification services, facilitating ongoing quality assurance and uncertainty quantification throughout the twin lifecycle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on a service‑oriented architecture where Eclipse Hono serves as the central message broker, handling heterogeneous drivers (sensor, actuator, building management). Eclipse Ditto provides an entity registry and event bus over the same transport, enabling real‑time synchronization. The network topology is a multitenant hub‑and‑spoke model with a gateway per building zone, ensuring scalable, low‑latency communication between physical devices and digital twin services."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The framework is designed to be interoperable across heterogeneous systems, with interoperability highlighted as a core non‑functional requirement. While specific protocols (e.g., REST, MQTT) are not mentioned, the architecture supports seamless integration with external devices, services, and enterprise systems, allowing the Digital Twin to connect to varied infrastructure components."
]