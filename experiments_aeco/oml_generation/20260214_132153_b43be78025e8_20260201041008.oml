// C2: Acting Components
instance LightFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture defined as a controllable device in BIM, instantiated in the digital twin as a TwinComponent for on/off and dimming control"
]

instance HVACRegulatorActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC regulator defined as a controllable device in BIM, instantiated in the twin to adjust temperature setpoints and airflow rates"
]

// C10: Models/Data
instance EnrichedBIMGeometryModel : DTDFVocab:Model [
    base:desc "Enriched BIM geometry including architectural, structural, and infrastructure information"
    DTDFVocab:inputTo MDETransformationEngine
]

instance DeviceControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral model representing device control logic coded by Building Control Engineers and extracted from BIM annotations"
    DTDFVocab:inputTo MDETransformationEngine
]

instance AssetConfigurationModel : DTDFVocab:Model [
    base:desc "Configuration model linking sensors, actuators, and controllers as defined in the BIM environment"
    DTDFVocab:inputTo MDETransformationEngine
]

instance BIMMetadataData : DTDFVocab:Data [
    base:desc "Metadata extracted from the BIM model, including Revit photometric values for lighting"
    DTDFVocab:inputTo MDETransformationEngine
    DTDFVocab:fromData MDEDataTransmitted
]

instance SensorStreamData : DTDFVocab:Data [
    base:desc "Real‑time sensor streams ingested from building sensors via Eclipse Hono"
    DTDFVocab:inputTo EclipseHonoInterface
]

instance SensorDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Real‑time sensor data transmitted via Eclipse Hono to the twin"
    DTDFVocab:fromData SensorStreamData
]

instance CommandMessageData : DTDFVocab:Data [
    base:desc "Command messages issued to actuators for physical control via Eclipse Ditto"
    DTDFVocab:inputTo EclipseDittoInterface
    DTDFVocab:fromData CommandDataTransmitted
]

instance CommandDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Command messages transmitted via Eclipse Ditto for actuation"
    DTDFVocab:fromData CommandMessageData
]

// C11: Enablers
instance MDETransformationEngine : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering transformation engine that converts enriched BIM models into deployable digital twin artifacts"
    DTDFVocab:enables MonitoringService, PredictiveAnalyticsService, OptimizationService
]

instance EclipseHonoInterface : DTDFVocab:Enabler [
    base:desc "Eclipse Hono interface for real‑time data ingestion from building sensors into the twin"
    DTDFVocab:enables MonitoringService, PredictiveAnalyticsService
]

instance EclipseDittoInterface : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto interface that abstracts building devices and routes command messages to actuators"
    DTDFVocab:enables ControlService
]

instance UnrealEngine5Renderer : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 renderer accessed via a TwinComponent layer to provide immersive visualization"
    DTDFVocab:enables VisualizationService
]

instance TwinComponentLayer : DTDFVocab:Enabler [
    base:desc "Layer that connects digital twin components to the Unreal Engine rendering pipeline"
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of sensor streams and system states through the twin"
    DTDFVocab:provides SystemStateInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics and failure forecasting enabled by AI models attached to the twin"
    DTDFVocab:provides FailureForecastInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization of energy usage and system performance via analytical models in the twin"
    DTDFVocab:provides EnergyEfficiencyInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Control services that enable building control engineers and facility managers to issue commands directly to the physical building via the twin"
    DTDFVocab:provides ExecuteCommandAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization dashboards that provide an immersive interface for monitoring and controlling building operations"
    DTDFVocab:provides LaunchDashboardAction
]

// C17: Insights
instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Insight into real‑time system states derived from continuous sensor monitoring"
]

instance FailureForecastInsight : DTDFVocab:Insight [
    base:desc "Insight predicting potential failures based on predictive analytics of sensor data"
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insight into energy usage optimization opportunities derived from analytical models"
]

// C17: Actions
instance ExecuteCommandAction : DTDFVocab:Action [
    base:desc "Action to execute control commands issued via the twin to physical actuators"
    DTDFVocab:IsAutomatic false
]

instance LaunchDashboardAction : DTDFVocab:Action [
    base:desc "Action to launch an interactive visualization dashboard within Unreal Engine 5"
    DTDFVocab:IsAutomatic false
]

// Placeholder for transferred data constructs
instance MDEDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Data transmitted from the MDE transformation process to downstream enablers and services"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange capabilities enable continuous synchronization between the physical building and its digital twin, but the documents do not specify exact polling or push frequencies, latency thresholds, or temporal granularity beyond the term 'real‑time'."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT framework follows a modular architecture pattern with standardized extension points, enabling custom service integration and analytics. A central hub facilitates bidirectional data exchange between the physical building and the digital twin and provides a holistic approach to building lifecycle management. Runtime configuration management allows adaptability without full redeployment, supporting coordination among roles such as Building Control Engineers, Facility Managers, and DT Engineers."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Initiation – Building control engineers enrich BIM models with sensor, actuator and controller elements, addressing BIM’s static limitations; Transformation – Using model‑driven engineering (MDE) the framework extracts structured representations from the enriched BIM and automatically generates deployable Digital‑Twin artifacts (model‑based digital assets); Deployment – Devices are provisioned, real‑time data‑exchange links are established to keep the digital twin synchronized with the physical building; Operation – Facility managers monitor the twin through immersive visualization dashboards, control physical infrastructure via the twin, and provide feedback for tuning; Evolution – DT engineers extend functionality by publishing custom services or analytics through standardized extension points; the modular architecture supports versioning and rollback. Governance is enforced through actor roles (Building Control Engineer, Facility Manager, DT Engineer) and lifecycle checkpoints defined in the deployment framework."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by validating enriched BIM models against defined schemas before conversion. Eclipse Ditto’s policy‑based validation enforces value ranges, units, and consistency for incoming sensor measurements, thereby preventing out‑of‑range data from corrupting the twin. Fault tolerance is achieved through Eclipse Hono’s at‑least‑once delivery semantics and Ditto’s persistent event storage, which safeguard against transient network failures. Pre‑execution checks for actuator commands ensure that potentially unsafe or conflicting actuations are rejected before reaching the physical device. The framework’s modular architecture allows for the integration of additional verification layers (e.g., simulation‑based validation) at defined extension points, thus supporting continuous quality assurance throughout the DT lifecycle."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT framework emphasizes interoperability across heterogeneous systems, supporting integration of external systems via standardized extension points and real‑time data exchange mechanisms. Specific data exchange protocols or interoperability standards are not detailed in the provided documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework aims for interoperability via bidirectional real‑time communication but does not specify compliance with particular industry standards; it acknowledges the absence of standardized data schemas and robust integration frameworks in many AECO deployments. Existing open‑source platforms such as Eclipse Ditto and BaSyx provide standard compliance for connectivity but require manual configuration, highlighting the need for automated, standard‑aligned solutions in AECO contexts."
]