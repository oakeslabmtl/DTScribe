    base:desc "Electromechanical actuator for automated window shades in the university library, integrated with occupancy sensors and lighting controls to optimize natural light utilization and energy efficiency."
]

instance SmartRelayActuator : DTDFVocab:ActingComponent [
    base:desc "Digital relay actuator for electrical circuit control in both buildings, supporting occupancy-based lighting and equipment power management through BACnet/Modbus communication protocols."
]

instance PIDControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Proportional-Integral-Derivative controller actuator for precise HVAC system regulation, implementing closed-loop control algorithms to maintain setpoint temperatures and humidity levels."
]

