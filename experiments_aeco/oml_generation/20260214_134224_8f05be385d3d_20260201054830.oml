// C2: Acting Components
// (Acting components are defined within the enriched BIM and are represented by ServiceActions)

// C3: Physical sensing components
instance TemperatureSensorBIM : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor defined in enriched BIM with unit °C and location in Heating Zone"
    DTDFVocab:producedData TemperatureTelemetry
]

instance OccupancySensorBIM : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor defined in enriched BIM with binary occupancy flag and location in Lobby"
    DTDFVocab:producedData OccupancyTelemetry
]

instance AirflowSensorBIM : DTDFVocab:SensingComponent [
    base:desc "Airflow sensor defined in enriched BIM measuring airflow rate in CFM in HVAC duct"
    DTDFVocab:producedData AirflowTelemetry
]

// C4: Physical‑to‑virtual interaction
instance TemperatureTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorBIM
]

instance OccupancyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensorBIM
]

instance AirflowTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirflowSensorBIM
]

// C5: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Continuous temperature telemetry data transferred from TemperatureSensorBIM, stored in Ditto"
    DTDFVocab:fromData TemperatureTelemetry
    DTDFVocab:inputTo EclipseDitto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Discrete occupancy event data transferred from OccupancySensorBIM, stored in Ditto"
    DTDFVocab:fromData OccupancyTelemetry
    DTDFVocab:inputTo EclipseDitto
]

instance AirflowData : DTDFVocab:Data [
    base:desc "Continuous airflow telemetry data transferred from AirflowSensorBIM, stored in Ditto"
    DTDFVocab:fromData AirflowTelemetry
    DTDFVocab:inputTo EclipseDitto
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM enriched with sensors, actuators, control logic, serving as source for MDE pipeline"
    DTDFVocab:inputTo MDEPipeline
]

instance IFCBasedOntologyModel : DTDFVocab:Model [
    base:desc "IFC-based ontology derived from EnrichedBIMModel via MDE pipeline"
    DTDFVocab:inputTo MDEPipeline
]

instance ThermalSimulationModel : DTDFVocab:Model [
    base:desc "Thermal simulation model derived from IFCBasedOntologyModel, executed by SimulationEngine"
    DTDFVocab:inputTo SimulationEngine
]

instance LightingSimulationModel : DTDFVocab:Model [
    base:desc "Lighting simulation model derived from IFCBasedOntologyModel, executed by SimulationEngine"
    DTDFVocab:inputTo SimulationEngine
]

instance AirflowSimulationModel : DTDFVocab:Model [
    base:desc "Airflow simulation model derived from IFCBasedOntologyModel, executed by SimulationEngine"
    DTDFVocab:inputTo SimulationEngine
]

// C11: Enablers
instance MDEPipeline : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline that transforms enriched BIM into structured digital twin artifacts"
    DTDFVocab:enables SimulationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine that executes thermal, lighting, and airflow models"
    DTDFVocab:enables SimulationService
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono ingestion service for sensor data streams, ensuring at‑least‑once message delivery"
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto event store for telemetry events, enabling data‑driven services"
    DTDFVocab:enables RealTimeMonitoringService, ControlService, OptimizationService
]

instance BIMViewer : DTDFVocab:Enabler [
    base:desc "BIM viewer providing overlay of live data onto 3‑D models for immersive visualization"
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real‑time monitoring of building states via telemetry streams from physical sensors"
    DTDFVocab:provides OccupancyPatternInsight, TemperatureInsight, AirflowInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service executing thermal, lighting, and airflow simulations on digital twin models"
    DTDFVocab:provides ThermalInsight, LightingInsight, AirflowSimulationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service performing optimization of energy and resource consumption based on digital twin analytics"
    DTDFVocab:provides EnergyConsumptionInsight, OptimizeEnergyAction
]

instance ControlService : DTDFVocab:Service [
    base:desc "Service controlling embedded devices via predefined logic transmitted from the digital twin"
    DTDFVocab:provides DeviceControlAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service delivering immersive interactive visualizations of building states in BIM viewers"
    DTDFVocab:provides VisualizeStateAction
]

// C17: Insights
instance OccupancyPatternInsight : DTDFVocab:Insight [
    base:desc "Insight indicating occupancy trends extracted from real‑time telemetry"
]

instance TemperatureInsight : DTDFVocab:Insight [
    base:desc "Insight indicating temperature anomalies detected by real‑time monitoring"
]

instance AirflowInsight : DTDFVocab:Insight [
    base:desc "Insight indicating airflow deviations identified by monitoring data"
]

instance ThermalInsight : DTDFVocab:Insight [
    base:desc "Thermal behavior insight derived from simulation of thermal models"
]

instance LightingInsight : DTDFVocab:Insight [
    base:desc "Lighting performance insight derived from simulation of lighting models"
]

instance AirflowSimulationInsight : DTDFVocab:Insight [
    base:desc "Airflow dynamics insight derived from simulation of airflow models"
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Energy consumption insight derived from optimization analysis"
]

// C17: Actions
instance DeviceControlAction : DTDFVocab:Action [
    base:desc "Action to trigger actuator commands in response to control logic"
    DTDFVocab:IsAutomatic true
]

instance OptimizeEnergyAction : DTDFVocab:Action [
    base:desc "Action to adjust device setpoints to achieve optimized energy consumption"
    DTDFVocab:IsAutomatic false
]

instance VisualizeStateAction : DTDFVocab:Action [
    base:desc "Action to render current building state in BIM viewer overlay"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Bidirectional communication between the Digital Twin and physical assets is facilitated through the same event stream used for telemetry. Control commands—such as HVAC setpoint adjustments, lighting level changes, and equipment operation changes—are embedded in the twin’s service layer and translated into actuator instructions sent to the physical devices. Validation and authorization of these commands are performed by the middleware, and execution confirmation is returned as acknowledgment events, forming a closed‑loop feedback system that resolves conflicts and ensures command consistency."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time, continuous bidirectional data exchange between the physical building and its digital twin, providing real‑time synchronization; no specific frequency or latency values are specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT Constellation follows a modular, service‑oriented architecture with a central DT Framework hub that orchestrates bidirectional data exchange between enriched BIM models and runtime sensor streams. Standardized extension points allow insertion of custom analytics and control services, and runtime configuration management enables dynamic adaptation without full redeployment. System‑wide coordination is enforced through the hub’s configuration and event‑based messaging, providing a holistic approach to building life‑cycle management."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "1) Enrichment of the BIM model with device‑level metadata (sensors, actuators, controllers) by Building Control Engineers, establishing a unified semantic foundation. 2) Model‑Driven Engineering (MDE) transformations extract structured representations (e.g., IFC extensions or domain ontologies) from the enriched BIM, automatically mapping BIM constructs to runtime components. 3) Artifacts (executable services, APIs, database schemas) are generated and deployed from the transformed models with minimal manual configuration, enabling rapid iteration. 4) Runtime operation continuously synchronises sensor data and actuator commands via real‑time data exchange protocols, providing real‑time state alignment between the physical building and its Digital Twin. 5) Continuous evolution is supported by modular extension points, allowing new analytics or control logic to be plugged in without modifying core artifacts. Governance is realised through defined stakeholder roles—Building Control Engineer, Facility Manager, DT Engineer—each responsible for specific lifecycle stages."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured by embedding the semantic constraints of the BIM model into Ditto’s policy framework, which enforces value ranges and units during runtime message validation. Verification of actuator command safety is performed by the policy engine before dispatch, preventing unsafe state transitions. Data validity is maintained via Hono’s reliable message broker guaranteeing at‑least‑once delivery and Ditto’s persistent event store, providing recoverable event streams. Fault tolerance is achieved by persistent storage in Ditto, so that events are not lost during service interruptions. No formal static verification of control logic is described; the system relies on runtime validation and memory of past events to ensure consistent behavior."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved via standardized extension points that support interoperability across heterogeneous enterprise systems; specific protocols or messaging patterns are not specified in the provided documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The platform is designed to interoperate with established open‑source DT frameworks such as Eclipse Ditto and BaSyx, providing bidirectional communication with sensor networks through standardized protocols. It aligns with AECO‑specific interoperability requirements by building on BIM as a semantic foundation, and the modular architecture facilitates compliance with evolving industry standards and data schemas."
]