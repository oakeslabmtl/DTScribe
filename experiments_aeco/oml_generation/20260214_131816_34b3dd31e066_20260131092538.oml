//----- Enablers -----
instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering pipeline that transforms IFC models to runtime artifact templates"
    DTDFVocab:enables BIMTransformationService
]

instance EclipseHonoBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Hono message broker that forwards real-time telemetry via MQTT topics"
    DTDFVocab:enables LiveMonitoringDashboardService, PredictiveEnergyAnalyticsService, RLLightingOptimizationService, AnomalyDetectionService, RESTGraphQLAPIService
]

instance EclipseDittoRegistry : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin registry that synchronizes twin states and exposes them as GeoJSON and SF JSON events"
    DTDFVocab:enables TwinRegistrySyncService
]

instance UnrealEngine5RenderingEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 rendering engine that renders live monitoring dashboards"
    DTDFVocab:enables LiveMonitoringDashboardService
]

instance KubernetesContainerOrchestration : DTDFVocab:Enabler [
    base:desc "Kubernetes orchestrates containerized DT services and provides deployment automation"
    DTDFVocab:enables DeploymentAutomationService
]

//----- Services -----
instance BIMTransformationService : DTDFVocab:Service [
    base:desc "Transforms IFC models to runtime artifact templates for deployment"
]

instance TwinRegistrySyncService : DTDFVocab:Service [
    base:desc "Synchronizes twin registry state with physical devices through Eclipse Ditto"
]

instance LiveMonitoringDashboardService : DTDFVocab:Service [
    base:desc "Live monitoring dashboards rendered in Unreal Engine 5"
    DTDFVocab:provides OccupancyHeatMapInsight, EnergyUsageDashboardInsight
]

instance PredictiveEnergyAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive energy-usage analytics that forecasts consumption and generates alerts"
    DTDFVocab:provides PredictiveMaintenanceAlertInsight
]

instance RLLightingOptimizationService : DTDFVocab:Service [
    base:desc "Reinforcement-learning driven lighting optimization that generates scheduling actions"
    DTDFVocab:provides LightingScheduleOptimizationAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Automated anomaly detection on telemetry streams"
    DTDFVocab:provides AutomatedAnomalyDetectionInsight
]

instance RESTGraphQLAPIService : DTDFVocab:Service [
    base:desc "REST/GraphQL API for third-party analytics services"
    DTDFVocab:provides APIEndpointInsight
]

instance DeploymentAutomationService : DTDFVocab:Service [
    base:desc "Automates deployment of DT services on Kubernetes"
]

//----- Insights & Actions -----
instance EnergyUsageDashboardInsight : DTDFVocab:Insight [
    base:desc "Real-time energy-usage dashboard presented to facility managers"
]

instance OccupancyHeatMapInsight : DTDFVocab:Insight [
    base:desc "Real-time occupancy heat map derived from sensor telemetry"
]

instance PredictiveMaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance alerts generated from anomaly detection and analytics"
]

instance LightingScheduleOptimizationInsight : DTDFVocab:Insight [
    base:desc "Lighting schedule optimization suggestions derived from reinforcement learning"
]

instance RLLightingOptimizationInsight : DTDFVocab:Insight [
    base:desc "Reinforcement learning driven lighting optimizations"
]

instance AutomatedAnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Automated anomaly detection insights on telemetry streams"
]

instance APIEndpointInsight : DTDFVocab:Insight [
    base:desc "API endpoint for third-party analytics services"
]

instance LightingScheduleOptimizationAction : DTDFVocab:Action [
    base:desc "Automated lighting schedule optimization action derived from reinforcement learning"
    DTDFVocab:IsAutomatic true
]

//----- Modeling and Data Instances -----
instance EnrichedSemanticBIMModel : DTDFVocab:Model [
    base:desc "Semantic BIM model enriched with control metadata (IfcControl, IfcSensor)"
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance DittoTwinObjectsCollection : DTDFVocab:Data [
    base:desc "Collection of Ditto twin objects representing devices in the building"
    DTDFVocab:inputTo EclipseDittoRegistry
]

//----- Physical Sensing Components -----
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor embedded within rooms and zones of the building"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance IlluminanceSensor : DTDFVocab:SensingComponent [
    base:desc "Illuminance sensor measuring indoor light levels"
    DTDFVocab:producedData IlluminanceDataTransmitted
]

instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor monitoring indoor temperature"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor measuring indoor air quality"
    DTDFVocab:producedData CO2DataTransmitted
]

instance MotionDetector : DTDFVocab:SensingComponent [
    base:desc "Motion detector embedded within rooms and zones of the building"
    DTDFVocab:producedData MotionDataTransmitted
]

//----- Physical Transmitted Data -----
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminanceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminanceSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance MotionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionDetector
]

//----- Telemetry Data -----
instance OccupancyTelemetryData : DTDFVocab:Data [
    base:desc "Real-time occupancy telemetry published via MQTT and exposed as GeoJSON events"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHonoBroker
]

instance IlluminanceTelemetryData : DTDFVocab:Data [
    base:desc "Real-time illuminance telemetry published via MQTT and exposed as SF JSON events"
    DTDFVocab:fromData IlluminanceDataTransmitted
    DTDFVocab:inputTo EclipseHonoBroker
]

instance TemperatureTelemetryData : DTDFVocab:Data [
    base:desc "Real-time temperature telemetry published via MQTT and exposed as SF JSON events"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoBroker
]

instance CO2TelemetryData : DTDFVocab:Data [
    base:desc "Real-time CO₂ telemetry published via MQTT and exposed as SF JSON events"
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseHonoBroker
]

instance MotionTelemetryData : DTDFVocab:Data [
    base:desc "Real-time motion telemetry published via MQTT and exposed as SF JSON events"
    DTDFVocab:fromData MotionDataTransmitted
    DTDFVocab:inputTo EclipseHonoBroker
]

//----- Physical Acting Components -----
instance LightingFixtureDimmingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture equipped with dimming actuator interfaced via the building's BCS"
]

instance HVACDamperActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC damper actuator controlled through the building's BCS"
]

instance WindowShadeActuator : DTDFVocab:ActingComponent [
    base:desc "Motorized window shade actuator integrated into the building's BCS"
]

//----- Hierarchical Twin Architecture -----
instance BuildingRootTwin : DTDFVocab:Component [
    base:desc "Root twin representing the university campus living laboratory building"
]

instance Zone1Twin : DTDFVocab:Environment [
    base:contains LightingDeviceTwin1, HVACDeviceTwin1
]

instance LightingDeviceTwin1 : DTDFVocab:Component [
    base:desc "Lighting fixture twin for zone 1"
]

instance HVACDeviceTwin1 : DTDFVocab:Component [
    base:desc "HVAC unit twin for zone 1"
]

instance Zone2Twin : DTDFVocab:Environment [
    base:contains LightingDeviceTwin2, HVACDeviceTwin2
]

instance LightingDeviceTwin2 : DTDFVocab:Component [
    base:desc "Lighting fixture twin for zone 2"
]

instance HVACDeviceTwin2 : DTDFVocab:Component [
    base:desc "HVAC unit twin for zone 2"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., lighting dimming levels, HVAC set‑points) are serialized as MQTT messages via Hono and pushed to the building’s BCS, which then actuates the corresponding physical devices"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sub‑second latency (≈ 200 ms) for sensor telemetry and command propagation; synchronization of data streams occurs in near‑real time, with batch updates delivered every few seconds for analytics"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Co‑located microservice ecosystem: an Hono broker, Ditto twin manager, a controller microservice implementing reinforcement learning, a data analytics microservice, and a visualization front‑end in Unreal Engine, all orchestrated under a central Building Twin manager"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (BIM model generation), Construction (model‑to‑device mapping and deployment), Operation (live monitoring and control), and Decommissioning (schema removal), covering the full life‑cycle of the asset"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Alignment verified via the Overall Digital Twin Entanglement (ODTE) metric, with nightly consistency checks; model drift mitigated by re‑parsing IFC models and synchronizing state snapshots"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT over TLS for sensor and actuator messages, Ditto REST/JSON over HTTPS for twin state updates, and WebSocket connections from the Unreal Engine client for real‑time rendering; all routed via Eclipse Hono broker"
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Containerized microservices deployed on a Kubernetes cluster, physical building embedded IoT gateways (e.g., ARM Cortex‑M platforms) for edge data ingestion, and cloud‑hosted visualization server exposing the Unreal Engine instance via WebRTC"
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "REST/HTTP and MQTT interfaces to external Building Management System (BMS), weather API connectors, and interoperability with other DTs via the Ditto event bus"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of IFC (industry‑standard 4.0) for BIM, MQTT protocol per OASIS MQTT, ISO 19650 for BIM information delivery, and adherence to Eclipse Hono’s secure authentication mechanisms; ODTE metric provides standardised entanglement assessment"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Secure transmission via MQTT over TLS, Hono authentication for device identities, access controls in Ditto, audit logging; safety considerations require prior verification of control logic before deployment, with fail‑safe overrides, but detailed safety policies are not specified in the document"
]