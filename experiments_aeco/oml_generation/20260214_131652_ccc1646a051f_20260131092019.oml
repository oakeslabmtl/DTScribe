// C2: Acting Components
instance ActuatedLightingFixture : DTDFVocab:ActingComponent [
    base:desc "Actuated lighting fixture controlled via Eclipse Ditto command bus"
]

instance HVACDamper : DTDFVocab:ActingComponent [
    base:desc "HVAC damper controlled by building automation system through Ditto"
]

instance HeatingCoolingSetpoint : DTDFVocab:ActingComponent [
    base:desc "Heating/cooling setpoint actuator driven by adaptive control logic"
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring ambient temperature in the building"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Light sensor measuring illuminance in each zone"
    DTDFVocab:producedData LightDataTransmitted
]

instance OccupancyDetector : DTDFVocab:SensingComponent [
    base:desc "Occupancy detector using infrared proximity sensing"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor measuring indoor air quality"
    DTDFVocab:producedData CO2DataTransmitted
]

instance PowerMeter : DTDFVocab:SensingComponent [
    base:desc "Power meter that measures electrical consumption of each device"
    DTDFVocab:producedData PowerDataTransmitted
]

instance IoTDevice : DTDFVocab:SensingComponent [
    base:desc "General IoT device providing miscellaneous telemetry"
    DTDFVocab:producedData IoTDeviceDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance LightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancyDetector
]

instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

instance PowerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerMeter
]

instance IoTDeviceDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IoTDevice
]

// Data instances
instance TemperatureMeasurementData : DTDFVocab:Data [
    base:desc "Temperature measurement data published over MQTT via Hono"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance LightMeasurementData : DTDFVocab:Data [
    base:desc "Light measurement data published over MQTT via Hono"
    DTDFVocab:fromData LightDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance OccupancyMeasurementData : DTDFVocab:Data [
    base:desc "Occupancy detection data published over MQTT via Hono"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance CO2MeasurementData : DTDFVocab:Data [
    base:desc "CO₂ concentration data published over MQTT via Hono"
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance PowerMeasurementData : DTDFVocab:Data [
    base:desc "Electrical power consumption data published over MQTT via Hono"
    DTDFVocab:fromData PowerDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

instance IoTDeviceMeasurementData : DTDFVocab:Data [
    base:desc "Miscellaneous IoT telemetry data published over MQTT via Hono"
    DTDFVocab:fromData IoTDeviceDataTransmitted
    DTDFVocab:inputTo EclipseHono
]

// Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono gateway for secure MQTT/AMQP telemetry transport"
    DTDFVocab:enables MQTTBrokerService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto broker for device twin management"
    DTDFVocab:enables DittoTwinningService
]

instance ReinforcementLearningEngine : DTDFVocab:Enabler [
    base:desc "Reinforcement learning framework for adaptive control policies"
    DTDFVocab:enables AdaptiveLightingControlService,
                  AdaptiveHVACControlService,
                  EnergyOptimizationService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 used for immersive 3D visualization of the DT"
    DTDFVocab:enables Immersive3DVisualizationService
]

// Services
instance MQTTBrokerService : DTDFVocab:Service [
    base:desc "MQTT broker service publishing sensor telemetry over TLS"
    DTDFVocab:provides TemperatureSensorInsight
]

instance DittoTwinningService : DTDFVocab:Service [
    base:desc "Ditto twin management service that creates and updates device twins"
    DTDFVocab:provides TwinAggregationInsight
]

instance AdaptiveLightingControlService : DTDFVocab:Service [
    base:desc "Service that computes lighting schedules using reinforcement learning"
    DTDFVocab:provides AdjustLightingScheduleAction
]

instance AdaptiveHVACControlService : DTDFVocab:Service [
    base:desc "Service that determines HVAC setpoints using reinforcement learning"
    DTDFVocab:provides AdjustHVACSetpointAction
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Service that provides energy consumption forecasts and optimization"
    DTDFVocab:provides EnergyConsumptionForecastInsight
]

instance Immersive3DVisualizationService : DTDFVocab:Service [
    base:desc "Service that renders the building model and twin state in Unreal Engine 5"
    DTDFVocab:provides 3DVisualizationInsight
]

// Insights
instance TemperatureSensorInsight : DTDFVocab:Insight [
    base:desc "Real-time temperature data used for building climate control decisions"
]

instance TwinAggregationInsight : DTDFVocab:Insight [
    base:desc "Aggregated state of all device twins managed by Ditto"
]

instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted energy consumption based on historical telemetry and models"
]

instance 3DVisualizationInsight : DTDFVocab:Insight [
    base:desc "Current 3D rendering of the building and twin entities"
]

// Actions
instance AdjustLightingScheduleAction : DTDFVocab:Action [
    base:desc "Automatically adjusts lighting schedules based on occupancy and daylight"
    DTDFVocab:IsAutomatic true
]

instance AdjustHVACSetpointAction : DTDFVocab:Action [
    base:desc "Automatically adjusts HVAC setpoints based on CO₂ and temperature"
    DTDFVocab:IsAutomatic true
]

// C10: Models/Data
instance BIMIfcModel : DTDFVocab:Model [
    base:desc "BIM IFC model transformed into a domain model via MDE"
    DTDFVocab:inputTo EclipseDitto
]

instance ControlSemanticsModel : DTDFVocab:Model [
    base:desc "BIM annotations extended with control semantics for actuation"
    DTDFVocab:inputTo EclipseDitto
]

instance PredictiveOccupancySchedulingModel : DTDFVocab:Model [
    base:desc "Predictive occupancy scheduling model derived from sensor history"
    DTDFVocab:inputTo ReinforcementLearningEngine
]

instance EnergyOptimizationModel : DTDFVocab:Model [
    base:desc "Model for optimizing building energy consumption"
    DTDFVocab:inputTo ReinforcementLearningEngine
]

instance AdaptiveLightingControlModel : DTDFVocab:Model [
    base:desc "Model used by reinforcement learning engine to compute lighting strategies"
    DTDFVocab:inputTo ReinforcementLearningEngine
]

// Environment and components
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor, LightSensor, OccupancyDetector,
    CO2Sensor, PowerMeter, IoTDevice, ActuatedLightingFixture,
    HVACDamper, HeatingCoolingSetpoint
]

instance BuildingComponent : DTDFVocab:Component [
    base:desc "Digital representation of the Living Laboratory building in the DT"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control command events generated by the DT (e.g., lighting schedules, HVAC setpoints) are published by Ditto to the middleware and forwarded via Hono to the building control system, which actuates the physical hardware."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous data exchange at sub‑second intervals (typical MQTT QoS 1, latency < 1 s), with event‑driven updates; DT services execute at a tens‑of‑milliseconds scale for control loops and at minute‑scale for analytics and optimization."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Central DT framework coordinating device twins, middleware (Hono/Ditto), simulation engine (Unreal), and analytics modules, forming a service‑oriented architecture with defined extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (BIM creation), Commissioning (embedding device metadata), Construction (hardware installation), Operation (real‑time monitoring/optimization), and Retrofitting/Evolution (iterative updates and reinforcement learning)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Alignment verified by the Overall Digital Twin Entanglement (ODTE) metric, sensor calibration, QoS‑based data integrity checks, and periodic cross‑validation against BIM‑derived geometric constraints."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "MQTT over TLS 1.2 between physical devices and Hono gateway, Ditto REST/WS for twin updates, and CoAP for constrained devices; all connected through a secure private network with IPsec VPN to the DT host."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital twin services are hosted on an on‑premise Docker cluster running Eclipse Ditto, Hono, and Unreal Engine 5 instances, with optional cloud scaling via Kubernetes in a secure private VNet."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external building automation standards (BACnet, KNX), industry data repositories, and other DT platforms via standard MQTT/REST interfaces, enabling interoperability beyond the local DT."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Data generated by the physical building remains owned by the PT owner; the DT provider accesses it only under service agreements, with GDPR‑compliant data handling and encryption at rest and in transit."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Use of IFC for BIM modeling, MQTT for messaging, OGC SensorThings API for sensor data representation, and ISO/IEC 20922 for digital twin architecture guidance."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "TLS encryption for all network traffic, mutual authentication for devices and services, role‑based access control in Ditto, audit logging, and safety‑critical operation checks to ensure remote commands cannot trigger hazardous actions during human presence."
]