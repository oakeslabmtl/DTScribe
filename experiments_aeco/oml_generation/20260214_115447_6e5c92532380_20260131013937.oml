// C2: Acting Components
instance LightingFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture represented in the BIM model, capable of receiving command messages from the twin to adjust illumination levels."
]

instance HVACValveActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC valve represented in the BIM model, can be commanded by the twin to regulate airflow and temperature."
]

// C3: Physical sensing components
instance EnvironmentSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental sensor captured in the BIM model, measuring temperature, humidity, CO₂, etc., and feeding telemetry into the twin."
    DTDFVocab:producedData EnvDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post‑occupancy sensor captured in the BIM model, detecting presence and occupancy patterns for space‑use analysis."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical-to-virtual interaction                                           
instance EnvDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Models/Data
instance BIMSemanticModel : DTDFVocab:Model [
    base:desc "Static BIM geometry and semantic model enriched with runtime metadata for devices."
    DTDFVocab:inputTo EclipseHono, EclipseDitto
]

instance RuntimeControlLogicModel : DTDFVocab:Model [
    base:desc "Control‑logic model derived from BIM specifications, defining how actuator commands are generated."
    DTDFVocab:inputTo EclipseDitto
]

instance EnvData : DTDFVocab:Data [
    base:desc "Live stream of environmental measurements (temperature, humidity, CO₂) from the building."
    DTDFVocab:inputTo EclipseHono, EclipseDitto
    DTDFVocab:fromData EnvDataTransmitted
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live stream of occupancy detections from post‑occupancy sensors."
    DTDFVocab:inputTo EclipseHono, EclipseDitto
    DTDFVocab:fromData OccupancyDataTransmitted
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware handling MQTT/HTTP messaging for bi‑directional data exchange between sensors and the twin."
    DTDFVocab:enables DataIngestionService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto platform storing twin state, exposing Thing APIs and handling command routing."
    DTDFVocab:enables TwinStateService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 providing immersive 3‑D visualisation of the building twin."
    DTDFVocab:enables ImmersiveVisualizationService
]

instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline that extracts BIM metadata, validates models and generates twin artefacts."
    DTDFVocab:enables TwinArtifactGenerationService
]

// C6: Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Consumes data from Eclipse Hono and forwards it to Eclipse Ditto, updating twin state in real time."
    DTDFVocab:provides OperationalInsight
]

instance TwinStateService : DTDFVocab:Service [
    base:desc "Exposes the current state of each device‑level twin via Eclipse Ditto APIs."
    DTDFVocab:provides OperationalInsight
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time 3‑D immersive visualisation of the building twin in Unreal Engine 5."
    DTDFVocab:provides SimulationOutcomeInsight
]

instance TwinArtifactGenerationService : DTDFVocab:Service [
    base:desc "Automated generation of Ditto thing models and Hono topic configurations from enriched BIM metadata."
    DTDFVocab:provides ArtifactGenerationInsight
]

instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Dashboard presenting live sensor streams, twin state and alerts to stakeholders."
    DTDFVocab:provides OperationalInsight, OptimizationRecommendationInsight
]

instance BuildingPerformanceSimulationService : DTDFVocab:Service [
    base:desc "Runs performance simulations (energy, comfort) using the BIMSemanticModel and control‑logic model."
    DTDFVocab:provides SimulationOutcomeInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Applies machine‑learning models to historic sensor data to forecast energy consumption and occupant behaviour."
    DTDFVocab:provides OptimizationRecommendationInsight
]

// C17: Insights/Actions
instance OperationalInsight : DTDFVocab:Insight [
    base:desc "Real‑time operational insight offering status of lighting, HVAC and environmental conditions."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation suggesting optimal lighting levels or HVAC set‑points to reduce energy use while maintaining comfort."
]

instance SimulationOutcomeInsight : DTDFVocab:Insight [
    base:desc "Delivers results of building‑performance simulations, such as energy savings and thermal‑comfort scores."
]

instance ArtifactGenerationInsight : DTDFVocab:Insight [
    base:desc "Reports successful creation of twin artefacts (Ditto things, Hono topics) from the BIM model."
]

instance AdjustLightingAction : DTDFVocab:Action [
    base:desc "Command to modify illumination levels of a LightingFixtureActuator based on optimisation recommendation."
    DTDFVocab:IsAutomatic true
]

instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Command to change valve position of an HVACValveActuator to achieve desired temperature set‑point."
    DTDFVocab:IsAutomatic true
]

// C18: Environment (grouping)
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains EnvironmentSensor, OccupancySensor, LightingFixtureActuator, HVACValveActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the twin (e.g., lighting set‑points) are sent back through Ditto to Hono and delivered to the corresponding actuators, providing bidirectional control of the physical assets."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization between physical assets and the twin, driven by the streaming capabilities of Hono and Ditto."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central DT framework acting as hub that connects the enriched BIM model, the Hono/Ditto communication layer, the Unreal Engine visualization, and plug‑in services; roles include Building Control Engineer, Facility Manager, and DT Engineer."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers design (as‑designed BIM), construction/as‑built (enriched BIM with device metadata), and operation (as‑operated with live sensor streams)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Alignment between physical building and its twin is quantified using the Overall Digital Twin Entanglement (ODTE) metric; model validation is performed prior to deployment."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Real‑time bi‑directional communication is realized through Eclipse Hono handling device telemetry and command channels, and Eclipse Ditto maintaining the digital twin’s state; together they provide the technical link between PT and DT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM is employed as the industry‑standard modeling framework; the ODTE metric provides a standardized measure of twin entanglement; the framework adopts open‑source standards (Eclipse Hono, Eclipse Ditto) for interoperability."
]