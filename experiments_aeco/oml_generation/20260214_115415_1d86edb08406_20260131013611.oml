// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor installed in the Living Lab building, configuration captured in the enriched BIM"
    DTDFVocab:producedData OccupancyDataTransmitted
]
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Environmental temperature sensor in the Living Lab, configuration captured in the enriched BIM"
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Environmental humidity sensor in the Living Lab, configuration captured in the enriched BIM"
    DTDFVocab:producedData HumidityDataTransmitted
]
instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ concentration sensor in the Living Lab, configuration captured in the enriched BIM"
    DTDFVocab:producedData CO2DataTransmitted
]

// C2: Acting components
instance AdaptiveLightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting control actuator able to receive set‑points from the Digital Twin for adaptive lighting"
]

// C4: Physical-to-virtual interaction (data transmitted)
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]
instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]

// C5: Data (processed / stored)
instance OccupancyData : DTDFVocab:Data [
    base:desc "Realtime occupancy values streamed from OccupancySensor"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDittoStateManagement
]
instance TemperatureData : DTDFVocab:Data [
    base:desc "Realtime temperature values streamed from TemperatureSensor"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseDittoStateManagement
]
instance HumidityData : DTDFVocab:Data [
    base:desc "Realtime humidity values streamed from HumiditySensor"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseDittoStateManagement
]
instance CO2Data : DTDFVocab:Data [
    base:desc "Realtime CO₂ concentration values streamed from CO2Sensor"
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseDittoStateManagement
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "BIM enriched with geometry, topology, device metadata and middleware configuration"
    DTDFVocab:inputTo ModelDrivenPipeline
]
instance BuildingControlLogicModel : DTDFVocab:Model [
    base:desc "Runtime model of building control logic generated from the enriched BIM"
    DTDFVocab:inputTo ModelDrivenPipeline
]
instance ReinforcementLearningLightingModel : DTDFVocab:Model [
    base:desc "Reinforcement‑learning model for adaptive lighting control"
    DTDFVocab:inputTo ReinforcementLearningEngine
]
instance EnergyConsumptionForecastModel : DTDFVocab:Model [
    base:desc "Predictive model forecasting building energy consumption"
    DTDFVocab:inputTo PredictiveAnalyticsEngine
]
instance ComfortAssessmentModel : DTDFVocab:Model [
    base:desc "Model assessing occupant comfort levels based on environmental data"
    DTDFVocab:inputTo PredictiveAnalyticsEngine
]

// C11: Enablers
instance EclipseHonoMiddleware : DTDFVocab:Enabler [
    base:desc "Eclipse Hono middleware ingests bidirectional real‑time sensor streams and forwards them to Ditto"
    DTDFVocab:enables RealTimeMonitoringDashboard
]
instance EclipseDittoStateManagement : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto maintains synchronized digital‑twin state for live sensor updates"
    DTDFVocab:enables RealTimeMonitoringDashboard
]
instance ModelDrivenPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven transformation pipeline that validates enriched BIM and auto‑generates runtime artifacts"
    DTDFVocab:enables DecisionSupportService
]
instance UnrealEngine5Visualization : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 provides immersive 3D visualization of the twin"
    DTDFVocab:enables Interactive3DVisualization
]
instance ReinforcementLearningEngine : DTDFVocab:Enabler [
    base:desc "Engine executing reinforcement‑learning policies for adaptive lighting optimization"
    DTDFVocab:enables EnergyOptimizationService
]
instance PredictiveAnalyticsEngine : DTDFVocab:Enabler [
    base:desc "Engine delivering forecasts and comfort assessments based on predictive models"
    DTDFVocab:enables PredictiveAnalyticsService
]

// C6: Services
instance RealTimeMonitoringDashboard : DTDFVocab:Service [
    base:desc "Realtime monitoring dashboards showing live sensor state and actuator status"
    DTDFVocab:provides EnergyConsumptionRealtimeInsight
]
instance Interactive3DVisualization : DTDFVocab:Service [
    base:desc "Immersive 3D visualization of the Living Lab building in Unreal Engine 5"
    DTDFVocab:provides VisualTwinInsight
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Simulation and predictive analytics delivering energy‑consumption forecasts and comfort assessments"
    DTDFVocab:provides EnergyConsumptionForecastInsight, ComfortLevelAssessmentInsight
]
instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of energy consumption through adaptive lighting control"
    DTDFVocab:provides OptimizedControlSetpointAction, AdaptiveLightingAdjustmentAction
]
instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Decision‑support service for facility‑manager actions based on integrated insights"
    DTDFVocab:provides EnergyConsumptionForecastInsight, OptimizedControlSetpointAction
]

// C17: Insights/Actions
instance EnergyConsumptionRealtimeInsight : DTDFVocab:Insight [
    base:desc "Realtime view of current energy consumption across building systems"
]
instance VisualTwinInsight : DTDFVocab:Insight [
    base:desc "Insight into spatial relationships via immersive 3D twin"
]
instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of future energy consumption generated by predictive analytics"
]
instance ComfortLevelAssessmentInsight : DTDFVocab:Insight [
    base:desc "Assessment of occupant comfort levels derived from environmental data"
]
instance OptimizedControlSetpointAction : DTDFVocab:Action [
    base:desc "Automated adjustment of control set‑points for HVAC, lighting, etc."
    DTDFVocab:IsAutomatic true
]
instance AdaptiveLightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Reinforcement‑learning driven adaptive lighting adjustments"
    DTDFVocab:IsAutomatic true
]

// C1: System under study
instance LivingLabBuilding : DTDFVocab:Component [
    base:desc "Physical building (Living Lab academic building) that is the target of the Digital Twin implementation"
]

// Environment aggregation (optional)
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, TemperatureSensor, HumiditySensor, CO2Sensor, AdaptiveLightingActuator, LivingLabBuilding
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT (e.g., lighting set‑points, HVAC adjustments) are transmitted back to the physical actuators through the Ditto platform, enabling closed‑loop operation of the building control systems."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data exchange and model updates occur continuously in real time, providing up‑to‑date virtual representations of the physical building."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular, service‑oriented architecture consisting of (1) an enriched BIM model, (2) a configurator that extracts device metadata, (3) Eclipse Hono/Ditto for bidirectional communication, (4) optional custom services (e.g., reinforcement‑learning control), and (5) an Unreal Engine visualization front‑end, all coordinated by standardized extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin spans the full building lifecycle: design (BIM‑based modeling), construction (integration of device metadata), operation (real‑time monitoring and control), and later refurbishment or adaptation phases."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The fidelity of the DT is evaluated using the Overall Digital Twin Entanglement (ODTE) metric, which quantifies how well the digital representation mirrors the physical counterpart. The approach also acknowledges semantic drift and incorporates verification steps during model validation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is deployed on a modular service‑oriented platform that integrates Eclipse Ditto and Eclipse Hono for runtime services, with Unreal Engine 5 providing the visualization layer; deployment is automated through the model‑driven pipeline."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework introduces a modeling methodology that standardizes BIM semantics for automated transformation, and provides standardized extension points conforming to AECO interoperability goals, ensuring compatibility with BIM standards (e.g., IFC) and service‑oriented DT architectures."
]