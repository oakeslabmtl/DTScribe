// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in BIM capturing presence data."
    DTDFVocab:producedData OccupancyTelemetry
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Illumination sensor modeled in BIM measuring ambient light levels."
    DTDFVocab:producedData IlluminationTelemetry
]

// C4: Physical‑to‑virtual interaction
instance OccupancyTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance IlluminationTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

// C4: Data derived from telemetry
instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy data derived from occupancy telemetry."
    DTDFVocab:inputTo HonoConnectivityEnabler
    DTDFVocab:fromData OccupancyTelemetry
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Illumination data derived from illumination telemetry."
    DTDFVocab:inputTo HonoConnectivityEnabler
    DTDFVocab:fromData IlluminationTelemetry
]

// C2: Acting components
instance LightFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Light fixture with controllable drivers and dimming interfaces driven by BCS logic."
]

instance ControlModuleActuator : DTDFVocab:ActingComponent [
    base:desc "Control module issuing commands to light fixtures via building control system logic."
]

// C4: Actuator telemetry
instance LightFixtureStateTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightFixtureActuator
]

instance ControlModuleCommandTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ControlModuleActuator
]

// C4: Actuator data
instance LightFixtureStateData : DTDFVocab:Data [
    base:desc "State information of light fixtures transmitted from actuator."
    DTDFVocab:inputTo DittoTwinSynchronizer
    DTDFVocab:fromData LightFixtureStateTelemetry
]

instance ControlModuleCommandData : DTDFVocab:Data [
    base:desc "Control commands transmitted from control module to actuators."
    DTDFVocab:inputTo DittoTwinSynchronizer
    DTDFVocab:fromData ControlModuleCommandTelemetry
]

// C10: Models/Data
instance BIMMetadataModel : DTDFVocab:Model [
    base:desc "BIM metadata containing geometry, topology, and functional attributes."
    DTDFVocab:inputTo MDEBIMExtractor
]

instance RuntimeModel : DTDFVocab:Model [
    base:desc "Runtime artifact generated from BIM semantic extraction."
    DTDFVocab:inputTo TransformationToolEnabler
]

instance SensorDataStream : DTDFVocab:Data [
    base:desc "Continuous sensor data stream for occupancy and illumination."
    DTDFVocab:fromData OccupancyTelemetry, IlluminationTelemetry
]

instance ActuatorStateInfo : DTDFVocab:Data [
    base:desc "Actuator state information represented in runtime model."
    DTDFVocab:inputTo TransformationToolEnabler
]

instance HonoDittoConfigMetadata : DTDFVocab:Data [
    base:desc "Configuration metadata for Hono/Ditto integration."
    DTDFVocab:inputTo HonoConnectivityEnabler
]

// C11: Enablers
instance MDEBIMExtractor : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering extraction tool that semantically reads BIM metadata."
    DTDFVocab:enables AnalyticsPipeline
]

instance TransformationToolEnabler : DTDFVocab:Enabler [
    base:desc "Model-to-model transformation tool generating runtime models."
    DTDFVocab:enables AnalyticsPipeline
]

instance HonoConnectivityEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono connector providing MQTT-based telemetry ingestion."
    DTDFVocab:enables DittoTwinSynchronizer
]

instance DittoTwinSynchronizer : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto twin management synchronizing sensor data to Ditto entities."
    DTDFVocab:enables RealTimeMonitoringService, DataDashboardService, InteractiveVisualizationService
]

instance UnrealVisualizationEngine : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for rich, interactive 3D visualization of the building twin."
    DTDFVocab:enables InteractiveVisualizationService
]

instance AnalyticsPipeline : DTDFVocab:Service [
    base:desc "Analytics pipeline ingesting sensor data streams for predictive modeling and insights."
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation and predictive analytics for energy consumption forecasts."
    DTDFVocab:provides EnergyConsumptionForecastInsight
]

instance EnergyForecastService : DTDFVocab:Service [
    base:desc "Energy consumption forecasting service utilizing predictive analytics."
    DTDFVocab:provides EnergyConsumptionForecastInsight
]

instance LightingOptimizationService : DTDFVocab:Service [
    base:desc "Adaptive lighting optimization service applying rules and reinforcement learning."
    DTDFVocab:provides LightingScheduleOptimizationInsight, AdaptiveLightingControlAction
]

instance MaintenancePlanningService : DTDFVocab:Service [
    base:desc "Task planning service generating maintenance schedules for facility managers."
    DTDFVocab:provides OperationalRecommendationInsight, MaintenanceScheduleAction
]

instance InteractiveVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization service integrated with Unreal Engine 5."
]

instance DataDashboardService : DTDFVocab:Service [
    base:desc "Data analytics dashboards for facility managers displaying live telemetry."
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring service aggregating telemetry data for alerts."
]

// C17: Insights
instance LightingScheduleOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized lighting schedule derived from adaptive lighting optimization service."
]

instance EnergyConsumptionForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasted energy consumption generated by simulation and predictive analytics."
]

instance OperationalRecommendationInsight : DTDFVocab:Insight [
    base:desc "Operational recommendations for facility managers from maintenance planning service."
]

// C17: Actions
instance AdaptiveLightingControlAction : DTDFVocab:Action [
    base:desc "Automatic dimming and scheduling adjustments for lighting fixtures."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceScheduleAction : DTDFVocab:Action [
    base:desc "Scheduled maintenance tasks issued to facility managers."
    DTDFVocab:IsAutomatic false
]

// Environment
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, IlluminationSensor, LightFixtureActuator, ControlModuleActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control messages generated by the digital twin are transmitted as JSON payloads through Ditto to Eclipse Hono, which forwards them to the building control system; BCS controllers consume these commands and actuate the physical devices."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization of telemetry and control messages with sub‑second latency; simulations and optimizations can be performed at configurable intervals such as every minute or triggered on demand."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Service‑oriented architecture: BIM model processor → MDE transformer → Hono/Ditto dispatcher → DT runtime engine (simulation, optimization) → visualization layer (Unreal) with optional DT services plugins"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (BIM modeling), Construction, Commissioning, Operation & Maintenance; the DT spans from design through operation, referencing design‑time models, as‑built data, and live operational data"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The OTTE metric assesses the correspondence between the digital and physical representations; consistency checks are performed during model validation to ensure that the twin accurately reflects the BIM derived assets."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication relies on Eclipse Hono as an MQTT broker, with Ditto providing CoAP/HTTPS endpoints for twin interaction; physical devices publish to Hono, which forwards messages to Ditto, and commands flow back in the same manner."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Deployment is conducted through the Hono/Ditto configurator, which provisions tenant and device entries and orchestrates the running of twin components in a scalable, service‑oriented runtime environment."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Standardized extension points in Ditto allow integration with third‑party OT platforms and external DT systems (e.g., HVAC, security)"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The twin adheres to IFC standards for BIM data and employs model‑driven transformations following the conventions outlined in the paper, ensuring interoperability within the AECO domain."
]