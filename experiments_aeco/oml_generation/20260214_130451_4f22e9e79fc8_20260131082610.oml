instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor within Building Control Systems (BCS)"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance LightIntensitySensor : DTDFVocab:SensingComponent [
    base:desc "Light intensity sensor within Building Control Systems (BCS)"
    DTDFVocab:producedData LightIntensityDataTransmitted
]

instance CO2ConcentrationSensor : DTDFVocab:SensingComponent [
    base:desc "CO2 concentration sensor within Building Control Systems (BCS)"
    DTDFVocab:producedData CO2ConcentrationDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor within Building Control Systems (BCS)"
    DTDFVocab:producedData HumidityDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor within Building Control Systems (BCS)"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance HVACController : DTDFVocab:ActingComponent [
    base:desc "HVAC controller within Building Control Systems (BCS) for temperature regulation"
]

instance LightingController : DTDFVocab:ActingComponent [
    base:desc "Lighting controller within Building Control Systems (BCS) for adjusting light levels"
]

instance WindowBlindsActuator : DTDFVocab:ActingComponent [
    base:desc "Window blind actuator within Building Control Systems (BCS) for natural light management"
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance LightIntensityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightIntensitySensor
]

instance CO2ConcentrationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2ConcentrationSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature readings from physical sensors"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHono, Ditto
]

instance LightIntensityData : DTDFVocab:Data [
    base:desc "Real-time light intensity measurements"
    DTDFVocab:fromData LightIntensityDataTransmitted
    DTDFVocab:inputTo EclipseHono, Ditto
]

instance CO2ConcentrationData : DTDFVocab:Data [
    base:desc "CO2 concentration levels from sensors"
    DTDFVocab:fromData CO2ConcentrationDataTransmitted
    DTDFVocab:inputTo EclipseHono, Ditto
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Relative humidity measurements"
    DTDFVocab:fromData HumidityDataTransmitted
    DTDFVocab:inputTo EclipseHono, Ditto
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy status data"
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono, Ditto
]

instance BuildingBIMModel : DTDFVocab:Model [
    base:desc "BIM-based model containing geometric, spatial, and functional characteristics of building components"
    DTDFVocab:inputTo BIMTools, MDEMethodologies
]

instance BIMTools : DTDFVocab:Enabler [
    base:desc "BIM tools for modeling geometric, spatial, and functional characteristics of building components"
    DTDFVocab:enables SimulationService, EnergyOptimizationService, VisualComfortAdjustmentService, HealthEffectManagementService
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono for IoT data exchange and real-time data transmission"
    DTDFVocab:enables RealTimeMonitoringService, SimulationService, EnergyOptimizationService, VisualComfortAdjustmentService, HealthEffectManagementService
]

instance Ditto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto for digital twin representation and device management"
    DTDFVocab:enables RealTimeMonitoringService, SimulationService, EnergyOptimizationService, VisualComfortAdjustmentService, HealthEffectManagementService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 for interactive 3D visualization"
    DTDFVocab:enables Interactive3DVisualizationService
]

instance MDEMethodologies : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering methodologies for automated transformation of BIM models"
    DTDFVocab:enables SimulationService, EnergyOptimizationService, VisualComfortAdjustmentService, HealthEffectManagementService
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring of building operations using sensor data"
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of building operations for predictive analysis"
    DTDFVocab:provides SimulationInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy consumption optimization"
    DTDFVocab:provides EnergyOptimizationInsight, AdjustHVACTemperatureAction
]

instance VisualComfortAdjustmentService : DTDFVocab:Service [
    base:desc "Adjustment of lighting and window blinds for optimal visual comfort"
    DTDFVocab:provides VisualComfortInsight, AdjustLightingIntensityAction, AdjustWindowBlindsAction
]

instance HealthEffectManagementService : DTDFVocab:Service [
    base:desc "Management of non-visual health effects through air quality monitoring and control"
    DTDFVocab:provides HealthEffectsInsight, AdjustVentilationAction
]

instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization of building assets using Unreal Engine 5"
    DTDFVocab:provides VisualizationInsight
]

instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time operational status and monitoring data for facility managers"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Predictive simulation results for building performance"
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics for energy consumption optimization"
]

instance VisualComfortInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics for optimal lighting levels and visual comfort"
]

instance HealthEffectsInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics for indoor air quality and health effects"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "3D visualization of building assets for interactive monitoring"
]

instance AdjustHVACTemperatureAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of HVAC temperature settings based on optimization algorithms"
    DTDFVocab:IsAutomatic true
]

instance AdjustLightingIntensityAction : DTDFVocab:Action [
    base:desc "Adjustment of lighting intensity for visual comfort optimization"
    DTDFVocab:IsAutomatic true
]

instance AdjustWindowBlindsAction : DTDFVocab:Action [
    base:desc "Control of window blinds for natural light management"
    DTDFVocab:IsAutomatic true
]

instance AdjustVentilationAction : DTDFVocab:Action [
    base:desc "Adjustment of ventilation systems based on CO2 and air quality data"
    DTDFVocab:IsAutomatic true
]

instance BOREALIS : DTDFVocab:Enabler [
    base:desc "Reinforcement learning framework for iterative control policy improvement"
    DTDFVocab:enables EnergyOptimizationService, VisualComfortAdjustmentService, HealthEffectManagementService
]

instance ModularServiceComponent : DTDFVocab:Component [
    base:desc "Modular service-oriented components for scalability via standardized extension points"
]

instance LivingLab : DTDFVocab:Environment [
    base:desc "Building infrastructure in AECO domain for real-time monitoring and optimization of building operations"
    base:contains TemperatureSensor, LightIntensitySensor, CO2ConcentrationSensor, HumiditySensor, OccupancySensor, HVACController, LightingController, WindowBlindsActuator, ModularServiceComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control signals generated by the DT sent to actuators in the BCS via Eclipse Hono and Ditto for real-time adjustment of building systems."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time synchronization for data exchange and service execution."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular system where BIM serves as the semantic backbone, integrated with Eclipse Hono and Ditto for real-time data exchange, Unreal Engine for visualization, and service-oriented extensions for monitoring, control, and optimization."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers all building life cycle stages from design, construction, operation, to refurbishments, with the case study focused on operational phase."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Measured using the Overall Digital Twin Entanglement (ODTE) metric to assess alignment with physical counterpart; synchronization techniques to prevent semantic drift over time."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono and Ditto for bidirectional real-time communication between physical assets and the DT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adherence to BIM standards as the semantic backbone; use of standardized extension points and model-driven engineering for consistent data schemas."
]