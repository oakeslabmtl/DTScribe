// ---------- Sensing Components ----------
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy sensor that captures occupancy status of the living lab space."
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnvironmentalParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that measures environmental parameters such as temperature, humidity, and CO₂ within the building."
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

instance EnergyParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor that records energy consumption parameters for lighting and HVAC systems."
    DTDFVocab:producedData EnergyDataTransmitted
]

// ---------- Acting Components ----------
instance DimmableLightingFixture : DTDFVocab:ActingComponent [
    base:desc "Dimmable lighting fixture controlled via BIM-defined controller units within the building automation system."
]

// ---------- Environment ----------
instance BuildingLivingLabEnvironment : DTDFVocab:Environment [
    base:contains OccupancySensor, EnvironmentalParameterSensor, EnergyParameterSensor, DimmableLightingFixture
]

// ---------- Data Transmitted ----------
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalParameterSensor
]

instance EnergyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyParameterSensor
]

// ---------- Data ----------
instance EnrichedIFCDataJSON : DTDFVocab:Data [
    base:desc "JSON representation of the enriched IFC BIM model used as input for the MDE pipeline."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance OccupancyTelemetryJSON : DTDFVocab:Data [
    base:desc "Structured JSON of real‑time occupancy telemetry transmitted from the sensor."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseHono
    DTDFVocab:inputTo DittoTwinUpdateEnabler
]

instance EnvironmentalTelemetryJSON : DTDFVocab:Data [
    base:desc "Structured JSON of real‑time environmental telemetry transmitted from the sensor."
    DTDFVocab:fromData EnvironmentalDataTransmitted
    DTDFVocab:inputTo EclipseHono
    DTDFVocab:inputTo DittoTwinUpdateEnabler
]

instance EnergyTelemetryJSON : DTDFVocab:Data [
    base:desc "Structured JSON of real‑time energy consumption telemetry transmitted from the sensor."
    DTDFVocab:fromData EnergyDataTransmitted
    DTDFVocab:inputTo EclipseHono
    DTDFVocab:inputTo DittoTwinUpdateEnabler
]

instance TwinMetadataJSON : DTDFVocab:Data [
    base:desc "JSON twin metadata generated by the MDE transformation service."
    DTDFVocab:inputTo EclipseDitto
]

instance ConfigScriptJSON : DTDFVocab:Data [
    base:desc "Configuration script for Eclipse Hono/Ditto generated by the MDE transformation service."
    DTDFVocab:inputTo EclipseHono
]

// ---------- Models ----------
instance IFCBIMModel : DTDFVocab:Model [
    base:desc "IFC-based BIM representation of the academic living lab building."
    DTDFVocab:inputTo ModelDrivenEngineeringPipeline
]

instance RLPolicyModel : DTDFVocab:Model [
    base:desc "Reinforcement learning policy model for predictive energy analytics."
    DTDFVocab:inputTo RLEngineEnabler
]

// ---------- Services ----------
instance HonoDataIngestionService : DTDFVocab:Service [
    base:desc "Handles ingestion of sensor telemetry via Eclipse Hono MQTT streams."
    DTDFVocab:provides DataIngestionAction
]

instance DittoTwinRegistryService : DTDFVocab:Service [
    base:desc "Registers and maintains device twins in Eclipse Ditto registry."
    DTDFVocab:provides TwinRegistryInsight
]

instance DittoTwinUpdateService : DTDFVocab:Service [
    base:desc "Updates properties of device twins in Eclipse Ditto based on incoming telemetry."
    DTDFVocab:provides TwinUpdateAction
]

instance MDETransformationService : DTDFVocab:Service [
    base:desc "Transforms enriched BIM data into executable DT artifacts (JSON twin metadata and configuration scripts)."
    DTDFVocab:provides ModelTransformationInsight
]

instance UnrealEngine5VisualizationService : DTDFVocab:Service [
    base:desc "Provides immersive 3D visualization of the building in Unreal Engine 5."
    DTDFVocab:provides VisualizeInUnrealAction
]

instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Continuous monitoring dashboard delivering real‑time energy consumption profiles and occupant comfort analysis."
    DTDFVocab:provides EnergyConsumptionProfileInsight
    DTDFVocab:provides OccupantComfortAnalysisInsight
]

instance BuildingEnvelopeSimulationService : DTDFVocab:Service [
    base:desc "Simulates the building envelope to assess thermal performance."
    DTDFVocab:provides BuildingEnvelopeSimulationInsight
]

instance PredictiveEnergyAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics engine powered by reinforcement learning for energy consumption forecasting."
    DTDFVocab:provides PredictiveMaintenanceAlertInsight
]

instance LightingScheduleOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes lighting schedules based on occupancy and environmental data."
    DTDFVocab:provides LightingScheduleOptimisationRecommendationInsight
]

// ---------- Actions ----------
instance DataIngestionAction : DTDFVocab:Action [
    base:desc "Automated ingestion of telemetry data into the DT platform."
    DTDFVocab:IsAutomatic true
]

instance TwinUpdateAction : DTDFVocab:Action [
    base:desc "Automated update of twin properties in response to sensor telemetry."
    DTDFVocab:IsAutomatic true
]

instance VisualizeInUnrealAction : DTDFVocab:Action [
    base:desc "Triggers immersive visualization of the living lab building in Unreal Engine 5."
    DTDFVocab:IsAutomatic false
]

instance AdjustLightingScheduleAction : DTDFVocab:Action [
    base:desc "Automatically adjusts dimmable lighting fixtures to the optimized schedule."
    DTDFVocab:IsAutomatic true
]

// ---------- Insights ----------
instance EnergyConsumptionProfileInsight : DTDFVocab:Insight [
    base:desc "Real‑time energy consumption profiles derived from sensor telemetry."
]

instance OccupantComfortAnalysisInsight : DTDFVocab:Insight [
    base:desc "Analysis of occupant comfort based on environmental parameter telemetry."
]

instance LightingScheduleOptimisationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for lighting schedule optimization derived from reinforcement learning."
]

instance PredictiveMaintenanceAlertInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance alerts generated by the reinforcement learning analytics engine."
]

instance BuildingEnvelopeSimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation insight on thermal performance of the building envelope."
]

instance TwinRegistryInsight : DTDFVocab:Insight [
    base:desc "Insight into the health and status of the device twin registry."
]

instance ModelTransformationInsight : DTDFVocab:Insight [
    base:desc "Insight on the quality and fidelity of the BIM-to-JSON model transformation."
]

// ---------- Enablers ----------
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono IoT gateway for real‑time telemetry ingestion."
    DTDFVocab:enables HonoDataIngestionService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin registry for registering and updating device twins."
    DTDFVocab:enables DittoTwinRegistryService, DittoTwinUpdateService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 3D visualization engine for immersive building representation."
    DTDFVocab:enables UnrealEngine5VisualizationService
]

instance ModelDrivenEngineeringPipeline : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering pipeline that translates enriched BIM into executable DT artifacts."
    DTDFVocab:enables MDETransformationService
]

instance RLEngineEnabler : DTDFVocab:Enabler [
    base:desc "Reinforcement learning engine for predictive energy analytics."
    DTDFVocab:enables PredictiveEnergyAnalyticsService
]

instance MonitoringDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the continuous monitoring dashboard service."
    DTDFVocab:enables MonitoringDashboardService
]

instance BuildingEnvelopeSimEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the building envelope simulation service."
    DTDFVocab:enables BuildingEnvelopeSimulationService
]

instance LightingOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the lighting schedule optimization service."
    DTDFVocab:enables LightingScheduleOptimizationService
]

instance DittoTwinUpdateEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that triggers twin property updates in Eclipse Ditto."
    DTDFVocab:enables DittoTwinUpdateService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT are written as twin updates in Eclipse Ditto, then propagated via Hono to the target devices. The physical actuators receive the command payloads (e.g., brightness adjustment, HVAC setpoint) and execute the prescribed actions."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Operational data is synchronized in real‑time with low‑latency update cycles; control loops (e.g., lighting, HVAC) execute on minute‑scale intervals while sensor sampling may be faster. The DT processes events as they arrive without batching beyond the Hono middleware limits."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A central orchestrator comprising Hono, Ditto, and the synthesized runtime services, linking the virtual twin ecosystem to the physical building. Device twins are exposed via Ditto, analytics services consume these twins, and visualization clients render the model in Unreal Engine."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design‑time BIM modeling, construction‑time as‑built BIM capture, post‑construction operational monitoring, and runtime optimization during building operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric quantifies how closely the virtual state mirrors the physical counterpart. Semantic drift is monitored by comparing model‑derived expectations against live sensor readings; discrepancies trigger re‑validation of the BIM model or retraining of control policies."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical devices publish telemetry and receive commands via Eclipse Hono, which bridges device protocols to the Ditto event bus. Ditto exposes device twins through a RESTful API for the DT’s consumption. The exact transport protocols are encapsulated by Hono and are not explicitly detailed in the documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "BIM (IFC) serves as the canonical modeling standard; Hono/Ditto provide interoperability via IoT‑standard event messaging. The MDE transformation pipeline enforces consistent semantic mapping across the asset life cycle."
]