instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring and insights for infrastructure management"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive visualization interfaces for infrastructure monitoring and control"
]

instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Predictive insights for infrastructure maintenance and performance"
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized operational strategies for infrastructure"
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation results for scenario analysis and planning"
]

instance RealTimeInsightsService : DTDFVocab:Service [
    base:desc "Real-time insights for data-driven infrastructure management in AECO domain"
    DTDFVocab:provides RealTimeInsight, VisualizationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for infrastructure management"
    DTDFVocab:provides PredictiveInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization capabilities for infrastructure management"
    DTDFVocab:provides OptimizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation capabilities for infrastructure management"
    DTDFVocab:provides SimulationInsight
]

instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Real-time data exchange between physical buildings and digital twins using MQTT protocol and HTTP APIs"
    DTDFVocab:enables RealTimeInsightsService, PredictiveAnalyticsService, OptimizationService, SimulationService
]

instance Ditto : DTDFVocab:Enabler [
    base:desc "Digital Twin integration platform for managing digital twins and their attributes"
    DTDFVocab:enables RealTimeInsightsService, PredictiveAnalyticsService, OptimizationService, SimulationService
]

instance UnrealEngine : DTDFVocab:Enabler [
    base:desc "Interactive visualization platform for immersive monitoring and control of physical infrastructure"
    DTDFVocab:enables RealTimeInsightsService
]

instance MDETransformation : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering process for transforming enriched BIM models into structured digital artifacts for deployable DT components"
]

instance DTFramework : DTDFVocab:Enabler [
    base:desc "Centralized coordination hub for modular DT architecture with standardized extension points for custom services"
    DTDFVocab:enables RealTimeInsightsService, PredictiveAnalyticsService, OptimizationService, SimulationService
]

instance BIMModel : DTDFVocab:Model [
    base:desc "Enriched Building Information Modeling structure with semantic representations of BCS components"
    DTDFVocab:inputTo MDETransformation
]

instance GeometricModel : DTDFVocab:Model [
    base:desc "Geometric modeling for spatial layout of building infrastructure"
    DTDFVocab:inputTo UnrealEngine
]

instance BehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral modeling for control logic of building systems"
    DTDFVocab:inputTo EclipseHono
]

instance AnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical models for operational analytics via modular custom services"
    DTDFVocab:inputTo DTFramework
]

instance BcsSensor : DTDFVocab:SensingComponent [
    base:desc "Sensors within Building Control System components for monitoring physical infrastructure"
    DTDFVocab:producedData RealTimeSensorData
]

instance BcsActuator : DTDFVocab:ActingComponent [
    base:desc "Actuators within Building Control System components for controlling physical infrastructure"
]

instance BcsController : DTDFVocab:ActingComponent [
    base:desc "Controllers within Building Control System components for managing building systems"
]

instance RealTimeSensorData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BcsSensor
]

instance RealTimeData : DTDFVocab:Data [
    base:desc "Live operational data from physical building systems"
    DTDFVocab:fromData RealTimeSensorData
]

instance BuildingControlEngineer : DTDFVocab:Component [
    base:desc "Role for device modeling and deployment in modular DT architecture"
]

instance FacilityManager : DTDFVocab:Component [
    base:desc "Role for real-time monitoring and control in modular DT architecture"
]

instance DTEngineer : DTDFVocab:Component [
    base:desc "Role for service integration in modular DT architecture"
]

instance DTFrameworkComponent : DTDFVocab:Component [
    base:desc "Centralized coordination hub for modular DT architecture"
]

instance BuildingInfrastructure : DTDFVocab:DigitalTwin [
    base:desc "Infrastructure assets in the Architecture, Engineering, Construction, and Operations (AECO) domain represented as virtual models integrating static models with runtime data for simulation, analysis, and optimization throughout the building lifecycle"
    base:contains BuildingControlEngineer, FacilityManager, DTEngineer, DTFrameworkComponent, BcsSensor, BcsActuator, BcsController, BIMModel, GeometricModel, BehavioralModel, AnalyticalModel, RealTimeData, EclipseHono, Ditto, UnrealEngine, MDETransformation, DTFramework, RealTimeInsightsService, PredictiveAnalyticsService, OptimizationService, SimulationService, RealTimeInsight, VisualizationInsight, PredictiveInsight, OptimizationInsight, SimulationInsight
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The framework facilitates bidirectional communication between virtual and physical assets by feeding control signals back to the Building Control System (BCS)."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real-time data exchange capabilities ensuring continuous synchronization between physical buildings and their digital counterparts"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized DT Framework orchestrating components through modular architecture and standardized extension points, facilitating bidirectional data exchange and holistic building lifecycle management via runtime configuration management"
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle encompasses initial device modeling in BIM where Building Control Engineers define sensors, actuators, and controllers to establish a unified semantic foundation; Model-Driven Engineering (MDE) transformation to extract structured representations and automatically generate deployable DT artifacts; runtime operation with real-time data exchange for synchronization between physical and digital twins, interactive visualization for monitoring and control; and modular integration of custom services and analytics via standardized extension points for evolving operational needs. Lifecycle transitions are automated with minimal manual intervention, and governance is managed through role-based responsibilities of Building Control Engineers, Facility Managers, and DT Engineers."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The framework integrates Eclipse Hono and Ditto for real-time data exchange and utilizes relevant middleware metadata for Hono and Ditto."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Nonfunctional requirements (NF_X) address interoperability across heterogeneous systems to ensure compatibility and data exchange between disparate technologies and platforms."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Compliance with AECO-specific standards including Building Information Modeling (BIM) for semantic modeling, and implementation of standardized extension points to ensure interoperability and service integration within the Digital Twin framework."
]