// C1: Environment
instance CommercialBuildingAsset : DTDFVocab:Environment [
    base:contains StructuralComponent, HVACComponent, ElectricalComponent, LightingComponent, ControlSubsystemComponent
]

// C3: Components
instance StructuralComponent : DTDFVocab:Component [
    base:desc "Structural elements of the commercial building."
]
instance HVACComponent : DTDFVocab:Component [
    base:desc "HVAC subsystems."
]
instance ElectricalComponent : DTDFVocab:Component [
    base:desc "Electrical distribution system."
]
instance ControlSubsystemComponent : DTDFVocab:Component [
    base:desc "Control subsystems for building automation."
]
instance LightingComponent : DTDFVocab:Component [
    base:desc "Lighting subsystem of the building."
    base:contains LightTwinComponent
]

// C2: Acting Components
instance LightTwinComponent : DTDFVocab:ActingComponent [
    base:desc "Represents and controls lighting fixtures defined in the BIM. Receives control commands (on/off, brightness, colour‑temperature) via UE5 Delegates and forwards them to the corresponding physical device through the DittoController."
]

// C3: Physical sensing components
instance PhysicalDeviceSensor : DTDFVocab:SensingComponent [
    base:desc "Physical device sensor collecting real‑time telemetry data from building equipment."
    DTDFVocab:producedData PhysicalDeviceTelemetryTransmitted
]
instance BIMMetadataExtractor : DTDFVocab:SensingComponent [
    base:desc "Extracts enriched BIM metadata for all BCS components during the model‑driven transformation pipeline."
    DTDFVocab:producedData BIMDeviceMetadataTransmitted
]

// C4: Physical-to-virtual interaction
instance PhysicalDeviceTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalDeviceSensor
]
instance BIMDeviceMetadataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BIMMetadataExtractor
]
instance LightingCommandTransmitted : DTDFVocab:DataTransmitted [
]

// C10: Data and Models
instance PhysicalDeviceTelemetryData : DTDFVocab:Data [
    base:desc "Runtime telemetry data from building devices delivered via Eclipse Hono (at‑least‑once) and persisted in Eclipse Ditto."
    DTDFVocab:fromData PhysicalDeviceTelemetryTransmitted
    DTDFVocab:inputTo RealtimeDataExchangeEnabler
]
instance BIMDeviceMetadataData : DTDFVocab:Data [
    base:desc "Semantically annotated BIM metadata extracted via the MDE pipeline."
    DTDFVocab:fromData BIMDeviceMetadataTransmitted
    DTDFVocab:inputTo BIMExtractionEnabler
]
instance LightingCommandData : DTDFVocab:Data [
    base:desc "Control command to lighting fixtures encoded via Ditto and sent through Hono."
    DTDFVocab:fromData LightingCommandTransmitted
    DTDFVocab:inputTo DittoCommandEnabler
]
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Enriched BIM mesh rendered by UE5 via LightTwinComponent translating Revit photometric values to UE5 light primitives."
    DTDFVocab:inputTo UE5RendererEnabler
]
instance UE5BehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model implemented as UE5 TwinComponents observing device values and exposing control commands through an Observer pattern."
    DTDFVocab:inputTo UE5ObserverEnabler
]
instance DittoAnalyticalModel : DTDFVocab:Model [
    base:desc "Runtime state stored in Eclipse Ditto, enforcing value ranges, units, and safety pre‑execution checks via user‑defined policies."
    DTDFVocab:inputTo DittoRuntimeEnabler
]

// C11: Enablers
instance RealtimeDataExchangeEnabler : DTDFVocab:Enabler [
    base:desc "Handles real‑time data exchange between physical devices and the digital twin using Eclipse Hono and ensures continuous synchronization."
    DTDFVocab:enables RealTimeMonitoringService, EnergyOptimizationService
]
instance BIMExtractionEnabler : DTDFVocab:Enabler [
    base:desc "Transforms enriched BIM models into structured twin artefacts (geometric, behavioral, analytical)."
    DTDFVocab:enables ModelGenerationService
]
instance DittoCommandEnabler : DTDFVocab:Enabler [
    base:desc "Relays control commands via Eclipse Ditto to physical devices, ensuring policy enforcement and safety constraints."
    DTDFVocab:enables AutomaticControlIntegrationService
]
instance UE5RendererEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for rendering geometric model in UE5."
    DTDFVocab:enables Interactive3DVisualizationService
]
instance UE5ObserverEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for UE5 TwinComponents observer pattern."
    DTDFVocab:enables AutomaticControlIntegrationService
]
instance DittoRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for analytical model in Eclipse Ditto, handling policy enforcement."
    DTDFVocab:enables PredictiveAnalyticsService, EnergyOptimizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of building state, providing live updates to Facility Managers and Building Control Engineers."
    DTDFVocab:provides BuildingStateInsight
]
instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes energy and operational performance of building systems."
    DTDFVocab:provides EnergyConsumptionInsight
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for condition and fault detection."
    DTDFVocab:provides FaultDetectionInsight, ConditionHealthInsight
]
instance AutomaticControlIntegrationService : DTDFVocab:Service [
    base:desc "Automatic control integration for building systems, enabling seamless command issuance."
    DTDFVocab:provides ControlLightingAction, ControlHVACAction
]
instance Interactive3DVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization using UE5, allowing immersive stakeholder engagement."
    DTDFVocab:provides VisualizationInsight
]
instance ModelGenerationService : DTDFVocab:Service [
    base:desc "Service to generate geometric, behavioral, and analytical models from enriched BIM metadata."
    DTDFVocab:provides ModelInsight
]

// C17: Insights
instance BuildingStateInsight : DTDFVocab:Insight [
    base:desc "Insight into current building operational state derived from live telemetry."
]
instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Insight into energy consumption patterns and opportunities for optimization."
]
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight identifying faults in building systems based on predictive analytics."
]
instance ConditionHealthInsight : DTDFVocab:Insight [
    base:desc "Insight into the health condition of building components."
]
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight presented via interactive 3D visualization."
]
instance ModelInsight : DTDFVocab:Insight [
    base:desc "Insight into the coverage and completeness of generated twin models."
]

// C17: Actions
instance ControlLightingAction : DTDFVocab:Action [
    base:desc "Command to adjust lighting fixtures (on/off, brightness, colour temperature)."
    DTDFVocab:IsAutomatic true
]
instance ControlHVACAction : DTDFVocab:Action [
    base:desc "Command to adjust HVAC system parameters for energy optimization."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Digital control flows to physical assets are routed through the same bidirectional framework that handles data exchange. Facility Managers can initiate control actions via an interactive visualization interface, and Device Engineers can extend command capabilities through service integration. The documents do not specify the command formats, authentication or validation procedures, feedback mechanisms, conflict resolution strategies, or execution‑confirmation protocols used in the control path."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange capabilities ensure continuous synchronization between the physical building and its digital twin, enabling an up‑to‑date representation of the system state. The architecture supports low‑latency bidirectional communication, suitable for operational control and predictive analytics; however, explicit synchronization frequencies, latency thresholds, and temporal granularity are not specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin system follows a modular, service‑oriented architecture where a central DT Framework hub coordinates enriched BIM models, runtime data, and extensions. Components include device modeling workflows executed by Building Control Engineers, real‑time monitoring interfaces used by Facility Managers, and extensible services added by DT Engineers. Runtime configuration management allows dynamic adaptation of the system without full redeployment, while standardized extension points and a centralized bidirectional data bus facilitate orchestration and resource management across the digital twin ecosystem."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Device modeling and enrichment within BIM (Defining sensors, actuators, controllers), MDE‑based extraction of structured artefacts, automated generation of deployable Digital Twin components, deployment to runtime with real‑time bidirectional data exchange, immersive visualization, and subsequent customization via modular extension points. Transition management is achieved through automated transformation pipelines, while lifecycle governance is enforced by the framework’s standardized extension points and minimal manual intervention."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through policy‑based validation in Eclipse Ditto, which enforces sensor data to respect predefined value ranges and units, and pre‑execution checks that prevent unsafe actuator commands.  Runtime fault tolerance is provided by Hono’s at‑least‑once message delivery, which guarantees that no event is lost even in the face of network failures, and Ditto’s persistent event storage, which allows state recovery and replay.  Symptom checks for actuator conflicts and safety violations are performed before command execution, thus providing a basic error detection and correction mechanism.  No explicit quantitative uncertainty bounds or verification procedures are detailed in the cited documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT framework is architected to be interoperable with heterogeneous systems, providing real‑time bidirectional communication between physical and digital entities. The documents do not enumerate the underlying network protocols, topology, bandwidth, latency, reliability, redundancy, or security mechanisms, but assert that runtime configuration management allows adaptation of network parameters without full redeployment."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosting specifics are not described; the framework's modular architecture and runtime configuration suggest flexibility for deployment on cloud, edge, or on‑premise platforms. Computational and storage requirements, scalability strategies, supported deployment models, and availability or reliability guarantees are not provided in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The framework achieves interoperability with heterogeneous systems through standardized extension points and real‑time data exchange protocols (details unspecified). It integrates enriched BIM models from conventional Building Information Modeling tools and supports bidirectional communication with external subsystems such as building automation controllers and enterprise resource planning (ERP) systems. The architecture is designed to accommodate additional digital twins and enterprise services via modular interfaces, ensuring seamless data flow across the building lifecycle."
]