// C3: Physical sensing components
instance BuildingBIMSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor defined in the BIM model as a first‑class object, annotated with location, tenant and device ID."
    DTDFVocab:producedData BuildingSensorDataTransmitted
]

// C4: Physical-to-virtual interaction
instance BuildingSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingBIMSensor
]

// C11: Data
instance BuildingSensorData : DTDFVocab:Data [
    base:desc "Real‑time measurements streamed from the physical building sensor."
    DTDFVocab:fromData BuildingSensorDataTransmitted
    DTDFVocab:inputTo EclipseHonoEnabler, EclipseDittoEnabler, DeploymentFrameworkEnabler
]

// C10: Models/Data (BIM model)
instance EnrichedBIMGeometricModel : DTDFVocab:Model [
    base:desc "BIM geometric model enriched with device definitions (sensors, actuators, controllers) serving as the unified semantic foundation."
    DTDFVocab:inputTo MDEEngineEnabler, DeploymentFrameworkEnabler
]

// C6: Enablers
instance MDEEngineEnabler : DTDFVocab:Enabler [
    base:desc "Model‑Driven Engineering engine that extracts domain semantics from enriched BIM models and synthesises DT runtime interfaces."
    DTDFVocab:enables ModelExtractionService
]

instance EclipseHonoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Hono component that receives real‑time sensor streams and forwards them into the twin platform."
    DTDFVocab:enables RealTimeIngestionService
]

instance EclipseDittoEnabler : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto component that synchronises incoming measurements with the digital twin state."
    DTDFVocab:enables TwinSynchronizationService
]

instance DeploymentFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Deployment framework that packages extracted models and services, manages addressing of actuator instances and orchestrates runtime execution."
    DTDFVocab:enables RealTimeMonitoringService, BuildingSimulationService, PredictiveAnalyticsService,
               EnergyOptimizationService, DecisionSupportVisualizationService, CollaborativeLifecycleService,
               RemoteActuationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides continuous monitoring of sensor and operational data."
    DTDFVocab:provides RealTimeMonitoringInsight
]

instance BuildingSimulationService : DTDFVocab:Service [
    base:desc "Simulates building behaviour based on the BIM‑derived model."
    DTDFVocab:provides BuildingSimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Performs predictive analytics to forecast building performance."
    DTDFVocab:provides PerformanceForecastInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimises energy and resource use across the building life‑cycle."
    DTDFVocab:provides EnergyOptimizationInsight
]

instance DecisionSupportVisualizationService : DTDFVocab:Service [
    base:desc "Delivers decision‑support visualisations for stakeholders."
    DTDFVocab:provides StakeholderVisualizationInsight
]

instance CollaborativeLifecycleService : DTDFVocab:Service [
    base:desc "Provides collaborative tools that span design, construction, operation and refurbishment."
    DTDFVocab:provides LifecycleCollaborationInsight
]

instance RemoteActuationService : DTDFVocab:Service [
    base:desc "Enables Facility Manager to remotely operate physical actuators via the digital twin interface."
    DTDFVocab:provides ActuationCommandAction
]

instance ModelExtractionService : DTDFVocab:Service [
    base:desc "Generates runtime artefacts from the enriched BIM model using MDE techniques."
    DTDFVocab:provides ModelExtractionInsight
]

instance RealTimeIngestionService : DTDFVocab:Service [
    base:desc "Handles ingestion of continuous sensor streams from Eclipse Hono."
    DTDFVocab:provides IngestionInsight
]

instance TwinSynchronizationService : DTDFVocab:Service [
    base:desc "Synchronises incoming data with the twin state in Eclipse Ditto."
    DTDFVocab:provides SynchronizationInsight
]

// C17: Insights
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight derived from live sensor streams indicating current building conditions."
]

instance BuildingSimulationInsight : DTDFVocab:Insight [
    base:desc "Insight from simulation describing predicted physical states under given scenarios."
]

instance PerformanceForecastInsight : DTDFVocab:Insight [
    base:desc "Forecast of future performance metrics based on predictive analytics."
]

instance EnergyOptimizationInsight : DTDFVocab:Insight [
    base:desc "Recommendations for optimal energy and resource usage."
]

instance StakeholderVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representations tailored for stakeholder decision‑making."
]

instance LifecycleCollaborationInsight : DTDFVocab:Insight [
    base:desc "Collaborative view integrating data across the building life‑cycle stages."
]

instance ModelExtractionInsight : DTDFVocab:Insight [
    base:desc "Verification that the extracted model conforms to the BIM schema."
]

instance IngestionInsight : DTDFVocab:Insight [
    base:desc "Status of real‑time data ingestion pipeline."
]

instance SynchronizationInsight : DTDFVocab:Insight [
    base:desc "Confirmation that twin state reflects the latest physical measurements."
]

instance ActuationCommandAction : DTDFVocab:Action [
    base:desc "Remote actuation command issued to a physical actuator via the digital twin."
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance BIMActuator : DTDFVocab:ActingComponent [
    base:desc "Physical actuator modeled as a component within the BIM model and configured by the Building Control Engineer; remotely operated via the DT runtime by the Facility Manager."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT Framework enables bidirectional data exchange, allowing Facility Managers to issue real‑time monitoring and control commands from the digital twin to the physical building infrastructure. Commands are transmitted via the same modular, configurable runtime, but the document does not detail command formats, validation, authentication, feedback systems, conflict resolution, or execution confirmation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The platform provides continuous, real‑time synchronization between the physical asset and its digital counterpart. Sensor data are ingested via Eclipse Hono and immediately propagated to the Eclipse Ditto twin, enabling live synchronization with low latency (exact latency not quantified). This supports services that require up‑to‑date state such as simulation, analysis and optimization, thus operating on a real‑time time scale."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a central‑hub architecture where the DT Framework acts as the core orchestrator. It exposes standardized extension points for modular service integration, mediates bidirectional data exchange, and centrally manages resources. Eclipse Hono provides device connectivity and telemetry ingestion, while Eclipse Ditto supplies the twin management layer; together they form an orchestrated constellation of components integrated through the DT Framework."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The framework defines a four‑stage life‑cycle for a building Digital Twin: (1) **Device Modeling** – Building Control Engineers enrich BIM models with explicit sensor, actuator and controller entities, creating a semantically‑rich BIM representation; (2) **Model Transformation** – Model‑Driven Engineering (MDE) extracts a platform‑independent structured representation (e.g., domain‑specific metamodel) from the enriched BIM and automatically generates deployable DT artifacts; (3) **Deployment & Runtime** – The generated artifacts are instantiated as a live Twin, with real‑time data exchange synchronising physical devices and the digital counterpart; (4) **Operation & Evolution** – Facility Managers monitor and control the system via interactive visualisation, while DT Engineers add custom services through standardized extension points. Transition between stages is automated by the model‑driven pipeline, and governance is enforced through role‑based responsibilities (Control Engineer, Facility Manager, DT Engineer) and the functional‑requirement checklist (Table III)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed using the Overall Digital Twin Entanglement (ODTE) metric, which quantifies the degree of alignment between the enriched BIM model and the physical system. Prior to deployment, models undergo a validation step (referencing prior work [65]) to ensure correctness; only validated models are passed to the Hono/Ditto configurator. Model‑driven engineering contributes to governance by enforcing compliance, encouraging reuse, and supporting quality‑assurance processes throughout the DT lifecycle."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection is described as a modular architecture with standardized extension points and runtime configuration, supporting interoperability across heterogeneous systems, scalability, maintainability, and accessibility (NF_X). No concrete communication protocols, network topology, bandwidth, latency, redundancy mechanisms, or security protocols are enumerated in the document."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration is achieved through interoperability standards with external BIM environments. The DT framework consumes and produces Building Information Modeling data using standard formats (e.g., IFC) and offers generic APIs for bidirectional communication with enterprise systems, allowing the twin to be linked to other digital twins or operational management platforms without specifying particular transport protocols."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The approach is grounded in the Building Information Modeling (BIM) standard, using BIM as the primary source of semantic data for device definition and control logic. The framework adopts standardized extension points for plug‑in integration, providing a consistent interface for extending functionality. No additional industry specifications, certification schemes, or interoperability standards are explicitly cited in the document."
]