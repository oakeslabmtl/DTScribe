import DTDFVocab from "https://w3id.org/DTDFVocab"
instance BuildingTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Real-time temperature sensor monitoring building environment",
    DTDFVocab:producedData TemperatureDataTransmitted
]
instance BuildingHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Real-time humidity sensor monitoring building environment",
    DTDFVocab:producedData HumidityDataTransmitted
]
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingTemperatureSensor
]
instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingHumiditySensor
]
instance TemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature readings from building sensors",
    DTDFVocab:fromData TemperatureDataTransmitted,
    DTDFVocab:inputTo MonitoringEnabler, AnalyticsEnabler
]
instance HumidityData : DTDFVocab:Data [
    base:desc "Real-time humidity readings from building sensors",
    DTDFVocab:fromData HumidityDataTransmitted,
    DTDFVocab:inputTo MonitoringEnabler, AnalyticsEnabler
]
instance SensorDefinition : DTDFVocab:Data [
    base:desc "BIM-enriched sensor definitions containing metadata for building sensors",
    DTDFVocab:inputTo BIMEnabler
]
instance ActuatorDefinition : DTDFVocab:Data [
    base:desc "BIM-enriched actuator definitions containing metadata for building actuators",
    DTDFVocab:inputTo BIMEnabler
]
instance ControllerDefinition : DTDFVocab:Data [
    base:desc "BIM-enriched controller definitions containing metadata for building controllers",
    DTDFVocab:inputTo BIMEnabler
]
instance BIMGeometricModel : DTDFVocab:Model [
    base:desc "Geometric model derived from Building Information Modeling (BIM) for spatial representation",
    DTDFVocab:inputTo BIMEnabler
]
instance ControlLogicBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral model defined via control logic by Building Control Engineers",
    DTDFVocab:inputTo AnalyticsEnabler
]
instance CustomServicesAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical model integrated through custom services developed by DT Engineers",
    DTDFVocab:inputTo AnalyticsEnabler
]
instance BIMEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for BIM-based geometric models and sensor definitions",
    DTDFVocab:enables VisualizationService
]
instance AnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for custom analytics services",
    DTDFVocab:enables AnalyticsService, RealTimeMonitoringService, OptimizationService, DecisionSupportService
]
instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for real-time monitoring services",
    DTDFVocab:enables RealTimeMonitoringService
]
instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for operational efficiency optimization services",
    DTDFVocab:enables OptimizationService
]
instance DecisionSupportEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for decision-making support services",
    DTDFVocab:enables DecisionSupportService
]
instance MDEEnabler : DTDFVocab:Enabler [
    base:desc "Model-Driven Engineering enabler for extracting structured representations and generating deployable DT artifacts",
    DTDFVocab:enables AnalyticsService
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Interactive visualization service providing immersive interfaces for Facility Managers to monitor and control operations",
    DTDFVocab:provides VisualizationInsight
]
instance AnalyticsService : DTDFVocab:Service [
    base:desc "Custom analytics service integrated via standardized extension points for predictive maintenance and performance forecasting",
    DTDFVocab:provides PredictiveMaintenanceInsight
]
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real-time monitoring service providing data-driven insights for facility operations",
    DTDFVocab:provides RealTimeMonitoringInsight
]
instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service for operational efficiency and resource management",
    DTDFVocab:provides OperationalEfficiencyInsight
]
instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Enhanced decision-making service for AECO stakeholders",
    DTDFVocab:provides DecisionSupportInsight
]
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time visualization of building operations for Facility Managers"
]
instance PredictiveMaintenanceInsight : DTDFVocab:Insight [
    base:desc "Predictive insights for maintenance and performance forecasting"
]
instance RealTimeMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring insights for facility operations"
]
instance OperationalEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Insights for optimizing operational efficiency"
]
instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Enhanced decision-making capabilities for infrastructure management"
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The framework utilizes Building Information Modeling (BIM) standards and Model-Driven Engineering (MDE) principles, with standardized extension points for interoperability and custom service integration. Specific industry standards, compliance frameworks, or certifications beyond BIM and MDE are not detailed in the provided documents."
]