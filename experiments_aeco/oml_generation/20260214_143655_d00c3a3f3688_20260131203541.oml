    base:desc "Performance evaluation insights from simulations supporting clash detection and optimization"
]

instance LifeCycleCostModel : DTDFVocab:Insight [
    base:desc "Life-cycle cost modeling derived from operational data for facility management decisions"
]

instance OperationalEfficiencyMetrics : DTDFVocab:Insight [
    base:desc "Operational efficiency metrics derived from real-time monitoring and analytics"
]

instance AutomatedClashDetection : DTDFVocab:Action [
    base:desc "Automated workflow for clash detection during design coordination"
    DTDFVocab:IsAutomatic true
]

instance RealTimeDashboard : DTDFVocab:Action [
    base:desc "Real-time dashboard interface for facility managers and AECO professionals"
    DTDFVocab:IsAutomatic false
]

instance PredictiveMaintenanceAlert : DTDFVocab:Action [
    base:desc "AI-driven predictive maintenance alerts based on operational data trends"
    DTDFVocab:IsAutomatic true
]

RealTimeMonitoringService DTDFVocab:provides RealTimeOperationalInsights
RealTimeMonitoringService DTDFVocab:provides OperationalEfficiencyMetrics

SimulationService DTDFVocab:provides PerformanceValidationInsights
SimulationService DTDFVocab:provides LifeCycleCostModel

ScalableServiceDeploymentService DTDFVocab:provides AutomatedClashDetection
ScalableServiceDeploymentService DTDFVocab:provides RealTimeDashboard

PredictiveAnalyticsService DTDFVocab:provides PredictiveMaintenanceAlert

// C15: Environment Components
instance AECOInfrastructureEnvironment : DTDFVocab:Environment [
    base:contains BIMPhysicalAssetModel,
            ControlLogicModel,
            PerformanceSimulationModel,
            LightingActuator,
            HVACActuator,
            SafetyConstraintEnforcer,
            OccupancySensor,
            EnvironmentalParameterSensor,
            SpatialContextSensor,
            TenantSpecificDeviceSensor
]

