// C2: Acting Components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Generic BCS (Building Control System) components for lighting systems in TwinLight, modeled as configurable actuators enabling dynamic adjustments to operational parameters via MDE-extracted control semantics"
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "Building Control System actuator components for HVAC systems, governed by MDE-extracted control semantics with real-time remote activation via standardized interfaces (e.g., Ditto's API)"
]

instance SafetyConstraintEnforcer : DTDFVocab:ActingComponent [
    base:desc "Implicitly enforced through BIM's static validation rules and MDE's runtime checks, ensuring compliance with operational limits (e.g., lighting intensity thresholds)"
]

// C3: Physical sensing components
instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Post-occupancy sensor for occupancy detection, modeled within BIM by Building Control Engineers with tenant-specific IDs embedded in metadata"
    DTDFVocab:producedData OccupancyDataTransmitted
]

instance EnvironmentalParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor for environmental parameters (e.g., temperature, humidity) capturing real-time telemetry via BIM-enriched models"
    DTDFVocab:producedData EnvironmentalParameterDataTransmitted
]

instance SpatialContextSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing spatial metadata (e.g., device IDs, spatial coordinates) automatically extracted during MDE transformation"
    DTDFVocab:producedData SpatialContextDataTransmitted
]

instance TenantSpecificDeviceSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing tenant-specific device endpoints for precise control coordination within BIM models"
    DTDFVocab:producedData TenantSpecificDataTransmitted
]

