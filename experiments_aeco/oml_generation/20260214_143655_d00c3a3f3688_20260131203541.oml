instance BIMPhysicalAssetModel : DTDFVocab:Model [
    base:desc "3D spatial and functional BIM models representing building components and their interrelationships for collaborative design coordination"
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Behavioral models implementing sensor-actuator mappings and real-time decision-making algorithms via MDE-driven transformations"
]

instance PerformanceSimulationModel : DTDFVocab:Model [
    base:desc "Analytical models extracted from BIM for performance simulation, clash detection, and documentation generation"
]

instance RealTimeSynchronizationData : DTDFVocab:Data [
    base:desc "Continuously updated operational parameters derived from physical systems for real-time synchronization between physical assets and digital twins"
]

instance OperationalParameterData : DTDFVocab:Data [
    base:desc "Structured data extracted through MDE for deployable DT artifacts ensuring consistency across life-cycle stages"
]

instance SpatialMetadataData : DTDFVocab:Data [
    base:desc "Metadata capturing sensor IDs, spatial coordinates, and contextual relevance automatically extracted during MDE transformations"
]

instance ControlParameterData : DTDFVocab:Data [
    base:desc "Dynamic operational parameters for actuator control with embedded tenant-specific addressing mechanisms"
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Real-time data synchronization protocol enabling bidirectional communication between physical assets and digital twins"
]

instance DittoFramework : DTDFVocab:Enabler [
    base:desc "Framework for DT runtime orchestration supporting scalable service deployment and interoperability"
]

instance ModelDrivenDeploymentFramework : DTDFVocab:Enabler [
    base:desc "Automated processes reducing manual intervention for reproducible DT setups via Design Science Research methodologies"
]

instance UnrealEngine : DTDFVocab:Enabler [
    base:desc "Visualization engine for creating interactive high-fidelity 3D digital twin visualizations"
]

instance BIMIntegrationFramework : DTDFVocab:Enabler [
    base:desc "Framework leveraging BIM models as semantic backbone for digital twin construction with IFC interoperability"
]

// C12: Data Flow Connections
instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance EnvironmentalParameterDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalParameterSensor
]

instance SpatialContextDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SpatialContextSensor
]

instance TenantSpecificDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TenantSpecificDeviceSensor
]

RealTimeSynchronizationData DTDFVocab:fromData OccupancyDataTransmitted
RealTimeSynchronizationData DTDFVocab:fromData EnvironmentalParameterDataTransmitted
RealTimeSynchronizationData DTDFVocab:fromData SpatialContextDataTransmitted
RealTimeSynchronizationData DTDFVocab:fromData TenantSpecificDataTransmitted

OperationalParameterData DTDFVocab:fromData OccupancyDataTransmitted
OperationalParameterData DTDFVocab:fromData EnvironmentalParameterDataTransmitted
OperationalParameterData DTDFVocab:fromData SpatialContextDataTransmitted
OperationalParameterData DTDFVocab:fromData TenantSpecificDataTransmitted

SpatialMetadataData DTDFVocab:fromData SpatialContextDataTransmitted

// C13: Model/Enabler Connections
BIMPhysicalAssetModel DTDFVocab:inputTo EclipseHono
BIMPhysicalAssetModel DTDFVocab:inputTo DittoFramework
BIMPhysicalAssetModel DTDFVocab:inputTo ModelDrivenDeploymentFramework

ControlLogicModel DTDFVocab:inputTo EclipseHono
ControlLogicModel DTDFVocab:inputTo DittoFramework
ControlLogicModel DTDFVocab:inputTo UnrealEngine

PerformanceSimulationModel DTDFVocab:inputTo BIMIntegrationFramework
PerformanceSimulationModel DTDFVocab:inputTo EclipseHono

// C14: Enabler/Service Connections
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Core service enabling live synchronization of physical asset data with digital twins via Eclipse Hono and Ditto"
    DTDFVocab:provides RealTimeSynchronizationData
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service supporting design-time and runtime simulations for performance evaluation and optimization"
    DTDFVocab:provides PerformanceSimulationModel
]

instance ScalableServiceDeploymentService : DTDFVocab:Service [
    base:desc "Service facilitating modular extension points for integrating additional services without disrupting core functionality"
    DTDFVocab:provides RealTimeSynchronizationData
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service leveraging AI-driven insights for cost modeling and operational efficiency"
    DTDFVocab:provides RealTimeSynchronizationData
]

instance LifeCycleOptimizationService : DTDFVocab:Service [
    base:desc "Service enabling life-cycle-encompassing optimization bridging design-time and runtime models"
    DTDFVocab:provides OperationalParameterData
]

DittoFramework DTDFVocab:enables RealTimeMonitoringService
DittoFramework DTDFVocab:enables SimulationService
DittoFramework DTDFVocab:enables ScalableServiceDeploymentService
DittoFramework DTDFVocab:enables PredictiveAnalyticsService

ModelDrivenDeploymentFramework DTDFVocab:enables ScalableServiceDeploymentService

// C17: Insights/Actions
