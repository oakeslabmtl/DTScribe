// C2: Acting Components
instance LightFixtureActuator : DTDFVocab:ActingComponent [
    base:desc "Physical lighting fixture with on/off, brightness percentage (0‑100%) and color temperature (2000‑6500K) exposed as properties on a DittoDevice twin and controlled via DittoController through Hono."
]

// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor publishing temperature telemetry to Hono for real‑time building monitoring."
    DTDFVocab:producedData TemperatureDataTx
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor publishing humidity telemetry to Hono for real‑time building monitoring."
    DTDFVocab:producedData HumidityDataTx
]

instance EnergyConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Energy consumption sensor publishing power usage telemetry to Hono for real‑time building monitoring."
    DTDFVocab:producedData EnergyConsumptionDataTx
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor publishing occupancy telemetry to Hono for real‑time building monitoring."
    DTDFVocab:producedData OccupancyDataTx
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance TemperatureDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance HumidityDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance EnergyConsumptionDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnergyConsumptionSensor
]

instance OccupancyDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Models/Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Aggregated temperature data stored in Ditto twin secrets and events, enabling real‑time visualization of building conditions."
    DTDFVocab:fromData TemperatureDataTx
    DTDFVocab:inputTo HonoEdgeAdapter
]

instance HumidityData : DTDFVocab:Data [
    base:desc "Aggregated humidity data stored in Ditto twin secrets and events, enabling real‑time visualization of building conditions."
    DTDFVocab:fromData HumidityDataTx
    DTDFVocab:inputTo HonoEdgeAdapter
]

instance EnergyConsumptionData : DTDFVocab:Data [
    base:desc "Aggregated energy consumption data stored in Ditto twin secrets and events, enabling real‑time visualization of building power usage."
    DTDFVocab:fromData EnergyConsumptionDataTx
    DTDFVocab:inputTo HonoEdgeAdapter
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Aggregated occupancy data stored in Ditto twin secrets and events, enabling real‑time visualization of building occupancy patterns."
    DTDFVocab:fromData OccupancyDataTx
    DTDFVocab:inputTo HonoEdgeAdapter
]

instance BIMtoDittoConversionModel : DTDFVocab:Model [
    base:desc "Model‑driven engineering pipeline converting enriched BIM entities into Ditto device twins and connection registry for runtime deployment."
]

// C11: Enablers
instance HonoEdgeAdapter : DTDFVocab:Enabler [
    base:desc "Edge adapter in Hono that normalizes units and forwards telemetry to Ditto, ensuring filtered and time‑stamped data streams."
    DTDFVocab:enables MonitoringService
]

instance DittoTwinBackend : DTDFVocab:Enabler [
    base:desc "Ditto backend that persists device twin state and events, providing a synchronized, persistent data store for all building telemetry."
    DTDFVocab:enables ControlService, PredictionService, OptimizationService, VisualizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous acquisition of environmental data mapped onto BIM‑based digital twin for real‑time monitoring."
    DTDFVocab:provides TemperatureInsight, HumidityInsight, EnergyConsumptionInsight, OccupancyInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Executes actuated commands (e.g., lighting setpoints) via twin’s control logic, enabling direct remote operation of the physical infrastructure."
    DTDFVocab:provides LightingControlAction
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Lightweight predictive analytics forecasting component failures and occupancy trends."
    DTDFVocab:provides MaintenanceAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Data‑driven analysis recommending energy‑saving strategies to improve system efficiency."
    DTDFVocab:provides EnergySavingAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Immersive dashboards overlay twin status onto BIM model, enabling stakeholders to inspect and interact with the building’s virtual representation."
]

// C17: Insights/Actions
instance TemperatureInsight : DTDFVocab:Insight [
    base:desc "Real‑time temperature trend insight derived from sensor data."
]

instance HumidityInsight : DTDFVocab:Insight [
    base:desc "Real‑time humidity trend insight derived from sensor data."
]

instance EnergyConsumptionInsight : DTDFVocab:Insight [
    base:desc "Real‑time energy consumption insight derived from sensor data."
]

instance OccupancyInsight : DTDFVocab:Insight [
    base:desc "Real‑time occupancy insight derived from sensor data."
]

instance LightingControlAction : DTDFVocab:Action [
    base:desc "Automated actuation command to adjust lighting fixture brightness and color temperature."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceAction : DTDFVocab:Action [
    base:desc "Predictive maintenance action to schedule lighting fixture replacement based on failure forecasts."
    DTDFVocab:IsAutomatic false
]

instance EnergySavingAction : DTDFVocab:Action [
    base:desc "Optimization action recommending lighting dimming schedules to reduce energy consumption."
    DTDFVocab:IsAutomatic true
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time data exchange between the physical building and its digital twin, enabling synchronization as soon as sensor or BIM updates become available. The system does not specify explicit polling intervals or latency thresholds, but the real‑time data exchange capabilities imply sub‑second to real‑time performance, ensuring that the virtual replica reflects the state of the physical asset with minimal delay."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a modular architecture pattern with a clear separation of concerns. Core components include a central hub that facilitates bidirectional data exchange, runtime configuration management for dynamic adaptation, and standardized extension points for service integration. Resource management is performed by the hub, which orchestrates sensor data ingestion, analytics services, and visualization modules. System‑wide coordination relies on the hub’s orchestration layer that manages event routing, data flow, and versioning of models."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin life cycle is stratified into (1) **Design & Enrichment** where Building Control Engineers embed sensors, actuators, and controllers into BIM models, extending the BIM geometry with functional metadata; (2) **Transformation** where Model‑Driven Engineering (MDE) principles automatically extract structured representations from the enriched BIM, producing deployable DT artifacts while preserving semantic integrity; (3) **Automated Deployment** enabled by requirement R2, which reduces manual configuration and ensures a reproducible, version‑controlled DT setup; (4) **Runtime Operation** featuring continuous real‑time data exchange via Eclipse Hono and Ditto (requirement R3), interactive visualization for monitoring and control, and ongoing synchronization between physical assets and the twin; and (5) **Evolution & Governance** where the modular architecture (requirement R4) and defined extension points allow the twin to scale, incorporate new services, and adhere to governance practices that coordinate model updates, runtime policies, and change management."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is guaranteed by Eclipse Ditto’s policy‑based validation engine, which applies schema constraints on sensor values (ranges, units) and verifies actuator command integrity before execution. Validation errors trigger immediate message rejection and audit logging. Fault tolerance is achieved via Eclipse Hono’s at‑least‑once delivery semantics and Ditto’s event persistence, replaying lost updates to restore consistency. Continuous synchronization between digital twins and physical devices is monitored by heartbeat messages; discrepancies trigger corrective actions or escalated alerts. An integrated quality assurance pipeline checks for version drift between the BIM source and runtime twins, applying automated diffing of device metadata to detect unauthorized modifications."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical infrastructure relies on Eclipse Hono as the message broker and Eclipse Ditto for twin representation, providing a bidirectional, publish/subscribe communication path. The system is designed to support real‑time data transfer, but specific bandwidth, latency, or redundancy mechanisms are not detailed in the documents. Network topology is conceptualized as a layered middleware system, with Hono routing messages from physical devices to Ditto’s twin service. Security is handled by the standard authentication and authorization mechanisms offered by both Hono and Ditto, although explicit security protocols are not named."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through data exchange between the Digital Twin and BIM models, sensor networks, and AI/analytics services. The design accounts for interoperability across heterogeneous systems, enabling the DT to ingest BIM representation during deployment and maintain real‑time synchronization with sensor feeds. The framework is open to integrating with other enterprise systems and additional Digital Twins via standard interfaces exposed by the central hub, although specific protocols are not defined within the provided documents."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The architecture adopts Eclipse Ditto and Eclipse Hono to meet real‑time connectivity requirements; these open‑source frameworks provide standardized messaging support (MQTT, HTTP, AMQP) and a JSON‑based twin model, thereby ensuring interoperability with industrial and IoT ecosystems. The framework’s model‑driven approach also aligns with BIM (IFC) semantics, offering a pathway to compliance with AECO primary data standards and fostering integration with existing digital‑primed workflows."
]