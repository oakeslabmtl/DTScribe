// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor embedded in BIM, exposed as Ditto virtual device sending high‑frequency telemetry"
]
instance CO2Sensor : DTDFVocab:SensingComponent [
    base:desc "CO₂ sensor embedded in BIM, communicated via my-bldg-mqtt topics"
]
instance MotionSensor : DTDFVocab:SensingComponent [
    base:desc "Motion sensor embedded in BIM, streamed to Einstein through Eclipse Hono"
]
instance LightSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient light sensor embedded in BIM, data published through MQTT to the building control system"
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]
instance CO2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CO2Sensor
]
instance MotionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MotionSensor
]
instance LightDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightSensor
]

// C10: Models/Data - Runtime data
instance TemperatureData : DTDFVocab:Data [
    base:desc "High‑frequency temperature time‑series, produced by TemperatureSensor"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseHonoMQTTTransport, EclipseDittoDataBroker
]
instance CO2SensorData : DTDFVocab:Data [
    base:desc "High‑frequency CO₂ concentration series, produced by CO2Sensor"
    DTDFVocab:fromData CO2DataTransmitted
    DTDFVocab:inputTo EclipseHonoMQTTTransport, EclipseDittoDataBroker
]
instance MotionSensorData : DTDFVocab:Data [
    base:desc "Occupancy binary series, produced by MotionSensor"
    DTDFVocab:fromData MotionDataTransmitted
    DTDFVocab:inputTo EclipseHonoMQTTTransport, EclipseDittoDataBroker
]
instance LightSensorData : DTDFVocab:Data [
    base:desc "Ambient light level series, produced by LightSensor"
    DTDFVocab:fromData LightDataTransmitted
    DTDFVocab:inputTo EclipseHonoMQTTTransport, EclipseDittoDataBroker
]
instance ControlHistoryData : DTDFVocab:Data [
    base:desc "Log of actuator control events, used by predictive analytics"
    DTDFVocab:inputTo EclipseDittoDataBroker
]

// C10: Models - BIM & Rendering
instance IFC4BIMModel : DTDFVocab:Model [
    base:desc "IFC4 BIM model of the LEED Platinum campus building enriched with device and control annotations"
    DTDFVocab:inputTo EMF_Xtext_MDE
]
instance DittoRuntimeDataModel : DTDFVocab:Model [
    base:desc "Ditto runtime data schema (JSON) describing sensors, actuators and their telemetry"
    DTDFVocab:inputTo EclipseDittoDataBroker
]
instance UnrealEngine5SceneModel : DTDFVocab:Model [
    base:desc "Unreal Engine 5 scene assets used for immersive 3D visualization"
    DTDFVocab:inputTo UnrealEngine5Rendering
]

// C2: Acting components (actuators)
instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC unit modeled in BIM, represented as a Ditto virtual device and controlled via MQTT"
]
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting fixture modeled in BIM, represented as a Ditto virtual device and controlled via MQTT"
]
instance BlindActuator : DTDFVocab:ActingComponent [
    base:desc "Operable blind modeled in BIM, mapped to physical hardware through MQTT connectivity"
]

// C11: Enablers
instance EMF_Xtext_MDE : DTDFVocab:Enabler [
    base:desc "EMF/Xtext-based model transformation engine converting enriched BIM into Ditto runtime metadata"
    DTDFVocab:enables ModelValidationService, TransformationService
]
instance EclipseHonoMQTTTransport : DTDFVocab:Enabler [
    base:desc "Eclipse Hono MQTT transport handling real‑time sensor telemetry streams"
    DTDFVocab:enables MonitoringDashboardService, PredictiveAnalyticsService
]
instance EclipseDittoDataBroker : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto data broker for virtual device communication"
    DTDFVocab:enables MonitoringDashboardService, PredictiveAnalyticsService, OptimizationService, MaintenanceSchedulerService
]
instance UnrealEngine5Rendering : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 rendering pipeline for immersive 3D visualization of the twin"
    DTDFVocab:enables ImmersiveVisualizationService
]
instance DockerKubernetesOrchestration : DTDFVocab:Enabler [
    base:desc "Docker/Kubernetes orchestrator managing internal subsystem twins as containers"
    DTDFVocab:enables HVACTwinContainer, LightingTwinContainer, ShadingTwinContainer
]
instance CustomDTServiceSDK : DTDFVocab:Enabler [
    base:desc "SDK for building custom Digital Twin services"
    DTDFVocab:enables CustomServiceDeployment
]
instance BOREALISReinforcementLearning : DTDFVocab:Enabler [
    base:desc "BOREALIS reinforcement learning engine driving iterative optimisation updates"
    DTDFVocab:enables LearningUpdateService
]
instance TwinLightModelDriftCorrection : DTDFVocab:Enabler [
    base:desc "TwinLight drift correction system maintaining model validity over time"
    DTDFVocab:enables DriftCorrectionService
]

// New Service Definitions for referenced services
instance ModelValidationService : DTDFVocab:Service [
    base:desc "Validates enriched BIM model against DT constraints"
]
instance TransformationService : DTDFVocab:Service [
    base:desc "Transforms enriched BIM into Ditto runtime metadata"
]
instance HVACTwinContainer : DTDFVocab:Service [
    base:desc "Docker container for HVAC twin"
]
instance LightingTwinContainer : DTDFVocab:Service [
    base:desc "Docker container for lighting twin"
]
instance ShadingTwinContainer : DTDFVocab:Service [
    base:desc "Docker container for shading twin"
]
instance CustomServiceDeployment : DTDFVocab:Service [
    base:desc "Custom service deployment in Docker"
]
instance LearningUpdateService : DTDFVocab:Service [
    base:desc "Reinforcement learning model update service"
]
instance DriftCorrectionService : DTDFVocab:Service [
    base:desc "Model drift correction service for TwinLight"
]

// C6: Services
instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real‑time monitoring dashboard displaying energy consumption and thermal state"
    DTDFVocab:provides EnergySavingsInsight, ComfortIndexInsight, DisplayDashboardAction
]
instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics for energy consumption, occupancy patterns and maintenance scheduling"
    DTDFVocab:provides MaintenanceScheduleInsight, CO2ForecastInsight
]
instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization engine for HVAC and lighting schedules"
    DTDFVocab:provides OptimizationRecommendationInsight, RunOptimizationAction
]
instance MaintenanceSchedulerService : DTDFVocab:Service [
    base:desc "Task planning service scheduling maintenance based on predictive analytics"
    DTDFVocab:provides MaintenanceScheduleInsight, ScheduleMaintenanceAction
]
instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D visualization of the campus building using Unreal Engine 5"
    DTDFVocab:provides Render3DVisualizationAction
]

// C17: Insights and Actions
instance EnergySavingsInsight : DTDFVocab:Insight [
    base:desc "Projected energy savings result of HVAC and lighting schedule optimisation"
]
instance ComfortIndexInsight : DTDFVocab:Insight [
    base:desc "Calculated occupant comfort index based on temperature, CO₂, and lighting data"
]
instance MaintenanceScheduleInsight : DTDFVocab:Insight [
    base:desc "Predictive maintenance schedule derived from actuator control logs and sensor trends"
]
instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommended adjustments to HVAC and lighting set‑points for optimal performance"
]
instance CO2ForecastInsight : DTDFVocab:Insight [
    base:desc "Forecasted CO₂ concentration levels for the next 24 hours"
]
instance RunOptimizationAction : DTDFVocab:Action [
    base:desc "Applies optimisation recommendations to the real‑time twin"
    DTDFVocab:IsAutomatic true
]
instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Schedules maintenance tasks as per periodic optimisation"
    DTDFVocab:IsAutomatic false
]
instance DisplayDashboardAction : DTDFVocab:Action [
    base:desc "Refreshes and displays the real‑time monitoring dashboard"
    DTDFVocab:IsAutomatic false
]
instance Render3DVisualizationAction : DTDFVocab:Action [
    base:desc "Triggers rendering of the immersive 3D scene in Unreal Engine 5"
    DTDFVocab:IsAutomatic false
]

// C10: Components & Environment
instance CampusBuildingComponent : DTDFVocab:Component [
    base:desc "Main campus building component, representing the overall LEED Platinum structure"
]
instance HVACTwinComponent : DTDFVocab:Component [
    base:desc "Internal twin for HVAC subsystem, exposed as a Docker container"
]
instance LightingTwinComponent : DTDFVocab:Component [
    base:desc "Internal twin for lighting subsystem, exposed as a Docker container"
]
instance ShadingTwinComponent : DTDFVocab:Component [
    base:desc "Internal twin for operable blinds subsystem, exposed as a Docker container"
]
instance DittoCentralInstanceComponent : DTDFVocab:Component [
    base:desc "Central Ditto instance orchestrating all internal twins"
]

// C17: Environment
instance LEEDPlatinumCampusBuilding : DTDFVocab:Environment [
    base:contains CampusBuildingComponent, HVACTwinComponent, LightingTwinComponent, ShadingTwinComponent, DittoCentralInstanceComponent
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT generates control command messages (e.g., setpoint changes, actuator activation) which are forwarded by Ditto to Eclipse Hono and then delivered via MQTT to the physical controlling devices, closing the causal loop."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Live data ingestion occurs at sub‑second to 1‑minute intervals depending on sensor publish frequency; control loops operate at 1–10 Hz; simulation and optimization tasks run at real‑time or near‑real‑time based on the Unreal Engine rendering pipeline."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized DT hub (Ditto) connected to Hono for transport; multiple micro‑services (control logic, analytics, visualization) deployed as Docker containers; Unreal Engine runtime linked via WebSocket to display live state; all components coordinated through a model‑driven deployment pipeline."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Encompasses the full lifecycle: design (BIM creation), manufacturing/construction (BIM interpreted for on‑site commissioning), and operation (runtime monitoring and control). The DT aligns with the design‑time BIM, anchors to the constructed model, and evolves during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Odte metric used to quantify entanglement between DT and physical system; semantic drift monitored via diffs between BIM and runtime; validation via test suites against real sensor data and control response; uncertainty quantified through confidence intervals on forecasted energy consumption."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication established over MQTT/WS using TLS 1.2; Eclipse Hono routes MQTT messages to Ditto via HTTPS; Ditto exposes REST and WebSocket APIs for external services; on‑premise data nodes communicate over LAN with 802.11n or Ethernet."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Containerised deployment on Kubernetes cluster; Ditto and Hono run as stateful sets; Unreal Engine server runs on a dedicated GPU node; deployment files generated by MDE tooling and applied with Helm charts; cloud‑agnostic (supports on‑prem or public cloud)."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Exposes REST endpoints for external BIM servers, building management systems (BMS), and other DTs via standardized IoT protocols; enables bi‑directional data exchange with enterprise asset management systems."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Sensor data is owned by the building (PT) and is encrypted in transit (TLS) and at rest; DT provider implements role‑based access control; GDPR compliant data handling policies applied; no explicit data sharing without consent."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Adheres to IFC4 for BIM, MQTT and OWS protocols for device communication, and OGC SensorThings API for sensor data representation; follows ISO 15926 for semantic interoperability where applicable."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "All MQTT traffic protected by TLS and client certificates; authentication via OAuth2/OIDC; command validation layer ensures control messages respect safety constraints (placeholders for emergency shutdown); role‑based access controls enforce least privilege; fail‑safe state machines implemented in the control logic to prevent unsafe actuator states."
]