// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor modeled in the BIM model, providing continuous thermal readings of zones."
    DTDFVocab:producedData TemperatureMeasurement
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Occupancy sensor modeled in the BIM model, detecting presence of occupants for space utilization."
    DTDFVocab:producedData OccupancyMeasurement
]

instance LightingSensor : DTDFVocab:SensingComponent [
    base:desc "Ambient lighting sensor modeled in the BIM model, measuring illumination levels for lighting control."
    DTDFVocab:producedData LightingMeasurement
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance TemperatureMeasurement : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance OccupancyMeasurement : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

instance LightingMeasurement : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LightingSensor
]

// C10: Data produced from transmitted measurements
instance TemperatureData : DTDFVocab:Data [
    base:desc "Live temperature data stream derived from TemperatureMeasurement."
    DTDFVocab:fromData TemperatureMeasurement
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Live occupancy data stream derived from OccupancyMeasurement."
    DTDFVocab:fromData OccupancyMeasurement
]

instance LightingData : DTDFVocab:Data [
    base:desc "Live illumination data stream derived from LightingMeasurement."
    DTDFVocab:fromData LightingMeasurement
]

// C11: Enablers
instance EclipseHono : DTDFVocab:Enabler [
    base:desc "Eclipse Hono IoT gateway that ingests sensor messages and forwards them to the digital twin platform."
    DTDFVocab:enables RealTimeMonitoringService
]

instance EclipseDitto : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto digital twin engine that stores and manages twin state, providing APIs for services."
    DTDFVocab:enables RealTimeMonitoringService
]

instance UnrealEngine5 : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 runtime used for high‑fidelity 3D visualization of the building twin."
    DTDFVocab:enables Visualization3DService
]

instance ModelDrivenPipeline : DTDFVocab:Enabler [
    base:desc "Model‑driven engineering pipeline that automatically generates deployment artifacts and control logic from the enriched BIM model."
    DTDFVocab:enables SimulationService, PredictiveAnalyticsService, OptimizationService
]

instance BIMAuthoringTool : DTDFVocab:Enabler [
    base:desc "BIM authoring tool (e.g., Revit) used to create the enriched BIM model containing geometry, spatial relations, and device metadata."
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service delivering real‑time monitoring of building sensor data to stakeholders."
    DTDFVocab:provides RealTimeInsight
]

instance Visualization3DService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization of the building twin powered by Unreal Engine 5."
    DTDFVocab:provides VisualizationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service that runs virtual scenarios based on the enriched BIM model and live data."
    DTDFVocab:provides SimulationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics service that generates forecasts and anomaly detection for building operations."
    DTDFVocab:provides PredictiveAnalyticsInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that suggests energy‑saving actions and automatically adjusts actuators."
    DTDFVocab:provides OptimizationSuggestionInsight, AdjustHVACAction, ToggleLightingAction
]

// C17: Insights
instance RealTimeInsight : DTDFVocab:Insight [
    base:desc "Real‑time insight into current temperature, occupancy, and illumination conditions."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insightful 3D visual representation of space usage and system status."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Resulting data from virtual simulations of building performance."
]

instance PredictiveAnalyticsInsight : DTDFVocab:Insight [
    base:desc "Predictive analytics insight offering forecasts of temperature trends and occupancy patterns."
]

instance OptimizationSuggestionInsight : DTDFVocab:Insight [
    base:desc "Optimization suggestion insight recommending energy‑saving setpoints and schedules."
]

// C17: Actions
instance AdjustHVACAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust HVAC setpoints based on optimization suggestions."
    DTDFVocab:IsAutomatic true
]

instance ToggleLightingAction : DTDFVocab:Action [
    base:desc "Automatic action to dim or switch on lighting according to occupancy and illumination data."
    DTDFVocab:IsAutomatic true
]

// C2: Acting components
instance HVACController : DTDFVocab:ActingComponent [
    base:desc "HVAC controller modeled in the BIM model that receives command messages to regulate heating, ventilation, and cooling."
]

instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled in the BIM model that receives command messages to control lighting levels."
]

// C10: Models/Data
instance EnrichedBIMModel : DTDFVocab:Model [
    base:desc "Core enriched BIM model containing geometry, spatial relations, and device metadata for the building."
]

instance RuntimeControlLogic : DTDFVocab:Data [
    base:desc "Control logic generated by model‑driven transformations, governing actuator behavior at runtime."
    DTDFVocab:fromData TemperatureMeasurement, OccupancyMeasurement, LightingMeasurement
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT are sent back to physical actuators via the same Hono/Ditto middleware, enabling bidirectional communication."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous real‑time synchronization between physical sensors/actuators and the DT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A modular architecture composed of the BIM model, a Hono/Ditto middleware layer for bidirectional data exchange, a visualization layer (Unreal Engine), and extensible service modules connected through standardized extension points."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Supports the full building life‑cycle—from design (BIM model) through construction to operational monitoring and control."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Overall Digital Twin Entanglement (ODTE) metric is used to quantify how accurately the DT mirrors its physical counterpart."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Integration of Eclipse Hono (acting as protocol gateway for telemetry) with Eclipse Ditto (digital‑twin state management), providing a real‑time bidirectional communication channel between physical devices and the DT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Leverages BIM standards for geometry and semantics, and defines standardized extension points for service integration, ensuring interoperability across AECO tools."
]