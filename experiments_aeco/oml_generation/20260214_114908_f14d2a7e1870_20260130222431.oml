// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Building temperature sensor embedded in the enriched BIM model for runtime data acquisition."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance IlluminationSensor : DTDFVocab:SensingComponent [
    base:desc "Building illumination sensor embedded in the enriched BIM model for runtime data acquisition."
    DTDFVocab:producedData IlluminationDataTransmitted
]

instance OccupancySensor : DTDFVocab:SensingComponent [
    base:desc "Building occupancy sensor embedded in the enriched BIM model for runtime data acquisition."
    DTDFVocab:producedData OccupancyDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

instance IlluminationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IlluminationSensor
]

instance OccupancyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OccupancySensor
]

// C10: Data generated from transmitted streams
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature readings streamed from building sensors."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo EclipseDittoTwinManager
]

instance IlluminationData : DTDFVocab:Data [
    base:desc "Illumination level readings streamed from building sensors."
    DTDFVocab:fromData IlluminationDataTransmitted
    DTDFVocab:inputTo EclipseDittoTwinManager
]

instance OccupancyData : DTDFVocab:Data [
    base:desc "Occupancy status readings streamed from building sensors."
    DTDFVocab:fromData OccupancyDataTransmitted
    DTDFVocab:inputTo EclipseDittoTwinManager
]

// C11: Enablers (tooling & enablers)
instance EclipseHonoAdapter : DTDFVocab:Enabler [
    base:desc "Eclipse Hono protocol adapters (MQTT/HTTP) collecting real‑time sensor streams."
    DTDFVocab:enables SensorStreamIngestionService
]

instance EclipseDittoTwinManager : DTDFVocab:Enabler [
    base:desc "Eclipse Ditto managing device twins, updating state and triggering analytics."
    DTDFVocab:enables RealTimeDashboardService,
                     PredictiveAnalyticsService,
                     OptimizationRecommendationService
]

instance UnrealEngine5Renderer : DTDFVocab:Enabler [
    base:desc "Unreal Engine 5 rendering engine providing immersive 3D visualization of the digital twin."
    DTDFVocab:enables ImmersiveVisualizationService
]

// C6: Services
instance SensorStreamIngestionService : DTDFVocab:Service [
    base:desc "Service that ingests sensor streams from Hono and forwards them to Ditto."
    DTDFVocab:provides SensorStreamInsight
]

instance RealTimeDashboardService : DTDFVocab:Service [
    base:desc "Continuous monitoring dashboards delivering real‑time status of building systems."
    DTDFVocab:provides RealTimeStatusInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Predictive analytics delivering energy‑usage forecasts based on streaming sensor data."
    DTDFVocab:provides EnergyForecastInsight
]

instance OptimizationRecommendationService : DTDFVocab:Service [
    base:desc "Optimization engine suggesting parameter adjustments for lighting and climate control."
    DTDFVocab:provides OptimizationRecommendationAction,
                     LightingAdjustmentAction,
                     ClimateControlAdjustmentAction
]

instance ImmersiveVisualizationService : DTDFVocab:Service [
    base:desc "Immersive 3D visualization of the building twin via Unreal Engine 5."
    DTDFVocab:provides ImmersiveVisualizationInsight
]

// C17: Insights / Actions
instance RealTimeStatusInsight : DTDFVocab:Insight [
    base:desc "Real‑time status dashboards for facility managers."
]

instance EnergyForecastInsight : DTDFVocab:Insight [
    base:desc "Predictive energy‑usage forecasts for the building."
]

instance OptimizationRecommendationAction : DTDFVocab:Action [
    base:desc "Optimization recommendations for lighting and climate control."
    DTDFVocab:IsAutomatic false
]

instance LightingAdjustmentAction : DTDFVocab:Action [
    base:desc "Suggested adjustment of lighting parameters."
    DTDFVocab:IsAutomatic false
]

instance ClimateControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Suggested adjustment of HVAC climate settings."
    DTDFVocab:IsAutomatic false
]

instance ImmersiveVisualizationInsight : DTDFVocab:Insight [
    base:desc "Immersive 3D visualization of the building twin in Unreal Engine 5."
]

instance SensorStreamInsight : DTDFVocab:Insight [
    base:desc "Acknowledgement that sensor streams have been successfully ingested."
]

// C10: Models and Data
instance BIMGeometryModel : DTDFVocab:Model [
    base:desc "Base BIM geometry and semantics of the building."
    DTDFVocab:inputTo UnrealEngine5Renderer
]

instance EnrichedDeviceMetadataModel : DTDFVocab:Model [
    base:desc "Device metadata enriched in BIM for sensors and actuators."
    DTDFVocab:inputTo EclipseDittoTwinManager
]

instance ControlLogicModel : DTDFVocab:Model [
    base:desc "Control‑logic models for building control system."
    DTDFVocab:inputTo EclipseDittoTwinManager
]

instance PredictiveEnergyModel : DTDFVocab:Model [
    base:desc "Predictive analytics model for building energy consumption."
    DTDFVocab:inputTo EclipseDittoTwinManager
]

instance ODTEMetricModel : DTDFVocab:Model [
    base:desc "Overall Digital Twin Entanglement (ODTE) metric model measuring fidelity."
    DTDFVocab:inputTo EclipseDittoTwinManager
]

// C2: Acting components
instance LightingActuator : DTDFVocab:ActingComponent [
    base:desc "Lighting actuator modeled within BIM, driven by twin commands for illumination adjustments."
]

instance HVACActuator : DTDFVocab:ActingComponent [
    base:desc "HVAC actuator modeled within BIM, driven by twin commands for climate control adjustments."
]

// C14: Environment (composite twin)
instance BuildingEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensor,
                 IlluminationSensor,
                 OccupancySensor,
                 LightingActuator,
                 HVACActuator
]

// C13: Component – Model‑driven pipeline
instance ModelDrivenPipelineComponent : DTDFVocab:Component [
    base:desc "Model‑driven pipeline: enrich BIM with device semantics → validate model → auto‑generate Hono/Ditto configurations → deploy twins → operate. Extensions may be added via defined extension points without full redeployment."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control logic generated by the twin emits command messages via Ditto to Eclipse Hono, which forwards them to the physical actuators using the same protocol adapters, enabling bidirectional actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Continuous near‑real‑time synchronization; sensor updates and control commands are exchanged with sub‑second latency as supported by Hono/Ditto."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A service‑oriented architecture where the enriched BIM feeds a configurator, which produces Ditto twin definitions and Hono connection descriptors; Ditto hosts the twin state, Hono streams data, and Unreal Engine visualizes the twin for users."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Covers design (BIM as the ideal model), deployment (automatic generation of runtime artifacts), operation (real‑time data exchange), and maintenance (runtime configuration updates)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation before deployment and quantitative assessment of twin‑physical alignment using the Overall Digital Twin Entanglement (ODTE) metric; runtime consistency ensured by continuous bidirectional updates."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Eclipse Hono provides MQTT, HTTP, and CoAP adapters; Ditto exposes HTTP/REST and WebSocket APIs; communication between Hono and Ditto is over standard internet protocols (TCP/IP)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital twin runtime components (Ditto server and Hono gateway) are hosted on a cloud/edge infrastructure; Unreal Engine runs as a client visualization layer connecting to Ditto via its APIs."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The framework integrates BIM, IoT sensor streams, control middleware (Hono/Ditto), and third‑party analytics services through its standardized extension points, enabling exchange with external enterprise systems."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Uses BIM industry standards for building data, open IoT standards supported by Eclipse Hono (MQTT, HTTP, CoAP), and Ditto’s adherence to the Eclipse Vorto and Digital Twin Definition Language (DTDL) conventions; ODTE metric provides a standardized fidelity measure."
]