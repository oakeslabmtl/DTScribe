// C3: Physical sensing components
instance BuildingSensorNetwork : DTDFVocab:SensingComponent [
    base:desc "Hypothetical sensor network representing all physical sensing components in the building infrastructure."
    DTDFVocab:producedData SensorDataTransmitted
]

// C2: Acting Components
instance BuildingControlSystemComponents : DTDFVocab:ActingComponent [
    base:desc "Hypothetical acting components representing Building Control System elements including actuators and controllers."
]

instance CustomAnalyticsComponents : DTDFVocab:ActingComponent [
    base:desc "Hypothetical components representing custom analytics and service extensions integrated through Digital Twin framework."
]

// C4: Physical-to-virtual interaction
instance SensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BuildingSensorNetwork
]

