// C11: Enablers
instance BuildingInformationModelingFramework : DTDFVocab:Enabler [
    base:desc "Serves as the foundational static model for the physical twin, integrating geometric, spatial, and functional data (e.g., Revit, ArchiCAD) to ensure semantic consistency across lifecycle phases."
    DTDFVocab:enables BimToDigitalTwinTransformationService, StaticModelVisualizationService
]

instance EclipseHonoMessagingBroker : DTDFVocab:Enabler [
    base:desc "Lightweight MQTT-based messaging broker for secure, scalable IoT data ingestion, supporting high-throughput sensor streams from heterogeneous devices."
    DTDFVocab:enables RealTimeDataIngestionService, RealTimeMonitoringService
]

instance EclipseDittoFramework : DTDFVocab:Enabler [
    base:desc "Digital twin framework providing device and asset abstraction, enabling dynamic twin state management and event-driven updates between physical and virtual layers."
    DTDFVocab:enables DigitalTwinStateManagementService, EventTriggeredUpdateInsight
]

instance AnsysStructuralAnalysisEngine : DTDFVocab:Enabler [
    base:desc "Domain-specific solver for structural analysis to model physical behaviors and validate Digital Twin predictions."
    DTDFVocab:enables StructuralBehaviorSimulationService, PredictiveAnalyticsService
]

instance EnergyPlusHvacSimulationEngine : DTDFVocab:Enabler [
    base:desc "Domain-specific solver for HVAC simulation to model physical behaviors and validate Digital Twin predictions."
    DTDFVocab:enables EnergyConsumptionSimulationService, OptimizationService
]

instance UnrealEngineVisualizationPlatform : DTDFVocab:Enabler [
    base:desc "Real-time rendering platform supporting VR/AR interactions, multi-user collaboration, and immersive analytics (e.g., overlaying sensor data on 3D models)."
    DTDFVocab:enables ImmersiveMonitoringService, CollaborativeWorkflowService
]

instance InfluxDbTimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time-series database for storing and querying structured operational data from disparate sources, ensuring low-latency access for Digital Twin services."
    DTDFVocab:enables RealTimeDataStorageService, PerformanceTrendAnalysisInsight
]

instance Neo4jGraphDatabase : DTDFVocab:Enabler [
    base:desc "Graph database for storing and querying unstructured data relationships from disparate sources, enabling complex query patterns for Digital Twin services."
    DTDFVocab:enables SemanticDataIntegrationService, DataRelationshipMappingInsight
]

instance OpcUaInteroperabilityProtocol : DTDFVocab:Enabler [
    base:desc "Standardized protocol for data exchange between legacy systems, IoT devices, and Digital Twin components, addressing fragmented AECO data ecosystems."
    DTDFVocab:enables LegacySystemIntegrationService
]

instance RestApiInteroperabilityProtocol : DTDFVocab:Enabler [
    base:desc "Standardized REST API protocol for data exchange between Digital Twin components and external systems, ensuring compatibility with modern web services."
    DTDFVocab:enables CloudServiceIntegrationService, ExternalServiceAccessInsight
]

instance LinkedDataSemanticFramework : DTDFVocab:Enabler [
    base:desc "RDF/OWL-based framework for semantic data exchange, enabling standardized representation and querying of Digital Twin data across heterogeneous systems."
    DTDFVocab:enables SemanticDataStandardizationService, OntologyAlignmentInsight
]

// C10: Models/Data
instance EnrichedBimModel : DTDFVocab:Model [
    base:desc "Static representation combining geometric, spatial, and functional data from BIM tools (e.g., Revit, ArchiCAD) serving as the foundational model for Digital Twin deployment."
    DTDFVocab:inputTo BuildingInformationModelingFramework
]

instance BuildingControlSystemModel : DTDFVocab:Model [
    base:desc "Behavioral model enriched with Building Control System components including sensors, actuators, and controllers derived from BIM."
    DTDFVocab:inputTo EclipseDittoFramework
]

instance AnalyticalModel : DTDFVocab:Model [
    base:desc "Automatically generated model via Model-Driven Engineering principles, enabling structured representations for Digital Twin artifacts."
    DTDFVocab:inputTo AnsysStructuralAnalysisEngine, EnergyPlusHvacSimulationEngine
]

instance RealTimeOperationalData : DTDFVocab:Data [
    base:desc "Synchronized data stream between physical building systems and Digital Twin, including sensor telemetry and system logs."
    DTDFVocab:fromData SensorDataTransmitted, SystemTelemetryDataTransmitted
    DTDFVocab:inputTo EclipseHonoMessagingBroker, EclipseDittoFramework, InfluxDbTimeSeriesDatabase
]

instance CustomServiceData : DTDFVocab:Data [
    base:desc "Modular, standardized data integrated through extension points for domain-specific analytics and services."
    DTDFVocab:fromData CustomAnalyticsDataTransmitted
    DTDFVocab:inputTo Neo4jGraphDatabase, LinkedDataSemanticFramework
]

// C6: Services
instance BimToDigitalTwinTransformationService : DTDFVocab:Service [
    base:desc "Automated service converting enriched BIM models into deployable Digital Twin artifacts with minimal manual intervention."
    DTDFVocab:provides DigitalTwinArtifactGenerationInsight, ModelConsistencyValidationInsight
]

instance RealTimeDataIngestionService : DTDFVocab:Service [
    base:desc "Service handling high-throughput IoT data ingestion from heterogeneous devices via MQTT-based messaging."
    DTDFVocab:provides DeviceDataIngestionInsight, DataQualityAssuranceInsight
]

instance DigitalTwinStateManagementService : DTDFVocab:Service [
    base:desc "Service managing dynamic twin state and event-driven updates between physical and virtual layers."
    DTDFVocab:provides TwinStateSynchronizationInsight, EventTriggeredUpdateInsight
]

instance StructuralBehaviorSimulationService : DTDFVocab:Service [
    base:desc "Service modeling structural behaviors using ANSYS solver for Digital Twin validation and predictive analysis."
    DTDFVocab:provides StructuralIntegrityInsight, LoadAnalysisInsight
]

instance EnergyConsumptionSimulationService : DTDFVocab:Service [
    base:desc "Service modeling HVAC behaviors using EnergyPlus solver for Digital Twin validation and energy optimization."
    DTDFVocab:provides EnergyEfficiencyInsight, ThermalPerformanceInsight
]

instance ImmersiveMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real-time 3D visualization with VR/AR interactions and sensor data overlays."
    DTDFVocab:provides VisualizationInsight, MultiUserCollaborationInsight
]

instance RealTimeDataStorageService : DTDFVocab:Service [
    base:desc "Service storing and querying time-series operational data with low-latency access."
    DTDFVocab:provides DataRetrievalInsight, PerformanceTrendAnalysisInsight
]

instance SemanticDataIntegrationService : DTDFVocab:Service [
    base:desc "Service integrating unstructured data relationships using graph database capabilities."
    DTDFVocab:provides DataRelationshipMappingInsight, ComplexQuerySupportInsight
]

instance LegacySystemIntegrationService : DTDFVocab:Service [
    base:desc "Service enabling OPC UA-based integration of legacy building systems with Digital Twin."
    DTDFVocab:provides SystemInteroperabilityInsight, DataStandardizationInsight
]

instance CloudServiceIntegrationService : DTDFVocab:Service [
    base:desc "Service enabling REST API-based integration with cloud services and third-party applications."
    DTDFVocab:provides CloudConnectivityInsight, ExternalServiceAccessInsight
]

instance SemanticDataStandardizationService : DTDFVocab:Service [
    base:desc "Service standardizing data representation using RDF/OWL ontologies for Digital Twin components."
    DTDFVocab:provides OntologyAlignmentInsight, SemanticQuerySupportInsight
]

instance StaticModelVisualizationService : DTDFVocab:Service [
    base:desc "Service providing visualization of static BIM models for design review and validation."
    DTDFVocab:provides ModelVisualizationInsight, DesignValidationInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service providing real-time monitoring of building performance metrics (energy consumption, structural integrity, occupancy patterns)."
    DTDFVocab:provides PerformanceMetricInsight, AnomalyDetectionInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service providing predictive analytics for proactive maintenance, failure prediction, and lifecycle optimization."
    DTDFVocab:provides FailurePredictionInsight, MaintenanceRecommendationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service providing simulation-based decision support for operational efficiency and cost reduction."
    DTDFVocab:provides EfficiencyOptimizationInsight, CostReductionInsight
]

instance VisualizationAndSimulationService : DTDFVocab:Service [
    base:desc "Service simulating building performance under varying conditions for design validation and refurbishment planning."
    DTDFVocab:provides ScenarioSimulationInsight, AdaptiveModificationInsight
]

instance CollaborativeWorkflowService : DTDFVocab:Service [
    base:desc "Service enabling multi-disciplinary stakeholder engagement across the building lifecycle."
    DTDFVocab:provides StakeholderCollaborationInsight, WorkflowIntegrationInsight
]

