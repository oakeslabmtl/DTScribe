// C3: Physical Sensing Components
instance PermafrostTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "High-precision temperature sensor for permafrost monitoring with ±0.1°C accuracy"
]

instance SoilMoistureSensor : DTDFVocab:SensingComponent [
    base:desc "Capacitive soil moisture sensor with 1% volumetric water content resolution"
]

instance StructuralStrainSensor : DTDFVocab:SensingComponent [
    base:desc "Fiber optic strain sensor array for structural health monitoring with 10 microstrain resolution"
]

instance EnvironmentalHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Industrial-grade humidity sensor with ±2% RH accuracy for climate control"
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PermafrostTemperatureSensor
    base:desc "Real-time temperature data transmitted via LoRaWAN at 15-minute intervals"
]

instance MoistureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SoilMoistureSensor
    base:desc "Soil moisture measurements transmitted via MQTT at hourly intervals"
]

instance StrainDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralStrainSensor
    base:desc "Structural strain data streamed via Ethernet at 1Hz frequency"
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalHumiditySensor
    base:desc "Environmental humidity data collected via RS485 at 30-minute intervals"
]

// C10: Models/Data
instance ThermalConductionModel : DTDFVocab:Model [
    base:desc "Finite element thermal model simulating permafrost temperature distribution"
    DTDFVocab:inputTo DigitalTwinSimulationEngine
]

instance SoilWaterBalanceModel : DTDFVocab:Model [
    base:desc "Hydrological model predicting soil moisture dynamics based on climate data"
    DTDFVocab:inputTo DigitalTwinSimulationEngine
]

instance StructuralHealthModel : DTDFVocab:Model [
    base:desc "Machine learning-based structural health assessment model"
    DTDFVocab:inputTo DigitalTwinSimulationEngine
]

instance ClimateData : DTDFVocab:Data [
    base:desc "Historical and real-time climate data including temperature, precipitation, and solar radiation"
    DTDFVocab:fromData TemperatureDataTransmitted, HumidityDataTransmitted
    DTDFVocab:inputTo DigitalTwinSimulationEngine, DataVisualizationService
]

instance StructuralData : DTDFVocab:Data [
    base:desc "Structural response data including strain measurements and vibration patterns"
    DTDFVocab:fromData StrainDataTransmitted
    DTDFVocab:inputTo DigitalTwinSimulationEngine, StructuralAnalysisService
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Environmental monitoring data including soil moisture and atmospheric conditions"
    DTDFVocab:fromData MoistureDataTransmitted
    DTDFVocab:inputTo DigitalTwinSimulationEngine, EnvironmentalMonitoringService
]

// C11: Enablers
instance DigitalTwinSimulationEngine : DTDFVocab:Enabler [
    base:desc "High-performance computing engine for real-time digital twin simulations"
    DTDFVocab:enables StructuralAnalysisService, EnvironmentalMonitoringService, PredictiveMaintenanceService
]

instance DataVisualizationService : DTDFVocab:Enabler [
    base:desc "3D visualization platform with real-time data rendering capabilities"
    DTDFVocab:enables MonitoringDashboardService, ScenarioAnalysisService
]

instance EdgeComputingGateway : DTDFVocab:Enabler [
    base:desc "Edge computing node for preprocessing and filtering sensor data"
    DTDFVocab:enables DataVisualizationService, DigitalTwinSimulationEngine
]

// C6: Services
instance StructuralAnalysisService : DTDFVocab:Service [
    base:desc "Structural health monitoring and damage detection service"
    DTDFVocab:provides StructuralIntegrityInsight, MaintenanceRecommendationAction
]

instance EnvironmentalMonitoringService : DTDFVocab:Service [
    base:desc "Environmental condition monitoring with anomaly detection"
    DTDFVocab:provides ClimatePatternInsight, SoilConditionAlertAction
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance scheduling based on structural health data"
    DTDFVocab:provides MaintenanceScheduleInsight, AutomaticWorkOrderAction
]

instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real-time monitoring dashboard with customizable views"
    DTDFVocab:provides SystemStatusInsight
]

instance ScenarioAnalysisService : DTDFVocab:Service [
    base:desc "What-if scenario analysis for different environmental conditions"
    DTDFVocab:provides ScenarioImpactInsight
]

// C17: Insights/Actions
instance StructuralIntegrityInsight : DTDFVocab:Insight [
    base:desc "Quantitative assessment of structural integrity with confidence intervals"
]

instance ClimatePatternInsight : DTDFVocab:Insight [
    base:desc "Identified climate patterns affecting permafrost stability"
]

instance MaintenanceScheduleInsight : DTDFVocab:Insight [
    base:desc "Optimized maintenance schedule with cost-benefit analysis"
]

instance SystemStatusInsight : DTDFVocab:Insight [
    base:desc "Current operational status of the monitored system"
]

instance ScenarioImpactInsight : DTDFVocab:Insight [
    base:desc "Predicted impact of environmental scenarios on system performance"
]

instance SoilConditionAlertAction : DTDFVocab:Action [
    base:desc "Automated alert generation for critical soil moisture conditions"
    DTDFVocab:IsAutomatic true
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Recommended maintenance actions based on structural health assessment"
    DTDFVocab:IsAutomatic false
]

instance AutomaticWorkOrderAction : DTDFVocab:Action [
    base:desc "Automated generation of work orders for predictive maintenance"
    DTDFVocab:IsAutomatic true
]