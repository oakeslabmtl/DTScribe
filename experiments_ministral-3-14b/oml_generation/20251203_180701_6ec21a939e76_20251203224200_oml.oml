// C3: Physical Sensing Components
instance PermafrostTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "High-precision temperature sensor deployed in permafrost regions to measure ground thermal state with ±0.1°C accuracy"
    DTDFVocab:producedData PermafrostTemperatureDataTransmitted
]

instance SoilMoistureSensor : DTDFVocab:SensingComponent [
    base:desc "Capacitance-based soil moisture sensor with 1% volumetric water content resolution, operating at 1Hz sampling rate"
    DTDFVocab:producedData SoilMoistureDataTransmitted
]

instance StructuralHealthMonitor : DTDFVocab:SensingComponent [
    base:desc "Fiber optic distributed sensing system for structural deformation monitoring with 1mm spatial resolution"
    DTDFVocab:producedData StructuralDeformationDataTransmitted
]

instance EnvironmentalRadiationSensor : DTDFVocab:SensingComponent [
    base:desc "Spectroradiometer measuring UV-B to PAR spectrum with 3nm resolution for environmental impact assessment"
    DTDFVocab:producedData EnvironmentalRadiationDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance PermafrostTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PermafrostTemperatureSensor
]

instance SoilMoistureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SoilMoistureSensor
]

instance StructuralDeformationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralHealthMonitor
]

instance EnvironmentalRadiationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalRadiationSensor
]

// C10: Models/Data
instance PermafrostThermalModel : DTDFVocab:Model [
    base:desc "Finite element model simulating permafrost thaw processes with 0.5m spatial discretization"
    DTDFVocab:inputTo DigitalTwinSimulationEngine
]

instance SoilMoistureTransportModel : DTDFVocab:Model [
    base:desc "Richard's equation-based model for unsaturated flow with hysteresis effects"
    DTDFVocab:inputTo DigitalTwinSimulationEngine
]

instance StructuralResponseModel : DTDFVocab:Model [
    base:desc "Finite element model for structural dynamics with material nonlinearities"
    DTDFVocab:inputTo DigitalTwinSimulationEngine
]

instance EnvironmentalImpactModel : DTDFVocab:Model [
    base:desc "Coupled climate-ecosystem model assessing radiation effects on local biodiversity"
    DTDFVocab:inputTo DigitalTwinSimulationEngine
]

instance PermafrostTemperatureData : DTDFVocab:Data [
    base:desc "Time-series temperature data from permafrost monitoring network with 15-minute resolution"
    DTDFVocab:fromData PermafrostTemperatureDataTransmitted
    DTDFVocab:inputTo DataProcessingPipeline
]

instance SoilMoistureData : DTDFVocab:Data [
    base:desc "Processed soil moisture content data with 1Hz raw and 1-minute aggregated outputs"
    DTDFVocab:fromData SoilMoistureDataTransmitted
    DTDFVocab:inputTo DataProcessingPipeline
]

instance StructuralDeformationData : DTDFVocab:Data [
    base:desc "Processed structural deformation measurements with noise-filtered strain data"
    DTDFVocab:fromData StructuralDeformationDataTransmitted
    DTDFVocab:inputTo DataProcessingPipeline
]

instance EnvironmentalRadiationData : DTDFVocab:Data [
    base:desc "Spectral radiation measurements with quality flags for cloud interference"
    DTDFVocab:fromData EnvironmentalRadiationDataTransmitted
    DTDFVocab:inputTo DataProcessingPipeline
]

// C11: Enablers
instance DigitalTwinSimulationEngine : DTDFVocab:Enabler [
    base:desc "High-performance computing cluster running COMSOL Multiphysics for coupled simulations"
    DTDFVocab:enables PermafrostSimulationService, StructuralAnalysisService, EnvironmentalImpactService
]

instance DataProcessingPipeline : DTDFVocab:Enabler [
    base:desc "Apache Spark-based pipeline for real-time data processing and feature extraction"
    DTDFVocab:enables DataVisualizationService, AnomalyDetectionService
]

instance DigitalTwinIntegrationPlatform : DTDFVocab:Enabler [
    base:desc "Microsoft Azure Digital Twins platform managing all twin instances and relationships"
    DTDFVocab:enables TwinManagementService, CrossDomainIntegrationService
]

instance KnowledgeGraphEngine : DTDFVocab:Enabler [
    base:desc "Neo4j-based knowledge graph storing all digital twin relationships and metadata"
]

// C6: Services
instance PermafrostSimulationService : DTDFVocab:Service [
    base:desc "Service providing permafrost thaw predictions with 95% confidence intervals"
    DTDFVocab:provides PermafrostThawInsight
]

instance StructuralAnalysisService : DTDFVocab:Service [
    base:desc "Service calculating structural safety factors with probabilistic risk assessment"
    DTDFVocab:provides StructuralRiskInsight
]

instance EnvironmentalImpactService : DTDFVocab:Service [
    base:desc "Service assessing ecological impact of environmental changes with biodiversity metrics"
    DTDFVocab:provides EcologicalImpactInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Interactive 3D visualization service with time-sliced data exploration capabilities"
    DTDFVocab:provides VisualizationInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Machine learning service detecting anomalies with 99% precision using isolation forests"
    DTDFVocab:provides AnomalyAlertAction
]

instance TwinManagementService : DTDFVocab:Service [
    base:desc "Service managing twin lifecycle from creation to decommissioning with version control"
    DTDFVocab:provides TwinStatusInsight
]

instance CrossDomainIntegrationService : DTDFVocab:Service [
    base:desc "Service enabling cross-domain data exchange between different digital twin instances"
    DTDFVocab:provides IntegrationAlertAction
]

// C17: Insights/Actions
instance PermafrostThawInsight : DTDFVocab:Insight [
    base:desc "Predicted permafrost thaw depth with 5-year forecast and uncertainty quantification"
]

instance StructuralRiskInsight : DTDFVocab:Insight [
    base:desc "Structural safety assessment with remaining service life estimation"
]

instance EcologicalImpactInsight : DTDFVocab:Insight [
    base:desc "Biodiversity impact assessment with species-specific vulnerability metrics"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive 3D visualization of current and predicted environmental conditions"
]

instance AnomalyAlertAction : DTDFVocab:Action [
    base:desc "Automated alert generation for detected anomalies with severity classification"
    DTDFVocab:IsAutomatic true
]

instance TwinStatusInsight : DTDFVocab:Insight [
    base:desc "Current status and health metrics of all digital twin components"
]

instance IntegrationAlertAction : DTDFVocab:Action [
    base:desc "Automated notification for cross-domain data integration events"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance PermafrostCoolingSystemActuator : DTDFVocab:ActingComponent [
    base:desc "Active cooling system for permafrost stabilization with PID temperature control"
]

instance StructuralRepairRobot : DTDFVocab:ActingComponent [
    base:desc "Autonomous robotic system for structural repair with adaptive path planning"
]

instance EnvironmentalMitigationSystem : DTDFVocab:ActingComponent [
    base:desc "Dynamic shading system for radiation management with real-time adjustment"
]

// C1: Environment
instance ArcticPermafrostEnvironment : DTDFVocab:Environment [
    base:desc "Cold climate environment with continuous permafrost conditions"
    base:contains PermafrostTemperatureSensor, SoilMoistureSensor
]

instance CivilInfrastructureEnvironment : DTDFVocab:Environment [
    base:desc "Built environment with structural components requiring health monitoring"
    base:contains StructuralHealthMonitor, StructuralRepairRobot
]

instance EcologicalStudyArea : DTDFVocab:Environment [
    base:desc "Protected area requiring environmental impact assessment"
    base:contains EnvironmentalRadiationSensor, EnvironmentalMitigationSystem
]