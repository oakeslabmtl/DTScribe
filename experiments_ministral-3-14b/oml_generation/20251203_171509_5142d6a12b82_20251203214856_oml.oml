// C3: Physical Sensing Components
instance PermafrostTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "High-precision temperature sensor for permafrost monitoring with ±0.1°C accuracy"
]

instance SoilMoistureSensor : DTDFVocab:SensingComponent [
    base:desc "Capacitive soil moisture sensor with 0-100% volumetric water content range"
]

instance GroundDisplacementSensor : DTDFVocab:SensingComponent [
    base:desc "Fiber-optic distributed temperature sensing (DTS) for ground displacement measurement"
]

instance AtmosphericPressureSensor : DTDFVocab:SensingComponent [
    base:desc "Barometric pressure sensor with 0.1 hPa resolution for atmospheric monitoring"
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PermafrostTemperatureSensor
]

instance MoistureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SoilMoistureSensor
]

instance DisplacementDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GroundDisplacementSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AtmosphericPressureSensor
]

// C10: Models/Data
instance ThermalConductionModel : DTDFVocab:Model [
    base:desc "Finite element model simulating heat transfer in permafrost with seasonal boundary conditions"
    DTDFVocab:inputTo DataProcessingEnabler, VisualizationEnabler
]

instance SoilWaterBalanceModel : DTDFVocab:Model [
    base:desc "Hydrological model predicting soil moisture dynamics using Richards equation"
    DTDFVocab:inputTo DataProcessingEnabler, DecisionSupportEnabler
]

instance TemperatureData : DTDFVocab:Data [
    base:desc "Time-series temperature data with 1-hour resolution from permafrost monitoring network"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, VisualizationEnabler
]

instance MoistureData : DTDFVocab:Data [
    base:desc "Soil moisture measurements with 30-minute interval from capacitive sensors"
    DTDFVocab:fromData MoistureDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, DecisionSupportEnabler
]

instance DisplacementData : DTDFVocab:Data [
    base:desc "Ground displacement measurements with 1-meter spatial resolution from DTS system"
    DTDFVocab:fromData DisplacementDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, StructuralAnalysisEnabler
]

instance PressureData : DTDFVocab:Data [
    base:desc "Atmospheric pressure readings with 5-minute interval for meteorological context"
    DTDFVocab:fromData PressureDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, WeatherCorrectionEnabler
]

// C11: Enablers
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Python-based data processing pipeline using Pandas and NumPy for time-series analysis"
    DTDFVocab:enables MonitoringService, AnomalyDetectionService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Web-based visualization platform using D3.js for interactive permafrost maps"
    DTDFVocab:enables MonitoringService, ReportingService
]

instance DecisionSupportEnabler : DTDFVocab:Enabler [
    base:desc "Machine learning decision support system using scikit-learn for threshold-based alerts"
    DTDFVocab:enables AlertingService
]

instance StructuralAnalysisEnabler : DTDFVocab:Enabler [
    base:desc "Finite element analysis software for structural integrity assessment"
    DTDFVocab:enables StabilityAnalysisService
]

instance WeatherCorrectionEnabler : DTDFVocab:Enabler [
    base:desc "Meteorological data correction module using WRF model outputs"
    DTDFVocab:enables DataQualityService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time dashboard showing current permafrost conditions with historical comparison"
    DTDFVocab:provides PermafrostConditionInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Automated detection of temperature anomalies exceeding ±2 standard deviations"
    DTDFVocab:provides TemperatureAnomalyInsight
    DTDFVocab:provides ThresholdExceededAction
]

instance AlertingService : DTDFVocab:Service [
    base:desc "Multi-channel alerting system (email/SMS) for critical permafrost conditions"
    DTDFVocab:provides CriticalConditionAlertInsight
    DTDFVocab:provides EmergencyNotificationAction
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Automated PDF/Excel reports generated weekly with key performance indicators"
    DTDFVocab:provides WeeklyReportInsight
]

instance StabilityAnalysisService : DTDFVocab:Service [
    base:desc "Structural stability assessment service for infrastructure on permafrost"
    DTDFVocab:provides StabilityRiskInsight
]

instance DataQualityService : DTDFVocab:Service [
    base:desc "Data validation and correction service using statistical quality control"
    DTDFVocab:provides DataQualityInsight
]

// C17: Insights/Actions
instance PermafrostConditionInsight : DTDFVocab:Insight [
    base:desc "Current permafrost temperature and moisture conditions with 30-day trend analysis"
]

instance TemperatureAnomalyInsight : DTDFVocab:Insight [
    base:desc "Detected temperature anomalies with statistical significance and location"
]

instance ThresholdExceededAction : DTDFVocab:Action [
    base:desc "Automated action to trigger maintenance protocols when temperature thresholds exceeded"
    DTDFVocab:IsAutomatic true
]

instance CriticalConditionAlertInsight : DTDFVocab:Insight [
    base:desc "Confirmed critical permafrost conditions requiring immediate attention"
]

instance EmergencyNotificationAction : DTDFVocab:Action [
    base:desc "Automated emergency notification to operations center with severity level"
    DTDFVocab:IsAutomatic true
]

instance WeeklyReportInsight : DTDFVocab:Insight [
    base:desc "Comprehensive weekly report with KPIs, anomalies, and recommendations"
]

instance StabilityRiskInsight : DTDFVocab:Insight [
    base:desc "Assessment of structural stability risk based on current permafrost conditions"
]

instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Data quality metrics including completeness, accuracy, and consistency scores"
]