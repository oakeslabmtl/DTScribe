// C3: Physical Sensing Components
instance PermafrostTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "High-precision temperature sensor for permafrost monitoring with ±0.1°C accuracy"
]

instance SoilMoistureSensor : DTDFVocab:SensingComponent [
    base:desc "Capacitive soil moisture sensor with 0-100% volumetric water content range"
]

instance GroundDisplacementSensor : DTDFVocab:SensingComponent [
    base:desc "Fiber-optic distributed temperature sensing (DTS) for ground displacement measurement"
]

instance AtmosphericPressureSensor : DTDFVocab:SensingComponent [
    base:desc "Barometric pressure sensor with 0.1 hPa resolution for atmospheric monitoring"
]

// C4: Physical-to-Virtual Interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PermafrostTemperatureSensor
]

instance MoistureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SoilMoistureSensor
]

instance DisplacementDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GroundDisplacementSensor
]

instance PressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AtmosphericPressureSensor
]

// C10: Models/Data
instance ThermalConductionModel : DTDFVocab:Model [
    base:desc "Finite element model simulating heat transfer in permafrost with seasonal boundary conditions"
    DTDFVocab:inputTo DataProcessingEnabler, VisualizationEnabler
]

instance SoilWaterBalanceModel : DTDFVocab:Model [
    base:desc "Hydrological model predicting soil moisture dynamics using Richards equation"
    DTDFVocab:inputTo DataProcessingEnabler, SimulationEnabler
]

instance PermafrostDeformationModel : DTDFVocab:Model [
    base:desc "Coupled thermo-mechanical model for ground displacement prediction"
    DTDFVocab:inputTo DataProcessingEnabler, AnalysisEnabler
]

instance RawSensorData : DTDFVocab:Data [
    base:desc "Time-series data from all physical sensors with 15-minute sampling interval"
    DTDFVocab:fromData TemperatureDataTransmitted, MoistureDataTransmitted, DisplacementDataTransmitted, PressureDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance ProcessedEnvironmentalData : DTDFVocab:Data [
    base:desc "Derived environmental parameters including active layer thickness and frost heave rates"
    DTDFVocab:fromData TemperatureDataTransmitted, MoistureDataTransmitted
    DTDFVocab:inputTo VisualizationEnabler, SimulationEnabler
]

// C11: Enablers
instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Python-based data processing pipeline using Pandas and NumPy for real-time calculations"
    DTDFVocab:enables MonitoringService, PredictionService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Web-based visualization platform using Three.js for 3D environmental modeling"
    DTDFVocab:enables MonitoringService, ReportingService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "High-performance computing cluster for running coupled permafrost models"
    DTDFVocab:enables PredictionService, ScenarioAnalysisService
]

instance AnalysisEnabler : DTDFVocab:Enabler [
    base:desc "Machine learning framework for anomaly detection in sensor data"
    DTDFVocab:enables AlertingService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real-time dashboard showing current environmental conditions with historical trends"
    DTDFVocab:provides CurrentConditionsInsight, HistoricalTrendsInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Seasonal forecasting of permafrost conditions using trained neural networks"
    DTDFVocab:provides SeasonalForecastInsight
]

instance ReportingService : DTDFVocab:Service [
    base:desc "Automated PDF/Excel reports generated weekly with key performance indicators"
    DTDFVocab:provides WeeklyReportInsight
]

instance ScenarioAnalysisService : DTDFVocab:Service [
    base:desc "What-if analysis tool for climate change impact scenarios"
    DTDFVocab:provides ScenarioOutcomeInsight
]

instance AlertingService : DTDFVocab:Service [
    base:desc "Automated alert system for critical threshold breaches (e.g., rapid thaw events)"
    DTDFVocab:provides ThresholdAlertAction
]

// C17: Insights/Actions
instance CurrentConditionsInsight : DTDFVocab:Insight [
    base:desc "Real-time display of temperature, moisture, and displacement measurements with color-coded thresholds"
]

instance HistoricalTrendsInsight : DTDFVocab:Insight [
    base:desc "Interactive time-series plots showing 5-year environmental trends with statistical annotations"
]

instance SeasonalForecastInsight : DTDFVocab:Insight [
    base:desc "Probabilistic forecasts of active layer thickness with 95% confidence intervals"
]

instance WeeklyReportInsight : DTDFVocab:Insight [
    base:desc "Standardized report format including KPIs, anomaly summaries, and data quality metrics"
]

instance ScenarioOutcomeInsight : DTDFVocab:Insight [
    base:desc "Visual comparison of baseline vs. scenario projections with impact assessments"
]

instance ThresholdAlertAction : DTDFVocab:Action [
    base:desc "Automated email/SMS notifications to operators when predefined thresholds are exceeded"
    DTDFVocab:IsAutomatic true
]

// C1: System Environment
instance ArcticPermafrostEnvironment : DTDFVocab:Environment [
    base:desc "High-latitude permafrost region with continuous permafrost conditions"
    base:contains PermafrostTemperatureSensor,
                 SoilMoistureSensor,
                 GroundDisplacementSensor,
                 AtmosphericPressureSensor
]