// C3: Physical Sensing Components
instance PermafrostTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "High-precision temperature sensor deployed in permafrost regions to measure ground thermal state with ±0.1°C accuracy at 15-minute intervals"
    DTDFVocab:producedData PermafrostTemperatureDataTransmitted
]

instance SoilMoistureSensor : DTDFVocab:SensingComponent [
    base:desc "Capacitive soil moisture sensor with 1% volumetric water content resolution, sampling every 30 minutes in active layer"
    DTDFVocab:producedData SoilMoistureDataTransmitted
]

instance GroundDisplacementSensor : DTDFVocab:SensingComponent [
    base:desc "Fiber-optic distributed temperature sensing (DTS) system detecting millimeter-scale ground deformation along 500m transects"
    DTDFVocab:producedData GroundDisplacementDataTransmitted
]

instance AtmosphericPressureSensor : DTDFVocab:SensingComponent [
    base:desc "Barometric pressure sensor with 0.1hPa resolution for snow load calculations, transmitting hourly"
    DTDFVocab:producedData AtmosphericPressureDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance PermafrostTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PermafrostTemperatureSensor
    base:desc "LoRaWAN-encrypted temperature telemetry from 12 sensor nodes in 10km² grid"
]

instance SoilMoistureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SoilMoistureSensor
    base:desc "NB-IoT uplinked soil moisture profiles with GPS coordinates and timestamp precision to ±1 second"
]

instance GroundDisplacementDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom GroundDisplacementSensor
    base:desc "High-bandwidth fiber-optic data stream processed via edge node before cloud transmission"
]

instance AtmosphericPressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AtmosphericPressureSensor
    base:desc "MQTT-published pressure readings with 1-minute buffering for snow accumulation modeling"
]

// C10: Models/Data
instance PermafrostThermalModel : DTDFVocab:Model [
    base:desc "3D finite element model using COMSOL Multiphysics with phase change material properties for active layer simulation"
    DTDFVocab:inputTo PermafrostDataProcessingEnabler, VisualizationEnabler
]

instance SoilHydrologicalModel : DTDFVocab:Model [
    base:desc "HYDRUS-1D model calibrated with field data for unsaturated flow in organic soils"
    DTDFVocab:inputTo SoilDataProcessingEnabler, DecisionSupportEnabler
]

instance GroundStabilityModel : DTDFVocab:Model [
    base:desc "Machine learning regression model predicting thaw settlement using DTS deformation patterns"
    DTDFVocab:inputTo StructuralRiskEnabler
]

instance PermafrostTemperatureData : DTDFVocab:Data [
    base:desc "Time-series temperature data with 15-minute resolution, quality-flagged for sensor drift"
    DTDFVocab:fromData PermafrostTemperatureDataTransmitted
    DTDFVocab:inputTo PermafrostDataProcessingEnabler
]

instance SoilMoistureData : DTDFVocab:Data [
    base:desc "Processed soil moisture profiles with depth-specific uncertainty estimates"
    DTDFVocab:fromData SoilMoistureDataTransmitted
    DTDFVocab:inputTo SoilDataProcessingEnabler
]

instance GroundDisplacementData : DTDFVocab:Data [
    base:desc "Processed deformation gradients with spatial smoothing applied"
    DTDFVocab:fromData GroundDisplacementDataTransmitted
    DTDFVocab:inputTo GroundStabilityModel
]

instance AtmosphericPressureData : DTDFVocab:Data [
    base:desc "Hourly pressure readings with snow load conversion factors"
    DTDFVocab:fromData AtmosphericPressureDataTransmitted
    DTDFVocab:inputTo SnowLoadModelingEnabler
]

// C11: Enablers
instance PermafrostDataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Python-based data pipeline using PyTorch for anomaly detection in temperature time series"
    DTDFVocab:enables PermafrostMonitoringService, ThawWarningService
]

instance SoilDataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "R-based workflow for soil moisture data fusion with satellite observations"
    DTDFVocab:enables SoilConditionService, ErosionRiskService
]

instance StructuralRiskEnabler : DTDFVocab:Enabler [
    base:desc "C++ library implementing finite difference methods for settlement prediction"
    DTDFVocab:enables InfrastructureAlertService, MaintenanceRecommendationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Three.js-based web application for 3D permafrost temperature visualization"
    DTDFVocab:enables PermafrostDashboardService
]

instance ArchiveStorageEnabler : DTDFVocab:Enabler [
    base:desc "PostgreSQL time-series database with 10-year retention policy for raw sensor data"
    DTDFVocab:enables DataRetrievalService
]

instance DecisionSupportEnabler : DTDFVocab:Enabler [
    base:desc "Rule-based expert system for infrastructure decision support using IF-THEN logic"
    DTDFVocab:enables CriticalAssetService
]

instance SnowLoadModelingEnabler : DTDFVocab:Enabler [
    base:desc "Specialized model for converting pressure data to snow load estimates"
    DTDFVocab:enables WeatherIntegrationEnabler
]

instance WeatherIntegrationEnabler : DTDFVocab:Enabler [
    base:desc "Service integration layer for combining pressure data with meteorological forecasts"
    DTDFVocab:enables ClimateTrendInsight
]

instance CriticalAssetService : DTDFVocab:Service [
    base:desc "Service identifying critical infrastructure assets at risk from permafrost degradation"
    DTDFVocab:provides StructuralRiskInsight
]

instance PolicyRecommendationService : DTDFVocab:Service [
    base:desc "Service providing policy recommendations based on permafrost degradation analysis"
    DTDFVocab:provides ClimateTrendInsight
]

instance InfrastructureRiskEnabler : DTDFVocab:Enabler [
    base:desc "Risk assessment framework for infrastructure vulnerability to permafrost changes"
    DTDFVocab:enables InfrastructureAlertService
]

instance ClimateModelingEnabler : DTDFVocab:Enabler [
    base:desc "Integration with climate models for long-term permafrost trend analysis"
    DTDFVocab:enables ClimateTrendInsight
]

instance HistoricalAnalysisService : DTDFVocab:Service [
    base:desc "Service providing historical trend analysis of permafrost conditions"
    DTDFVocab:provides ClimateTrendInsight
]

instance ResearchVisualizationService : DTDFVocab:Service [
    base:desc "Service providing advanced visualization tools for research purposes"
    DTDFVocab:provides ClimateTrendInsight
]

// C6: Services
instance PermafrostMonitoringService : DTDFVocab:Service [
    base:desc "Real-time dashboard showing active layer thickness with color-coded thaw status"
    DTDFVocab:provides PermafrostThawInsight
]

instance ThawWarningService : DTDFVocab:Service [
    base:desc "Automated SMS alerts for rapid thaw events exceeding 2°C/day threshold"
    DTDFVocab:provides ThawAlertAction
]

instance SoilConditionService : DTDFVocab:Service [
    base:desc "API endpoint providing soil moisture percentiles for agricultural planning"
    DTDFVocab:provides SoilMoistureInsight
]

instance ErosionRiskService : DTDFVocab:Service [
    base:desc "Geospatial service identifying high-risk erosion zones based on moisture gradients"
    DTDFVocab:provides ErosionWarningAction
]

instance InfrastructureAlertService : DTDFVocab:Service [
    base:desc "Priority-based alerting system for critical infrastructure near thaw-sensitive areas"
    DTDFVocab:provides StructuralRiskInsight
]

instance MaintenanceRecommendationService : DTDFVocab:Service [
    base:desc "AI-generated maintenance schedules optimized for permafrost conditions"
    DTDFVocab:provides MaintenanceAction
]

instance PermafrostDashboardService : DTDFVocab:Service [
    base:desc "Interactive web portal with historical trend analysis and scenario modeling"
    DTDFVocab:provides ClimateTrendInsight
]

instance DataRetrievalService : DTDFVocab:Service [
    base:desc "REST API for querying sensor data with spatial and temporal filters"
    DTDFVocab:provides DataAccessInsight
]

// C17: Insights/Actions
instance PermafrostThawInsight : DTDFVocab:Insight [
    base:desc "Current active layer thickness with 95% confidence interval derived from temperature inversion"
]

instance ThawAlertAction : DTDFVocab:Action [
    base:desc "Automated notification to field crews when thaw rate exceeds safety threshold"
    DTDFVocab:IsAutomatic true
]

instance SoilMoistureInsight : DTDFVocab:Insight [
    base:desc "Volumetric water content at 10cm, 30cm, and 60cm depths with seasonal variability"
]

instance ErosionWarningAction : DTDFVocab:Action [
    base:desc "Geofenced warning system for construction equipment near erosion-prone areas"
    DTDFVocab:IsAutomatic true
]

instance StructuralRiskInsight : DTDFVocab:Insight [
    base:desc "Predicted settlement rates for infrastructure foundations with risk classification"
]

instance MaintenanceAction : DTDFVocab:Action [
    base:desc "Generated work orders with prioritization based on structural risk scores"
    DTDFVocab:IsAutomatic false
]

instance ClimateTrendInsight : DTDFVocab:Insight [
    base:desc "Decadal trends in permafrost temperature with climate model comparison"
]

instance DataAccessInsight : DTDFVocab:Insight [
    base:desc "Metadata about available sensor data including spatial coverage and temporal resolution"
]