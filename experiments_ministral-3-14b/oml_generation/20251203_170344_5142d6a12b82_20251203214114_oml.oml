// C3: Physical Sensing Components
instance PermafrostTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "High-precision temperature sensor deployed in permafrost regions to measure ground thermal state with ±0.1°C accuracy at 15-minute intervals"
    DTDFVocab:producedData PermafrostTemperatureDataTransmitted
]

instance SoilMoistureSensor : DTDFVocab:SensingComponent [
    base:desc "Capacitance-based soil moisture sensor with 3% volumetric water content resolution, sampling every 30 minutes in active layer"
    DTDFVocab:producedData SoilMoistureDataTransmitted
]

instance ThawDepthProbe : DTDFVocab:SensingComponent [
    base:desc "Acoustic depth sensor measuring active layer thickness with ±2cm precision, triggered by temperature threshold crossings"
    DTDFVocab:producedData ThawDepthDataTransmitted
]

instance MethaneFluxChamber : DTDFVocab:SensingComponent [
    base:desc "Closed-path eddy covariance chamber measuring CH4 emissions at 1Hz frequency with 0.1ppm resolution"
    DTDFVocab:producedData MethaneFluxDataTransmitted
]

instance VegetationCanopyCamera : DTDFVocab:SensingComponent [
    base:desc "Multispectral camera (450-900nm) capturing NDVI and canopy structure at 10-minute intervals during daylight"
    DTDFVocab:producedData VegetationCanopyDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance PermafrostTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PermafrostTemperatureSensor
]

instance SoilMoistureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SoilMoistureSensor
]

instance ThawDepthDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ThawDepthProbe
]

instance MethaneFluxDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom MethaneFluxChamber
]

instance VegetationCanopyDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VegetationCanopyCamera
]

// C10: Models/Data
instance PermafrostThermalModel : DTDFVocab:Model [
    base:desc "Finite difference heat transfer model with phase change capability, parameterized by soil thermal properties and boundary conditions"
    DTDFVocab:inputTo PermafrostModelEnabler
]

instance SoilMoistureBalanceModel : DTDFVocab:Model [
    base:desc "Richard's equation-based model accounting for frost heave and capillary effects in unsaturated zone"
    DTDFVocab:inputTo SoilMoistureEnabler
]

instance MethaneEmissionsModel : DTDFVocab:Model [
    base:desc "Process-based model combining microbial kinetics, substrate availability, and temperature dependence (Q10=2.5)"
    DTDFVocab:inputTo MethaneModelEnabler
]

instance VegetationProductivityModel : DTDFVocab:Model [
    base:desc "Light-use efficiency model with temperature acclimation parameters for Arctic tundra species"
    DTDFVocab:inputTo VegetationEnabler
]

instance PermafrostTemperatureData : DTDFVocab:Data [
    base:desc "Time-series temperature measurements at 10cm, 30cm, and 100cm depths with metadata including sensor calibration coefficients"
    DTDFVocab:fromData PermafrostTemperatureDataTransmitted
    DTDFVocab:inputTo PermafrostModelEnabler, DataVisualizationEnabler
]

instance SoilMoistureData : DTDFVocab:Data [
    base:desc "Volumetric water content profiles with uncertainty estimates derived from sensor calibration curves"
    DTDFVocab:fromData SoilMoistureDataTransmitted
    DTDFVocab:inputTo SoilMoistureEnabler, DataValidationEnabler
]

instance ThawDepthData : DTDFVocab:Data [
    base:desc "Active layer thickness measurements with temporal derivatives calculated for thaw rate analysis"
    DTDFVocab:fromData ThawDepthDataTransmitted
    DTDFVocab:inputTo ThawDepthEnabler
]

instance MethaneFluxData : DTDFVocab:Data [
    base:desc "High-frequency CH4 flux measurements with quality flags for periods of sensor drift or maintenance"
    DTDFVocab:fromData MethaneFluxDataTransmitted
    DTDFVocab:inputTo MethaneModelEnabler, EmissionInventoryEnabler
]

instance VegetationCanopyData : DTDFVocab:Data [
    base:desc "Multispectral imagery with derived vegetation indices (NDVI, EVI) and canopy height estimates from stereo reconstruction"
    DTDFVocab:fromData VegetationCanopyDataTransmitted
    DTDFVocab:inputTo VegetationEnabler, PhenologyTrackingEnabler
]

// C11: Enablers
instance PermafrostModelEnabler : DTDFVocab:Enabler [
    base:desc "High-performance computing cluster with parallelized finite difference solver and GPU-accelerated phase change calculations"
    DTDFVocab:enables PermafrostForecastService, ThawDepthAnalysisService
]

instance SoilMoistureEnabler : DTDFVocab:Enabler [
    base:desc "Hydrological modeling framework with inverse modeling capabilities for parameter estimation"
    DTDFVocab:enables SoilMoistureForecastService, FrostHeaveWarningService
]

instance MethaneModelEnabler : DTDFVocab:Enabler [
    base:desc "Biogeochemical modeling platform with machine learning components for parameter optimization"
    DTDFVocab:enables MethaneFluxService, EmissionScenarioService
]

instance VegetationEnabler : DTDFVocab:Enabler [
    base:desc "Remote sensing processing toolkit with cloud masking and atmospheric correction algorithms"
    DTDFVocab:enables VegetationHealthService, PhenologyTrendService
]

instance DataVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Interactive 3D visualization platform with time-slicing capabilities for permafrost temperature profiles"
    DTDFVocab:enables PermafrostMonitoringService, DataExplorationService
]

instance DataValidationEnabler : DTDFVocab:Enabler [
    base:desc "Automated quality control system with statistical process control for sensor data streams"
    DTDFVocab:enables DataQualityService
]

instance ThawDepthEnabler : DTDFVocab:Enabler [
    base:desc "Geostatistical analysis toolkit for spatial interpolation of active layer thickness measurements"
    DTDFVocab:enables ThawDepthMappingService
]

instance EmissionInventoryEnabler : DTDFVocab:Enabler [
    base:desc "Greenhouse gas accounting system with Tier 2 methodology implementation"
    DTDFVocab:enables EmissionReportingService
]

instance PhenologyTrackingEnabler : DTDFVocab:Enabler [
    base:desc "Time-series analysis package with phenological transition detection algorithms"
    DTDFVocab:enables PhenologyAlertService
]

// C6: Services
instance PermafrostForecastService : DTDFVocab:Service [
    base:desc "Seasonal permafrost temperature predictions with 95% confidence intervals"
    DTDFVocab:provides PermafrostTemperatureInsight
]

instance ThawDepthAnalysisService : DTDFVocab:Service [
    base:desc "Active layer thickness trend analysis with statistical significance testing"
    DTDFVocab:provides ThawDepthInsight
]

instance SoilMoistureForecastService : DTDFVocab:Service [
    base:desc "7-day soil moisture predictions with frost susceptibility indicators"
    DTDFVocab:provides SoilMoistureInsight
]

instance FrostHeaveWarningService : DTDFVocab:Service [
    base:desc "Automated alerts for critical frost heave conditions based on moisture and temperature thresholds"
    DTDFVocab:provides FrostHeaveAction
]

instance MethaneFluxService : DTDFVocab:Service [
    base:desc "Real-time CH4 flux monitoring with anomaly detection for sudden emission spikes"
    DTDFVocab:provides MethaneFluxInsight
]

instance EmissionScenarioService : DTDFVocab:Service [
    base:desc "Projected methane emission scenarios under different warming trajectories"
    DTDFVocab:provides EmissionScenarioInsight
]

instance VegetationHealthService : DTDFVocab:Service [
    base:desc "Vegetation stress assessment using multispectral indices and historical baselines"
    DTDFVocab:provides VegetationHealthInsight
]

instance PhenologyTrendService : DTDFVocab:Service [
    base:desc "Long-term phenological trend analysis with climate change attribution"
    DTDFVocab:provides PhenologyTrendInsight
]

instance PermafrostMonitoringService : DTDFVocab:Service [
    base:desc "Dashboards showing real-time permafrost conditions with historical comparisons"
    DTDFVocab:provides PermafrostMonitoringInsight
]

instance DataExplorationService : DTDFVocab:Service [
    base:desc "Interactive data exploration with custom query capabilities for permafrost researchers"
    DTDFVocab:provides DataExplorationInsight
]

instance DataQualityService : DTDFVocab:Service [
    base:desc "Automated data quality reports with flagged anomalies and correction recommendations"
    DTDFVocab:provides DataQualityInsight
]

instance ThawDepthMappingService : DTDFVocab:Service [
    base:desc "Spatial maps of active layer thickness with uncertainty visualization"
    DTDFVocab:provides ThawDepthMappingInsight
]

instance EmissionReportingService : DTDFVocab:Service [
    base:desc "Standardized emission reports compatible with IPCC guidelines"
    DTDFVocab:provides EmissionReportingInsight
]

instance PhenologyAlertService : DTDFVocab:Service [
    base:desc "Automated alerts for significant phenological transitions detected in vegetation cycles"
    DTDFVocab:provides PhenologyAlertAction
]

// C17: Insights/Actions
instance PermafrostTemperatureInsight : DTDFVocab:Insight [
    base:desc "Current permafrost temperature state with 3-year warming trend analysis"
]

instance ThawDepthInsight : DTDFVocab:Insight [
    base:desc "Active layer thickness measurements with decadal change rates"
]

instance SoilMoistureInsight : DTDFVocab:Insight [
    base:desc "Soil moisture conditions with frost susceptibility assessment"
]

instance FrostHeaveAction : DTDFVocab:Action [
    base:desc "Automated infrastructure warning system for critical frost heave events"
    DTDFVocab:IsAutomatic true
]

instance MethaneFluxInsight : DTDFVocab:Insight [
    base:desc "Real-time methane flux measurements with emission source identification"
]

instance EmissionScenarioInsight : DTDFVocab:Insight [
    base:desc "Projected methane emissions under RCP 4.5 and RCP 8.5 scenarios"
]

instance VegetationHealthInsight : DTDFVocab:Insight [
    base:desc "Vegetation stress indicators with species-specific vulnerability assessment"
]

instance PhenologyTrendInsight : DTDFVocab:Insight [
    base:desc "Long-term phenological shifts with climate change attribution"
]

instance PermafrostMonitoringInsight : DTDFVocab:Insight [
    base:desc "Comprehensive permafrost monitoring dashboard with historical comparisons"
]

instance DataExplorationInsight : DTDFVocab:Insight [
    base:desc "Customizable data exploration results for permafrost research queries"
]

instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Automated data quality assessment with anomaly detection results"
]

instance ThawDepthMappingInsight : DTDFVocab:Insight [
    base:desc "Spatial maps of active layer thickness with uncertainty visualization"
]

instance EmissionReportingInsight : DTDFVocab:Insight [
    base:desc "Standardized emission reports ready for regulatory submission"
]

instance PhenologyAlertAction : DTDFVocab:Action [
    base:desc "Automated notification system for significant phenological transitions"
    DTDFVocab:IsAutomatic true
]