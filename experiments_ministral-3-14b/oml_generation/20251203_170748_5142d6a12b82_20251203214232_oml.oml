// C3: Physical sensing components
instance PermafrostTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "High-precision temperature sensor for permafrost monitoring with ±0.1°C accuracy"
    DTDFVocab:producedData PermafrostTemperatureDataTransmitted
]

instance SoilMoistureSensor : DTDFVocab:SensingComponent [
    base:desc "Capacitive soil moisture sensor with 0-100% volumetric water content measurement range"
    DTDFVocab:producedData SoilMoistureDataTransmitted
]

instance StructuralStrainSensor : DTDFVocab:SensingComponent [
    base:desc "Fiber optic strain sensor array for structural health monitoring with 1µε resolution"
    DTDFVocab:producedData StructuralStrainDataTransmitted
]

instance EnvironmentalHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Industrial-grade humidity sensor with ±2% RH accuracy for environmental conditions"
    DTDFVocab:producedData EnvironmentalHumidityDataTransmitted
]

// C4: Physical-to-virtual interaction
instance PermafrostTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PermafrostTemperatureSensor
]

instance SoilMoistureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SoilMoistureSensor
]

instance StructuralStrainDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StructuralStrainSensor
]

instance EnvironmentalHumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalHumiditySensor
]

// C10: Models/Data
instance PermafrostThermalModel : DTDFVocab:Model [
    base:desc "Finite element thermal model simulating permafrost degradation with 1m³ resolution"
    DTDFVocab:inputTo DigitalTwinSimulationEngine
]

instance StructuralHealthModel : DTDFVocab:Model [
    base:desc "Dynamic structural response model using ANSYS simulation framework"
    DTDFVocab:inputTo DigitalTwinSimulationEngine
]

instance EnvironmentalConditionData : DTDFVocab:Data [
    base:desc "Historical and real-time environmental data including temperature, humidity, and solar radiation"
    DTDFVocab:fromData EnvironmentalHumidityDataTransmitted
    DTDFVocab:inputTo DataProcessingPipeline
]

instance SensorCalibrationData : DTDFVocab:Data [
    base:desc "Calibration datasets for all physical sensors with timestamped reference measurements"
    DTDFVocab:fromData PermafrostTemperatureDataTransmitted, SoilMoistureDataTransmitted, StructuralStrainDataTransmitted
    DTDFVocab:inputTo DataProcessingPipeline
]

// C11: Enablers
instance DigitalTwinSimulationEngine : DTDFVocab:Enabler [
    base:desc "High-performance computing cluster running COMSOL Multiphysics for digital twin simulations"
    DTDFVocab:enables PermafrostDegradationService, StructuralHealthService
]

instance DataProcessingPipeline : DTDFVocab:Enabler [
    base:desc "Apache Kafka-based stream processing pipeline with Spark for real-time data analysis"
    DTDFVocab:enables MonitoringDashboardService, PredictiveMaintenanceService
]

instance EdgeComputingGateway : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 cluster with LoRaWAN gateway for local data preprocessing"
    DTDFVocab:enables SensorDataAggregationService
]

// C6: Services
instance PermafrostDegradationService : DTDFVocab:Service [
    base:desc "Service providing permafrost stability analysis and degradation predictions"
    DTDFVocab:provides PermafrostStabilityInsight
]

instance StructuralHealthService : DTDFVocab:Service [
    base:desc "Service monitoring structural integrity with fatigue life predictions"
    DTDFVocab:provides StructuralFatigueInsight, EmergencyActionTrigger
]

instance MonitoringDashboardService : DTDFVocab:Service [
    base:desc "Real-time visualization dashboard with customizable alert thresholds"
    DTDFVocab:provides EnvironmentalConditionInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive maintenance scheduling based on structural health data"
    DTDFVocab:provides MaintenanceRecommendationAction
]

instance SensorDataAggregationService : DTDFVocab:Service [
    base:desc "Service aggregating and validating sensor data before transmission"
    DTDFVocab:provides DataQualityInsight
]

// C17: Insights/Actions
instance PermafrostStabilityInsight : DTDFVocab:Insight [
    base:desc "Quantitative assessment of permafrost stability with confidence intervals"
]

instance StructuralFatigueInsight : DTDFVocab:Insight [
    base:desc "Remaining useful life estimation for critical structural components"
]

instance EnvironmentalConditionInsight : DTDFVocab:Insight [
    base:desc "Current environmental conditions with historical comparison and anomaly detection"
]

instance DataQualityInsight : DTDFVocab:Insight [
    base:desc "Real-time assessment of sensor data quality and potential measurement errors"
]

instance EmergencyActionTrigger : DTDFVocab:Action [
    base:desc "Automated trigger for emergency response protocols based on structural thresholds"
    DTDFVocab:IsAutomatic true
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Suggested maintenance actions with priority levels and estimated costs"
    DTDFVocab:IsAutomatic false
]

// C1: System Environment
instance ArcticInfrastructureEnvironment : DTDFVocab:Environment [
    base:desc "Physical environment containing all monitoring infrastructure in Arctic permafrost regions"
    base:contains PermafrostTemperatureSensor,
                 SoilMoistureSensor,
                 StructuralStrainSensor,
                 EnvironmentalHumiditySensor,
                 EdgeComputingGateway
]