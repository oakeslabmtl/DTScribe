// C3: Physical sensing components
instance InsideTempSensorLeft : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor mounted inside the left side of the styrofoam insulated incubator box"
    DTDFVocab:producedData InsideTempSensorLeftMessage
]

instance InsideTempSensorRight : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor mounted inside the right side of the styrofoam insulated incubator box"
    DTDFVocab:producedData InsideTempSensorRightMessage
]

instance RoomTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor mounted outside the incubator to monitor ambient room temperature"
    DTDFVocab:producedData RoomTempSensorMessage
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance InsideTempSensorLeftMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensorLeft
    DTDFVocab:fromData InsideTempData_Left
]

instance InsideTempSensorRightMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensorRight
    DTDFVocab:fromData InsideTempData_Right
]

instance RoomTempSensorMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTempSensor
    DTDFVocab:fromData RoomTempData
]

// C10: Models/Data
instance InsideTempData_Left : DTDFVocab:Data [
    base:desc "Temperature data (°C) from InsideTempSensorLeft, transmitted via RabbitMQ"
    DTDFVocab:inputTo RabbitMQBroker
    DTDFVocab:fromData InsideTempSensorLeftMessage
]

instance InsideTempData_Right : DTDFVocab:Data [
    base:desc "Temperature data (°C) from InsideTempSensorRight, transmitted via RabbitMQ"
    DTDFVocab:inputTo RabbitMQBroker
    DTDFVocab:fromData InsideTempSensorRightMessage
]

instance RoomTempData : DTDFVocab:Data [
    base:desc "Ambient room temperature data (°C) transmitted via RabbitMQ"
    DTDFVocab:inputTo RabbitMQBroker
    DTDFVocab:fromData RoomTempSensorMessage
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker used to transmit sensor data from low‑level driver to the digital twin"
    DTDFVocab:enables ServiceMonitoring, ServiceSafetyMonitoring
]

instance PythonRuntime : DTDFVocab:Enabler [
    base:desc "Python runtime environment on the Raspberry Pi 4 that executes thermal models and optimisation routines using Scipy"
    DTDFVocab:enables ServiceCalibration, ServiceSimulation
]

// C2: Acting components (kept once)
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET/optocoupler circuit that switches the heatbed on and off via the Raspberry Pi controller"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET/optocoupler circuit that switches the fan on and off via the Raspberry Pi controller"
]

// C0: Physical components
instance InsulatedBoxComponent : DTDFVocab:Component [
    base:desc "Styrofoam insulated box that houses the heatbed and interior sensors"
]

instance HeatbedHardware : DTDFVocab:Component [
    base:desc "Electric calefaction element (heatbed) supplied with power via MOSFET driver"
]

instance FanHardware : DTDFVocab:Component [
    base:desc "Electric fan powered and controlled via MOSFET driver for airflow"
]

instance RaspberryPi4Controller : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 running low‑level driver and control software"
]

instance MOSFETDriverCircuit : DTDFVocab:Component [
    base:desc "MOSFET driver board that switches power to the heatbed and fan"
]

instance OptocouplerIsolation : DTDFVocab:Component [
    base:desc "Optocoupler isolation circuit to protect the Raspberry Pi from high‑voltage MOSFET driver"
]

instance DS18S20SensorSet : DTDFVocab:Component [
    base:desc "Set of three DS18S20 1‑Wire digital temperature sensors inside the incubator"
]

// C6: Services
instance ServiceMonitoring : DTDFVocab:Service [
    base:desc "Real‑time monitoring service that ingests temperature data and tracks PT states"
    DTDFVocab:provides InsightRealTimeMonitoring
]

instance ServiceSimulation : DTDFVocab:Service [
    base:desc "Simulation service that runs ModelA and ModelB to predict temperature dynamics"
    DTDFVocab:provides InsightPredictedTemperatureProfiles
]

instance ServiceCalibration : DTDFVocab:Service [
    base:desc "Calibration service that performs nonlinear least‑squares optimisation to refine model parameters"
    DTDFVocab:provides InsightCalibratedParameterEstimates
]

instance ServiceSafetyMonitoring : DTDFVocab:Service [
    base:desc "Safety monitoring service that detects operating violations and can trigger corrective actions"
    DTDFVocab:provides InsightFaultDetectionAlert, ActionAdjustControlParameters
]

// C17: Insights/Actions
instance InsightRealTimeMonitoring : DTDFVocab:Insight [
    base:desc "Continuous display of instantaneous temperature readings and actuator states within the incubator"
]

instance InsightPredictedTemperatureProfiles : DTDFVocab:Insight [
    base:desc "Predicted temperature profiles over time generated by the validated thermal models"
]

instance InsightCalibratedParameterEstimates : DTDFVocab:Insight [
    base:desc "Calibrated parameter values for the selected thermal models derived from experimental data"
]

instance InsightFaultDetectionAlert : DTDFVocab:Insight [
    base:desc "Alert generated when sensor readings exceed pre‑defined safety thresholds, indicating potential operating violations"
]

instance ActionAdjustControlParameters : DTDFVocab:Action [
    base:desc "Automatic adjustment of control parameters such as heating duration H and waiting duration C based on model predictions and fault detections"
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance ModelA : DTDFVocab:Model [
    base:desc "Single‑temperature model with parameters C_air and G_box representing the thermal dynamics of the incubator"
    DTDFVocab:inputTo PythonRuntime
]

instance ModelB : DTDFVocab:Model [
    base:desc "Two‑temperature model with parameters C_air, C_heater, G_box, G_heater for detailed heatbed influence"
    DTDFVocab:inputTo PythonRuntime
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (heatbed ON/OFF, fan ON/OFF, heating duration H, waiting duration C) are transmitted from the DT to the Raspberry Pi via RabbitMQ; the low‑level driver translates these into GPIO pulses that drive the MOSFET/optocoupler circuits."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centrally hosted constellation comprising: a RabbitMQ broker; a Python‑based controller that implements bang‑bang temperature control; a low‑level driver on the Raspberry Pi that interfaces with sensors and actuators; and the two simulation models (A and B) that receive sensor data and generate predictions."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design – derivation of the dynamic heat transfer models; Manufacture – construction of the physical incubator and assembly of the Raspberry Pi, PCB, sensors and actuators; Operation – deployment of the DT for real‑time monitoring, simulation, calibration, and control during daily use."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity is assessed by minimising the residual error between measured and simulated temperatures during calibration; validity depends on the assumptions (uniform temperature, negligible wall heat, constant specific heat, negligible fan heat) which are verified via experiments; model parameters are calibrated to fit the observed temperature trajectories."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data flow between PT and DT occurs over a RabbitMQ message broker; the Raspberry Pi uses its built‑in Wi‑Fi for network connectivity, and sensors are connected via the 1‑Wire bus while actuators are commanded through GPIO pins."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted on the Raspberry Pi 4 itself, running the Python control and calibration services, with all models and data stored locally in the project repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is incorporated in the low‑level driver to prevent unsafe actuation states; however specific cybersecurity measures (e.g., encryption) are not detailed in the document."
]