// -------------------------------
// Physical Sensing Components
// -------------------------------

instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "First interior temperature sensor inside the insulated styrofoam box."
    DTDFVocab:producedData InternalTempReadingA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Second interior temperature sensor inside the insulated styrofoam box."
    DTDFVocab:producedData InternalTempReadingB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "Exterior temperature sensor mounted on the incubator housing."
    DTDFVocab:producedData ExternalTempReading
]

// -------------------------------
// Physical Acting Components
// -------------------------------

instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that supplies heat to the air volume inside the incubator."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal fan that circulates heated air to homogenize temperature."
]

// -------------------------------
// Data Transmission (Physical → Virtual)
// -------------------------------

instance InternalTempReadingA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempReadingB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempReading : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// -------------------------------
// Virtual Data Objects
// -------------------------------

instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Temperature value (with timestamp) received from InternalTempSensorA."
    DTDFVocab:fromData InternalTempReadingA
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine
]

instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Temperature value (with timestamp) received from InternalTempSensorB."
    DTDFVocab:fromData InternalTempReadingB
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Temperature value (with timestamp) received from ExternalTempSensor."
    DTDFVocab:fromData ExternalTempReading
    DTDFVocab:inputTo CalibrationEngine
]

// -------------------------------
// Models
// -------------------------------

instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model of the incubator based on all four simplifying assumptions."
    DTDFVocab:inputTo CalibrationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Analytical thermal model that relaxes Assumption 4 and accounts for the heat‑bed’s thermal inertia."
    DTDFVocab:inputTo KalmanFilterEngine, CoSimulationEngine
]

// -------------------------------
// Enablers (Tools & Infrastructure)
// -------------------------------

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "AMQP message broker used for publish/subscribe communication between driver, controller and other DT components."
    DTDFVocab:enables RealTimeMonitoringService, SelfAdaptationService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time‑series database that stores incoming temperature telemetry for visualization, calibration and state estimation."
    DTDFVocab:enables RealTimeMonitoringService, ModelCalibrationService, HeatBedStateEstimationService
]

instance DashboardEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard that visualises temperature streams, controller status and diagnostic insights."
    DTDFVocab:enables RealTimeMonitoringService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Automated calibration algorithm that updates parameters of ThermalModelA and ThermalModelB using sensor data."
    DTDFVocab:enables ModelCalibrationService
]

instance KalmanFilterEngine : DTDFVocab:Enabler [
    base:desc "Kalman‑filter implementation that fuses sensor measurements with ThermalModelB to estimate heat‑bed state and detect anomalies."
    DTDFVocab:enables HeatBedStateEstimationService
]

instance CoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation infrastructure that runs what‑if analyses by coupling ThermalModelB with alternative controller parameters."
    DTDFVocab:enables WhatIfSimulationService
]

// -------------------------------
// Services Provided by the Digital Twin
// -------------------------------

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring and visualization of internal and external temperature streams."
    DTDFVocab:provides TemperatureVisualizationInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "On‑demand calibration of ThermalModelA and ThermalModelB using automated tracking‑simulator routines."
    DTDFVocab:provides ModelCalibrationInsight
]

instance HeatBedStateEstimationService : DTDFVocab:Service [
    base:desc "Anomaly detection and heat‑bed state estimation via Kalman filter fusion of sensor data and ThermalModelB."
    DTDFVocab:provides HeatBedStateEstimationInsight, AnomalyDetectionInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Predictive what‑if simulations that evaluate alternative bang‑bang controller parameters."
    DTDFVocab:provides WhatIfAnalysisInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Closed‑loop self‑adaptation loop that detects behavioural changes, triggers re‑calibration, re‑configures the Kalman filter and updates the controller automatically."
    DTDFVocab:provides SelfAdaptationAction
]

// -------------------------------
// Insights and Actions
// -------------------------------

instance TemperatureVisualizationInsight : DTDFVocab:Insight [
    base:desc "Operator‑facing visualisation of real‑time temperature values and controller status on the dashboard."
]

instance ModelCalibrationInsight : DTDFVocab:Insight [
    base:desc "Feedback on calibrated parameter values for ThermalModelA and ThermalModelB."
]

instance HeatBedStateEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated heat‑bed power state derived from Kalman filter fusion."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature anomalies indicating possible disturbances (e.g., cold object introduction)."
]

instance WhatIfAnalysisInsight : DTDFVocab:Insight [
    base:desc "Results of co‑simulation scenarios showing predicted temperature trajectories under alternative controller settings."
]

instance SelfAdaptationAction : DTDFVocab:Action [
    base:desc "Automatic re‑configuration of controller parameters, re‑calibration of models and re‑deployment of updated controller logic."
    DTDFVocab:IsAutomatic true
]

// -------------------------------
// Additional Physical Components (for completeness)
// -------------------------------

instance RaspberryPiHost : DTDFVocab:Component [
    base:desc "Raspberry Pi that runs the low‑level driver, bang‑bang controller and hosts the DT software stack."
]

instance LowLevelDriver : DTDFVocab:Component [
    base:desc "Low‑level driver that abstracts sensor/actuator I/O, formats readings as AMQP messages and enforces a safe‑state protocol."
]

instance BangBangController : DTDFVocab:Component [
    base:desc "Bang‑bang controller implementing lower‑limit (LL), upper‑limit (UL), heating duration (H) and cooling/wait duration (C) logic."
]

// -------------------------------
// Environment Definition
// -------------------------------

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InternalTempSensorA, InternalTempSensorB, ExternalTempSensor,
                HeatBedActuator, FanActuator,
                RaspberryPiHost, LowLevelDriver, BangBangController,
                RabbitMQBroker, TimeSeriesDatabase, DashboardEnabler
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the Digital Twin (e.g., turn fan on/off, activate heat‑bed for a specified heating duration, waiting duration) are packaged as AMQP messages and sent via RabbitMQ to the low‑level driver. The driver validates the commands using its safe protocol, translates them into actuator signals for the fan and heat‑bed, and acknowledges execution back through the broker. This round‑trip provides feedback on command execution status."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The low‑level driver periodically reads temperature sensors and uploads the measurements to a RabbitMQ message broker; the controller also sends fan and heat‑bed command messages to the same broker. All DT components (real‑time visualisation, calibration service, Kalman‑filter estimator, what‑if simulator) subscribe to these streams, providing near‑real‑time synchronization between the physical twin and the digital twin. Temporal granularity is determined by the sensor polling interval (unspecified) and the low latency of RabbitMQ message propagation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The incubator DT follows a CPS‑based architecture where the physical twin (heat‑bed, fan, sensors) is linked to a cyber layer composed of a low‑level driver, a bang‑bang controller running on a Raspberry Pi, and a RabbitMQ message broker that mediates all communications. DT services—including a time‑series store for visualization, an on‑demand calibration module, a Kalman‑filter state estimator, and a co‑simulation what‑if engine—are implemented as independent components that subscribe to the broker. Coordination and orchestration are achieved through message passing, allowing the DT to close the control loop by feeding calibration results back to the controller and re‑configuring it as needed."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The documents describe a lifecycle that starts with model development (e.g., CAD model of the incubator box and dynamic temperature models Model A and Model B), proceeds to integration where the Physical Twin (PT) is equipped with sensors and actuators and the models, data streams and algorithms are assembled into a Digital Twin (DT). After deployment, the DT enters an operational stage that continuously collects sensor data, runs calibration algorithms to update model parameters, and executes monitors that assess safety and optimality. When violations are detected, a response stage allows humans or algorithms to modify the PT (e.g., re‑configure the controller). The cycle repeats, supporting continual adaptation and re‑calibration."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is governed by four simplifying assumptions (uniform temperature, negligible wall heat storage, constant specific heat capacity, and that all electrical power becomes heat). Model B relaxes the fourth assumption, improving prediction of the heat‑bed’s thermal inertia, as demonstrated in the experimental results. Validation is performed by comparing model predictions against the recorded temperature data from the three sensors; calibration algorithms adjust model parameters on‑demand to minimise prediction error. Uncertainty arises from the violated assumptions (e.g., wall heat accumulation, fan power loss) and from sensor noise. Anomaly detection is achieved with a Kalman filter that flags deviations between measured and estimated states, and monitors check safe operation. The DT relies on continuous calibration and monitoring to assure model and data quality."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT and Physical Twin communicate through a RabbitMQ message broker implementing the AMQP protocol over TCP/IP. The Raspberry Pi runs the low‑level driver and controller that publish and subscribe to queues; DT services (visualisation, calibration, anomaly detection) also connect as clients. RabbitMQ offers reliable message delivery with acknowledgements, can be clustered for redundancy, and is deployable on‑premise or in the cloud, supporting the tens‑of‑thousands‑of‑users scalability claim. No explicit bandwidth, latency, or security (e.g., TLS) specifications are provided in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through the RabbitMQ message broker, which routes sensor data, control commands, and DT service outputs to any component that can connect to the broker. This enables dashboards, analytics tools, or other digital twins to consume and produce data streams. Additionally, the complete hardware and software specifications are released in a public GitHub repository, facilitating further coupling with enterprise IT environments and other external applications."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The incubator DT incorporates a safety‑oriented low‑level driver that embeds a safe protocol to keep the physical device in a safe state. The controller enforces upper‑limit (UL) and lower‑limit (LL) temperature thresholds, a heating duration (H) and a waiting duration (C) to prevent overheating, and monitors sensor readings to trigger safe shutdowns if limits are breached. Anomaly detection and heat‑bed state estimation are performed by a Kalman filter using Model B, providing runtime fault detection. Communication between the controller, low‑level driver, and DT components is realized via a RabbitMQ message broker; while no explicit authentication or encryption mechanisms are described, the architecture relies on the broker’s message‑passing semantics to coordinate safe operation. Calibration routines and what‑if simulations run on‑line to keep the twin aligned with the physical twin, supporting fail‑safe re‑configuration when abnormal behavior is detected."
]