// Physical Sensing Components
instance DS18S20TempSensor1 : DTDFVocab:SensingComponent [
    base:desc "High-Precision DS18S20 1-Wire Digital Thermometer sensor for internal temperature monitoring with -55°C to +125°C range and ±0.5°C accuracy"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance DS18S20TempSensor2 : DTDFVocab:SensingComponent [
    base:desc "High-Precision DS18S20 1-Wire Digital Thermometer sensor for internal temperature monitoring with -55°C to +125°C range and ±0.5°C accuracy"
    DTDFVocab:producedData TemperatureDataTransmitted
]

// Physical Acting Components
instance Heatbed : DTDFVocab:ActingComponent [
    base:desc "Heatbed for heating content within styrofoam box in thermal incubator system"
]

instance CoolingFan : DTDFVocab:ActingComponent [
    base:desc "Cooling fan for thermal distribution in thermal incubator system"
]

// Physical System Components
instance StyrofoamBox : DTDFVocab:Component [
    base:desc "Styrofoam box for insulation in thermal incubator system"
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi microcontroller acting as embedded controller hardware interfacing with physical components"
]

// Data Flow Elements
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20TempSensor1, DS18S20TempSensor2
]

instance ThermalIncubatorTemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature data from DS18S20 sensors for thermal incubator system"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo RabbitMQEnabler, TimeSeriesDatabaseEnabler
]

// Models
instance CADModel : DTDFVocab:Model [
    base:desc "Computer-Aided Design model for structural dimensions of thermal incubator system"
    DTDFVocab:inputTo SciPyEnabler
]

instance ThermalDynamicsModel : DTDFVocab:Model [
    base:desc "Behavioral model described by differential equations for thermal dynamics analysis"
    DTDFVocab:inputTo SciPyEnabler
]

// Enablers
instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ communication server for data exchange between sensors and Digital Twin"
    DTDFVocab:enables MonitoringService
]

instance SciPyEnabler : DTDFVocab:Enabler [
    base:desc "Python SciPy package for numerical optimization and solving thermal dynamics equations"
    DTDFVocab:enables OptimizationService, PredictiveSimulationService, FaultDetectionService, StateEstimationService, ControlService
]

instance MQTTEnabler : DTDFVocab:Enabler [
    base:desc "MQTT protocol for lightweight messaging between components"
    DTDFVocab:enables MonitoringService
]

instance TimeSeriesDatabaseEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database for historical data storage"
    DTDFVocab:enables MonitoringService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitoring service to assess safety and optimal performance through real-time data analysis"
    DTDFVocab:provides SafetyAssessmentInsight, OptimalityAssessmentInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation capabilities to replicate and forecast PT behavior under current conditions"
    DTDFVocab:provides PredictiveSimulationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization via algorithmic optimisers"
    DTDFVocab:provides OptimizationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection and diagnostics"
    DTDFVocab:provides FaultDetectionInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "State estimation for diagnostics"
    DTDFVocab:provides StateEstimationInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Control through supervisory controllers"
    DTDFVocab:provides ControlAction
]

// Insights
instance SafetyAssessmentInsight : DTDFVocab:Insight [
    base:desc "Safety assessment based on real-time temperature monitoring and model parameters"
]

instance OptimalityAssessmentInsight : DTDFVocab:Insight [
    base:desc "Optimality assessment for thermal performance of incubator system"
]

instance PredictiveSimulationInsight : DTDFVocab:Insight [
    base:desc "Predictive simulation of physical twin behavior under current conditions"
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization insights for thermal control parameters"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Fault detection insights from sensor data analysis"
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "State estimation for current system conditions"
]

// Actions
instance ControlAction : DTDFVocab:Action [
    base:desc "Corrective actions initiated by supervisory controllers for thermal incubator system"
    DTDFVocab:IsAutomatic true
]

// Environment
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Thermal incubator system environment for laboratory or medical applications"
    base:contains StyrofoamBox, Heatbed, CoolingFan, DS18S20TempSensor1, DS18S20TempSensor2, RaspberryPiController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The controller on the Raspberry Pi listens to commands from the RabbitMQ server to control the fan and heatbed, with control states shared as feedback. A safe protocol is incorporated into the low-level driver for command execution."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Calibration algorithms update model parameters using sensor data to maintain fidelity. Monitoring systems validate system performance against safety and optimization criteria, detecting violations that trigger corrective actions by humans or algorithms."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "RabbitMQ messaging server facilitates communication, 1-Wire bus supports sensor connectivity, and built-in Wi-Fi and Bluetooth enable wireless communication. Network topology is not specified in the source document."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "RabbitMQ server is deployed on-premises using a Raspberry Pi, with support for cloud deployment due to RabbitMQ's flexible scalability across on-premises and cloud environments."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin uses monitoring systems to assess the Physical Twin's safety and operational optimization; when violations are detected, human operators or algorithmic interventions adjust the Physical Twin accordingly."
]