// ------------------------------------------------------------
// C3: Physical sensing components
// ------------------------------------------------------------
instance InteriorAirTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor placed inside the insulated styrofoam box (sensor 1)."
    DTDFVocab:producedData InteriorAirTempDataTransmitted1
]

instance InteriorAirTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor placed inside the insulated styrofoam box (sensor 2)."
    DTDFVocab:producedData InteriorAirTempDataTransmitted2
]

instance ExteriorAirTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor placed outside the incubator to monitor ambient temperature."
    DTDFVocab:producedData ExteriorAirTempDataTransmitted
]

// ------------------------------------------------------------
// C4: Physical-to-virtual interaction (DataTransmitted)
// ------------------------------------------------------------
instance InteriorAirTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorAirTempSensor1
]

instance InteriorAirTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorAirTempSensor2
]

instance ExteriorAirTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExteriorAirTempSensor
]

// ------------------------------------------------------------
// C5: Data (stored in time‑series DB)
// ------------------------------------------------------------
instance InteriorAirTempData1 : DTDFVocab:Data [
    base:desc "Real‑time interior temperature values (°C) received from sensor 1."
    DTDFVocab:fromData InteriorAirTempDataTransmitted1
    DTDFVocab:inputTo TimeSeriesDatabase
    DTDFVocab:inputTo CalibrationAlgorithm
    DTDFVocab:inputTo KalmanFilterEngine
    DTDFVocab:inputTo CoSimulationFramework
    DTDFVocab:inputTo DashboardVisualizationTool
]

instance InteriorAirTempData2 : DTDFVocab:Data [
    base:desc "Real‑time interior temperature values (°C) received from sensor 2."
    DTDFVocab:fromData InteriorAirTempDataTransmitted2
    DTDFVocab:inputTo TimeSeriesDatabase
    DTDFVocab:inputTo CalibrationAlgorithm
    DTDFVocab:inputTo KalmanFilterEngine
    DTDFVocab:inputTo CoSimulationFramework
    DTDFVocab:inputTo DashboardVisualizationTool
]

instance ExteriorAirTempData : DTDFVocab:Data [
    base:desc "Real‑time ambient temperature values (°C) received from the exterior sensor."
    DTDFVocab:fromData ExteriorAirTempDataTransmitted
    DTDFVocab:inputTo TimeSeriesDatabase
    DTDFVocab:inputTo CalibrationAlgorithm
    DTDFVocab:inputTo KalmanFilterEngine
    DTDFVocab:inputTo CoSimulationFramework
    DTDFVocab:inputTo DashboardVisualizationTool
]

// ------------------------------------------------------------
// C2: Acting components
// ------------------------------------------------------------
instance ResistiveHeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed providing on/off heating power to raise incubator temperature."
]

instance CirculationFanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan that circulates air inside the incubator to achieve uniform temperature."
]

// ------------------------------------------------------------
// C10: Models
// ------------------------------------------------------------
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model assuming all electrical power is transferred to the internal air."
    DTDFVocab:inputTo CalibrationAlgorithm
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Analytical thermal model that accounts for heat‑bed thermal inertia; used by Kalman filter."
    DTDFVocab:inputTo KalmanFilterEngine
    DTDFVocab:inputTo CoSimulationFramework
]

// ------------------------------------------------------------
// C11: Enablers
// ------------------------------------------------------------
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "AMQP message broker used for publishing sensor readings and controller commands."
    DTDFVocab:enables RealTimeVisualizationService
    DTDFVocab:enables CalibrationService
    DTDFVocab:enables AnomalyDetectionService
    DTDFVocab:enables WhatIfSimulationService
    DTDFVocab:enables SelfAdaptationService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time‑series database storing temperature streams for archival and query."
    DTDFVocab:enables RealTimeVisualizationService
]

instance DashboardVisualizationTool : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard that visualizes temperature, fan and heat‑bed states in real time."
    DTDFVocab:enables RealTimeVisualizationService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Automatic calibration routine that adjusts free parameters of Model A and Model B from streamed sensor data."
    DTDFVocab:enables CalibrationService
]

instance KalmanFilterEngine : DTDFVocab:Enabler [
    base:desc "Kalman filter that fuses sensor measurements with Model B predictions to estimate heat‑bed state and detect anomalies."
    DTDFVocab:enables AnomalyDetectionService
]

instance CoSimulationFramework : DTDFVocab:Enabler [
    base:desc "Co‑simulation engine that replays historic or live PT data to evaluate alternative controller settings."
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationLoopEngine : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop that triggers experiments, re‑calibrates models, updates the Kalman filter and re‑configures the controller."
    DTDFVocab:enables SelfAdaptationService
]

// ------------------------------------------------------------
// C6: Services
// ------------------------------------------------------------
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides live visualization of incubator temperature, fan, and heat‑bed states on a dashboard."
    DTDFVocab:provides TemperatureVisualizationInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Executes on‑demand calibration of thermal models using the latest sensor data."
    DTDFVocab:provides ModelParameterUpdateInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Detects sensor anomalies and estimates heat‑bed state via a Kalman filter."
    DTDFVocab:provides AnomalyFlagInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Runs what‑if simulations forecasting temperature evolution under alternative controller parameters."
    DTDFVocab:provides TemperatureForecastInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Orchestrates the self‑adaptation loop: detection, experiment planning, re‑calibration, and controller re‑configuration."
    DTDFVocab:provides ControlParameterRecommendationInsight
    DTDFVocab:provides AutomaticControlAdjustmentAction
    DTDFVocab:provides HumanApprovalRecommendationAction
]

// ------------------------------------------------------------
// C17: Insights
// ------------------------------------------------------------
instance TemperatureVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time temperature, fan, and heat‑bed state visualized on the dashboard."
]

instance ModelParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Updated parameter values for Model A and Model B after calibration."
]

instance AnomalyFlagInsight : DTDFVocab:Insight [
    base:desc "Flag indicating detected temperature sensor or state estimation anomalies."
]

instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory for a given set of controller parameters."
]

instance ControlParameterRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommended adjustments to controller lower/upper limits, heating duration, or waiting duration."
]

// ------------------------------------------------------------
// C17: Actions
// ------------------------------------------------------------
instance AutomaticControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatically applies the recommended controller parameter changes."
    DTDFVocab:IsAutomatic true
]

instance HumanApprovalRecommendationAction : DTDFVocab:Action [
    base:desc "Presents the recommended controller changes to a human operator for approval."
    DTDFVocab:IsAutomatic false
]

// ------------------------------------------------------------
// Environment (optional aggregation)
// ------------------------------------------------------------
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InteriorAirTempSensor1, InteriorAirTempSensor2, ExteriorAirTempSensor,
                  ResistiveHeatbedActuator, CirculationFanActuator,
                  RabbitMQBroker, TimeSeriesDatabase, DashboardVisualizationTool,
                  CalibrationAlgorithm, KalmanFilterEngine, CoSimulationFramework,
                  SelfAdaptationLoopEngine, ThermalModelA, ThermalModelB
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the controller (a bang‑bang controller) and sent as RabbitMQ messages to the low‑level driver. Commands include heat‑bed actuation (on/off) and fan control, together with parameters such as lower/upper temperature limits (LL/UL), heating duration (H) and waiting duration (C). The low‑level driver validates each command against its safe protocol before driving the physical actuators and can acknowledge execution via a response message."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The low‑level driver periodically reads temperature sensors and uploads the measurements to the RabbitMQ communication server; the controller listens to these messages and publishes its control commands. The DT subscribes to the same RabbitMQ topics, stores the incoming stream in a time‑series database and updates visualisations on a dashboard in near real‑time. No explicit sampling period, latency requirement, or temporal granularity is specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a service‑oriented architecture coordinated through the RabbitMQ message broker (AMQP). Core DT services—calibration, Kalman‑filter‑based anomaly detection, what‑if simulation, and the self‑adaptation loop—subscribe to controller and driver messages, exchange data via the broker, persist streams in a time‑series database, and present results on a dashboard. This component integration constitutes the overall orchestration of the Digital Twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The incubator Digital Twin follows a lifecycle composed of (1) a development phase where the physical hardware (styrofoam box, heat‑bed, fan, temperature sensors) and the software stack (Raspberry Pi controller, low‑level driver, RabbitMQ communication server) are defined (Document 2, 5); (2) a modelling phase in which two simulation models (Model A and Model B) are constructed based on the four assumptions (Document 6); (3) a calibration phase that runs the calibration algorithm (section 3.3) to estimate model parameters from sensor data (Document 1, 4); (4) an operation phase where data from the physical twin are continuously streamed to the DT, monitors evaluate safety and performance, and visualization dashboards display the current status (Document 1, 4); and (5) a self‑adaptation phase that closes the loop by detecting anomalies, planning experiments, re‑calibrating the model, updating the Kalman filter and the controller, and re‑deploying new control parameters (Document 4). Transition between phases is managed through the RabbitMQ communication infrastructure and the calibration/monitoring algorithms, providing governance of the DT throughout its life."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity relies on four explicit assumptions: (1) uniform temperature distribution inside the box (ensured by the fan), (2) negligible heat storage in the box walls, (3) constant specific heat capacity of the internal air, and (4) that the majority of electrical power is converted to heat in the air (relaxed in Model B). Validation is performed by experimental comparison of model predictions against measured temperature traces (section 4 of the study, not detailed here) and by calibrating model parameters on‑line. Uncertainty sources include sensor noise, the simplifying assumptions above, and errors in estimated parameters. On‑demand calibration and a Kalman filter‑based state estimator are used to detect anomalies, re‑estimate the heatbed temperature, and correct model drift, thereby providing a quality‑assurance loop for the Digital Twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin uses a RabbitMQ message broker as the technical communication layer. RabbitMQ provides a publish/subscribe topology where the controller, low‑level driver, and DT components publish and subscribe to specific topics. The broker is described as mature, lightweight, and easy to deploy on‑premise or in the cloud, offering reliable message delivery. Specific bandwidth, latency, redundancy, or security (e.g., TLS) requirements are not detailed in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external components relies on the RabbitMQ broker for message exchange (AMQP protocol) between the controller, low‑level driver, and DT services, and on a time‑series database and visualization dashboard for data storage and presentation. No additional enterprise‑level standards or external system dependencies are described."
]