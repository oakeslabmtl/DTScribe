// C3: Physical sensing component
instance PhysicalSensorStream : DTDFVocab:SensingComponent [
    base:desc "Time-series sensor streams collected from the Physical Twin"
    DTDFVocab:producedData SensorDataTransmission
]

// C4: Data transmitted by the sensing component
instance SensorDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalSensorStream
]

// C10: Data layer
instance TimeSeriesData : DTDFVocab:Data [
    base:desc "Aggregated time-series data collected from the physical sensors"
    DTDFVocab:fromData SensorDataTransmission
    DTDFVocab:inputTo CalibrationAlgorithm
]

// C10: Models incorporated in the Digital Twin
instance GeometricCADModel : DTDFVocab:Model [
    base:desc "Geometric model (CAD representation) storing dimensional data such as wheel diameters, chassis geometry, and styling attributes"
    DTDFVocab:inputTo CalibrationAlgorithm
]

instance DynamicDifferentialEquationModel : DTDFVocab:Model [
    base:desc "Behavioral or dynamic model governed by differential equations that captures temporal evolution of the system under physical forces"
    DTDFVocab:inputTo CalibrationAlgorithm
]

instance AnalyticalKnowledgeModel : DTDFVocab:Model [
    base:desc "Analytical models encoding knowledge about cyber and physics of the Physical Twin and its environment"
    DTDFVocab:inputTo CalibrationAlgorithm
]

// C11: Enabler orchestrating data and models
instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Calibration algorithms that iteratively adjust parameter estimates of the cyber‑physical system and environmental models"
    DTDFVocab:enables ContinuousMonitoringService, PredictiveSimulationService, OptimizationService, DecisionSupportService
]

// C6: Services provided by the Digital Twin
instance ContinuousMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of physical twin performance for safety violations"
    DTDFVocab:provides SafetyViolationInsight, HumanRemedialAction
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation reproducing system behaviour under current operating conditions"
    DTDFVocab:provides PredictiveBehaviorInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimisation service calibrating models to the best‑possible parameter estimates"
    DTDFVocab:provides OptimizedParametersInsight
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Decision‑support mechanism alerting humans or automated controllers when safety or performance thresholds are breached"
    DTDFVocab:provides AutomatedControllerAdjustment
]

// C17: Insights delivered by services
instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating breach of safety or performance thresholds detected during monitoring"
]

instance PredictiveBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight depicting simulated system behaviour under current operational conditions"
]

instance OptimizedParametersInsight : DTDFVocab:Insight [
    base:desc "Insight providing optimised parameter estimates derived from calibration"
]

// C17: Actions triggered by services
instance HumanRemedialAction : DTDFVocab:Action [
    base:desc "Manual remedial action initiated by human operators upon safety violation alert"
    DTDFVocab:IsAutomatic false
]

instance AutomatedControllerAdjustment : DTDFVocab:Action [
    base:desc "Automated controller adjustment triggered when thresholds are breached"
    DTDFVocab:IsAutomatic true
]