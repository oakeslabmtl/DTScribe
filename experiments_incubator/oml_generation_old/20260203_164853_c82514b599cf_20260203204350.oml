// C3: Physical sensing components
instance TemperatureSensorInternalNearHeatbed : DTDFVocab:SensingComponent [
    base:desc "Digital temperature probe (DS18B20) mounted close to the heatbed to monitor local heat source temperature, sampling every few seconds via 1‑Wire bus."
    DTDFVocab:producedData TempInternalNearHeatbedTransmitted
]

instance TemperatureSensorInternalCenter : DTDFVocab:SensingComponent [
    base:desc "Digital temperature probe (DS18B20) located in the central airspace of the insulated box, sampling every few seconds via 1‑Wire bus."
    DTDFVocab:producedData TempInternalCenterTransmitted
]

instance TemperatureSensorExternal : DTDFVocab:SensingComponent [
    base:desc "Digital temperature probe (DS18B20) mounted outside the insulated box to record ambient temperature, sampling every few seconds via 1‑Wire bus."
    DTDFVocab:producedData TempExternalTransmitted
]

// C4: Physical‑to‑virtual interaction
instance TempInternalNearHeatbedTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorInternalNearHeatbed
]

instance TempInternalCenterTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorInternalCenter
]

instance TempExternalTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorExternal
]

// C10: Models/Data
instance TempInternalNearHeatbedData : DTDFVocab:Data [
    base:desc "Time‑series temperature data from the sensor near the heatbed, used for calibration and prediction."
    DTDFVocab:fromData TempInternalNearHeatbedTransmitted
    DTDFVocab:inputTo CalibrationEngineEnabler, PredictiveEngineEnabler, MonitoringEngineEnabler
]

instance TempInternalCenterData : DTDFVocab:Data [
    base:desc "Time‑series temperature data from the central airspace sensor, used for calibration and prediction."
    DTDFVocab:fromData TempInternalCenterTransmitted
    DTDFVocab:inputTo CalibrationEngineEnabler, PredictiveEngineEnabler, MonitoringEngineEnabler
]

instance TempExternalData : DTDFVocab:Data [
    base:desc "Ambient temperature time‑series data, used for baseline correction and monitoring."
    DTDFVocab:fromData TempExternalTransmitted
    DTDFVocab:inputTo CalibrationEngineEnabler, PredictiveEngineEnabler, MonitoringEngineEnabler
]

instance ModelAThermalSimulation : DTDFVocab:Model [
    base:desc "Model A – first‑order linear differential equation with two free parameters (overall heat‑transfer coefficient and initial temperature offset)."
    DTDFVocab:inputTo CalibrationEngineEnabler, PredictiveEngineEnabler
]

instance ModelBThermalSimulation : DTDFVocab:Model [
    base:desc "Model B – extended first‑order differential equation with four free parameters, including heatbed thermal inertia (heat capacity and heat‑transfer constant)."
    DTDFVocab:inputTo CalibrationEngineEnabler, PredictiveEngineEnabler
]

// C11: Enablers
instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker used to transport temperature data from the Raspberry Pi to the digital twin over the local network."
    DTDFVocab:enables DataIngestionService
]

instance CalibrationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Calibration engine that processes live temperature data to adjust model parameters, executed on local Raspberry Pi."
    DTDFVocab:enables CalibrationService
]

instance PredictiveEngineEnabler : DTDFVocab:Enabler [
    base:desc "Predictive engine that runs Model A and Model B to forecast future temperature trajectories and assess thermal inertia."
    DTDFVocab:enables PredictiveService
]

instance MonitoringEngineEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring engine that checks temperature against safety and optimal bounds, issuing alerts or recommendations."
    DTDFVocab:enables MonitoringService
]

// C6: Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service that ingests raw temperature data from RabbitMQ into the twin's ingestion pipeline."
    DTDFVocab:provides RawDataInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that continually adjusts simulation model parameters using live sensor readings."
    DTDFVocab:provides CalibrationInsight
]

instance PredictiveService : DTDFVocab:Service [
    base:desc "Service that runs two parametric thermal models to forecast temperature trajectories."
    DTDFVocab:provides TemperatureTrendInsight, ControlRecommendationInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors temperature against safety and optimal performance bounds, generating alerts."
    DTDFVocab:provides AnomalyDetectionInsight, SafetyAlertInsight
]

// C17: Insights
instance RawDataInsight : DTDFVocab:Insight [
    base:desc "Insight that exposes raw temperature data streams for further analysis."
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating the convergence status of calibration parameters and their impact on model accuracy."
]

instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Insight forecasting the future temperature trajectory based on current sensor readings."
]

instance ControlRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting adjustments to heater or fan operation to maintain target temperature."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight that flags fault conditions by detecting deviations between model predictions and live sensor readings."
]

instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Insight that issues alerts when temperature exceeds safety limits or optimal performance bounds."
]

// C17: Actions
instance AdjustHeatbedPowerAction : DTDFVocab:Action [
    base:desc "Action to modify heatbed power via PWM to achieve desired temperature profile."
    DTDFVocab:IsAutomatic false
]

instance AdjustFanSpeedAction : DTDFVocab:Action [
    base:desc "Action to modify fan speed via PWM to improve air circulation and temperature homogenization."
    DTDFVocab:IsAutomatic false
]

// C4: Physical components (Acting Components)
instance IncubatorHeatbed : DTDFVocab:Component [
    base:desc "Electric heatbed positioned under the incubator base, driven by the Raspberry Pi through a digital‑to‑analog interface or PWM."
]

instance IncubatorFan : DTDFVocab:Component [
    base:desc "Centrifugal fan within the incubator, powered via PWM‑controlled transistor, used to circulate air."
]

instance HeatbedPowerController : DTDFVocab:Component [
    base:desc "Component that controls heatbed power output using PWM; exposes network sockets for remote setpoint adjustments."
]

instance FanSpeedController : DTDFVocab:Component [
    base:desc "Component that controls fan speed via PWM; enforces safety limits when internal temperature exceeds setpoint."
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Embedded Raspberry Pi microcontroller that interfaces with sensors and actuators, executing control logic."
]

// C4: Physical sensing components are already defined above.

// C4: Physical acting components are defined above.

// C4: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains IncubatorHeatbed, IncubatorFan, HeatbedPowerController, FanSpeedController, RaspberryPiController,
    TemperatureSensorInternalNearHeatbed, TemperatureSensorInternalCenter, TemperatureSensorExternal
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the controller application running on the Raspberry Pi and transmitted to the physical twin via the RabbitMQ server. Messages, formatted according to the AMQP specification, contain explicit command payloads such as 'turn_on_fan', 'turn_on_heatbed', 'set_heating_duration' and corresponding parameters. The low‑level driver subscribes to the command queue, validates incoming requests against an embedded safe protocol, executes the requested actuator operations, and then publishes acknowledgment or status updates back to RabbitMQ to confirm execution. The DT architecture ensures that any conflict between concurrent commands is resolved by queue ordering and the controller’s priority logic."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin of the incubator is orchestrated around a communication subsystem that receives low‑level driver and controller messages from the physical plant.

These messages are ingested into a time‑series database, where they are stored for historical analysis and real‑time querying.

A dashboard layer subscribes to the database to provide live visualisations of temperature, fan status, and controller signals.

On demand, a calibration module is triggered: it gathers recent sensor streams and runs a parameter‑identification routine to fit either Model A (two free parameters) or Model B (four free parameters).  The calibrated model is then supplied to a Kalman‑filter based anomaly‑detection and heat‑bed‑state‑estimation component.

For what‑if scenarios, the Digital Twin launches a co‑simulation engine that feeds the calibrated model with current or historical data, running scenario simulations to optimise controller gains.

All these functional blocks are coordinated by a central orchestration service that manages data flow, schedules calibration and simulation jobs, and ensures synchronization between the plant, data storage, and user interfaces."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin follows a developmental chronology beginning with the creation of two thermal simulation models (Model‑A with two free parameters and Model‑B with four free parameters) for the incubator’s heatbed dynamics, as outlined in the case study. These models are calibrated against real‑time data collected from the incubator’s physical twin via its Raspberry‑Pi controller, incorporating readings from two internal temperature sensors and one external sensor. Calibration algorithms iteratively adjust the models’ parameters to maximise predictive fidelity, and the updated parameter sets are logged to enable version tracking. Upon calibration, the models are instantiated in the twin’s simulation engine, where they operate concurrently with diagnostic and control algorithms—including fault detectors, supervisory controllers, state estimators, and optimizers. The operational phase continuously ingests sensor streams, computes real‑time forecasts, and monitors for safety or performance violations. When a violation is detected, the monitoring layer signals either a human operator or an autonomous algorithm to enact corrective actions on the physical twin. Transition management is thus governed by the calibration cycle, and governance is exercised through the monitoring and supervisory control layers that uphold safety constraints and initiate adaptations. This cyclical lifecycle—modeling → sensor data acquisition → calibration → deployment → monitoring → adaptation—ensures continuous refinement of the twin’s fidelity and value."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validity is established by comparing model predictions to the experimentally measured temperature traces. The non‑linear least‑squares calibration minimizes the residual error between simulated and measured temperatures, and the magnitude of the residual error is used to assess whether the model captures the thermal inertia of the heat‑bed. Model B consistently shows lower residuals than Model A, indicating higher fidelity for the Twin’s predictive tasks. No explicit uncertainty quantification beyond the residual‑error assessment is provided in the documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital twin relies on a RabbitMQ message broker deployed on the same Raspberry Pi that runs the controller; all communication between the physical and virtual layers occurs through RabbitMQ message queues. No explicit network topology beyond the on‑premise deployment, bandwidth, latency, redundancy, or security protocols are detailed in the documentation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin is hosted on the Raspberry Pi 4 that also runs the control software for the incubator; the deployment is an on‑premise, single‑node setup with RabbitMQ serving as the integration layer. No explicit scalability, cloud or edge options are described."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin architecture incorporates runtime safety monitoring that validates the behavior of the physical incubator by comparing sensor readings against the calibrated thermal models. Fault‑detection algorithms flag anomalies such as temperature drift or sensor failures, after which supervisory controllers are invoked to adjust heating cycles or trigger a halt of the heatbed. The Raspberry‑Pi‑based controller communicates with the monitoring layer via a low‑level driver that enforces a minimal safe operating mode, ensuring that the device remains in a safe state if communication or sensor data are lost. No explicit cyber‑security protocols, access controls, or authentication mechanisms are documented."
]