instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "First internal temperature sensor embedded in the incubator's insulated styrofoam box to measure real-time thermal conditions for model validation and control. Part of high-resolution monitoring infrastructure with spatial distribution to capture heterogeneous thermal dynamics."
    DTDFVocab:producedData InternalTemperatureDataStream1
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second internal temperature sensor embedded in the incubator's insulated styrofoam box, positioned to capture distinct thermal zones (e.g., heatbed proximity vs. air gaps). Supports dynamic model calibration with high-resolution data transmission."
    DTDFVocab:producedData InternalTemperatureDataStream2
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor measuring ambient conditions affecting the incubator's thermal performance. Provides contextual data for model calibration and environmental dependency analysis in the cyber-physical system."
    DTDFVocab:producedData ExternalTemperatureDataStream
]

instance HeatedBedTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Implicit sensor component representing the thermal monitoring of the incubator's heated bed, critical for validating the 4-parameter thermal model's superior predictive performance over the 2-parameter variant."
    DTDFVocab:producedData HeatedBedTemperatureDataStream
]

instance InternalTemperatureDataStream1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1
    base:desc "Raw analog temperature readings from the first internal sensor, transmitted via low-latency periodic polling (likely serial/USB or I2C/SPI) to the Raspberry Pi controller for preprocessing and model calibration."
]

instance InternalTemperatureDataStream2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor2
    base:desc "Raw analog temperature readings from the second internal sensor, synchronized with other streams to ensure spatial thermal dynamics are captured for heterogeneous model validation."
]

instance ExternalTemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
    base:desc "Ambient temperature data stream providing contextual environmental conditions for the incubator's thermal model calibration and fault detection algorithms."
]

instance HeatedBedTemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatedBedTemperatureSensor
    base:desc "Thermal data stream from the heated bed region, critical for validating the 4-parameter thermal model's accuracy in predicting thermal inertia."
]

instance TwoParameterThermalModel : DTDFVocab:Model [
    base:desc "Simplified thermal simulation model with two free parameters, representing basic heat transfer dynamics in the incubator. Used as a lower-fidelity baseline for comparison with the 4-parameter model."
    DTDFVocab:inputTo ThermalModelCalibrationEnabler
]

instance FourParameterThermalModel : DTDFVocab:Model [
    base:desc "High-fidelity thermal simulation model with four free parameters, demonstrating superior predictive performance for thermal inertia in the incubator's heated bed. Used for dynamic model calibration and control optimization."
    DTDFVocab:inputTo ThermalModelCalibrationEnabler, AdaptiveControlEnabler, WhatIfAnalysisEnabler
]

instance PreprocessedTemperatureData : DTDFVocab:Data [
    base:desc "Validated and noise-filtered temperature data after preprocessing on the Raspberry Pi controller. Includes calibration adjustments to ensure accuracy for model inputs."
    DTDFVocab:fromData InternalTemperatureDataStream1, InternalTemperatureDataStream2, ExternalTemperatureDataStream, HeatedBedTemperatureDataStream
    DTDFVocab:inputTo ThermalModelCalibrationEnabler, RealTimeStateEstimationEnabler
]

instance HistoricalTemperatureTrends : DTDFVocab:Data [
    base:desc "Time-series storage of temperature readings and model predictions, enabling historical trend analysis for predictive maintenance and system performance evaluation."
    DTDFVocab:fromData InternalTemperatureDataStream1, InternalTemperatureDataStream2
    DTDFVocab:inputTo PredictiveMaintenanceEnabler, VisualizationDashboardEnabler
]

instance ThermalModelCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Parameter estimation algorithms (e.g., least-squares fitting or Bayesian inference) that dynamically adjust the 2-parameter and 4-parameter thermal models using real-time sensor data to minimize prediction errors."
    DTDFVocab:enables RealTimeStateEstimationService, DynamicBehaviorReproductionService, ModelValidationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithms and differential equation models that identify deviations between predicted and observed behavior, flagging potential faults like sensor drift or heating element failure."
    DTDFVocab:enables AnomalyDetectionService, AutomatedCorrectiveActionsService
]

instance AdaptiveControlEnabler : DTDFVocab:Enabler [
    base:desc "Optimization algorithms (e.g., Model Predictive Control or reinforcement learning) that dynamically adjust PID controller parameters or heating profiles for energy efficiency and stability."
    DTDFVocab:enables AdaptiveControlTuningService, ResourceAllocationService
]

instance WhatIfAnalysisEnabler : DTDFVocab:Enabler [
    base:desc "Counterfactual scenario testing framework that simulates system responses to hypothetical conditions (e.g., failed sensor or altered heating profile) to assess robustness."
    DTDFVocab:enables WhatIfAnalysisService
]

instance RealTimeStateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "Sensor data fusion algorithms that generate a high-fidelity digital replica of the physical system's thermal state using internal and external temperature readings."
    DTDFVocab:enables RealTimeStateEstimationService
]

instance VisualizationDashboardEnabler : DTDFVocab:Enabler [
    base:desc "Web-based dashboard framework (e.g., Grafana or Dash) providing real-time graphical representations of temperature distributions, control signals, and system health metrics."
