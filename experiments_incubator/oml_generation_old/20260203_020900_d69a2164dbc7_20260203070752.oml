// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed controlled on/off via MOSFET driver, commanded through Raspberry Pi GPIO"
]

instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V DC fan driven through the same MOSFET circuitry, used for air circulation"
]

// C3: Physical sensing components
instance TemperatureSensorBoxInside1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (‑55 °C to +125 °C, ±0.5 °C) mounted inside the incubator box"
    DTDFVocab:producedData IncubatorTemperatureMessage
]

instance TemperatureSensorBoxInside2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (‑55 °C to +125 °C, ±0.5 °C) mounted inside the incubator box"
    DTDFVocab:producedData IncubatorTemperatureMessage
]

instance TemperatureSensorAmbient : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (‑55 °C to +125 °C, ±0.5 °C) measuring ambient temperature"
    DTDFVocab:producedData IncubatorTemperatureMessage
]

// C4: Physical-to-virtual interaction (data transmission)
instance IncubatorTemperatureMessage : DTDFVocab:DataTransmitted [
    base:desc "RabbitMQ message containing the latest readings from the three DS18S20 temperature sensors"
    DTDFVocab:producedFrom TemperatureSensorBoxInside1, TemperatureSensorBoxInside2, TemperatureSensorAmbient
]

// C10: Data
instance TemperatureTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature trajectory collected from IncubatorTemperatureMessage for model calibration"
    DTDFVocab:fromData IncubatorTemperatureMessage
    DTDFVocab:inputTo SciPyLeastSquaresOptimizer
]

// C10: Models/Data
instance IncubatorThermalModelA : DTDFVocab:Model [
    base:desc "Single‑mass model (heat capacity C_air) with heat‑loss parameter G_box for the incubator air"
    DTDFVocab:inputTo SciPyLeastSquaresOptimizer
]

instance IncubatorThermalModelB : DTDFVocab:Model [
    base:desc "Extended model adding heat‑bed thermal mass C_heater and coupling G_heater to Model A"
    DTDFVocab:inputTo SciPyLeastSquaresOptimizer
]

// C11: Enablers
instance SciPyLeastSquaresOptimizer : DTDFVocab:Enabler [
    base:desc "SciPy least‑squares optimizer used to fit Model A and Model B parameters against experimental temperature data"
    DTDFVocab:enables ParameterOptimizationService
]

// C6: Services
instance ParameterOptimizationService : DTDFVocab:Service [
    base:desc "Service that performs non‑linear parameter fitting of the incubator thermal models using SciPy"
    DTDFVocab:provides TemperatureModelFitInsight
]

// C17: Insight
instance TemperatureModelFitInsight : DTDFVocab:Insight [
    base:desc "Insight that the calibrated thermal model accurately predicts temperature trajectories after optimisation"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (e.g., heat‑bed ON/OFF, fan speed) to the RabbitMQ server. The controller on the Raspberry Pi consumes these messages and drives the MOSFET/optocoupler circuit to actuate the heat‑bed and fan via GPIO outputs."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture follows a CPS‑based pattern: physical hardware → low‑level driver → RabbitMQ communication server → controller (bang‑bang with hysteresis) → DT components (model calibration, monitoring). All software runs on the same Raspberry Pi, enabling tight integration of data acquisition, control, and model‑based services."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by explicit assumptions (uniform temperature, negligible wall heat storage, constant air specific heat, heat‑bed power fully converted to heat). Validation experiments test temperature uniformity (maximum deviation ≤ 7 °C, reduced to ≤ 6 °C with higher fan voltage) and calibrate the four free parameters of Model B. The calibration error is minimised via gradient‑descent optimisation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT relies on the RabbitMQ message broker (AMQP protocol) hosted on the Raspberry Pi, using the Pi's built‑in Wi‑Fi or Ethernet. Sensor data uses the 1‑Wire protocol over GPIO; actuator commands are transmitted via GPIO to MOSFET drivers isolated with optocouplers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components (communication server, low‑level driver, controller, and model services) are deployed on the Raspberry Pi 4 Model B itself. The software is container‑agnostic but runs as Python processes; source code and configuration are maintained in the publicly available GitHub repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver implements a safe protocol that enforces a safe state for the hardware; MOSFETs are driven through optocouplers to electrically isolate the Raspberry Pi from high‑current loads, reducing risk of damage or unsafe operation."
]