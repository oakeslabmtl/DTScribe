// C3: Physical sensing components
instance InternalTemperatureSensorBox1 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor located at position 1 inside the incubator box"
    DTDFVocab:producedData InternalTempDataBox1Msg
]

instance InternalTemperatureSensorBox2 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor located at position 2 inside the incubator box"
    DTDFVocab:producedData InternalTempDataBox2Msg
]

instance ExternalTemperatureSensorAmbient : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor monitoring ambient conditions outside the incubator"
    DTDFVocab:producedData ExternalTempDataAmbientMsg
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance InternalTempDataBox1Msg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensorBox1
]

instance InternalTempDataBox2Msg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensorBox2
]

instance ExternalTempDataAmbientMsg : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensorAmbient
]

// C10: Data
instance InternalTempReadingBox1 : DTDFVocab:Data [
    base:desc "Raw temperature reading from internal sensor Box1"
    DTDFVocab:fromData InternalTempDataBox1Msg
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine, VisualizationEngine, CoSimulationEngine, SelfAdaptationEngine
]

instance InternalTempReadingBox2 : DTDFVocab:Data [
    base:desc "Raw temperature reading from internal sensor Box2"
    DTDFVocab:fromData InternalTempDataBox2Msg
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine, VisualizationEngine, CoSimulationEngine, SelfAdaptationEngine
]

instance ExternalTempReadingAmbient : DTDFVocab:Data [
    base:desc "Raw temperature reading from external ambient sensor"
    DTDFVocab:fromData ExternalTempDataAmbientMsg
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine, VisualizationEngine, CoSimulationEngine, SelfAdaptationEngine
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model A with two free parameters"
    DTDFVocab:inputTo CalibrationEngine, CoSimulationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Analytical thermal model B with four free parameters, captures heat‑bed inertia"
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine, CoSimulationEngine
]

// C11: Enablers
instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Automated calibration algorithm that adjusts model parameters using time‑series temperature data"
    DTDFVocab:enables ModelCalibrationService
]

instance KalmanFilterEngine : DTDFVocab:Enabler [
    base:desc "Kalman filter that fuses sensor data with ThermalModelB to estimate heat‑bed temperature and detect anomalies"
    DTDFVocab:enables StateEstimationService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard that consumes temperature data from the time‑series database for real‑time visualization"
    DTDFVocab:enables RealTimeVisualizationService
]

instance CoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation framework that runs what‑if analyses by replaying physical data and evaluating alternative controller parameters"
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationEngine : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop that detects behavioural changes, schedules experiments, re‑calibrates models, updates the Kalman filter and re‑deploys controller settings"
    DTDFVocab:enables SelfAdaptationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of incubator temperature status via dashboard"
    DTDFVocab:provides InsightThermalInertia, InsightSafetyThresholds
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "On‑demand calibration of ThermalModelA and ThermalModelB using latest sensor data"
    DTDFVocab:provides InsightThermalInertia
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Anomaly detection and heat‑bed state estimation using Kalman filter and ModelB"
    DTDFVocab:provides InsightSafetyThresholds, ActionTriggerAlert
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Runs what‑if co‑simulations to evaluate and optimise controller parameters"
    DTDFVocab:provides InsightOptimalControlActions
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Automated self‑adaptation loop that reconfigures controller and actuation based on detected changes"
    DTDFVocab:provides ActionAdjustHeatingPower, ActionAdjustFanSpeed, ActionReconfigureController
]

// C17: Insights
instance InsightThermalInertia : DTDFVocab:Insight [
    base:desc "Insight on the thermal inertia of the incubator derived from calibrated models"
]

instance InsightSafetyThresholds : DTDFVocab:Insight [
    base:desc "Insight on safety thresholds indicating when temperature exceeds safe limits"
]

instance InsightOptimalControlActions : DTDFVocab:Insight [
    base:desc "Insight on optimal control actions generated by what‑if simulation outcomes"
]

// C17: Actions
instance ActionAdjustHeatingPower : DTDFVocab:Action [
    base:desc "Automatically adjust heating power of the resistive heat‑bed"
    DTDFVocab:IsAutomatic true
]

instance ActionAdjustFanSpeed : DTDFVocab:Action [
    base:desc "Automatically adjust fan speed to improve temperature uniformity"
    DTDFVocab:IsAutomatic true
]

instance ActionTriggerAlert : DTDFVocab:Action [
    base:desc "Trigger an alarm when temperature deviates from safety thresholds"
    DTDFVocab:IsAutomatic true
]

instance ActionReconfigureController : DTDFVocab:Action [
    base:desc "Reconfigure controller parameters after successful calibration or experiment"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed driven by the Raspberry Pi through GPIO driver circuits"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Air circulation fan driven by the Raspberry Pi through GPIO driver circuits"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (heat‑bed ON/OFF and fan ON/OFF) are issued by the Digital Twin as AMQP messages to the same RabbitMQ server; the low‑level driver receives these messages, validates them with an incorporated safe‑state protocol, and actuates the corresponding hardware, sending back status acknowledgments through the broker."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT processes sensor data in near real‑time: controller and low‑level driver messages are streamed to a time‑series database and visualised on a dashboard, with on‑demand calibration, Kalman‑filter based anomaly detection and co‑simulation triggered as needed. The documents do not provide explicit sampling frequencies, latency requirements or temporal granularity specifications."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a centralized Digital Twin architecture that integrates the physical incubator (plant), a Raspberry‑Pi controller, a data acquisition layer that relays sensor readings to a time‑series database, a visualization dashboard, calibration algorithms, a Kalman filter for heat‑bed state estimation, and a co‑simulation engine for what‑if analysis. Components communicate through controller and driver messages, and the DT hosts models, monitoring and optimisation services as described in the documents."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is required to accurately represent the heat‑bed’s thermal inertia; this is validated experimentally by comparing model predictions against measured temperature trajectories, where Model B (four‑parameter) shows superior fidelity. Validation and verification are performed through on‑demand calibration that minimizes the error between sensor data and model output, and through Kalman‑filter residual monitoring for anomaly detection. Sources of uncertainty include sensor noise and parameter estimation errors; these are quantified during calibration and addressed by re‑calibrating the models when deviations exceed predefined thresholds. Quality assurance is maintained via continuous monitoring, automated calibration cycles, and the self‑adaptation loop that re‑configures models, filters and controllers in response to detected deviations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system uses a TCP/IP network with a RabbitMQ message broker (AMQP protocol) as the central hub; the Raspberry Pi controller, low‑level driver and Digital Twin components are connected in a client‑server topology, relying on RabbitMQ’s built‑in reliability (message persistence, acknowledgements); specific bandwidth, latency, or security (TLS) requirements are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ server and the controller software are deployed on‑premise (the RabbitMQ broker runs on a local machine; the controller runs on a Raspberry Pi); no cloud or edge platform is mentioned, and scalability or storage specifications are not provided."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT ingests data from the incubator controller and low‑level drivers into a time‑series database and exchanges this information with calibration, estimation and simulation modules, but the documents do not specify any external communication protocols, interoperability standards, or integration with other enterprise systems."
]