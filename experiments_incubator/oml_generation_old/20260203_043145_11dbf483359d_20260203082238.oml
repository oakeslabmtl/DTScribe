// ===============================
// Physical Sensing Components
// ===============================

// Sensor 1 – Inner chamber temperature sensor (DS18S20)
instance IncubatorInnerTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Maxim Integrated DS18S20 high‑precision 1‑Wire digital thermometer mounted inside the incubator chamber; operates –55 °C to +125 °C with ±0.5 °C accuracy; read by Raspberry Pi via 1‑Wire bus."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// Sensor 2 – Inner chamber temperature sensor (second DS18S20)
instance IncubatorInnerTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second Maxim Integrated DS18S20 high‑precision 1‑Wire digital thermometer also mounted inside the incubator chamber; identical specifications to the first inner sensor."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// Sensor 3 – External temperature sensor (DS18S20)
instance IncubatorOuterTempSensor : DTDFVocab:SensingComponent [
    base:desc "Maxim Integrated DS18S20 digital thermometer mounted outside the insulated incubator box; provides ambient temperature reference for calibration."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// ===============================
// Physical‑to‑Virtual Interaction
// ===============================

// Aggregated temperature data stream from the three sensors
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInnerTempSensor1, IncubatorInnerTempSensor2, IncubatorOuterTempSensor
]

// ===============================
// Data Produced in the Twin
// ===============================

instance TemperatureTimeSeries : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements (°C) streamed from the physical incubator to the Digital Twin; used for model calibration and monitoring."
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

// ===============================
// Acting Component
// ===============================

instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed inside the incubator that raises internal temperature; driven by a controller reachable via serial or network messages; power settings limited by DT safety monitors."
]

// ===============================
// Models
// ===============================

// Thermal model with two free parameters (captures basic inertia)
instance ThermalModelTwoParam : DTDFVocab:Model [
    base:desc "Analytical thermal simulation model of incubator temperature dynamics containing two free parameters representing primary thermal inertia."
    DTDFVocab:inputTo MonitoringEnabler, OptimisationEnabler
]

// Thermal model with four free parameters (more detailed inertia)
instance ThermalModelFourParam : DTDFVocab:Model [
    base:desc "Analytical thermal simulation model of incubator temperature dynamics containing four free parameters to capture detailed heat‑bed inertia."
    DTDFVocab:inputTo MonitoringEnabler, OptimisationEnabler
]

// Model output data transmission
instance ModelOutputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ThermalModelTwoParam, ThermalModelFourParam
]

// Model output data (e.g., predicted temperature trajectories)
instance ModelOutputData : DTDFVocab:Data [
    base:desc "Predicted temperature trajectories generated by the calibrated thermal models; fed to optimisation algorithms."
    DTDFVocab:fromData ModelOutputDataTransmitted
    DTDFVocab:inputTo OptimisationEnabler
]

// ===============================
// Enablers (Algorithms / Tools)
// ===============================

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that estimates free parameters of the thermal models using incoming temperature time‑series."
    DTDFVocab:enables CalibrationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring logic that evaluates real‑time temperature data and model predictions to assess safety and optimal operation."
    DTDFVocab:enables MonitoringService
]

instance OptimisationEnabler : DTDFVocab:Enabler [
    base:desc "Optimisation routine that uses calibrated model outputs to generate power‑setpoint recommendations for the heat‑bed."
    DTDFVocab:enables OptimisationService
]

// ===============================
// Services
// ===============================

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that executes calibration of thermal models and updates their parameters in the Digital Twin."
    DTDFVocab:provides CalibrationInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that continuously monitors temperature data and model predictions, detecting faults and evaluating performance."
    DTDFVocab:provides AnomalyAlertInsight, PerformanceMetricInsight
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Service that computes optimal heater power settings and issues recommendations to maintain target temperature efficiently."
    DTDFVocab:provides OptimizationRecommendationAction
]

// ===============================
// Insights & Actions
// ===============================

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful update of model parameters after calibration, including confidence metrics."
]

instance AnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when temperature deviates beyond safety thresholds, signalling a potential fault."
]

instance PerformanceMetricInsight : DTDFVocab:Insight [
    base:desc "Metric reporting current temperature stability, variance, and energy consumption of the incubator."
]

instance OptimizationRecommendationAction : DTDFVocab:Action [
    base:desc "Recommendation to adjust heat‑bed power settings for optimal temperature control."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is organized as a pipeline of distinct services: sensor data are continuously collected from the physical twin, calibration algorithms use these data to update the parameters of cyber models that represent the CPS and its environment, the calibrated models produce information that feeds monitoring components which assess whether the system is operating safely and optimally, and when a violation is detected a decision component (either a human operator or an automated algorithm) triggers corrective actions on the physical twin. This structure integrates data acquisition, model calibration, monitoring, and decision-making in a coordinated sequence."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the two thermal simulation models against experimental temperature traces. The four‑parameter model was found to better predict the heat‑bed’s thermal inertia, indicating higher fidelity. Calibration algorithms continuously adjust model parameters using the incoming sensor data, while monitors detect deviations from expected behaviour. Validation is performed experimentally, and uncertainty is mitigated through recalibration, but quantitative uncertainty metrics are not provided."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The incubator digital twin incorporates a safety protocol directly within the low‑level driver to ensure that the device remains in a safe state during operation. This embedded protocol is designed to monitor critical parameters and trigger predefined safe actions when anomalous conditions are detected, thereby providing a fail‑safe mechanism for the physical twin."
]