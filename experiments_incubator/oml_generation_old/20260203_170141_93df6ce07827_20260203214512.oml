// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed that distributes heat uniformly across the incubator box, actuated via MOSFET controlled by the Raspberry Pi 4."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan (12 V or 24 V) to circulate air inside the incubator, actuated via MOSFET with optocoupler isolation."
]

instance RaspberryPiControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi 4 Model B that serves as the controller; receives commands from the Digital Twin and drives heatbed and fan."
]

// C3: Physical sensing components
instance InBoxTempSensorA : DTDFVocab:SensingComponent [
    base:desc "First DS18S20 high‑precision 1 Wire temperature sensor (0.5 °C accuracy) inside the incubator."
    DTDFVocab:producedData InBoxTempDataA
]

instance InBoxTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 1 Wire temperature sensor (0.5 °C accuracy) inside the incubator."
    DTDFVocab:producedData InBoxTempDataB
]

instance OutsideTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1 Wire temperature sensor (0.5 °C accuracy) outside the incubator."
    DTDFVocab:producedData OutsideTempData
]

instance FanStatusSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor unit reading the binary fan status (on/off) via the Raspberry Pi GPIO."
    DTDFVocab:producedData FanStatusDataTransmitted
]

instance PowerConsumptionSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor unit measuring power consumption of the heatbed and fan via a current sense resistor."
    DTDFVocab:producedData PowerConsumptionDataTransmitted
]

// C4: Physical‑to‑virtual interaction – Data transmission via RabbitMQ
instance InBoxTempDataA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InBoxTempSensorA
]

instance InBoxTempDataB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InBoxTempSensorB
]

instance OutsideTempData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideTempSensor
]

instance FanStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FanStatusSensor
]

instance PowerConsumptionDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerConsumptionSensor
]

// C10: Models/Data
instance InBoxTemperatureDataA : DTDFVocab:Data [
    base:desc "Realtime temperature data from the first inside sensor."
    DTDFVocab:inputTo PythonRuntimeEnabler
    DTDFVocab:fromData InBoxTempDataA
]

instance InBoxTemperatureDataB : DTDFVocab:Data [
    base:desc "Realtime temperature data from the second inside sensor."
    DTDFVocab:inputTo PythonRuntimeEnabler
    DTDFVocab:fromData InBoxTempDataB
]

instance OutsideTemperatureData : DTDFVocab:Data [
    base:desc "Realtime temperature data from the outside sensor."
    DTDFVocab:inputTo PythonRuntimeEnabler
    DTDFVocab:fromData OutsideTempData
]

instance FanStatusData : DTDFVocab:Data [
    base:desc "Realtime fan status (on/off) data."
    DTDFVocab:inputTo AnomalyDetectionEnabler
    DTDFVocab:fromData FanStatusDataTransmitted
]

instance PowerConsumptionData : DTDFVocab:Data [
    base:desc "Realtime power consumption data of the heatbed and fan."
    DTDFVocab:inputTo PythonRuntimeEnabler
    DTDFVocab:fromData PowerConsumptionDataTransmitted
]

instance ModelA : DTDFVocab:Model [
    base:desc "Two‑parameter thermal model (Model A) forecasting internal temperature based on measured power and fan status."
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance ModelB : DTDFVocab:Model [
    base:desc "Four‑parameter thermal model (Model B) capturing additional dynamics between heatbed, air and box."
    DTDFVocab:inputTo PythonRuntimeEnabler
]

// C11: Enablers
instance LowLevelDriverEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level driver on Raspberry Pi reading DS18S20 sensors and publishing to RabbitMQ."
    DTDFVocab:enables TemperatureDataIngestionService
]

instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker facilitating message exchange between physical twin and Digital Twin."
    DTDFVocab:enables DataIngestionService
]

instance PythonRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime environment enabling model simulation, calibration, and predictive inference."
    DTDFVocab:enables PredictiveSimulationService, ModelCalibrationService
]

instance LeastSquaresEnabler : DTDFVocab:Enabler [
    base:desc "SciPy least‑squares optimization tool for calibrating thermal model parameters."
    DTDFVocab:enables ModelCalibrationService
]

instance AnomalyDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Finger‑printing algorithm detecting abnormal temperature trends."
    DTDFVocab:enables FaultDetectionService
]

instance BangBangControllerEnabler : DTDFVocab:Enabler [
    base:desc "Bang‑bang controller logic generating heating commands."
    DTDFVocab:enables SupervisorBangBangService
]

instance ActuationHardwareEnabler : DTDFVocab:Enabler [
    base:desc "Hardware interface controlling MOSFETs for heatbed and fan based on commands from the Supervisor."
    DTDFVocab:enables SupervisorBangBangService
]

// C6: Services
instance TemperatureDataIngestionService : DTDFVocab:Service [
    base:desc "Service subscribing to RabbitMQ and ingesting realtime temperature, fan status, and power samples."
]

instance DataIngestionService : DTDFVocab:Service [
    base:desc "Service receiving raw sensor data over RabbitMQ for downstream processing."
]

instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of internal temperature and fan power consumption."
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation using Model A or B to forecast future temperature trajectories."
    DTDFVocab:provides PredictedTemperatureTrajectoryInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Least‑squares–based calibration of Model A and B parameters using experimental data."
    DTDFVocab:provides CalibratedModelParametersInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection for abnormal temperature trends using anomaly detection algorithms."
    DTDFVocab:provides AnomalyAlertInsight
]

instance SupervisorBangBangService : DTDFVocab:Service [
    base:desc "Supervisory bang‑bang controller issuing heating commands to the heatbed."
    DTDFVocab:provides OptimalHeatingScheduleInsight, IssueHeatingCommandAction
]

// C17: Insights
instance CalibratedModelParametersInsight : DTDFVocab:Insight [
    base:desc "Insight containing calibrated parameters such as C_air, G_box, G_heater, and C_heater."
]

instance PredictedTemperatureTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight with model‑based predictions of future internal temperature evolution."
]

instance AnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Insight alerting operators to abnormal temperature trends that may indicate faults."
]

instance OptimalHeatingScheduleInsight : DTDFVocab:Insight [
    base:desc "Insight recommending optimal heating schedules derived from bang‑bang control analysis."
]

// C17: Actions
instance IssueHeatingCommandAction : DTDFVocab:Action [
    base:desc "Automatic action to issue heating power commands to the heatbed via MOSFET."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin publishes control commands (heatbed on/off, fan speed adjustments) to designated RabbitMQ queues, which the low‑level driver consumes and forwards to the GPIO pins via MOSFETs to actuate the heatbed and fan."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of a RabbitMQ broker, a low‑level driver subscribing to sensor data and publishing actuator commands, and a controller implementing bang‑bang logic. The Digital Twin runs in the same physical node and consumes/produces messages via RabbitMQ queues, enabling tight integration between the PT and virtual simulation components."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle includes (i) design – development of mathematical models and simulation tools; (ii) manufacturing – construction of the physical incubator and assembly of hardware; (iii) deployment – installation of the Raspberry Pi, RabbitMQ, and drivers; (iv) operation – continuous monitoring, calibration, and model update during real‑time use."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity governed by simplifying assumptions (1: uniform temperature; 2: negligible heat transfer to walls; 3: constant specific heat; 4: neglecting heat from fan). Validation achieved by experimental comparison, residual error minimization, and iterative parameter update. Uncertainty quantified via least‑squares residuals; model adequacy evaluated by fit to empirical data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical–virtual communication uses the RabbitMQ AMQP broker running on the same Raspberry Pi; commands and sensor data are exchanged via defined message queues. Sensor data is transmitted over the 1‑Wire bus from DS18S20 to the Pi, then forwarded to RabbitMQ. The Pi connects to external network (Wi‑Fi) for optional remote access."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin is hosted locally on the Raspberry Pi 4 Model B running a lightweight Linux (Raspbian) environment; RabbitMQ is installed directly on the Pi; all other software components (driver, controller, simulation scripts) are executed as local processes."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is embedded in the low‑level driver to prevent unsafe actuator states; the bang‑bang controller includes hysteresis (LL, UL, H, C). The system limits fan current to 4 A using MOSFETs, isolating the Pi via optocouplers. No explicit cybersecurity measures are described, but localized deployment reduces exposure."
]