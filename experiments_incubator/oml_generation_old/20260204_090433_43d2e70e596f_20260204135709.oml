]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Model calibration service refining parameters via online learning and stochastic gradient descent."
    DTDFVocab:provides CalibrationInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "State estimation service reconstructing hidden system states from noisy sensor data using Kalman filters."
    DTDFVocab:provides StateEstimationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection service identifying deviations from nominal behavior using machine learning anomaly detection."
    DTDFVocab:provides FaultDetectionInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "3D visualization service enabling immersive exploration of DT-PT interactions via holographic renderings."
