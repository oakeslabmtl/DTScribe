// C3: Physical Sensing Components
instance AccelerometerSensor : DTDFVocab:SensingComponent [
    base:desc "High-frequency accelerometer measuring dynamic forces and vibrations at 1kHz for structural health monitoring, with ±0.1% accuracy and time-synchronized via IEEE 1588 protocol."
    DTDFVocab:producedData AccelerometerDataTransmitted
]

instance StrainGaugeSensor : DTDFVocab:SensingComponent [
    base:desc "Precision strain gauge measuring structural stress with ±0.1% accuracy, deployed at critical load-bearing joints with 100Hz sampling frequency."
    DTDFVocab:producedData StrainGaugeDataTransmitted
]

instance TemperatureProbeSensor : DTDFVocab:SensingComponent [
    base:desc "Thermal sensor measuring environmental and component temperatures with ±0.5°C precision, distributed across the system for heat distribution analysis."
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance HumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Environmental humidity sensor providing contextual data for material degradation analysis, with 1Hz sampling frequency."
    DTDFVocab:producedData HumidityDataTransmitted
]

instance VoltageCurrentSensor : DTDFVocab:SensingComponent [
    base:desc "IoT-enabled transducer measuring electrical parameters (voltage/current) with 10Hz sampling, deployed at power distribution nodes."
    DTDFVocab:producedData ElectricalDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance AccelerometerDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AccelerometerSensor
]

instance StrainGaugeDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StrainGaugeSensor
]

instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureProbeSensor
]

instance HumidityDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HumiditySensor
]

instance ElectricalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VoltageCurrentSensor
]

// C10: Models/Data
instance GeometricModel : DTDFVocab:Model [
    base:desc "CAD-based geometric representation of the Physical Twin including structural dimensions, spatial relationships, and component layouts using SolidWorks or AutoCAD."
    DTDFVocab:inputTo CADToolEnabler
]

instance PhysicsBasedBehavioralModel : DTDFVocab:Model [
    base:desc "Dynamic behavioral model using finite element analysis (ANSYS) and differential equations for simulating forces, thermal gradients, and vibration modes."
    DTDFVocab:inputTo PhysicsSimulatorEnabler
]

instance AnalyticalPredictiveModel : DTDFVocab:Model [
    base:desc "Physics-informed analytical model for aerodynamic drag, vibration modes, and structural integrity predictions using MATLAB/Simulink."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance StateEstimationModel : DTDFVocab:Model [
    base:desc "Kalman filter-based state estimator reconstructing hidden system states from noisy sensor data with 100ms latency requirements."
    DTDFVocab:inputTo StateEstimationEnabler
]

instance FaultDetectionModel : DTDFVocab:Model [
    base:desc "Machine learning-based anomaly detection model using Isolation Forest algorithms to identify deviations from nominal behavior with 95% confidence intervals."
    DTDFVocab:inputTo FaultDetectionEnabler
]

instance RealTimeDataStream : DTDFVocab:Data [
    base:desc "Time-series database storing raw and preprocessed sensor data with event-driven architecture for 100ms latency processing."
    DTDFVocab:fromData AccelerometerDataTransmitted, StrainGaugeDataTransmitted, TemperatureDataTransmitted, HumidityDataTransmitted, ElectricalDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler
]

instance CalibratedParametersData : DTDFVocab:Data [
    base:desc "Parameterized model data calibrated via Bayesian methods and machine learning, ensuring alignment between virtual and physical states with 5% error margin."
    DTDFVocab:fromData RealTimeDataStream
    DTDFVocab:inputTo CalibrationEnabler
]

// C11: Enablers
instance CADToolEnabler : DTDFVocab:Enabler [
    base:desc "SolidWorks or AutoCAD toolset for creating and managing geometric models with version control via Git-LFS for large CAD files."
    DTDFVocab:enables GeometricModelService
]

instance PhysicsSimulatorEnabler : DTDFVocab:Enabler [
    base:desc "ANSYS or COMSOL Multiphysics platform for multi-domain simulations including thermal, structural, and fluid dynamics."
