]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Gazebo or MATLAB/Simulink simulation engine for co-simulation with CAD tools and physics-based models."
    DTDFVocab:enables CoSimulationService
]

instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter implementation on NVIDIA Jetson edge devices for real-time state reconstruction with 100ms latency."
    DTDFVocab:enables StateEstimationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Isolation Forest algorithm deployed on AWS SageMaker for real-time anomaly detection with 95% confidence thresholds."
    DTDFVocab:enables FaultDetectionService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Apache Kafka pipeline for real-time data ingestion, preprocessing, and feature extraction using scikit-learn."
    DTDFVocab:enables DataProcessingService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Bayesian optimization and stochastic gradient descent algorithms for online model parameter tuning."
    DTDFVocab:enables CalibrationService
]

instance DigitalTwinFrameworkEnabler : DTDFVocab:Enabler [
    base:desc "Siemens MindSphere or PTC ThingWorx platform integrating data, models, and algorithms with OPC UA middleware."
