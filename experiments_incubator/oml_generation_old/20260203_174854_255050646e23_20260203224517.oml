]

instance FailureForecastInsight : DTDFVocab:Insight [
    base:desc "Predictive insights into potential system failures based on current operational trends and historical data."
]

instance EnergyConsumptionTrendInsight : DTDFVocab:Insight [
    base:desc "Analysis of energy consumption patterns to identify inefficiencies and opportunities for optimization."
]

instance ControlViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of control violations such as temperature drifts or sensor failures requiring intervention."
]

instance ManualInterventionAction : DTDFVocab:Action [
    base:desc "Manual corrective actions taken by operators based on digital twin insights and alerts."
    DTDFVocab:IsAutomatic false
]

instance AutomatedAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated adjustments to control parameters (e.g., PID tuning) in response to detected violations."
    DTDFVocab:IsAutomatic true
]

instance DiagnosticVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representations of system behavior (e.g., time-series plots, 3D thermal maps) for diagnostic analysis."
]

instance ReconfigurationRecommendation : DTDFVocab:Action [
    base:desc "Strategic recommendations for reconfiguring the physical twin (e.g., adjusting insulation properties, heating profiles)."
    DTDFVocab:IsAutomatic false
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Identification of optimization opportunities for energy efficiency and performance based on digital twin predictions."
]

instance ControlParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Automated or manual adjustment of control parameters (e.g., heater/fan settings) to achieve optimal performance."
    DTDFVocab:IsAutomatic true
]

