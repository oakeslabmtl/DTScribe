// C3: Physical Sensing Components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "First internal temperature sensor monitoring the temperature inside the incubator's insulated container for real-time thermal state estimation and feedback control."
    DTDFVocab:producedData InternalTemperatureData1
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second internal temperature sensor monitoring the temperature inside the incubator's insulated container, providing redundant measurement for improved reliability in thermal monitoring."
    DTDFVocab:producedData InternalTemperatureData2
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor measuring ambient conditions to provide environmental context awareness for the incubator's thermal regulation system."
    DTDFVocab:producedData ExternalTemperatureData
]

// C4: Physical-to-Virtual Interaction
instance InternalTemperatureData1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1
    base:desc "Analog temperature readings from the first internal sensor transmitted in real-time with time-series granularity for thermal monitoring and simulation."
]

instance InternalTemperatureData2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor2
    base:desc "Analog temperature readings from the second internal sensor transmitted in real-time with time-series granularity for redundancy and cross-validation."
]

instance ExternalTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
    base:desc "Analog temperature readings from the external environment transmitted in real-time to provide context for thermal behavior prediction."
]

// C10: Models/Data
instance TwoParameterThermalModel : DTDFVocab:Model [
    base:desc "Physics-based thermal model with two free parameters representing simplified thermal dynamics of the incubator for initial state estimation and transient response prediction."
    DTDFVocab:inputTo ThermalModelCalibrationEnabler, DynamicSimulationEnabler
]

instance FourParameterThermalModel : DTDFVocab:Model [
    base:desc "High-fidelity physics-based thermal model with four free parameters capturing detailed thermal inertia and heat transfer characteristics for accurate temperature prediction."
    DTDFVocab:inputTo ThermalModelCalibrationEnabler, DynamicSimulationEnabler
]

instance InternalTemperatureDataProcessed : DTDFVocab:Data [
    base:desc "Preprocessed internal temperature data including calibration adjustments, noise filtering (e.g., moving averages), and unit normalization for model input."
    DTDFVocab:fromData InternalTemperatureData1, InternalTemperatureData2
    DTDFVocab:inputTo DynamicSimulationEnabler, CalibrationAlgorithmEnabler, FaultDetectionEnabler
]

instance ExternalTemperatureDataProcessed : DTDFVocab:Data [
    base:desc "Preprocessed external temperature data including calibration and environmental context integration for boundary condition modeling."
    DTDFVocab:fromData ExternalTemperatureData
    DTDFVocab:inputTo DynamicSimulationEnabler, CalibrationAlgorithmEnabler
]

instance HistoricalPerformanceData : DTDFVocab:Data [
    base:desc "Time-series historical data of temperature trajectories, control actions, and operational conditions used for model validation and predictive analytics."
    DTDFVocab:inputTo PredictiveAnalyticsEnabler
]

// C11: Enablers
instance RaspberryPiController : DTDFVocab:Enabler [
    base:desc "Embedded Raspberry Pi acting as the central controller for real-time data acquisition, actuation, and low-level control logic (e.g., PID loops) for the incubator system."
    DTDFVocab:enables RealTimeMonitoringService, DynamicSimulationService, SafetyMonitoringService
]

instance ThermalModelCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm using least-squares optimization or Bayesian inference to update thermal model parameters (e.g., thermal conductivity, heat loss coefficients) with real-time sensor data."
    DTDFVocab:enables ModelRefinementService, PredictiveAnalyticsService
]

instance DynamicSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Physics-based simulation engine (e.g., custom differential equation solver or MATLAB/Simulink) executing thermal models to replicate and predict incubator behavior under current or hypothetical conditions."
    DTDFVocab:enables DynamicSimulationService, PredictiveAnalyticsService
]

instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Parameter estimation algorithms ensuring alignment between digital twin models and physical twin behavior through continuous recalibration with sensor data."
    DTDFVocab:enables ModelRefinementService, SafetyMonitoringService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Fault detection algorithms identifying anomalies or violations (e.g., temperature thresholds breached) and triggering alerts for corrective actions."
    DTDFVocab:enables SafetyMonitoringService, HumanInTheLoopControlService
]

instance PredictiveAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Data-driven algorithms (e.g., state estimators, optimizers) generating predictive insights such as failure forecasts and energy consumption trends."
    DTDFVocab:enables PredictiveAnalyticsService, OptimizationRecommendationService
]

instance SupervisoryControllerEnabler : DTDFVocab:Enabler [
    base:desc "High-level control logic overriding or tuning low-level controllers (e.g., PID) based on digital twin predictions for optimal performance."
    DTDFVocab:enables HumanInTheLoopControlService, OptimizationRecommendationService
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Database storing high-frequency sensor data with timestamps for historical analysis, model calibration, and long-term performance evaluation."
    DTDFVocab:enables RealTimeMonitoringService, PredictiveAnalyticsService
]

instance VisualizationDashboard : DTDFVocab:Enabler [
    base:desc "Custom dashboard providing real-time plots (e.g., temperature trajectories, control signals) and 3D thermal simulations for diagnostic analysis."
    DTDFVocab:enables VisualizationAndDecisionSupportService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous acquisition and processing of sensor data from the physical twin to enable state estimation and anomaly detection in real-time."
    DTDFVocab:provides ThermalStateInsight, AnomalyDetectionAction
]

instance DynamicSimulationService : DTDFVocab:Service [
    base:desc "Execution of physics-based thermal models to replicate and predict the incubator's thermal behavior under current or hypothetical operating conditions."
    DTDFVocab:provides ThermalBehaviorPredictionInsight, TransientResponseInsight
]

instance ModelRefinementService : DTDFVocab:Service [
    base:desc "Use of calibration algorithms to update cyber-physical thermal models with real-time sensor data, ensuring parameter accuracy and reducing simulation errors."
    DTDFVocab:provides ModelAccuracyInsight, ParameterUpdateAction
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Deployment of fault detectors and supervisory controllers to assess whether the physical twin operates within safe operational bounds and optimal efficiency metrics."
    DTDFVocab:provides SafetyComplianceInsight, CorrectiveActionRecommendation
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Generation of predictive insights such as failure forecasts and energy consumption trends using data-driven algorithms."
    DTDFVocab:provides FailureForecastInsight, EnergyConsumptionTrendInsight
]

instance HumanInTheLoopControlService : DTDFVocab:Service [
    base:desc "Facilitation of manual or automated interventions when violations (e.g., temperature drifts) are detected, enabling corrective actions."
    DTDFVocab:provides ControlViolationInsight, ManualInterventionAction, AutomatedAdjustmentAction
]

instance VisualizationAndDecisionSupportService : DTDFVocab:Service [
    base:desc "Provision of advanced visualizations (e.g., time-series plots, 3D thermal maps) for diagnostic analysis and strategic reconfiguration of the physical twin."
    DTDFVocab:provides DiagnosticVisualizationInsight, ReconfigurationRecommendation
]

instance OptimizationRecommendationService : DTDFVocab:Service [
    base:desc "Suggestion of corrective actions (e.g., adjusting heater/fan settings) to restore optimal performance based on digital twin predictions."
    DTDFVocab:provides OptimizationInsight, ControlParameterAdjustmentAction
]

// C17: Insights/Actions
instance ThermalStateInsight : DTDFVocab:Insight [
    base:desc "Real-time estimation of the incubator's internal thermal state based on processed sensor data and model predictions."
]

instance AnomalyDetectionAction : DTDFVocab:Action [
    base:desc "Automatic detection of deviations from expected thermal behavior indicating potential faults or inefficiencies."
    DTDFVocab:IsAutomatic true
]

instance ThermalBehaviorPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted thermal behavior of the incubator under current or hypothetical conditions, including transient responses to disturbances."
]

instance TransientResponseInsight : DTDFVocab:Insight [
    base:desc "Analysis of the incubator's response to disturbances such as door openings or load changes, providing insights into dynamic thermal stability."
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Assessment of the digital twin's model accuracy through comparison with real-time sensor data and historical performance."
]

instance ParameterUpdateAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of model parameters (e.g., thermal conductivity) to improve alignment with physical twin behavior."
    DTDFVocab:IsAutomatic true
]

instance SafetyComplianceInsight : DTDFVocab:Insight [
    base:desc "Evaluation of whether the physical twin operates within predefined safe operational bounds (e.g., temperature thresholds)."
]

instance CorrectiveActionRecommendation : DTDFVocab:Action [
    base:desc "Suggested corrective actions to restore safe operation, such as adjusting PID parameters or triggering maintenance alerts."
