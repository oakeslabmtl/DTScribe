// ------------------------------
// Acting Components
// ------------------------------
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that provides the primary heating power for the incubator."
]

instance CoolingFanActuator : DTDFVocab:ActingComponent [
    base:desc "Auxiliary cooling fan driven to regulate temperature inside the incubator."
]

instance ActuationEnabler : DTDFVocab:Enabler [
    base:desc "Driver implementing the ‘safe protocol’ that checks command limits and forces a safe state on violation."
    DTDFVocab:enables ActuationService
]

instance ActuationService : DTDFVocab:Service [
    base:desc "Executes actuator commands over the serial/TCP‑IP channel, limited to heater power range and fan speed range."
    DTDFVocab:provides SafetyViolationInsight, AutomaticCorrectionAction
]

// ------------------------------
// Physical Sensing Components
// ------------------------------
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor mounted inside the incubator (±0.5 °C accuracy)."
    DTDFVocab:producedData InternalTempDataTx
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 digital temperature sensor mounted inside the incubator (±0.5 °C accuracy)."
    DTDFVocab:producedData InternalTempDataTx
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External digital temperature sensor monitoring ambient conditions."
    DTDFVocab:producedData ExternalTempDataTx
]

// ------------------------------
// Physical‑to‑Virtual Data Transmission
// ------------------------------
instance InternalTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA, InternalTempSensorB
]

instance ExternalTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// ------------------------------
// Data Instances
// ------------------------------
instance InternalTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements from the two internal DS18S20 sensors."
    DTDFVocab:fromData InternalTempDataTx
    DTDFVocab:inputTo CalibrationEngine, MonitoringEngine
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurement from the external ambient sensor."
    DTDFVocab:fromData ExternalTempDataTx
    DTDFVocab:inputTo CalibrationEngine, MonitoringEngine
]

// ------------------------------
// Models
// ------------------------------
instance SimpleThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model with two free parameters for predicting internal temperature."
    DTDFVocab:inputTo SimulationEngine
]

instance DetailedThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model with four free parameters that captures heat‑bed thermal inertia."
    DTDFVocab:inputTo SimulationEngine
]

// ------------------------------
// Enablers (Algorithms / Engines)
// ------------------------------
instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that continuously updates model parameters using latest sensor readings."
    DTDFVocab:enables CalibrationService
]

instance MonitoringEngine : DTDFVocab:Enabler [
    base:desc "Monitoring algorithm that compares real‑time sensor data with model predictions and detects violations."
    DTDFVocab:enables SafetyMonitoringService, VisualizationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs the thermal models to generate temperature forecasts."
    DTDFVocab:enables PredictiveSimulationService
]

// ------------------------------
// Services
// ------------------------------
instance CalibrationService : DTDFVocab:Service [
    base:desc "Provides automatic calibration of model parameters based on incoming temperature data."
    DTDFVocab:provides PerformanceViolationInsight, OperatorAlertAction
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Monitors safety constraints; raises alerts when temperature exceeds safe limits."
    DTDFVocab:provides SafetyViolationInsight, AutomaticCorrectionAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Delivers advanced visualisations of real‑time temperature, model predictions, and alerts."
    DTDFVocab:provides PredictiveAlertInsight, OperatorAlertAction
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Runs predictive simulations to forecast future temperature trajectories."
    DTDFVocab:provides PredictiveAlertInsight, AutomaticCorrectionAction
]

instance ReconfigurabilityService : DTDFVocab:Service [
    base:desc "Allows reconfiguration of twin parameters and models to adapt to changing environments."
    DTDFVocab:provides InsightReconfiguration
]

instance MaintenanceReductionService : DTDFVocab:Service [
    base:desc "Supports reduced maintenance by providing diagnostics and health‑state predictions."
    DTDFVocab:provides InsightMaintenance
]

// ------------------------------
// Insights
// ------------------------------
instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of a safety violation when temperature exceeds predefined safe bounds."
]

instance PerformanceViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of performance deviation when temperature drifts from target set‑point."
]

instance PredictiveAlertInsight : DTDFVocab:Insight [
    base:desc "Forecasted temperature breach predicted by the simulation engine."
]

instance InsightReconfiguration : DTDFVocab:Insight [
    base:desc "Recommendation to reconfigure twin settings in response to environmental changes."
]

instance InsightMaintenance : DTDFVocab:Insight [
    base:desc "Diagnostic insight indicating upcoming maintenance needs based on wear patterns."
]

// ------------------------------
// Actions
// ------------------------------
instance OperatorAlertAction : DTDFVocab:Action [
    base:desc "Generates an alert for a human operator to take corrective action."
    DTDFVocab:IsAutomatic false
]

instance AutomaticCorrectionAction : DTDFVocab:Action [
    base:desc "Automatically forces actuators into a predefined safe state to mitigate violation."
    DTDFVocab:IsAutomatic true
]

instance InsightReconfigurationAction : DTDFVocab:Action [
    base:desc "Applies reconfiguration changes to the twin's parameters and models."
    DTDFVocab:IsAutomatic true
]

instance InsightMaintenanceAction : DTDFVocab:Action [
    base:desc "Schedules maintenance activities based on predictive health insights."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The incubator’s physical plant is driven by a Raspberry Pi that receives control decisions from the digital twin and actuates the heat‑bed and fan to achieve and maintain the target temperature, as the physical components are described as being controlled by a Raspberry Pi."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The incubator DT synchronises physical sensor readings with the digital model using a periodic data‑acquisition loop in the low‑level driver that reads the two internal temperature sensors and the external sensor at a regular interval (the exact period is not specified). The collected data are published to a local RabbitMQ message broker, which provides the asynchronous communication channel between the physical twin and the cyber components. The controller component consumes the sensor messages, executes the control algorithm and may introduce a waiting duration between control actions, thereby defining the overall control cycle time. Latency is limited to the round‑trip time of the RabbitMQ publish/subscribe cycle, and the temporal granularity of the DT is therefore bounded by the sensor sampling period and the message‑passing latency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is organised as a small, centrally managed constellation consisting of three main software entities deployed on the Raspberry Pi: (1) a low‑level driver that periodically reads temperature sensor data, (2) a RabbitMQ server that acts as the communication backbone for publish/subscribe of sensor readings and command messages, and (3) a controller that receives the sensor data, runs the calibration and control algorithms, and issues actuation commands to the heater and fan. This architecture follows a classic cyber‑physical loop where the RabbitMQ broker orchestrates data flow and decouples components, enabling modular integration of the models, algorithms and monitors described in Document 1."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated experimentally by comparing the predicted temperature trajectories of the two thermal models against measured sensor data; the four‑parameter model demonstrated superior prediction of thermal inertia. Calibration algorithms adjust model parameters to align predictions with observations, serving as an error‑correction mechanism. Monitors within the DT assess whether the system operates safely and optimally, flagging violations for human or algorithmic intervention. While uncertainty sources (e.g., sensor noise, model simplifications) are implied, explicit quantification or formal verification procedures are not described in the provided documents."
]