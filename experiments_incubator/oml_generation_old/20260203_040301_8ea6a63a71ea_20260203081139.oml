// =====================
// C3: Physical sensing components
// =====================

// Sensors inside the incubator
instance InsideTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor placed inside the incubator's styrofoam box to measure internal temperature."
    DTDFVocab:producedData InsideTempDataTransmittedA
]

instance InsideTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Second temperature sensor placed inside the incubator's styrofoam box to provide redundancy."
    DTDFVocab:producedData InsideTempDataTransmittedB
]

// Sensor outside the incubator
instance OutsideTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor mounted on the exterior of the incubator to monitor ambient temperature."
    DTDFVocab:producedData OutsideTempDataTransmitted
]

// Additional sensors (e.g., for payload monitoring)
instance PayloadTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Additional temperature sensor used to monitor the temperature of the payload inside the incubator."
    DTDFVocab:producedData PayloadTempDataTransmitted1
]

instance PayloadTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second additional temperature sensor for payload monitoring, providing fault‑tolerance."
    DTDFVocab:producedData PayloadTempDataTransmitted2
]

// =====================
// C4: Physical-to-virtual interaction (DataTransmitted)
// =====================

instance InsideTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensorA
]

instance InsideTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensorB
]

instance OutsideTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideTempSensor
]

instance PayloadTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PayloadTempSensor1
]

instance PayloadTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PayloadTempSensor2
]

// =====================
// C10: Data
// =====================

instance InsideTempDataA : DTDFVocab:Data [
    base:desc "Temperature reading stream from InsideTempSensorA."
    DTDFVocab:fromData InsideTempDataTransmittedA
    DTDFVocab:inputTo CalibrationEngine, SimulationEngine, MonitoringEngine, OptimisationEngine, VisualisationEngine
]

instance InsideTempDataB : DTDFVocab:Data [
    base:desc "Temperature reading stream from InsideTempSensorB."
    DTDFVocab:fromData InsideTempDataTransmittedB
    DTDFVocab:inputTo CalibrationEngine, SimulationEngine, MonitoringEngine, OptimisationEngine, VisualisationEngine
]

instance OutsideTempData : DTDFVocab:Data [
    base:desc "Ambient temperature reading stream from OutsideTempSensor."
    DTDFVocab:fromData OutsideTempDataTransmitted
    DTDFVocab:inputTo CalibrationEngine, SimulationEngine, MonitoringEngine, OptimisationEngine, VisualisationEngine
]

instance PayloadTempData1 : DTDFVocab:Data [
    base:desc "Payload temperature reading stream from PayloadTempSensor1."
    DTDFVocab:fromData PayloadTempDataTransmitted1
    DTDFVocab:inputTo CalibrationEngine, SimulationEngine, MonitoringEngine, OptimisationEngine, VisualisationEngine
]

instance PayloadTempData2 : DTDFVocab:Data [
    base:desc "Payload temperature reading stream from PayloadTempSensor2."
    DTDFVocab:fromData PayloadTempDataTransmitted2
    DTDFVocab:inputTo CalibrationEngine, SimulationEngine, MonitoringEngine, OptimisationEngine, VisualisationEngine
]

// =====================
// C10: Models
// =====================

instance CyberPhysicalModel : DTDFVocab:Model [
    base:desc "Cyber‑physical model representing the incubator’s thermal dynamics and heat‑distribution behavior."
    DTDFVocab:inputTo SimulationEngine, OptimisationEngine
]

instance EnvironmentalModel : DTDFVocab:Model [
    base:desc "Model of the surrounding environment (room temperature, airflow) used for accurate simulation and calibration."
    DTDFVocab:inputTo SimulationEngine, CalibrationEngine
]

// =====================
// C11: Enablers
// =====================

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Calibration algorithm engine that updates parameters of the CyberPhysicalModel and EnvironmentalModel using incoming sensor data."
    DTDFVocab:enables CalibrationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine that reproduces and predicts temperature dynamics of the incubator under current operating conditions."
    DTDFVocab:enables SimulationService
]

instance MonitoringEngine : DTDFVocab:Enabler [
    base:desc "Real‑time monitoring engine that evaluates safety (temperature bounds) and optimality (energy efficiency) criteria."
    DTDFVocab:enables MonitoringService
]

instance OptimisationEngine : DTDFVocab:Enabler [
    base:desc "Optimisation engine that generates control set‑points or actuator commands to keep temperature within the desired range."
    DTDFVocab:enables OptimisationService
]

instance VisualisationEngine : DTDFVocab:Enabler [
    base:desc "Advanced visualisation engine that renders temperature evolution, sensor readings and control actions."
    DTDFVocab:enables VisualisationService
]

instance ReconfigurationEngine : DTDFVocab:Enabler [
    base:desc "Engine that adapts the Digital Twin configuration to changes in environment or payload."
    DTDFVocab:enables ReconfigurationService
]

// =====================
// C6: Services
// =====================

instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Continuous acquisition of temperature data from all five sensors."
    DTDFVocab:provides DataAcquisitionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration service that updates model parameters based on latest sensor data."
    DTDFVocab:provides ModelUpdateInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service that predicts future temperature trajectories under current control settings."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitoring service that checks safety and optimality of temperature regulation in real time."
    DTDFVocab:provides SafetyOptimalityInsight, TriggerCorrectiveAction
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Optimisation service that computes control set‑points or actuator commands."
    DTDFVocab:provides ControlSetpointInsight, ExecuteControlAction
]

instance VisualisationService : DTDFVocab:Service [
    base:desc "Visualisation service providing advanced displays of temperature evolution, sensor data and actions."
    DTDFVocab:provides TemperatureVisualisationInsight
]

instance ReconfigurationService : DTDFVocab:Service [
    base:desc "Re‑configuration service allowing the Digital Twin to adapt to environmental or payload changes."
    DTDFVocab:provides ReconfigurationInsight, ManualReconfigurationAction
]

// =====================
// C17: Insights/Actions
// =====================

instance DataAcquisitionInsight : DTDFVocab:Insight [
    base:desc "Insight that the latest sensor measurements have been successfully acquired and stored."
]

instance ModelUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight that model parameters have been updated using the latest calibration algorithm."
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Insight that the simulation engine has produced a future temperature profile."
]

instance SafetyOptimalityInsight : DTDFVocab:Insight [
    base:desc "Insight indicating whether current temperature regulation satisfies safety bounds and optimality criteria."
]

instance ControlSetpointInsight : DTDFVocab:Insight [
    base:desc "Insight that the optimisation engine has generated a new temperature set‑point."
]

instance TemperatureVisualisationInsight : DTDFVocab:Insight [
    base:desc "Insight that the visualisation engine has rendered the temperature evolution graph."
]

instance ReconfigurationInsight : DTDFVocab:Insight [
    base:desc "Insight that the Digital Twin configuration has been successfully adapted."
]

// Actions

instance TriggerCorrectiveAction : DTDFVocab:Action [
    base:desc "Action that triggers a human operator or automated algorithm to apply corrective measures when a safety/optimality violation is detected."
    DTDFVocab:IsAutomatic false
]

instance ExecuteControlAction : DTDFVocab:Action [
    base:desc "Action that sends computed control commands (e.g., heater power level) to the physical actuators."
    DTDFVocab:IsAutomatic true
]

instance ManualReconfigurationAction : DTDFVocab:Action [
    base:desc "Action allowing an operator to manually reconfigure the Digital Twin settings."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin can produce control actions for the incubator’s actuators (heatbed and fan) that are executed by the Raspberry Pi; the document does not detail command types, message formats, validation or authentication procedures, feedback loops, conflict resolution, or execution confirmations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The incubator’s network consists of a Raspberry Pi edge device that hosts both the low‑level sensor/actuator drivers and a RabbitMQ communication server. Connectivity to the physical components uses a 1‑Wire bus for temperature sensors and GPIO lines for the heat‑bed and fan. The Raspberry Pi provides built‑in Wi‑Fi and Bluetooth, enabling wireless Ethernet connectivity to external networks or cloud services. Communication between the Digital Twin and the Physical Twin is performed via MQTT over TCP/IP through the RabbitMQ broker. The topology is a star‑like edge architecture where the Pi acts as the central hub. Bandwidth requirements are low (a few kilobytes per second for sensor updates and control messages); latency is constrained by MQTT’s lightweight protocol, typically sub‑second. Reliability is supported by RabbitMQ’s message acknowledgements and durable queues. Security is not detailed in the documents, so no specific encryption or authentication mechanisms are reported."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin is deployed on‑premise on the Raspberry Pi edge device. The Pi runs the RabbitMQ server that underpins the Twin’s messaging layer and hosts the control algorithms that process sensor data and issue commands. The document mentions only this edge deployment; it does not provide details about cloud hosting, resource sizing, scalability strategies, or formal availability/reliability provisions."
]