// ==== Environment and Physical Components ====
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Thermal incubator consisting of a styrofoam insulated container, heat‑bed, internal fan, Raspberry Pi 4 controller, custom PCB and 12 V/24 V power supply"
    base:contains InsulatedContainer, HeatBedActuator, InternalFanActuator,
                 RaspberryPi4Controller, CustomPCB, PowerSupply
]

instance InsulatedContainer : DTDFVocab:Component [
    base:desc "Styrofoam insulated container (~0.03 m³ volume) that houses the incubator interior"
]

instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed (≤100 W) switched via MOSFET driver on the custom PCB"
]

instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal circulation fan (≤0.02 m³·s⁻¹ airflow) driven by MOSFET on the PCB"
]

instance RaspberryPi4Controller : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running the low‑level driver and control software"
]

instance CustomPCB : DTDFVocab:Component [
    base:desc "Custom PCB containing MOSFET drivers and optocouplers for heater and fan control"
]

instance PowerSupply : DTDFVocab:Component [
    base:desc "12 V/24 V power supply feeding the heater, fan and controller"
]

// ==== Physical Sensing Components ====
instance IncubatorInnerTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer inside the incubator (–55 °C to +125 °C, ±0.5 °C accuracy)"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance IncubatorInnerTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer inside the incubator (–55 °C to +125 °C, ±0.5 °C accuracy)"
    DTDFVocab:producedData TemperatureDataTransmitted
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring ambient room temperature (–55 °C to +125 °C, ±0.5 °C accuracy)"
    DTDFVocab:producedData TemperatureDataTransmitted
]

// ==== Physical‑to‑Virtual Interaction (Data Transmission) ====
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "AMQP messages containing temperature samples published to the RabbitMQ broker"
    DTDFVocab:producedFrom IncubatorInnerTempSensor1,
                       IncubatorInnerTempSensor2,
                       AmbientTempSensor
]

// ==== Virtual Data ====
instance TemperatureData : DTDFVocab:Data [
    base:desc "Temperature readings (°C) from the three DS18S20 sensors"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo PythonDriver, SciPyCalibrationEngine
]

// ==== Models ====
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Physics‑based thermal model A with two free parameters (C_air, G_box)"
    DTDFVocab:inputTo PythonDriver, SciPyCalibrationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Physics‑based thermal model B with four free parameters (C_air, G_box, C_heater, G_heater)"
    DTDFVocab:inputTo PythonDriver, SciPyCalibrationEngine
]

// ==== Enablers (Tools & Infrastructure) ====
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "AMQP RabbitMQ broker used for publishing sensor samples, actuator status and safety events"
    DTDFVocab:enables ModelBasedSimulationService, RealTimeTemperatureMonitoringService,
                       FaultStateSafetyProtocolService, ParameterCalibrationService,
                       HeatingCycleOptimizationService
]

instance PythonDriver : DTDFVocab:Enabler [
    base:desc "Low‑level driver on the Raspberry Pi that reads DS18S20 sensors and publishes AMQP messages"
    DTDFVocab:enables RealTimeTemperatureMonitoringService, FaultStateSafetyProtocolService
]

instance SciPyCalibrationEngine : DTDFVocab:Enabler [
    base:desc "Python SciPy non‑linear least‑squares optimizer used for model parameter calibration and optimization"
    DTDFVocab:enables ParameterCalibrationService, HeatingCycleOptimizationService
]

instance BangBangController : DTDFVocab:Enabler [
    base:desc "Controller implementing bang‑bang heating logic with waiting periods, using calibrated model parameters"
    DTDFVocab:enables ModelBasedSimulationService, HeatingCycleOptimizationService
]

// ==== Services ====
instance ModelBasedSimulationService : DTDFVocab:Service [
    base:desc "Runs Model A or Model B simulations to predict incubator temperature trajectories"
    DTDFVocab:provides SimulationResultInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates model parameters using non‑linear least‑squares on temperature trajectories"
    DTDFVocab:provides CalibrationResultInsight
]

instance RealTimeTemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Continuously monitors temperature bounds in real time"
    DTDFVocab:provides TemperatureAlertInsight
]

instance FaultStateSafetyProtocolService : DTDFVocab:Service [
    base:desc "Detects fault conditions and initiates safety actions"
    DTDFVocab:provides FaultDetectionInsight, ShutdownActuatorAction
]

instance HeatingCycleOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes heating cycles based on calibrated model predictions"
    DTDFVocab:provides AdjustHeatingAction
]

// ==== Insights ====
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulated temperature trajectory generated by the selected thermal model"
]

instance CalibrationResultInsight : DTDFVocab:Insight [
    base:desc "Updated model parameters (C_air, G_box, C_heater, G_heater) after calibration"
]

instance TemperatureAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when temperature exceeds defined upper or lower limits"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of fault state such as heater over‑power or fan failure"
]

// ==== Actions ====
instance AdjustHeatingAction : DTDFVocab:Action [
    base:desc "Adjust heat‑bed power setting according to optimized heating cycle"
    DTDFVocab:IsAutomatic true
]

instance AdjustFanAction : DTDFVocab:Action [
    base:desc "Adjust internal fan speed or on/off state"
    DTDFVocab:IsAutomatic true
]

instance ShutdownActuatorAction : DTDFVocab:Action [
    base:desc "Shut down heater and/or fan to protect the system"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (heat‑bed ON/OFF, fan ON/OFF, timing parameters) to the same RabbitMQ broker; the controller on the Raspberry Pi subscribes and drives the MOSFETs accordingly."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture comprises the PT (incubator hardware), a Raspberry Pi controller, a low‑level driver, a RabbitMQ communication server on the Pi, DT components that subscribe to sensor streams and publish control commands, and a calibration module that updates model parameters; all components exchange data via AMQP."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is based on four explicit assumptions (uniform temperature, negligible wall heat storage, constant air specific heat, heat‑bed energy fully transferred). Validation experiments test temperature uniformity; calibration minimizes residual error between model output and measured temperature trajectories."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange uses AMQP over RabbitMQ running on the Raspberry Pi; sensor communication uses 1‑Wire over GPIO; control signals are isolated via MOSFETs and optocouplers; network connectivity (Wi‑Fi/Bluetooth) of the Pi enables remote access."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ broker and the low‑level driver are deployed directly on the Raspberry Pi 4 Model B, which also hosts the controller software."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safety protocol to keep the hardware in a safe state; MOSFET drivers are isolated with optocouplers to prevent electrical faults; the DT enforces upper/lower temperature limits to avoid unsafe heating."
]