// Sensors
instance PhysicalTwinMeasurementSensor : DTDFVocab:SensingComponent [
    base:desc "Measures physical quantities of the Physical Twin and streams outputs to the data acquisition layer."
    DTDFVocab:producedData PhysicalTwinDataTransmission
]

// Data Transmission
instance PhysicalTwinDataTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalTwinMeasurementSensor
]

// Data
instance PhysicalTwinTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series data of measurable physical states retrieved from the Physical Twin."
    DTDFVocab:fromData PhysicalTwinDataTransmission
    DTDFVocab:inputTo DataAcquisitionLayer, ModelingSubsystem, AlgorithmicLayer
]

// Enablers
instance DataAcquisitionLayer : DTDFVocab:Enabler [
    base:desc "Layer that streams sensor outputs into InfluxDB time‑series database."
    DTDFVocab:enables MonitoringService, OptimizationService, PredictiveService
]

instance ModelingSubsystem : DTDFVocab:Enabler [
    base:desc "Subsystem encapsulating physics‑based differential equation models, empirical models, and agent‑based representations."
    DTDFVocab:enables OptimizationService, PredictiveService
]

instance AlgorithmicLayer : DTDFVocab:Enabler [
    base:desc "Includes calibration routines, fault‑detection logic, supervisory controllers, state‑estimation filters, and optimisation solvers."
    DTDFVocab:enables MonitoringService, ControlService, PredictiveService, OptimizationService
]

instance DigitalTwinEngine : DTDFVocab:Enabler [
    base:desc "Orchestrates simulation engines, database interfaces, and event‑driven middleware."
    DTDFVocab:enables MonitoringService, ControlService, VisualizationService
]

// Models
instance CADModel : DTDFVocab:Model [
    base:desc "Geometric CAD representation integrated within the simulation subsystem."
    DTDFVocab:inputTo ModelingSubsystem
]

instance DynamicBehavioralModel : DTDFVocab:Model [
    base:desc "Differential equations capturing dynamic behavior."
    DTDFVocab:inputTo ModelingSubsystem
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitors live sensor data against calibrated models using real‑time monitors to detect deviations from safety and optimal operating envelopes."
    DTDFVocab:provides FaultDetectionInsight, FaultAlertAction, ControlDecisionInsight, ControlAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Runs simulation‑based optimisation to improve performance metrics."
    DTDFVocab:provides OptimizationInsight, OptimizationAction
]

instance PredictiveService : DTDFVocab:Service [
    base:desc "Uses state estimators and fault detectors to extrapolate future states."
    DTDFVocab:provides PredictiveInsight, PredictiveAction
]

instance ControlService : DTDFVocab:Service [
    base:desc "Provides supervisory control actions to adjust the Physical Twin or recommend manual interventions."
    DTDFVocab:provides ControlDecisionInsight, ControlAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Maps simulation outputs, sensor streams, and diagnostic reports into dashboards for engineers and stakeholders."
    DTDFVocab:provides VisualizationInsight, VisualizationAction
]

// Insights
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identifies when monitors detect violations and flags potential fault onset."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Presents optimized operational decisions."
]

instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Forecasts future states based on current data and model predictions."
]

instance ControlDecisionInsight : DTDFVocab:Insight [
    base:desc "Recommends control actions or automatically changes PT behaviour."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of PT status and trends."
]

// Actions
instance FaultAlertAction : DTDFVocab:Action [
    base:desc "Alerts operator upon fault detection."
    DTDFVocab:IsAutomatic true
]

instance OptimizationAction : DTDFVocab:Action [
    base:desc "Deploys optimal control parameters."
    DTDFVocab:IsAutomatic true
]

instance PredictiveAction : DTDFVocab:Action [
    base:desc "Triggers predictive maintenance operation."
    DTDFVocab:IsAutomatic true
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Adjusts PT parameters."
    DTDFVocab:IsAutomatic true
]

instance VisualizationAction : DTDFVocab:Action [
    base:desc "Refreshes dashboard."
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin orchestrates data, models, and algorithms within a layered architecture. Data are ingested continuously from the Physical Twin via its sensors and stored in a time‑series repository. A calibration layer of algorithms iteratively updates the cyber and physical models, producing a calibrated model set that represents the CPS and its environment. Monitoring services consume the calibrated data to enforce safety and performance constraints. Violations trigger either automated corrective action or human intervention. The system manages resources by coordinating model updates, simulation cycles, and monitor executions, ensuring that data, computational models, and control logic are coherently integrated and deployed across the Digital Twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Development Phase: creation of abstract models (e.g., CAD representations of a car’s geometry and dynamic differential‑equation models of its motion). Representation Transition: conversion of these design‑time models into runtime models that incorporate streamed sensor data; calibration algorithms iteratively adjust model parameters to align simulated dynamics with measured physical behavior. Deployment Phase: launch of the Digital Twin framework alongside the Physical Twin, enabling real‑time monitoring and simulation. Transition Management: continuous calibration loops and parameter estimation embedded in the Digital Twin’s core engine. Governance: safety and performance monitors evaluate operational metrics; upon detection of violations, alerts trigger human review or automated corrective actions, thereby enforcing lifecycle control."
]