// C3: Physical sensing components
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer attached to the physical twin; read periodically by a Raspberry Pi driver"
    DTDFVocab:producedData TemperatureDataTransmitted
]

// C4: Physical-to-virtual interaction
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// C10: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Numeric temperature value streamed from the DS18S20 sensor"
    DTDFVocab:fromData TemperatureDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker,
                CalibrationEngine,
                SimulationEngine,
                MonitoringEngine,
                OptimisationEngine
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker using AMQP protocol for transporting sensor readings to the Digital Twin"
    DTDFVocab:enables DataIngestionService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Algorithmic engine that performs model parameter estimation (calibration) using incoming sensor data"
    DTDFVocab:enables CalibrationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine that executes CPS and environment models to reproduce and predict PT behaviour"
    DTDFVocab:enables SimulationService
]

instance MonitoringEngine : DTDFVocab:Enabler [
    base:desc "Engine implementing fault detection, supervisory control and state estimation for continuous monitoring"
    DTDFVocab:enables MonitoringService
]

instance OptimisationEngine : DTDFVocab:Enabler [
    base:desc "Optimisation algorithm that computes optimal set‑points and performance metrics"
    DTDFVocab:enables OptimisationService
]

// C6: Services
instance DataIngestionService : DTDFVocab:Service [
    base:desc "Ingests raw temperature data from RabbitMQ and makes it available to downstream DT components"
    DTDFVocab:provides RawTemperatureDataInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibrates CPS and environment models by updating parameters to best‑estimate values"
    DTDFVocab:provides ParameterEstimationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs simulations to reproduce observed PT behaviour and predict future states under current conditions"
    DTDFVocab:provides PredictionInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuously evaluates health indicators and performance metrics to detect safety or optimality violations"
    DTDFVocab:provides SafetyViolationInsight,
                TriggerHumanIntervention
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Optimises operation by generating performance metrics and set‑points; can trigger automated remediation"
    DTDFVocab:provides PerformanceMetricInsight,
                AutomatedRemediation
]

// C17: Insights
instance RawTemperatureDataInsight : DTDFVocab:Insight [
    base:desc "Indicates that fresh temperature data has been received from the physical twin"
]

instance ParameterEstimationInsight : DTDFVocab:Insight [
    base:desc "Provides best‑estimate model parameters resulting from the calibration process"
]

instance PredictionInsight : DTDFVocab:Insight [
    base:desc "Predicts future temperature trajectories and other state variables of the physical twin"
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detects safety or optimality violations based on monitored health indicators"
]

instance PerformanceMetricInsight : DTDFVocab:Insight [
    base:desc "Generates performance metrics (e.g., efficiency, energy consumption) from simulation outputs"
]

// C17: Actions
instance TriggerHumanIntervention : DTDFVocab:Action [
    base:desc "Human operator evaluates alerts and decides on corrective actions for the physical twin"
    DTDFVocab:IsAutomatic false
]

instance AutomatedRemediation : DTDFVocab:Action [
    base:desc "Automated algorithm applies corrective actions (e.g., adjust set‑points) when violations are detected"
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance CPSModel : DTDFVocab:Model [
    base:desc "Cyber‑Physical System model representing the physical twin’s dynamics"
    DTDFVocab:inputTo CalibrationEngine,
                SimulationEngine,
                OptimisationEngine
]

instance EnvironmentModel : DTDFVocab:Model [
    base:desc "Model of the surrounding environment influencing the CPS behavior"
    DTDFVocab:inputTo CalibrationEngine,
                SimulationEngine,
                OptimisationEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands originate from the Digital Twin and are sent to the physical twin through the same RabbitMQ server. The controller component subscribes to command queues on RabbitMQ, listening for messages that request actions such as turning the fan on/off or activating the heatbed. Commands are simple control messages (e.g., a heating‑signal flag) delivered via AMQP. Upon receipt, the controller validates the message format, issues the corresponding electrical signal to the heatbed (or fan), and implicitly confirms execution by the physical actuation; explicit acknowledgment mechanisms are not detailed in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "According to Document 1, the Digital Twin is realized as a closed‑loop orchestration that integrates three core artifacts—sensor Data collected from the Physical Twin, domain Models describing the cyber and physical aspects, and Algorithms that process Data and Models. Calibration algorithms continuously adjust model parameters using the latest sensor data. The calibrated models feed monitoring components that evaluate safety and optimality criteria; upon detection of violations, the system (or a human operator) may trigger corrective actions on the Physical Twin. Thus the DT coordinates data ingestion, model update, monitoring, and decision‑making within a single framework, without explicit mention of distributed resource management or architectural patterns."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is governed by explicitly stated assumptions (Assumptions 1‑4) concerning system linearity, thermal homogeneity, and actuator response. Validation is performed through dedicated experiments (Section 4.1) that compare model predictions against measured sensor data, quantifying uncertainty via statistical analysis of repeated trials. Calibration algorithms iteratively adjust model parameters to minimise prediction error, and residuals are monitored for out‑of‑bounds deviations. Uncertainty sources (sensor noise, parameter drift) are propagated through the models, and error‑correction mechanisms (e.g., Kalman filtering) are applied. A quality‑assurance process includes verification of model code, regression testing after each calibration cycle, and documentation of validation results within the DT repository."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The technical connection relies on a RabbitMQ message broker deployed on the Raspberry Pi itself, providing the network backbone for data exchange. Communication between the sensor/actuator nodes and the broker uses the AMQP protocol over the Raspberry Pi’s built‑in Wi‑Fi (IEEE 802.11). The architecture is a star‑like topology with the Raspberry Pi acting as the central hub. Bandwidth and latency requirements are not quantified, but Wi‑Fi is assumed to meet the periodic sensor update rate. Reliability is supported by RabbitMQ’s durable queues, though redundancy mechanisms are not described. Security aspects such as authentication or encryption for the AMQP links are not mentioned in the source material."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin components, including the RabbitMQ server, are hosted directly on the edge device—a Raspberry Pi single‑board computer—representing an on‑premise/edge deployment model. Computational resources are limited to the Pi’s CPU and RAM, and storage is provided by its local micro‑SD card. The deployment is monolithic; no cloud or distributed scaling mechanisms are detailed. Availability is implied by the local hosting of the broker, but specific reliability guarantees or fail‑over strategies are not discussed."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT architecture includes safety‑oriented components: calibration algorithms update model parameters; monitors continuously evaluate the twin’s state to verify safe and optimal operation; fault‑detection and supervisory control algorithms generate alerts when violations are detected, at which point human operators or higher‑level algorithms may intervene to adjust the Physical Twin. These mechanisms constitute the safety considerations described in the document, though no specific cybersecurity protocols, authentication, or access‑control methods are detailed."
]