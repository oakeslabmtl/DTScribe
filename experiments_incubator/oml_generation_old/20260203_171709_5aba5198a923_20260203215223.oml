// Sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire digital temperature sensor inside the container measuring internal temperature at point A"
    DTDFVocab:producedData InternalTemp1DataTransmitted
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire digital temperature sensor inside the container measuring internal temperature at point B"
    DTDFVocab:producedData InternalTemp2DataTransmitted
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire digital temperature sensor outside the container measuring ambient room temperature"
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// Acting components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Relay‑driven heatbed controlled via a Raspberry‑Pi GPIO relay through a MOSFET/optocoupler interface, capable of ON/OFF commands"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Relay‑driven fans controlled via a Raspberry‑Pi GPIO relay through a MOSFET/optocoupler interface, capable of ON/OFF commands"
]

// Data transmitted from sensors
instance InternalTemp1DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTemp2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// Processed data
instance InternalTemp1Data : DTDFVocab:Data [
    base:desc "Temperature reading from internal DS18S20 sensor point A"
    DTDFVocab:fromData InternalTemp1DataTransmitted
    DTDFVocab:inputTo RaspberryPiEnabler
]

instance InternalTemp2Data : DTDFVocab:Data [
    base:desc "Temperature reading from internal DS18S20 sensor point B"
    DTDFVocab:fromData InternalTemp2DataTransmitted
    DTDFVocab:inputTo RaspberryPiEnabler
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Temperature reading from DS18S20 sensor outside the container"
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo RaspberryPiEnabler
]

// Experimental and calibration data
instance ExperimentalTemperatureTraceData : DTDFVocab:Data [
    base:desc "Recorded temperature traces from DS18S20 sensors for model calibration"
    DTDFVocab:inputTo RaspberryPiEnabler
]

instance ActuatorLogData : DTDFVocab:Data [
    base:desc "Logs of actuator ON/OFF events for heater and fan"
    DTDFVocab:inputTo RaspberryPiEnabler
]

instance CalibrationResidualData : DTDFVocab:Data [
    base:desc "Residuals from least‑squares calibration of physics‑based models"
    DTDFVocab:inputTo RaspberryPiEnabler
]

// Physics‑based temperature models
instance ModelA : DTDFVocab:Model [
    base:desc "Single‑parameter temperature dynamics model using parameters C_air and G_box"
    DTDFVocab:inputTo RaspberryPiEnabler
]

instance ModelB : DTDFVocab:Model [
    base:desc "Two‑parameter temperature dynamics model with parameters C_air, C_heater, G_box, G_heater"
    DTDFVocab:inputTo RaspberryPiEnabler
]

// Enablers
instance RaspberryPiEnabler : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4B hosting controller logic, polling sensors and sending data to RabbitMQ"
    DTDFVocab:enables TemperatureMonitoringService, TemperaturePredictionService, ParameterCalibrationService, BangBangControlService, VisualizationDashboardService
]

instance CustomPCBEnabler : DTDFVocab:Enabler [
    base:desc "Custom PCB with MOSFETs and optocouplers connecting Raspberry Pi GPIO pins to heatbed and fan relays"
    DTDFVocab:enables HeatbedActuator, FanActuator
]

instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker publishing sensor and actuator data over TCP"
    DTDFVocab:enables TemperatureMonitoringService, VisualizationDashboardService
]

// Services
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Online monitoring of temperature readings for real‑time dashboards"
    DTDFVocab:provides RealTimeTemperatureMeasurementsInsight
]

instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Digital simulation using ModelA and ModelB to predict temperature dynamics"
    DTDFVocab:provides RealTimeTemperaturePredictionsInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Non‑linear least‑squares optimization to calibrate physics‑based model parameters"
    DTDFVocab:provides CalibratedModelCoefficientsInsight
]

instance BangBangControlService : DTDFVocab:Service [
    base:desc "Bang‑bang temperature controller adjusting heater and fan ON/OFF states based on setpoint"
    DTDFVocab:provides BangBangTemperatureControlAction
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Live visualization dashboard displaying current temperature, actuator status, and control timing"
    DTDFVocab:provides MonitoringDashboardInsight
]

// Actions
instance BangBangTemperatureControlAction : DTDFVocab:Action [
    base:desc "Actuator control logic updating heater and fan on/off states according to bang‑bang temperature control algorithm"
    DTDFVocab:IsAutomatic true
]

// Insights
instance CalibratedModelCoefficientsInsight : DTDFVocab:Insight [
    base:desc "Calibrated model coefficients derived from least‑squares optimization"
]

instance RealTimeTemperaturePredictionsInsight : DTDFVocab:Insight [
    base:desc "Real‑time temperature predictions from physics‑based models"
]

instance MonitoringDashboardInsight : DTDFVocab:Insight [
    base:desc "Monitoring dashboard displaying current temperature, actuator status, and control timing"
]

instance RealTimeTemperatureMeasurementsInsight : DTDFVocab:Insight [
    base:desc "Real‑time temperature measurements from DS18S20 sensors"
]

// Physical components
instance ContainerInsulatedBox : DTDFVocab:Component [
    base:desc "Styrofoam insulated box approximating 0.03 m³ volume"
]

instance PowerSupply : DTDFVocab:Component [
    base:desc "12 V/24 V power supply powering the heatbed, fan, Raspberry Pi, and PCB"
]

// Environment
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:contains ContainerInsulatedBox, HeatbedActuator, FanActuator, InternalTempSensor1, InternalTempSensor2, AmbientTempSensor, RaspberryPiEnabler, CustomPCBEnabler, RabbitMQEnabler, PowerSupply
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Messages received by the Raspberry Pi over the RabbitMQ broker carry actuator commands (e.g., heater on/off, fan on/off). The low‑level driver translates these commands into GPIO pulses via the MOSFET interface to control the heatbed and fan."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time near‑real‑time operations where sensor polling and command exchanges occur on the order of seconds, consistent with the physical control loop’s heating (H) and waiting (C) durations."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellation consists of a RabbitMQ communication server running on the Raspberry Pi, a low‑level driver linking the PT hardware to the broker, a controller that implements a bang‑bang temperature policy, and the simulation models (Model A/B) which consume sensor data and produce predictions; all modules run centrally on the Pi and exchange messages via the broker."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design → Build → Calibration → Operation. The Physical Twin was fabricated (PCB, heatbed, sensors), the Digital Twin’s models were developed and calibrated against experimental data, and both systems operate together in continuous operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Assumptions: uniform temperature inside the container (validated by multi‑sensor tests), negligible heat transfer to walls, constant specific heat capacity of air, and in Model A the heatbed treated as a perfect heat source (excluded in Model B). Model validation was performed via comparison of predicted temperature traces with measured sensor data, minimising residual error through optimization."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical and virtual interactions are mediated by a local RabbitMQ broker running on the same Raspberry Pi. The broker implements the AMQP 0‑9‑1 protocol and exchanges JSON messages over the loopback interface (127.0.0.1). No external network exposure or additional transport protocols are employed."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT software (controller, driver, RabbitMQ, simulation models) runs locally on the Raspberry Pi. The PT and DT share the same board, eliminating remote cloud hosting; the system is physically deployed within the incubator bench."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safety is enforced by a simple safe protocol within the low‑level driver: every incoming command is validated against configured limits (e.g., heater or fan enabled only for specified durations), and temperature thresholds are monitored to prevent overheating. No cyber‑security measures (authentication, encryption) are implemented, as the RabbitMQ broker and all components operate on the same device with no external network exposure."
]