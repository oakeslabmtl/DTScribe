instance SensorNetwork : DTDFVocab:SensingComponent [
    base:desc "Sensor network collecting data from Physical Twin"
    DTDFVocab:producedData SensorDataTransmitted
]

instance SensorDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Data transmitted from sensor network to Digital Twin"
    DTDFVocab:producedFrom SensorNetwork
]

instance SensorData : DTDFVocab:Data [
    base:desc "Calibrated sensor data updated via calibration algorithms for model parameters"
    DTDFVocab:fromData SensorDataTransmitted
    DTDFVocab:inputTo FaultDetectionAlgorithm, StateEstimationAlgorithm, SupervisoryControlAlgorithm, OptimizationAlgorithm, PredictiveSimulationAlgorithm
]

instance GeometricModel : DTDFVocab:Model [
    base:desc "CAD representation of physical components for geometric modeling"
    DTDFVocab:inputTo FaultDetectionAlgorithm, StateEstimationAlgorithm, SupervisoryControlAlgorithm, OptimizationAlgorithm, PredictiveSimulationAlgorithm
]

instance BehavioralModel : DTDFVocab:Model [
    base:desc "Dynamic model described by differential equations for system dynamics"
    DTDFVocab:inputTo FaultDetectionAlgorithm, StateEstimationAlgorithm, SupervisoryControlAlgorithm, OptimizationAlgorithm, PredictiveSimulationAlgorithm
]

instance AnalyticalModel : DTDFVocab:Model [
    base:desc "Physics-based simulation model for analytical purposes"
    DTDFVocab:inputTo FaultDetectionAlgorithm, StateEstimationAlgorithm, SupervisoryControlAlgorithm, OptimizationAlgorithm, PredictiveSimulationAlgorithm
]

instance FaultDetectionAlgorithm : DTDFVocab:Enabler [
    base:desc "Algorithm for detecting faults using sensor data and models"
    DTDFVocab:enables FaultDetectionService
]

instance StateEstimationAlgorithm : DTDFVocab:Enabler [
    base:desc "Algorithm for estimating system state using sensor data and models"
    DTDFVocab:enables StateEstimationService
]

instance SupervisoryControlAlgorithm : DTDFVocab:Enabler [
    base:desc "Algorithm for automated adjustments based on system state"
    DTDFVocab:enables SupervisoryControlService
]

instance OptimizationAlgorithm : DTDFVocab:Enabler [
    base:desc "Algorithm for optimizing system performance"
    DTDFVocab:enables OptimizationService
]

instance PredictiveSimulationAlgorithm : DTDFVocab:Enabler [
    base:desc "Algorithm for predictive simulations of Physical Twin behavior"
    DTDFVocab:enables PredictiveSimulationService
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Service that checks system safety using sensor data"
    DTDFVocab:provides SafetyViolationDetectedInsight
]

instance PerformanceMonitoringService : DTDFVocab:Service [
    base:desc "Service that checks system performance for optimality using sensor data"
    DTDFVocab:provides SuboptimalPerformanceDetectedInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Service that reproduces and forecasts Physical Twin behavior under current conditions"
    DTDFVocab:provides OptimalConfigurationFoundInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service that detects faults using sensor data and models"
    DTDFVocab:provides FaultDetectedInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Service that assesses system state using sensor data and models"
    DTDFVocab:provides StateEstimatedInsight
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Service that provides automated adjustments based on system state"
    DTDFVocab:provides AutomatedAdjustmentAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that enhances performance through optimization algorithms"
    DTDFVocab:provides OptimalConfigurationFoundInsight
]

instance FaultDetectedInsight : DTDFVocab:Insight [
    base:desc "Insight generated by fault detection algorithms indicating a fault condition"
]

instance SafetyViolationDetectedInsight : DTDFVocab:Insight [
    base:desc "Insight generated by monitoring systems indicating a safety violation"
]

instance SuboptimalPerformanceDetectedInsight : DTDFVocab:Insight [
    base:desc "Insight generated by monitoring systems indicating suboptimal performance"
]

instance OptimalConfigurationFoundInsight : DTDFVocab:Insight [
    base:desc "Insight generated by optimizers indicating an optimal configuration"
]

instance StateEstimatedInsight : DTDFVocab:Insight [
    base:desc "Insight generated by state estimators for system state assessment"
]

instance ManualInterventionAction : DTDFVocab:Action [
    base:desc "Human-driven decision to modify Physical Twin based on insights"
    DTDFVocab:IsAutomatic false
]

instance AutomatedAdjustmentAction : DTDFVocab:Action [
    base:desc "Algorithm-driven decision to modify Physical Twin based on insights"
    DTDFVocab:IsAutomatic true
]