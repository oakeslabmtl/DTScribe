// Sensing Component
instance VehicleOnboardSensor : DTDFVocab:SensingComponent [
    base:desc "On-board vehicle sensor providing time-series measurements"
    DTDFVocab:producedData VehicleTelemetryTransmitted
]

// Data Transmitted
instance VehicleTelemetryTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleOnboardSensor
]

// Data
instance VehicleTelemetryData : DTDFVocab:Data [
    base:desc "Time-series vehicle telemetry data transmitted from VehicleOnboardSensor"
    DTDFVocab:fromData VehicleTelemetryTransmitted
    DTDFVocab:inputTo DataIngestionEnabler, CalibrationEngine, GeometricModelEnabler, BehavioralModelEnabler
]

// Models
instance VehicleGeometricModel : DTDFVocab:Model [
    base:desc "Hybrid geometric representation using CAD mesh encoding wheel dimensions, chassis geometry, and styling attributes"
    DTDFVocab:inputTo GeometricModelEnabler
]

instance VehicleBehavioralModel : DTDFVocab:Model [
    base:desc "Behavioral dynamic model expressed through ODEs relating physical forces to vehicle motion"
    DTDFVocab:inputTo BehavioralModelEnabler
]

// Enablers
instance DataIngestionEnabler : DTDFVocab:Enabler [
    base:desc "Facilitates ingestion of vehicle telemetry data into the digital twin"
    DTDFVocab:enables MonitoringService, FaultDetectionService, StateEstimationService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Calibration algorithms that ingest telemetry data to update models"
    DTDFVocab:enables FaultDetectionService, StateEstimationService
]

instance GeometricModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the geometric model used in supervisory control"
    DTDFVocab:enables SupervisoryControlService
]

instance BehavioralModelEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for the behavioral model used in optimisation"
    DTDFVocab:enables OptimisationService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of vehicle data and safety assessment"
    DTDFVocab:provides VehicleSafetyInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults based on model outputs and telemetry"
    DTDFVocab:provides FaultDetectionAlertAction
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Provides supervisory control and state estimation"
    DTDFVocab:provides DispatchCorrectionCommand
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "State estimation of vehicle physical state"
    DTDFVocab:provides StateEstimateInsight
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Optimises vehicle performance and predicts maintenance"
    DTDFVocab:provides PerformanceOptimizationInsight, ScheduleMaintenanceAction
]

// Insights
instance VehicleSafetyInsight : DTDFVocab:Insight [
    base:desc "Insight assessing safety by comparing current vehicle state against predefined thresholds"
]

instance StateEstimateInsight : DTDFVocab:Insight [
    base:desc "Estimated vehicle physical state derived from state estimation service"
]

instance PerformanceOptimizationInsight : DTDFVocab:Insight [
    base:desc "Predictive insight on optimal vehicle performance under various operating conditions"
]

// Actions
instance FaultDetectionAlertAction : DTDFVocab:Action [
    base:desc "Alert generated when a fault is detected in vehicle operation"
    DTDFVocab:IsAutomatic true
]

instance DispatchCorrectionCommand : DTDFVocab:Action [
    base:desc "Command to correct vehicle trajectory based on supervisory control"
    DTDFVocab:IsAutomatic true
]

instance ScheduleMaintenanceAction : DTDFVocab:Action [
    base:desc "Recommendation for maintenance scheduling based on performance optimisation"
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system is structured as a framework that integrates data acquisition from the Physical Twin via sensors, computational models representing both cyber‑physical and environmental aspects, and adaptive algorithms (such as calibration, fault detection, supervisory control, and optimisation). Calibration algorithms use incoming sensor data and model predictions to update model parameters; the updated model outputs are then consumed by monitors that assess safety and performance. When violations are detected, the framework allows human operators or autonomous decision‑making algorithms to initiate changes to the physical twin. This orchestration exemplifies the virtual‑physical mapping and continuous refinement cycle described in the document, though explicit architecture patterns or resource‑management details are not specified."
]