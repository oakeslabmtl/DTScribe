// C2: Acting Components
instance HeatbedActuator : DTDFVocab:Actuator [
    base:desc "Physical component delivering ≥100W power via MOSFETs and optocouplers for current isolation, controlled by Raspberry Pi 4 GPIO pins"
]

instance FanActuator : DTDFVocab:Actuator [
    base:desc "Operates at 12V/24V to circulate air at 0.02 m³/s through styrofoam insulated box, controlled via GPIO and RabbitMQ communication"
    DTDFVocab:producedData FanStatusDataTransmitted
]

// C3: Physical Sensing Components
instance RoomTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "External DS18S20 High-Precision 1-Wire Digital Thermometer measuring room temperature (-55°C to +125°C, 0.5°C accuracy)"
    DTDFVocab:producedData RoomTemperatureDataTransmitted
]

instance InternalTemperatureSensorT2 : DTDFVocab:SensingComponent [
    base:desc "Internal DS18S20 sensor (T2) measuring box air temperature at specific position (0.5°C accuracy)"
    DTDFVocab:producedData InternalTemperatureT2DataTransmitted
]

instance InternalTemperatureSensorT3 : DTDFVocab:SensingComponent [
    base:desc "Internal DS18S20 sensor (T3) measuring box air temperature at different position (0.5°C accuracy)"
    DTDFVocab:producedData InternalTemperatureT3DataTransmitted
]

// C4: Data Transmission
instance RoomTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTemperatureSensor
]

instance InternalTemperatureT2DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensorT2
]

instance InternalTemperatureT3DataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensorT3
]

instance PowerInputDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatbedActuator
]

instance FanStatusDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FanActuator
]

// C5: Data Collections
instance TemperatureReadingsData : DTDFVocab:Data [
    base:desc "Combined temperature readings (T_bair, T_room, T_heater) from all three DS18S20 sensors with 0.5°C accuracy"
    DTDFVocab:fromData RoomTemperatureDataTransmitted, InternalTemperatureT2DataTransmitted, InternalTemperatureT3DataTransmitted
]

instance PowerInputData : DTDFVocab:Data [
    base:desc "Power input measurements (V*I) from heatbed actuator"
    DTDFVocab:fromData PowerInputDataTransmitted
]

instance ExperimentalTrajectoriesData : DTDFVocab:Data [
    base:desc "Experimental temperature trajectories (uniform testing figures 10-12) for model validation"
]

// C6: Models
instance SimplifiedThermalModel : DTDFVocab:Model [
    base:desc "Single-parameter model (C_air) describing energy flow between box air and room via heat equation (Q = C_air * ΔT)"
]

instance DetailedThermalModel : DTDFVocab:Model [
    base:desc "Four-parameter model (C_air, C_heater, G_box, G_heater) accounting for heatbed thermal inertia and multi-path energy transfer"
]

// C10: Enablers
instance RaspberryPi4Hardware : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B serving as controller with GPIO for sensor/actuator control and RabbitMQ message broker deployment"
]

instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "Message broker facilitating real-time data transmission (discrete events + continuous streams) between PT and DT"
    DTDFVocab:inputTo SimplifiedThermalModel, DetailedThermalModel
]

instance PythonScipyEnabler : DTDFVocab:Enabler [
    base:desc "Python environment with SciPy library for non-linear least squares optimization (model calibration)"
]

// C6: Services
instance TemperatureRegulationService : DTDFVocab:Service [
    base:desc "Implements bang-bang controller with waiting delays to maintain target temperatures (293K-300K) via heatbed/fan adjustments"
    DTDFVocab:enables TemperatureRegulationAction
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Performs non-linear least squares optimization (Python Scipy) to refine parameters (C_air, C_heater, G_box, G_heater) for improved predictive accuracy"
    DTDFVocab:enables ParameterUpdateAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides temperature trend visualization and system state logging via RabbitMQ server and data logging infrastructure"
    DTDFVocab:enables VisualizationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Implicitly monitors system performance via residual error minimization during model calibration"
    DTDFVocab:enables ResidualErrorInsight
]

// C17: Insights/Actions
instance TemperatureRegulationAction : DTDFVocab:Action [
    base:desc "Adjusts heatbed/fan based on real-time sensor feedback to maintain target temperature range (293K-300K)"
    DTDFVocab:IsAutomatic true
]

instance ParameterUpdateAction : DTDFVocab:Action [
    base:desc "Calibrates model parameters (C_air, C_heater, G_box, G_heater) to improve predictive accuracy via optimization"
    DTDFVocab:IsAutomatic true
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides real-time temperature trend visualization and system state monitoring (heatbed/fan status)"
]

instance ResidualErrorInsight : DTDFVocab:Insight [
    base:desc "Detects system performance deviations implicitly through residual error minimization during model calibration"
]

// C12: Environment
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator, FanActuator, RoomTemperatureSensor, InternalTemperatureSensorT2, InternalTemperatureSensorT3
]

instance StyrofoamBoxEnvironment : DTDFVocab:Environment [
    base:desc "Insulated styrofoam container (0.03 m³ volume) housing all thermal components with uniform temperature target (293K-300K)"
    DTDFVocab:hasEnvironment ThermalIncubatorEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT communicates with the PT via the RabbitMQ server to issue commands for actuating the heatbed and fan. The interaction follows a bang-bang control strategy: the DT sends a heating command to the heatbed until the measured temperature (from T2/T3) reaches the reference temperature, followed by a waiting period (H and C parameters) to prevent overshoot. The DT uses a statechart-based controller (LL, UL, H, C parameters) to regulate temperature dynamically."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates on a **real-time to near-real-time** scale. Temperature data is sampled at a frequency determined by the control loop (H + C delay periods, e.g., ~2 seconds for heatbed actuation) and model updates occur via non-linear least squares calibration (experimental data collection rate: ~10–20 samples per minute). Synchronization between DT and PT is tightly coupled to the control cycle, ensuring timely feedback for temperature regulation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is a **centralized architecture** with the following components orchestrated via RabbitMQ: (1) **Physical Twin (PT)**: Insulated box, heatbed, fan, sensors, and Raspberry Pi controller; (2) **Digital Twin (DT)**: Calibration algorithms (Python), model updates, and visualization tools; (3) **Communication Layer**: RabbitMQ server (on Raspberry Pi) for message synchronization between PT and DT; (4) **Control Loop**: PT → RabbitMQ → DT (temperature feedback) → DT → RabbitMQ → PT (actuation commands)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the following life-cycle stages for the incubator PT: (1) **As-designed**: Idealized models (Model A/B) with assumptions (uniform temperature, negligible heat loss to walls, constant air properties). (2) **As-manufactured**: Calibrated models (Model B) with four parameters (C_air, C_heater, G_box, G_heater) derived from experimental data. (3) **As-operated**: Real-time DT operation with temperature regulation, model updates, and fault monitoring during runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT’s fidelity and validity are ensured through: (1) **Assumptions Validation**: Uniform temperature distribution is experimentally validated (figs. 10–12), showing discrepancies ≤7°C with fan adjustments; (2) **Model Calibration**: Non-linear least squares optimization minimizes residual error between model predictions and experimental data (section 3.3); (3) **Uncertainty Handling**: Model parameters (C_air, C_heater, G_box, G_heater) are empirically derived from calibration experiments; (4) **Verification/Validation**: Experimental setup (figs. 9–12) and model comparison (Model B outperforms Model A by accounting for heatbed inertia)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT technical connection uses a **networked CPS architecture** with the following details: (1) **Protocol**: RabbitMQ (open-source message broker) for real-time data exchange between PT and DT; (2) **Network**: Deployed on the Raspberry Pi (local network) with built-in Wi-Fi/Bluetooth; (3) **Communication Flow**: PT → RabbitMQ (temperature/fan status) → DT (model updates/control logic) → RabbitMQ → PT (actuation commands); (4) **Latency**: Control loop latency is dominated by H + C delays (~2 seconds), ensuring real-time synchronization."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted/deployed on the **Raspberry Pi 4 Model B** as a local, on-premises system. The RabbitMQ server runs on the same device, enabling low-latency communication between PT and DT components. The hardware/software specifications are publicly available in the INTO-CPS Association repository ([link](https://github.com/INTO-CPS-Association/example-incubator))."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT includes safety considerations: (1) **Hardware Isolation**: MOSFETs/optocouplers decouple Raspberry Pi control signals from high-current heatbed actuation; (2) **Control Protocol**: Bang-bang controller with waiting delays (H, C parameters) prevents overshoot; (3) **Data Safety**: RabbitMQ ensures message integrity and synchronization between PT and DT; (4) **Remote Operation**: The DT can remotely control the PT (heatbed/fan) via the Raspberry Pi’s GPIO and RabbitMQ, but physical safety is ensured by the hardware isolation and control logic (no direct human intervention required)."
]