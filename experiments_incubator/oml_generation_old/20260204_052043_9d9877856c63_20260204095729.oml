instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "High-precision DS18S20 1-Wire digital thermometer measuring real-time temperature inside the styrofoam box for thermal monitoring and control."
    DTDFVocab:producedData InternalTemperatureDataTransmitted
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "High-precision DS18S20 1-Wire digital thermometer measuring real-time temperature inside the styrofoam box (secondary location) for redundancy and uniform temperature validation."
    DTDFVocab:producedData InternalTemperatureDataTransmitted
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "High-precision DS18S20 1-Wire digital thermometer measuring ambient room temperature outside the styrofoam box to account for environmental conditions affecting the PT."
    DTDFVocab:producedData ExternalTemperatureDataTransmitted
]

instance InternalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1, InternalTemperatureSensor2
    base:desc "Continuously transmitted temperature measurements from internal DS18S20 sensors to Raspberry Pi via GPIO at high frequency for real-time monitoring."
]

instance ExternalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
    base:desc "Continuously transmitted ambient temperature measurements from external DS18S20 sensor to Raspberry Pi via GPIO for environmental compensation."
]

instance SystemStateDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Collected system state data (heatbed/fan activation states, power supply metrics) from low-level driver and sent to RabbitMQ for DT processing."
]

instance SimplifiedThermalModel : DTDFVocab:Model [
    base:desc "A simplified thermal model with 2 free parameters (_G_box_, _C_air_) assuming all energy from the heatbed is transferred to the air without heatbed accumulation."
    DTDFVocab:inputTo ThermalSimulationScripts, PythonModelCalibrationLogic
]

instance DetailedThermalModel : DTDFVocab:Model [
    base:desc "A detailed thermal model with 4 free parameters (_G_box_, _C_air_, _G_heater_, _C_heater_) accounting for heat accumulation in the heatbed and more accurate energy distribution."
    DTDFVocab:inputTo ThermalSimulationScripts, PythonModelCalibrationLogic, RaspberryPiController
]

instance RealTimeTemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature measurements from DS18S20 sensors used for monitoring, control, and model validation."
    DTDFVocab:fromData InternalTemperatureDataTransmitted, ExternalTemperatureDataTransmitted
    DTDFVocab:inputTo ThermalSimulationScripts, PythonModelCalibrationLogic, RaspberryPiController, DataVisualizationService
]

instance ActuatorStateData : DTDFVocab:Data [
    base:desc "Power supply voltage/current and activation states of heatbed/fan collected for system state awareness and control adjustments."
    DTDFVocab:fromData SystemStateDataTransmitted
    DTDFVocab:inputTo RaspberryPiController, DataVisualizationService
]

instance EnvironmentalConditionData : DTDFVocab:Data [
    base:desc "Room temperature and external conditions affecting the PT, used for environmental compensation in thermal models."
    DTDFVocab:fromData ExternalTemperatureDataTransmitted
    DTDFVocab:inputTo ThermalSimulationScripts, PythonModelCalibrationLogic
]

instance RabbitMQCommunicationServer : DTDFVocab:Enabler [
    base:desc "Central message broker (RabbitMQ) handling all communication between physical components (sensors, actuators) and DT modules via publish-subscribe model."
    DTDFVocab:enables ThermalSimulationService, ModelCalibrationService, FaultDetectionService, ControlOptimizationService, DataVisualizationService
]

instance PythonModelCalibrationLogic : DTDFVocab:Enabler [
    base:desc "Python-based optimization logic using Scipy for least-squares parameter calibration of thermal models against real-world data."
    DTDFVocab:enables ModelCalibrationService
]

instance RaspberryPiController : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B executing low-level control logic (e.g., bang-bang controller) and interfacing with sensors/actuators via GPIO."
    DTDFVocab:enables FaultDetectionService, ControlOptimizationService
]

instance ThermalSimulationScripts : DTDFVocab:Enabler [
    base:desc "Custom Python scripts for running thermal simulations using Model A/B and validating against experimental data."
    DTDFVocab:enables ThermalSimulationService
]

instance ThermalSimulationService : DTDFVocab:Service [
    base:desc "Service running simulations to predict thermal behavior of the PT under current or hypothetical conditions (e.g., ambient temperature changes)."
    DTDFVocab:provides ThermalBehaviorPredictionInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Service adjusting model parameters (_G_box_, _C_air_, _G_heater_, _C_heater_) using least-squares optimization to minimize residuals against real-world data."
    DTDFVocab:provides CalibratedModelParametersInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service monitoring temperature deviations and system state anomalies to detect faults (e.g., overheating, cooling failures)."
    DTDFVocab:provides FaultAlertAction, AutomaticCorrectiveAction
]

instance ControlOptimizationService : DTDFVocab:Service [
    base:desc "Service fine-tuning control parameters (e.g., heating/waiting durations) for energy efficiency and system responsiveness."
    DTDFVocab:provides OptimizedControlParametersInsight
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Service presenting real-time and simulated data (e.g., temperature trajectories, energy flow) for analysis and decision-making."
    DTDFVocab:provides VisualizedThermalDataInsight
]

instance ThermalBehaviorPredictionInsight : DTDFVocab:Insight [
    base:desc "Forecasted system behavior under different conditions (e.g., ambient temperature changes) aiding proactive decision-making."
]

instance CalibratedModelParametersInsight : DTDFVocab:Insight [
    base:desc "Optimized model parameters (_G_heater_, _C_air_) providing insights into thermal inertia and energy efficiency of the PT."
]

instance OptimizedControlParametersInsight : DTDFVocab:Insight [
    base:desc "Refined control parameters (e.g., heating/waiting durations) improving system responsiveness and energy use."
]

instance FaultAlertAction : DTDFVocab:Action [
    base:desc "Automatic alert triggered by temperature anomalies or system malfunctions."
    DTDFVocab:IsAutomatic true
]

instance AutomaticCorrectiveAction : DTDFVocab:Action [
    base:desc "Automatic corrective measures (e.g., reducing heatbed power) in response to detected faults."
    DTDFVocab:IsAutomatic true
]

instance VisualizedThermalDataInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of real-time and simulated temperature trajectories, energy flow, and system state for analysis."
]

instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heating element controlling air temperature inside the styrofoam box via MOSFET-driven power regulation."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Air circulation fan ensuring uniform temperature distribution inside the box, controlled via Raspberry Pi."
]

instance RaspberryPiControllerActuator : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi executing control logic (e.g., bang-bang controller) to regulate HeatbedActuator and FanActuator based on sensor data."
]

instance MosfetDriver : DTDFVocab:ActingComponent [
    base:desc "MOSFET-based high-current driver decoupling Raspberry Pi from heatbed power control signals for safety and efficiency."
]

instance StyrofoamBox : DTDFVocab:Component [
    base:desc "Insulated container providing thermal isolation for the incubator system."
]

instance Heatbed : DTDFVocab:Component [
    base:desc "Heating element with thermal mass accumulating heat energy for precise temperature control."
]

instance Fan : DTDFVocab:Component [
    base:desc "Air circulation device ensuring uniform temperature distribution within the styrofoam box."
]

instance PowerSupply : DTDFVocab:Component [
    base:desc "Electrical power source providing voltage/current to heatbed and fan via controlled actuators."
]

instance PhysicalThermalIncubator : DTDFVocab:Component [
    base:desc "Cyber-Physical System (CPS) integrating physical components (styrofoam box, heatbed, fan) with cyber components (Raspberry Pi, software controller) for autonomous temperature regulation."
    base:contains StyrofoamBox, Heatbed, Fan, PowerSupply, InternalTemperatureSensor1, InternalTemperatureSensor2, ExternalTemperatureSensor
]

instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Operational environment for the PhysicalThermalIncubator including ambient conditions and external influences."
    base:contains PhysicalThermalIncubator, ExternalTemperatureSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The **interactions from the DT to the PT** include:
  - **Control Commands**: Sent from the DT (via RabbitMQ) to the Raspberry Pi controller to activate/deactivate the heatbed or fan.
  - **Parameter Adjustments**: Dynamic updates to control parameters (e.g., heating duration, waiting duration) based on DT simulations or optimization algorithms.
  - **Actuation Signals**: Generated by the controller to modulate the heatbed and fan based on real-time feedback."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The **twinning time scale** for the incubator DT is characterized by:
1. **Real-Time Monitoring**:
   - **Sensor polling rate**: ~2 seconds (aligned with fan circulation time of 0.03 m³ / 0.02 m³/s).
   - **Actuator response time**: <2 seconds (heatbed can raise T_bair by 200J in <2s at 100W).
   - **Control loop latency**: Determined by RabbitMQ message propagation (<100ms) and GPIO signal delay (<1ms).
2. **Offline Calibration**:
   - **Parameter optimization**: Executed periodically (e.g., daily) using the **Scipy least-squares solver** to update G_box, C_air, G_heater, and C_heater.
   - **Validation experiments**: Conducted to test Assumption 1 (uniform temperature) with 12V/18V fan setups.
3. **Time-Scale Hierarchy**:
   - **Fast dynamics**: Fan circulation (2s) and heatbed response (<2s).
   - **Slow dynamics**: Heat loss through box walls (modeled via G_box) and heatbed thermal inertia (Model B).
   - **Event-driven updates**: Control parameter adjustments (LL, UL, H, C) triggered by deviations >7°C/6°C.

The DT operates in a **hybrid time scale**, with **real-time closed-loop control** for safety and **offline batch processing** for calibration. The system is designed for **low-latency actuation** (<2s) but tolerates **asynchronous model updates** (e.g., nightly recalibration)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **DT constellation** is orchestrated as follows:
  - **Physical Layer**: Includes the incubator hardware (sensors, actuators, Raspberry Pi).
  - **Cyber Layer**: Comprises the software components (controller, low-level driver, RabbitMQ server) running on the Raspberry Pi.
  - **Communication Layer**: RabbitMQ acts as a message broker to synchronize data between the PT and DT, enabling decoupled and scalable interactions.
  - **Service Layer**: The DT provides services like simulation, calibration, and optimization, which are accessed via the RabbitMQ interface."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The **life-cycle stages** covered by the DT include:
  - **As Designed (Ideal)**: Initial models (Model A and Model B) are derived from theoretical assumptions and simplified physics.
  - **As Manufactured**: Hardware components (e.g., PCB, sensors) are calibrated and tested to ensure they meet design specifications.
  - **As Operated**: The DT continuously monitors and adapts to real-world conditions (e.g., temperature fluctuations, sensor noise) during operation. The system supports runtime adjustments (e.g., parameter calibration) to maintain performance."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The **fidelity and validity** aspects include:
  - **Assumptions Testing**: Experiments validate critical assumptions (e.g., uniform temperature distribution via fan airflow, negligible heat loss through box walls).
  - **Model Validation**: Model B (4 parameters) outperforms Model A (2 parameters) in predicting thermal inertia, as demonstrated by lower residual errors during calibration.
  - **Uncertainty Handling**: Free parameters in models are calibrated using non-linear least squares to account for real-world variability (e.g., sensor noise, environmental fluctuations).
  - **Verification**: Experimental results (e.g., temperature trajectories) are compared against simulated data to ensure model accuracy.
  - **Error Mitigation**: Safe protocols in the low-level driver prevent unsafe states (e.g., overheating) during operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical connections** between PT and DT include:
  - **Network Protocol**: RabbitMQ (message broker) for asynchronous communication between components.
  - **Data Transmission**: Temperature data and control commands are exchanged via RabbitMQ queues/topics.
  - **Hardware Interface**: GPIO pins on the Raspberry Pi connect sensors/actuators to the cyber layer.
  - **Architecture**: Decentralized but coordinated, with the Raspberry Pi acting as the central node for data collection and control."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **hosting and deployment** details are:
  - **Local Deployment**: The DT and its components (RabbitMQ, controller, drivers) run on the Raspberry Pi itself, minimizing latency and network dependencies.
  - **Cloud Potential**: While not explicitly deployed in the cloud, the architecture supports cloud integration (e.g., hosting RabbitMQ or simulation models remotely).
  - **Open-Source Accessibility**: All code and hardware designs are available on GitHub, enabling easy replication or extension."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The **horizontal integration** aspects are:
  - **Limited to Internal Systems**: The current DT focuses on internal incubator operations (e.g., temperature control) without explicit integration with external systems (e.g., other DTs, enterprise resource planning).
  - **Extensible Architecture**: RabbitMQ’s modular design allows future integration with external systems (e.g., IoT platforms, cloud services) by adding new message queues/topics."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The **standardization** aspects include:
  - **Open Standards**: Use of open-source tools (RabbitMQ, Python, Scipy) and hardware (Raspberry Pi, DS18S20 sensors) adheres to widely adopted standards.
  - **Interoperability**: The RabbitMQ-based communication protocol enables interoperability with other systems supporting AMQP (Advanced Message Queuing Protocol).
  - **No Proprietary Standards**: The system avoids vendor-locked solutions, ensuring flexibility and reproducibility."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The **security and safety** considerations include:
  - **Safety**:
    - **Hardware Safeguards**: MOSFETs and optocouplers isolate high-power components from the Raspberry Pi to prevent damage.
    - **Control Logic**: The bang-bang controller includes safety limits (e.g., upper/lower temperature thresholds) to avoid overheating or excessive cooling.
    - **Low-Level Driver Protocols**: Safe protocols ensure the system remains in a stable state even during failures (e.g., sensor malfunctions).
  - **Security**:
    - **Local Deployment**: The DT runs locally on the Raspberry Pi, reducing exposure to remote attacks.
    - **No Explicit Security Measures**: While not detailed, potential risks (e.g., unauthorized RabbitMQ access) could be mitigated by adding authentication (e.g., TLS for RabbitMQ) or firewalls in a networked deployment.
    - **Remote Operations**: The DT could theoretically execute remote operations (e.g., adjusting control parameters), but safety mechanisms (e.g., manual overrides) would be required to prevent accidents with humans or equipment."
]