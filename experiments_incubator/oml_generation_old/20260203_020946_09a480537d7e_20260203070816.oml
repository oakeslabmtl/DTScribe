// C3: Physical sensing components
instance TemperatureSensorIncubatorInside1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (unique 64‑bit ID) measuring temperature inside the incubator (location 1)."
    DTDFVocab:producedData TemperatureMessageIncubatorInside1
]
instance TemperatureSensorIncubatorInside2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (unique 64‑bit ID) measuring temperature inside the incubator (location 2)."
    DTDFVocab:producedData TemperatureMessageIncubatorInside2
]
instance TemperatureSensorRoomAmbient : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer (unique 64‑bit ID) measuring ambient room temperature."
    DTDFVocab:producedData TemperatureMessageRoomAmbient
]

// C4: Physical-to-virtual interaction (data transmitted)
instance TemperatureMessageIncubatorInside1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorIncubatorInside1
]
instance TemperatureMessageIncubatorInside2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorIncubatorInside2
]
instance TemperatureMessageRoomAmbient : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensorRoomAmbient
]

// C10: Data objects
instance TemperatureDataIncubatorInside1 : DTDFVocab:Data [
    base:desc "Temperature measurement (°C) read from TemperatureSensorIncubatorInside1."
    DTDFVocab:fromData TemperatureMessageIncubatorInside1
    DTDFVocab:inputTo RabbitMQBrokerEnabler
]
instance TemperatureDataIncubatorInside2 : DTDFVocab:Data [
    base:desc "Temperature measurement (°C) read from TemperatureSensorIncubatorInside2."
    DTDFVocab:fromData TemperatureMessageIncubatorInside2
    DTDFVocab:inputTo RabbitMQBrokerEnabler
]
instance TemperatureDataRoomAmbient : DTDFVocab:Data [
    base:desc "Temperature measurement (°C) read from TemperatureSensorRoomAmbient."
    DTDFVocab:fromData TemperatureMessageRoomAmbient
    DTDFVocab:inputTo RabbitMQBrokerEnabler
]

// C11: Enablers
instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker running on the Raspberry Pi, transporting sensor measurements to DT services."
    DTDFVocab:enables MonitoringService, ActuationService
]
instance SciPyOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "SciPy Python library used for non‑linear least‑squares calibration and optimisation of thermal models."
    DTDFVocab:enables CalibrationService, SimulationService, PredictionService, OptimizationService
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Dynamic thermal Model A with free parameters V I Δt and G_box."
    DTDFVocab:inputTo SciPyOptimizationEnabler
]
instance ThermalModelB : DTDFVocab:Model [
    base:desc "Dynamic thermal Model B with free parameters C_heater, C_air, G_heater, G_box."
    DTDFVocab:inputTo SciPyOptimizationEnabler
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature limits, detecting violations."
    DTDFVocab:provides TemperatureViolationInsight
]
instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration of Model A and Model B parameters using non‑linear least‑squares optimisation."
    DTDFVocab:provides CalibratedParametersInsight
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of incubator temperature dynamics using Model A or Model B."
    DTDFVocab:provides SimulationResultInsight
]
instance PredictionService : DTDFVocab:Service [
    base:desc "Prediction of future temperature trajectories based on calibrated models."
    DTDFVocab:provides PredictedTrajectoryInsight
]
instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimisation of heating (H) and waiting (C) durations for safe operation."
    DTDFVocab:provides OptimizedDurationInsight
]
instance ActuationService : DTDFVocab:Service [
    base:desc "Translates DT commands into actuation signals for the heat‑bed and fan."
    DTDFVocab:provides TurnHeatBedOnAction, TurnHeatBedOffAction, TurnFanOnAction, TurnFanOffAction, AdjustHeatingDurationAction, AdjustWaitingDurationAction
]

// C17: Insights
instance TemperatureViolationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that measured temperature exceeds or falls below predefined safe limits."
]
instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Calibrated model parameters (e.g., V I Δt, G_box, C_heater, C_air, G_heater) derived from experimental temperature trajectories."
]
instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Simulated temperature trajectory of incubator air and heater for given input voltage/current."
]
instance PredictedTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature evolution over the next time horizon."
]
instance OptimizedDurationInsight : DTDFVocab:Insight [
    base:desc "Optimised values for heating duration H and waiting duration C to maintain temperature within limits."
]

// C17: Actions
instance TurnHeatBedOnAction : DTDFVocab:Action [
    base:desc "Command to activate the heat‑bed via MOSFET switch on the custom PCB."
    DTDFVocab:IsAutomatic true
]
instance TurnHeatBedOffAction : DTDFVocab:Action [
    base:desc "Command to deactivate the heat‑bed via MOSFET switch."
    DTDFVocab:IsAutomatic true
]
instance TurnFanOnAction : DTDFVocab:Action [
    base:desc "Command to start the internal fan via MOSFET switch."
    DTDFVocab:IsAutomatic true
]
instance TurnFanOffAction : DTDFVocab:Action [
    base:desc "Command to stop the internal fan via MOSFET switch."
    DTDFVocab:IsAutomatic true
]
instance AdjustHeatingDurationAction : DTDFVocab:Action [
    base:desc "Suggested adjustment of heating duration H based on insights."
    DTDFVocab:IsAutomatic false
]
instance AdjustWaitingDurationAction : DTDFVocab:Action [
    base:desc "Suggested adjustment of waiting duration C based on insights."
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed driven on/off through MOSFET switch on the custom PCB."
]
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V fan driven on/off via MOSFET switch on the custom PCB."
]

// C9: Environment (optional grouping)
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains TemperatureSensorIncubatorInside1, TemperatureSensorIncubatorInside2, TemperatureSensorRoomAmbient,
                 HeatBedActuator, FanActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT components subscribe to the RabbitMQ broker and send control commands (heat‑bed ON/OFF, fan ON/OFF) back to the controller, which then actuates the MOSFET switches to affect the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture comprises a RabbitMQ communication server, a low‑level driver that abstracts sensor/actuator I/O, a controller implementing a bang‑bang‑like algorithm with limits (LL, UL) and timing parameters (H, C), and external DT components that listen to the message bus to run simulations, perform calibration, and generate monitoring alerts."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is validated through uniform‑temperature experiments (comparing three sensor readings) and through calibration that minimises the least‑squares error between measured and simulated temperature trajectories; residual errors are reduced via gradient‑descent optimisation. Assumptions (uniform air temperature, negligible wall heat storage, constant air specific heat) are explicitly tested and documented."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual and virtual‑to‑physical data exchange occurs over the RabbitMQ message broker using the AMQP protocol over the Raspberry Pi's network interfaces (Wi‑Fi or Ethernet)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components (RabbitMQ server, low‑level driver, controller, and simulation/calibration services) are hosted on the same Raspberry Pi 4 hardware that also controls the incubator."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the device in a safe state, and the controller monitors temperature limits (LL, UL) to prevent overheating; safety monitoring is part of the DT's runtime checks."
]