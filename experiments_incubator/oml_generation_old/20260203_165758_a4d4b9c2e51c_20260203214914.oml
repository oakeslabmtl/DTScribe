// C3: Physical sensing components
instance HeatbedTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor inside the insulated box measuring heatbed temperature."
    DTDFVocab:producedData HeatbedTempMessage
]
instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor positioned outside the insulated box measuring ambient temperature."
    DTDFVocab:producedData AmbientTempMessage
]
instance ExperimentalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor reused during experiments to monitor internal temperature."
    DTDFVocab:producedData ExperimentalTempMessage
]

// C4: Physical‑to‑virtual interaction
instance HeatbedTempMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatbedTemperatureSensor
]
instance AmbientTempMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]
instance ExperimentalTempMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExperimentalTemperatureSensor
]

// C10: Models/Data
instance HeatbedTempData : DTDFVocab:Data [
    base:desc "Time‑series of heatbed temperature readings received from Heatbed temperature sensor."
    DTDFVocab:inputTo MonitoringEnabler
    DTDFVocab:fromData HeatbedTempMessage
]
instance AmbientTempData : DTDFVocab:Data [
    base:desc "Time‑series of ambient temperature readings received from Ambient temperature sensor."
    DTDFVocab:inputTo MonitoringEnabler
    DTDFVocab:fromData AmbientTempMessage
]
instance ExperimentalTempData : DTDFVocab:Data [
    base:desc "Time‑series of internal temperature readings received from Experimental temperature sensor."
    DTDFVocab:inputTo MonitoringEnabler
    DTDFVocab:fromData ExperimentalTempMessage
]
instance ActuatorStateData : DTDFVocab:Data [
    base:desc "Historical logs of heatbed and fan actuator states."
    DTDFVocab:inputTo MonitoringEnabler
    DTDFVocab:fromData HeatbedTempMessage, AmbientTempMessage, ExperimentalTempMessage
]
instance CalibrationDataSet : DTDFVocab:Data [
    base:desc "Calibration data collected from temperature sensors and power usage for model parameter estimation."
    DTDFVocab:inputTo CalibrationEnabler
    DTDFVocab:fromData HeatbedTempMessage, AmbientTempMessage, ExperimentalTempMessage
]

instance ModelA_Thermal : DTDFVocab:Model [
    base:desc "Thermal model A describing temperature evolution using differential equations."
    DTDFVocab:inputTo ThermoSimulationEnabler
]
instance ModelB_Thermal : DTDFVocab:Model [
    base:desc "Thermal model B providing an alternative set of heat transfer equations."
    DTDFVocab:inputTo ThermoSimulationEnabler
]

// C11: Enablers
instance ThermoSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Integrator that feeds Model A and Model B into the simulation service."
    DTDFVocab:enables ThermalSimulationService
]
instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Processor that aggregates sensor and actuator data for monitoring, fault detection, and safety checks."
    DTDFVocab:enables RealTimeMonitoringService, FaultDetectionService, SafetyCheckingService
]
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Least‑squares optimizer that calibrates Model A and B parameters using collected data."
    DTDFVocab:enables CalibrationService
]
instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Frontend component that provides a dashboard of temperature evolution and control status."
    DTDFVocab:enables VisualizationService
]
instance ControllerEnabler : DTDFVocab:Enabler [
    base:desc "High‑level controller that sends heating and fan commands over the DT channel."
    DTDFVocab:enables ControlService
]

// C6: Services
instance ThermalSimulationService : DTDFVocab:Service [
    base:desc "Simulates future temperature based on power input and heat transfer parameters."
    DTDFVocab:provides ModelPredictionInsight
]
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature trajectories and actuator states."
    DTDFVocab:provides CurrentTemperatureInsight
]
instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects over‑temperature and actuator failures."
    DTDFVocab:provides FaultDetectedInsight
]
instance SafetyCheckingService : DTDFVocab:Service [
    base:desc "Performs safety checks and triggers alarms on threshold breaches."
    DTDFVocab:provides SafetyAlarmInsight
]
instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration of thermal models using non‑linear least‑squares optimization."
    DTDFVocab:provides CalibrationImprovementInsight
]
instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualizes temperature evolution and control status on a dashboard."
    DTDFVocab:provides VisualizationOutcome
]
instance ControlService : DTDFVocab:Service [
    base:desc "Issues bang‑bang control commands to heatbed and fan based on DT logic."
    DTDFVocab:provides HeaterControlAction, FanControlAction
]

// C17: Insights
instance ModelPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicts future temperature trajectory using the chosen thermal model."
]
instance CurrentTemperatureInsight : DTDFVocab:Insight [
    base:desc "Real‑time display of current temperature readings."
]
instance FaultDetectedInsight : DTDFVocab:Insight [
    base:desc "Indicates that an over‑temperature or actuator failure has been detected."
]
instance SafetyAlarmInsight : DTDFVocab:Insight [
    base:desc "Triggers an alarm when temperature exceeds safety limits."
]
instance CalibrationImprovementInsight : DTDFVocab:Insight [
    base:desc "Recommends updated model parameters after calibration."
]
instance VisualizationOutcome : DTDFVocab:Insight [
    base:desc "Provides visual representation of temperature evolution and control actions."
]

// C17: Actions
instance HeaterControlAction : DTDFVocab:Action [
    base:desc "Automatically turns the heatbed on or off in response to temperature setpoints."
    DTDFVocab:IsAutomatic true
]
instance FanControlAction : DTDFVocab:Action [
    base:desc "Sets the fan motor voltage to optimize airflow based on temperature."
    DTDFVocab:IsAutomatic true
]
instance AlarmAction : DTDFVocab:Action [
    base:desc "Sends an audible or visual alarm notification when safety thresholds are breached."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heating element controlled via MOSFET through the Raspberry Pi 4B."
]
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12/24 V fan driven via MOSFET and optocoupler to circulate air inside the insulated box."
]

// C1: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator, FanActuator, HeatbedTemperatureSensor, AmbientTemperatureSensor, ExperimentalTemperatureSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT generates control commands (heatbed enable/disable, fan speed selection) and publishes them to RabbitMQ. The controller consumes these messages and transmits GPIO signals through MOSFETs/optocouplers to actuate the heatbed and fan. The DT also sends diagnostic and calibration updates to the PT via the same broker."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data acquisition and command loop operating on a few‑second timescale (e.g., temperature samples every few seconds and control updates every few seconds). The DT synchronizes with the PT continuously through the message broker."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized DT architecture comprising a RabbitMQ communication server, low‑level driver acting as bridge to PT hardware, a controller module implementing control law, and simulation models connected to the same message broker. All components run locally on the Raspberry Pi, forming a tightly coupled virtual‑physical loop."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design phase – development of physical components and initial model equations; Implementation phase – programming controller, low‑level driver, and RabbitMQ server; Calibration phase – running experiments, collecting data, optimizing model parameters; Operation phase – continuous monitoring, prediction, and safety enforcement within the incubation process."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation of models against experimental data; calibration of free parameters to minimize residual error using Scipy optimization; verification that uniform temperature assumption holds within ± 7 °C; explicit modeling of heat transfer to box and heatbed; use of non‑linear least‑squares to ensure convergence and uniqueness of parameter estimates."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Local AMQP communication via RabbitMQ broker running on the Raspberry Pi; 1‑Wire bus (DS18S20 sensors) over GPIO; GPIO outputs driving MOSFETs and optocouplers to actuators. All communication occurs over the internally connected network (Wi‑Fi/Bluetooth for external access, but not used for DT loop)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted entirely on the Raspberry Pi 4; all software components (broker, driver, controller, models) run locally; open‑source code available in a public GitHub repository. No external cloud hosting required."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safe‑protocol implemented in the low‑level driver to prevent unsafe states; hardware isolation via MOSFETs and optocouplers; communication confined to local broker; however no explicit cybersecurity controls or remote operation safeguards are described."
]