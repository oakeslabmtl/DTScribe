// C3: Physical Sensing Components
instance InternalThermalGradientSensor : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor positioned near the heatbed to capture localized thermal gradients with 0.5°C accuracy and 0.0625°C resolution, operating in continuous polling mode via GPIO interface at 9600 baud rate."
    DTDFVocab:producedData InternalThermalDataTransmitted
]

instance CoreThermalStratificationSensor : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor deployed in the PT's core to detect thermal stratification with 0.5°C accuracy and 0.0625°C resolution, interfaced with Raspberry Pi 4 via GPIO at 9600 baud rate."
    DTDFVocab:producedData CoreThermalDataTransmitted
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor deployed outside the PT to measure ambient conditions with 0.5°C accuracy and 0.0625°C resolution, positioned to minimize wind interference and interfaced via GPIO at 9600 baud rate."
    DTDFVocab:producedData AmbientTemperatureDataTransmitted
]

instance DS18S20TemperatureSensorModel : DTDFVocab:SensingComponent [
    base:desc "Model specification for DS18S20 temperature sensors used in the system, configured for 0.5°C accuracy and 0.0625°C resolution with GPIO-based communication at 9600 baud."
]

// C4: Physical-to-Virtual Interaction
instance InternalThermalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalThermalGradientSensor
]

instance CoreThermalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom CoreThermalStratificationSensor
]

instance AmbientTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

instance SensorDataTransmissionProtocol : DTDFVocab:DataTransmitted [
    base:desc "GPIO-based serial communication protocol operating at 9600 baud rate for transmitting raw sensor readings to the DT computational layer."
    DTDFVocab:producedFrom InternalThermalGradientSensor, CoreThermalStratificationSensor, AmbientTemperatureSensor
]

// C10: Models/Data
instance ThermalIncubatorCADModel : DTDFVocab:Model [
    base:desc "Geometric/structural CAD model representing the physical dimensions, shapes, and configurations of the styrofoam box, heatbed, and fan components of the incubator system."
    DTDFVocab:inputTo RabbitMQMessageBroker, PythonScipyProcessing
]

instance ThermalDiffusionODEModel : DTDFVocab:Model [
    base:desc "Behavioral model using ordinary differential equations to describe thermal dynamics within the incubator, calibrated using non-linear least squares solvers to estimate parameters like thermal conductivity and mass distribution."
    DTDFVocab:inputTo PythonScipyProcessing, ModelPredictiveControlService
]

instance EnvironmentalThermalModel : DTDFVocab:Model [
    base:desc "Simplified environmental model representing external factors like ambient temperature and airflow that influence the PT's performance, integrated with the behavioral thermal model for comprehensive predictions."
    DTDFVocab:inputTo PythonScipyProcessing, FaultDetectionService
]

instance InternalThermalData : DTDFVocab:Data [
    base:desc "Time-series data collected from internal temperature sensors measuring localized thermal gradients within the PT, used for state estimation and model calibration."
    DTDFVocab:fromData InternalThermalDataTransmitted, CoreThermalDataTransmitted
    DTDFVocab:inputTo PythonScipyProcessing, StateEstimationService
]

instance AmbientThermalData : DTDFVocab:Data [
    base:desc "Time-series data collected from the external temperature sensor measuring ambient conditions, used for environmental corrections in behavioral models and fault detection."
    DTDFVocab:fromData AmbientTemperatureDataTransmitted
    DTDFVocab:inputTo PythonScipyProcessing, EnvironmentalThermalModel
]

instance SensorCalibrationData : DTDFVocab:Data [
    base:desc "Calibration dataset containing cross-validated sensor readings against DT behavioral models to ensure consistency with theoretical predictions, used for parameter refinement."
    DTDFVocab:fromData SensorDataTransmissionProtocol
    DTDFVocab:inputTo PythonScipyProcessing, CalibrationAlgorithmService
]

// C11: Enablers
instance RaspberryPi4Controller : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B hosting the real-time controller and DT monitoring algorithms, featuring quad-core Cortex-A72 CPU at 1.5GHz, GPIO interface for sensor/actuator communication, and Raspberry Pi OS for Python-based processing."
    DTDFVocab:enables StateEstimationService, ControlAdjustmentService, FaultDetectionService
]

instance RabbitMQMessageBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ server enabling asynchronous message queuing for synchronizing data between physical sensors, DT processing nodes, and controller, using AMQP protocol for low-latency reliable transmission."
    DTDFVocab:enables DataAggregationService, ModelUpdateService, ActuatorCommandService
]

instance PythonScipyProcessing : DTDFVocab:Enabler [
    base:desc "Python-based processing layer using SciPy libraries for numerical methods including nonlinear least squares optimization, parameter estimation, and signal processing for sensor noise reduction."
    DTDFVocab:enables CalibrationAlgorithmService, OptimizationService, SimulationService
]

instance SQLiteTimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Lightweight SQLite database for storing time-series sensor data and logging model parameters, control actions, and operational metrics for historical analysis and model validation."
    DTDFVocab:enables DataStorageService, ModelValidationService
]

// C6: Services
instance StateEstimationService : DTDFVocab:Service [
    base:desc "Service reconstructing the PT's operational state (e.g., temperature gradients) from noisy sensor data using Kalman filters, improving accuracy for diagnostics and control."
    DTDFVocab:provides ThermalStateInsight, ControlAdjustmentAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service identifying anomalies in PT operation by comparing real-time data against model predictions, using statistical methods like Chi-squared tests to detect sensor failures or component degradation."
    DTDFVocab:provides FaultDiagnosisInsight, SafetyAlertAction
]

instance ModelPredictiveControlService : DTDFVocab:Service [
    base:desc "Service implementing model predictive control algorithms to adjust actuators in real-time based on DT-generated insights, ensuring correction of deviations from desired thermal states."
    DTDFVocab:provides ControlOptimizationInsight, ActuatorAdjustmentAction
]

instance CalibrationAlgorithmService : DTDFVocab:Service [
    base:desc "Service dynamically updating model parameters using data-driven methods like least-squares or Bayesian inference to adjust thermal conductivity, sensor offsets, and environmental factors."
    DTDFVocab:provides ModelAccuracyInsight, ParameterAdjustmentAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service executing dynamic simulations using ODE-based models to reproduce and predict PT behavior under current or hypothetical operating conditions for what-if analysis."
    DTDFVocab:provides PredictiveAnalysisInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service applying optimization algorithms to adjust PT configurations for improved performance or resource efficiency, simulating trade-offs between cost, safety, and productivity."
    DTDFVocab:provides ResourceAllocationInsight, EfficiencyImprovementAction
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Service aggregating raw sensor data from RabbitMQ for model updates and processing, ensuring synchronized data flow between physical components and DT computational layer."
    DTDFVocab:provides DataConsolidationInsight
]

instance ModelUpdateService : DTDFVocab:Service [
    base:desc "Service updating model parameters based on new sensor data to maintain accuracy of predictive capabilities."
    DTDFVocab:provides ModelAccuracyInsight
]

instance ActuatorCommandService : DTDFVocab:Service [
    base:desc "Service translating control insights into actuator commands for real-time adjustment of heating and fan systems."
    DTDFVocab:provides ActuatorAdjustmentAction
]

instance DataStorageService : DTDFVocab:Service [
    base:desc "Service storing time-series data and operational logs in SQLite database for historical analysis, model validation, and performance monitoring."
    DTDFVocab:provides HistoricalDataInsight
]

instance ModelValidationService : DTDFVocab:Service [
    base:desc "Service validating model accuracy by comparing simulated results with real-time sensor data."
    DTDFVocab:provides ModelAccuracyInsight
]

instance ControlAdjustmentService : DTDFVocab:Service [
    base:desc "Service adjusting control parameters based on state estimation and optimization algorithms."
    DTDFVocab:provides ControlAdjustmentAction
]

// C17: Insights/Actions
instance ThermalStateInsight : DTDFVocab:Insight [
    base:desc "Reconstructed thermal state of the PT including localized gradients and internal conditions, derived from sensor data and state estimation algorithms."
]

instance FaultDiagnosisInsight : DTDFVocab:Insight [
    base:desc "Root-cause analysis of detected anomalies in PT operation, including sensor failures, component degradation, or environmental interference."
]

instance ControlOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimal control parameters and strategies for maintaining desired thermal states, generated through model predictive control algorithms."
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Metrics quantifying the fidelity between simulated and observed PT behavior, used to assess model calibration quality and parameter accuracy."
]

instance PredictiveAnalysisInsight : DTDFVocab:Insight [
    base:desc "Forecasted PT behavior under current or hypothetical conditions, enabling proactive decision-making for operational adjustments."
]

instance ResourceAllocationInsight : DTDFVocab:Insight [
    base:desc "Optimized resource allocation recommendations for energy consumption, maintenance schedules, and operational parameters."
]

instance ControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of heating/fan parameters based on DT-generated insights to correct deviations from desired thermal states."
    DTDFVocab:IsAutomatic true
]

instance ActuatorAdjustmentAction : DTDFVocab:Action [
    base:desc "Execution of control commands to adjust heatbed power or fan speed via Raspberry Pi GPIO outputs, synchronized through RabbitMQ message queue."
    DTDFVocab:IsAutomatic true
]

instance SafetyAlertAction : DTDFVocab:Action [
    base:desc "Automatic triggering of safety protocols when deviations exceed predefined thresholds, including emergency shutdown or parameter adjustments."
    DTDFVocab:IsAutomatic true
]

instance ParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Dynamic recalibration of model parameters to mitigate drift between DT and PT, ensuring long-term accuracy of predictive capabilities."
    DTDFVocab:IsAutomatic true
]

instance EfficiencyImprovementAction : DTDFVocab:Action [
    base:desc "Implementation of optimized operational strategies to reduce energy consumption or improve thermal uniformity within the PT."
    DTDFVocab:IsAutomatic false
]

instance DataConsolidationInsight : DTDFVocab:Insight [
    base:desc "Aggregated sensor data for comprehensive model updates and processing."
]

instance HistoricalDataInsight : DTDFVocab:Insight [
    base:desc "Historical time-series data for performance analysis and model validation."
]

