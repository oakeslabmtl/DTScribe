// C3: Physical sensing components
instance FrontLeftWheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel speed sensor measuring rotational speed on the front-left wheel"
    DTDFVocab:producedData FrontLeftWheelSpeedDataTransmitted
]

instance FrontRightWheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel speed sensor measuring rotational speed on the front-right wheel"
    DTDFVocab:producedData FrontRightWheelSpeedDataTransmitted
]

instance RearLeftWheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel speed sensor measuring rotational speed on the rear-left wheel"
    DTDFVocab:producedData RearLeftWheelSpeedDataTransmitted
]

instance RearRightWheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "Wheel speed sensor measuring rotational speed on the rear-right wheel"
    DTDFVocab:producedData RearRightWheelSpeedDataTransmitted
]

instance VehicleAccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Accelerometer capturing vehicle acceleration in three axes"
    DTDFVocab:producedData VehicleAccelerationDataTransmitted
]

instance VehicleYawRateSensor : DTDFVocab:SensingComponent [
    base:desc "Gyroscope sensor measuring vehicle yaw rate"
    DTDFVocab:producedData VehicleYawRateDataTransmitted
]

instance EngineTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor monitoring engine core temperature"
    DTDFVocab:producedData EngineTemperatureDataTransmitted
]

instance BrakePressureSensor : DTDFVocab:SensingComponent [
    base:desc "Pressure sensor measuring brake fluid pressure"
    DTDFVocab:producedData BrakePressureDataTransmitted
]

// C4: Physical-to-virtual interaction (Data transmitted)
instance FrontLeftWheelSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FrontLeftWheelSpeedSensor
]

instance FrontRightWheelSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom FrontRightWheelSpeedSensor
]

instance RearLeftWheelSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RearLeftWheelSpeedSensor
]

instance RearRightWheelSpeedDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RearRightWheelSpeedSensor
]

instance VehicleAccelerationDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleAccelerationSensor
]

instance VehicleYawRateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleYawRateSensor
]

instance EngineTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EngineTemperatureSensor
]

instance BrakePressureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BrakePressureSensor
]

// C9: Data instances
instance FrontLeftWheelSpeedMeasurement : DTDFVocab:Data [
    base:desc "Real-time wheel speed measurement of the front-left wheel"
    DTDFVocab:fromData FrontLeftWheelSpeedDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler_CarModels
    DTDFVocab:inputTo FaultDetectionEnabler_AnomalyAnalysis
]

instance FrontRightWheelSpeedMeasurement : DTDFVocab:Data [
    base:desc "Real-time wheel speed measurement of the front-right wheel"
    DTDFVocab:fromData FrontRightWheelSpeedDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler_CarModels
    DTDFVocab:inputTo FaultDetectionEnabler_AnomalyAnalysis
]

instance RearLeftWheelSpeedMeasurement : DTDFVocab:Data [
    base:desc "Real-time wheel speed measurement of the rear-left wheel"
    DTDFVocab:fromData RearLeftWheelSpeedDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler_CarModels
    DTDFVocab:inputTo FaultDetectionEnabler_AnomalyAnalysis
]

instance RearRightWheelSpeedMeasurement : DTDFVocab:Data [
    base:desc "Real-time wheel speed measurement of the rear-right wheel"
    DTDFVocab:fromData RearRightWheelSpeedDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler_CarModels
    DTDFVocab:inputTo FaultDetectionEnabler_AnomalyAnalysis
]

instance VehicleAccelerationMeasurement : DTDFVocab:Data [
    base:desc "Vehicle acceleration data collected from the acceleration sensor"
    DTDFVocab:fromData VehicleAccelerationDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler_CarModels
    DTDFVocab:inputTo FaultDetectionEnabler_AnomalyAnalysis
    DTDFVocab:inputTo StateEstimationEnabler_StateInference
]

instance VehicleYawRateMeasurementData : DTDFVocab:Data [
    base:desc "Yaw rate data collected from the gyroscope sensor"
    DTDFVocab:fromData VehicleYawRateDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler_CarModels
    DTDFVocab:inputTo FaultDetectionEnabler_AnomalyAnalysis
    DTDFVocab:inputTo StateEstimationEnabler_StateInference
]

instance EngineTemperatureMeasurement : DTDFVocab:Data [
    base:desc "Engine temperature measurement from the temperature sensor"
    DTDFVocab:fromData EngineTemperatureDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler_CarModels
    DTDFVocab:inputTo FaultDetectionEnabler_AnomalyAnalysis
]

instance BrakePressureMeasurement : DTDFVocab:Data [
    base:desc "Brake pressure measurement from the pressure sensor"
    DTDFVocab:fromData BrakePressureDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler_CarModels
    DTDFVocab:inputTo FaultDetectionEnabler_AnomalyAnalysis
    DTDFVocab:inputTo SupervisoryControlEnabler_SafetyConstraints
]

// C10: Models
instance CADModel_CarGeometry : DTDFVocab:Model [
    base:desc "CAD geometry model encoding wheel dimensions, chassis shape, and styling"
    DTDFVocab:inputTo CalibrationEnabler_CarModels
]

instance DynamicModel_CarMotion : DTDFVocab:Model [
    base:desc "Dynamic model expressed by differential equations capturing car motion"
    DTDFVocab:inputTo CalibrationEnabler_CarModels
]

instance AnalyticalModel_EngineThermal : DTDFVocab:Model [
    base:desc "Analytical model representing auxiliary processes such as engine thermal behavior"
    DTDFVocab:inputTo CalibrationEnabler_CarModels
]

// C11: Enablers
instance CalibrationEnabler_CarModels : DTDFVocab:Enabler [
    base:desc "Calibration algorithm continuously updating model parameters based on sensor data"
    DTDFVocab:enables SimulationService_ModelExecution
]

instance MonitoringEnabler_PerformanceCheck : DTDFVocab:Enabler [
    base:desc "Service monitoring real-time performance by comparing simulated states against actual data"
    DTDFVocab:enables MonitoringService_RealTimeMonitoring
]

instance FaultDetectionEnabler_AnomalyAnalysis : DTDFVocab:Enabler [
    base:desc "Fault detector analysing sensor streams for anomalies"
    DTDFVocab:enables FaultDetectionService_AnomalyAlert
]

instance SupervisoryControlEnabler_SafetyConstraints : DTDFVocab:Enabler [
    base:desc "Supervisory controller imposing safety constraints based on model predictions"
    DTDFVocab:enables SupervisoryControlService_SafetyOrchestration
]

instance StateEstimationEnabler_StateInference : DTDFVocab:Enabler [
    base:desc "State estimator inferring unmeasured states from sensor data"
    DTDFVocab:enables StateEstimationService_SensorFusion
]

instance OptimisationEnabler_PerformanceOptimization : DTDFVocab:Enabler [
    base:desc "Optimizer computing operating points to improve performance"
    DTDFVocab:enables OptimisationService_PerformanceAdjustment
]

// C6: Services
instance SimulationService_ModelExecution : DTDFVocab:Service [
    base:desc "Simulation-based reproduction and prediction of the Physical Twin under current operating conditions"
    DTDFVocab:provides PerformanceMetricInsight
    DTDFVocab:provides CalibrationConfidenceInsight
]

instance MonitoringService_RealTimeMonitoring : DTDFVocab:Service [
    base:desc "Real‑time monitoring to verify safe and optimal performance"
    DTDFVocab:provides SafeOperatingInsight
]

instance FaultDetectionService_AnomalyAlert : DTDFVocab:Service [
    base:desc "Fault detection service generating alerts for anomalies in sensor streams"
    DTDFVocab:provides FaultDetectedInsight
    DTDFVocab:provides HumanReviewAction
]

instance SupervisoryControlService_SafetyOrchestration : DTDFVocab:Service [
    base:desc "Supervisory control service imposing safety constraints on the physical twin"
    DTDFVocab:provides ViolationDetectedInsight
    DTDFVocab:provides AutonomousBrakeAction
]

instance StateEstimationService_SensorFusion : DTDFVocab:Service [
    base:desc "State estimation service providing inferred unmeasured states from sensor data"
]

instance OptimisationService_PerformanceAdjustment : DTDFVocab:Service [
    base:desc "Optimization service computing adjustments to improve performance"
    DTDFVocab:provides OptimisationRecommendationInsight
    DTDFVocab:provides OptimisationApplyAction
]

// C17: Insights
instance CalibrationConfidenceInsight : DTDFVocab:Insight [
    base:desc "Model parameter confidence derived from calibration aligning with sensor data"
]

instance FaultDetectedInsight : DTDFVocab:Insight [
    base:desc "An anomaly detected in sensor streams"
]

instance SafeOperatingInsight : DTDFVocab:Insight [
    base:desc "Vehicle is operating within safe and optimal bounds based on model predictions"
]

instance PerformanceMetricInsight : DTDFVocab:Insight [
    base:desc "Real‑time comparison of simulated states against actual sensor data, generating performance metrics"
]

instance ViolationDetectedInsight : DTDFVocab:Insight [
    base:desc "Detected violation of safety constraints by the vehicle"
]

instance OptimisationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Optimization algorithm recommends an operating point adjustment"
]

// C17: Actions
instance HumanReviewAction : DTDFVocab:Action [
    base:desc "Human reviewer investigates detected anomaly"
    DTDFVocab:IsAutomatic false
]

instance AutonomousBrakeAction : DTDFVocab:Action [
    base:desc "Automatic braking action applied to correct a detected safety violation"
    DTDFVocab:IsAutomatic true
]

instance AutonomousThrottleAdjustAction : DTDFVocab:Action [
    base:desc "Automatic throttle adjustment applied to improve performance metrics"
    DTDFVocab:IsAutomatic true
]

instance OptimisationApplyAction : DTDFVocab:Action [
    base:desc "Apply optimizer’s recommended operating point adjustment"
    DTDFVocab:IsAutomatic true
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Lifecycle stages include: 1) Conceptual modelling of system aspects such as geometry (CAD) and physics (differential equations); 2) Concrete modelling of cyber‑physical interactions and environment dynamics; 3) Integration of models and time‑series data acquired from PT sensors into a Digital Twin framework; 4) Calibration, where algorithms update model parameters to reconcile the DT with PT; 5) Monitoring, where DT‑hosted monitors assess safety and performance and detect violations; 6) Optimization/control, where fault detectors, supervisory controllers, state estimators, or optimisers generate decision data; 7) Evolution, where detected violations trigger human or algorithmic modifications to the PT and corresponding updates to the DT; governance hinges on continuous feedback loops and parameter re‑calibration, but formal lifecycle governance is not explicitly described."
]