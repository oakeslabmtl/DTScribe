// ==================== Sensing Components ====================
// Box Air Temperature Sensor (inside the insulated box)
instance BoxAirTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer inside the incubator box (unique 64‑bit code), range -55 °C to +125 °C, accuracy ±0.5 °C (10 °C–85 °C)"
    DTDFVocab:producedData BoxAirTempDataTransmitted
]

// Heat‑Bed Temperature Sensor (mounted on the heating element)
instance HeatBedTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer attached to the heat‑bed surface, same specifications as other sensors"
    DTDFVocab:producedData HeatBedTempDataTransmitted
]

// Ambient Temperature Sensor (outside the box)
instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring ambient laboratory temperature, unique 64‑bit code"
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// ==================== Data Transmitted ====================
// Data emitted by the box air temperature sensor
instance BoxAirTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxAirTempSensor
]

// Data emitted by the heat‑bed temperature sensor
instance HeatBedTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatBedTempSensor
]

// Data emitted by the ambient temperature sensor
instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// ==================== Data ====================
// Time‑stamped temperature reading from the box air sensor
instance BoxAirTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading (°C) from BoxAirTempSensor"
    DTDFVocab:fromData BoxAirTempDataTransmitted
    DTDFVocab:inputTo LowLevelDriverEnabler
]

// Time‑stamped temperature reading from the heat‑bed sensor
instance HeatBedTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading (°C) from HeatBedTempSensor"
    DTDFVocab:fromData HeatBedTempDataTransmitted
    DTDFVocab:inputTo LowLevelDriverEnabler
]

// Time‑stamped temperature reading from the ambient sensor
instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading (°C) from AmbientTempSensor"
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo LowLevelDriverEnabler
]

// Calibration power‑supply logs (voltage/current)
instance PowerSupplyLogData : DTDFVocab:Data [
    base:desc "Voltage and current logs from the 5 V/12 V power supply used for heater and fan"
    DTDFVocab:inputTo SciPyOptimizerEnabler
]

// ==================== Enablers ====================
// Low‑level driver handling GPIO, 1‑Wire and publishing AMQP messages
instance LowLevelDriverEnabler : DTDFVocab:Enabler [
    base:desc "Python low‑level driver library on Raspberry Pi abstracting GPIO, 1‑Wire communication and publishing AMQP messages to RabbitMQ"
    DTDFVocab:enables RealTimeTemperaturePredictionService
    DTDFVocab:enables FaultMonitoringService
]

// RabbitMQ AMQP broker
instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "Locally hosted RabbitMQ server (AMQP 0‑9‑1) used for PT→DT data flow"
    DTDFVocab:enables RealTimeTemperaturePredictionService
    DTDFVocab:enables ParameterCalibrationService
]

// SciPy optimizer for nonlinear least‑squares calibration
instance SciPyOptimizerEnabler : DTDFVocab:Enabler [
    base:desc "SciPy (Python) nonlinear least‑squares optimizer used to calibrate thermal model parameters"
    DTDFVocab:enables ParameterCalibrationService
    DTDFVocab:enables SimulationServiceModelA
    DTDFVocab:enables SimulationServiceModelB
]

// Visualization engine for temperature trajectories
instance VisualizationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python visualization module (matplotlib) rendering temperature trajectories for experimental validation"
    DTDFVocab:enables TemperatureTrajectoryVisualizationService
]

// Simulation engine for executing thermal models
instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Numerical simulation engine solving thermal ODEs for Model A and Model B"
    DTDFVocab:enables SimulationServiceModelA
    DTDFVocab:enables SimulationServiceModelB
]

// ==================== Services ====================
// Real‑time temperature prediction service
instance RealTimeTemperaturePredictionService : DTDFVocab:Service [
    base:desc "Provides real‑time prediction of box air temperature using calibrated thermal model"
    DTDFVocab:provides TemperatureDeviationAlertInsight
]

// Parameter calibration service
instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates Model A and Model B parameters (C_air, G_box, C_heater, G_heater) by minimizing squared residuals"
    DTDFVocab:provides ModelParameterUpdateAction
]

// Fault monitoring service (safe‑state driver)
instance FaultMonitoringService : DTDFVocab:Service [
    base:desc "Monitors temperature streams for out‑of‑bounds conditions and triggers safe‑state actions"
    DTDFVocab:provides FaultAlertInsight
]

// Temperature trajectory visualization service
instance TemperatureTrajectoryVisualizationService : DTDFVocab:Service [
    base:desc "Visualises measured vs. simulated temperature curves for validation"
    DTDFVocab:provides CalibrationSuccessInsight
]

// Simulation service for Model A (single capacitance)
instance SimulationServiceModelA : DTDFVocab:Service [
    base:desc "Executes thermal Model A (single capacitance C_air, conductance G_box) for scenario analysis"
    DTDFVocab:provides SimulationResultInsightA
]

// Simulation service for Model B (dual capacitance)
instance SimulationServiceModelB : DTDFVocab:Service [
    base:desc "Executes thermal Model B (capacitances C_air, C_heater; conductances G_box, G_heater) for scenario analysis"
    DTDFVocab:provides SimulationResultInsightB
]

// ==================== Insights ====================
// Alert when predicted temperature deviates from defined limits
instance TemperatureDeviationAlertInsight : DTDFVocab:Insight [
    base:desc "Temperature deviation alert issued when predicted temperature exceeds user‑defined thresholds"
]

// Fault alert insight
instance FaultAlertInsight : DTDFVocab:Insight [
    base:desc "Fault alert generated when sensor data indicates failure or unsafe condition"
]

// Insight confirming successful calibration
instance CalibrationSuccessInsight : DTDFVocab:Insight [
    base:desc "Indicates that model parameters have been successfully calibrated against experimental data"
]

// Insight from Model A simulation results
instance SimulationResultInsightA : DTDFVocab:Insight [
    base:desc "Provides predicted temperature curve from Model A for the current operating point"
]

// Insight from Model B simulation results
instance SimulationResultInsightB : DTDFVocab:Insight [
    base:desc "Provides predicted temperature curve from Model B for the current operating point"
]

// ==================== Actions ====================
// Suggestion to adjust temperature set‑point
instance SetpointAdjustmentAction : DTDFVocab:Action [
    base:desc "Operator suggestion to modify the temperature set‑point based on deviation insight"
    DTDFVocab:IsAutomatic false
]

// Recommendation to improve insulation
instance InsulationImprovementAction : DTDFVocab:Action [
    base:desc "Operator recommendation to enhance box insulation to reduce heat loss"
    DTDFVocab:IsAutomatic false
]

// Action to update calibrated model parameters in the DT
instance ModelParameterUpdateAction : DTDFVocab:Action [
    base:desc "Updates the DT with newly calibrated thermal parameters (C_air, G_box, …)"
    DTDFVocab:IsAutomatic false
]

// ==================== Models ====================
// Thermal Model A (single capacitance)
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Physics‑based thermal Model A with one thermal capacitance C_air and conductance G_box representing the box"
    DTDFVocab:inputTo SciPyOptimizerEnabler
    DTDFVocab:inputTo SimulationServiceModelA
]

// Thermal Model B (dual capacitance)
instance ThermalModelB : DTDFVocab:Model [
    base:desc "Physics‑based thermal Model B with separate capacitances C_air, C_heater and conductances G_box, G_heater"
    DTDFVocab:inputTo SciPyOptimizerEnabler
    DTDFVocab:inputTo SimulationServiceModelB
]

// ==================== Acting Components ====================
// Heat‑bed actuator (electrical heating element)
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heating element (heat‑bed) driven by MOSFET switch on PCB; duty‑cycle controllable via GPIO"
]

// Fan actuator (air circulation)
instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12/24 V fan providing air circulation, driven by MOSFET switch on PCB; speed adjustable via PWM"
]

// ==================== Environments & Components ====================
// Physical incubator environment containing components
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains BoxAirTempSensor, HeatBedTempSensor, AmbientTempSensor, HeatBedActuator, FanActuator
]

// Physical components (non‑sensor elements)
instance PolystyreneBox : DTDFVocab:Component [
    base:desc "Polystyrene insulated box (~0.03 m³ volume) housing the heat‑bed and sensors"
]

instance HeatBedElement : DTDFVocab:Component [
    base:desc "Rectangular heat‑bed (≈ 214 × 214 × 3 mm) providing heating power up to 100 W"
]

instance FanElement : DTDFVocab:Component [
    base:desc "Small 12/24 V fan capable of ~0.02 m³ s⁻¹ airflow (air exchange in ~2 s)"
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running the low‑level driver and DT services"
]

instance PowerSupplyUnit : DTDFVocab:Component [
    base:desc "5 V/12 V power supply capable of ≥100 W (≈4 A for heat‑bed)"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT services send control commands (heat‑bed ON/OFF, fan ON/OFF or voltage level) as AMQP messages to the same RabbitMQ broker; the controller subscribes to these topics, interprets the commands and drives the MOSFETs/optocouplers to actuate the heat‑bed and fan."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture comprises the PT, a low‑level driver that captures sensor data and forwards it to RabbitMQ, the RabbitMQ broker mediating communication, DT components that subscribe to sensor streams for monitoring and model calibration, and the controller that receives DT commands and drives the actuators; all components are co‑located on the Raspberry Pi, forming a tightly coupled CPS‑based DT."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is examined through four explicit assumptions (uniform air temperature, negligible wall heat storage, constant air specific heat, negligible fan heat). Validation is performed by uniform‑temperature experiments (comparing three sensor readings) and by calibrating model parameters against measured temperature trajectories; the calibrated Model B showed superior prediction of thermal inertia, indicating higher validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses the AMQP protocol over TCP/IP via the RabbitMQ broker; the Raspberry Pi provides Wi‑Fi (and Bluetooth) connectivity, enabling the broker to be accessed locally or remotely. Sensor data and control commands are exchanged as discrete messages on dedicated topics."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT software components (RabbitMQ server, low‑level driver, model calibration scripts, controller logic) are deployed on the same Raspberry Pi 4 Model B that also hosts the physical controller, thus the DT runs on‑edge without external cloud resources."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe‑state protocol that forces the actuators into a defined safe configuration if communication fails; MOSFET control is isolated by optocouplers to protect the Raspberry Pi, and the RabbitMQ broker can be secured via standard AMQP authentication mechanisms (though specific security settings are not detailed in the document)."
]