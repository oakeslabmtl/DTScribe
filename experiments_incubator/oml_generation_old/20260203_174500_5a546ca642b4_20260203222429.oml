// Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "The heatbed heater driven by the Raspberry Pi via MOSFET and optocoupler, providing thermal power to the incubator box."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "The fan driven by the Raspberry Pi via MOSFET and optocoupler, providing air circulation within the incubator box."
]

// Physical Sensing Components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside the incubator, measuring internal temperature for one side of the box."
    DTDFVocab:producedData InternalTempData
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside the incubator, measuring internal temperature for the opposite side of the box."
    DTDFVocab:producedData InternalTempData
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located outside the incubator, measuring room temperature."
    DTDFVocab:producedData ExternalTempData
]

// Physical-to-Virtual Interaction: Data Transmitted
instance InternalTempData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1, InternalTempSensor2
]

instance ExternalTempData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

instance ActuatorStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatBedActuator, FanActuator
]

instance PowerUsageData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatBedActuator
]

// Processed Data
instance ProcessedInternalTempData : DTDFVocab:Data [
    base:desc "Internal temperature readings processed for model calibration, filtering, and trend analysis."
    DTDFVocab:fromData InternalTempData
    DTDFVocab:inputTo PythonCalibrationTool, PythonSimulationTool
]

instance ProcessedExternalTempData : DTDFVocab:Data [
    base:desc "External (room) temperature readings processed for reference and ambient condition modeling."
    DTDFVocab:fromData ExternalTempData
    DTDFVocab:inputTo PythonCalibrationTool, PythonSimulationTool
]

instance ActuatorStateLog : DTDFVocab:Data [
    base:desc "Log of heatbed and fan on/off states along with timestamps."
    DTDFVocab:fromData ActuatorStateData
    DTDFVocab:inputTo DataLoggingService
]

instance PowerUsageLog : DTDFVocab:Data [
    base:desc "Log of power consumption measurements from the heatbed over time."
    DTDFVocab:fromData PowerUsageData
    DTDFVocab:inputTo DataLoggingService
]

// Virtual Models
instance TempDynamicsModelA : DTDFVocab:Model [
    base:desc "Simplified temperature dynamics model assuming all heatbed power instantly affects air temperature without considering thermal inertia."
    DTDFVocab:inputTo PythonSimulationTool
]

instance TempDynamicsModelB : DTDFVocab:Model [
    base:desc "Temperature dynamics model incorporating the heatbed’s thermal inertia and heat transfer to the air."
    DTDFVocab:inputTo PythonSimulationTool
]

// Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "AMQP message broker providing Wi‑Fi transport for sensor data and actuator command exchange between the digital twin and the physical twin."
    DTDFVocab:enables DataExchangeService
]

instance PythonCalibrationTool : DTDFVocab:Enabler [
    base:desc "Python application using SciPy for non‑linear least‑squares calibration of the thermal models."
    DTDFVocab:enables CalibrationService
]

instance PythonSimulationTool : DTDFVocab:Enabler [
    base:desc "Python simulation module executing Models A and B to predict temperature trajectories."
    DTDFVocab:enables SimulationService
]

// Services
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring internal and external temperatures for safety thresholds and optimality of heating policy."
    DTDFVocab:provides AnomalyAlertInsight, RecommendedHeatingDutyCycleInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service performing parameter calibration of the thermal models using the processed temperature data."
    DTDFVocab:provides CalibratedModelParametersInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service simulating temperature dynamics using Models A and B to forecast future temperature trajectories."
    DTDFVocab:provides TemperatureTrajectoryPredictionInsight
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Service storing all sensor, actuator, and power consumption logs for later analysis."
    DTDFVocab:provides DataLoggingInsight
]

instance OpenSourceInterfaceService : DTDFVocab:Service [
    base:desc "Service exposing an open‑source interface for future visualization and advanced control modules."
    DTDFVocab:provides OpenSourceInterfaceInsight
]

instance DataExchangeService : DTDFVocab:Service [
    base:desc "Service managing message passing over RabbitMQ between the digital twin and the physical twin."
    DTDFVocab:provides DataExchangeInsight
]

// Insights
instance CalibratedModelParametersInsight : DTDFVocab:Insight [
    base:desc "Insight containing calibrated free parameters for models A and B after non‑linear least‑squares fitting."
]

instance TemperatureTrajectoryPredictionInsight : DTDFVocab:Insight [
    base:desc "Insight predicting future temperature trajectories based on current sensor readings and model simulations."
]

instance AnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Insight alerting operators when temperature deviates beyond defined safety limits during real‑time monitoring."
]

instance RecommendedHeatingDutyCycleInsight : DTDFVocab:Insight [
    base:desc "Insight recommending heater duty cycle to maintain optimal temperature profiles."
]

instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Insight confirming successful logging of sensor and actuator data."
]

instance OpenSourceInterfaceInsight : DTDFVocab:Insight [
    base:desc "Insight providing access details for visualization and advanced control integration."
]

instance DataExchangeInsight : DTDFVocab:Insight [
    base:desc "Insight confirming message broker status and data transmission integrity."
]

// Actions
instance AdjustHeatingDutyCycleAction : DTDFVocab:Action [
    base:desc "Action automatically adjusting the heatbed duty cycle based on the recommended heating duty cycle insight."
    DTDFVocab:IsAutomatic true
]

instance ManualHeatingAdjustmentAction : DTDFVocab:Action [
    base:desc "Action allowing operators to manually set the heatbed duty cycle."
    DTDFVocab:IsAutomatic false
]

// Physical Environment
instance InsulatedIncubatorBox : DTDFVocab:Environment [
    base:contains RaspberryPi, HeatBedActuator, FanActuator, InternalTempSensor1, InternalTempSensor2, ExternalTempSensor, MOSFETModule, Optocoupler, PCBLayout
]

// Physical Components
instance RaspberryPi : DTDFVocab:Component [
    base:desc "RPi 4 used as central controller, reading sensors via GPIO, driving MOSFETs, and communicating over Wi‑Fi."
]

instance Heatbed : DTDFVocab:Component [
    base:desc "Insulated heating element providing thermal power to the incubator box."
]

instance Fan : DTDFVocab:Component [
    base:desc "Air circulation fan for even temperature distribution within the incubator box."
]

instance MOSFETModule : DTDFVocab:Component [
    base:desc "MOSFET driver module controlling high‑current loads (heatbed and fan) from the Raspberry Pi GPIO pins."
]

instance Optocoupler : DTDFVocab:Component [
    base:desc "Optocoupler isolating Raspberry Pi logic from high‑voltage MOSFET control signals."
]

instance PCBLayout : DTDFVocab:Component [
    base:desc "Custom PCB integrating Raspberry Pi, sensors, MOSFETs, and optocouplers for the incubator control system."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT via RabbitMQ, instructing the Raspberry Pi to turn the heatbed or fan on or off, adjusting duration parameters, and potentially updating model parameters. The DT’s decisions are executed by the PT’s low‑level driver."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates on a real‑time timescale of seconds: sensor sampling and actuator commands are exchanged at ~1–2 s intervals. Model calibration and validation runs offline but targets the same sampling horizon. The DT keeps up‑to‑date with the PT’s state in near real‑time."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized architecture where the controller, low‑level driver, and RabbitMQ server reside on the same Raspberry Pi. The DT model runs as a listener on the message broker, receives sensor data, performs simulation and calibration, and publishes control commands. The hardware components (sensors and actuators) are connected through the Raspberry Pi GPIOs and the PCB."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans all lifecycle phases: design (model creation), manufacturing (embedding sensors and hardware), and operation (runtime monitoring, calibration, and feedback control). The same model is calibrated and updated during the operational phase, maintaining relevance over the entire lifecycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is limited by assumptions (uniform temperature, constant heat capacity, negligible wall heating). Validation is performed experimentally (uniformity tests) and through comparison of model output to measured data. Uncertainties are mitigated by calibrating four free parameters in Model B. Remaining errors are quantified by residual analysis in the least‑squares calibration."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "PT and DT communicate via RabbitMQ over Wi‑Fi using the AMQP protocol. The Raspberry Pi hosts both the physical controller and the message broker, enabling fast data exchange and command dissemination. The communication schedule is set to a 1‑2 s refresh rate."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted on a Raspberry Pi 4 B running a Linux distribution (e.g., Raspbian). RabbitMQ broker, Python controller, and low‑level driver are installed directly on the Pi as background services; no containerisation or cloud deployment is described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not explicitly described in the document. The architecture could be extended to exchange data with external logging or cloud services, but no existing integration is mentioned."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not in Document; the case study does not specify data ownership or privacy controls."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "No specific industry or academic standards are referenced beyond the open‑source repository and the use of standard protocols (AMQP). The design follows general CPS and digital twin principles described in the literature."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is incorporated in the low‑level driver to ensure the physical device remains in a safe state. Commands are received via RabbitMQ, but the document does not describe encryption, authentication, or access control mechanisms. Safety is maintained through controlled actuation and monitoring of temperature limits."
]