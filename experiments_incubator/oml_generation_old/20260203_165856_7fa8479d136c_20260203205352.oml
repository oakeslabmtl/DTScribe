// C3: Physical sensing components
instance InternalDS18S20SensorOne : DTDFVocab:SensingComponent [
    base:desc "First DS18S20 high‑precision temperature sensor inside the styrofoam incubator box."
    DTDFVocab:producedData IncubatorTemperatureTransmission
]

instance InternalDS18S20SensorTwo : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 high‑precision temperature sensor inside the styrofoam incubator box."
    DTDFVocab:producedData IncubatorTemperatureTransmission
]

instance ExternalDS18S20Sensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision temperature sensor positioned on the exterior side of the incubator box."
    DTDFVocab:producedData IncubatorTemperatureTransmission
]

// C4: Physical-to-virtual interaction
instance IncubatorTemperatureTransmission : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalDS18S20SensorOne, InternalDS18S20SensorTwo, ExternalDS18S20Sensor
]

// C10: Data
instance IncubatorTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series temperature data collected from DS18S20 sensors, serialized as JSON on RabbitMQ."
    DTDFVocab:fromData IncubatorTemperatureTransmission
    DTDFVocab:inputTo CalibrationEnabler, KalmanFilterEnabler, RuntimePredictionEnabler, CoSimulationEnabler, SelfAdaptationEnabler
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Two‑parameter thermal model capturing the insulated box dynamics."
    DTDFVocab:inputTo CalibrationEnabler, KalmanFilterEnabler, RuntimePredictionEnabler, CoSimulationEnabler, SelfAdaptationEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Four‑parameter thermal model that accurately captures heat‑bed inertia."
    DTDFVocab:inputTo CalibrationEnabler, KalmanFilterEnabler, RuntimePredictionEnabler, CoSimulationEnabler, SelfAdaptationEnabler
]

// C11: Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Nonlinear least‑squares fitting routine that calibrates ModelA and ModelB against in‑field temperature data."
    DTDFVocab:enables OnDemandCalibrationService
]

instance KalmanFilterEnabler : DTDFVocab:Enabler [
    base:desc "Kalman filter that fuses internal and external temperature measurements to estimate the heat‑bed temperature and flag anomalies."
    DTDFVocab:enables AnomalyDetectionService
]

instance RuntimePredictionEnabler : DTDFVocab:Enabler [
    base:desc "Runtime state prediction engine that uses ModelB to forecast temperature trajectories for real‑time monitoring."
    DTDFVocab:enables RealTimeVisualizationService
]

instance CoSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Co‑simulation runner that executes what‑if scenarios with historical or live data and ModelB."
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationEnabler : DTDFVocab:Enabler [
    base:desc "Self‑adaptation controller that schedules adaptive experiments, recalibrates ModelB, reconfigures the Kalman filter and controller upon detecting altered plant behaviour."
    DTDFVocab:enables SelfAdaptationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization service that ingests temperature data and updates dashboards."
    DTDFVocab:provides RealTimeTemperatureInsight
]

instance OnDemandCalibrationService : DTDFVocab:Service [
    base:desc "On‑demand calibration service that triggers model calibration routines."
    DTDFVocab:provides ModelCalibrationInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection service that uses Kalman filter to flag abnormal temperatures and behaviours."
    DTDFVocab:provides FaultDetectionInsight, HeatbedTemperatureEstimateInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Co‑simulation service that performs what‑if analyses using ModelB and live data."
    DTDFVocab:provides ControllerOptimizationInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Self‑adaptation service that schedules experiments, recalibrates models, and reconfigures controls."
    DTDFVocab:provides AdaptiveExperimentInsight, AdjustControllerSetpointAction
]

// C17: Insights
instance RealTimeTemperatureInsight : DTDFVocab:Insight [
    base:desc "Real‑time monitoring of temperature data streams."
]

instance HeatbedTemperatureEstimateInsight : DTDFVocab:Insight [
    base:desc "Estimated heat‑bed temperature derived from Kalman filter."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of fault conditions such as sensor drift or actuator failure."
]

instance ControllerOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized controller parameters suggested by what‑if simulation."
]

instance AdaptiveExperimentInsight : DTDFVocab:Insight [
    base:desc "Schedule of adaptive experiments triggered by self‑adaptation."
]

instance ModelCalibrationInsight : DTDFVocab:Insight [
    base:desc "Updated parameters for ThermalModelA and ThermalModelB after calibration."
]

// C17: Actions
instance AdjustControllerSetpointAction : DTDFVocab:Action [
    base:desc "Automatically adjusts the controller set‑point temperature based on model predictions."
    DTDFVocab:IsAutomatic true
]

// C3: Physical acting components (components)
instance RaspberryPi : DTDFVocab:Component [
    base:desc "Raspberry Pi controlling sensors, actuators, and running the digital twin logic."
]

instance HeatbedHeater : DTDFVocab:Component [
    base:desc "Heater providing thermal input to the incubator's heatbed."
]

instance Fan : DTDFVocab:Component [
    base:desc "Fan actuator that circulates air inside the incubator."
]

// C17: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains RaspberryPi, HeatbedHeater, Fan
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands generated by the DT are transmitted over RabbitMQ to the Raspberry Pi controller, which interprets them as actuation requests for the fan and the heatbed. The controller operates as a bang‑bang regulator, using the parameters lower limit (LL), upper limit (UL), heating duration (H), and waiting duration (C) to decide when to turn the heater or fan on or off. The low‑level driver receives these commands from the controller via the communication server and actuates the hardware. The controller reports its state back to RabbitMQ, providing feedback of the executed command. The documents provide no details on command authentication, conflict resolution, or explicit confirmation protocols beyond this state reporting."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is ensured through a two‑step process: first, each model is calibrated using a non‑linear least‑squares solver against a representative set of experimental data; second, the calibrated model is validated by comparing its predictions to an independent measurement trajectory, computing the root‑mean‑square error as the quantitative metric. Uncertainty in the models originates from variability in the heatbed’s thermal inertia and from random sensor noise; these are propagated through a Kalman filter that not only estimates the unmeasured heatbed temperature but also provides real‑time residuals that serve as anomaly indicators. When residuals exceed a statistically-defined threshold, the Twin’s monitor triggers a safety shutdown or logs the violation for further review. The entire calibration and validation workflow is automated and can be re‑run on demand (e.g., when a new load is introduced) to maintain fidelity. Additionally, co‑simulations that replay historical or live data are used to perform “what‑if” analyses, providing an operational validation of controller settings and further reinforcing the quality assurance process."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All data and control flow between the physical and virtual twins is mediated by a RabbitMQ message broker. The broker is deployed as part of the software stack and provides an AMQP‑based messaging layer that connects the low‑level driver, the Raspberry Pi controller, and the DT services. The documents do not describe network topology beyond this single‑broker architecture, nor do they detail bandwidth, latency, or redundancy requirements."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The core software components – the low‑level driver, the controller executing a bang‑bang logic, and the RabbitMQ communication server – are all hosted on a Raspberry Pi 4 Model B. This edge deployment is supported by the open‑source repository released by the authors. The documents do not provide explicit computational or storage resource specifications, nor do they describe additional deployment models, scalability mechanisms, or availability guarantees beyond the single‑device setup."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The digital twin framework for the incubator incorporates real‑time safety monitoring by running dedicated monitor algorithms that continuously evaluate the physical twin’s operating state against safety and optimality thresholds. Calibration algorithms update the embedded physics models using incoming sensor data (two temperature sensors inside the styrofoam box and one outside), ensuring the model predictions stay synchronized with the measured temperature dynamics. When a monitor detects a violation—such as a deviation from the target temperature band or anomalous heat‑bed performance—the system generates an alert that can be handled by a human operator or an automated safety‑action module. This integration of monitoring and calibration establishes a safety‑critical feedback loop that maintains the incubator within safe operating limits while enabling adaptive control of the heater and fan. No specific cybersecurity or access‑control measures are described in the provided documents."
]