// =============================
// Physical Sensing Components
// =============================

instance IncubatorAirTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer mounted inside the incubator (two sensors, ±0.5 °C accuracy, –55 °C to +125 °C)"
    DTDFVocab:producedData IncubatorAirTempDataTransmitted
]

instance AmbientRoomTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring ambient room temperature (±0.5 °C accuracy, –55 °C to +125 °C)"
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// =============================
// Data Transmitted (PT‑to‑DT)
// =============================

instance IncubatorAirTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorAirTempSensor
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientRoomTempSensor
]

// =============================
// DT Data Assets
// =============================

instance IncubatorAirTempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature readings from the incubator interior"
    DTDFVocab:fromData IncubatorAirTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature readings from the surrounding room"
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

// =============================
// Models
// =============================

instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single‑zone thermal model (heat capacity C_air, conductance G_box) for the incubator air"
    DTDFVocab:inputTo PredictionEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Extended thermal model adding heat‑bed capacity C_heater and conductance G_heater"
    DTDFVocab:inputTo PredictionEngine
]

// =============================
// Enablers (Tools & Infrastructure)
// =============================

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on the Raspberry Pi, relays sensor streams to the DT"
    DTDFVocab:enables RealTimeTemperatureMonitoringService,
                    SafetyViolationMonitoringService,
                    VisualizationService,
                    AutomaticCalibrationService
]

instance SciPyCalibrationEngine : DTDFVocab:Enabler [
    base:desc "Python SciPy non‑linear least‑squares optimizer used for model parameter calibration"
    DTDFVocab:enables AutomaticCalibrationService
]

instance PredictionEngine : DTDFVocab:Enabler [
    base:desc "Python runtime that executes ThermalModelA and ThermalModelB for temperature prediction"
    DTDFVocab:enables ModelBasedPredictionService
]

instance GitHubRepository : DTDFVocab:Enabler [
    base:desc "Open‑source GitHub repo (https://github.com/INTO-CPS-Association/example-incubator) providing schematics and code"
    DTDFVocab:enables VisualizationService
]

// =============================
// DT Services
// =============================

instance RealTimeTemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Provides live monitoring of incubator temperature streams"
    DTDFVocab:provides CurrentTemperatureInsight
]

instance ModelBasedPredictionService : DTDFVocab:Service [
    base:desc "Offers model‑based prediction of air temperature using ThermalModelA and ThermalModelB"
    DTDFVocab:provides PredictedTemperatureInsight
]

instance AutomaticCalibrationService : DTDFVocab:Service [
    base:desc "Automatically calibrates model parameters via SciPy optimisation on incoming data"
    DTDFVocab:provides CalibratedModelParametersInsight
]

instance SafetyViolationMonitoringService : DTDFVocab:Service [
    base:desc "Monitors temperature against safety limits and raises alerts on violations"
    DTDFVocab:provides TemperatureViolationInsight,
                    TriggerAlertAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualises sensor data and model outputs through a web dashboard"
    DTDFVocab:provides VisualizationInsight,
                    AdjustHeatingDurationAction
]

// =============================
// Insights & Actions
// =============================

instance CurrentTemperatureInsight : DTDFVocab:Insight [
    base:desc "Current measured temperature inside the incubator"
]

instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted future air temperature from the selected thermal model"
]

instance CalibratedModelParametersInsight : DTDFVocab:Insight [
    base:desc "Optimised parameters (C_air, G_box, C_heater, G_heater) after calibration"
]

instance TemperatureViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature exceeding defined safety thresholds"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of temperature trends and model predictions"
]

instance AdjustHeatingDurationAction : DTDFVocab:Action [
    base:desc "Operator‑initiated adjustment of heater on‑time to correct temperature drift"
    DTDFVocab:IsAutomatic false
]

instance TriggerAlertAction : DTDFVocab:Action [
    base:desc "Automatic generation of an alert message when a safety violation occurs"
    DTDFVocab:IsAutomatic true
]

instance UpdateControlLimitsAction : DTDFVocab:Action [
    base:desc "Updates the temperature control limits based on new calibration results"
    DTDFVocab:IsAutomatic false
]

// =============================
// Acting Components (Physical)
// =============================

instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heatbed (≈214 × 214 × 3 mm) delivering up to 100 W, switched on/off via MOSFET driver"
]

instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal fan providing ≈0.02 m³·s⁻¹ airflow for air mixing, controlled via GPIO"
]

// =============================
// Physical Components & Environment
// =============================

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B hosting the driver, controller software and RabbitMQ broker"
]

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator,
                InternalFanActuator,
                IncubatorAirTempSensor,
                AmbientRoomTempSensor,
                RaspberryPiController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (heatbed power enable/disable, fan activation) to RabbitMQ; the low‑level driver on the Raspberry Pi subscribes to these messages and drives the MOSFET/GPIO outputs to actuate the heatbed and fan."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture consists of the PT (incubator hardware) → low‑level driver → RabbitMQ broker → DT components (model calibration, monitoring, safety watchdog) → controller state‑chart (bang‑bang with lower/upper limits, heating and waiting durations) → actuation signals back to the PT. All components communicate via RabbitMQ messages, forming a centralized DT orchestration around the Raspberry Pi."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by explicit assumptions (uniform temperature, negligible wall heat storage, constant air specific heat) and validated through experiments: (a) uniformity test with three temperature sensors at different locations, (b) variation of fan voltage to assess mixing, and (c) calibration error minimisation using least‑squares. Model B, with additional heatbed dynamics, showed higher predictive accuracy for thermal inertia."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT uses the RabbitMQ message broker over the Raspberry Pi’s built‑in Wi‑Fi (or Bluetooth) network interface, employing standard AMQP protocol for publish/subscribe of sensor data and control commands."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ server and all DT software components (driver, controller, calibration scripts) are hosted locally on the Raspberry Pi 4 Model B, enabling on‑premises deployment without external cloud services."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the PT in a safe state on communication failures; the DT monitors for safety violations (temperature out‑of‑bounds) and can trigger human intervention. No further security standards are described."
]