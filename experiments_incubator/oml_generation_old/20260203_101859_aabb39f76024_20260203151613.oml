// C3: Physical sensing components
instance InsideTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer inside the incubator box"
    DTDFVocab:producedData InsideTempDataTransmitted1
]

instance InsideTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer inside the incubator box"
    DTDFVocab:producedData InsideTempDataTransmitted2
]

instance InsideTemperatureSensor3 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer inside the incubator box"
    DTDFVocab:producedData InsideTempDataTransmitted3
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer positioned outside the incubator to measure ambient room temperature"
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransferred)
instance InsideTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor1
]

instance InsideTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor2
]

instance InsideTempDataTransmitted3 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor3
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

// C10: Models/Data
instance InsideTemperatureData1 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature log from InsideTemperatureSensor1"
    DTDFVocab:fromData InsideTempDataTransmitted1
    DTDFVocab:inputTo RabbitMQEnabler
]

instance InsideTemperatureData2 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature log from InsideTemperatureSensor2"
    DTDFVocab:fromData InsideTempDataTransmitted2
    DTDFVocab:inputTo RabbitMQEnabler
]

instance InsideTemperatureData3 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature log from InsideTemperatureSensor3"
    DTDFVocab:fromData InsideTempDataTransmitted3
    DTDFVocab:inputTo RabbitMQEnabler
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped ambient temperature log from AmbientTemperatureSensor"
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo RabbitMQEnabler
]

instance ActuatorStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatbedHeater, FanActuator
]

instance ActuatorStateData : DTDFVocab:Data [
    base:desc "Time‑stamped actuator state log (heatbed and fan)"
    DTDFVocab:fromData ActuatorStateDataTransmitted
    DTDFVocab:inputTo RabbitMQEnabler
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "First dynamic temperature model (Model A) with parameters C_air, G_box, C_heater, G_heater calibrated via nonlinear least squares"
    DTDFVocab:inputTo PythonEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Second dynamic temperature model (Model B) with parameters C_air, G_box, C_heater, G_heater calibrated via nonlinear least squares"
    DTDFVocab:inputTo PythonEnabler
]

// C11: Enablers
instance RaspberryPiEnabler : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B running control scripts, GPIO, and 1‑Wire interfaces"
    DTDFVocab:enables TemperatureMonitoringService
]

instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP server running on Raspberry Pi for bidirectional data synchronization"
    DTDFVocab:enables TemperatureMonitoringService, ControllerStateVisualizationService, SupervisoryDecisionMakingService
]

instance PythonEnabler : DTDFVocab:Enabler [
    base:desc "Python environment with Scipy for parameter estimation, nonlinear least squares, and dynamic modeling"
    DTDFVocab:enables TemperatureSimulationService, CalibrationService
]

// C6: Services
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time temperature monitoring via RabbitMQ"
    DTDFVocab:provides OptimalHeatingDurationInsight, AdjustHeatingDurationAction
]

instance ControllerStateVisualizationService : DTDFVocab:Service [
    base:desc "Visualization of controller state and temperature limits in real‑time"
    DTDFVocab:provides ControlLimitAnalyticsInsight, CalibrateControlLimitsAction
]

instance SupervisoryDecisionMakingService : DTDFVocab:Service [
    base:desc "Supervisory decision‑making for temperature regulation (heating duration, fan speed)"
    DTDFVocab:provides TemperatureDiscrepancyInsight, AdjustFanSpeedAction
]

instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Simulation of temperature dynamics using Model A and Model B"
    DTDFVocab:provides SimulationResultInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration of model parameters via nonlinear least squares"
    DTDFVocab:provides ModelParameterCalibrationInsight, CalibrateControlLimitsAction
]

// C17: Insights
instance OptimalHeatingDurationInsight : DTDFVocab:Insight [
    base:desc "DT estimates optimal heating duration based on calibrated models"
]

instance TemperatureDiscrepancyInsight : DTDFVocab:Insight [
    base:desc "DT identifies temperature discrepancies to adjust fan speed"
]

instance ModelParameterCalibrationInsight : DTDFVocab:Insight [
    base:desc "DT provides insight into model parameter calibration to improve prediction"
]

instance ControlLimitAnalyticsInsight : DTDFVocab:Insight [
    base:desc "DT provides analytics for tuning control limits (LL, UL)"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "DT provides simulated temperature dynamics from Model A and Model B"
]

// C17: Actions
instance AdjustHeatingDurationAction : DTDFVocab:Action [
    base:desc "Automatically adjust heating duration according to DT insight"
    DTDFVocab:IsAutomatic true
]

instance AdjustFanSpeedAction : DTDFVocab:Action [
    base:desc "Automatically adjust fan speed based on temperature discrepancy insight"
    DTDFVocab:IsAutomatic true
]

instance CalibrateControlLimitsAction : DTDFVocab:Action [
    base:desc "Calibrate lower and upper temperature limits based on analytics insight"
    DTDFVocab:IsAutomatic false
]

// C3: Physical sensing components (actuating side)
instance HeatbedHeater : DTDFVocab:ActingComponent [
    base:desc "Heatbed heater (~100 W) controlled via MOSFET, switched by Raspberry Pi GPIO"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V fan (airflow ~0.02 m³/s) controlled via MOSFET, switched by Raspberry Pi GPIO"
]

// C3: Components
instance InsulatedStyrofoamBox : DTDFVocab:Component [
    base:desc "Styrofoam insulated box forming the incubator enclosure"
]

instance Heatbed : DTDFVocab:Component [
    base:desc "Heatbed plate spread over the base of the styrofoam box"
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B acting as the central controller, handling sensors, actuators, and data transmission"
]

// C17: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedHeater, FanActuator, RaspberryPiController, InsulatedStyrofoamBox, Heatbed
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands over RabbitMQ; the controller on the Pi receives these messages and actuates the heatbed or fan via the MOSFETs according to the commanded state."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange and control loop executed at the sampling interval of the low‑level driver (typically in seconds); DT updates models and sends control commands within the same time step."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Comprised of a low‑level driver (sensor/actuator abstraction), a control logic module (bang‑bang controller with LL, UL, H, C parameters), a RabbitMQ communication server, and the physical components (heatbed, fan, sensors, Raspberry Pi)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Stages include design (idealized models), manufacturing (actual hardware case, PCB, Raspberry Pi setup), operation (daily temperature regulation), and calibration/validation (parameter estimation and model verification)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Assumptions: uniform temperature inside box, negligible wall heat transfer, constant air specific heat, ignoring fan heat. Model validation through residual error minimization and comparison to experimental temperature trajectories; calibration ensures predictive accuracy for inertial effects of heatbed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "AMQP protocol over LAN/Wi‑Fi between Raspberry Pi (host) and digital twin processes; messages carry sensor readings, control commands, and state updates."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital twin services run locally on the Raspberry Pi executing RabbitMQ; the system is deployable on a single board computer with open‑source code repository, potentially scalable to cloud deployment via the same RabbitMQ broker."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Low‑level driver implements a safe protocol to prevent unsafe actuator states; RabbitMQ ensures message integrity; critical control commands are monitored for safety violations before execution."
]