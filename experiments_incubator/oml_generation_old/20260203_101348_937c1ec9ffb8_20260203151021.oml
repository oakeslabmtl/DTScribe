// C2: Acting Components
instance HeatbedHeaterActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed heater controlled by Raspberry Pi GPIO outputs through MOSFET driver and optocoupler."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan for air circulation driven by Raspberry Pi GPIO outputs through MOSFET driver and optocoupler."
]

// C3: Physical sensing components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer mounted inside the styrofoam box."
    DTDFVocab:producedData InternalTemperatureDataTransmitted1
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer mounted inside the styrofoam box."
    DTDFVocab:producedData InternalTemperatureDataTransmitted2
]

instance InternalTemperatureSensor3 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer mounted inside the styrofoam box."
    DTDFVocab:producedData InternalTemperatureDataTransmitted3
]

instance ExternalRoomTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer placed outside the box for room temperature measurement."
    DTDFVocab:producedData ExternalRoomTemperatureDataTransmitted
]

// C4: Data transmitted from sensors
instance InternalTemperatureDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1
]

instance InternalTemperatureDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor2
]

instance InternalTemperatureDataTransmitted3 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor3
]

instance ExternalRoomTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalRoomTemperatureSensor
]

// C10: Models
instance ModelA : DTDFVocab:Model [
    base:desc "Physics‑based single‑energy‑transfer thermal model for the incubator."
    DTDFVocab:inputTo SimulationEngineEnabler
]

instance ModelB : DTDFVocab:Model [
    base:desc "Physics‑based dual‑energy‑transfer thermal model with heatbed for the incubator."
    DTDFVocab:inputTo SimulationEngineEnabler
]

// C10: Data
instance InternalTemperatureData1 : DTDFVocab:Data [
    base:desc "Time‑series temperature reading from InternalTemperatureSensor1."
    DTDFVocab:inputTo CalibrationEngineEnabler, RabbitMQBrokerEnabler
    DTDFVocab:fromData InternalTemperatureDataTransmitted1
]

instance InternalTemperatureData2 : DTDFVocab:Data [
    base:desc "Time‑series temperature reading from InternalTemperatureSensor2."
    DTDFVocab:inputTo CalibrationEngineEnabler, RabbitMQBrokerEnabler
    DTDFVocab:fromData InternalTemperatureDataTransmitted2
]

instance InternalTemperatureData3 : DTDFVocab:Data [
    base:desc "Time‑series temperature reading from InternalTemperatureSensor3."
    DTDFVocab:inputTo CalibrationEngineEnabler, RabbitMQBrokerEnabler
    DTDFVocab:fromData InternalTemperatureDataTransmitted3
]

instance ExternalRoomTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series room temperature reading from ExternalRoomTemperatureSensor."
    DTDFVocab:inputTo CalibrationEngineEnabler, RabbitMQBrokerEnabler
    DTDFVocab:fromData ExternalRoomTemperatureDataTransmitted
]

// C11: Enablers
instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker facilitating real‑time data exchange between sensors and Digital Twin."
    DTDFVocab:enables TemperatureComplianceMonitoringService, SafetyCheckService, GraphicalOverviewService
]

instance CalibrationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python‑SciPy least‑squares engine for calibrating thermal model parameters."
    DTDFVocab:enables ParameterCalibrationService
]

instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python engine executing ModelA and ModelB simulations for temperature dynamics."
    DTDFVocab:enables TemperatureSimulationService
]

// C6: Services
instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Model‑based simulation of temperature dynamics using Models A and B."
    DTDFVocab:provides SimulationResultInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Parameter calibration via non‑linear least‑squares using SciPy."
    DTDFVocab:provides ParameterUpdateInsight
]

instance TemperatureComplianceMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time temperature compliance monitoring, safety checks, and graphical overview of actuator states."
    DTDFVocab:provides TemperatureComplianceInsight, AdjustmentRecommendationInsight, DeviationFlaggingInsight, AdjustHeatingScheduleAction
]

instance SafetyCheckService : DTDFVocab:Service [
    base:desc "Safety checks for over‑temperature conditions."
    DTDFVocab:provides DeviationFlaggingInsight, FlagDeviationAction
]

instance GraphicalOverviewService : DTDFVocab:Service [
    base:desc "Graphical overview of actuator states."
    DTDFVocab:provides ActuatorStateGraphInsight
]

// C17: Insights
instance TemperatureComplianceInsight : DTDFVocab:Insight [
    base:desc "Inference that current heating schedules meet temperature targets."
]

instance AdjustmentRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation to adjust heating durations based on model predictions."
]

instance DeviationFlaggingInsight : DTDFVocab:Insight [
    base:desc "Flag that temperature has deviated from target for a prolonged period."
]

instance ParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Updated parameter values for C_air, C_heater, G_box, G_heater after calibration."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory from simulation."
]

instance ActuatorStateGraphInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of current actuator states."
]

// C17: Actions
instance AdjustHeatingScheduleAction : DTDFVocab:Action [
    base:desc "Recommend adjustment of heating durations based on model predictions."
    DTDFVocab:IsAutomatic true
]

instance FlagDeviationAction : DTDFVocab:Action [
    base:desc "Flag prolonged temperature deviations to supervisor."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin publishes control commands (heatbed on/off, fan on/off, heating duration) to RabbitMQ; the low‑level driver consumes these messages and actuates the GPIO outputs to drive MOSFETs that switch the heater and fan."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Synchronization is achieved in real‑time with sensor polling and command cycles occurring on the order of seconds; the bang‑bang controller uses heating bursts of duration H and waiting periods C, while the Digital Twin processes data and commands at a comparable time scale."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation comprises the physical hardware (box, heater, fan, sensors, Raspberry Pi and PCB), the low‑level driver interfacing with the PT, the RabbitMQ broker routing messages between PT and DT, the Digital Twin logic subscribing to sensor streams, executing calibration and monitoring, publishing actuator commands, and a graphical interface visualising temperature and state—all orchestrated via AMQP queues on a local network."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin operates during the operational lifecycle of the incubator: it is calibrated at commissioning, continuously monitors and controls temperature during normal operation, and updates parameters or models during maintenance, covering the 'operated' stage of the PT."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity depends on assumptions: uniform temperature distribution, negligible wall heat absorption, constant air specific heat, and negligible fan heat; validation compares simulated trajectories with experimental data using least‑squares residuals; uncertainties arise from sensor accuracy (±0.5 °C) and control loop delay causing over‑heating; safety monitors detect violations and can trigger human intervention."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The PT–DT interface uses RabbitMQ running on the Raspberry Pi over the local Wi‑Fi network; messages follow the AMQP protocol; sensor data and actuator commands are transferred via dedicated queues; GPIO outputs drive MOSFETs isolated by optocouplers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin runtime, simulation, and RabbitMQ broker are hosted on the same Raspberry Pi 4 Model B, providing edge deployment with low latency; the source code is open‑source and can be redeployed in alternative cloud environments if desired."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "No explicit horizontal integration with external systems or other Digital Twins is described in the documents."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Physical isolation is ensured via optocouplers between the Raspberry Pi and MOSFET drivers; the low‑level driver implements a safe protocol limiting heater duration to prevent overheating; cybersecurity aspects are not explicitly addressed in the documents."
]