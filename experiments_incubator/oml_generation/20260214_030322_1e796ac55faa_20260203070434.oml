// -------------------------------------------------
// Physical Sensing Components
// -------------------------------------------------
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor placed inside the incubator box, measures ambient temperature and supplies readings to the Raspberry Pi controller."
    DTDFVocab:producedData InternalTempDataTxA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor placed inside the incubator box at a second location, measures ambient temperature and supplies readings to the Raspberry Pi controller."
    DTDFVocab:producedData InternalTempDataTxB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor placed outside the incubator box, measures ambient temperature and supplies readings to the Raspberry Pi controller."
    DTDFVocab:producedData ExternalTempDataTx
]

// -------------------------------------------------
// Data Transmitted from Sensors
// -------------------------------------------------
instance InternalTempDataTxA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempDataTxB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// -------------------------------------------------
// Data Objects (temperature readings)
// -------------------------------------------------
instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Temperature reading (numeric value with timestamp) from InternalTempSensorA."
    DTDFVocab:fromData InternalTempDataTxA
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Temperature reading (numeric value with timestamp) from InternalTempSensorB."
    DTDFVocab:fromData InternalTempDataTxB
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Temperature reading (numeric value with timestamp) from ExternalTempSensor."
    DTDFVocab:fromData ExternalTempDataTx
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler
]

// -------------------------------------------------
// Models (thermal simulation)
// -------------------------------------------------
instance TwoParamThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model of the incubator using two free parameters to predict internal temperature dynamics."
    DTDFVocab:inputTo CalibrationEnabler, PredictionEnabler
]

instance FourParamThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model of the incubator using four free parameters, captures thermal inertia of the heat‑bed more accurately."
    DTDFVocab:inputTo CalibrationEnabler, PredictionEnabler
]

// -------------------------------------------------
// Enablers (algorithms / engines)
// -------------------------------------------------
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Algorithm that ingests temperature data and updates the free parameters of the thermal models."
    DTDFVocab:enables CalibrationService
]

instance PredictionEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs calibrated thermal models to generate temperature forecasts."
    DTDFVocab:enables PredictionService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring component that compares predicted temperature against safety bounds and detects violations."
    DTDFVocab:enables SafetyMonitoringService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimization algorithm that selects heater power and fan speed set‑points to achieve target temperature efficiently."
    DTDFVocab:enables OptimizationService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Visualization tool that presents predicted temperature trajectories and current sensor readings to operators."
    DTDFVocab:enables VisualizationService
]

// -------------------------------------------------
// Services
// -------------------------------------------------
instance CalibrationService : DTDFVocab:Service [
    base:desc "Continuously calibrates the thermal models using latest sensor data."
    DTDFVocab:provides ModelCalibratedInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Provides predictive simulation of incubator temperature using calibrated models."
    DTDFVocab:provides TemperatureForecastInsight
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Monitors temperature data and model forecasts to detect safety or optimality violations."
    DTDFVocab:provides TemperatureViolationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Generates prescriptive control actions (heater power, fan speed) to maintain target temperature."
    DTDFVocab:provides AdjustHeaterPowerAction, AdjustFanSpeedAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualises real‑time temperature data and forecast trajectories for operator decision support."
    DTDFVocab:provides TemperatureForecastInsight
]

// -------------------------------------------------
// Insights
// -------------------------------------------------
instance ModelCalibratedInsight : DTDFVocab:Insight [
    base:desc "Indicates that the thermal model parameters have been successfully updated based on recent sensor data."
]

instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Provides forecasted temperature trajectory over the next prediction horizon."
]

instance TemperatureViolationInsight : DTDFVocab:Insight [
    base:desc "Detects deviation of temperature from target bounds, signalling a safety or optimality violation."
]

// -------------------------------------------------
// Actions
// -------------------------------------------------
instance AdjustHeaterPowerAction : DTDFVocab:Action [
    base:desc "Command to change the heat‑bed power setting to bring temperature back within target range."
    DTDFVocab:IsAutomatic true
]

instance AdjustFanSpeedAction : DTDFVocab:Action [
    base:desc "Command to adjust fan speed to improve heat distribution and temperature stability."
    DTDFVocab:IsAutomatic true
]

// -------------------------------------------------
// Physical Acting Components
// -------------------------------------------------
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed actuator providing controllable heating power, driven by the Raspberry Pi controller."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan actuator that circulates air inside the insulated styrofoam box, driven by the Raspberry Pi controller."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by DT components and sent as messages to the RabbitMQ server. The controller, listening on the RabbitMQ queues, receives these messages and translates them into actuator commands for the heat‑bed and fan (e.g., turn heating on/off, set heating duration, fan speed). After execution, the controller publishes the resulting control state back to RabbitMQ, providing implicit execution confirmation. The low‑level driver incorporates a safe protocol that validates incoming commands before they are applied to the physical actuators."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The incubator DT processes data in (near) real‑time: controller and low‑level driver messages are streamed continuously to a time‑series database and visualized on a dashboard; a Kalman‑filter based anomaly detector runs on the incoming measurements, and calibration of Model B can be triggered on demand. Co‑simulations can use either historical or live PT data, implying that the digital twin can operate both in offline (batch) and online (real‑time) modes. No explicit sampling period or latency bound is given in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture comprises (i) data acquisition from the PT via controller and driver messages, (ii) storage in a time‑series database, (iii) real‑time visualization on a dashboard, (iv) an on‑demand calibration module that updates Model B parameters, (v) a Kalman‑filter based anomaly detection and heat‑bed state estimator, (vi) what‑if simulations performed by co‑simulation that consume historical or live PT data, and (vii) a self‑adaptation loop that sequences detection, experiment planning, controller re‑configuration, data collection, recalibration, filter re‑tuning and optimisation. This constitutes a closed feedback (MAPE‑style) orchestration of monitoring, analysis, planning and execution components."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by providing two variants: a low‑fidelity model with two free parameters and a higher‑fidelity model with four free parameters that better captures the heatbed’s thermal inertia. Validation is performed experimentally by comparing model predictions against the temperature data collected from the sensors, with the higher‑fidelity model demonstrating superior predictive accuracy. Uncertainty arises from parameter estimation errors and sensor measurement noise. Calibration algorithms are employed to minimize these uncertainties by continuously updating model parameters based on incoming data. Monitors within the DT architecture detect deviations from expected behaviour, enabling error correction and ensuring the reliability of both models and data throughout operation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The digital‑twin communication backbone is a RabbitMQ message broker that mediates all message exchange between PT components (low‑level driver, controller) and DT software. All participants connect as clients to this central broker, forming a star‑like topology where the broker routes messages. RabbitMQ offers reliable delivery and persistence; specific bandwidth, latency, redundancy or security configurations are not detailed in the provided documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The physical twin runs on a Raspberry Pi that hosts both the low‑level driver and the controller software. The RabbitMQ server, which provides the communication platform for the DT, is deployed as a separate service (the documents do not specify whether it is on‑premise or cloud‑based). No explicit computational or storage requirements, scalability mechanisms, or availability guarantees are described in the source material."
]