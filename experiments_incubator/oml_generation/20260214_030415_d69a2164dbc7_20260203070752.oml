// C3: Physical sensing components
instance BoxTempSensorInside1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer inside the incubator box (range –55 °C to +125 °C, accuracy ±0.5 °C) connected to Raspberry Pi GPIO via 1‑Wire bus."
    DTDFVocab:producedData BoxTempDataTransmitted1
]

instance BoxTempSensorInside2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 1‑Wire digital thermometer inside the incubator box (range –55 °C to +125 °C, accuracy ±0.5 °C) connected to Raspberry Pi GPIO via 1‑Wire bus."
    DTDFVocab:producedData BoxTempDataTransmitted2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring ambient temperature outside the incubator (range –55 °C to +125 °C, accuracy ±0.5 °C) connected to Raspberry Pi GPIO."
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// C4: Physical‑to‑virtual interaction (DataTransmitted)
instance BoxTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxTempSensorInside1
]

instance BoxTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxTempSensorInside2
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// C10: Data objects
instance BoxTemperatureData1 : DTDFVocab:Data [
    base:desc "Real‑time temperature reading from the first internal DS18S20 sensor."
    DTDFVocab:fromData BoxTempDataTransmitted1
    DTDFVocab:inputTo RabbitMQBroker
]

instance BoxTemperatureData2 : DTDFVocab:Data [
    base:desc "Real‑time temperature reading from the second internal DS18S20 sensor."
    DTDFVocab:fromData BoxTempDataTransmitted2
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Real‑time ambient temperature reading from the external DS18S20 sensor."
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

// C2: Acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed controlled on/off via MOSFET driver on the custom PCB; command issued through Raspberry Pi GPIO."
]

instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V DC fan for air circulation, driven through the same MOSFET circuitry; command issued via Raspberry Pi GPIO."
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on the Raspberry Pi; receives sensor messages and publishes them to DT components."
    DTDFVocab:enables TemperatureMonitoringService
]

instance SciPyLeastSquaresOptimizer : DTDFVocab:Enabler [
    base:desc "SciPy least‑squares solver used to calibrate thermal model parameters against experimental temperature trajectories."
    DTDFVocab:enables ModelCalibrationService
]

instance PythonControllerRuntime : DTDFVocab:Enabler [
    base:desc "Python driver layer that reads sensors, formats messages, and interacts with RabbitMQ and GPIO for actuation."
    DTDFVocab:enables TemperatureMonitoringService, ModelCalibrationService
]

// C6: Services
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Service that subscribes to RabbitMQ temperature topics, evaluates real‑time temperature stability, and detects anomalies."
    DTDFVocab:provides TemperatureAnomalyInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Service that performs non‑linear parameter fitting of Model A and Model B using SciPy based least‑squares optimisation."
    DTDFVocab:provides HeatBedControlAction
]

// C17: Insight / Action
instance TemperatureAnomalyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating temperature deviation beyond predefined limits, prompting operator attention."
]

instance HeatBedControlAction : DTDFVocab:Action [
    base:desc "Automatic action to adjust heat‑bed on/off state to bring incubator temperature back within target range."
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Physics‑based dynamic model of incubator temperature with single heat capacity C_air and heat loss parameter G_box."
    DTDFVocab:inputTo SciPyLeastSquaresOptimizer
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Extended temperature model adding heat‑bed thermal mass C_heater and coupling parameter G_heater."
    DTDFVocab:inputTo SciPyLeastSquaresOptimizer
]

// C13: Environment composition
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains BoxTempSensorInside1, BoxTempSensorInside2, AmbientTempSensor,
                HeatBedActuator, InternalFanActuator,
                RaspberryPiController, CustomPCBCircuit,
                PowerSupplyUnit, InsulatedStyrofoamContainer
]

// C12: Physical components (non‑sensor/actuator)
instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B running Linux, providing Wi‑Fi/Bluetooth, GPIO for sensor/actuator I/O, and hosting the Python controller."
]

instance CustomPCBCircuit : DTDFVocab:Component [
    base:desc "Custom printed circuit board containing MOSFET drivers and optocouplers for safe actuation of heat‑bed and fan."
]

instance PowerSupplyUnit : DTDFVocab:Component [
    base:desc "Power supply delivering regulated voltage to Raspberry Pi, heat‑bed, fan, and PCB circuitry."
]

instance InsulatedStyrofoamContainer : DTDFVocab:Component [
    base:desc "Insulated styrofoam box (~0.03 m³ volume) forming the physical enclosure of the incubator."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (e.g., heat‑bed ON/OFF, fan speed) to the RabbitMQ server. The controller on the Raspberry Pi consumes these messages and drives the MOSFET/optocoupler circuit to actuate the heat‑bed and fan via GPIO outputs."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture follows a CPS‑based pattern: physical hardware → low‑level driver → RabbitMQ communication server → controller (bang‑bang with hysteresis) → DT components (model calibration, monitoring). All software runs on the same Raspberry Pi, enabling tight integration of data acquisition, control, and model‑based services."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by explicit assumptions (uniform temperature, negligible wall heat storage, constant air specific heat, heat‑bed power fully converted to heat). Validation experiments test temperature uniformity (maximum deviation ≤ 7 °C, reduced to ≤ 6 °C with higher fan voltage) and calibrate the four free parameters of Model B. The calibration error is minimised via gradient‑descent optimisation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT relies on the RabbitMQ message broker (AMQP protocol) hosted on the Raspberry Pi, using the Pi's built‑in Wi‑Fi or Ethernet. Sensor data uses the 1‑Wire protocol over GPIO; actuator commands are transmitted via GPIO to MOSFET drivers isolated with optocouplers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components (communication server, low‑level driver, controller, and model services) are deployed on the Raspberry Pi 4 Model B itself. The software is container‑agnostic but runs as Python processes; source code and configuration are maintained in the publicly available GitHub repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver implements a safe protocol that enforces a safe state for the hardware; MOSFETs are driven through optocouplers to electrically isolate the Raspberry Pi from high‑current loads, reducing risk of damage or unsafe operation."
]