// Actuating components
instance ActuatorHeatbed : DTDFVocab:ActingComponent [
    base:desc "Heatbed (heater) controlled by the Raspberry Pi via MOSFETs and optocouplers"
]

instance ActuatorFan : DTDFVocab:ActingComponent [
    base:desc "Fan (air circulation device) controlled by the Raspberry Pi via MOSFETs and optocouplers"
]

// Physical sensing components
instance SensingInternalTemperature1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor inside the incubator (sensor 1)"
    DTDFVocab:producedData DataTransmittedTemp
]

instance SensingInternalTemperature2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor inside the incubator (sensor 2)"
    DTDFVocab:producedData DataTransmittedTemp
]

instance SensingOutsideTemperature : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor outside the incubator (room temperature sensor)"
    DTDFVocab:producedData DataTransmittedTemp
]

// Component for power monitoring
instance ComponentRaspberryPiPowerMonitor : DTDFVocab:Component [
    base:desc "Raspberry Pi power supply monitoring via GPIO"
]

// Physical-to-virtual interaction: data transmitted via RabbitMQ
instance DataTransmittedTemp : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SensingInternalTemperature1, SensingInternalTemperature2, SensingOutsideTemperature
]

instance DataTransmittedActuatorState : DTDFVocab:DataTransmitted [
    // No producedFrom for actuators to avoid semantic conflict
]

instance DataTransmittedPowerUsage : DTDFVocab:DataTransmitted [
    // No producedFrom for power monitor to avoid semantic conflict
]

instance DataTransmittedStatusInfo : DTDFVocab:DataTransmitted [
    // No producedFrom for status info to avoid semantic conflict
]

// Internally recorded data
instance DataTemperature : DTDFVocab:Data [
    base:desc "Aggregated temperature readings from DS18S20 sensors"
    DTDFVocab:inputTo EnablerSimulation, EnablerCalibration
    DTDFVocab:fromData DataTransmittedTemp
]

instance DataActuatorState : DTDFVocab:Data [
    base:desc "Current on/off state of heatbed and fan actuators"
    DTDFVocab:inputTo EnablerSimulation
    DTDFVocab:fromData DataTransmittedActuatorState
]

instance DataPowerUsage : DTDFVocab:Data [
    base:desc "Power consumption metrics of the incubator system"
    DTDFVocab:inputTo EnablerSimulation
    DTDFVocab:fromData DataTransmittedPowerUsage
]

instance DataStatusInfo : DTDFVocab:Data [
    base:desc "General status information of the physical twin (e.g., health, errors)"
    DTDFVocab:inputTo EnablerMonitoring
    DTDFVocab:fromData DataTransmittedStatusInfo
]

// Enablers
instance EnablerRabbitMQ : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker over Wi‑Fi for transmitting PT data to the DT"
    DTDFVocab:enables ServiceTemperatureSimulation, ServiceParameterCalibration, ServiceSafetyMonitoring, ServiceDataLogging, ServiceOpenSourceInterface
]

instance EnablerSimulation : DTDFVocab:Enabler [
    base:desc "Simulation enabler for running thermal dynamics models A and B"
    DTDFVocab:enables ServiceTemperatureSimulation
]

instance EnablerCalibration : DTDFVocab:Enabler [
    base:desc "Calibration enabler using Python SciPy for non‑linear least‑squares"
    DTDFVocab:enables ServiceParameterCalibration
]

instance EnablerMonitoring : DTDFVocab:Enabler [
    base:desc "Monitoring enabler to generate safety alerts and basic logging"
    DTDFVocab:enables ServiceSafetyMonitoring, ServiceDataLogging
]

instance EnablerInterface : DTDFVocab:Enabler [
    base:desc "Enabler for providing an open‑source interface to visualization and advanced control"
    DTDFVocab:enables ServiceOpenSourceInterface
]

// Required Insight for Data Logging
instance DataLoggedAction : DTDFVocab:Insight [
    base:desc "Logged data actions from the Data Logging service"
]

// Services
instance ServiceTemperatureSimulation : DTDFVocab:Service [
    base:desc "Simulates temperature dynamics using Models A and B"
    DTDFVocab:provides InsightTemperatureTrajectory, InsightRecommendedHeatingDutyCycle
]

instance ServiceParameterCalibration : DTDFVocab:Service [
    base:desc "Performs parameter calibration of thermal models via non‑linear least‑squares"
    DTDFVocab:provides InsightCalibrationResult
]

instance ServiceSafetyMonitoring : DTDFVocab:Service [
    base:desc "Monitors temperature trajectory for safety and generates anomaly alerts"
    DTDFVocab:provides InsightAnomalyAlert
]

instance ServiceDataLogging : DTDFVocab:Service [
    base:desc "Logs all PT data for further analysis and future model refinements"
    DTDFVocab:provides DataLoggedAction
]

instance ServiceOpenSourceInterface : DTDFVocab:Service [
    base:desc "Provides open‑source interface for future visualization and supervisory control"
    DTDFVocab:provides InterfaceVisualizationInsight
]

// Insights
instance InsightTemperatureTrajectory : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory of the incubator over time"
]

instance InsightRecommendedHeatingDutyCycle : DTDFVocab:Insight [
    base:desc "Recommended heating duty cycle based on simulation results"
]

instance InsightAnomalyAlert : DTDFVocab:Insight [
    base:desc "Alert when temperature deviates beyond safety limits"
]

instance InsightCalibrationResult : DTDFVocab:Insight [
    base:desc "Results of parameter calibration for models A and B"
]

instance InterfaceVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of temperature and actuator data for operators"
]

// Action
instance ActionManualSetHeatingDutyCycle : DTDFVocab:Action [
    base:desc "Allows operator to manually set heating duty cycle"
    DTDFVocab:IsAutomatic false
]

// Models
instance ModelAThermalDynamics : DTDFVocab:Model [
    base:desc "Simplified thermal model A assuming all power goes to air"
    DTDFVocab:inputTo EnablerSimulation
]

instance ModelBThermalDynamics : DTDFVocab:Model [
    base:desc "Model B including heatbed thermal inertia"
    DTDFVocab:inputTo EnablerSimulation
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands back to the PT via RabbitMQ, instructing the Raspberry Pi to turn the heatbed or fan on or off, adjusting duration parameters, and potentially updating model parameters. The DT’s decisions are executed by the PT’s low‑level driver."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The system operates on a real‑time timescale of seconds: sensor sampling and actuator commands are exchanged at ~1–2 s intervals. Model calibration and validation runs offline but targets the same sampling horizon. The DT keeps up‑to‑date with the PT’s state in near real‑time."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized architecture where the controller, low‑level driver, and RabbitMQ server reside on the same Raspberry Pi. The DT model runs as a listener on the message broker, receives sensor data, performs simulation and calibration, and publishes control commands. The hardware components (sensors and actuators) are connected through the Raspberry Pi GPIOs and the PCB."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans all lifecycle phases: design (model creation), manufacturing (embedding sensors and hardware), and operation (runtime monitoring, calibration, and feedback control). The same model is calibrated and updated during the operational phase, maintaining relevance over the entire lifecycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is limited by assumptions (uniform temperature, constant heat capacity, negligible wall heating). Validation is performed experimentally (uniformity tests) and through comparison of model output to measured data. Uncertainties are mitigated by calibrating four free parameters in Model B. Remaining errors are quantified by residual analysis in the least‑squares calibration."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "PT and DT communicate via RabbitMQ over Wi‑Fi using the AMQP protocol. The Raspberry Pi hosts both the physical controller and the message broker, enabling fast data exchange and command dissemination. The communication schedule is set to a 1‑2 s refresh rate."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted on a Raspberry Pi 4 B running a Linux distribution (e.g., Raspbian). RabbitMQ broker, Python controller, and low‑level driver are installed directly on the Pi as background services; no containerisation or cloud deployment is described."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Not explicitly described in the document. The architecture could be extended to exchange data with external logging or cloud services, but no existing integration is mentioned."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "Not in Document; the case study does not specify data ownership or privacy controls."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "No specific industry or academic standards are referenced beyond the open‑source repository and the use of standard protocols (AMQP). The design follows general CPS and digital twin principles described in the literature."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is incorporated in the low‑level driver to ensure the physical device remains in a safe state. Commands are received via RabbitMQ, but the document does not describe encryption, authentication, or access control mechanisms. Safety is maintained through controlled actuation and monitoring of temperature limits."
]