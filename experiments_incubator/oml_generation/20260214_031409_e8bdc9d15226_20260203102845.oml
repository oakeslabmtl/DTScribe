// =============================
// Sensing Components (Physical)
// =============================

instance IncubatorInternalSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer inside the incubator (range –55 °C to +125 °C, accuracy 0.5 °C within –10 °C to +85 °C, unique 64‑bit ID)"
    DTDFVocab:producedData InternalTempDataTx1
]

instance IncubatorInternalSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 1‑Wire digital thermometer inside the incubator (identical specs to InternalSensor1)"
    DTDFVocab:producedData InternalTempDataTx2
]

instance IncubatorAmbientSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring ambient temperature outside the box"
    DTDFVocab:producedData AmbientTempDataTx
]

// =============================
// Data Transmitted (Physical → Virtual)
// =============================

instance InternalTempDataTx1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInternalSensor1
]

instance InternalTempDataTx2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInternalSensor2
]

instance AmbientTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorAmbientSensor
]

// =============================
// Virtual Data (Collected by DT)
// =============================

instance InternalTempData1 : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from InternalSensor1"
    DTDFVocab:fromData InternalTempDataTx1
    DTDFVocab:inputTo LowLevelDriverEnabler
]

instance InternalTempData2 : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from InternalSensor2"
    DTDFVocab:fromData InternalTempDataTx2
    DTDFVocab:inputTo LowLevelDriverEnabler
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Timestamped temperature reading from AmbientSensor"
    DTDFVocab:fromData AmbientTempDataTx
    DTDFVocab:inputTo LowLevelDriverEnabler
]

// Aggregate trace data for calibration
instance TemperatureTraceDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInternalSensor1, IncubatorInternalSensor2, IncubatorAmbientSensor
]

instance TemperatureTraceData : DTDFVocab:Data [
    base:desc "Historical temperature traces (all three sensors) used for model calibration"
    DTDFVocab:fromData TemperatureTraceDataTx
    DTDFVocab:inputTo CalibrationEngineEnabler
]

// =============================
// Acting Components (Physical)
// =============================

instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Surface heat source (heatbed) capable of ≤100 W, up to 4 A, switched via MOSFET on custom PCB"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V fan for air circulation with airflow ≈0.02 m³ s⁻¹, driven through MOSFET switches"
]

// =============================
// Enablers (Software / Middleware)
// =============================

instance LowLevelDriverEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level driver on Raspberry Pi that reads DS18S20 sensors and publishes messages to RabbitMQ"
    DTDFVocab:enables TemperatureMonitoringService, BangBangControlService, ParameterCalibrationService
]

instance RabbitMQBrokerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on the Raspberry Pi, mediating data flow between drivers and DT components"
    DTDFVocab:enables TemperatureMonitoringService, PredictiveSimulationService, ParameterCalibrationService, BangBangControlService
]

instance CalibrationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Python‑SciPy non‑linear least‑squares optimizer that calibrates thermal‑model parameters"
    DTDFVocab:enables ParameterCalibrationService
]

instance PredictiveSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Prediction engine that runs calibrated ModelA or ModelB to forecast box temperature"
    DTDFVocab:enables PredictiveSimulationService
]

instance BangBangControllerEnabler : DTDFVocab:Enabler [
    base:desc "Bang‑bang controller that decides heating or waiting periods based on temperature limits"
    DTDFVocab:enables BangBangControlService
]

// =============================
// Models (Physics‑Based)
// =============================

instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single thermal mass model with heat‑transfer coefficient G_box"
    DTDFVocab:inputTo PredictiveSimulationEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Two‑mass model (air and heatbed) with parameters C_air, C_heater, G_box, G_heater"
    DTDFVocab:inputTo PredictiveSimulationEnabler
]

// =============================
// Services (DT Capabilities)
// =============================

instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time temperature monitoring via streamed sensor data"
    DTDFVocab:provides TemperatureLimitViolationInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation of box temperature using calibrated ModelA or ModelB"
    DTDFVocab:provides PredictedTemperatureInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Automatic calibration of thermal‑model parameters using SciPy non‑linear least‑squares"
    DTDFVocab:provides CalibratedModelParametersInsight
]

instance BangBangControlService : DTDFVocab:Service [
    base:desc "Model‑based bang‑bang control that activates heating or waiting periods according to LL and UL"
    DTDFVocab:provides HeatingCommandAction, WaitingCommandAction
]

// =============================
// Insights & Actions (DT Output)
// =============================

instance TemperatureLimitViolationInsight : DTDFVocab:Insight [
    base:desc "Detected violation of lower (LL) or upper (UL) temperature limits, requiring operator attention"
]

instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Forecasted box temperature trajectory based on the selected thermal model"
]

instance CalibratedModelParametersInsight : DTDFVocab:Insight [
    base:desc "Updated set of calibrated parameters for ModelA/ModelB resulting from the calibration routine"
]

instance HeatingCommandAction : DTDFVocab:Action [
    base:desc "Command to activate the heatbed for a duration H when temperature  LL"
    DTDFVocab:IsAutomatic true
]

instance WaitingCommandAction : DTDFVocab:Action [
    base:desc "Command to deactivate heating (wait) for a duration C when temperature  UL"
    DTDFVocab:IsAutomatic true
]

// =============================
// Environment & Physical Components
// =============================

instance IncubatorBox : DTDFVocab:Component [
    base:desc "Insulated styrofoam container (~0.03 m³ volume) housing all internal components"
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B that runs the low‑level driver, RabbitMQ broker and DT software"
]

instance CustomPCBCircuit : DTDFVocab:Component [
    base:desc "PCB with MOSFET switches and optocouplers providing isolated power control to heatbed and fan"
]

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains IncubatorBox, RaspberryPiController, CustomPCBCircuit, HeatbedActuator, FanActuator,
                IncubatorInternalSensor1, IncubatorInternalSensor2, IncubatorAmbientSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands to the RabbitMQ server; the Raspberry Pi controller subscribes to these messages, interprets them, and drives the MOSFETs to turn the heatbed and fan on or off, thereby affecting the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture comprises the physical components (container, heatbed, fan, sensors, PCB, Raspberry Pi), a low‑level driver that reads sensors and publishes data, a RabbitMQ message broker mediating all PT↔DT messages, a controller module that subscribes to commands and implements the bang‑bang strategy, calibrated thermal models (Model A/B) used for simulation and prediction, and monitoring modules that evaluate safety constraints."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validity was examined through two experiments: (1) uniform temperature verification by comparing sensors at different locations with varied fan voltages (12 V vs 18 V) showing max temperature deviation of 7 °C and 6 °C respectively; (2) calibration using least‑squares fitting to minimise residual error between model output and measured data. Assumptions such as uniform air temperature, negligible wall heat storage, constant air specific heat, and ignored fan heat were explicitly stated and tested."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange between PT and DT is performed via a RabbitMQ message broker running on the Raspberry Pi, using standard AMQP messaging (implicit in RabbitMQ). The Raspberry Pi provides Wi‑Fi and Bluetooth connectivity for network access."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT components (RabbitMQ server, low‑level driver, controller, and calibration scripts) are hosted on the Raspberry Pi 4 Model B, which runs the full software stack. Source code and hardware schematics are publicly available in the GitHub repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the PT in a safe state during communication failures. The DT includes monitors that check temperature limits and can trigger safety alerts. Actuation signals are isolated via MOSFETs and optocouplers to prevent electrical hazards. No explicit cybersecurity standards are mentioned."
]