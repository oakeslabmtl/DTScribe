// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Surface heat source (214x214x3 mm) delivering up to 100W (100J/s) power controlled via MOSFETs and optocouplers to isolate Raspberry Pi GPIO signals. Used to heat air inside the styrofoam container."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12V/24V fan with 0.02 m³/s airflow for air circulation. Operates at variable voltages (tested at 12V and 18V) to adjust airflow strength and ensure uniform temperature distribution."
]

instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "Central controller executing bang-bang-like control strategy with configurable parameters (LL: Lower Limit, UL: Upper Limit, H: Heating Duration, C: Waiting Duration) to regulate heatbed and fan based on sensor feedback."
]

instance MosfetOptocouplerDriver : DTDFVocab:ActingComponent [
    base:desc "Decouples control signals from Raspberry Pi (limited to ~4A current) and safely drives the heatbed with isolated signals."
]

// C3: Physical Sensing Components
instance RoomTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer measuring ambient room temperature with ±0.5°C accuracy (range: -55°C to +125°C)."
]

instance InternalAirTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer measuring internal air temperature at a distinct position (hottest point) with ±0.5°C accuracy (range: -55°C to +125°C)."
]

instance InternalAirTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer measuring internal air temperature at a distinct position (coldest point) with ±0.5°C accuracy (range: -55°C to +125°C)."
]

instance LowLevelDriver : DTDFVocab:SensingComponent [
    base:desc "Periodically reads temperature data from DS18S20 sensors via 1-Wire bus and uploads to RabbitMQ communication server."
]

// C4: Physical-to-Virtual Interaction
instance RoomTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTemperatureSensor
]

instance InternalAirTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalAirTemperatureSensor1, InternalAirTemperatureSensor2
]

instance SensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LowLevelDriver
]

// C10: Models/Data
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Differential equation for air temperature (dT_bair/dt) with 2 free parameters (C_air, G_box), assuming all heat energy transfers directly to air. Simpler but less accurate for dynamic scenarios."
    DTDFVocab:inputTo PythonScipyEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Extended thermal model with 4 free parameters (C_air, G_box, C_heater, G_heater) accounting for heatbed thermal inertia. More accurate for thermal inertia predictions but computationally heavier."
    DTDFVocab:inputTo PythonScipyEnabler
]

instance TemperatureTrajectoryData : DTDFVocab:Data [
    base:desc "Time-series temperature readings (T1, T2, T3) with timestamps collected during heating/cooling experiments for model calibration."
    DTDFVocab:fromData SensorDataTransmitted
    DTDFVocab:inputTo PythonScipyEnabler
]

instance ActuatorLogData : DTDFVocab:Data [
    base:desc "Logs of heatbed power (V*I*Δt), fan voltage, and control states (ON/OFF) for real-time monitoring and offline analysis."
    DTDFVocab:fromData SensorDataTransmitted
    DTDFVocab:inputTo PythonScipyEnabler
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Room temperature (T_room) and external conditions (e.g., humidity) collected for contextual analysis."
    DTDFVocab:fromData RoomTemperatureDataTransmitted
    DTDFVocab:inputTo PythonScipyEnabler
]

// C11: Enablers
instance PythonScipyEnabler : DTDFVocab:Enabler [
    base:desc "Python Scipy library used for non-linear least squares optimization (least_squares) to calibrate model parameters by minimizing residual error between simulated and measured temperature trajectories."
    DTDFVocab:enables ModelCalibrationService, TemperaturePredictionService
]

instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "Open-source message broker facilitating asynchronous communication between Physical Twin (sensors/actuators) and Digital Twin (models/algorithms) via RabbitMQ queues."
    DTDFVocab:enables DataTransmissionService, StateSynchronizationService
]

instance BangBangControllerEnabler : DTDFVocab:Enabler [
    base:desc "Statechart-based bang-bang controller implementing configurable parameters (LL, UL, H, C) for temperature regulation with ON/OFF actuation logic."
    DTDFVocab:enables ControllerTuningService
]

// C6: Services
instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Uses calibrated dynamic models (Model A with 2 parameters: C_air, G_box Model B with 4 parameters: C_heater, C_air, G_heater, G_box) to predict internal air temperature and heatbed thermal inertia."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Employs non-linear least squares solver to calibrate model parameters by minimizing residual error between simulated and measured temperature trajectories."
    DTDFVocab:provides ModelSelectionInsight, ParameterOptimizationAction
]

instance UniformityValidationService : DTDFVocab:Service [
    base:desc "Assesses temperature distribution inside the box via experimental data (e.g., max discrepancy of 7°C with 12V fan, reduced to 6°C with 18V fan)."
    DTDFVocab:provides UniformityAnalysisInsight
]

instance ControllerTuningService : DTDFVocab:Service [
    base:desc "Optimizes controller parameters (LL, UL, H, C) to improve temperature regulation performance based on model predictions and real-world data."
    DTDFVocab:provides ControllerParameterOptimizationAction
]

instance DataVisualizationService : DTDFVocab:Service [
    base:desc "Facilitates analysis of experimental results (e.g., temperature vs. time plots, power input curves) to validate assumptions (e.g., uniform temperature distribution)."
    DTDFVocab:provides DataVisualizationInsight
]

instance DataTransmissionService : DTDFVocab:Service [
    base:desc "Transmits sensor data from Physical Twin to Digital Twin via RabbitMQ queues for real-time processing."
    DTDFVocab:provides DataTransmissionAction
]

instance StateSynchronizationService : DTDFVocab:Service [
    base:desc "Mirrors Physical Twin's operational state (e.g., heatbed/fan status) back to Digital Twin via RabbitMQ for synchronization."
    DTDFVocab:provides StateSynchronizationAction
]

// C17: Insights/Actions
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Provides real-time and predictive temperature trajectories inside the incubator based on calibrated Model B (4 parameters) for superior thermal inertia prediction."
]

instance ModelSelectionInsight : DTDFVocab:Insight [
    base:desc "Validates Model B as the preferred model for thermal inertia prediction due to its superior accuracy in dynamic scenarios compared to Model A."
]

instance UniformityAnalysisInsight : DTDFVocab:Insight [
    base:desc "Identifies temperature gradients (e.g., 7°C discrepancy at 12V fan) to inform fan voltage adjustments for improved uniformity."
]

instance ControllerParameterOptimizationAction : DTDFVocab:Action [
    base:desc "Automatically tunes controller parameters (LL, UL, H, C) to achieve optimal temperature regulation performance."
    DTDFVocab:IsAutomatic true
]

instance DataTransmissionAction : DTDFVocab:Action [
    base:desc "Periodically transmits sensor data from Physical Twin to Digital Twin via RabbitMQ queues."
    DTDFVocab:IsAutomatic true
]

instance StateSynchronizationAction : DTDFVocab:Action [
    base:desc "Synchronizes control states (heatbed/fan status) between Physical Twin and Digital Twin."
    DTDFVocab:IsAutomatic true
]

instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Provides visual analysis of experimental results (e.g., temperature vs. time plots) to validate model assumptions and system performance."
]

instance ParameterOptimizationAction : DTDFVocab:Action [
    base:desc "Optimizes model parameters (C_air, G_box, C_heater, G_heater) via non-linear least squares to minimize prediction error."
    DTDFVocab:IsAutomatic true
]

