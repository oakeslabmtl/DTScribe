// ---------------------------------------------------
// C3: Physical sensing components
// ---------------------------------------------------
instance InternalTempSensorBox1 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor #1 placed inside the incubator air space (°C)"
    DTDFVocab:producedData TempDataTransmittedBox1
]

instance InternalTempSensorBox2 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor #2 placed inside the incubator air space (°C)"
    DTDFVocab:producedData TempDataTransmittedBox2
]

instance ExternalTempSensorRoom : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor monitoring ambient room temperature (°C)"
    DTDFVocab:producedData TempDataTransmittedRoom
]

// ---------------------------------------------------
// C4: Physical-to-virtual interaction (DataTransmitted)
// ---------------------------------------------------
instance TempDataTransmittedBox1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorBox1
]

instance TempDataTransmittedBox2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorBox2
]

instance TempDataTransmittedRoom : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensorRoom
]

// ---------------------------------------------------
// C10: Data (temperature readings)
// ---------------------------------------------------
instance TemperatureDataBox1 : DTDFVocab:Data [
    base:desc "Temperature reading in °C from internal sensor #1"
    DTDFVocab:fromData TempDataTransmittedBox1
    DTDFVocab:inputTo TimeSeriesDatabase, CalibrationAlgorithm,
                 KalmanFilterComponent, CoSimulationEngine,
                 SelfAdaptationLoop
]

instance TemperatureDataBox2 : DTDFVocab:Data [
    base:desc "Temperature reading in °C from internal sensor #2"
    DTDFVocab:fromData TempDataTransmittedBox2
    DTDFVocab:inputTo TimeSeriesDatabase, CalibrationAlgorithm,
                 KalmanFilterComponent, CoSimulationEngine,
                 SelfAdaptationLoop
]

instance TemperatureDataRoom : DTDFVocab:Data [
    base:desc "Ambient room temperature reading in °C from external sensor"
    DTDFVocab:fromData TempDataTransmittedRoom
    DTDFVocab:inputTo TimeSeriesDatabase, CalibrationAlgorithm,
                 KalmanFilterComponent, CoSimulationEngine,
                 SelfAdaptationLoop
]

// ---------------------------------------------------
// C2: Acting components (actuators)
// ---------------------------------------------------
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heating element (heat‑bed) that provides thermal energy"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Air circulation fan that distributes warm air inside the insulated box"
]

// ---------------------------------------------------
// C11: Enablers (software/hardware infrastructure)
// ---------------------------------------------------
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker mediates AMQP (TCP) messages between DT components"
]

instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Low‑level driver abstracts sensor/actuator I/O and publishes/subscribes via RabbitMQ"
]

instance TimeSeriesDatabase : DTDFVocab:Enabler [
    base:desc "Time‑series database storing temperature streams for real‑time dashboards"
    DTDFVocab:enables VisualizationService
]

instance DashboardComponent : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard visualising temperature and controller state"
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Algorithm that updates parameters of ModelA and ModelB on‑demand"
    DTDFVocab:enables CalibrationService
]

instance KalmanFilterComponent : DTDFVocab:Enabler [
    base:desc "Kalman filter fuses ModelB predictions with measurements for heat‑bed state estimation and anomaly detection"
    DTDFVocab:enables AnomalyDetectionService
]

instance CoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation engine runs what‑if scenarios using historical or live PT data"
    DTDFVocab:enables PredictiveSimulationService
]

instance SelfAdaptationLoop : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop detects behavioural changes, schedules experiments, and orchestrates re‑calibration & optimisation"
    DTDFVocab:enables SelfAdaptationService
]

instance OptimisationEngine : DTDFVocab:Enabler [
    base:desc "Optimization engine searches for optimal bang‑bang controller parameters"
]

instance ControllerComponent : DTDFVocab:Enabler [
    base:desc "Bang‑bang controller on Raspberry Pi that issues heat‑bed and fan commands"
]

// ---------------------------------------------------
// C10: Models (analytical)
// ---------------------------------------------------
instance ModelA : DTDFVocab:Model [
    base:desc "Analytical temperature dynamics model based on heat‑transfer equations (uniform air, no wall storage, constant specific heat)"
    DTDFVocab:inputTo CalibrationAlgorithm, KalmanFilterComponent, CoSimulationEngine
]

instance ModelB : DTDFVocab:Model [
    base:desc "Enhanced analytical model including heat‑bed thermal inertia; preferred for higher fidelity"
    DTDFVocab:inputTo CalibrationAlgorithm, KalmanFilterComponent, CoSimulationEngine
]

// ---------------------------------------------------
// C6: Services (digital twin capabilities)
// ---------------------------------------------------
instance VisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization of incubator temperature and controller status via dashboard"
    DTDFVocab:provides RealTimeTemperatureInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "On‑demand calibration of ModelA and ModelB using latest sensor data"
    DTDFVocab:provides CalibrationInsight, TriggerCalibrationAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Anomaly detection and heat‑bed state estimation through Kalman filtering"
    DTDFVocab:provides AnomalyInsight, UpdateControllerParametersAction
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "What‑if predictive simulations combining models with PT data to evaluate alternative control settings"
    DTDFVocab:provides WhatIfInsight, RunOptimizationAction
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Self‑adaptation loop that auto‑triggers experiments, re‑calibrates, optimises and re‑configures the controller"
    DTDFVocab:provides AdaptiveControlInsight, ReconfigureActuatorAction
]

// ---------------------------------------------------
// C17: Insights
// ---------------------------------------------------
instance RealTimeTemperatureInsight : DTDFVocab:Insight [
    base:desc "Current temperature profile inside the incubator and ambient conditions"
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Result of parameter update for ModelA/ModelB (e.g., reduced prediction error)"
]

instance AnomalyInsight : DTDFVocab:Insight [
    base:desc "Detected deviation from expected temperature dynamics indicating possible fault"
]

instance WhatIfInsight : DTDFVocab:Insight [
    base:desc "Projected temperature trajectories under alternative controller configurations"
]

instance AdaptiveControlInsight : DTDFVocab:Insight [
    base:desc "Decision that the controller parameters have been re‑tuned to maintain target temperature"
]

// ---------------------------------------------------
// C17: Actions
// ---------------------------------------------------
instance TriggerCalibrationAction : DTDFVocab:Action [
    base:desc "User‑initiated trigger to start model calibration"
    DTDFVocab:IsAutomatic false
]

instance UpdateControllerParametersAction : DTDFVocab:Action [
    base:desc "Automatic update of bang‑bang controller limits based on Kalman filter feedback"
    DTDFVocab:IsAutomatic true
]

instance RunOptimizationAction : DTDFVocab:Action [
    base:desc "Execute optimisation routine to find optimal heating duration (H) and waiting duration (C)"
    DTDFVocab:IsAutomatic true
]

instance ReconfigureActuatorAction : DTDFVocab:Action [
    base:desc "Re‑configure heat‑bed and fan actuation commands according to new controller settings"
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT issues actuation commands (e.g., turn heat‑bed on/off, set heating duration, activate fan) by publishing command messages to RabbitMQ. The controller on the Raspberry Pi subscribes to these command topics, validates the payload against expected formats (temperature limits, heating/waiting durations), and forwards the resulting control signals to the hardware drivers that drive the heat‑bed and fan. After execution the controller publishes status updates back to RabbitMQ, allowing the DT to confirm command execution."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The incubator Digital Twin is orchestrated around a RabbitMQ message broker that synchronises the physical twin (PT) components—the low‑level driver that reads sensor data and issues actuator commands—and the cyber components such as the controller, calibration service, Kalman‑filter based anomaly detector, co‑simulation engine, and visualization dashboard. All cyber services subscribe to the same RabbitMQ topics, allowing a loosely‑coupled, publish‑subscribe architecture where data flows from the PT to a time‑series database for real‑time visualisation and to analysis services. The DT components operate as independent processes that consume the same streams of measurement and command messages, providing a centralized coordination point (the broker) without a single monolithic application. This constitutes the system‑wide coordination and resource management pattern described in the documents."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing Model A (simpler) and Model B (includes heat‑bed inertia); experimental results (section 4) show Model B yields higher prediction accuracy for thermal dynamics. Model validity is ensured through on‑demand calibration that updates model parameters using observed sensor data, and through Kalman‑filter‑based state estimation that detects anomalies. Uncertainties stem from modeling assumptions (uniform temperature distribution, negligible wall heat storage, constant specific heat capacity, and power‑to‑heat conversion). Validation is performed via empirical experiments and calibration results (Figure 13). Errors are identified by the anomaly detection module, and model updates are performed to maintain accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "All components of the incubator DT are interconnected through a RabbitMQ message broker deployed on‑premise (or in the cloud). Communication uses RabbitMQ’s AMQP protocol over TCP/IP, forming a star‑like topology where the Raspberry Pi (low‑level driver and controller) and DT services are clients that publish/subscribe to the broker. RabbitMQ provides message persistence and acknowledgement, offering reliable delivery with low latency suitable for near‑real‑time control. Security is handled by RabbitMQ’s built‑in authentication (username/password), though specific mechanisms are not detailed in the documents."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin implementation for the incubator incorporates safety measures through a 'safe protocol' embedded in the low‑level driver, which continuously monitors temperature readings and command messages to ensure the physical twin remains in a safe state before issuing actuator commands. Communication between the Raspberry Pi controller and the physical twin is mediated by a RabbitMQ message broker, providing reliable message passing; however, the documents do not detail authentication, encryption, or access‑control mechanisms, so only the presence of the safe protocol and the use of RabbitMQ are documented safety‑related aspects."
]