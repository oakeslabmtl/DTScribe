// C3: Physical sensing components
instance WheelContactSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor measuring wheel contact forces and slip rates, deployed on the vehicle’s wheels."
    DTDFVocab:producedData WheelContactDataT
]

instance ChassisAccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor capturing chassis acceleration time‑series data, deployed on the vehicle’s chassis."
    DTDFVocab:producedData ChassisAccelerationDataT
]

// C4: Physical-to-virtual interaction
instance WheelContactDataT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelContactSensor
]

instance ChassisAccelerationDataT : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChassisAccelerationSensor
]

// C10: Models/Data
instance WheelContactData : DTDFVocab:Data [
    base:desc "Time‑series measurements of wheel contact forces and slip rates."
    DTDFVocab:inputTo CalibrationEnabler, FaultDetectionEnabler, SupervisoryControlEnabler, OptimizationEnabler
    DTDFVocab:fromData WheelContactDataT
]

instance ChassisAccelerationData : DTDFVocab:Data [
    base:desc "Time‑series of chassis acceleration readings."
    DTDFVocab:inputTo CalibrationEnabler, FaultDetectionEnabler, SupervisoryControlEnabler, OptimizationEnabler
    DTDFVocab:fromData ChassisAccelerationDataT
]

instance GeometricModel : DTDFVocab:Model [
    base:desc "Geometric model derived from CAD artefacts representing wheel and chassis geometry."
    DTDFVocab:inputTo CalibrationEnabler
]

instance DynamicBehaviorModel : DTDFVocab:Model [
    base:desc "Differential‑equation based model capturing dynamic vehicle response."
    DTDFVocab:inputTo CalibrationEnabler
]

instance SupervisoryModel : DTDFVocab:Model [
    base:desc "Supervisory model that interfaces between the physical twin and its environment."
    DTDFVocab:inputTo CalibrationEnabler
]

// C11: Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Subsystem that calibrates analytic models using sensor data."
    DTDFVocab:enables CalibrationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that feeds data to fault detection algorithms."
    DTDFVocab:enables FaultDetectionService
]

instance SupervisoryControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that passes data and model outputs to supervisory control."
    DTDFVocab:enables SupervisoryControlService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that provides data to optimization algorithms."
    DTDFVocab:enables OptimizationService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that performs model calibration and refines parameters."
    DTDFVocab:provides CalibrationInsight, ParameterAdjustmentAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service that detects safety violations and anomalies."
    DTDFVocab:provides SafetyViolationInsight, CorrectiveAction
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Service that enacts corrective actions based on supervisory model."
    DTDFVocab:provides SupervisoryControlAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that generates optimization recommendations."
    DTDFVocab:provides PerformanceImprovementInsight, OptimizationRecommendationAction
]

// C17: Insights/Actions
instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating refined model parameters after calibration."
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of safety violations due to anomalies in sensor data."
]

instance PerformanceImprovementInsight : DTDFVocab:Insight [
    base:desc "Insight into operational efficiency improvements from optimization."
]

instance ParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of model parameters to align with observed data."
    DTDFVocab:IsAutomatic true
]

instance CorrectiveAction : DTDFVocab:Action [
    base:desc "Corrective action to mitigate detected safety violations."
    DTDFVocab:IsAutomatic true
]

instance SupervisoryControlAction : DTDFVocab:Action [
    base:desc "Control commands generated by the supervisory controller."
    DTDFVocab:IsAutomatic true
]

instance OptimizationRecommendationAction : DTDFVocab:Action [
    base:desc "Recommendation to improve operational efficiency."
    DTDFVocab:IsAutomatic false
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin orchestrates data acquisition via sensors, model calibration, monitoring, and optimisation within a single framework. It integrates modelling, simulation, monitoring, and optimisation technologies, where calibration algorithms update the models of the cyber‑physical system and its environment with the best‑estimate parameters, and the resulting data informs safety and performance monitors."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The document specifies that calibration algorithms are employed to update the models with the best‑estimate parameters, ensuring the fidelity of the computational representation. Model updates are monitored for violations of safety and performance constraints; any deviation triggers an alert that can lead to corrective action. Although detailed verification or uncertainty quantification methods are not explicitly described, the DT relies on this continuous monitoring loop to maintain validity, with human or automated decision logic that can modify the Physical Twin in response to detected failures. Quality assurance is implied through the integration of sensor‑derived data, calibration, and monitoring steps that collectively maintain model integrity and system safety."
]