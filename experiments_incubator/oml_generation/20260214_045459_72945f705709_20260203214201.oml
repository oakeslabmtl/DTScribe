// Physical Sensing Components
instance InteriorTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer measuring interior temperature (sensor 1)."
    DTDFVocab:producedData InteriorTempDataTransmitted1
]

instance InteriorTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer measuring interior temperature (sensor 2)."
    DTDFVocab:producedData InteriorTempDataTransmitted2
]

instance ExteriorTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer measuring exterior (room) temperature."
    DTDFVocab:producedData ExteriorTempDataTransmitted
]

// Data Transmitted (RabbitMQ Message) Instances
instance InteriorTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTempSensor1
]

instance InteriorTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTempSensor2
]

instance ExteriorTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExteriorTempSensor
]

// Data Instances (Time‑Stamped Temperature Records)
instance InteriorTempData1 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature record from InteriorTempSensor1."
    DTDFVocab:inputTo SciPyRuntimeEnabler
    DTDFVocab:fromData InteriorTempDataTransmitted1
]

instance InteriorTempData2 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature record from InteriorTempSensor2."
    DTDFVocab:inputTo SciPyRuntimeEnabler
    DTDFVocab:fromData InteriorTempDataTransmitted2
]

instance ExteriorTempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature record from ExteriorTempSensor."
    DTDFVocab:inputTo SciPyRuntimeEnabler
    DTDFVocab:fromData ExteriorTempDataTransmitted
]

// Enablers
instance SciPyRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime utilizing SciPy for nonlinear least‑squares calibration and physics‑based temperature simulations."
    DTDFVocab:enables TemperatureSimulationService, ParameterEstimationService
]

// Models
instance DynAModel : DTDFVocab:Model [
    base:desc "Two‑parameter physics‑based temperature model (DynA) describing temperature evolution in the box and heatbed; parameters: C_air, G_box."
    DTDFVocab:inputTo SciPyRuntimeEnabler
]

instance DynBModel : DTDFVocab:Model [
    base:desc "Four‑parameter physics‑based temperature model (DynB) describing temperature evolution in the box and heatbed; parameters: C_air, G_box, C_heater, G_heater."
    DTDFVocab:inputTo SciPyRuntimeEnabler
]

// Services
instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Service providing short‑term inside‑box temperature trajectory predictions using DynA and DynB models."
    DTDFVocab:provides PredictedTemperatureTrajectoryInsight
]

instance ParameterEstimationService : DTDFVocab:Service [
    base:desc "Service performing nonlinear least‑squares calibration of model parameters using SciPy."
    DTDFVocab:provides CalibratedParametersInsight
]

// Insights
instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Calibrated values for C_air, G_box, C_heater, and G_heater derived from experimental data."
]

instance PredictedTemperatureTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory for the incubation environment based on calibrated models."
]

// Actions
instance OptimizeHeatingScheduleAction : DTDFVocab:Action [
    base:desc "Automated optimization of heater activation schedule to maintain target temperature."
    DTDFVocab:IsAutomatic false
]

// Physical Acting Components
instance HeatbedHeaterActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heater plate (heatbed) controlled by MOSFET drivers and optocouplers."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V or 24 V fan actuator used to circulate air within the incubator."
]

// Physical Component Hardware
instance DS18S20SensorHardware : DTDFVocab:Component [
    base:desc "DS18S20 digital thermometer hardware."
]

instance HeatbedHeaterHardware : DTDFVocab:Component [
    base:desc "Electrical heater plate hardware."
]

instance FanMotorHardware : DTDFVocab:Component [
    base:desc "12 V/24 V fan motor hardware."
]

instance RaspberryPiHardware : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B controller hardware."
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains DS18S20SensorHardware, HeatbedHeaterHardware, FanMotorHardware, RaspberryPiHardware
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control messages (heatbed on/off, fan on/off) through the RabbitMQ server to the Raspberry Pi’s controller, which actuates the MOSFET‑driven heatbed and fan. Outputs include heating duration commands and waiting duration commands derived from the bang‑bang logic."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data exchange and control; the low‑level driver samples sensors on a few‑second interval, while the continuous‑time differential‑equation models represent the thermal dynamics. DT computations run on the Raspberry Pi in real time, synchronized with PT operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An integrated stack consisting of the physical hardware (box, heatbed, fan, sensors), the Raspberry Pi controller, the RabbitMQ communication layer, the low‑level driver, the high‑level bang‑bang controller, and the DT models and simulation components, all orchestrated within a single embedded environment."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Operated stage – the Digital Twin is deployed during operation of the thermal incubator for monitoring, control, and calibration. Design and manufacturing stages are not covered."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model assumptions such as uniform temperature distribution, negligible heat storage in walls, constant specific heat capacity, and negligible fan heat contribution were validated experimentally. Calibration minimizes residual error against real temperature trajectories. Sensor accuracy (±0.5 °C) and the limited number of sensors introduce uncertainty in state estimation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "RabbitMQ broker running on the Raspberry Pi, communicating via AMQP over the local network. Sensor data is transmitted over the 1‑Wire bus to the Raspberry Pi; control commands are published back over RabbitMQ. The Pi’s built‑in Wi‑Fi/Bluetooth provide optional external connectivity."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT components and models run directly on the Raspberry Pi 4 B, which acts as both controller hardware and hosting platform. The system is deployed locally, open‑source, and can be redeployed on any compatible embedded Linux device."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safety protocol within the low‑level driver ensures that the system is placed in a safe state during exceptions; however, specific cybersecurity measures or safety certifications are not detailed in the document."
]