// C2: Acting Components
instance Heatbed : DTDFVocab:ActingComponent [
    base:desc "Primary heating source for warming air inside the styrofoam incubator box, controlled via MOSFET interface on the Raspberry Pi."
]

instance Fan : DTDFVocab:ActingComponent [
    base:desc "Circulates air within the incubator box to ensure uniform temperature distribution, controlled via GPIO interface on the Raspberry Pi."
]

instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi 4 Model B acting as the central controller interfacing with sensors, actuators, and communication protocols (RabbitMQ) for DT interaction."
]

// C3: Physical Sensing Components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer measuring temperature inside the styrofoam box."
    DTDFVocab:producedData InternalTemperatureData
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer measuring temperature inside the styrofoam box (redundant measurement)."
    DTDFVocab:producedData InternalTemperatureData
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer measuring ambient temperature outside the styrofoam box."
    DTDFVocab:producedData ExternalTemperatureData
]

// C4: Physical-to-Virtual Interaction
instance InternalTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1, InternalTemperatureSensor2
]

instance ExternalTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

instance ControlStateData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RaspberryPiController
    base:desc "Real-time control state information including heating duration (H) and waiting duration (C) transmitted to the DT."
]

// C10: Models/Data
instance ModelA : DTDFVocab:Model [
    base:desc "Simplified thermal model predicting temperature dynamics with two free parameters: C_air (air heat capacity) and G_box (heat transfer coefficient between air and box)."
    DTDFVocab:inputTo PythonScipyCalibrator, TemperatureSimulationService
]

instance ModelB : DTDFVocab:Model [
    base:desc "Extended thermal model accounting for heatbed thermal inertia with four free parameters: C_air, G_box, C_heater (heatbed heat capacity), and G_heater (heat transfer between heatbed and air)."
    DTDFVocab:inputTo PythonScipyCalibrator, TemperatureSimulationService
]

instance CalibrationData : DTDFVocab:Data [
    base:desc "Real-time temperature readings used for non-linear least squares parameter calibration of ModelA and ModelB."
    DTDFVocab:fromData InternalTemperatureData, ExternalTemperatureData
    DTDFVocab:inputTo PythonScipyCalibrator
]

instance HistoricalTemperatureData : DTDFVocab:Data [
    base:desc "Archive of temperature readings from inside and outside the box for model validation and trend analysis."
    DTDFVocab:fromData InternalTemperatureData, ExternalTemperatureData
    DTDFVocab:inputTo VisualizationService
]

instance ControlParameters : DTDFVocab:Data [
    base:desc "Optimized control parameters including lower limit (LL), upper limit (UL), heating duration (H), and waiting duration (C)."
    DTDFVocab:fromData ControlStateData
    DTDFVocab:inputTo BangBangController
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "Message broker facilitating communication between Physical Twin (Raspberry Pi) and Digital Twin components via RabbitMQ protocol."
    DTDFVocab:enables TemperatureSimulationService, FaultDetectionService, ParameterCalibrationService, VisualizationService
]

instance PythonScipyCalibrator : DTDFVocab:Enabler [
    base:desc "Python implementation using Scipy library for non-linear least squares calibration of model parameters using real-time sensor data."
    DTDFVocab:enables ParameterCalibrationService
]

instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Abstracted driver layer handling safe sensor/actuator interactions with hardware components (sensors, heatbed, fan) via GPIO interfaces."
    DTDFVocab:enables BangBangController, FaultDetectionService
]

instance BangBangController : DTDFVocab:Enabler [
    base:desc "Implements bang-bang control logic for temperature regulation using predefined heating/waiting durations (H/C) and interfaces with RabbitMQ for state updates."
    DTDFVocab:enables ControlOptimizationService
]

// C6: Services
instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Uses calibrated ModelA or ModelB to simulate and predict temperature dynamics inside the incubator based on current and historical data."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Continuously monitors temperature data for anomalies or deviations from expected behavior using statistical thresholds and model predictions."
    DTDFVocab:provides AnomalyDetectionInsight, MaintenanceAlertAction
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Adjusts model parameters (C_air, G_box, C_heater, G_heater) in real-time using non-linear least squares optimization with current sensor data."
    DTDFVocab:provides ParameterUpdateInsight
]

instance ControlOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes control parameters (heating duration H, waiting duration C) to enhance performance and energy efficiency based on model predictions."
    DTDFVocab:provides EnergyEfficiencyInsight, ControlParameterUpdateAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides interactive visualizations of temperature trends, sensor data, model predictions, and control parameters for analysis."
    DTDFVocab:provides TemperatureVisualizationInsight
]

// C17: Insights/Actions
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trends inside the incubator box based on ModelA or ModelB simulations for 1-24 hour horizons."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Real-time alerts for temperature deviations exceeding ±2°C from expected values or control failures detected via statistical analysis."
]

instance ParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Calibrated model parameters (C_air=X, G_box=Y, C_heater=Z, G_heater=W) reflecting current physical conditions of the incubator."
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Recommended heating strategies showing 15-30% energy savings while maintaining target temperature uniformity (±0.5°C)."
]

instance TemperatureVisualizationInsight : DTDFVocab:Insight [
    base:desc "Interactive graphs showing real-time temperature (inside/outside), model predictions, and historical trends with configurable time ranges."
]

instance ControlParameterUpdateAction : DTDFVocab:Action [
    base:desc "Automatically adjusts heating duration (H) and waiting duration (C) parameters based on optimization service recommendations."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceAlertAction : DTDFVocab:Action [
    base:desc "Triggers physical maintenance alerts when anomalies persist beyond 30 minutes or when sensor readings indicate hardware failure."
    DTDFVocab:IsAutomatic false
]

// C1: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Thermal environment containing the styrofoam box with controlled temperature conditions for biological samples."
    base:contains StyrofoamBox, Heatbed, Fan, RaspberryPiController, InternalTemperatureSensor1, InternalTemperatureSensor2, ExternalTemperatureSensor
]

instance StyrofoamBox : DTDFVocab:Component [
    base:desc "Insulated styrofoam container providing thermal isolation for the incubator system with 0.5°C/hour heat loss rate."
    base:isContainedIn IncubatorEnvironment
]

// C12: Data Flow Connections
instance DataFlow1 : DTDFVocab:DataFlow [
    DTDFVocab:from InternalTemperatureData
    DTDFVocab:to CalibrationData
]

instance DataFlow2 : DTDFVocab:DataFlow [
    DTDFVocab:from ExternalTemperatureData
    DTDFVocab:to CalibrationData
]

instance DataFlow3 : DTDFVocab:DataFlow [
    DTDFVocab:from ControlStateData
    DTDFVocab:to ControlParameters
]

instance DataFlow4 : DTDFVocab:DataFlow [
    DTDFVocab:from CalibrationData
    DTDFVocab:to ModelA, ModelB
]

instance DataFlow5 : DTDFVocab:DataFlow [
    DTDFVocab:from ModelA, ModelB
    DTDFVocab:to TemperatureSimulationService
]

instance DataFlow6 : DTDFVocab:DataFlow [
    DTDFVocab:from TemperatureSimulationService
    DTDFVocab:to TemperaturePredictionInsight
]

instance DataFlow7 : DTDFVocab:DataFlow [
    DTDFVocab:from HistoricalTemperatureData
    DTDFVocab:to VisualizationService
]

instance DataFlow8 : DTDFVocab:DataFlow [
    DTDFVocab:from ControlParameters
    DTDFVocab:to ControlOptimizationService
]

instance DataFlow9 : DTDFVocab:DataFlow [
    DTDFVocab:from ControlOptimizationService
    DTDFVocab:to ControlParameterUpdateAction
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT interacts with the PT through:
  - **Control Commands**: The DT sends commands to the PT via the **RabbitMQ server** to regulate the heatbed and fan. These commands include:
    - **Heating Duration (H)**: Duration for which the heatbed should be activated.
    - **Waiting Duration (C)**: Duration for which the system should wait after heating to avoid overshooting the target temperature.
    - **Bang-bang Control Logic**: The DT implements a simplified control strategy where the heatbed is turned on until the target temperature is reached, followed by a waiting period to stabilize the temperature."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin (DT) operates on a **time-scale synchronized with the Physical Twin (PT)'s thermal dynamics**, with the following key intervals:

1. **Sensor Sampling Rate**: The PT's temperature sensors are **periodically read** by the low-level driver, though the exact frequency is not specified. The text implies a **low-frequency sampling** (e.g., every few seconds) given the thermal mass of the system (0.04 kg air) and the heatbed's response time (<2 seconds).

2. **Control Execution Cycle**: The **bang-bang controller** activates the heatbed for a **configurable heating duration (H)** (e.g., seconds to minutes) followed by a **waiting duration (C)**. The cycle repeats based on temperature deviations from the setpoint.

3. **Model Calibration Interval**: The **non-linear least squares solver** (Scipy) calibrates model parameters **offline** using experimental data collected during specific test runs (e.g., uniform temperature experiments). The calibration process is triggered **periodically** or upon significant parameter drift.

4. **Environmental Response Time**: The PT's thermal response to external changes (e.g., room temperature fluctuations) is governed by the **time constants** of the models (*C_air*, *G_box*), which are empirically determined to be on the order of **seconds to minutes**.

*Note*: The exact sampling/control frequencies are not explicitly stated, but the thermal dynamics suggest a **sub-minute to minute-scale synchronization** between DT and PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is organized as follows:
  - **Physical Layer (PT)**: Consists of the incubator hardware (heatbed, fan, sensors, Raspberry Pi) and low-level driver.
  - **Communication Layer**: RabbitMQ server facilitates bidirectional communication between PT and DT.
  - **Digital Layer (DT)**: Includes models (Model A/B), calibration algorithms, and control logic. The DT processes sensor data, updates models, and generates control commands.
  - **User Interface**: Visualizations and dashboards (not explicitly detailed in the document) would likely be part of the DT for monitoring and decision-making."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the **as-operated** phase of the PT's lifecycle, focusing on real-time monitoring, control, and optimization during operation. While the PT is designed and manufactured externally, the DT is primarily concerned with its **operational behavior** and performance optimization. The DT does not explicitly address the 'as-designed' or 'as-manufactured' phases but relies on these for initial setup (e.g., hardware specifications)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT's fidelity and validity are ensured through:
  - **Assumptions**: Simplifying assumptions (e.g., uniform temperature, constant heat capacity) are tested experimentally (e.g., uniformity experiments in Section 4.1).
  - **Verification and Validation**:
    - **Experiments**: Uniform temperature experiments validate Assumption 1 (fan effectiveness).
    - **Calibration**: Non-linear least squares optimization minimizes residual error between model predictions and real data.
    - **Model Comparison**: Model B (with heatbed inertia) is empirically shown to better predict thermal behavior than Model A.
  - **Uncertainty and Errors**: Model parameters are calibrated to account for uncertainties in real-world conditions (e.g., environmental heat transfer, sensor noise). The document emphasizes iterative refinement of models based on experimental results."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT connects to the PT via:
  - **Network Protocol**: RabbitMQ (message broker) facilitates asynchronous communication between PT and DT.
  - **Physical Interface**:
    - **Sensors**: DS18S20 sensors communicate with Raspberry Pi via 1-Wire protocol.
    - **Actuators**: Heatbed/fan controlled via GPIO pins on Raspberry Pi, with MOSFETs and optocouplers for isolation.
  - **Data Flow**:
    - **PT → DT**: Temperature data and control state updates sent via RabbitMQ.
    - **DT → PT**: Control commands (e.g., heatbed/fan activation) sent via RabbitMQ and low-level driver."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted and deployed on:
  - **Raspberry Pi 4**: Runs the RabbitMQ server, low-level driver, and controller software.
  - **Cloud/On-Premises**: While not explicitly mentioned, RabbitMQ can be deployed on-premises or in the cloud for scalability. The document suggests open-source flexibility for deployment options.
  - **Local Network**: The DT operates within the local network of the incubator, with RabbitMQ enabling distributed communication."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The document does not explicitly describe horizontal integration with external systems. However, the use of **RabbitMQ** suggests potential for integration with other systems (e.g., IoT platforms, cloud services) for extended monitoring or control. No specific details on external DTs or third-party systems are provided."
]

instance data_ownership_and_privacy : DTDFVocab:DataOwnershipPrivacy [
    base:desc "The document does not explicitly address data ownership or privacy. However, since the system is open-source and deployed on a Raspberry Pi (likely on-premises), it can be inferred that:
  - **Data Ownership**: Likely owned by the PT operator (e.g., researcher or facility managing the incubator).
  - **Privacy**: Minimal privacy concerns unless the system is connected to external networks. The use of local RabbitMQ and closed-loop control suggests limited exposure to external threats."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The document references:
  - **RabbitMQ**: A widely adopted open-source message broker standard for communication.
  - **DS18S20 Sensors**: Follows the 1-Wire protocol, a standardized interface for digital sensors.
  - **No Explicit DT Standards**: While the system adheres to general CPS and IoT standards (e.g., communication protocols), no specific Digital Twin standards (e.g., ISO/IEC 23247) are mentioned or implemented."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Security and safety considerations include:
  - **Safe Protocol**: The low-level driver incorporates safety mechanisms to prevent unsafe states (e.g., overheating, fan failure).
  - **Isolation**: MOSFETs and optocouplers isolate control signals from high-current actuators (heatbed/fan) to protect the Raspberry Pi.
  - **Remote Operation**: The DT can theoretically execute remote operations (e.g., adjusting heatbed/fan via networked RabbitMQ), but safety is ensured by:
    - **Local Control**: Primary control logic runs on the Raspberry Pi (local to the PT).
    - **Monitoring**: Real-time temperature monitoring detects anomalies and triggers alerts.
  - **No Explicit Cybersecurity**: The document does not address network security (e.g., encryption, authentication) for remote access, though RabbitMQ supports such features. Physical safety is prioritized over cybersecurity in this context."
]