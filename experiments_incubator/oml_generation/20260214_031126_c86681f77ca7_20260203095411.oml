// ========================
// Physical Sensing Components
// ========================
instance BoxTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor mounted inside the incubator box (sensor 1)."
    DTDFVocab:producedData TemperatureDataStream
]

instance BoxTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor mounted inside the incubator box (sensor 2)."
    DTDFVocab:producedData TemperatureDataStream
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire temperature sensor measuring ambient room temperature."
    DTDFVocab:producedData TemperatureDataStream
]

// ========================
// Data Transmission
// ========================
instance TemperatureDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxTempSensor1, BoxTempSensor2, AmbientTempSensor
]

// ========================
// Data (Time‑Series)
// ========================
instance TemperatureTimeSeries : DTDFVocab:Data [
    base:desc "Time‑series of temperature readings (°C) from the three DS18S20 sensors."
    DTDFVocab:fromData TemperatureDataStream
    DTDFVocab:inputTo SimulationEnabler, CalibrationEnabler, MonitoringEnabler
]

// ========================
// Acting Components
// ========================
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed heating element (214 × 214 × 3 mm) driven via MOSFET switch; accepts ON/OFF heating command."
]

instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal circulation fan (~2 s⁻¹) driven via MOSFET; accepts ON/OFF speed command."
]

// ========================
// Models
// ========================
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Thermal Model A with single air heat capacity C_air and box heat‑transfer coefficient G_box."
    DTDFVocab:inputTo SimulationEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Thermal Model B extends Model A with heater heat capacity C_heater and heater heat‑transfer coefficient G_heater."
    DTDFVocab:inputTo SimulationEnabler
]

// ========================
// Enablers (Tooling & Infrastructure)
// ========================
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker on the Raspberry Pi; transports temperature and actuator status messages."
    DTDFVocab:enables TemperatureSimulationService, RealTimeMonitoringService, FaultDetectionService, ParameterOptimizationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python simulation engine (SciPy) that runs calibrated thermal models using temperature time‑series data."
    DTDFVocab:enables TemperatureSimulationService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Parameter calibration engine implementing non‑linear least‑squares optimisation (SciPy) on experimental temperature trajectories."
    DTDFVocab:enables ParameterOptimizationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Real‑time monitoring component subscribing to RabbitMQ temperature messages."
    DTDFVocab:enables RealTimeMonitoringService, FaultDetectionService
]

// ========================
// Services (DT Functionality)
// ========================
instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Simulates incubator temperature using calibrated Model A or Model B."
    DTDFVocab:provides SimulatedTemperatureInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Monitors live temperature against configured upper and lower limits."
    DTDFVocab:provides TemperatureLimitAlertInsight, BangBangControlAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults and triggers safe‑state protocol for actuators."
    DTDFVocab:provides SafeStateAction
]

instance ParameterOptimizationService : DTDFVocab:Service [
    base:desc "Optimises model parameters (C_air, G_box, C_heater, G_heater) via non‑linear least‑squares calibration."
    DTDFVocab:provides CalibratedParametersInsight
]

// ========================
// Insights
// ========================
instance SimulatedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory from the selected thermal model."
]

instance TemperatureLimitAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when temperature exceeds defined upper or lower limits."
]

instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Calibrated model parameters (C_air, G_box, C_heater, G_heater) obtained after optimisation."
]

// ========================
// Actions
// ========================
instance SafeStateAction : DTDFVocab:Action [
    base:desc "Commands heat‑bed and fan to a safe off state upon fault detection."
    DTDFVocab:IsAutomatic true
]

instance BangBangControlAction : DTDFVocab:Action [
    base:desc "Determines optimal heating (H) and waiting (C) durations for the bang‑bang controller to maintain the setpoint."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (heat‑bed ON/OFF, fan ON/OFF, heating duration, waiting duration) are generated by the digital twin logic and sent as RabbitMQ messages to the controller, which forwards them via the low‑level driver to the MOSFET drivers on the PCB."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture consists of the physical incubator (PT), a low‑level driver on the Pi interfacing sensors and actuators, a RabbitMQ communication server linking the PT to the digital twin, and DT components (model simulator, calibrator, monitor) that subscribe to the broker. The DT can run on the same Pi or on external machines connected to the broker."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing simulated temperature trajectories with measured data from uniform‑temperature experiments. Assumptions (uniform air temperature, negligible wall heat accumulation, constant air specific heat, neglect of fan heat) are explicitly listed, and Model B relaxes the assumption that the heat‑bed does not store heat. Calibration residuals are minimised to ensure validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual and virtual‑to‑physical communication is realized through a RabbitMQ message broker running on the Raspberry Pi. Messages are exchanged over the local network using the Pi's built‑in Wi‑Fi, following RabbitMQ's standard messaging protocol. The low‑level driver publishes sensor readings, and the controller subscribes to command messages, both via RabbitMQ."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ server and controller software are deployed directly on the Raspberry Pi 4. DT computational components (simulation, calibration, monitoring) can be hosted on the same Pi or on external computers that connect to the Pi’s RabbitMQ broker."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safety protocol that forces the PT into a safe state (e.g., turning off heater/fan) if abnormal conditions are detected, providing basic safety guarantees for remote actuation."
]