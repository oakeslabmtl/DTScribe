// Actuating Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heating element controlled via a MOSFET and optocoupler on the Raspberry Pi GPIO, used to raise the temperature of the incubator box."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12/24 V DC fan for air circulation, driven by a MOSFET/optocoupler interface from the Raspberry Pi, used to homogenize temperature within the box."
]

// Sensing Components
instance InsideBoxTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire temperature sensor positioned inside the styrofoam insulated box, measuring the internal temperature of the incubator."
    DTDFVocab:producedData InsideBoxTemperatureDataTransmitted
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located outside the incubator box, measuring ambient laboratory temperature."
    DTDFVocab:producedData AmbientTemperatureDataTransmitted
]

instance InternalMonitoringSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor reused during experiments to monitor internal temperature at a secondary location for validation purposes."
    DTDFVocab:producedData InternalMonitoringTemperatureDataTransmitted
]

// Data Transmitted
instance InsideBoxTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideBoxTemperatureSensor
]

instance AmbientTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

instance InternalMonitoringTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalMonitoringSensor
]

// Data Instances
instance InsideBoxTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series of interior temperature readings captured by InsideBoxTemperatureSensor."
    DTDFVocab:inputTo RabbitMQBroker
    DTDFVocab:fromData InsideBoxTemperatureDataTransmitted
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series of ambient temperature readings captured by AmbientTemperatureSensor."
    DTDFVocab:inputTo RabbitMQBroker
    DTDFVocab:fromData AmbientTemperatureDataTransmitted
]

instance InternalMonitoringTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series of internal monitoring temperature readings captured by InternalMonitoringSensor."
    DTDFVocab:inputTo RabbitMQBroker
    DTDFVocab:fromData InternalMonitoringTemperatureDataTransmitted
]

// Enablers / Engines
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker that receives sensor data messages and publishes actuator commands between the physical plant and the digital twin."
    DTDFVocab:enables DigitalTwinRuntime
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Python Scipy‑based simulation engine executing thermal Model A and Model B differential equations."
    DTDFVocab:enables ThermalSimulationService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Non‑linear least‑squares optimizer using Scipy for calibrating thermal model parameters from experimental data."
    DTDFVocab:enables CalibrationService
]

instance SafetyEngine : DTDFVocab:Enabler [
    base:desc "Safety monitoring engine that checks temperature thresholds and actuator health for over‑temperature or failure conditions."
    DTDFVocab:enables FaultDetectionService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Visualization engine integrated with a dashboard to display temperature evolution and control status in real time."
    DTDFVocab:enables VisualizationService
]

// Digital Twin Runtime orchestrates services
instance DigitalTwinRuntime : DTDFVocab:Service [
    base:desc "Runtime orchestrator that binds sensor data, simulation, calibration, monitoring, safety, and visualization services together."
    DTDFVocab:provides PredictedTemperatureInsight, TemperatureSafetyAlarmInsight, ModelCalibrationResultInsight, OverTemperatureAlarmInsight, ActuatorFailureAlarmInsight, TemperatureEvolutionVisualizationInsight
]

// Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Thermal Model A differential equations describing the coupled temperature dynamics of air and the heatbed within the incubator box."
    DTDFVocab:inputTo SimulationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Thermal Model B differential equations similar to Model A but incorporating different heat transfer coefficients derived from experimental data."
    DTDFVocab:inputTo SimulationEngine
]

// Services
instance ThermalSimulationService : DTDFVocab:Service [
    base:desc "Service that runs accelerated thermal simulations using Model A and Model B to predict future internal temperature trajectories."
    DTDFVocab:provides PredictedTemperatureInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Service that continuously monitors live temperature incoming from the physical plant and compares against set thresholds."
    DTDFVocab:provides TemperatureSafetyAlarmInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that calibrates the thermal models by fitting model parameters using historical temperature and power usage data."
    DTDFVocab:provides ModelCalibrationResultInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service that detects over‑temperature events and actuator failures based on sensor data and actuator logs."
    DTDFVocab:provides OverTemperatureAlarmInsight, ActuatorFailureAlarmInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that visualizes temperature evolution curves and control status on a real‑time dashboard."
    DTDFVocab:provides TemperatureEvolutionVisualizationInsight
]

// Insights
instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Prediction of future internal temperature trajectory based on current state and model simulation results."
]

instance TemperatureSafetyAlarmInsight : DTDFVocab:Insight [
    base:desc "Real‑time safety alarm triggered when internal temperature exceeds safe operating limits."
]

instance ModelCalibrationResultInsight : DTDFVocab:Insight [
    base:desc "Resulting calibrated parameters (C_air, C_heater, G_box, G_heater) for thermal Model A and Model B after least‑squares optimization."
]

instance OverTemperatureAlarmInsight : DTDFVocab:Insight [
    base:desc "Alarm indicating that the incubator has exceeded the maximum internal temperature threshold."
]

instance ActuatorFailureAlarmInsight : DTDFVocab:Insight [
    base:desc "Alarm indicating suspected failure or abnormal status of the heatbed or fan actuators."
]

instance TemperatureEvolutionVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of the temperature evolution within the incubator box and the effect of control actions."
]

// Actions
instance CommandHeatbedActuator : DTDFVocab:Action [
    base:desc "Command to turn the heatbed on or off or adjust its power level via the MOSFET interface."
    DTDFVocab:IsAutomatic false
]

instance CommandFanActuator : DTDFVocab:Action [
    base:desc "Command to set fan voltage (12 V or 24 V) or turn the fan on/off via the MOSFET interface."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT generates control commands (heatbed enable/disable, fan speed selection) and publishes them to RabbitMQ. The controller consumes these messages and transmits GPIO signals through MOSFETs/optocouplers to actuate the heatbed and fan. The DT also sends diagnostic and calibration updates to the PT via the same broker."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time data acquisition and command loop operating on a few‑second timescale (e.g., temperature samples every few seconds and control updates every few seconds). The DT synchronizes with the PT continuously through the message broker."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A centralized DT architecture comprising a RabbitMQ communication server, low‑level driver acting as bridge to PT hardware, a controller module implementing control law, and simulation models connected to the same message broker. All components run locally on the Raspberry Pi, forming a tightly coupled virtual‑physical loop."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design phase – development of physical components and initial model equations; Implementation phase – programming controller, low‑level driver, and RabbitMQ server; Calibration phase – running experiments, collecting data, optimizing model parameters; Operation phase – continuous monitoring, prediction, and safety enforcement within the incubation process."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation of models against experimental data; calibration of free parameters to minimize residual error using Scipy optimization; verification that uniform temperature assumption holds within ± 7 °C; explicit modeling of heat transfer to box and heatbed; use of non‑linear least‑squares to ensure convergence and uniqueness of parameter estimates."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Local AMQP communication via RabbitMQ broker running on the Raspberry Pi; 1‑Wire bus (DS18S20 sensors) over GPIO; GPIO outputs driving MOSFETs and optocouplers to actuators. All communication occurs over the internally connected network (Wi‑Fi/Bluetooth for external access, but not used for DT loop)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted entirely on the Raspberry Pi 4; all software components (broker, driver, controller, models) run locally; open‑source code available in a public GitHub repository. No external cloud hosting required."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Safe‑protocol implemented in the low‑level driver to prevent unsafe states; hardware isolation via MOSFETs and optocouplers; communication confined to local broker; however no explicit cybersecurity controls or remote operation safeguards are described."
]