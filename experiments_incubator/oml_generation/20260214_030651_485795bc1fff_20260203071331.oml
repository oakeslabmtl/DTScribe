// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed surface heater (up to ~4 A) switched by MOSFET driver on the custom PCB"
]

instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal circulation fan switched by MOSFET driver on the custom PCB"
]

// C3: Physical sensing components
instance BoxTempSensorTop : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer inside the incubator (top position, ±0.5 °C accuracy)"
    DTDFVocab:producedData BoxTempDataTxTop
]

instance BoxTempSensorBottom : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer inside the incubator (bottom position, ±0.5 °C accuracy)"
    DTDFVocab:producedData BoxTempDataTxBottom
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer measuring ambient (room) temperature, ±0.5 °C accuracy"
    DTDFVocab:producedData AmbientTempDataTx
]

// C4: Physical-to-virtual interaction – DataTransmitted
instance BoxTempDataTxTop : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxTempSensorTop
]

instance BoxTempDataTxBottom : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom BoxTempSensorBottom
]

instance AmbientTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// C10: Data objects
instance BoxTempDataTop : DTDFVocab:Data [
    base:desc "Time‑series temperature data recorded by the top box sensor"
    DTDFVocab:fromData BoxTempDataTxTop
    DTDFVocab:inputTo PythonDriver
]

instance BoxTempDataBottom : DTDFVocab:Data [
    base:desc "Time‑series temperature data recorded by the bottom box sensor"
    DTDFVocab:fromData BoxTempDataTxBottom
    DTDFVocab:inputTo PythonDriver
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Time‑series ambient temperature data recorded by the external sensor"
    DTDFVocab:fromData AmbientTempDataTx
    DTDFVocab:inputTo PythonDriver
]

// C11: Enablers
instance PythonDriver : DTDFVocab:Enabler [
    base:desc "Python low‑level driver on the Raspberry Pi that reads sensors, publishes to RabbitMQ, and controls GPIO"
    DTDFVocab:enables RealTimeTempMonitoringService,
                    SafetyViolationDetectionService,
                    ModelSimulationService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker used for publishing sensor readings and status events"
    DTDFVocab:enables RealTimeTempMonitoringService,
                    SafetyViolationDetectionService,
                    ModelSimulationService,
                    ParameterCalibrationService
]

instance SciPyOptimiser : DTDFVocab:Enabler [
    base:desc "SciPy non‑linear least‑squares optimiser employed for calibrating thermal model parameters"
    DTDFVocab:enables ParameterCalibrationService
]

// C6: Services
instance RealTimeTempMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of incubator temperature limits"
    DTDFVocab:provides TemperatureMonitoringInsight
]

instance SafetyViolationDetectionService : DTDFVocab:Service [
    base:desc "Detects temperature safety violations and triggers corrective actions"
    DTDFVocab:provides SafetyAlertInsight,
                    AdjustHeatBedAction,
                    AdjustFanAction
]

instance ModelSimulationService : DTDFVocab:Service [
    base:desc "Runs Model A or Model B to predict box temperature evolution"
    DTDFVocab:provides TemperaturePredictionInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates Model A and Model B parameters (C_air, G_box, C_heater, G_heater) using experimental data"
    DTDFVocab:provides CalibrationUpdateInsight
]

// C17: Insights
instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Live temperature readings from the three DS18S20 sensors"
]

instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when temperature exceeds defined upper or lower safety limits"
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted incubator temperature trajectory based on calibrated Model A or Model B"
]

instance CalibrationUpdateInsight : DTDFVocab:Insight [
    base:desc "Updated thermal model parameters (C_air, G_box, C_heater, G_heater) after calibration run"
]

// C17: Actions
instance AdjustHeatBedAction : DTDFVocab:Action [
    base:desc "Automatically modify heat‑bed power to bring temperature back within limits"
    DTDFVocab:IsAutomatic true
]

instance AdjustFanAction : DTDFVocab:Action [
    base:desc "Automatically change fan voltage/speed to improve temperature uniformity"
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single‑capacitance thermal model with box heat‑loss parameter G_box"
    DTDFVocab:inputTo SciPyOptimiser,
                    PythonDriver
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Extended model adding heater capacitance C_heater and heat‑transfer parameter G_heater"
    DTDFVocab:inputTo SciPyOptimiser,
                    PythonDriver
]

// Optional: Environment grouping the physical components
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator,
                    InternalFanActuator,
                    BoxTempSensorTop,
                    BoxTempSensorBottom,
                    AmbientTempSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT components publish command messages (heat‑bed ON/OFF, fan speed setpoints) to the RabbitMQ broker; the controller on the Raspberry Pi consumes these messages and, via the low‑level driver, drives the MOSFETs to actuate the heat‑bed and fan."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture comprises the PT (incubator hardware), a low‑level driver that abstracts sensor/actuator I/O, a controller running on the Raspberry Pi, a RabbitMQ communication server on the same Pi, and external DT services that subscribe to the broker to receive sensor data, run simulations, and publish control commands; all components interact via the message bus."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is governed by four assumptions (uniform temperature, negligible wall heat accumulation, constant air specific heat, negligible heat losses from fan/heat‑bed). Validation is performed through uniform‑temperature experiments (comparing three sensor readings at 12 V and 18 V fan voltages) and by calibrating model parameters to minimise residual error between measured and simulated temperature trajectories."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT components uses the RabbitMQ message broker (AMQP protocol) running on the Raspberry Pi; messages are exchanged over the local network (Wi‑Fi or Ethernet) to which the Pi is connected."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ server and the controller software are hosted on the same Raspberry Pi 4 Model B that also runs the low‑level driver; the PCB and sensors are physically attached to this node, providing an embedded deployment of the DT."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the device in a safe state; the controller enforces lower and upper temperature limits (LL, UL) and includes waiting durations to prevent overshoot, thereby providing runtime safety monitoring."
]