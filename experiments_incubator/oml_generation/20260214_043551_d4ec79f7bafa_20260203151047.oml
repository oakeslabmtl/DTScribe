// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heating element in incubator, 4A current capability, controlled via MOSFET driver and optocoupler"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12/24V fan mounted on top, controlled via MOSFET driver and optocoupler"
]

// C3: Physical sensing components
instance InsideTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer measuring process temperature inside box (location 1)"
    DTDFVocab:producedData InsideTempDataTransmitted1
]

instance InsideTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer measuring process temperature inside box (location 2)"
    DTDFVocab:producedData InsideTempDataTransmitted2
]

instance OutsideTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer measuring ambient room temperature"
    DTDFVocab:producedData OutsideTempDataTransmitted
]

// C4: Physical-to-virtual interaction – Data transmitted
instance InsideTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensor1
]

instance InsideTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTempSensor2
]

instance OutsideTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideTempSensor
]

// C10: Models/Data
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single temperature dynamics model parameterized by C_air and G_box"
    DTDFVocab:inputTo SimulationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Coupled heatbed temperature model adding parameters C_heater, G_heater, and G_box"
    DTDFVocab:inputTo SimulationEngine
]

// Data produced by models
instance ModelAOutputTransmission : DTDFVocab:DataTransmitted [
    base:desc "Transmission of Model A output data"
]

instance ModelBOutputTransmission : DTDFVocab:DataTransmitted [
    base:desc "Transmission of Model B output data"
]

instance ModelAOutputData : DTDFVocab:Data [
    base:desc "Output data stream from ThermalModelA simulation"
    DTDFVocab:inputTo SimulationEngine
    DTDFVocab:fromData ModelAOutputTransmission
]

instance ModelBOutputData : DTDFVocab:Data [
    base:desc "Output data stream from ThermalModelB simulation"
    DTDFVocab:inputTo SimulationEngine
    DTDFVocab:fromData ModelBOutputTransmission
]

// Data from sensors
instance InsideTempDataStream1 : DTDFVocab:Data [
    base:desc "Stream of process temperature readings from InsideTempSensor1"
    DTDFVocab:inputTo RabbitMQBroker
    DTDFVocab:fromData InsideTempDataTransmitted1
]

instance InsideTempDataStream2 : DTDFVocab:Data [
    base:desc "Stream of process temperature readings from InsideTempSensor2"
    DTDFVocab:inputTo RabbitMQBroker
    DTDFVocab:fromData InsideTempDataTransmitted2
]

instance OutsideTempDataStream : DTDFVocab:Data [
    base:desc "Stream of ambient temperature readings from OutsideTempSensor"
    DTDFVocab:inputTo RabbitMQBroker
    DTDFVocab:fromData OutsideTempDataTransmitted
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker used to transmit sensor data and actuator commands"
    DTDFVocab:enables TemperatureMonitoringService, ControlService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Python simulation engine executing ThermalModelA and ThermalModelB"
    DTDFVocab:enables SimulationService
]

instance PythonDriver : DTDFVocab:Enabler [
    base:desc "Python script that reads DS18S20 sensors via 1‑Wire and publishes to RabbitMQ"
    DTDFVocab:enables TemperatureMonitoringService, ControlService
]

// C6: Services
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature readings via RabbitMQ"
    DTDFVocab:provides TemperatureMonitoringInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Control logic to adjust fan voltage and heatbed power"
    DTDFVocab:provides FanVoltageAdjustmentInsight, HeatbedPowerAdjustmentInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation of future temperature trajectories using calibrated models"
    DTDFVocab:provides TemperaturePredictionInsight, ModelValidationInsight
]

// C17: Insights/Actions
instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real‑time display of temperature data and alerts for deviations"
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predictive temperature curves generated by calibrated ModelA and ModelB"
]

instance FanVoltageAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Recommendation to adjust fan voltage to maintain desired temperature set‑point"
]

instance HeatbedPowerAdjustmentInsight : DTDFVocab:Insight [
    base:desc "Recommendation to adjust heatbed power based on temperature deviations"
]

instance ModelValidationInsight : DTDFVocab:Insight [
    base:desc "Assessment of model predictions against experimental data"
]

instance AdjustFanVoltageAction : DTDFVocab:Action [
    base:desc "Adjust fan voltage via Raspberry Pi MOSFET driver"
    DTDFVocab:IsAutomatic false
]

instance AdjustHeatbedPowerAction : DTDFVocab:Action [
    base:desc "Adjust heatbed power output via Raspberry Pi MOSFET driver"
    DTDFVocab:IsAutomatic false
]

// C1: Physical components
instance RaspberryPi4 : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B serving as controller and processor"
]

instance PCB : DTDFVocab:Component [
    base:desc "Printed Circuit Board connecting heatbed, fan, sensors, and Raspberry Pi"
]

// C5: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator, FanActuator, InsideTempSensor1, InsideTempSensor2, OutsideTempSensor,
    RaspberryPi4, PCB
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Commands generated by the DT’s control logic (bang‑bang controller) are sent as AMQP messages through RabbitMQ to the low‑level driver, which toggles the MOSFET‑controlled heatbed and fan. Output signals include heatbed power commands and fan speed control, all transmitted via the message broker."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The digital twin comprises: a low‑level driver interfacing with hardware; a controller implementing the bang‑bang logic; a RabbitMQ communication server as middleware; and simulation modules (Model A/B) running in Python on the same Raspberry Pi. All components are orchestrated via AMQP queues, producing a centralized but modular twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design & modelling of the incubator and the digital twin, calibration of model parameters using experimental data, validation of model accuracy, ongoing runtime operation with real‑time control, and planned future extensions (additional models, optimisation). The twin covers the PT from design through to operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Models assume uniform temperature (verified via experimental sensor comparison), negligible wall heat accumulation, constant air specific heat, and negligible fan heat. Calibration minimises residual error between measured and simulated temperatures; parameter uncertainty is reduced via repeated experiments. Validity is verified by comparing model predictions to measured data and testing temperature uniformity across sensors."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical sensors connect to the Pi via 1‑Wire; actuators interface through MOSFETs controlled by Raspberry Pi GPIO, isolated with optocouplers. The communication server (RabbitMQ) runs on the Pi and bridges sensor/actuator data to the digital‑twin logic over TCP/IP using AMQP. All communication occurs within a local Wi‑Fi network on the Raspberry Pi."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The entire twin stack—including controller, driver, message broker, and simulation modules—is hosted on a Raspberry Pi 4 running a Linux distribution. Source code and scripts are open‑source and available via GitHub, allowing deployment on any similar embedded platform."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is embedded in the low‑level driver to prevent unsafe actuator states. Optocouplers isolate Pi GPIO from high‑current MOSFET drivers. RabbitMQ is used as a lightweight, mature message broker; however, specific encryption or authentication measures are not described."
]