// Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Electric heating element heatbed controlled by Raspberry Pi GPIO via MOSFETs and optocouplers."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12‑24 V fan driven by Raspberry Pi GPIO through MOSFETs and optocouplers, controlled by on/off commands from the controller."
]

// Sensing Components
instance InsideTemperatureSensorOne : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire digital thermometer (±0.5 °C accuracy) positioned inside the incubator."
    DTDFVocab:producedData InsideTemperatureReadingMessage
]

instance InsideTemperatureSensorTwo : DTDFVocab:SensingComponent [
    base:desc "DS18S20 one‑wire digital thermometer (±0.5 °C accuracy) positioned inside the incubator."
    DTDFVocab:producedData InsideTemperatureReadingMessage
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 thermometer (±0.5 °C accuracy) positioned outside the incubator to capture ambient temperature."
    DTDFVocab:producedData AmbientTemperatureReadingMessage
]

// Data Transmitted
instance InsideTemperatureReadingMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensorOne, InsideTemperatureSensorTwo
]

instance AmbientTemperatureReadingMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
]

instance ActuatorStateMessage : DTDFVocab:DataTransmitted [
    base:desc "State of heatbed/fan actuators transmitted by controller."
]

// Data Instances
instance InsideTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series of inside temperature samples extracted from InsideTemperatureReadingMessage."
    DTDFVocab:fromData InsideTemperatureReadingMessage
    DTDFVocab:inputTo CentralControllerEnabler, CalibrationEnabler
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series of ambient temperature samples extracted from AmbientTemperatureReadingMessage."
    DTDFVocab:fromData AmbientTemperatureReadingMessage
    DTDFVocab:inputTo CentralControllerEnabler, CalibrationEnabler
]

instance ActuatorStateData : DTDFVocab:Data [
    base:desc "Time‑series of actuator status (heatbed, fan) samples extracted from ActuatorStateMessage."
    DTDFVocab:fromData ActuatorStateMessage
    DTDFVocab:inputTo CentralControllerEnabler, CalibrationEnabler
]

// Models
instance ModelAThermalModel : DTDFVocab:Model [
    base:desc "dT/dt = (VI Δt – G_box (T_air – T_room)) / C_air – four‑parameter analytical thermal model."
    DTDFVocab:inputTo CalibrationEnabler
]

instance ModelBThermalModel : DTDFVocab:Model [
    base:desc "dT/dt equations incorporating G_heater, C_heater, C_air, G_box – six‑parameter analytical temperature prediction model."
    DTDFVocab:inputTo CalibrationEnabler
]

// Enablers
instance CentralControllerEnabler : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B controller running low‑level driver and RabbitMQ broker, enabling real‑time monitoring and bang‑bang control."
    DTDFVocab:enables TemperatureMonitoringService, BangBangControlService
    DTDFVocab:enables TemperatureSimulationServiceA, TemperatureSimulationServiceB
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime on Raspberry Pi performing offline calibration, nonlinear least‑squares (SciPy), and parameter estimation for thermal models."
    DTDFVocab:enables CalibrationService, ParameterEstimationService
]

// Services
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature using InsideTemperatureData and AmbientTemperatureData."
    DTDFVocab:provides TemperatureMonitoringInsight
]

instance BangBangControlService : DTDFVocab:Service [
    base:desc "Bang‑bang control logic for heatbed and fan actuators based on temperature thresholds."
    DTDFVocab:provides BangBangControlAction
]

instance TemperatureSimulationServiceA : DTDFVocab:Service [
    base:desc "Simulation of temperature dynamics using ModelAThermalModel."
    DTDFVocab:provides ModelATemperaturePredictionInsight
]

instance TemperatureSimulationServiceB : DTDFVocab:Service [
    base:desc "Simulation of temperature dynamics using ModelBThermalModel."
    DTDFVocab:provides ModelBTemperaturePredictionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Offline calibration of thermal model parameters using historical data."
    DTDFVocab:provides ParameterEstimationInsight
]

instance ParameterEstimationService : DTDFVocab:Service [
    base:desc "Parameter estimation of C_air, G_box, G_heater from temperature time‑series."
    DTDFVocab:provides AdjustHeatingParameterAction, AdjustCoolingParameterAction
]

// Insights
instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight on recent temperature trend for visualization."
]

instance ModelATemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory from ModelAThermalModel."
]

instance ModelBTemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory from ModelBThermalModel."
]

instance ParameterEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated values of C_air, G_box, G_heater, enabling adjustment of control parameters."
]

instance OscillationDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature oscillations indicating instability."
]

// Actions
instance BangBangControlAction : DTDFVocab:Action [
    base:desc "Action to adjust heatbed/fan on/off states accordingly."
    DTDFVocab:IsAutomatic true
]

instance AdjustHeatingParameterAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of heating duration H based on ParameterEstimationInsight."
    DTDFVocab:IsAutomatic true
]

instance AdjustCoolingParameterAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of cooling parameter C based on OscillationDetectionInsight."
    DTDFVocab:IsAutomatic true
]

// Environment
instance IncubatorDigitalTwinEnvironment : DTDFVocab:Environment [
    base:desc "Digital twin environment containing all virtual and physical components of the incubator."
    base:contains HeatbedActuator, FanActuator,
                 InsideTemperatureSensorOne, InsideTemperatureSensorTwo, AmbientTemperatureSensor,
                 CentralControllerEnabler, CalibrationEnabler,
                 TemperatureMonitoringService, BangBangControlService,
                 TemperatureSimulationServiceA, TemperatureSimulationServiceB,
                 CalibrationService, ParameterEstimationService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT controller consumes RabbitMQ messages and publishes command messages (heatbed on/off, fan on/off, desired setpoint) that the low‑level driver translates into GPIO signals and MOSFET actuator control on the Raspberry Pi."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation runs on a 1 Hz sampling rate: temperature samples and control decisions are exchanged every second; simulation and calibration are performed offline with the same time discretization Δt (seconds)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT top‑down architecture: PT sensors/actuators → low‑level driver (data ingestion + safety protocol) → RabbitMQ broker → controller (bang‑bang, simulation, calibration) → RabbitMQ → actuator control via driver; all components run locally on the Raspberry Pi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The system evolves through: design (ideal model and hardware selection), manufacturing (PCB fabrication, device assembly), and operation (live control, calibration, and validation). The DT covers all three phases—models derived during design, hardware formed during manufacturing, and real‑time data during operation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model assumptions: uniform temperature distribution (validated via fan experiments), negligible wall heat exchange (Assumption 2), constant specific heat of air (Assumption 3), heatbed energy retention accounted only in Model B (Assumption 4). Validation performed by least‑squares calibration against experimental data; residual errors drive parameter refinement."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Local network over Wi‑Fi; communication uses AMQP protocol via RabbitMQ; messages are exchanged on local localhost; Raspberry Pi serves as both broker host and DT host."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components (low‑level driver, controller, RabbitMQ, simulation models) are hosted on the same Raspberry Pi 4 Model B; the system is physically co‑located with the PT and requires no external servers."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver implements a safe protocol to keep the device in a safe state; no explicit cybersecurity or access‑control mechanisms are detailed in the document."
]