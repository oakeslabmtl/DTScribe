instance GeometricModel : DTDFVocab:Model [
    base:desc "CAD representations for geometric modeling"
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, StateEstimatorEnabler, FaultDetectorEnabler, OptimizerEnabler
]

instance AnalyticalModel : DTDFVocab:Model [
    base:desc "Differential equations modeling dynamic behavior"
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, StateEstimatorEnabler, FaultDetectorEnabler, OptimizerEnabler
]

instance CyberModel : DTDFVocab:Model [
    base:desc "Cyber models for control logic implementation"
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, StateEstimatorEnabler, FaultDetectorEnabler, OptimizerEnabler
]

instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithms dynamically update model parameters using real-time sensor data"
    DTDFVocab:enables MonitoringService, PredictiveSimulationService
]

instance StateEstimatorEnabler : DTDFVocab:Enabler [
    base:desc "State estimation algorithms for precise system state determination"
    DTDFVocab:enables StateEstimationService
]

instance FaultDetectorEnabler : DTDFVocab:Enabler [
    base:desc "Fault detection algorithms to identify anomalies"
    DTDFVocab:enables FaultDetectionService
]

instance OptimizerEnabler : DTDFVocab:Enabler [
    base:desc "Optimizers and supervisory controllers for optimization capabilities"
    DTDFVocab:enables OptimizationService
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitoring services to assess safety and operational efficiency through real-time data analysis"
    DTDFVocab:provides SafetyViolationInsight, AdjustPhysicalOperations
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulations to reproduce and forecast physical twin behavior under current conditions"
    DTDFVocab:provides ForecastingInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection algorithms to identify anomalies"
    DTDFVocab:provides FaultDetectionInsight, AdjustPhysicalOperations
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "State estimation for precise system state determination"
    DTDFVocab:provides StateEstimationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization capabilities via optimisers and supervisory controllers"
    DTDFVocab:provides OptimizationInsight, AdjustPhysicalOperations
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Fault detection through algorithmic processing of sensor data and models"
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "State estimation for precise system state determination"
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization through algorithmic processing of sensor data and models"
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring identifying safety or efficiency violations"
]

instance ForecastingInsight : DTDFVocab:Insight [
    base:desc "Predictions of Physical Twin behavior under current conditions"
]

instance AdjustPhysicalOperations : DTDFVocab:Action [
    base:desc "Adaptive modifications to the Physical Twin via human intervention or automated algorithms"
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system employs calibration algorithms to update Cyber-Physical System (CPS) and environmental models with parameter estimates derived from sensor data, which informs monitoring systems for safety and optimization checks; detected violations prompt human or algorithmic adjustments to the Physical Twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin lifecycle integrates design-phase Computer-Aided Design (CAD) models for geometric specifications and analysis-phase dynamic models using differential equations for physical behavior simulation. Upon system deployment, these models are maintained and integrated into the Digital Twin framework to support ongoing monitoring, simulation, and optimization of the Physical Twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Calibration algorithms update model parameters using real-time sensor data to maintain fidelity with the Physical Twin. Monitoring systems validate system performance against safety and optimality criteria, with detected violations prompting corrective actions through human or algorithmic interventions."
]