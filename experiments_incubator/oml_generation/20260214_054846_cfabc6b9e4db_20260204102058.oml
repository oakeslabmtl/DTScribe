// C3: Physical Sensing Components
instance InternalAirTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer measuring internal air temperature near the heatbed. Range: -55°C to +125°C, accuracy: ±0.5°C (between -10°C and +85°C). Communicates via 1-Wire bus connected to Raspberry Pi GPIO."
    DTDFVocab:producedData InternalAirTemperatureDataTransmitted1
]

instance InternalAirTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer measuring internal air temperature in a colder zone. Range: -55°C to +125°C, accuracy: ±0.5°C (between -10°C and +85°C). Communicates via 1-Wire bus connected to Raspberry Pi GPIO."
    DTDFVocab:producedData InternalAirTemperatureDataTransmitted2
]

instance ExternalRoomTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer measuring external room temperature for model calibration. Range: -55°C to +125°C, accuracy: ±0.5°C (between -10°C and +85°C). Communicates via 1-Wire bus connected to Raspberry Pi GPIO."
    DTDFVocab:producedData ExternalRoomTemperatureDataTransmitted
]

instance LowLevelDriver : DTDFVocab:SensingComponent [
    base:desc "Periodically reads temperature data from DS18S20 sensors (sampling rate ~1Hz) and transmits to RabbitMQ server. Also monitors commands from controller to actuate heatbed and fan."
    DTDFVocab:producedData SensorDataTransmittedToRabbitMQ
]

// C4: Physical-to-Virtual Interaction
instance InternalAirTemperatureDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalAirTemperatureSensor1
]

instance InternalAirTemperatureDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalAirTemperatureSensor2
]

instance ExternalRoomTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalRoomTemperatureSensor
]

instance AveragedInternalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalAirTemperatureSensor1, InternalAirTemperatureSensor2
    base:desc "Averaged temperature data from two internal sensors for uniformity in DT models."
]

instance SensorDataTransmittedToRabbitMQ : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LowLevelDriver
    base:desc "Periodic temperature readings (internal air, external room) with timestamps, published to RabbitMQ server."
]

instance ActuatorStateFeedbackDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LowLevelDriver
    base:desc "Confirmation messages from low-level driver about executed commands (heatbed ON/OFF, fan speed) sent back to RabbitMQ server."
]

instance TemperatureThresholdViolationEvent : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LowLevelDriver
    base:desc "Event-based triggers for temperature threshold violations (LL/UL breaches) or fan/heatbed state changes."
]

// C10: Models/Data
instance ThermalModelA : DTDFVocab:Model [
    base:desc "First-order differential equation model (Eq. 5) with two parameters (G_box, C_air) representing energy transfer between air and box walls."
    DTDFVocab:inputTo PythonScipyEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Second-order system model (Eq. 9) with four parameters (G_box, C_air, G_heater, C_heater) accounting for heatbed thermal inertia. Empirically validated for better prediction fidelity."
    DTDFVocab:inputTo PythonScipyEnabler
]

instance InternalTemperatureTimeSeriesData : DTDFVocab:Data [
    base:desc "Time-series temperature readings from DS18S20 sensors (sampling rate: ~1Hz) used for model validation and calibration."
    DTDFVocab:fromData AveragedInternalTemperatureDataTransmitted, InternalAirTemperatureDataTransmitted1, InternalAirTemperatureDataTransmitted2
    DTDFVocab:inputTo PythonScipyEnabler, RabbitMQEnabler
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "External room temperature (T_room) used for model calibration and environmental context."
    DTDFVocab:fromData ExternalRoomTemperatureDataTransmitted
    DTDFVocab:inputTo PythonScipyEnabler
]

instance HeatbedPowerData : DTDFVocab:Data [
    base:desc "Heatbed power consumption logs (V×I×Δt) used for energy balance calculations."
    DTDFVocab:fromData ActuatorStateFeedbackDataTransmitted
    DTDFVocab:inputTo PythonScipyEnabler
]

instance FanVoltageData : DTDFVocab:Data [
    base:desc "Fan voltage logs (12V/18V) used to evaluate temperature uniformity trade-offs."
    DTDFVocab:fromData ActuatorStateFeedbackDataTransmitted
    DTDFVocab:inputTo PythonScipyEnabler
]

instance ModelCalibrationData : DTDFVocab:Data [
    base:desc "Experimental trajectories (e.g., Fig. 10) used to optimize model parameters via non-linear least squares."
    DTDFVocab:fromData InternalTemperatureTimeSeriesData, ExternalTemperatureData, HeatbedPowerData, FanVoltageData
    DTDFVocab:inputTo PythonScipyEnabler
]

// C11: Enablers
instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "Open-source message broker for asynchronous communication between Physical Twin (PT) and Digital Twin (DT) components. Handles sensor data transmission, actuator feedback, and event-based triggers."
    DTDFVocab:enables RealTimeTemperaturePredictionService, ModelCalibrationService, FaultDetectionService, BangBangControllerService
]

instance PythonScipyEnabler : DTDFVocab:Enabler [
    base:desc "Python Scipy library used for model calibration via optimize.least_squares to minimize residual error between simulated and measured temperature trajectories."
    DTDFVocab:enables ModelCalibrationService, RealTimeTemperaturePredictionService
]

instance BangBangControllerEnabler : DTDFVocab:Enabler [
    base:desc "Statechart-based controller implemented on Raspberry Pi with four parameters (LL, UL, H, C) to regulate heatbed and fan based on sensor feedback."
    DTDFVocab:enables BangBangControllerService
]

instance CustomPCBEnabler : DTDFVocab:Enabler [
    base:desc "Custom PCB with MOSFETs and optocouplers for safe heatbed power control, decoupling Raspberry Pi signals."
    DTDFVocab:enables HeatbedActuationService, FanActuationService
]

// C6: Services
instance RealTimeTemperaturePredictionService : DTDFVocab:Service [
    base:desc "Uses ThermalModelA (2 parameters) or ThermalModelB (4 parameters) to simulate and predict internal air temperature dynamics under current conditions."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Employs non-linear least squares solver to calibrate model parameters by minimizing the residual error between simulated (f(x, θ)) and observed (y) temperatures."
    DTDFVocab:provides CalibratedModelParametersInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Monitors deviations between PT's actual temperature and DT's predictions to detect anomalies (e.g., sensor failures, heatbed malfunctions)."
    DTDFVocab:provides AnomalyDetectionInsight
]

instance BangBangControllerService : DTDFVocab:Service [
    base:desc "Issues commands via RabbitMQ to low-level driver to actuate heatbed and fan based on temperature thresholds (LL/UL) and timing parameters (H/C)."
    DTDFVocab:provides ControllerAdjustmentAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Evaluates trade-offs between fan voltage (12V vs. 18V) and temperature uniformity (discrepancy reduced from 7°C to 6°C with higher voltage)."
    DTDFVocab:provides FanVoltageOptimizationInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Generates plots comparing sensor data, heatbed power, and model predictions to validate assumptions (e.g., uniform temperature distribution)."
    DTDFVocab:provides ValidationVisualizationInsight
]

// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Surface heat source (214×214×3 mm) controlled via MOSFETs and optocouplers to decouple Raspberry Pi signals, capable of delivering ≥100W power."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12V/24V DC fan (airflow: 0.02 m³/s) used to circulate air inside the box, ensuring uniform temperature distribution. Operates at variable voltages (tested at 12V and 18V)."
]

// C17: Insights/Actions
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Forecasts internal temperature trajectories under current conditions using calibrated thermal models (Model A or B)."
]

instance CalibratedModelParametersInsight : DTDFVocab:Insight [
    base:desc "Optimized model parameters (G_box, C_air, G_heater, C_heater) derived from non-linear least squares calibration against experimental data."
]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Flags deviations between PT and DT predictions (e.g., sudden temperature spikes) for manual review."
]

instance ControllerAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjusts bang-bang controller parameters (LL, UL, H, C) based on calibration results to improve temperature stability."
    DTDFVocab:IsAutomatic true
]

instance FanVoltageOptimizationInsight : DTDFVocab:Insight [
    base:desc "Decision to use 18V (vs. 12V) reduces temperature discrepancy from 7°C to 6°C, improving uniformity at the cost of increased power consumption."
]

instance ValidationVisualizationInsight : DTDFVocab:Insight [
    base:desc "Generated plots (e.g., Fig. 10, Fig. 12) comparing sensor data, heatbed power, and model predictions to validate assumptions like uniform temperature distribution."
]

// C1: Physical Twin Components
instance StyrofoamBox : DTDFVocab:Component [
    base:desc "Insulated styrofoam enclosure housing the thermal incubator system. Assumed to have negligible heat accumulation in walls."
]

instance RaspberryPi4Controller : DTDFVocab:Component [
    base:desc "Runs the bang-bang controller, low-level driver, and RabbitMQ server. Acts as the central processing unit for the PT-DT system."
]

instance CustomPowerControlPCB : DTDFVocab:Component [
    base:desc "Custom PCB with MOSFETs and optocouplers for safe heatbed power control, decoupling Raspberry Pi signals."
]

instance PowerSupply : DTDFVocab:Component [
    base:desc "Provides stable power to Raspberry Pi, heatbed, fan, and sensors."
]

// C16: Environment
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Physical environment containing the thermal incubator system."
    base:contains StyrofoamBox, HeatbedActuator, FanActuator, InternalAirTemperatureSensor1, InternalAirTemperatureSensor2, ExternalRoomTemperatureSensor, RaspberryPi4Controller, CustomPowerControlPCB, PowerSupply
]

// C2: Acting Components Services
instance HeatbedActuationService : DTDFVocab:Service [
    base:desc "Service that controls the heatbed actuator based on commands from the bang-bang controller."
    DTDFVocab:provides ControllerAdjustmentAction
]

instance FanActuationService : DTDFVocab:Service [
    base:desc "Service that controls the fan actuator based on commands from the bang-bang controller."
    DTDFVocab:provides ControllerAdjustmentAction
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The **Virtual-to-Physical (V2P) interaction** involves the following outputs from the DT to the PT:
  1. **Control Commands**: The DT (via the **controller**) sends commands to the **RabbitMQ server**, which are relayed to the **low-level driver** to:
     - Activate/deactivate the **heatbed** (via MOSFETs) for heating.
     - Adjust the **fan voltage** (12V/18V) to optimize air circulation.
  2. **Parameter Updates**: The DT dynamically adjusts the **bang-bang controller parameters** (`LL`, `UL`, `H`, `C`) based on model calibration results or external inputs (e.g., environmental changes).
  3. **Safe State Protocols**: The low-level driver enforces **safety checks** (e.g., current limits for the heatbed) before executing commands, ensuring the PT remains in a stable state even if the DT issues erroneous instructions."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The **Digital Twin (DT)** operates on the following time scales:
  1. **Real-Time Monitoring**:
     - **Sensor data sampling**: Periodic (frequency not explicitly stated but inferred as **sub-second** due to control loop requirements).
     - **Actuator response**: **<2 seconds** for heatbed to raise temperature by **6.85°C** (from **20°C to 26.85°C**).
  2. **Model Calibration**:
     - **Offline optimization**: Uses **Python Scipy’s least-squares solver** (iterative process with no explicit time constraint).
  3. **Communication Latency**:
     - **RabbitMQ** enables **low-latency synchronization** between PT and DT, with **asynchronous message passing** supporting **real-time control loops**.
  4. **Experimental Validation**:
     - **Uniformity tests**: Conducted over **minutes** (e.g., fig. 10 shows **~30-minute** temperature trajectories)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The **DT constellation** follows a **CPS-based architecture** (Fig. 1) with the following orchestration:
  1. **Physical Layer (PT)**:
     - **Sensors**: DS18S20 (temperature).
     - **Actuators**: Heatbed, fan.
     - **Controller**: Raspberry Pi with bang-bang logic.
  2. **Cyber Layer (DT)**:
     - **Communication**: RabbitMQ server for message-based synchronization.
     - **Models**: Model A/B for thermal prediction.
     - **Calibration Engine**: Non-linear least squares solver.
  3. **Interaction Flow**:
     - **P2V**: Sensors → Low-Level Driver → RabbitMQ → DT models.
     - **V2P**: DT controller → RabbitMQ → Low-Level Driver → Actuators.
     - **Feedback Loop**: DT monitors PT performance and recalibrates models as needed (Fig. 7)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the following **life-cycle stages** of the PT:
  1. **As Designed**: Models (A and B) are derived from theoretical assumptions (e.g., uniform temperature, negligible heat loss) and validated against experimental data.
  2. **As Manufactured**: The PT’s hardware (PCB, sensors, heatbed) is calibrated to match the DT’s models during the **experimental phase** (Section 4).
  3. **As Operated**: The DT continuously monitors and adjusts the PT’s behavior in real-time (e.g., via the bang-bang controller) and offline (e.g., model recalibration). The system does not explicitly address **end-of-life** stages (e.g., decommissioning)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The **fidelity and validity** of the DT are ensured through:
  1. **Model Assumptions**:
     - **Assumption 1**: Validated experimentally (Fig. 10, Fig. 12) by showing temperature discrepancies ≤7°C (reduced to ≤6°C with higher fan voltage).
     - **Assumption 2**: Negligible heat accumulation in box walls is implied but not explicitly validated.
     - **Assumption 3**: Constant specific heat capacity (`c_air = 700 J/kg·K`) is assumed for simplicity.
     - **Assumption 4**: Relaxed in **Model B** to account for heatbed thermal inertia.
  2. **Verification and Validation**:
     - **Parameter Calibration**: Uses **least-squares optimization** to minimize residual error between predicted and measured temperatures.
     - **Experimental Validation**: Compares Model A/B predictions with real-time sensor data (e.g., Fig. 10) to quantify uncertainty.
  3. **Uncertainty Sources**:
     - **Sensor Accuracy**: ±0.5°C for DS18S20 sensors.
     - **Model Approximations**: Simplified energy equations may introduce errors (e.g., ignored fan heat contribution).
     - **Environmental Factors**: External temperature fluctuations (`T_room`) affect model accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical connection** between the PT and DT includes:
  1. **Sensor Communication**:
     - **1-Wire Protocol**: Used by DS18S20 sensors to transmit temperature data to the Raspberry Pi GPIO.
  2. **Message Brokering**:
     - **RabbitMQ**: Deployed on the Raspberry Pi to facilitate **asynchronous communication** between the PT (low-level driver) and DT (models/controller). RabbitMQ supports **multiple queues** and **publish-subscribe patterns**, enabling scalable integration.
  3. **Actuator Control**:
     - **GPIO Signals**: The Raspberry Pi sends control signals to the **PCB**, which uses **MOSFETs** to switch the heatbed and **optocouplers** to isolate high-current signals.
  4. **Network Architecture**:
     - **Local Deployment**: All components (PT, DT, RabbitMQ) are hosted on the **same Raspberry Pi**, minimizing network latency.
     - **Potential Cloud Integration**: RabbitMQ can be deployed in the cloud, enabling remote DT access but requiring explicit security measures."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **DT hosting/deployment** is as follows:
  1. **Hardware Host**: **Raspberry Pi 4 Model B** (onboard Wi-Fi/Bluetooth for wireless deployment).
  2. **Software Stack**:
     - **Operating System**: Raspberry Pi OS (Linux-based).
     - **Middleware**: RabbitMQ for message brokering.
     - **Runtime Environment**: Python for model calibration and controller logic.
  3. **Deployment Model**:
     - **Edge Deployment**: DT runs locally on the Raspberry Pi, minimizing cloud dependency.
     - **Scalability**: RabbitMQ supports **distributed deployments** (e.g., multiple PTs/DTs) via additional brokers or queues."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT does not explicitly describe **horizontal integration** with external systems in the provided documents. However, the **RabbitMQ-based architecture** supports integration with:
  - **Other CPS**: Additional PTs/DTs can be added by extending RabbitMQ queues.
  - **Cloud Services**: RabbitMQ can be deployed in the cloud for centralized monitoring.
  - **Industry 4.0 Platforms**: Potential compatibility with **OPC UA** or **MQTT** via middleware adaptations (not implemented in this case study)."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "The **standardization** aspects include:
  1. **Protocols**:
     - **1-Wire Protocol**: Used for sensor communication (DS18S20).
     - **RabbitMQ/AMQP**: For message brokering (though AMQP 0-9-1 is not explicitly mentioned, RabbitMQ is AMQP-compliant).
  2. **Units**:
     - **SI Units**: Used consistently in models (e.g., Joules for energy, Kelvin for temperature, Watts for power).
  3. **Open-Source Licensing**:
     - The hardware and software are **publicly available** under an unspecified license (likely permissive, e.g., MIT or Apache 2.0), though the exact license is not stated in the document."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT includes the following **security and safety** measures:
  1. **Safety**:
     - **Current Limiting**: MOSFETs and PCB design prevent overcurrent to the heatbed (≤4A).
     - **Safe State Protocols**: Low-level driver enforces checks before executing commands (e.g., heatbed activation).
     - **Temperature Bounds**: Controller enforces `LL`/`UL` to prevent overheating or freezing.
  2. **Security**:
     - **Isolation**: Optocouplers decouple Raspberry Pi signals from high-power actuators.
     - **No Remote Execution**: The DT does not allow **direct remote control** of the PT; all commands are validated locally.
     - **Limited Exposure**: RabbitMQ is deployed locally (no cloud exposure by default), but no authentication/encryption is specified for message integrity.
  3. **Operational Risks**: The system assumes **human supervision** for critical decisions (e.g., handling anomalies detected by the DT)."
]