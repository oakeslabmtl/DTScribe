// C3: Physical sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor located inside the incubator to monitor one internal temperature point."
    DTDFVocab:producedData InternalTempData1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor located inside the incubator to monitor a second internal temperature point."
    DTDFVocab:producedData InternalTempData2
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor located outside the incubator to monitor ambient room temperature."
    DTDFVocab:producedData AmbientTempData
]

// C4: Physical-to-virtual interaction (data transmitted)
instance InternalTempData1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempData2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance AmbientTempData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// C10: Reports/Data
instance TempDataInternal1 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature data stream for the first internal sensor, received via RabbitMQ."
    DTDFVocab:fromData InternalTempData1
    DTDFVocab:inputTo RabbitMQEnabler
]

instance TempDataInternal2 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature data stream for the second internal sensor, received via RabbitMQ."
    DTDFVocab:fromData InternalTempData2
    DTDFVocab:inputTo RabbitMQEnabler
]

instance AmbientTempDataSet : DTDFVocab:Data [
    base:desc "Time‑stamped ambient temperature data stream received via RabbitMQ."
    DTDFVocab:fromData AmbientTempData
    DTDFVocab:inputTo RabbitMQEnabler
]

// C1: Acting components (physical actuators)
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed heater actuated through the Raspberry Pi controller using MOSFETs and optocouplers."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan actuated through the Raspberry Pi controller using MOSFETs and optocouplers."
]

// Data produced by actuators
instance HeatbedCommandData : DTDFVocab:DataTransmitted []

instance FanCommandData : DTDFVocab:DataTransmitted []

// C10: Data from actuators
instance HeatbedCommandDataSet : DTDFVocab:Data [
    base:desc "Time‑stamped command data stream for the heatbed heater, transmitted via RabbitMQ."
    DTDFVocab:fromData HeatbedCommandData
    DTDFVocab:inputTo RabbitMQEnabler
]

instance FanCommandDataSet : DTDFVocab:Data [
    base:desc "Time‑stamped command data stream for the fan, transmitted via RabbitMQ."
    DTDFVocab:fromData FanCommandData
    DTDFVocab:inputTo RabbitMQEnabler
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "State‑space thermal model A with parameters C_air, G_box, G_heater, C_heater."
    DTDFVocab:inputTo RabbitMQEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "State‑space thermal model B with parameters C_air, G_box, G_heater, C_heater."
    DTDFVocab:inputTo RabbitMQEnabler
]

// C11: Enablers
instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker facilitating communication between physical and virtual twins."
    DTDFVocab:enables MonitoringService, PredictionService, CalibrationService, FaultDetectionService, ControlService, OptimizationService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring and visualization of temperature data."
    DTDFVocab:provides RealTimeTemperatureInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Thermal‑model‑based temperature prediction."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration of model parameters using experimentally measured temperature time series."
    DTDFVocab:provides ModelAccuracyInsight, FanVoltageEffectInsight, CalibrationResultInsight, UpdateModelParameterAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection based on temperature anomalies."
    DTDFVocab:provides FaultDetectionInsight
]

instance ControlService : DTDFVocab:Service [
    base:desc "Supervisory bang‑bang control of heater and fan actuation."
    DTDFVocab:provides AdjustControlStrategyAction, BangBangControlAction
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Future optimization tasks on the incubator control strategy."
    DTDFVocab:provides OptimizationInsight
]

// C17: Insights
instance RealTimeTemperatureInsight : DTDFVocab:Insight [
    base:desc "Insight into current temperature levels from real‑time monitoring."
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Insight into predicted temperature trends from thermal models."
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Calibration result indicating which thermal model better captures heat‑bed inertia."
]

instance FanVoltageEffectInsight : DTDFVocab:Insight [
    base:desc "Insight into how fan voltage changes affect temperature uniformity."
]

instance CalibrationResultInsight : DTDFVocab:Insight [
    base:desc "Result of the calibration process identifying optimal parameter values."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature faults or anomalies within the incubator."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting potential optimizations for the control strategy."
]

// C17: Actions
instance UpdateModelParameterAction : DTDFVocab:Action [
    base:desc "Action to update model parameters based on calibration results."
    DTDFVocab:IsAutomatic false
]

instance AdjustControlStrategyAction : DTDFVocab:Action [
    base:desc "Action to adjust the control strategy for temperature regulation."
    DTDFVocab:IsAutomatic true
]

instance BangBangControlAction : DTDFVocab:Action [
    base:desc "Bang‑bang supervisory control action for heater and fan actuation."
    DTDFVocab:IsAutomatic true
]

// C18: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InsulatedStyrofoamBox, HeatbedActuator, FanActuator, InternalTempSensor1, InternalTempSensor2, AmbientTempSensor, RaspberryPiController
]

// C1: Physical components
instance InsulatedStyrofoamBox : DTDFVocab:Component [
    base:desc "Insulated Styrofoam box housing the heatbed, acting as thermal mass and boundary."
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 controller orchestrating sensors, MOSFETs, and optocouplers."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT generates model‑based predictions and control commands (e.g., heating duration, fan ON/OFF) that are sent via RabbitMQ to the controller, which drives the MOSFET switches to act on the heatbed and fan."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "DT operates in near real‑time with the PT, exchanging sensor data and control commands every few seconds via RabbitMQ; offline calibration and parameter optimization are performed on a separate batch timescale."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "PT consisting of hardware (heatbed, fan, sensors, Raspberry Pi) with firmware for low‑level driver and controller; DT comprising the same communication interface, calibrated thermal models, monitoring, and visualization components running on the same or remote host, all orchestrated via RabbitMQ."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (ideal specification), manufacturing (assembling Raspberry Pi, PCB, sensors, enclosure), and operation/maintenance (running the incubator under the DT’s supervision)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model calibration via nonlinear least‑squares, comparison of simulated trajectories with measured data, experimental validation of assumptions such as uniform temperature and heat loss; accuracy limited by sensor precision and model assumptions."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Connection between DT and PT is achieved through RabbitMQ over Wi‑Fi/ethernet using TCP; sensors communicate over 1‑wire bus, actuators via MOSFETs; messages typically contain JSON payloads."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All components run locally on the Raspberry Pi hardware; the design and code are open source and can be deployed on a single host or a remote server if desired."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver implements a safe protocol to keep the device in a safe state; RabbitMQ ensures message reliability; no explicit mention of encryption, access control, or enforcement of safety during remote execution, thus safety responsibilities rely on controller logic."
]