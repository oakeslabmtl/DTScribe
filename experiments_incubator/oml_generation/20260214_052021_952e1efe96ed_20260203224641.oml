]

instance AnomalyDetectionInsight : DTDFVocab:Insight [
    base:desc "Identified operational anomalies including sensor failures, actuator malfunctions, or environmental deviations from expected behavior patterns."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Actionable recommendations for improving system performance, such as adjusting control parameters for energy efficiency or maintenance scheduling."
]

