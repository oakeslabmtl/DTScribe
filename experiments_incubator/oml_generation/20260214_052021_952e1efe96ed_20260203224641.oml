    DTDFVocab:inputTo ThermalModelCalibrationEnabler, FaultDetectionEnabler
]

instance HistoricalTemperatureData : DTDFVocab:Data [
    base:desc "Archived temperature data used for offline validation of thermal models and long-term performance analysis."
    DTDFVocab:fromData InternalTemperatureData1, InternalTemperatureData2, ExternalTemperatureData
    DTDFVocab:inputTo DataManagementEnabler
]

instance ActuatorStateData : DTDFVocab:Data [
