    base:desc "Forecasted temperature evolution within the incubator over the next operational cycle, accounting for current environmental conditions and control inputs."
]

instance SystemStateVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real-time graphical representation of the incubator's current state, including temperature distributions, actuator statuses, and model predictions."
]

