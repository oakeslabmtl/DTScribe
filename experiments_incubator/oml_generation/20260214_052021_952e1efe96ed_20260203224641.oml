instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "High-precision temperature sensor placed inside the incubator's styrofoam box for redundant internal temperature monitoring. Supports thermal model calibration with ±0.1°C resolution."
