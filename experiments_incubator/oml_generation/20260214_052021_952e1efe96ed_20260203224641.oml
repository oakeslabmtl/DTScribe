]

instance FourParameterThermalModel : DTDFVocab:Model [
    base:desc "Enhanced differential equation-based thermal model with four free parameters, demonstrating superior accuracy in capturing thermal inertia for incubator temperature prediction."
    DTDFVocab:inputTo ThermalModelCalibrationEnabler, ThermalSimulationEnabler
]

instance DynamicThermalBehaviorModel : DTDFVocab:Model [
    base:desc "Physics-based model representing the incubator's dynamic thermal behavior under varying environmental conditions and control inputs."
    DTDFVocab:inputTo ThermalModelCalibrationEnabler, ThermalSimulationEnabler
]

instance GeometricIncubatorModel : DTDFVocab:Model [
