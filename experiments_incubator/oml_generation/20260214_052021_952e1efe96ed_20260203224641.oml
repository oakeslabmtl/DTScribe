    DTDFVocab:inputTo ControlAlgorithmEnabler
]

instance StructuralHealthData : DTDFVocab:Data [
    base:desc "Dynamic structural data from automotive systems, including strain and inertial measurements for predictive maintenance."
    DTDFVocab:fromData StrainGaugeData, IMUData
    DTDFVocab:inputTo FaultDetectionEnabler
]

// C11: Enablers
instance ThermalModelCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Algorithm implementing parameter estimation techniques to align thermal models with observed physical twin behavior using real-time sensor data."
    DTDFVocab:enables ThermalModelCalibrationService, DynamicSimulationService
]

instance ThermalSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Numerical solver executing physics-based thermal models to predict incubator temperature dynamics under current or hypothetical conditions."
    DTDFVocab:enables DynamicSimulationService, PredictiveAnalyticsService
]

instance ControlAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Supervisory controller (e.g., PID, MPC) implementing closed-loop temperature regulation based on real-time sensor feedback and model predictions."
    DTDFVocab:enables TemperatureControlService, OptimizationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring algorithm identifying safety violations or performance deviations by analyzing real-time data against predefined thresholds."
    DTDFVocab:enables SafetyValidationService, AnomalyDetectionService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Dashboard framework (e.g., Grafana, MATLAB App Designer) providing real-time visualizations of system states, model predictions, and operational metrics."
    DTDFVocab:enables MonitoringService
]

instance DataManagementEnabler : DTDFVocab:Enabler [
    base:desc "Time-series database system (e.g., InfluxDB) storing and processing sensor data and model outputs for historical analysis and real-time queries."
    DTDFVocab:enables DataIntegrationService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimization algorithm generating actionable recommendations for improving system performance, such as adjusting control parameters for energy efficiency."
    DTDFVocab:enables OptimizationService, PredictiveAnalyticsService
]

instance RaspberryPiController : DTDFVocab:Enabler [
    base:desc "Embedded controller platform executing real-time data acquisition, preprocessing, and actuation commands for the incubator's digital twin system."
    DTDFVocab:enables DataIntegrationService, ActuationService
]

// C6: Services
instance ThermalModelCalibrationService : DTDFVocab:Service [
    base:desc "Service continuously updating thermal model parameters using real-time sensor data to minimize prediction errors and maintain model accuracy."
    DTDFVocab:provides ThermalModelAccuracyInsight
]

instance DynamicSimulationService : DTDFVocab:Service [
    base:desc "Service executing physics-based simulations to reproduce and predict the incubator's thermal behavior under current or hypothetical operating conditions."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance TemperatureControlService : DTDFVocab:Service [
    base:desc "Service implementing closed-loop control algorithms to maintain target temperature within the incubator despite environmental disturbances."
    DTDFVocab:provides TemperatureRegulationAction
]

instance SafetyValidationService : DTDFVocab:Service [
    base:desc "Service assessing whether the physical twin operates within safe bounds by monitoring real-time data against predefined safety thresholds."
    DTDFVocab:provides SafetyComplianceInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Service identifying operational anomalies such as sensor failures, actuator malfunctions, or environmental deviations from expected behavior."
    DTDFVocab:provides AnomalyDetectionInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service generating optimization recommendations to improve system performance, such as adjusting control parameters for energy efficiency."
    DTDFVocab:provides OptimizationRecommendationInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Service generating predictive insights about future system behavior based on current trends and model predictions."
    DTDFVocab:provides PredictiveTemperatureTrajectoryInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service providing real-time visualizations of system states, including temperature, actuator status, and model predictions for operators."
    DTDFVocab:provides SystemStateVisualizationInsight
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Service managing the collection, preprocessing, and storage of sensor data from the physical twin for digital twin processing."
    DTDFVocab:provides DataQualityAssuranceInsight
]

instance ActuationService : DTDFVocab:Service [
    base:desc "Service transmitting control commands from the digital twin to physical actuators based on real-time monitoring and optimization recommendations."
    DTDFVocab:provides ActuationCommandAction
]

// C17: Insights/Actions
instance ThermalModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantitative measure of thermal model accuracy, updated continuously through calibration algorithms to reflect current physical twin behavior."
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectories within the incubator under current or hypothetical operating conditions, generated by physics-based simulations."
]

