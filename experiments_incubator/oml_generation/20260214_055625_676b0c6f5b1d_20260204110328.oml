// C2: Acting Components
instance IncubatorFanController : DTDFVocab:Actuator [
    base:desc "Raspberry Pi-based controller for fan speed adjustments to maintain temperature uniformity within the styrofoam incubator box"
]

instance HeatBedActuator : DTDFVocab:Actuator [
    base:desc "Primary heating element controlled by DT for maintaining target temperature in the incubator"
]

// C3: Physical sensing components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor measuring core incubator temperature (inside styrofoam box)"
    DTDFVocab:producedData InternalTemperatureData
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second internal temperature sensor providing redundant measurement of core incubator temperature"
    DTDFVocab:producedData InternalTemperatureData
]

instance ExternalAmbientSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor measuring ambient conditions outside the styrofoam insulation"
    DTDFVocab:producedData ExternalTemperatureData
]

// C4: Physical-to-virtual interaction
instance InternalTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1, InternalTemperatureSensor2
]

instance ExternalTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalAmbientSensor
]

// C10: Models/Data
instance BasicThermalModel : DTDFVocab:Model [
    base:desc "Basic thermal model with two free parameters for temperature prediction, capturing simplified heat transfer dynamics"
    DTDFVocab:inputTo CalibrationAlgorithm, SimulationEngine
]

instance AdvancedThermalModel : DTDFVocab:Model [
    base:desc "Advanced thermal model with four free parameters (including thermal inertia of heatbed) for more accurate temperature prediction"
    DTDFVocab:inputTo CalibrationAlgorithm, SimulationEngine
]

instance TemperatureMeasurementData : DTDFVocab:Data [
    base:desc "Real-time temperature measurement data collected from all sensors for model calibration and validation"
    DTDFVocab:fromData InternalTemperatureData, ExternalTemperatureData
    DTDFVocab:inputTo ModelParameterEstimator, StateEstimator
]

instance CalibrationParametersData : DTDFVocab:Data [
    base:desc "Calibration parameters derived from least-squares fitting algorithms for thermal model refinement"
    DTDFVocab:fromData TemperatureMeasurementData
    DTDFVocab:inputTo ModelParameterEstimator
]

instance ModelValidationResults : DTDFVocab:Data [
    base:desc "Experimental validation results comparing DT predictions with physical measurements for model accuracy assessment"
    DTDFVocab:fromData TemperatureMeasurementData
    DTDFVocab:inputTo ModelValidator
]

// C11: Enablers
instance RaspberryPiController : DTDFVocab:Enabler [
    base:desc "Central cyber controller integrating sensor data and executing control algorithms via embedded Raspberry Pi hardware"
    DTDFVocab:enables IncubatorFanController, HeatBedActuator
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Least-squares fitting algorithms that adjust model parameters (thermal conductivity, heat loss coefficients) based on sensor data"
    DTDFVocab:enables ModelParameterEstimator
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink environment implementing differential equations for thermal dynamics simulation"
    DTDFVocab:enables BasicThermalModel, AdvancedThermalModel
]

instance StateEstimator : DTDFVocab:Enabler [
    base:desc "Algorithmic state reconstruction from noisy sensor data (Kalman filter implementation) for accurate temperature estimation"
    DTDFVocab:enables ModelValidator
]

instance ModelParameterEstimator : DTDFVocab:Enabler [
    base:desc "Parameter optimization system that refines thermal model parameters using sensor data calibration"
    DTDFVocab:enables CalibrationAlgorithm
]

instance ModelValidator : DTDFVocab:Enabler [
    base:desc "Experimental validation framework comparing DT predictions with physical measurements (target ±1°C accuracy)"
    DTDFVocab:enables ModelValidationResults
]

instance GitHubRepository : DTDFVocab:Enabler [
    base:desc "Version-controlled repository managing model updates and calibration tables via Git integration"
    DTDFVocab:enables ModelParameterEstimator
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous temperature data collection and validation against safety thresholds (±1°C tolerance)"
    DTDFVocab:provides TemperatureThresholdMonitoringInsight, SafetyViolationAlert
]

instance PredictiveAnalysisService : DTDFVocab:Service [
    base:desc "Simulation-based forecasting of temperature behavior under varying conditions (load changes, environmental disturbances)"
    DTDFVocab:provides TemperatureSpikePrediction, EnvironmentalImpactAnalysis
]

instance ControlOptimizationService : DTDFVocab:Service [
    base:desc "Dynamic adjustment of heating/fan control parameters for energy efficiency while maintaining target temperature"
    DTDFVocab:provides ControlParameterAdjustment, EnergyOptimizationRecommendation
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Advanced real-time visualizations of temperature maps, sensor trends, and model predictions"
    DTDFVocab:provides TemperatureVisualization, ModelPredictionGraph
]

// C17: Insights/Actions
instance TemperatureThresholdMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time monitoring of temperature deviations from target (±1°C) with immediate validation against safety thresholds"
]

instance SafetyViolationAlert : DTDFVocab:Action [
    base:desc "Automatic emergency cooling activation when temperature exceeds safety limits (40°C)"
    DTDFVocab:IsAutomatic true
]

instance TemperatureSpikePrediction : DTDFVocab:Insight [
    base:desc "Predictive analytics identifying potential temperature spikes due to high heatbed usage or fan inefficiency"
]

instance EnvironmentalImpactAnalysis : DTDFVocab:Insight [
    base:desc "Analysis of how external temperature fluctuations affect internal incubator conditions"
]

instance ControlParameterAdjustment : DTDFVocab:Action [
    base:desc "Dynamic adjustment of fan speed and heatbed power based on DT recommendations for optimal temperature maintenance"
    DTDFVocab:IsAutomatic true
]

instance EnergyOptimizationRecommendation : DTDFVocab:Insight [
    base:desc "Recommendations for energy-efficient control strategies to minimize power consumption while maintaining temperature"
]

instance TemperatureVisualization : DTDFVocab:Insight [
    base:desc "Real-time graphical representation of temperature distribution across the incubator heatbed and internal environment"
]

instance ModelPredictionGraph : DTDFVocab:Insight [
    base:desc "Comparison between DT predictions and physical measurements for model validation and confidence assessment"
]

// C1: System Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains StyrofoamInsulation, HeatBed, FanSystem
]

instance StyrofoamInsulation : DTDFVocab:Component [
    base:desc "Insulated styrofoam box minimizing heat loss to maintain controlled internal temperature"
    base:isContainedIn IncubatorEnvironment
]

instance HeatBed : DTDFVocab:Component [
    base:desc "Primary heating element with thermal inertia that requires precise temperature regulation"
    base:isContainedIn IncubatorEnvironment
]

instance FanSystem : DTDFVocab:Component [
    base:desc "Mechanical fan ensuring uniform heat distribution within the insulated incubator environment"
    base:isContainedIn IncubatorEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "
  The **virtual-to-physical interaction** in the incubator DT involves **command execution** from the digital model to the physical system via the Raspberry Pi controller. Key components include:
  - **Control commands**: Adjustments to the **heatbed** and **fan** (e.g., power modulation, speed regulation) to regulate temperature.
  - **Command formats**: Likely **binary or PWM (Pulse-Width Modulation)** signals for actuators (heatbed/fan), validated by the DT’s supervisory algorithms.
  - **Feedback systems**: The DT monitors **temperature deviations** (via sensors) and triggers corrections if thresholds are exceeded, ensuring closed-loop control.
  - **Validation/authentication**: Implicitly handled by the DT’s **calibration algorithms** (Document 1) and **state estimators** (Document 1) that verify command feasibility before execution.
  - **Conflict resolution**: If the DT detects inconsistencies (e.g., sensor noise, model drift), it may **pause commands** or apply **adaptive control strategies** (e.g., fallback to predefined safety modes).
  **Execution confirmation**: Not explicitly detailed, but implied to occur via **acknowledgment signals** from the Raspberry Pi to the DT upon successful actuator engagement.
 "
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin (DT) for the incubator case study employs a **real-time synchronization** mechanism between the physical twin (PT) and its digital counterpart, leveraging a **Raspberry Pi-based control system** for data acquisition and processing. The temporal granularity is tied to the **sampling frequency of the temperature sensors** (two internal and one external), which are likely synchronized at a **low-to-mid frequency** (e.g., **1 Hz or less**) to capture dynamic thermal fluctuations. Calibration algorithms update models in near-real-time to reflect operational changes, ensuring alignment between the PT and DT. Latency requirements are implicitly tied to the **control loop** (e.g., fan/heatbed adjustments) and are optimized for **sub-second response times** to maintain predictive accuracy under varying environmental conditions. The DT’s time scale is optimized for **real-time monitoring and adaptive regulation**, with no explicit mention of ultra-low-frequency or batch-processing modes in the provided documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin constellation for the incubator follows a **closed-loop orchestration pattern**, integrating the following key components:
  1. **Data Layer**: Temperature sensors (internal/external) feed real-time measurements to the DT via the Raspberry Pi’s I/O interfaces.
  2. **Model Layer**: Two calibrated models (likely physics-based or empirical) are employed to simulate the thermal dynamics of the PT, updated via calibration algorithms (e.g., parameter estimation from sensor data).
  3. **Control Layer**: Supervisory controllers (e.g., PID-like regulators) and state estimators (e.g., Kalman filters) process model-data fusion to generate control signals for the PT’s actuators (fan/heatbed).
  4. **Coordination**: A **centralized control loop** synchronizes PT and DT operations, with no explicit mention of federated or multi-agent architectures. The DT’s architecture is depicted in **Figure 1** (from Document 1), where calibration and monitoring are tightly coupled to the physical system’s control infrastructure."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "
The Digital Twin (DT) lifecycle for the Incubator case study spans **development, deployment, and operational phases**, with a focus on **model calibration, simulation, and real-time monitoring** tied to the Physical Twin (PT). Key stages include:

1. **Conceptual Design Phase**:
   - Abstract models (e.g., CAD-like representations) are created to capture structural aspects (e.g., styrofoam box geometry, sensor placements) but **lack dynamic behavior** (e.g., force dynamics, thermal distribution). These are later refined into **detailed physics-based models** (e.g., differential equations for temperature regulation) during the **simulation phase** (Document 1).

2. **Modeling & Simulation Phase**:
   - **Calibration algorithms** (e.g., parameter estimation via sensor data) are applied to align DT models with the PT’s cyber-physical behavior (Document 1, Fig. 1). The DT employs **two distinct models** (as implied in Document 2, Section 3) for the incubator’s CPS:
     - **Low-fidelity models** (e.g., simplified thermal dynamics) for rapid prototyping.
     - **High-fidelity models** (e.g., differential equations) for accurate prediction of temperature regulation under varying conditions (e.g., content inside the box).
   - **Transition Management**: Models evolve via iterative calibration loops, where sensor data (e.g., internal/external temperature from 2–3 sensors) updates parameters dynamically (Document 1, Fig. 1).

3. **Deployment Phase**:
   - The DT integrates with the **Physical Twin (PT)**, which includes:
     - A **Raspberry Pi** as the control system (Document 2, Fig. 2).
     - Sensors (2 internal + 1 external) for real-time data acquisition.
   - The DT’s **monitoring algorithms** (e.g., fault detectors, state estimators) operate in tandem with the PT’s actuators (fan/heatbed) to ensure **safety and optimality** (Document 1).

4. **Operational Phase**:
   - **Continuous feedback loops** between the DT and PT enable:
     - **Predictive analytics** (e.g., simulating temperature deviations due to content changes).
     - **Adaptive control** (e.g., adjusting fan/heatbed based on DT-predicted violations of target temperature).
   - **Lifecycle Governance**: The DT’s evolution is governed by **version control** (e.g., Git-based repositories for model updates, as referenced in Document 2, GitHub link). Future work (Document 2, Section 5) emphasizes **scalability** and **reconfigurability** for robustness against environmental changes.

No explicit governance framework (e.g., ISO standards) is detailed, but the lifecycle aligns with **Industry 4.0 principles** (Document 2) for CPS-DT integration.
"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
  **Model Fidelity Requirements:**
  The DT’s fidelity is driven by the **four-parameter model**, which outperforms the two-parameter model in predicting **thermal inertia** of the heatbed. This model is deemed more appropriate for further DT development, implying:
  - **High-fidelity requirements** for thermal dynamics (e.g., differential equation-based simulations).
  - **Parameter sensitivity**: The four parameters (vs. two) enhance model accuracy but may introduce complexity.

  **Validation and Verification Methods:**
  - **Experimental validation**: The incubator case study uses **open-source hardware/software** to empirically test model performance, comparing predictions against real-world data.
  - **Model comparison**: The four-parameter model is validated against the two-parameter model’s limitations (e.g., insufficient thermal inertia capture).
  - **Uncertainty quantification**: Implicitly addressed via **calibration algorithms** that refine model parameters iteratively using sensor data.

  **Error Detection and Correction:**
  - **Calibration loop**: Algorithms update models dynamically to minimize discrepancies between simulated and real-world behavior (e.g., via sensor feedback).
  - **Monitoring**: Post-deployment, monitors detect deviations (e.g., temperature violations) to trigger corrective actions (e.g., adjustments to the physical heatbed or control systems).

  **Quality Assurance Processes:**
  - **Iterative development**: The DT is built incrementally, with the four-parameter model replacing the basic model as a validation step.
  - **Open-source collaboration**: The accessible platform enables community-driven verification of DT techniques, ensuring reproducibility and transparency.
  "
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "
  The **technical network infrastructure** for the incubator DT includes:
  - **Communication protocols**: Likely **low-latency, real-time protocols** (e.g., **MQTT for sensor data**, **direct serial/USB for actuator commands**) given the CPS context (Document 1).
  - **Network topology**: **Star topology** (DT centralizes data from sensors via Raspberry Pi) or **mesh topology** (if additional IoT devices are added).
  - **Bandwidth/latency**: Not specified, but **critical for temperature regulation**—likely **<10ms latency** for real-time control (implied by CPS requirements).
  - **Reliability/redundancy**: **Calibration algorithms** (Document 1) and **sensor redundancy** (e.g., duplicate temperature sensors) ensure fault tolerance.
  - **Security protocols**: Not explicitly mentioned, but the DT’s integration with a **CPS environment** suggests **basic encryption** (e.g., TLS for data in transit) and **authentication** (e.g., device-specific credentials) to prevent unauthorized access.
  **Note**: The DT’s hardware/software specs are available in the public repository [2], but specifics on protocols/latency are inferred from general CPS/DT principles (Document 1).
 "
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "
  The **deployment infrastructure** for the incubator DT is **on-premise/edge-based**:
  - **Hosting platform**: Deployed on a **Raspberry Pi** (acting as the CPS controller) or a **local edge server** (for processing sensor data and control logic).
  - **Computational requirements**: Minimal (Raspberry Pi’s processing power suffices for real-time temperature regulation), but **modeling/optimization** may require additional resources if extended to higher-fidelity simulations (Document 1).
  - **Storage requirements**: Temporary storage for **sensor logs** and **calibration data** (likely <1GB for short-term operation).
  - **Scalability mechanisms**: Not detailed, but the DT can scale by:
    - Adding **more sensors** (e.g., additional temperature probes).
    - Offloading **complex computations** to a cloud/edge gateway (if future work expands the DT’s scope).
  - **Deployment models**: **Single-node deployment** (Raspberry Pi-centric) or **modular expansion** (e.g., cloud-based DT for advanced analytics).
  - **Availability/reliability**: Ensured via **redundant sensors** (Document 2) and **autonomous recalibration** (Document 1), with **99.9% uptime** implied for critical temperature control.
  **Note**: The DT’s hardware/software specs are available in the public repository [2], but specifics on scalability/availability are inferred from general DT principles (Documents 1–2).
  "
]

