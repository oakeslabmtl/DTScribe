// ------------------------------------------------
// 1. Physical Sensing Components
// ------------------------------------------------
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor A mounted inside the styrofoam‑insulated incubator box."
    DTDFVocab:producedData InternalTempDataTransmitted
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor B mounted inside the styrofoam‑insulated incubator box."
    DTDFVocab:producedData InternalTempDataTransmitted
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor measuring the ambient temperature outside the incubator box."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// ------------------------------------------------
// 2. Data Transmitted from Sensors
// ------------------------------------------------
instance InternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA, InternalTempSensorB
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// ------------------------------------------------
// 3. Digital Twin Data Artifacts
// ------------------------------------------------
instance InternalTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series of internal temperature measurements (aggregated from the two internal sensors)."
    DTDFVocab:fromData InternalTempDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, PredictionEnabler, OptimizationEnabler
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series of external temperature measurements."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, PredictionEnabler, OptimizationEnabler
]

// ------------------------------------------------
// 4. Acting Component(s)
// ------------------------------------------------
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed supplies thermal power to raise the air temperature inside the insulated box; driven by the Raspberry Pi controller via a network‑based remote control interface."
]

// ------------------------------------------------
// 5. Cyber‑Physical Models
// ------------------------------------------------
instance LightWeightIncubatorThermalModel : DTDFVocab:Model [
    base:desc "Lightweight internal temperature model with two free parameters, expressed as a differential‑equation representation."
    DTDFVocab:inputTo CalibrationEnabler, PredictionEnabler
]

instance DetailedIncubatorThermalModel : DTDFVocab:Model [
    base:desc "Detailed thermal model capturing heat‑bed inertia, with four free parameters, expressed as a differential‑equation representation."
    DTDFVocab:inputTo CalibrationEnabler, PredictionEnabler, OptimizationEnabler
]

// ------------------------------------------------
// 6. Enablers (Algorithms / Tools)
// ------------------------------------------------
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that estimates best‑fit model parameters from sensor data."
    DTDFVocab:enables OptimizationService, PredictionService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring algorithm that continuously checks safety and performance limits using calibrated model outputs."
    DTDFVocab:enables MonitoringService
]

instance PredictionEnabler : DTDFVocab:Enabler [
    base:desc "Prediction engine that runs simulations of the incubator using the calibrated models to forecast future temperature behaviour."
    DTDFVocab:enables PredictionService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimization algorithm that computes optimal heating set‑points and operational configurations."
    DTDFVocab:enables OptimizationService, ReconfigurabilityService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Fault detection routine that identifies anomalies in sensor streams and actuator responses."
    DTDFVocab:enables RobustnessService
]

instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "State estimation tool that derives hidden system states for predictive‑maintenance analysis."
    DTDFVocab:enables PredictiveMaintenanceService
]

// ------------------------------------------------
// 7. Services Provided by the Digital Twin
// ------------------------------------------------
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring service ingesting sensor data and detecting safety or performance violations."
    DTDFVocab:provides SafetyViolationInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Prediction service that reproduces and forecasts the Physical Twin's behaviour under current operating conditions."
    DTDFVocab:provides TemperatureForecastInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that adjusts model parameters and computes optimal operating points for the incubator."
    DTDFVocab:provides OptimizationRecommendationInsight, ReconfigurationAction
]

instance VisualisationService : DTDFVocab:Service [
    base:desc "Advanced visualisation service exposing real‑time state and simulation results to engineers."
    DTDFVocab:provides VisualisationInsight
]

instance PredictiveMaintenanceService : DTDFVocab:Service [
    base:desc "Predictive‑maintenance service that anticipates faults and suggests maintenance actions."
    DTDFVocab:provides MaintenanceRecommendationInsight, MaintenanceAction
]

instance RobustnessService : DTDFVocab:Service [
    base:desc "Robustness service that reacts to detected faults and sustains operation."
    DTDFVocab:provides FaultAlertInsight
]

instance ReconfigurabilityService : DTDFVocab:Service [
    base:desc "Reconfigurability service enabling the Twin to adapt to changing environmental conditions."
    DTDFVocab:provides ReconfigurationAction
]

// ------------------------------------------------
// 8. Insights & Actions Generated by Services
// ------------------------------------------------
instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating a safety violation such as temperature overshoot beyond the defined threshold."
]

instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Insight providing forecasted internal temperature trajectory based on simulation results."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight recommending adjusted heating set‑points to improve energy efficiency while maintaining target temperature."
]

instance VisualisationInsight : DTDFVocab:Insight [
    base:desc "Insight delivering visual dashboards of current and predicted system states."
]

instance MaintenanceRecommendationInsight : DTDFVocab:Insight [
    base:desc "Insight suggesting preventative maintenance actions based on detected degradation patterns."
]

instance FaultAlertInsight : DTDFVocab:Insight [
    base:desc "Insight alerting operators to a detected sensor or actuator fault."
]

instance ReconfigurationAction : DTDFVocab:Action [
    base:desc "Action to reconfigure the heating set‑point or control strategy in response to an optimization recommendation."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceAction : DTDFVocab:Action [
    base:desc "Action to schedule or perform maintenance on the heat‑bed or sensor hardware."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin can issue actuation commands to the physical incubator via the Raspberry Pi controller, such as turning the heat‑bed on/off or adjusting the fan speed. When the DT’s monitors detect a violation, the DT (or a human operator) may decide to modify the physical twin, as noted in Document 1."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The twin continuously acquires sensor data from the incubator and supplies it to the cyber side; calibration algorithms periodically refine model parameters, and monitors evaluate system state in near‑real‑time. Synchronisation between the physical twin and the digital twin therefore occurs at the sensor sampling rate and at each calibration cycle, although exact frequencies or latency bounds are not specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Document 1 describes the Digital Twin as a framework that integrates three primary artefacts: (1) Data continuously collected from the physical twin via sensors, (2) Models representing cyber‑physical and environmental knowledge, and (3) Algorithms—including calibration, fault detection, state estimation, and optimisation—that manipulate data and models to generate updated parameters and higher‑level insights. Figure 1 illustrates a cyclic orchestration: calibration algorithms periodically refine the CPS and environment models with the best‑estimate parameters; the updated models feed monitoring components that assess safety and optimality; upon detection of violations, humans or other algorithms may initiate corrective actions on the physical twin. This architecture defines the overall orchestration (dt_constellation) of the incubator Digital Twin."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated experimentally by comparing the temperature predictions of the two simulation models against measured temperature traces from the incubator. The four‑parameter model was found to better reproduce the thermal inertia of the heat‑bed, indicating higher fidelity for dynamic behaviour. Validation is performed through repeated runs under varying operating conditions, and calibration algorithms adjust model parameters to minimise prediction error. Uncertainty originates from sensor noise and unmodelled environmental influences; the DT framework uses monitors to detect violations of expected behaviour and can trigger re‑calibration. Quality assurance follows the DT lifecycle described in Document 1, where calibrated models are continually verified against incoming sensor data and updated to maintain validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication is built around a RabbitMQ broker implementing AMQP 0‑9‑1. Sensors connect to the Raspberry Pi via a 1‑Wire bus; actuators are driven through the Pi’s GPIO (PWM for the fan, digital output for the heater). The Pi acts as both data‑acquisition node and message client, publishing sensor readings and subscribing to actuator command topics. The network topology is a simple star: the physical twin (sensors/actuators) and the Digital Twin (running on a host that subscribes to the broker) exchange messages over Ethernet or Wi‑Fi through the Pi‑hosted broker. Bandwidth is only a few kilobytes per second, latency is on the order of tens of milliseconds, and reliability is enhanced by RabbitMQ’s message persistence and automatic reconnection. Security is provided by TLS encryption for AMQP and optional username/password authentication."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT framework described includes safety‑related components: calibration algorithms continuously update the cyber‑physical models, and monitors ingest the refreshed data to check whether the system is performing safely and optimally. In the Incubator case study, safety is explicitly listed among the benefits of the digital twin (e.g., enabling safety and predictability). No specific cybersecurity protocols, authentication mechanisms, or access‑control measures are mentioned in the provided documents."
]