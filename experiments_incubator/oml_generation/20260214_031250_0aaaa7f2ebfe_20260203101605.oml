// C3: Physical sensing components
instance InsideIncubatorTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer placed inside the incubator (range –55 °C to +125 °C, accuracy 0.5 °C)."
    DTDFVocab:producedData TemperatureMessage
]

instance InsideIncubatorTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 high‑precision 1‑Wire digital thermometer placed inside the incubator."
    DTDFVocab:producedData TemperatureMessage
]

instance AmbientRoomTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 thermometer measuring ambient room temperature, connected to the same GPIO bus."
    DTDFVocab:producedData TemperatureMessage
]

// C4: Physical-to-virtual interaction
instance TemperatureMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideIncubatorTempSensor1, InsideIncubatorTempSensor2, AmbientRoomTempSensor
    base:desc "Periodic temperature readings packaged as AMQP messages published to a RabbitMQ broker on the Raspberry Pi."
]

// C10: Data
instance InsideIncubatorTempData1 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature stream from InsideIncubatorTempSensor1."
    DTDFVocab:fromData TemperatureMessage
    DTDFVocab:inputTo RabbitMQBroker, CalibrationEngine
]

instance InsideIncubatorTempData2 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature stream from InsideIncubatorTempSensor2."
    DTDFVocab:fromData TemperatureMessage
    DTDFVocab:inputTo RabbitMQBroker, CalibrationEngine
]

instance AmbientRoomTempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature stream from AmbientRoomTempSensor."
    DTDFVocab:fromData TemperatureMessage
    DTDFVocab:inputTo RabbitMQBroker, CalibrationEngine
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker running on the Raspberry Pi, receives temperature messages from the low‑level driver."
    DTDFVocab:enables RealTimeMonitoringService, FaultDetectionService, CalibrationService, OptimizationService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Python calibration component using SciPy’s non‑linear least‑squares solver to fit Model A/B parameters."
    DTDFVocab:enables CalibrationService, SimulationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Python simulation module executing thermal models (Model A, Model B) for predictive control."
    DTDFVocab:enables SimulationService
]

instance LowLevelGPIODriver : DTDFVocab:Enabler [
    base:desc "Low‑level driver abstracting Raspberry Pi GPIO access, isolates controller via optocouplers on the PCB."
    DTDFVocab:enables ActuationControlService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature limits using incoming sensor streams."
    DTDFVocab:provides TemperatureLimitViolationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Safety checks that detect out‑of‑range temperature conditions and hardware faults."
    DTDFVocab:provides FaultDetectionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Automatic calibration of thermal model parameters (C_air, G_box, C_heater, G_heater) from sensor data."
    DTDFVocab:provides CalibrationResultInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Bang‑bang controller optimizing heating duration and waiting periods based on calibrated models."
    DTDFVocab:provides HeatingAdjustmentAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Physics‑based thermal simulation using Model A and Model B."
    DTDFVocab:provides SimulationResultInsight
]

instance ActuationControlService : DTDFVocab:Service [
    base:desc "Issue on/off or speed commands to heat‑bed and fan via GPIO‑controlled MOSFET drivers."
    DTDFVocab:provides HeatBedOnAction, FanSpeedAction
]

// C17: Insights
instance TemperatureLimitViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature readings that exceed configured lower or upper limits."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of hardware faults such as MOSFET driver failure or sensor disconnect."
]

instance CalibrationResultInsight : DTDFVocab:Insight [
    base:desc "Calibrated model parameters (C_air, G_box, C_heater, G_heater) with residual statistics."
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectories from Model A or Model B."
]

// C17: Actions
instance HeatingAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjust heating duration and waiting period to keep temperature within safety bounds."
    DTDFVocab:IsAutomatic true
]

instance HeatBedOnAction : DTDFVocab:Action [
    base:desc "Turn the resistive heat‑bed on via MOSFET driver."
    DTDFVocab:IsAutomatic false
]

instance FanSpeedAction : DTDFVocab:Action [
    base:desc "Set fan speed (on/off or PWM) through MOSFET driver."
    DTDFVocab:IsAutomatic false
]

// C2: Acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed powered on/off by a MOSFET driver, command received from Raspberry Pi GPIO."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal fan controlled (on/off or speed) via MOSFET driver, command received from Raspberry Pi GPIO."
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Dynamic thermal model A with parameters C_air and G_box."
    DTDFVocab:inputTo CalibrationEngine, SimulationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Dynamic thermal model B extending Model A with heater capacitance C_heater and conductance G_heater."
    DTDFVocab:inputTo CalibrationEngine, SimulationEngine
]

// System under study – environment and components
instance InsulatedIncubatorBox : DTDFVocab:Component [
    base:desc "Insulated styrofoam box (~0.03 m³ air volume) hosting heat‑bed, fan and sensors."
]

instance PCBWithDrivers : DTDFVocab:Component [
    base:desc "Printed‑circuit board containing MOSFET drivers and optocouplers for electrical isolation."
]

instance PowerSupplyUnit : DTDFVocab:Component [
    base:desc "5 V power supply feeding the PCB and Raspberry Pi."
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B that runs the DT software, low‑level driver, and RabbitMQ broker."
]

instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InsulatedIncubatorBox, HeatBedActuator, FanActuator,
               InsideIncubatorTempSensor1, InsideIncubatorTempSensor2, AmbientRoomTempSensor,
               PCBWithDrivers, PowerSupplyUnit, RaspberryPiController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT services publish control commands (heat‑bed on/off, fan on/off, waiting durations) to the same RabbitMQ broker; the controller subscribes to these messages and forwards them to the low‑level driver, which drives the MOSFETs on the PCB to affect the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture comprises the PT (box, heat‑bed, fan, sensors, PCB, Pi), a low‑level driver interfacing hardware, a controller implementing the bang‑bang logic, a RabbitMQ communication server on the Pi, and DT components (simulation, calibration, monitoring) that subscribe/publish to the broker, forming a closed feedback loop."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is based on four assumptions (uniform temperature, negligible wall heat storage, constant air specific heat, negligible heat‑bed loss). Validity is assessed via (a) uniformity experiments confirming fan‑induced mixing, (b) calibration against measured temperature trajectories, and (c) comparison of Model A vs Model B residual errors."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual and virtual‑to‑physical messages are exchanged over the RabbitMQ message broker using the AMQP protocol over TCP/IP on the local Raspberry Pi network."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ server and all DT software components (controller, low‑level driver, simulation and calibration modules) are deployed on the Raspberry Pi 4 Model B that also hosts the PT controller."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the device in a safe state; electrical isolation is provided by optocouplers on the PCB, reducing risk of uncontrolled actuation. Safety monitoring is performed by DT monitors that check temperature limits before allowing actuator commands."
]