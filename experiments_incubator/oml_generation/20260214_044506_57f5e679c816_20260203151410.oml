// Sensing Components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor 1 located inside the styrofoam insulated incubator box (DS18S20) measuring internal temperature."
    DTDFVocab:producedData InternalTempTelemetry1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor 2 located inside the styrofoam insulated incubator box (DS18S20) measuring internal temperature."
    DTDFVocab:producedData InternalTempTelemetry2
]

instance RoomTempSensor : DTDFVocab:SensingComponent [
    base:desc "Room temperature sensor positioned outside the incubator box (DS18S20) measuring ambient room temperature."
    DTDFVocab:producedData RoomTempTelemetry
]

// Data Transmitted
instance InternalTempTelemetry1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempTelemetry2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance RoomTempTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTempSensor
]

// Data Logs
instance InternalTempLog1 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature log from internal sensor 1."
    DTDFVocab:fromData InternalTempTelemetry1
    DTDFVocab:inputTo SimulationBrain, CalibrationOptimizer
]

instance InternalTempLog2 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature log from internal sensor 2."
    DTDFVocab:fromData InternalTempTelemetry2
    DTDFVocab:inputTo SimulationBrain, CalibrationOptimizer
]

instance RoomTempLog : DTDFVocab:Data [
    base:desc "Time‑stamped temperature log from room sensor."
    DTDFVocab:fromData RoomTempTelemetry
    DTDFVocab:inputTo SimulationBrain, CalibrationOptimizer
]

// Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed electric heating element driven via MOSFET isolated by optocoupler from Raspberry Pi GPIO."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V fan driven via MOSFET isolated by optocoupler from Raspberry Pi GPIO."
]

// Actuator State Telemetry
instance HeatbedStateTelemetry : DTDFVocab:DataTransmitted [
    // Telemetry originates from the heatbed actuator
]

instance FanStateTelemetry : DTDFVocab:DataTransmitted [
    // Telemetry originates from the fan actuator
]

// Actuator State Logs
instance HeatbedStateLog : DTDFVocab:Data [
    base:desc "Log of heatbed on/off state."
    DTDFVocab:fromData HeatbedStateTelemetry
    DTDFVocab:inputTo SimulationBrain, CalibrationOptimizer
]

instance FanStateLog : DTDFVocab:Data [
    base:desc "Log of fan on/off state."
    DTDFVocab:fromData FanStateTelemetry
    DTDFVocab:inputTo SimulationBrain, CalibrationOptimizer
]

// Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Model A: Temperature dynamics expressed as an ODE with parameters C_air and G_box."
    DTDFVocab:inputTo SimulationBrain, CalibrationOptimizer
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Model B: Temperature dynamics expressed as an ODE with parameters C_air, G_box, C_heater and G_heater."
    DTDFVocab:inputTo SimulationBrain, CalibrationOptimizer
]

// Enablers
instance SimulationBrain : DTDFVocab:Enabler [
    base:desc "Python simulation engine that executes Model A and Model B ODEs."
    DTDFVocab:enables SimulationService, VisualizationService
]

instance CalibrationOptimizer : DTDFVocab:Enabler [
    base:desc "SciPy nonlinear least‑squares optimizer for parameter estimation."
    DTDFVocab:enables CalibrationService
]

instance RabbitMQSubscriber : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker subscriber that ingests telemetry from Raspberry Pi."
    DTDFVocab:enables MonitoringService
]

instance PiDriver : DTDFVocab:Enabler [
    base:desc "Python low‑level driver on Raspberry Pi that reads sensors and issues control signals."
    DTDFVocab:enables MonitoringService, CalibrationService
]

// Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Run‑time simulation of thermal dynamics using Model A and Model B."
    DTDFVocab:provides UpdateModelParametersAction
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of temperature trajectories and actuation states."
    DTDFVocab:provides TemperatureDiscrepancyInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Automated calibration of the DT model parameters via non‑linear least‑squares optimization."
    DTDFVocab:provides CalibrationResultInsight, UpdateModelParametersAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Predictive fault detection based on temperature discrepancies."
    DTDFVocab:provides FaultPredictionInsight, AdjustControlLimitsAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Real‑time visualization dashboards for incubator state."
    DTDFVocab:provides TemperatureDiscrepancyInsight, CalibrationResultInsight, FaultPredictionInsight
]

// Insights
instance TemperatureDiscrepancyInsight : DTDFVocab:Insight [
    base:desc "Insight indicating temperature discrepancy that may signal insufficient fan flow or heatbed degradation."
]

instance CalibrationResultInsight : DTDFVocab:Insight [
    base:desc "Insight reporting updated model parameters after calibration."
]

instance FaultPredictionInsight : DTDFVocab:Insight [
    base:desc "Insight predicting potential future faults in temperature control."
]

// Actions
instance UpdateModelParametersAction : DTDFVocab:Action [
    base:desc "Action to automatically update the DT model parameters to improve operation."
    DTDFVocab:IsAutomatic true
]

instance AdjustControlLimitsAction : DTDFVocab:Action [
    base:desc "Action to adjust temperature control limits based on detected discrepancies."
    DTDFVocab:IsAutomatic true
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Digital twin environment encompassing the physical incubator and all associated components."
    base:contains HeatbedActuator, FanActuator, InternalTempSensor1, InternalTempSensor2, RoomTempSensor, PiDriver, RabbitMQSubscriber, SimulationBrain, CalibrationOptimizer
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (heatbed ON/OFF, fan ON/OFF) back to RabbitMQ where the low‑level driver consumes them and actuates the GPIO outputs, thereby modifying the PT state."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data is sampled and transmitted at a physical sampling interval of approximately one second, with the DT maintaining synchronisation by applying a near‑real‑time control loop (additive heating durations of a few seconds and a waiting duration). Simulation and optimisation operate within the same time frame, enabling predictive analytics on the same timescale as the physical process."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation comprises the physical plant (insulated box, heatbed, fan, sensors, Raspberry Pi controller), the communication layer (RabbitMQ broker), the low‑level driver that bridges physical IO, the controller algorithm, and the DT processing nodes that subscribe to the broker for telemetry, perform simulations, calibrations, and publish control actions."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the design (ideal model creation), manufacturing (hardware assembly and software deployment), and operation (runtime monitoring, parameter calibration, and optimisation) phases, following a model‑at‑runtime approach."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing simulated temperature trajectories against experimental data, using a non‑linear least‑squares cost function. Validation assumes four physical assumptions; Model B provides better fit for thermal inertia. Uncertainty arises from sensor precision (±0.5 °C) and unmodeled heat loss; V&V is performed by root‑mean‑square error metrics and sensitivity analysis."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The primary virtual–physical link is a TCP/IP AMQP channel over the local Wi‑Fi network (Raspberry Pi hosts RabbitMQ). Physical IO is accessed via the Raspberry Pi GPIO through a 1‑wire bus for the DS18S20 and a MOSFET/optocoupler interface for heating and fan actuators."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin is deployed locally on the Raspberry Pi 4 Model B hardware, running RabbitMQ and the Python DT services; no remote or cloud hosting is employed in the presented case study."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is embedded in the low‑level driver to prevent unsafe actuator states; the use of Raspberry Pi GPIO isolation via optocouplers protects the controller. The system relies on open communication (RabbitMQ AMQP) with no explicit cybersecurity mechanisms described."
]