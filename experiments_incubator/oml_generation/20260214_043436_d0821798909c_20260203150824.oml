// ----- Physical sensing components -----
instance InsideTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside the incubator (point 1) 0.5 °C accuracy, 1‑Wire bus connected to Raspberry Pi."
    DTDFVocab:producedData InsideTempDataTransmitted1
]

instance InsideTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside the incubator (point 2) 0.5 °C accuracy, 1‑Wire bus connected to Raspberry Pi."
    DTDFVocab:producedData InsideTempDataTransmitted2
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 ambient temperature sensor mounted outside the incubator 0.5 °C accuracy, 1‑Wire bus connected to Raspberry Pi."
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// ----- Actuating components -----
instance HeatBedMOSFETActuator : DTDFVocab:ActingComponent [
    base:desc "MOSFET controlled heat‑bed element delivering electrical heating to the incubator."
]

instance FanPWMActuator : DTDFVocab:ActingComponent [
    base:desc "PWM‑controlled fan for regulating airflow through the incubator."
]

// ----- Data transmitted instances -----
instance InsideTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor1
    base:desc "Temperature data stream from InsideTemperatureSensor1 transmitted via RabbitMQ topic exchange."
]

instance InsideTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor2
    base:desc "Temperature data stream from InsideTemperatureSensor2 transmitted via RabbitMQ topic exchange."
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTemperatureSensor
    base:desc "Ambient temperature data stream from AmbientTemperatureSensor transmitted via RabbitMQ topic exchange."
]

// ----- Data instances used in DT -----
instance InsideTemperatureData1 : DTDFVocab:Data [
    base:desc "Raw temperature measurement from InsideTemperatureSensor1 used for parameter estimation and validation."
    DTDFVocab:fromData InsideTempDataTransmitted1
    DTDFVocab:inputTo PiGPIOBridge, PythonCalibrator, SimulationEngine
]

instance InsideTemperatureData2 : DTDFVocab:Data [
    base:desc "Raw temperature measurement from InsideTemperatureSensor2 used for parameter estimation and validation."
    DTDFVocab:fromData InsideTempDataTransmitted2
    DTDFVocab:inputTo PiGPIOBridge, PythonCalibrator, SimulationEngine
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Raw ambient temperature measurement used for environmental context in simulations."
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo PiGPIOBridge, PythonCalibrator, SimulationEngine
]

// ----- Enablers -----
instance PiGPIOBridge : DTDFVocab:Enabler [
    base:desc "Raspberry Pi library for GPIO and 1‑Wire communication reads sensor data and publishes to RabbitMQ."
    DTDFVocab:enables DataTransportService
]

instance PythonCalibrator : DTDFVocab:Enabler [
    base:desc "Python engine using scipy.optimize to perform non‑linear least‑squares calibration of ModelA and ModelB."
    DTDFVocab:enables CalibrationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Python simulation engine that executes ModelA and ModelB to predict future temperature trajectories."
    DTDFVocab:enables TemperaturePredictionService
]

// ----- Services -----
instance DataTransportService : DTDFVocab:Service [
    base:desc "Service that receives serialized temperature data from RabbitMQ and forwards it to downstream services."
    DTDFVocab:provides DataIngestionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that calibrates thermal models using experimental sensor data."
    DTDFVocab:provides ParameterEstimationInsight
]

instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Service that runs ModelA and ModelB to produce predicted temperature trajectories."
    DTDFVocab:provides PredictedTemperatureTrajectoryInsight, AnomalyPredictionInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors real‑time temperature trends and triggers alarms when thresholds are breached."
    DTDFVocab:provides TemperatureAlarmInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Service that visualizes sensor data and simulation output for operator monitoring."
    DTDFVocab:provides DataVisualizationInsight
]

instance SupervisoryControlProxyService : DTDFVocab:Service [
    base:desc "Proxy for supervisory control that suggests control adjustments and detects equipment faults."
    DTDFVocab:provides SuggestedControlAdjustmentAction, FaultDetectionInsight
]

// ----- Models -----
instance ModelA : DTDFVocab:Model [
    base:desc "Physics‑based temperature dynamics model assuming all power goes to the air uses single thermal conductance G_box."
    DTDFVocab:inputTo SimulationEngine
]

instance ModelB : DTDFVocab:Model [
    base:desc "Physics‑based temperature dynamics model incorporating heat‑bed thermal mass with conductances G_box and G_heater, and thermal capacities C_air and C_heater."
    DTDFVocab:inputTo SimulationEngine
]

// ----- Insights -----
instance DataIngestionInsight : DTDFVocab:Insight [
    base:desc "Insight indicating successful reception of temperature data in the DT."
]

instance ParameterEstimationInsight : DTDFVocab:Insight [
    base:desc "Insight containing calibrated parameter estimates for ModelA and ModelB."
]

instance PredictedTemperatureTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory over time generated by the simulation."
]

instance AnomalyPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted anomalies in temperature evolution based on model residuals."
]

instance TemperatureAlarmInsight : DTDFVocab:Insight [
    base:desc "Alarm generated when observed temperature deviates beyond safety thresholds."
]

instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visual representation of sensor data and simulation results."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of faults in heat‑bed or fan operation."
]

// ----- Actions -----
instance SuggestedControlAdjustmentAction : DTDFVocab:Action [
    base:desc "Suggested adjustment to fan speed or heater output to maintain target temperature."
    DTDFVocab:IsAutomatic false
]

// ----- Environment and Components -----
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Thermal incubator environment comprising a polystyrene box, heat‑bed, fan, sensors, and Raspberry Pi controller."
    base:contains InsideTemperatureSensor1, InsideTemperatureSensor2, AmbientTemperatureSensor, HeatBedMOSFETActuator, FanPWMActuator
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control command messages (heat‑bed on/off, fan PWM duty cycle, wait durations) to RabbitMQ. The controller listens to these messages, converts them to GPIO signals via the low‑level driver, and actuates the heat‑bed and fan accordingly. The DT also sends diagnostic and calibration updates back to the controller."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation comprises the Raspberry Pi (controller), the low‑level driver, the RabbitMQ communication server, the physics models (Model A,B), a calibration module, a monitoring module, and the sensor/actuator hardware. The PCB physically couples the Pi to the heat‑bed, fan, and sensors, while RabbitMQ provides the logical coupling between control, data gathering, and simulation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The digital twin is built during the design and manufacturing stage, calibrated and validated during the operational stage, and operates continuously during the usage phase to monitor and control the incubator. Post‑deployment, the model may be further refined as new experimental data is collected."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Assumptions include uniform internal temperature, negligible wall heat accumulation, constant air specific heat, and negligible fan heat influence. Validation is performed by comparing simulated temperature trajectories with experimental runs; Model B shows improved fidelity (captures thermal inertia). Uncertainty in parameters is handled via least‑squares residual minimization, and the model’s predictive accuracy is evaluated by RMSE against empirical data."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The physical interface uses a 1‑Wire bus for temperature sensors, GPIO for actuator control, and Wi‑Fi/Bluetooth for the Raspberry Pi’s network stack. RabbitMQ exchanges messages over TCP/IP, typically on localhost, with topic‑based routing. Control messages and sensor data follow lightweight JSON payloads."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components run on a Raspberry Pi 4 Model B. RabbitMQ server is installed locally on the Pi, leveraging the Pi’s built‑in Wi‑Fi for local network communication. No cloud hosting is referenced; the system is intended for on‑premises deployment."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is embedded in the low‑level driver to prevent unsafe actuator states; optocouplers isolate the Pi from high currents; the system relies on standard open‑source software with no intent for remote execution beyond the local Pi, thus limiting cybersecurity risk. However, no encryption or authentication mechanisms are described."
]