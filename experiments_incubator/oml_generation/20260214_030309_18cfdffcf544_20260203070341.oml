// C3: Physical sensing components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor inside the insulated styrofoam box monitoring internal temperature distribution."
    DTDFVocab:producedData IncubatorTempDataTransmitted
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor inside the insulated styrofoam box monitoring internal temperature distribution."
    DTDFVocab:producedData IncubatorTempDataTransmitted
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor positioned outside the incubator to measure ambient temperature."
    DTDFVocab:producedData IncubatorTempDataTransmitted
]

// C4: Physical-to-virtual interaction
instance IncubatorTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1, InternalTemperatureSensor2, ExternalTemperatureSensor
]

// C5: Data (from sensors)
instance IncubatorTemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature readings from internal and external sensors streamed to the Digital Twin."
    DTDFVocab:fromData IncubatorTempDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringAlgorithm, SimulationEngine
]

// C10: Models
instance TwoParamThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model of the incubator with two free parameters predicting internal temperature."
    DTDFVocab:inputTo SimulationEngine
]

instance FourParamThermalModel : DTDFVocab:Model [
    base:desc "Enhanced thermal model with four free parameters capturing heat‑bed inertia."
    DTDFVocab:inputTo SimulationEngine
]

// C11: Enablers (tooling and algorithms)
instance RabbitMQMessageBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker that receives temperature messages from the low‑level driver and distributes them to DT components."
    DTDFVocab:enables TemperaturePredictionService, ModelCalibrationService, ContinuousMonitoringService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Algorithm that calibrates model parameters using streamed temperature data."
    DTDFVocab:enables ModelCalibrationService
]

instance MonitoringAlgorithm : DTDFVocab:Enabler [
    base:desc "Algorithm that compares simulated and measured temperatures to detect safety or performance violations."
    DTDFVocab:enables ContinuousMonitoringService, ViolationDetectionService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine executing the two thermal models to predict incubator temperature dynamics."
    DTDFVocab:enables TemperaturePredictionService, OptimisationService
]

instance RaspberryPiController : DTDFVocab:Enabler [
    base:desc "Embedded Raspberry Pi running the plant controller, low‑level driver, and DT software stack."
]

instance OpenSourceSoftwareStack : DTDFVocab:Enabler [
    base:desc "Open‑source software stack hosted on GitHub providing communication, control, and simulation components."
    DTDFVocab:enables TemperaturePredictionService, ModelCalibrationService, ContinuousMonitoringService, OptimisationService, AdvancedVisualizationService
]

// C2: Acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed providing heating power to raise the temperature of the incubator contents."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan that distributes generated heat throughout the insulated styrofoam box."
]

// C6: Services (DT services)
instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Simulation‑based prediction of the incubator's internal temperature dynamics."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Service that updates model parameters using measured temperature data."
    DTDFVocab:provides ModelCalibrationInsight
]

instance ContinuousMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of temperature safety and optimality."
    DTDFVocab:provides SafetyViolationInsight, OptimalPerformanceInsight
]

instance ViolationDetectionService : DTDFVocab:Service [
    base:desc "Detection of temperature violations based on comparison of simulated and measured data."
    DTDFVocab:provides ViolationAlertInsight
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Optimization service that suggests control actions to maintain the desired temperature."
    DTDFVocab:provides OptimisationRecommendationInsight, TemperatureControlAction
]

instance AdvancedVisualizationService : DTDFVocab:Service [
    base:desc "Advanced visualisation of temperature trends, model states, and alerts."
    DTDFVocab:provides VisualizationInsight
]

// C17: Insights
instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory of the incubator over the upcoming time horizon."
]

instance ModelCalibrationInsight : DTDFVocab:Insight [
    base:desc "Updated model parameters reflecting current thermal characteristics."
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature safety violations (e.g., exceeding safe limits)."
]

instance OptimalPerformanceInsight : DTDFVocab:Insight [
    base:desc "Assessment that temperature is within optimal operating range."
]

instance ViolationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating a detected temperature fault or deviation."
]

instance OptimisationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation to adjust heating power or fan speed for optimal temperature control."
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Graphical representation of temperature data, model predictions, and alerts."
]

// C17: Actions
instance TemperatureControlAction : DTDFVocab:Action [
    base:desc "Command to adjust heat‑bed power or fan speed to correct temperature deviations."
    DTDFVocab:IsAutomatic true
]

instance ActuationControlAction : DTDFVocab:Action [
    base:desc "Signal from the Digital Twin to the Raspberry Pi to drive heat‑bed and fan actuators."
    DTDFVocab:IsAutomatic true
]

// Environment composition
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, FanActuator, InternalTemperatureSensor1, InternalTemperatureSensor2, ExternalTemperatureSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin issues control commands (heat‑bed on/off and fan on/off) by publishing messages to the same RabbitMQ broker. The Controller, executed on a Raspberry Pi, listens to these messages, interprets parameters such as lower limit (LL), upper limit (UL), heating duration (H) and waiting duration (C), and drives the actuators. The Low‑Level Driver validates incoming commands using an embedded safe protocol before applying them to the physical actuators and acknowledges execution by publishing its control state back to the broker. Command messages are transmitted via AMQP; exact format is not specified."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT provides real-time visualization by continuously listening to controller and low-level driver messages, streaming the sensor data into a time-series database and updating a dashboard, thus operating on a continuous sub-second data ingestion and display loop."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT follows a modular orchestration where sensed data from the physical twin are fed to calibration algorithms that update physics-based models of the CPS and its environment; the updated models feed monitors that assess safety and optimality, and upon detection of violations a human operator or higher-level algorithm may issue commands back to the physical twin. This loop integrates data, models, and algorithms as illustrated in Figure 1 of Document 1."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the two thermal simulation models against experimental temperature data. The four‑parameter model showed higher fidelity by more accurately reproducing the heat‑bed’s thermal inertia. Model validation is performed through calibration experiments where sensor data are used to adjust model parameters, thereby reducing prediction error. Uncertainty sources such as sensor noise and model simplifications are implicitly considered during calibration, though explicit quantification methods are not detailed. The DT relies on these calibrated models for reliable prediction and control of the physical twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between all components (Physical Twin, controller, low‑level driver and DT modules) is realized through a RabbitMQ server acting as a central message broker. RabbitMQ uses the AMQP protocol over TCP/IP, deployed either on‑premise or in the cloud. The network topology is a hub‑and‑spoke model where each component connects as a client to the broker. The broker provides reliable message delivery, but bandwidth, latency requirements and explicit security mechanisms (e.g., TLS) are not described in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The controller runs on a Raspberry Pi (edge device) while the RabbitMQ broker can be hosted on‑premise or in the cloud, as stated. RabbitMQ is described as mature, lightweight and easy to deploy, supporting scalability to tens of thousands of users. No detailed computational, storage or deployment model (e.g., containerisation) is provided, nor are specific availability or redundancy strategies beyond the general reliability of RabbitMQ."
]