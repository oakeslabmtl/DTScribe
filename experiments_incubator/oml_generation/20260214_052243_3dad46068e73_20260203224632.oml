// C3: Physical Sensing Components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "High-precision temperature sensor deployed inside the insulated container to monitor internal thermal conditions for real-time temperature regulation and model calibration."
    DTDFVocab:producedData InternalTemperatureDataStream1
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "High-precision temperature sensor deployed inside the insulated container to provide redundant internal thermal measurements for improved state estimation and fault detection."
    DTDFVocab:producedData InternalTemperatureDataStream2
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor deployed outside the insulated container to monitor ambient environmental conditions, providing contextual data for predictive simulations and control optimization."
    DTDFVocab:producedData ExternalTemperatureDataStream
]

// C4: Physical-to-Virtual Interaction
instance InternalTemperatureDataStream1 : DTDFVocab:DataTransmitted [
    base:desc "Analog temperature readings from InternalTemperatureSensor1 transmitted periodically (1-10s interval) via local network protocol (Wi-Fi/Ethernet/serial) to the Raspberry Pi controller for real-time processing."
    DTDFVocab:producedFrom InternalTemperatureSensor1
]

instance InternalTemperatureDataStream2 : DTDFVocab:DataTransmitted [
    base:desc "Analog temperature readings from InternalTemperatureSensor2 transmitted periodically (1-10s interval) via local network protocol (Wi-Fi/Ethernet/serial) to the Raspberry Pi controller for real-time processing."
    DTDFVocab:producedFrom InternalTemperatureSensor2
]

instance ExternalTemperatureDataStream : DTDFVocab:DataTransmitted [
    base:desc "Analog temperature readings from ExternalTemperatureSensor transmitted periodically (1-10s interval) via local network protocol (Wi-Fi/Ethernet/serial) to the Raspberry Pi controller for environmental context integration."
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

// C10: Models/Data
instance TwoParameterThermalModel : DTDFVocab:Model [
    base:desc "Mathematical model with two free parameters representing simplified thermal dynamics of the incubator, used as foundational input for higher-fidelity models and basic state estimation."
    DTDFVocab:inputTo ThermalModelCalibrationEnabler
]

instance FourParameterThermalModel : DTDFVocab:Model [
    base:desc "Mathematical model with four free parameters representing detailed thermal dynamics including heatbed thermal inertia, providing superior accuracy for predictive simulations and control optimization."
    DTDFVocab:inputTo ThermalModelCalibrationEnabler, PredictiveSimulationEnabler, ControlOptimizationEnabler
]

instance EnvironmentalThermalModel : DTDFVocab:Model [
    base:desc "Mathematical representation of external environmental factors (e.g., ambient temperature variations) influencing the incubator's thermal behavior, integrated with cyber-physical models for contextual simulations."
    DTDFVocab:inputTo PredictiveSimulationEnabler, FaultDetectionEnabler
]

instance InternalTemperatureData : DTDFVocab:Data [
    base:desc "Processed internal temperature measurements from both internal sensors, filtered and merged to provide comprehensive thermal state representation for model calibration and state estimation."
    DTDFVocab:fromData InternalTemperatureDataStream1, InternalTemperatureDataStream2
    DTDFVocab:inputTo StateEstimationEnabler, ThermalModelCalibrationEnabler
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Processed external temperature measurements providing environmental context for predictive simulations and control strategy adjustments under varying conditions."
    DTDFVocab:fromData ExternalTemperatureDataStream
    DTDFVocab:inputTo PredictiveSimulationEnabler, ControlOptimizationEnabler
]

instance HistoricalTemperatureData : DTDFVocab:Data [
    base:desc "Time-series database of past temperature measurements used for model validation, trend analysis, and long-term performance assessment of the incubator system."
    DTDFVocab:inputTo ModelValidationEnabler
]

// C11: Enablers
instance ThermalModelCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm using least-squares optimization or Bayesian inference to dynamically adjust model parameters (e.g., thermal conductivity, heat transfer coefficients) based on real-time sensor-PT discrepancies."
    DTDFVocab:enables ModelCalibrationService
]

instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "Kalman Filter or Particle Filter implementation for reconstructing internal temperature gradients and unmeasured states from noisy sensor measurements, providing comprehensive thermal state representation."
    DTDFVocab:enables StateEstimationService
]

instance PredictiveSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Numerical solver (e.g., Runge-Kutta methods) executing differential equation-based simulations to replicate and forecast incubator behavior under current or hypothetical conditions."
    DTDFVocab:enables PredictiveSimulationService
]

instance ControlOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Supervisory controller algorithm (e.g., model-predictive control) optimizing heatbed power and fan speed for energy efficiency or temperature stability based on real-time constraints."
    DTDFVocab:enables ControlOptimizationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Anomaly detection algorithm (e.g., statistical process control, machine learning classifiers) identifying deviations in sensor data or system behavior, triggering alerts or corrective actions."
    DTDFVocab:enables FaultDetectionService
]

instance ModelValidationEnabler : DTDFVocab:Enabler [
    base:desc "Validation framework comparing DT predictions against real-world PT behavior using experimental data, quantifying model accuracy and uncertainty."
    DTDFVocab:enables ModelValidationService
]

instance DataPreprocessingEnabler : DTDFVocab:Enabler [
    base:desc "Signal processing module applying filtering techniques (e.g., moving averages, Kalman filtering) to mitigate noise in sensor data before model integration."
    DTDFVocab:enables DataPreprocessingService
]

// C6: Services
instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Continuous real-time assessment of incubator performance against predefined safety thresholds (e.g., temperature limits), using data-driven algorithms to verify system safety and optimality."
    DTDFVocab:provides SafetyViolationInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Reconstruction of internal temperature dynamics from sensor data, accounting for uncertainties in the physical system to provide comprehensive thermal state representation."
    DTDFVocab:provides ThermalStateInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Execution of simulations to replicate and forecast thermal dynamics under current or perturbed operating conditions, enabling proactive decision-making."
    DTDFVocab:provides ThermalForecastInsight
]

instance WhatIfAnalysisService : DTDFVocab:Service [
    base:desc "Simulations reproducing incubator behavior under hypothetical conditions (e.g., external temperature changes, sensor failures) to evaluate system robustness and resilience."
    DTDFVocab:provides ScenarioAnalysisInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Iterative refinement of model parameters using real-time sensor data to minimize discrepancies between virtual and physical states, ensuring model fidelity."
    DTDFVocab:provides ModelAccuracyInsight
]

instance ControlOptimizationService : DTDFVocab:Service [
    base:desc "Adjustment of control policies (e.g., heatbed power, fan speed) for energy efficiency or temperature stability based on real-time constraints and predictive simulations."
    DTDFVocab:provides OptimizationRecommendation
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Identification of anomalies or deviations from expected behavior in sensor data or system performance, triggering alerts or corrective actions."
    DTDFVocab:provides FaultAlertInsight
]

instance ModelValidationService : DTDFVocab:Service [
    base:desc "Comparison of DT predictions against real-world physical twin behavior using experimental data to validate model accuracy and quantify uncertainty."
    DTDFVocab:provides ValidationResultInsight
]

instance DataPreprocessingService : DTDFVocab:Service [
    base:desc "Application of filtering and noise reduction techniques to sensor data before integration into models, ensuring high-quality input for simulations and analysis."
    DTDFVocab:provides CleanedDataInsight
]

// C17: Insights/Actions
instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Real-time assessment indicating whether current system performance violates predefined safety thresholds (e.g., temperature exceeding safe limits)."
]

instance ThermalStateInsight : DTDFVocab:Insight [
    base:desc "Comprehensive representation of internal temperature gradients and unmeasured states reconstructed from sensor data, accounting for system uncertainties."
]

instance ThermalForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted thermal behavior of the incubator under current operating conditions, enabling proactive decision-making for temperature regulation."
]

instance ScenarioAnalysisInsight : DTDFVocab:Insight [
    base:desc "Evaluation of incubator performance under hypothetical scenarios (e.g., external temperature changes, sensor failures) to assess system robustness."
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantitative measure of model fidelity, indicating how closely the digital twin's predictions align with real-world physical twin behavior."
]

instance OptimizationRecommendation : DTDFVocab:Action [
    base:desc "Suggested adjustments to control parameters (e.g., heatbed power, fan speed) for improved energy efficiency or temperature stability."
    DTDFVocab:IsAutomatic true
]

instance FaultAlertInsight : DTDFVocab:Insight [
    base:desc "Identification of anomalies or deviations from expected behavior in sensor data or system performance, indicating potential faults or malfunctions."
]

instance ValidationResultInsight : DTDFVocab:Insight [
    base:desc "Comparison results between digital twin predictions and real-world physical twin behavior, including accuracy metrics and uncertainty quantification."
]

instance CleanedDataInsight : DTDFVocab:Insight [
    base:desc "Processed sensor data with reduced noise and artifacts, ready for integration into models and simulations."
]

instance CorrectiveAction : DTDFVocab:Action [
    base:desc "Automated or suggested intervention to restore system performance to safe operating conditions when deviations exceed thresholds."
    DTDFVocab:IsAutomatic false
]

// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heating element responsible for generating and maintaining internal heat within the insulated container, controlled via Raspberry Pi based on digital twin recommendations."
]

instance AirCirculationFan : DTDFVocab:ActingComponent [
    base:desc "Fan distributing heat uniformly inside the insulated container to maintain temperature homogeneity and prevent hot/cold spots."
]

instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "Embedded controller acting as the supervisory control unit for real-time temperature regulation, integrating digital twin insights with physical system actuation."
]

// C1: System Under Study
instance IncubatorPhysicalTwin : DTDFVocab:SystemUnderStudy [
    base:desc "Cyber-Physical System-based incubator designed to regulate temperature within an insulated container, comprising heating elements, air circulation, sensing infrastructure, and embedded control."
]

instance InsulatedContainer : DTDFVocab:Component [
    base:desc "Styrofoam box providing thermal insulation to minimize external environmental influences on the incubator's internal temperature."
]

instance ThermalControlEnvironment : DTDFVocab:Environment [
    base:desc "Operating environment for the incubator system, including ambient temperature variations and external thermal influences affecting system performance."
    base:contains ExternalTemperatureSensor
]

instance IncubatorDigitalTwin : DTDFVocab:Environment [
    base:desc "Digital representation of the incubator's physical twin, integrating computational models, real-time data, and analytical capabilities for monitoring, prediction, and optimization."
    base:contains TwoParameterThermalModel, FourParameterThermalModel, EnvironmentalThermalModel,
                InternalTemperatureData, ExternalTemperatureData, HistoricalTemperatureData,
                ThermalModelCalibrationEnabler, StateEstimationEnabler, PredictiveSimulationEnabler,
                ControlOptimizationEnabler, FaultDetectionEnabler, ModelValidationEnabler,
                SafetyMonitoringService, StateEstimationService, PredictiveSimulationService,
                WhatIfAnalysisService, ModelCalibrationService, ControlOptimizationService,
                FaultDetectionService, ModelValidationService, DataPreprocessingService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin (DT) exerts **control commands** on the Physical Twin (PT) via the **Raspberry Pi controller**, which acts as the interface between the digital and physical layers. The **command types** include **temperature setpoints** and **actuation signals** (e.g., heatbed power modulation, fan speed adjustments). The **control message format** is unspecified but likely follows a **structured protocol** (e.g., JSON, MQTT, or proprietary CPS messages) to ensure compatibility with the embedded system. **Validation and authentication mechanisms** are not detailed, though the system implies **closed-loop control** where the DT continuously validates commands against **safety constraints** (e.g., max/min temperature thresholds). **Feedback systems** are critical: the PT’s sensor data (temperature readings) is looped back to the DT for **real-time correction** of control actions. **Conflict resolution** is handled implicitly via the **calibration algorithms** (Document 1, Fig. 1), which reconcile discrepancies between the DT’s predictive models and observed PT behavior. **Command execution confirmation** is inferred through **monitoring algorithms** that verify whether the PT’s state (e.g., temperature stability) aligns with the DT’s predictions."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin (DT) system operates with a **real-time synchronization paradigm**, where data is continuously collected from the Physical Twin (PT) via sensors (e.g., temperature sensors in the incubator case study) and fed into the DT framework. The temporal granularity depends on the **sampling rate of the sensors** and the **latency requirements of the calibration algorithms**, which update the models (e.g., differential equations for dynamic behavior) to reflect the PT's current state. While the document does not specify exact synchronization frequencies, the DT must support **low-latency data ingestion** to enable real-time monitoring (e.g., fault detection, state estimation) and **predictive simulations** under current operating conditions. The trade-off between model accuracy and computational speed (e.g., simulation runtime) is acknowledged, as highly accurate models may introduce delays in analysis. The DT’s temporal dynamics are further constrained by the **control loop** (e.g., Raspberry Pi-based temperature controller in the incubator), which requires timely data to adjust actuators (e.g., heatbed, fan) and maintain system stability. The overall time scale is thus **event-driven**, prioritizing responsiveness to PT state changes while balancing computational overhead for model updates and algorithm execution (e.g., optimizers, supervisory controllers)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a **service-oriented architecture** centered on three core orchestration pillars: **data ingestion**, **model-driven simulation**, and **algorithm-based decision-making**, as depicted in Fig. 1. The constellation is characterized by:
  - **Component Integration**: Sensors (e.g., temperature probes) feed real-time data into the DT, which is processed by **calibration algorithms** to refine models of the CPS and environment. These models are then utilized by **monitors** (safety/performance validators) and **controllers** (e.g., supervisory logic for actuator adjustments).
  - **Resource Management**: Computational resources are allocated dynamically to balance **model fidelity** (e.g., high-accuracy differential equations) and **real-time responsiveness** (e.g., low-latency fault detection). The incubator case study exemplifies this via a **Raspberry Pi-based controller**, suggesting lightweight yet reactive orchestration.
  - **System-Wide Coordination**: The DT employs a **feedback loop** where deviations (e.g., temperature drift) trigger corrective actions (e.g., fan/heatbed adjustments). Human-in-the-loop interventions are possible for non-automated decisions, implying a **hybrid orchestration** of algorithmic and manual oversight. The architecture leverages **modularity** (e.g., separable models for cyber/physical domains) and **adaptive calibration** to maintain synchronization with the PT’s evolving state."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The lifecycle of the Digital Twin (DT) system, as inferred from the provided documents, includes the following phases: **(1) Modeling Phase**: Abstract representations of the Physical Twin (PT) are created at varying levels of abstraction (e.g., CAD models for geometric properties, dynamic models for physics-based behavior via differential equations). These models may range from high-level conceptualizations (e.g., shapes, styles) to low-level, computationally intensive simulations (e.g., force dynamics). **(2) Integration Phase**: Models are integrated into the DT framework alongside real-time **data** (collected via sensors from the PT) and **algorithms** (e.g., calibration, fault detection, state estimation). **(3) Deployment Phase**: The DT is deployed to monitor and interact with the PT, leveraging **calibration algorithms** to update models dynamically with sensor data, ensuring alignment between the virtual and physical systems. **(4) Operational Phase**: The DT operates in real-time, using **monitors** to assess system performance (safety, optimality) and enabling **human/algorithm-driven interventions** (e.g., adjustments to the PT or DT models). **(5) Evolution Phase**: The DT undergoes continuous refinement through iterative updates to models and algorithms, driven by new data or environmental changes. **Transition Management**: The documents highlight the importance of retaining models post-deployment and integrating them into the DT, suggesting a seamless transition from design/analysis to operational use. **Lifecycle Governance**: While not explicitly detailed, the framework implies governance through **calibration-driven model updates** and **monitoring-based feedback loops**, ensuring adaptability and robustness. The Incubator case study exemplifies this lifecycle by building two models with calibration methods (Section 3) and validating them experimentally (Section 4)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The Digital Twin’s **fidelity and validity** are governed by rigorous **validation and verification (V&V) methods**, **uncertainty quantification**, and **quality assurance (QA)** processes. Key aspects include:
  - **Model Fidelity Requirements**: Higher-fidelity models (e.g., the incubator’s **4-parameter thermal model**) are preferred when they better capture critical PT behaviors (e.g., thermal inertia). Fidelity is assessed through **experimental validation**, where model predictions are compared against real-world PT performance (e.g., temperature measurements in the incubator).
  - **Validation Methods**: Empirical testing (e.g., running the incubator with known thermal inputs and comparing predicted vs. actual temperatures) to verify model accuracy. The incubator case study explicitly demonstrates that the **4-parameter model outperformed the 2-parameter model** in predicting thermal dynamics, justifying its use for further DT development.
  - **Uncertainty Sources and Quantification**: Model parameters (e.g., free parameters in thermal equations) introduce uncertainty, which is mitigated through **calibration algorithms** that adjust parameters using real-time sensor data. The documents imply **statistical or optimization-based techniques** to quantify and reduce uncertainty (e.g., minimizing prediction errors).
  - **Error Detection and Correction**: The DT framework includes **monitors** that detect deviations between the PT’s actual state and model predictions. When violations (e.g., unsafe temperatures or dynamic behavior) are identified, **corrective actions** are triggered, such as:
    - **Automated adjustments** (e.g., recalibrating model parameters or altering control inputs).
    - **Human intervention** (e.g., engineers manually overriding the system or refining models).
  - **Quality Assurance Processes**: Continuous V&V loops ensure models remain aligned with the PT’s evolving state. For instance, the incubator’s open-source hardware/software platform enables **reproducible validation**, allowing developers to test and refine DT techniques systematically. The documents emphasize **iterative improvement**, where models are discarded or updated based on performance metrics (e.g., prediction accuracy)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin (DT) of the incubator relies on a **cyber-physical system (CPS) architecture** where the **Raspberry Pi** serves as the central node for data acquisition, processing, and control. The **communication protocols** are not explicitly defined, but the system likely employs **standard CPS protocols** such as **MQTT (for lightweight IoT messaging), HTTP/REST (for configuration), or serial protocols (e.g., UART, I2C)** for sensor-actuator communication. The **network topology** is **star-shaped**, with the Raspberry Pi as the hub connecting to sensors (temperature probes) and actuators (heatbed, fan). **Bandwidth requirements** are minimal, given the **low-data-rate sensor inputs** (temperature readings), but **latency must be sub-second** to ensure real-time control and safety. **Reliability and redundancy mechanisms** are not specified, though the use of **multiple temperature sensors** (two inside, one outside) suggests **sensor fusion** for fault tolerance. **Security protocols** are implied but not detailed; typical CPS security measures (e.g., **TLS for network traffic, authentication tokens for command validation**) may be applied, though the documents do not specify."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin (DT) of the incubator is **hosted on a Raspberry Pi**, an **edge-computing device** co-located with the Physical Twin (PT) to minimize latency. The **computational requirements** are modest, involving **real-time sensor data processing, model calibration, and control algorithm execution**, which can be handled by the Pi’s **ARM-based processor** (e.g., quad-core 1.2–1.5 GHz). **Storage requirements** are minimal, primarily for **model parameters, calibration logs, and historical sensor data**, likely stored in **local flash memory or an SD card**. **Scalability mechanisms** are not addressed, as the system is designed for a **single, small-scale CPS**. The **deployment model** is **on-premise/edge**, with no mention of cloud integration. **Availability/reliability assurance** is implied through the **closed-loop control system**, where the DT continuously monitors the PT’s state and adjusts dynamically. However, no explicit redundancy (e.g., backup Pi or cloud failover) is described."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin (DT) system for the incubator case study incorporates **safety-critical considerations** through its **monitoring and calibration mechanisms**, which ensure the system operates within predefined operational boundaries. Specifically, the DT employs **monitors** that check whether the **Cyber-Physical System (CPS)** and its environment are performing **safely and optimally** (as depicted in Figure 1). These monitors likely rely on **real-time data** from sensors (e.g., temperature sensors inside and outside the insulated container) to detect deviations or violations, triggering **corrective actions** via human intervention or automated algorithms. While the documents do not explicitly mention **cybersecurity protocols** (e.g., encryption, access control, or authentication systems), the DT framework inherently requires **secure data transmission** between the Physical Twin (PT) and the DT to prevent unauthorized access or tampering. **Fail-safe mechanisms** are implied through the calibration algorithms that update models to reflect the **best estimate of parameters**, ensuring the system remains robust against environmental or operational changes. However, no explicit details on **risk assessment approaches**, **data anonymization**, or **compliance with data protection regulations** (e.g., GDPR) are provided in the documents."
]