// C17: Insights
instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight delivering clear visual representation of temperature evolution and system health"
]

instance ReconfigurabilityInsight : DTDFVocab:Insight [
    base:desc "Insight that indicates when model re‑parameterisation or control set‑point adjustment is required"
]

instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Alert insight generated when monitoring detects a safety or performance violation"
]

instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Predictive insight showing expected future temperature trajectories based on simulation"
]

instance MaintenanceInsight : DTDFVocab:Insight [
    base:desc "Insight highlighting maintenance‑related recommendations derived from repository artefacts and calibration status"
]

// C17: Actions
instance CorrectiveAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of heater power or fan speed to bring temperature back within safe bounds",
    DTDFVocab:IsAutomatic true
]

// C6: Services
instance VisualizationService : DTDFVocab:Service [
    base:desc "Advanced visualisation service delivering real‑time temperature plots and status dashboards",
    DTDFVocab:provides VisualizationInsight
]

instance ReconfigurabilityService : DTDFVocab:Service [
    base:desc "Reconfigurability service that adapts model parameters and control set‑points in response to new data",
    DTDFVocab:provides ReconfigurabilityInsight
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Safety monitoring service that detects temperature safety or performance violations",
    DTDFVocab:provides SafetyAlertInsight, CorrectiveAction
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation service that forecasts internal temperature using calibrated thermal models",
    DTDFVocab:provides PredictiveInsight
]

instance MaintenanceReductionService : DTDFVocab:Service [
    base:desc "Maintenance reduction service that minimises downtime by providing version‑controlled software and calibration artefacts",
    DTDFVocab:provides MaintenanceInsight
]

// C11: Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration engine that continuously updates model parameters using the latest temperature data",
    DTDFVocab:enables ReconfigurabilityService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs the analytical and detailed thermal models to generate predictions",
    DTDFVocab:enables PredictiveSimulationService
]

instance SafetyMonitorEnabler : DTDFVocab:Enabler [
    base:desc "Safety monitoring component that compares sensor data with model predictions and detects violations",
    DTDFVocab:enables SafetyMonitoringService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard engine providing advanced visualisations of temperature trends and system state",
    DTDFVocab:enables VisualizationService
]

instance MaintenanceEnabler : DTDFVocab:Enabler [
    base:desc "Maintenance support module that leverages version‑controlled artefacts from the GitHub repository",
    DTDFVocab:enables MaintenanceReductionService
]

// C10: Models
instance SimpleThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model with two free parameters used for quick temperature prediction",
    DTDFVocab:inputTo SimulationEnabler, CalibrationEnabler
]

instance DetailedThermalModel : DTDFVocab:Model [
    base:desc "Detailed thermal model with four free parameters capturing heat‑bed thermal inertia",
    DTDFVocab:inputTo SimulationEnabler, CalibrationEnabler
]

// C3: Physical sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor mounted inside the incubator (internal sensor 1) with ±0.5 °C accuracy"
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital temperature sensor mounted inside the incubator (internal sensor 2) with ±0.5 °C accuracy"
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor monitoring ambient conditions outside the styrofoam box"
]

// C4: Physical-to-virtual interaction (data stream)
instance TempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1, InternalTempSensor2, ExternalTempSensor
]

// C10: Data (raw sensor measurements)
instance TemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements collected from internal and external sensors",
    DTDFVocab:fromData TempDataTransmitted,
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler, SafetyMonitorEnabler
]

// C2: Acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed providing primary heating power to the incubator"
]

instance CoolingFanActuator : DTDFVocab:ActingComponent [
    base:desc "Auxiliary cooling fan driven to regulate temperature within the styrofoam enclosure"
]

// C12: Tooling and Enablers (hardware/software artefacts)
instance RaspberryPiController : DTDFVocab:Enabler [
    base:desc "Embedded Raspberry Pi controller that interfaces sensors, actuators and communicates with the Digital Twin via serial/TCP‑IP"
]

instance GitHubRepository : DTDFVocab:Enabler [
    base:desc "Public GitHub repository (https://github.com/INTO‑CPS‑Association/example‑incubator) containing hardware schematics, software code, model specifications and calibration algorithms"
]

// C13: Environment (overall incubator)
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, CoolingFanActuator, InternalTempSensor1, InternalTempSensor2, ExternalTempSensor, RaspberryPiController, GitHubRepository
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The incubator’s physical plant is driven by a Raspberry Pi that receives control decisions from the digital twin and actuates the heat‑bed and fan to achieve and maintain the target temperature, as the physical components are described as being controlled by a Raspberry Pi."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The incubator DT synchronises physical sensor readings with the digital model using a periodic data‑acquisition loop in the low‑level driver that reads the two internal temperature sensors and the external sensor at a regular interval (the exact period is not specified). The collected data are published to a local RabbitMQ message broker, which provides the asynchronous communication channel between the physical twin and the cyber components. The controller component consumes the sensor messages, executes the control algorithm and may introduce a waiting duration between control actions, thereby defining the overall control cycle time. Latency is limited to the round‑trip time of the RabbitMQ publish/subscribe cycle, and the temporal granularity of the DT is therefore bounded by the sensor sampling period and the message‑passing latency."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is organised as a small, centrally managed constellation consisting of three main software entities deployed on the Raspberry Pi: (1) a low‑level driver that periodically reads temperature sensor data, (2) a RabbitMQ server that acts as the communication backbone for publish/subscribe of sensor readings and command messages, and (3) a controller that receives the sensor data, runs the calibration and control algorithms, and issues actuation commands to the heater and fan. This architecture follows a classic cyber‑physical loop where the RabbitMQ broker orchestrates data flow and decouples components, enabling modular integration of the models, algorithms and monitors described in Document 1."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated experimentally by comparing the predicted temperature trajectories of the two thermal models against measured sensor data; the four‑parameter model demonstrated superior prediction of thermal inertia. Calibration algorithms adjust model parameters to align predictions with observations, serving as an error‑correction mechanism. Monitors within the DT assess whether the system operates safely and optimally, flagging violations for human or algorithmic intervention. While uncertainty sources (e.g., sensor noise, model simplifications) are implied, explicit quantification or formal verification procedures are not described in the provided documents."
]