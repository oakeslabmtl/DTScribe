// C2: Acting Components
instance Heatbed : DTDFVocab:ActingComponent [
    base:desc "Thermal source component providing controlled heat input to the incubator chamber for temperature regulation within the Physical Twin system."
]

instance Fan : DTDFVocab:ActingComponent [
    base:desc "Air circulation component ensuring uniform temperature distribution within the Styrofoam enclosure of the Physical Twin system."
]

instance BangBangController : DTDFVocab:ActingComponent [
    base:desc "Discrete-time bang-bang controller implemented on RaspberryPi4 that regulates temperature based on real-time sensor feedback from DS18S20 sensors."
]

// C3: Physical Sensing Components
instance InternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer sensor deployed inside the Styrofoam enclosure to monitor localized thermal gradients with ±0.5°C accuracy and 0.0625°C resolution."
    DTDFVocab:producedData InternalTemperatureDataTransmitted
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer sensor positioned outside the incubator enclosure to monitor ambient environmental conditions with ±0.5°C accuracy and 0.0625°C resolution."
    DTDFVocab:producedData ExternalTemperatureDataTransmitted
]

instance HeatbedTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer sensor placed near the heated bed component to monitor surface temperature with ±0.5°C accuracy and 0.0625°C resolution."
    DTDFVocab:producedData HeatbedTemperatureDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance InternalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor
]

instance ExternalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

instance HeatbedTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatbedTemperatureSensor
]

// C10: Models/Data
instance ThermalMassDynamicsModel : DTDFVocab:Model [
    base:desc "Behavioral model representing the thermal mass dynamics of the incubator system described by differential equations for force and heat transfer analysis."
    DTDFVocab:inputTo NonLinearLeastSquaresCalibrator
]

instance HeatTransferModel : DTDFVocab:Model [
    base:desc "Parameterized mathematical model describing heat transfer characteristics between components within the incubator enclosure."
    DTDFVocab:inputTo NonLinearLeastSquaresCalibrator
]

instance RealTimeTemperatureData : DTDFVocab:Data [
    base:desc "Continuous time-series dataset containing periodic temperature readings from all DS18S20 sensors transmitted via 1-Wire protocol to the RabbitMQ server."
    DTDFVocab:fromData InternalTemperatureDataTransmitted, ExternalTemperatureDataTransmitted, HeatbedTemperatureDataTransmitted
    DTDFVocab:inputTo NonLinearLeastSquaresCalibrator, StateEstimationService
]

instance HistoricalTemperatureTrajectories : DTDFVocab:Data [
    base:desc "Historical dataset of temperature readings used for model calibration and validation against real-world system behavior."
    DTDFVocab:fromData RealTimeTemperatureData
    DTDFVocab:inputTo NonLinearLeastSquaresCalibrator
]

// C11: Enablers
instance RaspberryPi4Controller : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B embedded system hosting the RabbitMQ server, sensor data acquisition interface, and bang-bang controller implementation."
    DTDFVocab:enables RealTimeDataAcquisitionService, StateEstimationService, ModelCalibrationService
]

instance RabbitMQServer : DTDFVocab:Enabler [
    base:desc "Message broker hosted on RaspberryPi4 facilitating real-time data streaming between sensors and downstream processing components via 1-Wire protocol."
    DTDFVocab:enables RealTimeDataAcquisitionService, ModelCalibrationService
]

instance NonLinearLeastSquaresCalibrator : DTDFVocab:Enabler [
    base:desc "Python SciPy-based non-linear least squares solver used for parameter estimation and model calibration against real-world temperature data."
    DTDFVocab:enables ModelCalibrationService
]

// C6: Services
instance RealTimeDataAcquisitionService : DTDFVocab:Service [
    base:desc "Continuous collection and transmission of temperature readings from DS18S20 sensors to the RabbitMQ server via periodic polling mechanism."
    DTDFVocab:provides TemperatureDataInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Non-linear least squares-based state estimation service that calibrates system models against real-time sensor data to ensure accurate parameter estimation."
    DTDFVocab:provides SystemStateInsight, FaultDetectionInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Iterative parameter calibration service that refines thermal and heat transfer models using historical and real-time data to improve predictive accuracy."
    DTDFVocab:provides ModelAccuracyInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Supervisory control service that monitors system performance against optimal operating conditions and detects deviations indicating potential faults."
    DTDFVocab:provides FaultAlertAction
]

// C17: Insights/Actions
instance TemperatureDataInsight : DTDFVocab:Insight [
    base:desc "Real-time temperature readings from all deployed DS18S20 sensors used for immediate system monitoring and control."
]

instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Estimated state of the incubator system derived from calibrated models and sensor data, representing current thermal conditions."
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantitative measure of model predictive accuracy against real-world system behavior, updated through continuous calibration."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of deviations from optimal system performance based on comparative analysis between simulated and actual temperature profiles."
]

instance FaultAlertAction : DTDFVocab:Action [
    base:desc "Automated alert generation when detected faults exceed predefined safety thresholds, triggering manual or algorithmic intervention."
    DTDFVocab:IsAutomatic true
]

// C5: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Controlled thermal environment within the Styrofoam enclosure representing the operational domain for the Digital Twin system."
    base:contains StyrofoamEnclosure, Heatbed, Fan, InternalTemperatureSensor, ExternalTemperatureSensor, HeatbedTemperatureSensor
]

// C7: Components
instance StyrofoamEnclosure : DTDFVocab:Component [
    base:desc "Insulated Styrofoam box serving as the primary chamber for thermal regulation within the Physical Twin system."
    base:isContainedIn IncubatorEnvironment
]

instance Heatbed : DTDFVocab:Component [
    base:desc "Thermal source component providing controlled heat input to the incubator chamber for temperature regulation within the Physical Twin system."
    base:isContainedIn IncubatorEnvironment
]

instance Fan : DTDFVocab:Component [
    base:desc "Air circulation component ensuring uniform temperature distribution within the Styrofoam enclosure of the Physical Twin system."
    base:isContainedIn IncubatorEnvironment
]

instance InternalTemperatureSensor : DTDFVocab:Component [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer sensor deployed inside the Styrofoam enclosure to monitor localized thermal gradients with ±0.5°C accuracy and 0.0625°C resolution."
    base:isContainedIn IncubatorEnvironment
]

instance ExternalTemperatureSensor : DTDFVocab:Component [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer sensor positioned outside the incubator enclosure to monitor ambient environmental conditions with ±0.5°C accuracy and 0.0625°C resolution."
    base:isContainedIn IncubatorEnvironment
]

instance HeatbedTemperatureSensor : DTDFVocab:Component [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer sensor placed near the heated bed component to monitor surface temperature with ±0.5°C accuracy and 0.0625°C resolution."
    base:isContainedIn IncubatorEnvironment
]

// Relationships
instance DataTransmission1 : DTDFVocab:Relationship [
    DTDFVocab:from InternalTemperatureDataTransmitted
    DTDFVocab:to RealTimeTemperatureData
]

instance DataTransmission2 : DTDFVocab:Relationship [
    DTDFVocab:from ExternalTemperatureDataTransmitted
    DTDFVocab:to RealTimeTemperatureData
]

instance DataTransmission3 : DTDFVocab:Relationship [
    DTDFVocab:from HeatbedTemperatureDataTransmitted
    DTDFVocab:to RealTimeTemperatureData
]

instance DataInput1 : DTDFVocab:Relationship [
    DTDFVocab:from RealTimeTemperatureData
    DTDFVocab:to StateEstimationService
]

instance DataInput2 : DTDFVocab:Relationship [
    DTDFVocab:from HistoricalTemperatureTrajectories
    DTDFVocab:to ModelCalibrationService
]

instance ModelInput1 : DTDFVocab:Relationship [
    DTDFVocab:from ThermalMassDynamicsModel
    DTDFVocab:to StateEstimationService
]

instance ModelInput2 : DTDFVocab:Relationship [
    DTDFVocab:from HeatTransferModel
    DTDFVocab:to ModelCalibrationService
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin system communicates control commands to the Physical Twin (PT) through a **low-level driver** integrated with the Raspberry Pi 4 Model B. Commands are issued via the RabbitMQ server, specifically targeting the **fan and heatbed** of the system, utilizing a **bang-bang controller** for actuation. Message formats are not explicitly detailed, but the system employs a **safe protocol** to ensure command execution integrity. No explicit validation, authentication, or feedback mechanisms are described beyond the implicit reliance on the RabbitMQ server for command transmission. Conflict resolution or command execution confirmation mechanisms are not mentioned in the provided documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows an architecture pattern that integrates three core components: **Data** (collected from the PT via sensors), **Models** (abstract representations of the PT's cyber and physical aspects), and **Algorithms** (e.g., fault detectors, supervisory controllers, state estimators, and optimizers). These components are orchestrated to enable continuous monitoring, predictive analysis, and optimization of the PT. The system employs calibration algorithms to update models dynamically, ensuring alignment between the digital and physical representations. Resource management is implied through the use of these algorithms, which manipulate data and models to generate actionable insights. System-wide coordination is achieved via feedback loops where detected violations (e.g., safety or performance issues) trigger human or automated interventions to adjust the PT. The document highlights a closed-loop architecture where the DT's outputs inform real-time decisions for the PT."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
The Digital Twin system emphasizes **model fidelity** through **validation and verification (V&V) processes** rooted in **model assumptions** and **calibration methodologies**. Model fidelity is ensured by comparing simulated outputs (from behavioral models) with **real-time sensor data trajectories** using a **non-linear least squares optimization** technique to minimize a cost function. This process adjusts model parameters iteratively, reducing discrepancies between the Digital Twin and Physical Twin behaviors. **Uncertainty quantification** is implicitly addressed via the calibration process, where deviations from observed data are treated as errors to be minimized. **Error detection and correction** are handled through the calibration algorithms, which refine model parameters dynamically. However, the documents do not explicitly detail **periodic recalibration schedules**, **convection effects**, or **quality assurance processes** beyond the calibration framework. The system assumes that model assumptions (e.g., thermal dynamics, environmental interactions) are sufficiently captured by the chosen behavioral models and sensor data.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin system employs a **local network infrastructure** centered around a **Raspberry Pi 4 Model B**, which supports **wireless internet (Wi-Fi and Bluetooth)** for communication. The system uses a **RabbitMQ server** hosted on the Raspberry Pi for message brokering, facilitating communication between the Physical Twin and Digital Twin components. No explicit mention of network topology (e.g., edge/core/cloud layers), bandwidth requirements, latency specifications, or redundancy mechanisms (e.g., failover protocols) is provided. Security protocols are not detailed beyond the implicit use of RabbitMQ for message integrity, though the Raspberry Pi’s built-in Wi-Fi may incorporate basic encryption (e.g., WPA2/WPA3)."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin system is deployed on a **Raspberry Pi 4 Model B**, which serves as both the hosting platform and computational unit. The RabbitMQ server is installed and runs **on the Raspberry Pi itself**, indicating an **on-premise, single-node deployment model**. No cloud or edge computing components are referenced. The system’s computational requirements are limited to the Raspberry Pi’s ARM-based processor and basic memory/storage capabilities, with no mention of scalability mechanisms, orchestration tools, or high-availability features. Availability/reliability assurance is not explicitly addressed beyond the system’s reliance on the Raspberry Pi’s hardware and RabbitMQ’s basic fault tolerance."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "
The Digital Twin (DT) system incorporates a **low-level driver protocol** designed to maintain the Physical Twin (PT) in a **safe operational state** by enforcing predefined constraints. While the document does not explicitly detail comprehensive cybersecurity protocols (e.g., encryption, firewalls, or authentication frameworks), it highlights that the DT framework integrates **monitoring algorithms** to detect deviations from safe performance. These monitors leverage real-time data from the PT to trigger **safety checks**, ensuring compliance with operational boundaries. The system’s **calibration algorithms** refine models dynamically, reducing the risk of misalignment between the DT and PT, thereby indirectly supporting safety-critical operations. However, no explicit mention of **access control mechanisms**, **threat mitigation strategies**, or **risk assessment methodologies** (e.g., penetration testing, vulnerability scanning) is provided in the context. The document emphasizes **safety** as a core outcome of DT integration but lacks granular technical specifications for security hardening or compliance frameworks (e.g., ISO 27001, NIST SP 800-53)."
]