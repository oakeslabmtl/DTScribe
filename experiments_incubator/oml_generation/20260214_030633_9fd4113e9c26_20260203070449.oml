// ==================== Digital Twin ====================
instance IncubatorDigitalTwin : DTDFVocab:SystemUnderStudy [
    DTDFVocab:hasEnvironment IncubatorEnvironment
]

// ==================== Physical Sensing Components ====================
// C3: Physical sensing components
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor inside the styrofoam enclosure (first of two internal sensors).",
    DTDFVocab:producedData InternalTempDataTransmittedA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor inside the styrofoam enclosure (second of two internal sensors).",
    DTDFVocab:producedData InternalTempDataTransmittedB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor mounted outside the incubator to record ambient temperature.",
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// ==================== Physical-to-Virtual Data Transmission ====================
// C4: Physical-to-virtual interaction
instance InternalTempDataTransmittedA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempDataTransmittedB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// ==================== Data Objects ====================
// C10: Data
instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Scalar temperature reading stream from InternalTempSensorA, sampled continuously.",
    DTDFVocab:fromData InternalTempDataTransmittedA,
    DTDFVocab:inputTo CalibrationAlgorithm, PredictionEngine, MonitoringEngine
]

instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Scalar temperature reading stream from InternalTempSensorB, sampled continuously.",
    DTDFVocab:fromData InternalTempDataTransmittedB,
    DTDFVocab:inputTo CalibrationAlgorithm, PredictionEngine, MonitoringEngine
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Scalar temperature reading stream from ExternalTempSensor, sampled continuously.",
    DTDFVocab:fromData ExternalTempDataTransmitted,
    DTDFVocab:inputTo CalibrationAlgorithm, PredictionEngine, MonitoringEngine
]

// ==================== Models ====================
instance ThermalModelTwoParams : DTDFVocab:Model [
    base:desc "Analytical thermal simulation model with two free parameters representing basic heat dynamics.",
    DTDFVocab:inputTo PredictionEngine, OptimizationEngine
]

instance ThermalModelFourParams : DTDFVocab:Model [
    base:desc "Analytical thermal simulation model with four free parameters capturing heat‑bed thermal inertia.",
    DTDFVocab:inputTo PredictionEngine, OptimizationEngine
]

// ==================== Enablers (Tools, Algorithms, Platforms) ====================
// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ communication server using AMQP over TCP/IP channels periodic temperature readings from drivers to DT components.",
    DTDFVocab:enables ContinuousTemperatureMonitoring
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Parameter‑estimation algorithm that calibrates the two thermal models using latest sensor data.",
    DTDFVocab:enables ParameterCalibrationService
]

instance PredictionEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs the calibrated thermal models to predict future temperature trajectories.",
    DTDFVocab:enables TemperatureTrajectoryPrediction
]

instance MonitoringEngine : DTDFVocab:Enabler [
    base:desc "Monitoring service that compares real‑time sensor data against calibrated models to detect safety or performance violations.",
    DTDFVocab:enables ContinuousTemperatureMonitoring
]

instance OptimizationEngine : DTDFVocab:Enabler [
    base:desc "Decision‑support optimizer that uses calibrated models to assess safe and optimal operation and suggest corrective actions.",
    DTDFVocab:enables OptimisationDecisionSupportService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Advanced visualisation module that renders simulation results and current state for operators.",
    DTDFVocab:enables AdvancedVisualizationService
]

// ==================== Services ====================
// C6: Services
instance ContinuousTemperatureMonitoring : DTDFVocab:Service [
    base:desc "Continuous monitoring of temperature sensors acquires data from the PT and checks against model expectations.",
    DTDFVocab:provides SafetyViolationInsight
]

instance TemperatureTrajectoryPrediction : DTDFVocab:Service [
    base:desc "Prediction of future temperature trajectories by executing the calibrated simulation models.",
    DTDFVocab:provides PredictiveInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibration/parameter‑estimation service that updates model parameters with best‑fit values based on latest sensor data.",
    DTDFVocab:provides CalibrationInsight
]

instance OptimisationDecisionSupportService : DTDFVocab:Service [
    base:desc "Optimisation and decision‑support service that evaluates safety/optimality and recommends corrective actions.",
    DTDFVocab:provides OptimisationSuggestionAction
]

instance AdvancedVisualizationService : DTDFVocab:Service [
    base:desc "Advanced visualisation service that displays simulation outcomes and current system state.",
    DTDFVocab:provides VisualisationInsight
]

// ==================== Insights ====================
// C17: Insights
instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that real‑time temperature deviates from calibrated model beyond safe thresholds."
]

instance PredictiveInsight : DTDFVocab:Insight [
    base:desc "Insight providing forecasted temperature evolution for the next operational horizon."
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight reporting the quality of model calibration and confidence in parameter estimates."
]

instance VisualisationInsight : DTDFVocab:Insight [
    base:desc "Insight delivering visual representations of current temperature field and predicted trajectories."
]

// ==================== Actions ====================
// C17: Actions
instance OptimisationSuggestionAction : DTDFVocab:Action [
    base:desc "Action proposing adjustment of heat‑bed set‑point or fan speed to restore safe and optimal operation.",
    DTDFVocab:IsAutomatic false
]

// ==================== Acting Components ====================
// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed providing heating power to the incubator interior controlled via GPIO commands from Raspberry Pi."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Circulating fan that distributes warm air within the incubator speed set via GPIO commands from Raspberry Pi."
]

// ==================== Environment ====================
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InternalTempSensorA, InternalTempSensorB, ExternalTempSensor,
                 HeatBedActuator, FanActuator, RabbitMQBroker, CalibrationAlgorithm,
                 PredictionEngine, MonitoringEngine, OptimizationEngine, VisualizationEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The controller (running on a Raspberry Pi) sends control commands to the low‑level driver through RabbitMQ messages. Commands include turning the heat‑bed on/off, fan activation, and parameters such as heating duration (H) and waiting duration (C). Messages are formatted as RabbitMQ payloads (AMQP). The low‑level driver validates incoming commands using an incorporated safe protocol before acting on the physical actuators, and it publishes status updates and sensor readings back to the broker, providing feedback to the controller. Conflict‑resolution and explicit execution acknowledgements are not detailed in the documents."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT streams sensor and controller messages from the physical incubator to a time‑series database in real‑time, enabling immediate dashboard updates for status monitoring."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT follows a centralized orchestration where the physical controller and low‑level driver feed data to a time‑series database; calibration, Kalman‑filter based anomaly detection, what‑if co‑simulation, and controller re‑configuration are coordinated in a self‑adaptation loop that closes the digital‑physical feedback cycle."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the two thermal models against experimental temperature traces; the four‑parameter model shows higher accuracy in reproducing the heat‑bed’s thermal inertia. Validation is performed through laboratory experiments that record temperature responses and compute prediction errors. Calibration algorithms update model parameters to reduce mismatch, providing a form of error correction. Sources of uncertainty include simplifications in the thermal model and sensor measurement noise; quantitative uncertainty quantification is not detailed."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between all components (controller, low‑level driver, and Digital Twin services) is mediated by a RabbitMQ message broker. RabbitMQ uses the AMQP protocol over TCP/IP, forming a star‑topology where each participant connects to the central broker. The broker can be deployed on‑premise or in the cloud and is described as lightweight, mature, and supporting reliable message delivery, though specific bandwidth, latency, redundancy or security mechanisms (e.g., TLS, authentication) are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ communication server, which underpins the Digital Twin, can be hosted either on‑premises or in a cloud environment, as stated in the documents. No quantitative specifications for computational power, storage capacity, scalability mechanisms, deployment models (e.g., containers, VMs) or availability guarantees are provided."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT integrates with external components such as a time‑series database and a visualization dashboard, and exchanges data with co‑simulation modules that can consume historical or real‑time PT data."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The described Digital Twin includes safety‑oriented mechanisms: calibration algorithms update the cyber‑physical system and environment models with the best parameter estimates, and the resulting data feed monitors that continuously verify that the physical twin is operating safely and optimally. When a safety violation is detected, the system can invoke human operators or automated algorithms to adjust or halt the physical twin. No specific security protocols, access control, or privacy measures are mentioned in the provided documents."
]