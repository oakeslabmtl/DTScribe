// C3: Physical sensing components
instance IncubatorInternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer inside incubator (range –55 °C to +125 °C, 0.5 °C accuracy) connected to Raspberry Pi GPIO"
    DTDFVocab:producedData InternalTempDataTxA
]

instance IncubatorInternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer inside incubator (range –55 °C to +125 °C, 0.5 °C accuracy) connected to Raspberry Pi GPIO"
    DTDFVocab:producedData InternalTempDataTxB
]

instance AmbientRoomTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring ambient room temperature (range –55 °C to +125 °C, 0.5 °C accuracy) connected to Raspberry Pi GPIO"
    DTDFVocab:producedData AmbientTempDataTx
]

// C4: Physical-to-virtual interaction – Data transmitted
instance InternalTempDataTxA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInternalTempSensorA
]

instance InternalTempDataTxB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInternalTempSensorB
]

instance AmbientTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientRoomTempSensor
]

// C10: Data
instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Temperature measurement (°C) from internal sensor A"
    DTDFVocab:fromData InternalTempDataTxA
    DTDFVocab:inputTo RabbitMQBroker, PythonOptimizer
]

instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Temperature measurement (°C) from internal sensor B"
    DTDFVocab:fromData InternalTempDataTxB
    DTDFVocab:inputTo RabbitMQBroker, PythonOptimizer
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Temperature measurement (°C) from ambient room sensor"
    DTDFVocab:fromData AmbientTempDataTx
    DTDFVocab:inputTo RabbitMQBroker, PythonOptimizer
]

// C2: Acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heat‑bed providing up to ≤100 W, switched via MOSFET on PCB controlled by Raspberry Pi GPIO"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V DC fan circulating air at ≤0.02 m³·s⁻¹ (full turnover ≈2 s), driven through MOSFET switches and optocouplers"
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on Raspberry Pi, receives temperature messages from driver and forwards to services"
    DTDFVocab:enables RealTimeMonitoringService, SafetyCheckService, PredictiveSimulationService
]

instance PythonOptimizer : DTDFVocab:Enabler [
    base:desc "Python 3 SciPy non‑linear least‑squares optimizer used for calibrating thermal models"
    DTDFVocab:enables ModelCalibrationService
]

instance ControllerStateChart : DTDFVocab:Enabler [
    base:desc "State‑chart implementation on Raspberry Pi that orchestrates heater and fan commands"
    DTDFVocab:enables RealTimeMonitoringService, SafetyCheckService
]

instance PredictiveEngine : DTDFVocab:Enabler [
    base:desc "Engine that runs calibrated thermal models for predictive temperature simulation"
    DTDFVocab:enables PredictiveSimulationService
]

// C6: Services
instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates Model A and Model B parameters using experimental temperature trajectory data"
    DTDFVocab:provides CalibrationCompleteInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Monitors real‑time temperature, detects deviation from set‑points and issues alerts"
    DTDFVocab:provides TemperatureDeviationInsight, RecommendedAdjustmentAction
]

instance SafetyCheckService : DTDFVocab:Service [
    base:desc "Performs safety checks via low‑level driver safe protocol and raises violation alerts"
    DTDFVocab:provides SafetyViolationAlert
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Runs predictive simulation of incubator thermal behaviour to support set‑point tracking"
    DTDFVocab:provides PredictiveTemperatureInsight
]

// C17: Insights & Actions
instance CalibrationCompleteInsight : DTDFVocab:Insight [
    base:desc "Indicates that model parameters (C_air, G_box, C_heater, G_heater) have been successfully calibrated"
]

instance TemperatureDeviationInsight : DTDFVocab:Insight [
    base:desc "Detects temperature deviation from desired set‑point and notifies operator"
]

instance RecommendedAdjustmentAction : DTDFVocab:Action [
    base:desc "Suggests increasing heater power or fan speed to correct temperature deviation"
    DTDFVocab:IsAutomatic false
]

instance SafetyViolationAlert : DTDFVocab:Insight [
    base:desc "Alerts operator when unsafe condition detected (e.g., over‑temperature or fan failure)"
]

instance PredictiveTemperatureInsight : DTDFVocab:Insight [
    base:desc "Provides forecasted temperature trajectory based on calibrated thermal model"
]

// C10: Models/Data
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single‑node thermal model with air heat capacity C_air and box conductance G_box"
    DTDFVocab:inputTo PythonOptimizer, PredictiveEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Extended thermal model adding heater temperature node with C_heater and G_heater"
    DTDFVocab:inputTo PythonOptimizer, PredictiveEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (heat‑bed ON/OFF, fan ON/OFF, heating duration, waiting duration) are sent from the DT to the Raspberry Pi via RabbitMQ; the controller extracts the commands and toggles the MOSFET drivers to actuate the heat‑bed and fan."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture consists of the Physical Twin (incubator hardware), a low‑level driver layer, a RabbitMQ communication server, a controller module (bang‑bang with wait), and DT components (calibration algorithm, monitor, simulator) that subscribe/publish to RabbitMQ, forming a closed loop between PT and virtual models."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the design stage (development of thermal models Model A and Model B), the manufacturing/implementation stage (hardware assembly and software deployment), and the operation stage (continuous monitoring, calibration against experimental data, and run‑time prediction)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity relies on four assumptions (uniform temperature, negligible wall heat storage, constant air specific heat, negligible fan heat). Calibration minimizes residual error using least‑squares; validation is performed with uniform‑temperature experiments (temperature spread ≤7 °C, reduced to ≤6 °C with higher fan voltage). Model B captures heat‑bed inertia, improving predictive accuracy."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data exchange uses the AMQP protocol of RabbitMQ over the Raspberry Pi’s built‑in Wi‑Fi/Bluetooth network; sensor data are sent as messages, and control commands are received via the same broker. The 1‑Wire bus provides sensor connectivity to the Pi GPIO."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "RabbitMQ server and all DT services are deployed locally on the Raspberry Pi 4 (on‑premises). The Pi’s Wi‑Fi enables remote monitoring if required; the open‑source repository provides the full software stack for replication."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol that forces the hardware into a known safe state on communication errors; the controller includes safety limits (lower/upper temperature bounds) and a waiting period to avoid overshoot, ensuring safe operation of the incubator."
]