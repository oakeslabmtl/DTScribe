// Sensing Component
instance PTTimeStampedMeasurementSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor data acquisition layer that collects time‑stamped measurements from the Physical Twin."
    DTDFVocab:producedData PTSensorDataStream
]

// Data Transmitted
instance PTSensorDataStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PTTimeStampedMeasurementSensor
]

// Data Repository
instance PTDataSeriesRepository : DTDFVocab:Data [
    base:desc "Continuously streamed from PTSensorDataStream, forming a time‑series repository that captures the PT’s operating conditions."
    DTDFVocab:fromData PTSensorDataStream
    DTDFVocab:inputTo CalibrationAlgorithm, MonitoringModule, FaultDetector, ModellingLayer
]

// Models
instance GeometricAbstractionModel : DTDFVocab:Model [
    base:desc "Encapsulates geometric abstractions of the physical twin."
    DTDFVocab:inputTo ModellingLayer, CalibrationAlgorithm
]

instance BehavioralDynamicsModel : DTDFVocab:Model [
    base:desc "Captures behavioral dynamics rendered as differential equations or simulation kernels."
    DTDFVocab:inputTo ModellingLayer, CalibrationAlgorithm
]

instance EnvironmentalKnowledgeModel : DTDFVocab:Model [
    base:desc "Incorporates environmental knowledge, including analytical formulations."
    DTDFVocab:inputTo ModellingLayer
]

// Enablers
instance SensorDataAcquisition : DTDFVocab:Enabler [
    base:desc "Enabler that schedules data ingestion from the PTTimeStampedMeasurementSensor."
    DTDFVocab:enables MonitoringService, PredictionService, OptimizationService, ControlService
]

instance ModellingLayer : DTDFVocab:Enabler [
    base:desc "Layer that integrates dynamic models expressed through differential equations capturing cyber and physical aspects."
    DTDFVocab:enables PredictionService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Calibration algorithms iteratively adjust model parameters with latest observations."
    DTDFVocab:enables PredictionService, OptimizationService
]

instance MonitoringModule : DTDFVocab:Enabler [
    base:desc "Module that evaluates safety and operational constraints from PTDataSeriesRepository."
    DTDFVocab:enables MonitoringService
]

instance FaultDetector : DTDFVocab:Enabler [
    base:desc "Fault detector algorithm that processes live sensor data and model predictions to detect anomalies."
    DTDFVocab:enables MonitoringService
]

instance SupervisoryController : DTDFVocab:Enabler [
    base:desc "Supervisory controller that recommends or enacts interventions on the physical system."
    DTDFVocab:enables ControlService
]

instance StateEstimator : DTDFVocab:Enabler [
    base:desc "State estimator that processes live data for accurate system state estimation."
    DTDFVocab:enables ControlService
]

instance Optimizer : DTDFVocab:Enabler [
    base:desc "Data‑driven optimizer that suggests parameter adjustments maximizing system performance."
    DTDFVocab:enables OptimizationService
]

// Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuously assesses safety and optimal performance of the Physical Twin by ingesting real‑time sensor data and running model‑based checks."
    DTDFVocab:provides SafetyAssessmentInsight, FaultDetectionInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Executes physics‑based simulation to reproduce and predict future behavior of the twin under current operating conditions."
    DTDFVocab:provides FutureBehaviorInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Applies data‑driven techniques to suggest parameter adjustments maximizing system performance."
    DTDFVocab:provides ParameterAdjustmentRecommendation
]

instance ControlService : DTDFVocab:Service [
    base:desc "Recommends or enacts interventions on the physical system based on model calibrations, supervisory controllers, and state estimators."
    DTDFVocab:provides CorrectiveAction
]

// Insights
instance SafetyAssessmentInsight : DTDFVocab:Insight [
    base:desc "Insight that evaluates safety and performance metrics derived from real‑time monitoring modules."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight generated by fault‑detector algorithms processing live sensor data and model predictions."
]

instance FutureBehaviorInsight : DTDFVocab:Insight [
    base:desc "Insight that reproduces and predicts future behavior of the twin under current operating conditions."
]

// Actions
instance CorrectiveAction : DTDFVocab:Action [
    base:desc "Action that recommends or enacts adjustments to physical system parameters."
    DTDFVocab:IsAutomatic true
]

instance ParameterAdjustmentRecommendation : DTDFVocab:Action [
    base:desc "Action that suggests parameter adjustments to maximize system performance."
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is implemented as an integrated framework that combines three core components: (1) Data – real‑time sensor streams recorded from the Physical Twin; (2) Models – analytical or simulation models that capture the cyber and physical aspects of the system and its environment; (3) Algorithms – processes that calibrate the models using the sensor data, run optimisers and fault detectors, and generate control or supervisory actions. The framework orchestrates these components in a pipeline where calibration algorithms first update model parameters, the updated models produce predictions that are compared against live data via monitors, and any violations trigger corrective actions. This design follows a modular, layered architecture with explicit data flow and feedback loops, and is often deployed within a cloud or edge‑computing environment to manage resources and coordinate simulation workloads."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Development, validation and simulation of abstract models (CAD geometry, differential equation dynamics) followed by deployment of a Digital Twin that ingests continuous sensor data. Real‑time calibration algorithms update model parameters, and monitors compare predicted and observed behavior to ensure safety and optimality. Violations trigger human or algorithmic interventions. Governance is exercised via these monitoring loops and model update cycles."
]