// C3: Physical sensing components
instance IncubatorInsideTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor located inside the incubator chamber, provides numeric temperature measurements."
    DTDFVocab:producedData IncubatorInsideTempDataTransmitted1
]

instance IncubatorInsideTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second temperature sensor located inside the incubator chamber, provides numeric temperature measurements."
    DTDFVocab:producedData IncubatorInsideTempDataTransmitted2
]

instance IncubatorExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor located outside the incubator, provides ambient temperature measurements."
    DTDFVocab:producedData IncubatorExternalTempDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance IncubatorInsideTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    base:desc "Temperature measurement stream transmitted from IncubatorInsideTempSensor1 to the Digital Twin."
    DTDFVocab:producedFrom IncubatorInsideTempSensor1
]

instance IncubatorInsideTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    base:desc "Temperature measurement stream transmitted from IncubatorInsideTempSensor2 to the Digital Twin."
    DTDFVocab:producedFrom IncubatorInsideTempSensor2
]

instance IncubatorExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "Temperature measurement stream transmitted from IncubatorExternalTempSensor to the Digital Twin."
    DTDFVocab:producedFrom IncubatorExternalTempSensor
]

// C10: Data
instance IncubatorInsideTempData1 : DTDFVocab:Data [
    base:desc "Temperature data collected over time from IncubatorInsideTempSensor1."
    DTDFVocab:fromData IncubatorInsideTempDataTransmitted1
    DTDFVocab:inputTo CalibrationEngine, SimulationEngine, MonitoringEngine, OptimisationEngine
]

instance IncubatorInsideTempData2 : DTDFVocab:Data [
    base:desc "Temperature data collected over time from IncubatorInsideTempSensor2."
    DTDFVocab:fromData IncubatorInsideTempDataTransmitted2
    DTDFVocab:inputTo CalibrationEngine, SimulationEngine, MonitoringEngine, OptimisationEngine
]

instance IncubatorExternalTempData : DTDFVocab:Data [
    base:desc "Ambient temperature data collected over time from IncubatorExternalTempSensor."
    DTDFVocab:fromData IncubatorExternalTempDataTransmitted
    DTDFVocab:inputTo CalibrationEngine, SimulationEngine, MonitoringEngine, OptimisationEngine
]

// C10: Models
instance SimpleIncubatorThermalModel : DTDFVocab:Model [
    base:desc "Simple thermal model of the incubator temperature with two free parameters, used for fast simulation."
    DTDFVocab:inputTo SimulationEngine, CalibrationEngine, MonitoringEngine
]

instance DetailedIncubatorThermalModel : DTDFVocab:Model [
    base:desc "Detailed thermal model with four free parameters capturing the thermal inertia of the heat‑bed."
    DTDFVocab:inputTo SimulationEngine, CalibrationEngine, MonitoringEngine
]

// C11: Enablers
instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Software component that runs calibration algorithms to continuously adjust model parameters using the latest sensor data."
    DTDFVocab:enables CalibrationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Computational engine that executes simulation models to predict the incubator’s thermal behaviour."
    DTDFVocab:enables ThermalPredictionService
]

instance MonitoringEngine : DTDFVocab:Enabler [
    base:desc "Monitoring component that compares simulated and measured temperature states to detect safety or performance violations."
    DTDFVocab:enables MonitoringService
]

instance OptimisationEngine : DTDFVocab:Enabler [
    base:desc "Optimisation component that suggests or enacts control actions to maintain the target temperature."
    DTDFVocab:enables OptimisationService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Provides calibration algorithms that adjust cyber‑physical model parameters based on sensor data."
    DTDFVocab:provides CalibrationInsight
]

instance ThermalPredictionService : DTDFVocab:Service [
    base:desc "Provides simulation‑based prediction of the incubator’s thermal behaviour."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Provides monitoring of temperature safety and optimality, generating alerts on violations."
    DTDFVocab:provides SafetyViolationAlertInsight
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Provides optimisation recommendations or automatic control actions for temperature regulation."
    DTDFVocab:provides OptimisationRecommendationInsight, AdjustControlAction
]

// C17: Insights
instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Updated set of model parameters after calibration using the latest sensor data."
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory of the incubator derived from simulation models."
]

instance SafetyViolationAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating deviation between measured and simulated temperature exceeding safety thresholds."
]

instance OptimisationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommendation to modify heating element setpoint or fan speed to achieve the target temperature."
]

// C17: Actions
instance AdjustControlAction : DTDFVocab:Action [
    base:desc "Action to adjust the heating element setpoint or fan speed; can be enacted automatically."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT can issue control actions back to the PT to regulate the incubator temperature. Commands are directed to the heatbed (heating element) and the fan (air distribution). The documents mention that the DT may make changes to the physical twin, but they do not describe the command format, validation or authentication mechanisms, feedback loops, conflict‑resolution strategies, or confirmation of command execution."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin follows a modular pipeline architecture: sensor data from the Physical Twin is ingested, calibration algorithms update the cyber‑physical system and environment models with the best‑estimate parameters, the refreshed models feed monitoring components that assess safety and optimality, and upon detection of violations a decision component (human operator or automated algorithm) triggers corrective actions on the Physical Twin. This reflects coordinated orchestration of data acquisition, model calibration, monitoring, and actuation as described in Document 1."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing two temperature prediction models: the four‑parameter model, which captures the heat‑bed’s thermal inertia, demonstrated higher predictive accuracy in experimental trials and was therefore selected for further DT development. Validation is performed through empirical experiments that measure the incubator temperature and compare it to model outputs. Calibration algorithms are used to update model parameters based on observed data, providing a mechanism for error correction. The documents do not detail uncertainty quantification, error detection methods, or broader quality‑assurance processes."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT architecture includes a cyber‑physical link that enables data acquisition from sensors and command transmission to actuators, but the documents do not provide details on the underlying network infrastructure such as specific communication protocols, network topology, bandwidth, latency, reliability, redundancy, or security protocols."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The documents describe the DT as a framework that integrates models, algorithms, and data, yet they give no information about the hosting environment (cloud, edge, or on‑premise), computational or storage resources, scalability approaches, deployment models, or availability and reliability guarantees."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The Digital Twin framework described integrates monitoring algorithms that continuously evaluate sensor data collected from the Physical Twin to detect safety violations. When a breach of predefined safety constraints is identified, the DT triggers alerts and a decision loop that may involve human operators or autonomous controllers to enact corrective actions on the Physical Twin. This safety‑centric monitoring is explicitly mentioned as a core part of the DT architecture, aiming to keep the system operating within safe limits and to enable predictive safety checks."
]