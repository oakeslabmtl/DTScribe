// C3: Physical sensing components
instance InteriorTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Interior temperature sensor placed inside the incubator box to measure internal air temperature."
    DTDFVocab:producedData InteriorTempDataTransmitted1
]

instance InteriorTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second interior temperature sensor placed inside the incubator box to measure internal air temperature."
    DTDFVocab:producedData InteriorTempDataTransmitted2
]

instance ExteriorTempSensor : DTDFVocab:SensingComponent [
    base:desc "Exterior temperature sensor placed outside the incubator box to monitor ambient temperature."
    DTDFVocab:producedData ExteriorTempDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance InteriorTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTempSensor1
]

instance InteriorTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTempSensor2
]

instance ExteriorTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExteriorTempSensor
]

// C10: Data
instance InteriorTemperatureData1 : DTDFVocab:Data [
    base:desc "Numeric air temperature reading (°C) from interior sensor 1."
    DTDFVocab:fromData InteriorTempDataTransmitted1
    DTDFVocab:inputTo CalibrationAlgorithm, KalmanFilter, VisualizationDashboard
]

instance InteriorTemperatureData2 : DTDFVocab:Data [
    base:desc "Numeric air temperature reading (°C) from interior sensor 2."
    DTDFVocab:fromData InteriorTempDataTransmitted2
    DTDFVocab:inputTo CalibrationAlgorithm, KalmanFilter, VisualizationDashboard
]

instance ExteriorTemperatureData : DTDFVocab:Data [
    base:desc "Numeric ambient temperature reading (°C) from exterior sensor."
    DTDFVocab:fromData ExteriorTempDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithm, KalmanFilter, VisualizationDashboard
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "AMQP message broker that receives sensor readings and controller states, archiving them in a time‑series database."
    DTDFVocab:enables RealTimeVisualizationService, CalibrationService, AnomalyDetectionService, WhatIfSimulationService, SelfAdaptationLoopService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Custom calibration routine that updates parameters of ModelB using streamed temperature data."
    DTDFVocab:enables CalibrationService
]

instance KalmanFilter : DTDFVocab:Enabler [
    base:desc "Kalman‑filter implementation that fuses sensor measurements with ModelB predictions to estimate heat‑bed state and detect anomalies."
    DTDFVocab:enables AnomalyDetectionService
]

instance CoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation framework that ingests historic or live physical‑twin data to run what‑if simulations of controller settings."
    DTDFVocab:enables WhatIfSimulationService
]

instance VisualizationDashboard : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard that visualizes real‑time temperature, fan, and heat‑bed states from the time‑series database."
    DTDFVocab:enables RealTimeVisualizationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides live visualization of incubator status including temperature, fan, and heat‑bed states."
    DTDFVocab:provides TemperatureVisualizationInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Executes on‑demand calibration of thermal models (ModelA and ModelB) by adjusting free parameters from sensor streams."
    DTDFVocab:provides ModelCalibrationInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Detects temperature anomalies and estimates heat‑bed state using Kalman filter applied to ModelB."
    DTDFVocab:provides AnomalyInsight, HeatBedStateInsight
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Runs what‑if simulations to forecast temperature evolution under alternative controller parameters for optimisation."
    DTDFVocab:provides SimulationForecastInsight, OptimizationRecommendationInsight
]

instance SelfAdaptationLoopService : DTDFVocab:Service [
    base:desc "Self‑adaptation loop that detects deviations, triggers experiments, recalibrates models, updates the Kalman filter and re‑configures the controller automatically."
    DTDFVocab:provides RecalibrationAction, ControllerReconfigurationAction
]

// C17: Insights
instance TemperatureVisualizationInsight : DTDFVocab:Insight [
    base:desc "Real‑time visualization of temperature readings from interior and exterior sensors on the dashboard."
]

instance ModelCalibrationInsight : DTDFVocab:Insight [
    base:desc "Indicates successful calibration of ModelA and ModelB parameters based on recent sensor data."
]

instance AnomalyInsight : DTDFVocab:Insight [
    base:desc "Flag raised when sensor data deviate from Kalman‑filter predictions, indicating a potential fault."
]

instance HeatBedStateInsight : DTDFVocab:Insight [
    base:desc "Estimated on/off state and thermal inertia of the heat‑bed derived from ModelB and Kalman filter."
]

instance SimulationForecastInsight : DTDFVocab:Insight [
    base:desc "Projected temperature trajectory under a given set of controller parameters generated by what‑if simulation."
]

instance OptimizationRecommendationInsight : DTDFVocab:Insight [
    base:desc "Recommended controller parameter adjustments to achieve the desired temperature set point efficiently."
]

// C17: Actions
instance RecalibrationAction : DTDFVocab:Action [
    base:desc "Automatic execution of the calibration routine to update ModelB parameters after detecting a deviation."
    DTDFVocab:IsAutomatic true
]

instance ControllerReconfigurationAction : DTDFVocab:Action [
    base:desc "Automatic update of bang‑bang controller thresholds (LL, UL, H, C) based on new model calibration."
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance ModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model assuming all supplied electrical power is transferred to the air inside the incubator (Q = c·m·ΔT)."
    DTDFVocab:inputTo CalibrationAlgorithm
]

instance ModelB : DTDFVocab:Model [
    base:desc "Analytical thermal model that accounts for thermal inertia of the heat‑bed and uses four free parameters."
    DTDFVocab:inputTo CalibrationAlgorithm, KalmanFilter
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are generated by the controller (a bang‑bang controller) and sent as RabbitMQ messages to the low‑level driver. Commands include heat‑bed actuation (on/off) and fan control, together with parameters such as lower/upper temperature limits (LL/UL), heating duration (H) and waiting duration (C). The low‑level driver validates each command against its safe protocol before driving the physical actuators and can acknowledge execution via a response message."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The low‑level driver periodically reads temperature sensors and uploads the measurements to the RabbitMQ communication server; the controller listens to these messages and publishes its control commands. The DT subscribes to the same RabbitMQ topics, stores the incoming stream in a time‑series database and updates visualisations on a dashboard in near real‑time. No explicit sampling period, latency requirement, or temporal granularity is specified in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a service‑oriented architecture coordinated through the RabbitMQ message broker (AMQP). Core DT services—calibration, Kalman‑filter‑based anomaly detection, what‑if simulation, and the self‑adaptation loop—subscribe to controller and driver messages, exchange data via the broker, persist streams in a time‑series database, and present results on a dashboard. This component integration constitutes the overall orchestration of the Digital Twin."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The incubator Digital Twin follows a lifecycle composed of (1) a development phase where the physical hardware (styrofoam box, heat‑bed, fan, temperature sensors) and the software stack (Raspberry Pi controller, low‑level driver, RabbitMQ communication server) are defined (Document 2, 5); (2) a modelling phase in which two simulation models (Model A and Model B) are constructed based on the four assumptions (Document 6); (3) a calibration phase that runs the calibration algorithm (section 3.3) to estimate model parameters from sensor data (Document 1, 4); (4) an operation phase where data from the physical twin are continuously streamed to the DT, monitors evaluate safety and performance, and visualization dashboards display the current status (Document 1, 4); and (5) a self‑adaptation phase that closes the loop by detecting anomalies, planning experiments, re‑calibrating the model, updating the Kalman filter and the controller, and re‑deploying new control parameters (Document 4). Transition between phases is managed through the RabbitMQ communication infrastructure and the calibration/monitoring algorithms, providing governance of the DT throughout its life."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity relies on four explicit assumptions: (1) uniform temperature distribution inside the box (ensured by the fan), (2) negligible heat storage in the box walls, (3) constant specific heat capacity of the internal air, and (4) that the majority of electrical power is converted to heat in the air (relaxed in Model B). Validation is performed by experimental comparison of model predictions against measured temperature traces (section 4 of the study, not detailed here) and by calibrating model parameters on‑line. Uncertainty sources include sensor noise, the simplifying assumptions above, and errors in estimated parameters. On‑demand calibration and a Kalman filter‑based state estimator are used to detect anomalies, re‑estimate the heatbed temperature, and correct model drift, thereby providing a quality‑assurance loop for the Digital Twin."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The Digital Twin uses a RabbitMQ message broker as the technical communication layer. RabbitMQ provides a publish/subscribe topology where the controller, low‑level driver, and DT components publish and subscribe to specific topics. The broker is described as mature, lightweight, and easy to deploy on‑premise or in the cloud, offering reliable message delivery. Specific bandwidth, latency, redundancy, or security (e.g., TLS) requirements are not detailed in the documents."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external components relies on the RabbitMQ broker for message exchange (AMQP protocol) between the controller, low‑level driver, and DT services, and on a time‑series database and visualization dashboard for data storage and presentation. No additional enterprise‑level standards or external system dependencies are described."
]