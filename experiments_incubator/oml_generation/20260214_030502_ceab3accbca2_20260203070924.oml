// C3: Physical sensing components
instance InteriorTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer inside the incubator, range -55 °C to +125 °C, 0.5 °C accuracy"
    DTDFVocab:producedData TemperatureTelemetry
]

instance InteriorTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer inside the incubator, second interior measurement point"
    DTDFVocab:producedData TemperatureTelemetry
]

instance ExteriorTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer mounted on the exterior of the incubator"
    DTDFVocab:producedData TemperatureTelemetry
]

// C2: Acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heater (heat‑bed) driven by MOSFETs on the PCB, up to 100 W"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal circulation fan driven by MOSFETs, 12‑24 V, 0.02 m³·s⁻¹ flow"
]

// C4: Physical‑to‑virtual interaction (data transmitted)
instance TemperatureTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTempSensor1, InteriorTempSensor2, ExteriorTempSensor
]

instance DeviceStatusTelemetry : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom LowLevelDriver
]

// C5: Data
instance TemperatureData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature measurements sampled by the low‑level driver and published via AMQP"
    DTDFVocab:fromData TemperatureTelemetry
    DTDFVocab:inputTo RabbitMQBroker, SciPyLeastSquares
]

instance DeviceStatusData : DTDFVocab:Data [
    base:desc "Operational status messages (heartbeat, errors) emitted by the driver"
    DTDFVocab:fromData DeviceStatusTelemetry
    DTDFVocab:inputTo RabbitMQBroker
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single‑capacity air thermal model with heat loss G_box"
    DTDFVocab:inputTo SciPyLeastSquares, PythonSimulator
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Extended model adding heater thermal capacity and conductance G_heater"
    DTDFVocab:inputTo SciPyLeastSquares, PythonSimulator
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "AMQP broker (RabbitMQ) receiving temperature and status messages in near‑real‑time"
    DTDFVocab:enables RealTimeMonitoringService, ModelBasedSimulationService, FaultDetectionService
]

instance SciPyLeastSquares : DTDFVocab:Enabler [
    base:desc "SciPy non‑linear least‑squares optimiser used for parameter calibration and predictive optimisation"
    DTDFVocab:enables ParameterCalibrationService, PredictiveOptimisationService
]

instance PythonSimulator : DTDFVocab:Enabler [
    base:desc "Python runtime executing the calibrated thermal models for simulation"
    DTDFVocab:enables ModelBasedSimulationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature streams from the incubator"
    DTDFVocab:provides CurrentTemperatureInsight
]

instance ModelBasedSimulationService : DTDFVocab:Service [
    base:desc "Model‑based simulation using Model A or Model B to predict temperature trajectories"
    DTDFVocab:provides SimulatedTemperatureInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Parameter calibration of thermal models via SciPy least‑squares on collected traces"
    DTDFVocab:provides CalibratedParametersInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection by checking safe‑protocol limits on incoming messages"
    DTDFVocab:provides FaultAlertInsight
]

instance PredictiveOptimisationService : DTDFVocab:Service [
    base:desc "Predictive optimisation of heating cycles using calibrated models"
    DTDFVocab:provides AdjustHeatingCycleAction
]

// C17: Insights
instance CurrentTemperatureInsight : DTDFVocab:Insight [
    base:desc "Current temperature reading for each sensor point"
]

instance SimulatedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory generated by the thermal model"
]

instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Updated model parameters (C_air, C_heater, G_box, G_heater) after calibration"
]

instance FaultAlertInsight : DTDFVocab:Insight [
    base:desc "Detected faults based on safe‑protocol checks (e.g., sensor out‑of‑range)"
]

// C17: Actions
instance AdjustHeatingCycleAction : DTDFVocab:Action [
    base:desc "Adjust heating duration (H), waiting duration (C), and temperature limits (LL, UL) based on calibrated parameters"
    DTDFVocab:IsAutomatic true
]

// Additional components
instance LowLevelDriver : DTDFVocab:Component [
    base:desc "Low‑level driver on Raspberry Pi that samples sensors, packages messages and reports device status"
]

instance RaspberryPi4Controller : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B providing GPIO for sensor readout and actuator control"
]

instance CustomPCB : DTDFVocab:Component [
    base:desc "Custom PCB with MOSFET drivers and optocouplers for safe actuation of heater and fan"
]

// Environment containing all components
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, FanActuator, InteriorTempSensor1, InteriorTempSensor2, ExteriorTempSensor, LowLevelDriver, RaspberryPi4Controller, CustomPCB
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (heat‑bed ON/OFF, fan ON/OFF, waiting durations) to the RabbitMQ broker; the controller on the Raspberry Pi subscribes, interprets the messages, and drives the MOSFETs to actuate the heat‑bed and fan."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture consists of the PT hardware layer, a low‑level driver layer, a RabbitMQ communication server hosted on the Raspberry Pi, and separate DT software modules that subscribe to the broker for sensor data and publish control commands. All components run on or communicate with the Pi, forming a tightly coupled CPS‑DT loop."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is limited by assumptions: uniform temperature (validated by fan‑induced mixing experiments), negligible wall heat storage, constant air specific heat, and ignored fan heat generation (Model A). Validation experiments measured temperature spread (≤7 °C, reduced to ≤6 °C with higher fan voltage) to assess uniformity. Calibration residuals guide validity."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual and virtual‑to‑physical data exchange uses the RabbitMQ message broker running on the Raspberry Pi, communicating over TCP/IP with the AMQP protocol. Messages carry temperature sensor values and control commands."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ server and all DT software components are deployed on the same Raspberry Pi 4 that also hosts the controller and low‑level driver; the PCB and sensors are physically attached to this platform."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the PT in a safe state; the controller includes monitoring for temperature limits and can trigger human intervention on violations. Communication via RabbitMQ can be secured by standard AMQP authentication, although specific security measures are not detailed."
]