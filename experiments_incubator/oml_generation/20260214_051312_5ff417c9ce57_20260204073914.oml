// C4: Physical-to-virtual interaction
instance TemperatureDataPacket : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor1, InternalTemperatureSensor2, ExternalTemperatureSensor
]

// C3: Physical sensing components
instance InternalTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor, positioned inside the styrofoam box (internal position 1)"
    DTDFVocab:producedData TemperatureDataPacket
]

instance InternalTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor, positioned inside the styrofoam box (internal position 2)"
    DTDFVocab:producedData TemperatureDataPacket
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor, positioned outside the styrofoam box for ambient temperature monitoring"
    DTDFVocab:producedData TemperatureDataPacket
]

// C10: Models/Data
instance TemperatureReadingsData : DTDFVocab:Data [
    base:desc "Temperature readings with timestamps from the DS18S20 sensors, stored in the digital twin data lake"
    DTDFVocab:inputTo OnboardRabbitMQBroker
    DTDFVocab:fromData TemperatureDataPacket
]

instance CalibrationObservationData : DTDFVocab:Data [
    base:desc "Observed temperature data used for calibration of thermal models"
    DTDFVocab:inputTo SciPyLeastSquaresOptimizer
    DTDFVocab:fromData TemperatureDataPacket
]

instance ModelInputData : DTDFVocab:Data [
    base:desc "Parameters and initial conditions for simulation of thermal models A and B"
    DTDFVocab:inputTo SimulationEngine
]

instance ThermalModelA : DTDFVocab:Model [
    base:desc "Energy balance equation model with parameters C_air and G_box"
    DTDFVocab:inputTo SimulationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Heatbed‑air coupling model with parameters C_air, C_heater, G_box, and G_heater"
    DTDFVocab:inputTo SimulationEngine
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature and actuator states via RabbitMQ"
    DTDFVocab:provides TemperatureAlertInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibrates parametric model parameters using non‑linear least‑squares solver in SciPy"
    DTDFVocab:provides CalibrationParameterUpdateInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimises selected model parameters to minimise residual error and suggest energy‑efficiency adjustments"
    DTDFVocab:provides FanVoltageAdjustmentSuggestionInsight, HeatingCycleAdjustmentSuggestionInsight
]

instance PredictiveAnalysisService : DTDFVocab:Service [
    base:desc "Provides predictive temperature graphs based on simulation of models A and B"
    DTDFVocab:provides PredictiveTemperatureGraphInsight
]

// C11: Enablers
instance OnboardRabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ broker running on Raspberry Pi, receives AMQP messages from sensors"
    DTDFVocab:enables RealTimeMonitoringService, CalibrationService
]

instance SciPyLeastSquaresOptimizer : DTDFVocab:Enabler [
    base:desc "SciPy least‑squares solver used for parameter calibration and optimisation"
    DTDFVocab:enables CalibrationService, OptimizationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "NumPy simulation engine that integrates thermal models A and B"
    DTDFVocab:enables PredictiveAnalysisService
]

// C7: Insights/Actions
instance TemperatureAlertInsight : DTDFVocab:Insight [
    base:desc "Real‑time alert when temperature limits are exceeded"
]

instance CalibrationParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Suggested updated model parameters after calibration"
]

instance PredictiveTemperatureGraphInsight : DTDFVocab:Insight [
    base:desc "Predictive temperature curves generated by simulation models"
]

instance FanVoltageAdjustmentSuggestionInsight : DTDFVocab:Insight [
    base:desc "Suggests decreasing fan voltage to improve energy efficiency"
]

instance HeatingCycleAdjustmentSuggestionInsight : DTDFVocab:Insight [
    base:desc "Suggests adjusting heating cycle duration to maintain desired temperature"
]

instance AdjustFanVoltageAction : DTDFVocab:Action [
    base:desc "Adjust fan voltage as suggested by the twin"
    DTDFVocab:IsAutomatic false
]

instance AdjustHeatingCycleAction : DTDFVocab:Action [
    base:desc "Adjust heating cycle duration as suggested by the twin"
    DTDFVocab:IsAutomatic false
]

// C1: Physical acting components
instance HeatingBedResistive : DTDFVocab:ActingComponent [
    base:desc "Resistive heater acting as the primary heat source in the incubator"
]

instance FanMotor : DTDFVocab:ActingComponent [
    base:desc "12 V/24 V fan driven via MOSFET transistors and optocouplers on the Raspberry Pi"
]

// C2: Acting Components (optional duplication)
instance Pi4ModelB : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B controller handling low‑level driver, safety protocol, and bang‑bang control"
]

instance PCBWithMOSFETs : DTDFVocab:Component [
    base:desc "Printed circuit board containing MOSFETs and optocouplers for heatbed and fan actuation"
]

instance OneWireBus : DTDFVocab:Component [
    base:desc "1‑Wire bus connecting DS18S20 sensors, wired to the Pi GPIO pins"
]

// C17: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatingBedResistive, FanMotor, Pi4ModelB, PCBWithMOSFETs, OneWireBus
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT consumes control messages from its workflow engine and transmits them over the RabbitMQ broker back to the controller. These messages dictate the on/off state of the heatbed and fan, effectively commanding the physical actuators. The controller listens to the command queue and actuates the MOSFETs accordingly, completing the closed‑loop DT‑PT interaction."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The interaction system performs polling of sensor data and command handling in an event‑driven manner; no explicit sampling interval or actuation latency is specified in the document."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation consists of the physical incubator, the low‑level driver, the controller, the RabbitMQ broker, and the DT engine running the simulation models. The driver and controller are tightly coupled to the Pi; the broker mediates between the PT and the remote DT services. All components are orchestrated via message queues and shared data structures."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle spans design (conceptual model and hardware selection), manufacturing (assembly of PCB, sensors, heatbed, and fan), and operation (deployment, periodic simulation, calibration, validation, and monitoring during experiments)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is constrained by assumptions: uniform temperature distribution (validated by uniform‑temperature experiments), negligible wall heat accumulation, constant specific heat of air, and ignoring fan heat. Validation via experimental temperature recordings against model predictions yielded residual errors; calibration improved fidelity. Uncertainty bounds arise from sensor accuracy (±0.5 °C) and parameter identifiability."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The communication stack uses AMQP over TCP/IP within the Raspberry Pi’s LAN. Sensors connect via 1‑Wire bus to GPIO pins; actuators are driven through MOSFETs controlled through GPIO lines. The RabbitMQ server runs locally on the Pi; controllers and DT services publish/subscribe to AMQP queues."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT components (controller, driver, RabbitMQ broker, simulation models) are hosted on the same Raspberry Pi 4, providing a tightly coupled local deployment without external cloud services."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safety protocol with defined lower and upper temperature limits (LL, UL), heating duration (H), and waiting duration (C) to avoid overheating. Electrical isolation is provided by optocouplers between the Pi and MOSFET controls. No further cybersecurity measures are detailed in the document."
]