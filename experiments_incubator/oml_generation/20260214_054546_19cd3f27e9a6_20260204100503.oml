// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "A 214x214x3 mm surface heat source delivering up to 100W (100J/s) of power to heat the air inside the styrofoam box. Requires ~4A current and is controlled via MOSFETs and optocouplers on the PCB."
]

instance AirCirculationFan : DTDFVocab:ActingComponent [
    base:desc "A 12V/24V fan with 0.02 m³/s airflow used to circulate air and ensure uniform temperature distribution inside the box."
]

instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi 4 Model B acting as central controller executing bang-bang control logic and interfacing with actuators via low-level driver and RabbitMQ communication server."
]

instance MosfetOptocouplerDriver : DTDFVocab:ActingComponent [
    base:desc "PCB components used to decouple control signals from Raspberry Pi GPIO and drive the heatbed actuator."
]

// C3: Physical Sensing Components
instance InsideHotZoneTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 High-Precision 1-Wire Digital Thermometer placed near the heatbed (hottest position) measuring air temperature with ±0.5°C accuracy (range: -55°C to +125°C)."
]

instance InsideColdZoneTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 High-Precision 1-Wire Digital Thermometer placed far from heatbed (coldest position) measuring air temperature with ±0.5°C accuracy (range: -55°C to +125°C)."
]

instance OutsideAmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 High-Precision 1-Wire Digital Thermometer measuring ambient room temperature with ±0.5°C accuracy (range: -55°C to +125°C)."
]

// C4: Physical-to-Virtual Interaction
instance InsideHotZoneTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideHotZoneTemperatureSensor
]

instance InsideColdZoneTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideColdZoneTemperatureSensor
]

instance OutsideAmbientTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideAmbientTemperatureSensor
]

instance HeatbedActivationStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HeatbedActuator
]

instance FanActivationStateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AirCirculationFan
]

// C10: Models/Data
instance FirstOrderThermalModelA : DTDFVocab:Model [
    base:desc "First-order differential equation thermal model (2 free parameters: C_air, G_box) assuming all heat energy transfers directly to air with negligible heatbed inertia."
    DTDFVocab:inputTo NonLinearLeastSquaresCalibrationEnabler
]

instance SecondOrderThermalModelB : DTDFVocab:Model [
    base:desc "Second-order thermal model (4 free parameters: C_air, C_heater, G_heater, G_box) accounting for heatbed thermal inertia with improved thermal dynamics prediction."
    DTDFVocab:inputTo NonLinearLeastSquaresCalibrationEnabler
]

instance TemperatureTrajectoryData : DTDFVocab:Data [
    base:desc "Time-series temperature measurements from all three sensors (±0.5°C accuracy) used for model calibration and validation."
    DTDFVocab:fromData InsideHotZoneTemperatureDataTransmitted, InsideColdZoneTemperatureDataTransmitted, OutsideAmbientTemperatureDataTransmitted
    DTDFVocab:inputTo NonLinearLeastSquaresCalibrationEnabler, BangBangControllerEnabler
]

instance ActuatorStateData : DTDFVocab:Data [
    base:desc "Heatbed and fan activation states with power profiles (e.g., 100W for 2s to heat 200J) used for control validation."
    DTDFVocab:fromData HeatbedActivationStateDataTransmitted, FanActivationStateDataTransmitted
    DTDFVocab:inputTo BangBangControllerEnabler
]

instance EnvironmentalData : DTDFVocab:Data [
    base:desc "Room temperature and fan airflow (0.02 m³/s) measurements used for environmental context in thermal models."
    DTDFVocab:fromData OutsideAmbientTemperatureDataTransmitted
    DTDFVocab:inputTo NonLinearLeastSquaresCalibrationEnabler
]

instance CalibrationTrajectoriesData : DTDFVocab:Data [
    base:desc "Experimental temperature trajectories (e.g., Fig. 10) used to optimize model parameters via least-squares methods."
    DTDFVocab:inputTo NonLinearLeastSquaresCalibrationEnabler
]

// C11: Enablers
instance RabbitMQCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "Open-source message broker facilitating asynchronous bidirectional communication between Physical Twin and Digital Twin via 1-Wire bus and GPIO."
    DTDFVocab:enables TemperatureMonitoringService, ControlCommandService, DataAggregationService
]

instance NonLinearLeastSquaresCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Python Scipy package implementation for non-linear least squares optimization of model parameters by minimizing residuals between simulated and experimental data."
    DTDFVocab:enables ModelCalibrationService, ParameterOptimizationService
]

instance BangBangControllerEnabler : DTDFVocab:Enabler [
    base:desc "Configurable bang-bang control logic implemented on Raspberry Pi with parameters (LL, UL, H, C) for temperature regulation."
    DTDFVocab:enables TemperatureControlService, EnergyOptimizationService
]

instance OneWireProtocolEnabler : DTDFVocab:Enabler [
    base:desc "1-Wire protocol enabling multi-sensor communication over a single GPIO pin on Raspberry Pi for efficient data collection."
    DTDFVocab:enables SensorDataCollectionService
]

// C6: Services
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of Physical Twin performance via RabbitMQ detecting deviations from optimal operation (e.g., temperature overshoot/undershoot)."
    DTDFVocab:provides TemperatureDeviationInsight, FaultDetectionAction
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Calibration of thermal models using non-linear least squares to optimize parameters (C_air, G_box, C_heater, G_heater) based on experimental data."
    DTDFVocab:provides CalibratedModelParametersInsight
]

instance TemperatureControlService : DTDFVocab:Service [
    base:desc "Execution of bang-bang control strategy to regulate temperature within specified limits (LL, UL) using heatbed and fan actuators."
    DTDFVocab:provides ControlParameterOptimizationAction
]

instance SimulationPredictionService : DTDFVocab:Service [
    base:desc "Runs both thermal models (Model A and Model B) to predict temperature dynamics inside the box with Model B offering higher fidelity."
    DTDFVocab:provides TemperaturePredictionInsight
]

instance DataAggregationService : DTDFVocab:Service [
    base:desc "Aggregates and processes real-time sensor data, actuator states, and environmental conditions from RabbitMQ for DT analysis."
    DTDFVocab:provides AggregatedSystemStateInsight
]

instance EnergyOptimizationService : DTDFVocab:Service [
    base:desc "Optimizes heating duration (H) and control parameters to minimize power consumption while meeting temperature targets."
    DTDFVocab:provides EnergyEfficiencyInsight, PowerProfileOptimizationAction
]

instance ParameterOptimizationService : DTDFVocab:Service [
    base:desc "Adjusts controller parameters (LL, UL, H, C) or Physical Twin configurations (e.g., fan voltage) to improve robustness and energy efficiency."
    DTDFVocab:provides OptimizedControlParametersInsight
]

instance SensorDataCollectionService : DTDFVocab:Service [
    base:desc "Periodic collection of temperature measurements from all three DS18S20 sensors via 1-Wire bus and transmission to RabbitMQ."
    DTDFVocab:provides SensorDataIntegrityInsight
]

instance ControlCommandService : DTDFVocab:Service [
    base:desc "Subscribes to RabbitMQ to receive real-time updates on Physical Twin states and send control commands to actuators."
    DTDFVocab:provides ActuatorCommandValidationInsight
]

// C17: Insights/Actions
instance TemperatureDeviationInsight : DTDFVocab:Insight [
    base:desc "Identifies temperature deviations from target (±7°C discrepancy reduced to ±6°C with 18V fan) indicating potential hardware or control issues."
]

instance FaultDetectionAction : DTDFVocab:Action [
    base:desc "Monitors temperature deviations to predict faults such as sensor drift or heatbed degradation."
    DTDFVocab:IsAutomatic true
]

instance CalibratedModelParametersInsight : DTDFVocab:Insight [
    base:desc "Reveals physical properties through calibrated values of C_air, G_box, C_heater, and G_heater, validating model assumptions."
]

instance ControlParameterOptimizationAction : DTDFVocab:Action [
    base:desc "Suggests adjustments to bang-bang parameters (LL, UL, H, C) to improve stability and reduce overshoot."
    DTDFVocab:IsAutomatic false
]

instance TemperaturePredictionInsight : DTDFVocab:Insight [
    base:desc "Provides predicted temperature trajectories using both Model A and Model B with Model B offering higher fidelity thermal dynamics."
]

instance EnergyEfficiencyInsight : DTDFVocab:Insight [
    base:desc "Quantifies energy consumption patterns and identifies opportunities for power reduction while maintaining temperature targets."
]

instance PowerProfileOptimizationAction : DTDFVocab:Action [
    base:desc "Optimizes heating duration (H) and power profiles to minimize energy consumption during temperature regulation."
    DTDFVocab:IsAutomatic true
]

instance OptimizedControlParametersInsight : DTDFVocab:Insight [
    base:desc "Provides optimal values for control parameters (LL, UL, H, C) based on experimental validation and model predictions."
]

instance SensorDataIntegrityInsight : DTDFVocab:Insight [
    base:desc "Validates sensor data quality and consistency across all three temperature measurements (±0.5°C accuracy)."
]

instance AggregatedSystemStateInsight : DTDFVocab:Insight [
    base:desc "Combines real-time sensor data, actuator states, and environmental conditions into a unified system state representation."
]

instance ActuatorCommandValidationInsight : DTDFVocab:Insight [
    base:desc "Validates actuator command execution and response against expected behavior in the thermal system."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT influences the PT through the following interactions: (1) **Control Commands**: The DT sends commands (e.g., turn heatbed/fan on/off) via the **RabbitMQ server** to the low-level driver on the Raspberry Pi. (2) **Parameter Updates**: The DT can adjust the **bang-bang controller parameters** (LL, UL, H, C) dynamically based on model predictions or optimization. (3) **Reconfiguration**: The DT may trigger reconfiguration of the PT (e.g., changing fan voltage from 12V to 18V) to improve temperature uniformity, as demonstrated in experiments. The **RabbitMQ server** acts as a message broker to synchronize these commands."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates on **real-time and quasi-real-time time scales**: (1) **Real-Time Control Loop**: The bang-bang controller on the Raspberry Pi executes at a **sub-second frequency** (e.g., 100ms–1s intervals) to regulate temperature based on sensor feedback. (2) **Quasi-Real-Time Calibration**: Model calibration occurs offline or during low-load periods, using historical data trajectories (e.g., 200J heating events over ~2s) to optimize parameters via iterative least-squares methods. (3) **Event-Driven Updates**: DT-to-PT synchronization happens asynchronously via RabbitMQ, with latency dependent on network conditions (local deployment minimizes delays)."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation follows a **cyber-physical integration framework** with the following orchestration: (1) **Physical Layer**: PT hardware (sensors, actuators, Raspberry Pi). (2) **Communication Layer**: RabbitMQ server acts as a message broker, decoupling PT components (sensors, actuators) from the DT. (3) **Virtual Layer**: DT runs on the same Raspberry Pi (or remotely) and includes: (a) **Simulation Models** (A and B), (b) **Calibration Engine** (Scipy-based), (c) **Control Logic** (bang-bang with parameter tuning). (4) **Feedback Loop**: The DT continuously updates models via calibration and adjusts PT behavior through RabbitMQ commands. The architecture is **modular**, allowing future extensions (e.g., cloud-based DT)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT covers the following lifecycle stages of the PT: (1) **As Designed**: Models (A and B) are derived from theoretical assumptions (e.g., uniform temperature, negligible heatbed inertia in Model A). (2) **As Manufactured**: Calibration adjusts models to match the **actual physical prototype** (e.g., styrofoam box, heatbed dimensions). (3) **As Operated**: The DT continuously monitors and optimizes the PT during runtime, adapting to environmental changes (e.g., room temperature fluctuations) and component wear (e.g., heatbed efficiency degradation). The DT does not explicitly cover **end-of-life** stages (e.g., decommissioning)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity and validity are addressed through: (1) **Model Assumptions**: Validated experimentally (e.g., Assumption 1 on uniform temperature tested via sensor placement in Fig. 9/11). (2) **Calibration Accuracy**: Model parameters are optimized using **least-squares minimization** (Scipy) to reduce residual errors between predictions and real data. (3) **Uncertainty Quantification**: Model B (4 parameters) accounts for heatbed thermal inertia, improving fidelity over Model A (2 parameters). (4) **Verification**: Experimental results (e.g., Fig. 10/12) show temperature discrepancies (±7°C to ±6°C) due to fan voltage adjustments, validating model assumptions. (5) **Error Handling**: The low-level driver includes a **safe protocol** to prevent unsafe PT states (e.g., overheating)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT connects to the PT via: (1) **Network Protocol**: **RabbitMQ** (AMQP-based) for asynchronous message passing between the Raspberry Pi and DT components. (2) **Physical Interface**: (a) **1-Wire Bus**: Connects DS18S20 sensors to Raspberry Pi GPIO. (b) **GPIO Pins**: Control heatbed/fan via MOSFETs (optocouplers isolate signals). (3) **Data Flow**: Temperature data is sampled at **sub-second intervals** and transmitted to RabbitMQ. Control commands are pushed from DT to PT with **low latency** (local deployment). (4) **Redundancy**: No explicit failover mechanisms, but RabbitMQ supports **message persistence** and **acknowledgments** for reliability."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted on the **same Raspberry Pi 4 Model B** as the PT controller, with the following deployment details: (1) **Local Deployment**: RabbitMQ server runs on the Raspberry Pi, minimizing network latency. (2) **Software Stack**: Python-based (Scipy for calibration, custom control logic). (3) **Scalability**: The architecture supports **remote DT deployment** (e.g., cloud-based) by leveraging RabbitMQ’s distributed nature. (4) **Resource Constraints**: Limited by Raspberry Pi’s computational power (e.g., calibration is performed offline or during low-load periods). (5) **Open-Source**: All hardware/software is available via [GitHub](https://github.com/INTO-CPS-Association/example-incubator)."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT incorporates the following safety and security measures: (1) **Safety**: (a) **Bang-Bang Controller Safeguards**: Configurable upper/lower limits (UL/LL) prevent overheating or excessive cooling. (b) **Low-Level Driver Protocol**: Ensures PT remains in a safe state (e.g., no commands during calibration). (c) **Hardware Redundancy**: Multiple temperature sensors (2 inside, 1 outside) cross-validate measurements. (2) **Security**: (a) **Local Deployment**: RabbitMQ runs on the Raspberry Pi, reducing exposure to external threats. (b) **No Explicit Encryption**: Data is transmitted locally without encryption (assumed secure in isolated environments). (c) **Access Control**: Not explicitly documented, but RabbitMQ supports **authentication/authorization** for message queues. (3) **Operational Safety**: The DT cannot execute **direct remote operations** on the PT without human oversight (e.g., parameter changes require manual validation)."
]