// C3: Physical sensing components
instance TimeSeriesDataSensor : DTDFVocab:SensingComponent [
    base:desc "Collects time‑series data streams from the physical twin using various unspecified sensors."
    DTDFVocab:producedData PhysicalTwinDataTransmitted
]

// C4: Physical-to-virtual interaction
instance PhysicalTwinDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TimeSeriesDataSensor
]

// C10: Models/Data
instance PhysicalTwinHistoricalData : DTDFVocab:Data [
    base:desc "Historical time‑series data streams received from the physical twin."
    DTDFVocab:fromData PhysicalTwinDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler, FaultDetectionEnabler
]

instance CadModel : DTDFVocab:Model [
    base:desc "CAD model that captures the macroscopic structure of the physical twin."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler
]

instance DifferentialEquationModel : DTDFVocab:Model [
    base:desc "Behavioral model expressed through differential equations capturing dynamic response."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler
]

// C11: Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration enabler updates model parameters using sensor data."
    DTDFVocab:enables SimulationService, OptimizationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Alignment enabler drives simulation services with updated models."
    DTDFVocab:enables MonitoringService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Fault detection enabler processes data streams to detect anomalies."
    DTDFVocab:enables FaultDetectionService
]

instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "State estimation enabler supplies real‑time state estimates for supervisory control."
    DTDFVocab:enables StateEstimationService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates and predicts the behavior of the physical twin under current operating conditions."
    DTDFVocab:provides BehaviorPredictionInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitors real‑time sensor data streams and reports system health."
    DTDFVocab:provides SystemHealthInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults in the physical twin from processed data streams."
    DTDFVocab:provides FaultDetectionInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Provides state estimation for supervisory control decisions."
    DTDFVocab:provides StateEstimationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimises system configuration and provides optimization routines."
    DTDFVocab:provides OptimizationInsight
    DTDFVocab:provides OptimizeConfigurationAction
]

// C17: Insights/Actions
instance BehaviorPredictionInsight : DTDFVocab:Insight [
    base:desc "Predicts behavior of the physical twin under current operating conditions."
]

instance SystemHealthInsight : DTDFVocab:Insight [
    base:desc "Assesses system health and performance based on real‑time monitoring."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detects faults in the physical twin from sensor data analysis."
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Provides state estimation of the physical twin for supervisory control."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Provides optimization routines for system configuration."
]

instance OptimizeConfigurationAction : DTDFVocab:Action [
    base:desc "Optimizes configuration of the physical twin."
    DTDFVocab:IsAutomatic true
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is maintained by calibration algorithms that continuously adjust model parameters based on live sensor data, thereby aligning the simulated behavior with observed physical twin behavior. Validation and verification are performed implicitly through monitors that compare simulated outputs with incoming sensor data to assess safety and optimality. When violations are detected, alarms or corrective directives can be issued to human operators or automatic control agents. The text does not specify formal uncertainty quantification, error correction procedures, or data quality assurance protocols beyond these monitoring mechanisms."
]