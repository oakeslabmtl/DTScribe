// C2: Acting Components
instance PhysicalTwinSensorArray : DTDFVocab:SensingComponent [
    base:desc "Array of distributed sensors on the physical twin that capture real‑time measurements across the system"
    DTDFVocab:producedData RealTimeSensorStream
]

// C4: Physical-to-virtual interaction
instance RealTimeSensorStream : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalTwinSensorArray
]

// C10: Models/Data
instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "Real‑time sensor data captured continuously from the physical twin"
    DTDFVocab:inputTo CalibrationEnabler, FaultDetectionEnabler, SupervisoryControlEnabler, StateEstimationEnabler, OptimizationEnabler, MonitoringEnabler, ModelingEnabler
    DTDFVocab:fromData RealTimeSensorStream
]

instance GeometricModel : DTDFVocab:Model [
    base:desc "Geometric description of the physical structure of the cyber‑physical system"
    DTDFVocab:inputTo ModelingEnabler
]

instance DynamicsModel : DTDFVocab:Model [
    base:desc "Behavioral dynamics captured via differential equations governing the cyber‑physical system"
    DTDFVocab:inputTo ModelingEnabler
]

instance AnalyticalPerformanceModel : DTDFVocab:Model [
    base:desc "Analytical abstractions of system performance for assessment and optimization"
    DTDFVocab:inputTo ModelingEnabler
]

// C11: Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for orchestration of calibration routines using sensor data to update model parameters"
    DTDFVocab:enables CalibrationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for real‑time fault detection algorithms using sensor‑derived data"
    DTDFVocab:enables FaultDetectionService
]

instance SupervisoryControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for supervisory control actions derived from model knowledge"
    DTDFVocab:enables SupervisoryControlService
]

instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for state estimation algorithms that fuse sensor data with model dynamics"
    DTDFVocab:enables StateEstimationService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for performance optimization directives based on model analysis"
    DTDFVocab:enables OptimizationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for safety and optimality monitoring using calibration and diagnostic outputs"
    DTDFVocab:enables MonitoringService
]

instance ModelingEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for integrating geometric, dynamic, and performance models into the digital twin"
    DTDFVocab:enables ModelingService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that orchestrates calibration routines to refine model parameters"
    DTDFVocab:provides CalibrationUpdateAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service that performs real‑time fault diagnostics using sensor data"
    DTDFVocab:provides FaultDetectionInsight
]

instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Service that issues supervisory control commands based on model insights"
    DTDFVocab:provides ControlAction
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Service that fuses sensor data with dynamics to estimate system state"
    DTDFVocab:provides StateEstimationInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Service that generates performance optimization directives"
    DTDFVocab:provides OptimizationDirectiveAction
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service that assesses safety and optimality, triggering corrective actions when violations occur"
    DTDFVocab:provides SafetyAssessmentInsight, CorrectiveAction
]

instance ModelingService : DTDFVocab:Service [
    base:desc "Service that integrates and manages geometric, dynamics, and performance models"
]

// C17: Insights/Actions
instance CalibrationUpdateAction : DTDFVocab:Action [
    base:desc "Update of model parameters resulting from calibration routines to refine pose"
    DTDFVocab:IsAutomatic true
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Real‑time fault diagnostics derived from sensor data"
]

instance ControlAction : DTDFVocab:Action [
    base:desc "Automated intervention control command issued by supervisory controller"
    DTDFVocab:IsAutomatic true
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Updated system state estimate combining sensor data and dynamic model"
]

instance OptimizationDirectiveAction : DTDFVocab:Action [
    base:desc "Performance optimization directive generated by optimization service"
    DTDFVocab:IsAutomatic true
]

instance SafetyAssessmentInsight : DTDFVocab:Insight [
    base:desc "Assessment of safety and optimality based on calibration and monitoring outputs"
]

instance CorrectiveAction : DTDFVocab:Action [
    base:desc "Triggered corrective action when safety violations are detected"
    DTDFVocab:IsAutomatic true
]