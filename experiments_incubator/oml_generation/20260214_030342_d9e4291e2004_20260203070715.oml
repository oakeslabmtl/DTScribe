// Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed that supplies thermal energy to raise the incubator internal temperature; controllable via set‑point commands from the Digital Twin"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan that circulates air inside the incubator, modulated by the Digital Twin to improve temperature uniformity"
]

// Sensing Components
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "First internal temperature sensor mounted inside the incubator chamber, providing time‑stamped temperature measurements"
    DTDFVocab:producedData InternalTempDataTxA
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "Second internal temperature sensor mounted inside the incubator chamber, providing time‑stamped temperature measurements"
    DTDFVocab:producedData InternalTempDataTxB
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor mounted on the incubator outer wall, providing time‑stamped temperature measurements"
    DTDFVocab:producedData ExternalTempDataTx
]

// Data Transmitted
instance InternalTempDataTxA : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempDataTxB : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// Data
instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Temperature measurement stream from InternalTempSensorA"
    DTDFVocab:fromData InternalTempDataTxA
    DTDFVocab:inputTo IncubatorControlEnabler
]

instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Temperature measurement stream from InternalTempSensorB"
    DTDFVocab:fromData InternalTempDataTxB
    DTDFVocab:inputTo IncubatorControlEnabler
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Temperature measurement stream from ExternalTempSensor"
    DTDFVocab:fromData ExternalTempDataTx
    DTDFVocab:inputTo IncubatorControlEnabler
]

// Models
instance SimpleThermalModel : DTDFVocab:Model [
    base:desc "Analytical model of internal temperature dynamics with two free parameters, calibrated from sensor data"
    DTDFVocab:inputTo IncubatorControlEnabler
]

instance DetailedThermalModel : DTDFVocab:Model [
    base:desc "Analytical model of internal temperature dynamics with four free parameters to capture heat‑bed thermal inertia, calibrated from sensor data"
    DTDFVocab:inputTo IncubatorControlEnabler
]

// Enabler
instance IncubatorControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that integrates calibrated models and real‑time temperature data to perform prediction, optimisation, and supervisory control"
    DTDFVocab:enables TemperatureMonitoringService,
                         TemperaturePredictionService,
                         OptimisationControlService,
                         SafetyMonitoringService,
                         VisualizationService
]

// Services
instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of internal and external temperature streams"
    DTDFVocab:provides SuboptimalPerformanceInsight
]

instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Predictive simulation of temperature trajectories using calibrated models"
    DTDFVocab:provides SystemStateInsight
]

instance OptimisationControlService : DTDFVocab:Service [
    base:desc "Optimisation and control actions that adjust the heat‑bed and fan to achieve the target temperature"
    DTDFVocab:provides AdjustHeatBedAction
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Safety monitoring that detects violations of safe operating limits and can halt or adjust heating"
    DTDFVocab:provides SafetyViolationInsight,
                         HaltHeatingAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualisation of system state for engineers and operators"
    DTDFVocab:provides SystemStateInsight
]

// Insights
instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating a breach of safe temperature operating limits"
]

instance SuboptimalPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight indicating sub‑optimal temperature control performance"
]

instance SystemStateInsight : DTDFVocab:Insight [
    base:desc "Insight representing the current overall state of the incubator for visualization"
]

// Actions
instance HaltHeatingAction : DTDFVocab:Action [
    base:desc "Action to halt heating commands to the heat‑bed when a safety breach is detected"
    DTDFVocab:IsAutomatic true
]

instance AdjustHeatBedAction : DTDFVocab:Action [
    base:desc "Action to adjust heat‑bed power set‑point as part of optimisation/control"
    DTDFVocab:IsAutomatic true
]

// Physical Components
instance IncubatorContainer : DTDFVocab:Component [
    base:desc "Styrofoam insulated container forming the physical enclosure of the incubator"
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi that hosts the plant‑controller software and mediates communication with sensors and actuators"
]

instance HeatBed : DTDFVocab:Component [
    base:desc "Heat‑bed hardware that provides thermal energy to raise internal temperature"
]

instance Fan : DTDFVocab:Component [
    base:desc "Fan hardware that circulates air inside the incubator"
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains IncubatorContainer,
                 RaspberryPiController,
                 HeatBed,
                 Fan,
                 InternalTempSensorA,
                 InternalTempSensorB,
                 ExternalTempSensor
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the two temperature prediction models: the four‑parameter model exhibits higher fidelity, accurately capturing the thermal inertia of the heat‑bed as demonstrated by experimental validation. Validation is performed by running the models against measured temperature data from the physical incubator and assessing prediction error. Calibration algorithms are employed to update model parameters, reducing uncertainty arising from parameter estimation. Model quality assurance relies on this iterative calibration‑validation loop, but specific quantitative error metrics or uncertainty quantification methods are not described in the documents."
]