// C3: Physical Sensing Components
instance ForceSensorNetwork : DTDFVocab:SensingComponent [
    base:desc "Distributed network of force sensors capturing real-time operational forces on physical components like chassis and wheels, with high-frequency sampling to enable dynamic system analysis."
    DTDFVocab:producedData ForceSensorDataTransmitted
]

instance EnvironmentalSensorNetwork : DTDFVocab:SensingComponent [
    base:desc "Network of environmental sensors monitoring external conditions (temperature, pressure, humidity) affecting the physical system's operational dynamics."
    DTDFVocab:producedData EnvironmentalSensorDataTransmitted
]

instance PositionalTrackingSensor : DTDFVocab:SensingComponent [
    base:desc "Geospatial/positional sensors tracking the physical system's location and movement trajectories for dynamic behavior analysis."
    DTDFVocab:producedData PositionalTrackingDataTransmitted
]

instance VibrationMonitoringSensor : DTDFVocab:SensingComponent [
    base:desc "Vibration sensors capturing dynamic structural responses to operational loads, enabling fault detection and predictive maintenance."
    DTDFVocab:producedData VibrationMonitoringDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance ForceSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ForceSensorNetwork
]

instance EnvironmentalSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensorNetwork
]

instance PositionalTrackingDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PositionalTrackingSensor
]

instance VibrationMonitoringDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationMonitoringSensor
]

// C10: Models/Data
instance CADGeometricModel : DTDFVocab:Model [
    base:desc "Geometric representation of physical components (e.g., car chassis, wheels) created using CAD systems for structural and spatial analysis."
    DTDFVocab:inputTo CADModellingEnabler
]

instance DynamicSimulationModel : DTDFVocab:Model [
    base:desc "Differential equation-based model capturing temporal behaviors such as force dynamics and movement trajectories for system simulation."
    DTDFVocab:inputTo DynamicSimulationEnabler
]

instance MultiphysicsSimulationModel : DTDFVocab:Model [
    base:desc "Multiphysics simulation model (e.g., fluid-structure interactions) using ANSYS/Fluent for comprehensive system behavior analysis."
    DTDFVocab:inputTo MultiphysicsSimulationEnabler
]

instance KnowledgeGraphModel : DTDFVocab:Model [
    base:desc "Structured knowledge graph representing relationships between physical components, sensors, actuators, and environmental factors for semantic querying."
    DTDFVocab:inputTo KnowledgeGraphEnabler
]

instance RealTimeSensorData : DTDFVocab:Data [
    base:desc "High-frequency time-series data collected from physical sensors representing current operational parameters of the system."
    DTDFVocab:fromData ForceSensorDataTransmitted, EnvironmentalSensorDataTransmitted, PositionalTrackingDataTransmitted, VibrationMonitoringDataTransmitted
    DTDFVocab:inputTo DataProcessingEnabler, CalibrationAlgorithmEnabler
]

instance CalibratedModelParameters : DTDFVocab:Data [
    base:desc "Dynamic model parameters refined through calibration algorithms using real-time sensor data to minimize prediction errors."
    DTDFVocab:fromData RealTimeSensorData
    DTDFVocab:inputTo OptimizationEnabler, StateEstimationEnabler
]

instance ModelCalibrationHistory : DTDFVocab:Data [
    base:desc "Structured metadata recording model calibration events, parameter updates, and validation results for audit and version control."
    DTDFVocab:fromData RealTimeSensorData
    DTDFVocab:inputTo ModelValidationService
]

// C11: Enablers
instance CADModellingEnabler : DTDFVocab:Enabler [
    base:desc "CAD systems enabling geometric and structural modeling of physical components for static representation."
    DTDFVocab:hasInput CADGeometricModel
    DTDFVocab:enables CADVisualizationService, ModelIntegrationService
]

instance DynamicSimulationEnabler : DTDFVocab:Enabler [
    base:desc "MATLAB/Simulink-based simulation engine for control system design and dynamic behavior analysis."
    DTDFVocab:hasInput DynamicSimulationModel
    DTDFVocab:enables DynamicBehaviorSimulationService
]

instance MultiphysicsSimulationEnabler : DTDFVocab:Enabler [
    base:desc "ANSYS/Fluent multiphysics simulation platform for analyzing complex interactions like fluid-structure dynamics."
    DTDFVocab:hasInput MultiphysicsSimulationModel
    DTDFVocab:enables MultiphysicsAnalysisService
]

instance KnowledgeGraphEnabler : DTDFVocab:Enabler [
    base:desc "Knowledge graph framework enabling semantic querying and integration of physical and cyber components."
    DTDFVocab:hasInput KnowledgeGraphModel
    DTDFVocab:enables SemanticQueryService
]

instance DataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Edge computing infrastructure processing low-latency sensor data to reduce bandwidth usage and enable real-time calibration."
    DTDFVocab:hasInput RealTimeSensorData
    DTDFVocab:enables DataValidationService, FeatureExtractionService
]

instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Parameter estimation algorithms (e.g., Kalman filters, Bayesian updates) refining digital twin models using real-time physical data."
    DTDFVocab:hasInput RealTimeSensorData, CalibratedModelParameters
    DTDFVocab:enables ModelCalibrationService, StateReconciliationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Machine learning-based anomaly detection systems identifying deviations from expected physical behavior."
    DTDFVocab:hasInput RealTimeSensorData
    DTDFVocab:enables AnomalyDetectionService, FaultDiagnosisService
]

instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "Extended Kalman Filter-based state estimators fusing sensor data with model predictions for accurate system state reconstruction."
    DTDFVocab:hasInput RealTimeSensorData, CalibratedModelParameters
    DTDFVocab:enables StateEstimationService, PredictiveAnalysisService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Constrained optimization solvers (e.g., gradient descent, genetic algorithms) deriving control parameters and design improvements."
    DTDFVocab:hasInput CalibratedModelParameters
    DTDFVocab:enables PerformanceOptimizationService
]

instance CloudHPCEnabler : DTDFVocab:Enabler [
    base:desc "Cloud/High-Performance Computing infrastructure hosting resource-intensive simulations for predictive analysis."
    DTDFVocab:enables LargeScaleSimulationService, PredictiveModelingService
]

instance ContainerizationEnabler : DTDFVocab:Enabler [
    base:desc "Docker/Kubernetes-based containerization enabling scalable deployment of digital twin components across heterogeneous environments."
    DTDFVocab:enables ComponentScalingService, ServiceDeploymentService
]

instance IntegrationAPIEnabler : DTDFVocab:Enabler [
    base:desc "API and middleware framework facilitating interoperability between physical sensors, digital twin models, and user interfaces."
    DTDFVocab:enables DataIntegrationService, ServiceOrchestrationService
]

instance RealTimeCommunicationEnabler : DTDFVocab:Enabler [
    base:desc "OPC UA and DDS-based real-time communication protocols enabling synchronized physical-to-virtual interactions."
    DTDFVocab:enables SynchronizationService, LowLatencyService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Unity/Unreal Engine-based 3D visualization tools creating immersive representations of digital twin states."
    DTDFVocab:enables InteractiveVisualizationService, SimulationPlaybackService
]

instance DataAnalyticsEnabler : DTDFVocab:Enabler [
    base:desc "Tableau/Grafana-based data analytics dashboards presenting customizable KPIs for user analysis."
    DTDFVocab:enables DashboardService, PerformanceTrackingService
]

