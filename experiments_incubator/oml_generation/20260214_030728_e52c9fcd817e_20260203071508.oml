// C3: Physical sensing components
instance IncubatorTempSensorInternal1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted inside the incubator chamber near the heat‑bed. Accuracy ±0.5 °C, range –10 °C to +85 °C. Connected to the Raspberry Pi via the 1‑Wire bus."
    DTDFVocab:producedData IncubatorTempDataTransmitted
]

instance IncubatorTempSensorInternal2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted inside the incubator chamber for local temperature readings. Accuracy ±0.5 °C, range –10 °C to +85 °C. Connected to the Raspberry Pi via the 1‑Wire bus."
    DTDFVocab:producedData IncubatorTempDataTransmitted
]

instance IncubatorTempSensorExternal : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer placed outside the incubator for ambient temperature measurement. Accuracy ±0.5 °C, range –10 °C to +85 °C. Connected to the Raspberry Pi via the 1‑Wire bus."
    DTDFVocab:producedData IncubatorTempDataTransmitted
]

// C4: Physical-to-virtual interaction (data transmission)
instance IncubatorTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorTempSensorInternal1, IncubatorTempSensorInternal2, IncubatorTempSensorExternal
]

// C10: Data
instance IncubatorTemperatureData : DTDFVocab:Data [
    base:desc "Timestamped temperature measurements (°C) from the three DS18S20 sensors, published to the RabbitMQ broker as soon as each reading is available."
    DTDFVocab:fromData IncubatorTempDataTransmitted
    DTDFVocab:inputTo IncubatorDataProcessingEnabler
]

// C10: Models
instance SimpleThermalModel : DTDFVocab:Model [
    base:desc "Analytical temperature model of the incubator with two free parameters, representing a simplified heat balance."
    DTDFVocab:inputTo IncubatorDataProcessingEnabler
]

instance DetailedThermalModel : DTDFVocab:Model [
    base:desc "Behavioral simulation model of the internal temperature with four free parameters, capturing thermal inertia of the heat‑bed."
    DTDFVocab:inputTo IncubatorDataProcessingEnabler
]

// C11: Enablers
instance IncubatorDataProcessingEnabler : DTDFVocab:Enabler [
    base:desc "Software stack (calibration, monitoring, optimisation, diagnostic algorithms) running on the Raspberry Pi; consumes temperature data and model outputs to provide DT services."
    DTDFVocab:enables SimulationService, MonitoringService, OptimisationService, DiagnosticService
]

// C6: Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation service reproducing and predicting the incubator temperature dynamics under current operating conditions."
    DTDFVocab:provides PredictedTemperatureInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitoring service evaluating safety and performance against model‑based expectations, detecting deviations."
    DTDFVocab:provides SafetyViolationInsight
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Optimisation service adjusting control parameters to achieve optimal temperature regulation."
    DTDFVocab:provides ControlSetpointRecommendationAction
]

instance DiagnosticService : DTDFVocab:Service [
    base:desc "Diagnostic service performing fault detection and state estimation based on sensor data and model residuals."
    DTDFVocab:provides FaultAlertAction
]

// C17: Insights
instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory generated by the calibrated model, used to inform operators of future system states."
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of safety or performance violations (e.g., temperature out‑of‑bounds) derived from monitoring algorithms."
]

// C17: Actions
instance ControlSetpointRecommendationAction : DTDFVocab:Action [
    base:desc "Recommended adjustment of heating set‑points to maintain target temperature."
    DTDFVocab:IsAutomatic false
]

instance FaultAlertAction : DTDFVocab:Action [
    base:desc "Generated alert indicating a detected fault or abnormal state in the incubator."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components (optional, not part of mandatory flow)
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed actuator driven by commands from the DT software to vary heating power for temperature control."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin follows a centralized orchestration pattern where sensor data collected from the Physical Twin is ingested by a cyber component that stores models of both the cyber‑physical system and its environment. Calibration algorithms continuously estimate the best‑fit parameters and update these models. The updated model outputs are supplied to monitor components that evaluate safety and optimality criteria. Upon detection of a violation, a decision component—either a human operator or an automated algorithm—issues corrective actions back to the Physical Twin. This architecture integrates data acquisition, model management, calibration, monitoring, and a closed feedback loop to the PT."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed by experimental comparison: the four‑parameter model better predicts the thermal inertia of the heat‑bed than the two‑parameter model, indicating higher fidelity for that aspect. Calibration algorithms are employed to update model parameters using measured temperature data, serving as a validation step. The documents do not describe explicit uncertainty quantification, error detection mechanisms, or broader quality assurance processes beyond this calibration and comparative testing."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT architecture incorporates safety monitoring components that continuously evaluate the physical twin's operating state; when a safety violation is detected, the monitor triggers a response—either human intervention or an automated corrective action. A dedicated safe‑state protocol is embedded in the low‑level driver of the incubator controller to ensure the device remains in a safe condition under fault conditions. These mechanisms together provide run‑time safety checks, fail‑safe behavior, and risk mitigation for the CPS."
]