// C3: Physical sensing components
instance InsideTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor inside the styrofoam box, measuring intra-box temperature."
    DTDFVocab:producedData TemperatureReadingsMQ
]

instance InsideTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor inside the styrofoam box, measuring intra-box temperature."
    DTDFVocab:producedData TemperatureReadingsMQ
]

instance AmbientTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor outside the incubator, measuring ambient temperature."
    DTDFVocab:producedData TemperatureReadingsMQ
]

// C4: Physical-to-virtual interaction
instance TemperatureReadingsMQ : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor1, InsideTemperatureSensor2, AmbientTemperatureSensor
]

// C10: Models/Data
instance InsideTemperatureTimeSeries : DTDFVocab:Data [
    base:desc "Time‑stamped temperature series from inside sensors."
    DTDFVocab:fromData TemperatureReadingsMQ
    DTDFVocab:inputTo PythonSciPy
]

instance AmbientTemperatureTimeSeries : DTDFVocab:Data [
    base:desc "Time‑stamped temperature series from ambient sensor."
    DTDFVocab:fromData TemperatureReadingsMQ
    DTDFVocab:inputTo PythonSciPy
]

instance ControlLogData : DTDFVocab:Data [
    base:desc "Control logs of heatbed and fan states."
    DTDFVocab:fromData TemperatureReadingsMQ
    DTDFVocab:inputTo PythonSciPy
]

instance ModelOutputData : DTDFVocab:Data [
    base:desc "Simulation outputs from thermal models."
    DTDFVocab:inputTo PythonSciPy
    DTDFVocab:fromData TemperatureReadingsMQ
]

instance CalibrationResidualsData : DTDFVocab:Data [
    base:desc "Residuals from least‑squares calibration of thermal model parameters."
    DTDFVocab:inputTo PythonSciPy
    DTDFVocab:fromData TemperatureReadingsMQ
]

instance ThermalModelAir : DTDFVocab:Model [
    base:desc "Differential equation model of air temperature (Model A)."
    DTDFVocab:inputTo PythonSciPy
]

instance ThermalModelHeatbedAir : DTDFVocab:Model [
    base:desc "Combined heatbed‑air model with parameters C_air, G_box, G_heater, C_heater (Model B)."
    DTDFVocab:inputTo PythonSciPy
]

// C11: Enablers
instance RaspberryPiLowLevelDriver : DTDFVocab:Enabler [
    base:desc "Low‑level driver for GPIO, 1‑Wire, Bluetooth on Raspberry Pi 4."
    DTDFVocab:enables TemperatureSimulationService, ParameterCalibrationService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker on Raspberry Pi for message passing."
    DTDFVocab:enables RealTimeMonitoringService, AlarmTriggerService
]

instance PythonSciPy : DTDFVocab:Enabler [
    base:desc "Python SciPy library for nonlinear least‑squares optimization and simulation."
    DTDFVocab:enables TemperatureSimulationService, ParameterCalibrationService
]

instance MOSFETActuatorCircuit : DTDFVocab:Enabler [
    base:desc "MOSFET‑controlled heatbed actuator circuit via optocouplers."
]

instance OptocouplerCircuit : DTDFVocab:Enabler [
    base:desc "Optocoupler interface between Raspberry Pi GPIO and MOSFETs."
]

// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Electrical heating element delivering up to 100 W, MOSFET‑controlled."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12/24 V DC fan providing airflow ~0.02 m³/s, MOSFET‑controlled."
]

// C6: Services
instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "On‑device simulation of temperature dynamics using two thermal models."
    DTDFVocab:provides ForecastTemperatureInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibration of thermal model parameters via nonlinear least‑squares."
    DTDFVocab:provides ParameterEstimationInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature and safety limits."
    DTDFVocab:provides SafetyViolationInsight, AdjustHeatingScheduleAction
]

instance AlarmTriggerService : DTDFVocab:Service [
    base:desc "Triggers alarms when temperature thresholds are breached."
    DTDFVocab:provides TriggerAlarmAction
]

// C17: Insights/Actions
instance ForecastTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted future temperature profiles based on simulation."
]

instance ParameterEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated thermal model parameters (C_air, G_box, G_heater, C_heater)."
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Flag indicating safety violations when temperatures exceed limits."
]

instance AdjustHeatingScheduleAction : DTDFVocab:Action [
    base:desc "Operator action to adjust heating duration H and waiting duration C."
    DTDFVocab:IsAutomatic false
]

instance TriggerAlarmAction : DTDFVocab:Action [
    base:desc "Automatic alarm activation when safety thresholds are breached."
    DTDFVocab:IsAutomatic true
]

// C17: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains IncubatorHardware, HeatBedActuator, FanActuator, InsideTemperatureSensor1, InsideTemperatureSensor2, AmbientTemperatureSensor
]

// Component
instance IncubatorHardware : DTDFVocab:Component [
    base:desc "Thermal incubator twin hardware: styrofoam box, heatbed, fan, temperature sensors."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The virtual twin publishes control messages (fan on/off, heatbed on/off, heating duration H, waiting duration C) to RabbitMQ; the controller listens for these commands, updates the actuator states via the GPIO outputs, and reports the resulting control states back to RabbitMQ."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Sensor data polling occurs in the low‑level driver loop (period not explicitly defined but occurs at each iteration). The controller operates on a state machine with heating duration H and waiting duration C (both expressed in seconds), typically on a timescale of a few seconds per cycle. Simulation and calibration computations are performed on the edge device, synchronized with the controller’s timing."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized framework on the Raspberry Pi: RabbitMQ brokers messages between the low‑level driver, the controller, and the simulation modules. The controller orchestrates actuation, the low‑level driver handles hardware I/O, and the simulation models provide predictive outputs, all composed within a single node."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design (selection of heatbed, fan, sensors), Manufacturing (PCB fabrication, assembly of the incubator), Operation (continuous temperature regulation during experiments); the DT is developed in parallel with operation, providing runtime monitoring, calibration, and simulation during the operational stage."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model validation through experimental temperature profiles (fig 10‑12). Calibration optimises parameters to minimise residual error via least‑squares. Assumptions (e.g., uniform temperature, negligible wall heat) are tested experimentally. Uncertainty handled by parameter bounds and residual analysis."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Electrical isolation using optocouplers and MOSFETs for actuation; 1‑Wire bus for DS18S20 sensors; Wi‑Fi (built‑in on Raspberry Pi) transmitting RabbitMQ AMQP messages over TCP/IP; no other protocols are specified."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Digital twin runs on the Raspberry Pi itself (edge deployment) with Python services; open‑source code is in the GitHub repository. The communication server (RabbitMQ) is also hosted on the Pi, making the system self‑contained."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Low‑level driver incorporates a safe protocol to default to a safe state if communication fails. The controller can switch devices off; system design ensures no over‑current via MOSFETs and optocouplers. No explicit cybersecurity measures are described, but message bus is local and used in a closed network."
]