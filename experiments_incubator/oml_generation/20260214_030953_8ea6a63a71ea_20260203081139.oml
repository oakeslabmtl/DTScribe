// ------------------------------------------------------------
// Physical Components (Sensors)
// ------------------------------------------------------------
instance InsideTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "Inside temperature sensor 1 placed within the insulated incubator box."
    DTDFVocab:producedData InsideTempDataTransmitted1
]

instance InsideTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Inside temperature sensor 2 placed within the insulated incubator box."
    DTDFVocab:producedData InsideTempDataTransmitted2
]

instance OutsideTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "Outside temperature sensor mounted on the exterior of the incubator box."
    DTDFVocab:producedData OutsideTempDataTransmitted
]

// ------------------------------------------------------------
// Data Transmitted (Physical → Virtual)
// ------------------------------------------------------------
instance InsideTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor1
]

instance InsideTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor2
]

instance OutsideTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideTemperatureSensor
]

// ------------------------------------------------------------
// Virtual Data Objects
// ------------------------------------------------------------
instance InsideTemperatureData1 : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from inside sensor 1."
    DTDFVocab:fromData InsideTempDataTransmitted1
    DTDFVocab:inputTo DataProcessingEngine
]

instance InsideTemperatureData2 : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from inside sensor 2."
    DTDFVocab:fromData InsideTempDataTransmitted2
    DTDFVocab:inputTo DataProcessingEngine
]

instance OutsideTemperatureData : DTDFVocab:Data [
    base:desc "Temperature reading (°C) from outside sensor."
    DTDFVocab:fromData OutsideTempDataTransmitted
    DTDFVocab:inputTo DataProcessingEngine
]

// ------------------------------------------------------------
// Models
// ------------------------------------------------------------
instance CalibrationModel : DTDFVocab:Model [
    base:desc "Parameter calibration model that updates the thermal model using recent sensor data."
    DTDFVocab:inputTo DataProcessingEngine
]

instance ThermalModel : DTDFVocab:Model [
    base:desc "Thermal dynamics model of the incubator and its surrounding environment."
    DTDFVocab:inputTo DataProcessingEngine
]

// ------------------------------------------------------------
// Enabler (Processing Engine)
// ------------------------------------------------------------
instance DataProcessingEngine : DTDFVocab:Enabler [
    base:desc "Software engine on the Raspberry Pi that processes temperature data for acquisition, calibration, simulation, monitoring, optimisation, visualisation and re‑configuration."
    DTDFVocab:enables ContinuousDataAcquisitionService,
               CalibrationService,
               SimulationService,
               MonitoringService,
               OptimisationService,
               VisualizationService,
               ReconfigurationService
]

// ------------------------------------------------------------
// Services
// ------------------------------------------------------------
instance ContinuousDataAcquisitionService : DTDFVocab:Service [
    base:desc "Continuously acquires temperature data from the three sensors."
    DTDFVocab:provides RealTimeTemperatureInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Runs calibration algorithms that update cyber‑physical and environmental model parameters from incoming sensor data."
    DTDFVocab:provides ModelParameterUpdateInsight,
               UpdateModelParametersAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates and predicts temperature dynamics of the incubator under current operating conditions."
    DTDFVocab:provides PredictedTemperatureInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitors temperature safety and optimality in real time."
    DTDFVocab:provides SafetyViolationInsight,
               OptimalityViolationInsight,
               TriggerHumanOperatorAction,
               TriggerAutomatedCorrectionAction
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Generates optimal temperature set‑points or actuator commands to keep temperature within the desired range."
    DTDFVocab:provides OptimalSetpointInsight,
               ApplyControlSetpointAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides advanced visualisation of temperature evolution, sensor readings and control actions."
    DTDFVocab:provides TemperatureEvolutionVisualizationInsight,
               GenerateVisualizationAction
]

instance ReconfigurationService : DTDFVocab:Service [
    base:desc "Allows the twin to be re‑configured in response to changes in the environment or payload."
    DTDFVocab:provides ConfigurationChangeInsight,
               ApplyConfigurationChangeAction
]

// ------------------------------------------------------------
// Insights
// ------------------------------------------------------------
instance RealTimeTemperatureInsight : DTDFVocab:Insight [
    base:desc "Continuous real‑time temperature readings from all three sensors."
]

instance ModelParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Best‑estimate parameters for the thermal model derived from the latest sensor data."
]

instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory of the incubator based on current conditions."
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature values that breach defined safety limits."
]

instance OptimalityViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of sub‑optimal temperature regulation relative to the target set‑point."
]

instance OptimalSetpointInsight : DTDFVocab:Insight [
    base:desc "Computation of the optimal temperature set‑point or actuator command."
]

instance TemperatureEvolutionVisualizationInsight : DTDFVocab:Insight [
    base:desc "Graphical visualisation of recorded and predicted temperature over time."
]

instance ConfigurationChangeInsight : DTDFVocab:Insight [
    base:desc "Identification of required twin re‑configuration due to environmental or payload changes."
]

// ------------------------------------------------------------
// Actions
// ------------------------------------------------------------
instance UpdateModelParametersAction : DTDFVocab:Action [
    base:desc "Automatically updates cyber‑physical model parameters with calibrated values."
    DTDFVocab:IsAutomatic true
]

instance TriggerHumanOperatorAction : DTDFVocab:Action [
    base:desc "Notifies a human operator of a safety violation for manual intervention."
    DTDFVocab:IsAutomatic false
]

instance TriggerAutomatedCorrectionAction : DTDFVocab:Action [
    base:desc "Automatically adjusts actuator commands to correct temperature deviations."
    DTDFVocab:IsAutomatic true
]

instance ApplyControlSetpointAction : DTDFVocab:Action [
    base:desc "Sends the computed optimal set‑point to the heating elements."
    DTDFVocab:IsAutomatic true
]

instance GenerateVisualizationAction : DTDFVocab:Action [
    base:desc "Renders temperature evolution graphs on the operator dashboard."
    DTDFVocab:IsAutomatic true
]

instance ApplyConfigurationChangeAction : DTDFVocab:Action [
    base:desc "Re‑configures twin models and pipelines to adapt to new conditions."
    DTDFVocab:IsAutomatic true
]

// ------------------------------------------------------------
// Physical Components (other)
// ------------------------------------------------------------
instance Incubator : DTDFVocab:Component [
    base:desc "Insulated incubator (styrofoam box) with heat‑bed and fan for temperature regulation."
]

instance StyrofoamBox : DTDFVocab:Component [
    base:desc "Thermal insulation enclosure of the incubator."
]

instance HeatBed : DTDFVocab:Component [
    base:desc "Heating element that raises the temperature inside the incubator."
]

instance Fan : DTDFVocab:Component [
    base:desc "Air circulation fan that distributes heat uniformly inside the incubator."
]

instance RaspberryPi : DTDFVocab:Component [
    base:desc "Raspberry Pi controller that gathers sensor data and runs the digital‑twin software stack."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin can produce control actions for the incubator’s actuators (heatbed and fan) that are executed by the Raspberry Pi; the document does not detail command types, message formats, validation or authentication procedures, feedback loops, conflict resolution, or execution confirmations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The incubator’s network consists of a Raspberry Pi edge device that hosts both the low‑level sensor/actuator drivers and a RabbitMQ communication server. Connectivity to the physical components uses a 1‑Wire bus for temperature sensors and GPIO lines for the heat‑bed and fan. The Raspberry Pi provides built‑in Wi‑Fi and Bluetooth, enabling wireless Ethernet connectivity to external networks or cloud services. Communication between the Digital Twin and the Physical Twin is performed via MQTT over TCP/IP through the RabbitMQ broker. The topology is a star‑like edge architecture where the Pi acts as the central hub. Bandwidth requirements are low (a few kilobytes per second for sensor updates and control messages); latency is constrained by MQTT’s lightweight protocol, typically sub‑second. Reliability is supported by RabbitMQ’s message acknowledgements and durable queues. Security is not detailed in the documents, so no specific encryption or authentication mechanisms are reported."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin is deployed on‑premise on the Raspberry Pi edge device. The Pi runs the RabbitMQ server that underpins the Twin’s messaging layer and hosts the control algorithms that process sensor data and issue commands. The document mentions only this edge deployment; it does not provide details about cloud hosting, resource sizing, scalability strategies, or formal availability/reliability provisions."
]