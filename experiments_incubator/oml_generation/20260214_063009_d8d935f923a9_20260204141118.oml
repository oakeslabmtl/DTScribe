// C2: Acting Components
instance Heatbed : DTDFVocab:ActingComponent [
    base:desc "Controlled thermal platform for maintaining stable incubation conditions using resistive heating elements to generate and distribute heat within the enclosed environment."
]

instance Fan : DTDFVocab:ActingComponent [
    base:desc "Mechanically driven airflow system ensuring uniform temperature distribution within the insulated Styrofoam enclosure through continuous circulation of air."
]

instance HighSideMosfetController : DTDFVocab:ActingComponent [
    base:desc "High-side MOSFET switches that isolate low-voltage control signals from high-power heating circuits, ensuring electrical safety and protection against short circuits in the actuation system."
]

instance RabbitMQMessageBroker : DTDFVocab:ActingComponent [
    base:desc "Lightweight message broker hosted on Raspberry Pi that coordinates actuation commands between control unit and physical components via asynchronous communication protocols."
]

instance RaspberryPiControlUnit : DTDFVocab:ActingComponent [
    base:desc "Embedded computing platform executing commands via RabbitMQ message broker to enforce safety constraints and coordinate actuation mechanisms for the incubation environment."
]

// C3: Physical Sensing Components
instance InternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer measuring internal box temperature with ±0.5°C accuracy across -10°C to +85°C range."
    DTDFVocab:producedData InternalTemperatureDataTransmitted
]

instance ExternalTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire digital thermometer measuring external environmental temperature with ±0.5°C accuracy across -10°C to +85°C range."
    DTDFVocab:producedData ExternalTemperatureDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance InternalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensor
]

instance ExternalTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTemperatureSensor
]

// C10: Models/Data
instance ThermalEnvironmentModel : DTDFVocab:Model [
    base:desc "Behavioral model described by differential equations simulating dynamic thermal regulation and heat distribution within the incubation environment."
    DTDFVocab:inputTo RabbitMQMessageBroker
]

instance CalibrationAlgorithm : DTDFVocab:Model [
    base:desc "Best-estimate algorithm updating model parameters (thermal conductivity, fan efficiency) using real-time sensor data to align virtual representation with physical behavior."
    DTDFVocab:inputTo PythonScipyStack
]

instance StateEstimationModel : DTDFVocab:Model [
    base:desc "State estimator (e.g., Kalman filter) reconstructing hidden system states from noisy sensor data to provide best-estimate parameters for monitoring and control."
    DTDFVocab:inputTo PythonScipyStack
]

instance InternalTemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature readings from internal DS18S20 sensor transmitted via 1-Wire bus to Raspberry Pi control unit."
    DTDFVocab:fromData InternalTemperatureDataTransmitted
    DTDFVocab:inputTo ThermalEnvironmentModel
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Real-time temperature readings from external DS18S20 sensor transmitted via 1-Wire bus to Raspberry Pi control unit."
    DTDFVocab:fromData ExternalTemperatureDataTransmitted
    DTDFVocab:inputTo ThermalEnvironmentModel
]

instance MonitoringData : DTDFVocab:Data [
    base:desc "Aggregated time-series data from sensors used for fault detection, state estimation, and performance validation of the incubation environment."
    DTDFVocab:fromData InternalTemperatureDataTransmitted, ExternalTemperatureDataTransmitted
]

// C11: Enablers
instance RabbitMQProtocol : DTDFVocab:Enabler [
    base:desc "Asynchronous message broker protocol enabling communication between sensors, control unit, and digital twin components via lightweight RabbitMQ server."
    DTDFVocab:enables DataTransmissionService, ControlCommandService
]

instance PythonScipyStack : DTDFVocab:Enabler [
    base:desc "Python-based computational environment with Scipy libraries implementing calibration algorithms, state estimation, and model parameter optimization."
    DTDFVocab:enables CalibrationService, StateEstimationService
]

instance OneWireBusInterface : DTDFVocab:Enabler [
    base:desc "1-Wire communication protocol interface enabling low-power, multi-drop connectivity between DS18S20 sensors and Raspberry Pi control unit."
    DTDFVocab:enables SensorDataAcquisitionService
]

// C6: Services
instance DataTransmissionService : DTDFVocab:Service [
    base:desc "Service facilitating real-time transmission of sensor data from physical components to digital twin via RabbitMQ message broker."
    DTDFVocab:provides TemperatureDataTransmissionInsight
]

instance ControlCommandService : DTDFVocab:Service [
    base:desc "Service executing actuation commands from digital twin to physical components through Raspberry Pi control unit and MOSFET controllers."
    DTDFVocab:provides ActuationCommandAction
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Service continuously updating model parameters using real-time sensor data to minimize discrepancies between virtual and physical system representations."
    DTDFVocab:provides ModelAccuracyInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Service reconstructing hidden system states from noisy sensor data using state estimation algorithms to provide best-estimate parameters."
    DTDFVocab:provides StateReconstructionInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service implementing anomaly detection algorithms to identify deviations from safe/optimal operating conditions in the incubation environment."
    DTDFVocab:provides FaultDetectionInsight
]

instance SensorDataAcquisitionService : DTDFVocab:Service [
    base:desc "Service managing real-time collection and preprocessing of sensor data from DS18S20 thermometers via 1-Wire bus interface."
    DTDFVocab:provides SensorDataQualityInsight
]

// C17: Insights/Actions
instance TemperatureDataTransmissionInsight : DTDFVocab:Insight [
    base:desc "Verification of successful transmission of temperature readings from DS18S20 sensors to digital twin components via RabbitMQ protocol."
]

instance ActuationCommandAction : DTDFVocab:Action [
    base:desc "Execution of control commands to adjust heatbed power and fan speed based on digital twin recommendations."
    DTDFVocab:IsAutomatic true
]

instance ModelAccuracyInsight : DTDFVocab:Insight [
    base:desc "Quantitative measure of model parameter alignment with physical system behavior, derived from calibration algorithm performance metrics."
]

instance StateReconstructionInsight : DTDFVocab:Insight [
    base:desc "Best-estimate reconstruction of hidden system states (e.g., thermal gradients, airflow patterns) from noisy sensor measurements."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Identification of anomalies in sensor data or system behavior indicating potential faults in the incubation environment."
]

instance SensorDataQualityInsight : DTDFVocab:Insight [
    base:desc "Assessment of sensor data reliability and accuracy based on calibration, noise levels, and transmission integrity metrics."
]

instance SafetyThresholdViolationAction : DTDFVocab:Action [
    base:desc "Automated intervention triggering when detected deviations exceed predefined safety thresholds for temperature or operational parameters."
    DTDFVocab:IsAutomatic true
]

// C1: Environment
instance IncubationEnvironment : DTDFVocab:Environment [
    base:contains Heatbed, Fan, StyrofoamEnclosure, InternalTemperatureSensor, ExternalTemperatureSensor
]

instance StyrofoamEnclosure : DTDFVocab:Component [
    base:desc "Insulated Styrofoam box housing the incubation chamber, regulating temperature and humidity while maintaining uniform environmental conditions."
]

// C5: Component Hierarchy
instance IncubationSystem : DTDFVocab:System [
    base:desc "Cyber-Physical System incorporating physical components, sensing infrastructure, and digital twin for precision environmental control."
    base:contains IncubationEnvironment, RaspberryPiControlUnit, HighSideMosfetController, RabbitMQMessageBroker
    DTDFVocab:hasEnvironment IncubationEnvironment
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "
The **virtual-to-physical interaction** in this DT system involves command execution and human-in-the-loop intervention, primarily mediated through the RabbitMQ server. Commands for controlling the PT—such as adjusting the fan or heatbed—are **listened from the RabbitMQ server**, indicating a message-based control mechanism. While the exact message formats are not specified, the system implies structured command payloads are transmitted to the PT for execution. Validation and authentication mechanisms are not explicitly detailed, but the reliance on RabbitMQ’s inherent message queuing suggests some level of ordered and reliable command delivery. Feedback systems are implied through the monitoring phase, where violations (e.g., safety or optimality breaches) trigger human or algorithmic decisions to modify the PT’s state. Conflict resolution is not addressed in the document, but the system assumes that human operators or higher-level algorithms can override or adjust commands dynamically. Command execution confirmation is not explicitly mentioned, but the calibration and monitoring loops suggest implicit feedback loops for system verification.
"
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The Digital Twin system described in the provided documents does not explicitly detail synchronization frequencies, time scales for services, or latency requirements between the Physical Twin (PT) and Digital Twin (DT). The document mentions a 'periodic' reading of temperature data from the PT to the DT, but no specific time intervals (e.g., milliseconds, seconds, or minutes) are specified. Additionally, the document references a 'waiting duration' for the controller to process data, though no concrete duration is provided. Synchronization is facilitated via a RabbitMQ server, which handles internal communication between the PT and DT, but no temporal granularity or latency constraints are quantified. Thus, the temporal aspects of the twinning process remain unspecified beyond 'periodic' data acquisition and controller processing without defined frequencies or latency thresholds."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system follows a **modular architecture pattern**, integrating **data**, **models**, and **algorithms** as core components to enable end-to-end functionality. The system employs **calibration algorithms** to update models dynamically, ensuring alignment between the DT and the Physical Twin (PT). **Monitoring services** are embedded within the DT to assess system performance, safety, and optimality, with violations triggering **human or algorithmic interventions** (e.g., parameter adjustments or control actions). Resource management is implicit in the system's design, where **data** (collected via sensors) and **models** (representing CPS and environment) are prioritized for real-time processing. System-wide coordination is achieved through **closed-loop feedback mechanisms**, where the DT's outputs (e.g., state estimates, predictions) inform both the PT and subsequent algorithmic or human decisions. The architecture leverages **simulation capabilities** to reproduce and predict PT behavior under current operating conditions, integrating **optimization techniques** to enhance performance."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "
The lifecycle of a Digital Twin (DT) spans multiple stages, beginning with **conceptualization and design**, where abstract models (e.g., CAD representations of physical components like car chassis or wheel dimensions) are developed to capture specific system aspects. These models are later refined into **dynamic models** (e.g., differential equations for force dynamics) to analyze behavior under operational conditions. During **development**, the DT integrates **data collection** (real-time sensor inputs from the Physical Twin (PT)), **models** (cyber-physical system (CPS) and environmental representations), and **algorithms** (e.g., calibration algorithms, fault detectors, and state estimators) to update parameters dynamically. Transition management between stages involves **model integration**—ensuring legacy models (e.g., CAD or dynamic simulations) are not discarded but repurposed into the DT framework. Lifecycle governance includes **continuous validation** of model accuracy via calibration algorithms that adjust parameters to align with PT behavior, ensuring the DT remains a reliable proxy for decision-making. The final stage emphasizes **operational deployment**, where the DT supports real-time monitoring, predictive analytics, and adaptive control, with governance mechanisms (e.g., human-in-the-loop interventions) to address violations detected by monitors (e.g., safety or optimality checks)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "
The Digital Twin (DT) emphasizes **model fidelity** and **validity** through structured methodologies to ensure accuracy and reliability:
- **Fidelity Requirements**:
  - Models must abstract **specific aspects** of the PT (e.g., geometric, behavioral, or analytical) while excluding irrelevant details (e.g., CAD models omit dynamic forces).
  - **Dynamic Models** (e.g., differential equations) are validated against real-world PT behavior to ensure predictive accuracy.
- **Validation and Verification Methods**:
  - **Calibration Algorithms**: Continuously refine models by updating parameters using real-time sensor data to minimize discrepancies between virtual and physical representations.
  - **Monitoring Systems**: Deployed to detect deviations (e.g., safety violations, suboptimal performance) via algorithms like fault detectors or state estimators.
- **Uncertainty Sources and Quantification**:
  - **Sensor Noise/Error**: Introduced by real-time data collection, requiring statistical or machine-learning-based error correction.
  - **Model Assumptions**: Parametric or empirical inaccuracies in behavioral/analytical models, quantified via residual analysis or comparison to benchmark datasets.
- **Error Detection and Correction Mechanisms**:
  - **Feedback Loops**: Algorithms (e.g., supervisory controllers) trigger corrective actions when violations are detected, either autonomously or via human intervention.
  - **Quality Assurance Processes**:
    - **Pre-deployment**: Models undergo rigorous testing (e.g., simulation validation) to ensure consistency with design specifications.
    - **Post-deployment**: Continuous calibration and monitoring to adapt to environmental/operational changes, maintaining long-term fidelity.
"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The **technical network infrastructure** for this Digital Twin system is a **local network** architecture centered around a **Raspberry Pi 4 Model B** hosting the RabbitMQ server as a message broker. The communication protocol relies on RabbitMQ’s lightweight, mature framework, though specific protocols (e.g., AMQP) or security protocols (e.g., TLS) are not mentioned. Network topology is not detailed beyond the local setup, and bandwidth/latency requirements are unspecified. Reliability mechanisms are not explicitly described, though RabbitMQ’s maturity suggests inherent fault tolerance. No mention of redundancy or security protocols (e.g., encryption, firewalls) is provided."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The **deployment infrastructure** for this Digital Twin system is hosted **on-premise** on a **Raspberry Pi 4 Model B**, with no cloud or edge deployment mentioned. Computational and storage requirements are not specified, but the system implies minimal resource demands due to the lightweight RabbitMQ server and local sensor integration. Scalability mechanisms are not addressed, and the deployment model is limited to a single-node setup. Availability and reliability are not quantified, though the use of RabbitMQ suggests basic fault tolerance. No redundancy or high-availability configurations are described."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "
The Digital Twin (DT) incorporates **safety-critical system considerations** by integrating **monitoring algorithms** that continuously assess the Physical Twin (PT) for operational safety and optimality. The system employs **calibration algorithms** to refine models of the Cyber-Physical System (CPS) and its environment, ensuring parameter accuracy for reliable decision-making. **Fail-safe mechanisms** are implied through the use of **monitors** that detect violations of predefined safety thresholds, triggering corrective actions (e.g., human intervention or automated adjustments) to maintain system integrity. While the document does not specify explicit **cybersecurity protocols** or **access control mechanisms**, it highlights the role of **algorithms** (e.g., fault detectors, state estimators) in mitigating risks by validating PT behavior against modeled expectations. The **low-level driver** referenced in the context enforces a 'safe protocol' to constrain the PT’s operational state, aligning with basic safety-critical design principles. No detailed mention of **authentication systems**, **threat mitigation strategies**, or **risk assessment frameworks** (e.g., ISO/IEC 27001, NIST SP 800-53) is provided."
]