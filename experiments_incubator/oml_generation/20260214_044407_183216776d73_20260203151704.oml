// C3: Physical sensing components
instance SensorInside1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire temperature sensor inside the incubator, mounted near the lower rack"
    DTDFVocab:producedData TempDataInside1
]

instance SensorInside2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire temperature sensor inside the incubator, mounted near the upper rack"
    DTDFVocab:producedData TempDataInside2
]

instance SensorOutside : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire temperature sensor external to the box, measuring ambient room temperature"
    DTDFVocab:producedData TempDataOutside
]

// C4: Physical‑to‑virtual interaction
instance TempDataInside1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SensorInside1
]

instance TempDataInside2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SensorInside2
]

instance TempDataOutside : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom SensorOutside
]

// C10: Models/Data
instance TempReadingInside1 : DTDFVocab:Data [
    base:desc "Temperature reading from SensorInside1, published to RabbitMQ"
    DTDFVocab:inputTo LowLevelDriver
    DTDFVocab:fromData TempDataInside1
]

instance TempReadingInside2 : DTDFVocab:Data [
    base:desc "Temperature reading from SensorInside2, published to RabbitMQ"
    DTDFVocab:inputTo LowLevelDriver
    DTDFVocab:fromData TempDataInside2
]

instance TempReadingOutside : DTDFVocab:Data [
    base:desc "Temperature reading from SensorOutside, published to RabbitMQ"
    DTDFVocab:inputTo LowLevelDriver
    DTDFVocab:fromData TempDataOutside
]

// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Electric heater (heatbed) driven via MOSFETs/optocouplers on the Raspberry Pi GPIO"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal fan controlled via MOSFETs/optocouplers to achieve ~0.02 m³/s airflow"
]

// C11: Enablers
instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Raspberry Pi low‑level driver for sensor I²C/1‑Wire bus communication and actuator GPIO control"
    DTDFVocab:enables BangBangControllerService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker for real‑time publishing of sensor data and actuator states"
    DTDFVocab:enables TemperatureSimulationService, SafetyMonitoringService, FaultDetectionService
]

instance ThermalSimulatorEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that runs the DT thermal simulation models A and B"
    DTDFVocab:enables TemperatureSimulationService
]

instance SciPyCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that performs nonlinear least‑squares calibration using SciPy over logged data"
]

instance BangBangControllerService : DTDFVocab:Service [
    base:desc "Service that implements the simple bang‑bang controller logic for heater and fan"
]

// C6: Services
instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Real‑time temperature simulation service using dynamic Models A and B to predict future trajectories"
    DTDFVocab:provides TemperatureForecastInsight
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors temperature safety limits and variance, issuing alerts"
    DTDFVocab:provides TemperatureVarianceAlertInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service that detects overheating or non‑uniform temperature distribution across the sensors"
    DTDFVocab:provides FaultDetectionInsight
]

// C10: Models
instance ModelA_Thermal : DTDFVocab:Model [
    base:desc "Dynamic thermal model A, includes states: air temperature, heater temperature, heat transfer constants G_box, G_heater"
    DTDFVocab:inputTo ThermalSimulatorEnabler
]

instance ModelB_Thermal : DTDFVocab:Model [
    base:desc "Dynamic thermal model B, alternative formulation for validation against experimental data"
    DTDFVocab:inputTo ThermalSimulatorEnabler
]

// C17: Insights/Actions
instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Projected temperature trajectory for the next interval based on current sensor data and calibrated model parameters"
]

instance TemperatureVarianceAlertInsight : DTDFVocab:Insight [
    base:desc "Alert indicating variance between internal sensors exceeds the threshold, signaling uneven heating"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detected fault due to overheating or non‑uniform temperature distribution within the incubator"
]

instance AdjustHeatbedAction : DTDFVocab:Action [
    base:desc "Automatically adjust heatbed ON/OFF state to maintain target temperature, driven by simulation forecast"
    DTDFVocab:IsAutomatic true
]

instance AdjustFanSpeedAction : DTDFVocab:Action [
    base:desc "Automatically adjust fan speed to distribute heat uniformly within the incubator"
    DTDFVocab:IsAutomatic true
]

// C17: Environment and Components
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains StyrofoamBoxComponent, HeatbedComponent, FanComponent, SensorInside1, SensorInside2, SensorOutside, HeatbedActuator, FanActuator, PCBComponent, RaspberryPiComponent, IncubatorSystem
]

instance StyrofoamBoxComponent : DTDFVocab:Component [
    base:desc "Styrofoam box with volume approximately 0.03 m³, providing thermal insulation"
]

instance HeatbedComponent : DTDFVocab:Component [
    base:desc "Electrical heatbed integrated within the box for uniform heating"
]

instance FanComponent : DTDFVocab:Component [
    base:desc "Internal fan mounted on the box, providing ~0.02 m³/s airflow"
]

instance PCBComponent : DTDFVocab:Component [
    base:desc "Custom PCB with MOSFETs and optocouplers routing the Raspberry Pi GPIO signals to the actuators"
]

instance RaspberryPiComponent : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B acting as the central controller and low‑level driver host"
]

instance IncubatorSystem : DTDFVocab:Component [
    base:desc "Thermally insulated incubator system consisting of a styrofoam box, heatbed, fan, sensors, and Raspberry Pi controller"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT’s controller publishes ON/OFF commands for the heatbed and fan through RabbitMQ, which the low‑level driver forwards to the Raspberry Pi GPIO, thereby actuating the PT."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An integrated stack where the PT (heater, fan, sensors, Raspberry Pi, PCB) communicates with the DT over RabbitMQ; the DT comprises a controller module, a simulation module (Model A/B), a calibration module, and a monitoring interface, all running on the same device or locally."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design of the physical incubator → development of dynamic models (Model A/B) → calibration of model parameters using experimental data → validation against measured temperature traces → deployment of the DT on the Raspberry Pi → future extensions to improve model fidelity and optimisation."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity depends on validity of assumptions (uniform temperature, negligible wall heat accumulation, constant specific heat of air, negligible heater heat loss). Validation is performed by comparing simulated temperature profiles with measured data from the uniform‑temperature experiments; residual errors after calibration are minimized using SciPy's least‑squares optimiser."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Data flows over the Raspberry Pi’s Wi‑Fi interface to a local RabbitMQ broker; temperature sensors communicate via the 1‑Wire bus; actuator commands are transmitted through GPIO‑controlled MOSFETs with optocoupler isolation; all messages are serialized using RabbitMQ's AMQP protocol."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT stack (controller, simulation, calibration) is hosted on the Raspberry Pi used for physical control, delivering low‑latency interaction; the RabbitMQ broker is also locally hosted, enabling near‑real‑time synchronization between PT and DT."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Hardware follows the DS18S20 1‑Wire specification for temperature sensing; communication uses the AMQP/RabbitMQ standard; controller logic follows established bang‑bang control algorithm; PCB design adheres to typical MOSFET/optocoupler isolation standards. No industry‑wide digital twin standards are explicitly referenced."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Low‑level driver incorporates a safe protocol to ensure the PT stays in a safe state; optocouplers isolate control signals; the AMQP broker supports authentication and access control; safety considerations include preventing overheating by enforcing temperature limits within the controller statechart."
]