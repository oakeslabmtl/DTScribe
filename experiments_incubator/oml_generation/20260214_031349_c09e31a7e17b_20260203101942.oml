// ------------------------------------------------------------
// Acting Components
// ------------------------------------------------------------
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed (214 × 214 × 3 mm) switched by a MOSFET driver delivering up to 4 A, controlled via Raspberry Pi GPIO."
]

instance InternalFanActuator : DTDFVocab:ActingComponent [
    base:desc "12‑24 V circulation fan (≈0.02 m³ s⁻¹) switched by a MOSFET driver, controlled via Raspberry Pi GPIO."
]

// ------------------------------------------------------------
// Sensing Components
// ------------------------------------------------------------
instance InternalAirTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer inside the incubator box, accuracy ±0.5 °C, range –55 °C to +125 °C."
    DTDFVocab:producedData InternalAirTempData1Transmitted
]

instance InternalAirTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer inside the incubator box, accuracy ±0.5 °C, range –55 °C to +125 °C."
    DTDFVocab:producedData InternalAirTempData2Transmitted
]

instance AmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer measuring ambient room temperature, accuracy ±0.5 °C, range –55 °C to +125 °C."
    DTDFVocab:producedData AmbientTempDataTransmitted
]

// ------------------------------------------------------------
// Data Transmitted (Physical → Virtual)
// ------------------------------------------------------------
instance InternalAirTempData1Transmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalAirTempSensor1
]

instance InternalAirTempData2Transmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalAirTempSensor2
]

instance AmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientTempSensor
]

// ------------------------------------------------------------
// Data (Virtual)
// ------------------------------------------------------------
instance InternalAirTempData1 : DTDFVocab:Data [
    base:desc "Temperature sample from internal air sensor 1 published to RabbitMQ."
    DTDFVocab:fromData InternalAirTempData1Transmitted
    DTDFVocab:inputTo PythonLowLevelDriver, SciPyOptimizer
]

instance InternalAirTempData2 : DTDFVocab:Data [
    base:desc "Temperature sample from internal air sensor 2 published to RabbitMQ."
    DTDFVocab:fromData InternalAirTempData2Transmitted
    DTDFVocab:inputTo PythonLowLevelDriver, SciPyOptimizer
]

instance AmbientTempData : DTDFVocab:Data [
    base:desc "Ambient temperature sample published to RabbitMQ."
    DTDFVocab:fromData AmbientTempDataTransmitted
    DTDFVocab:inputTo PythonLowLevelDriver, SciPyOptimizer
]

// ------------------------------------------------------------
// Models
// ------------------------------------------------------------
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Single‑node air temperature model with parameters C_air (thermal capacitance) and G_box (conductance to ambient)."
    DTDFVocab:inputTo SciPyOptimizer
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Dual‑node model (air + heat‑bed) with parameters C_air, C_heater, G_box, G_heater."
    DTDFVocab:inputTo SciPyOptimizer
]

// ------------------------------------------------------------
// Enablers (Tools & Infrastructure)
// ------------------------------------------------------------
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on the Raspberry Pi for pub/sub of sensor samples, controller state, and actuator commands."
    DTDFVocab:enables ModelCalibrationService, TemperatureSimulationService, SafetyMonitoringService, ControllerOptimizationService
]

instance PythonLowLevelDriver : DTDFVocab:Enabler [
    base:desc "Python low‑level driver that reads DS18S20 sensors and publishes temperature samples to RabbitMQ also receives actuator commands."
    DTDFVocab:enables TemperatureSimulationService, SafetyMonitoringService
]

instance SciPyOptimizer : DTDFVocab:Enabler [
    base:desc "SciPy optimisation library used for non‑linear least‑squares parameter estimation and controller‑limit optimisation."
    DTDFVocab:enables ModelCalibrationService, ControllerOptimizationService
]

// ------------------------------------------------------------
// Services
// ------------------------------------------------------------
instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Non‑linear least‑squares parameter estimation using SciPy to calibrate thermal model parameters (C_air, G_box, C_heater, G_heater) from sensor temperature trajectories."
    DTDFVocab:provides CalibrationInsight
]

instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Simulation of incubator temperature dynamics using Model A or Model B based on current control inputs."
    DTDFVocab:provides SimulationInsight
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of sensor thresholds generates alerts and automatic actions when temperature exceeds safety limits."
    DTDFVocab:provides SafetyViolationInsight, SafetyViolationAction
]

instance ControllerOptimizationService : DTDFVocab:Service [
    base:desc "Optimisation of controller limits (LL, UL, heating duration, waiting duration) using calibrated model and SciPy."
    DTDFVocab:provides OptimizationInsight, OptimizationAction
]

// ------------------------------------------------------------
// Insights & Actions
// ------------------------------------------------------------
instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Refined thermal model parameters (C_air, G_box, C_heater, G_heater) resulting from calibration."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory of the incubator under the given control settings."
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detection that temperature exceeds predefined safety thresholds."
]

instance SafetyViolationAction : DTDFVocab:Action [
    base:desc "Automatic command to deactivate the heat‑bed and/or fan to prevent overheating."
    DTDFVocab:IsAutomatic true
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimised controller limits (lower‑limit, upper‑limit, heating duration, waiting duration) derived from the calibrated model."
]

instance OptimizationAction : DTDFVocab:Action [
    base:desc "Update the controller configuration with the newly optimised limits."
    DTDFVocab:IsAutomatic false
]

// ------------------------------------------------------------
// Environment (Physical Context)
// ------------------------------------------------------------
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, InternalFanActuator,
                 InternalAirTempSensor1, InternalAirTempSensor2, AmbientTempSensor
]

// ------------------------------------------------------------
// Generic Physical Components (optional)
// ------------------------------------------------------------
instance HeatBedElement : DTDFVocab:Component [
    base:desc "Resistive heating element forming the heat‑bed."
]

instance FanElement : DTDFVocab:Component [
    base:desc "12‑24 V axial fan for internal air circulation."
]

instance DS18S20Thermometer : DTDFVocab:Component [
    base:desc "High‑precision 1‑Wire digital temperature sensor (±0.5 °C)."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT services send command messages over RabbitMQ to the Raspberry Pi controller, which forwards actuation commands to the low‑level driver; the driver then toggles the MOSFETs to turn the heat‑bed and fan on or off according to the virtual decisions."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT architecture follows a CPS‑based pattern: PT components connect to the controller via the PCB, the controller communicates bidirectionally with a RabbitMQ server on the same Pi, and DT modules subscribe to sensor topics and publish actuation commands, forming a centralized message‑driven constellation as illustrated in Fig. 7 of the document."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed through explicit assumptions (uniform air temperature, negligible wall heat accumulation, constant air specific heat, heat‑bed heat loss ignored in Model A) and validated by experiments measuring temperature uniformity with varied fan voltage; calibration residuals are minimized via non‑linear least‑squares, and the four‑parameter Model B shows improved prediction of thermal inertia compared to Model A."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication between PT and DT relies on the RabbitMQ AMQP broker (running locally on the Raspberry Pi) over the Pi's Wi‑Fi/Bluetooth network; sensor data uses the 1‑Wire bus protocol, and actuation commands are delivered through GPIO‑controlled MOSFET drivers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All DT services (RabbitMQ server, low‑level driver, controller, calibration scripts) are hosted on the Raspberry Pi 4 Model B itself, enabling on‑premises deployment; the complete hardware and software stack is publicly available via an open‑source GitHub repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver embeds a safe‑protocol to keep the device in a safe state; the controller includes monitoring of temperature limits (LL, UL) to prevent overheating, providing basic safety assurance, though no explicit security standards are mentioned."
]