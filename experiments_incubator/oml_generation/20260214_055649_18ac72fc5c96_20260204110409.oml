// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed component delivering ≥100W power via MOSFET/optocoupler isolation for temperature regulation in styrofoam insulated box"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan circulating air at 0.02 m³/s controlled at 12V/24V via Raspberry Pi GPIO for temperature regulation"
]

// C3: Physical Sensing Components
instance RoomTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "External DS18S20 temperature sensor measuring room temperature (-55°C to +125°C with 0.5°C accuracy)"
    DTDFVocab:producedData RoomTemperatureData
]

instance InternalTemperatureSensorT2 : DTDFVocab:SensingComponent [
    base:desc "Internal DS18S20 temperature sensor (T2) measuring box interior temperature (-55°C to +125°C with 0.5°C accuracy)"
    DTDFVocab:producedData InternalTemperatureDataT2
]

instance InternalTemperatureSensorT3 : DTDFVocab:SensingComponent [
    base:desc "Internal DS18S20 temperature sensor (T3) measuring box interior temperature at different position (-55°C to +125°C with 0.5°C accuracy)"
    DTDFVocab:producedData InternalTemperatureDataT3
]

// C4: Data Transmission
instance RoomTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom RoomTemperatureSensor
]

instance InternalTemperatureDataT2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensorT2
]

instance InternalTemperatureDataT3 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTemperatureSensorT3
]

// C5: Data Storage
instance TemperatureReadingsData : DTDFVocab:Data [
    base:desc "Combined temperature readings from all three DS18S20 sensors (T_room, T2, T3) with 0.5°C accuracy"
    DTDFVocab:fromData RoomTemperatureData, InternalTemperatureDataT2, InternalTemperatureDataT3
]

instance PowerMeasurementData : DTDFVocab:Data [
    base:desc "Voltage × Current measurements from heatbed power input (V*I) for thermal model calibration"
    DTDFVocab:fromData PowerInputData
]

instance ExperimentalTrajectoriesData : DTDFVocab:Data [
    base:desc "Experimental temperature trajectories for model validation (uniform temperature validation figures 9-12)"
]

// C6: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker deployed on Raspberry Pi for real-time communication between PT and DT"
    DTDFVocab:enables TemperatureRegulationService, ModelCalibrationService, VisualizationService
]

instance LowLevelDrivers : DTDFVocab:Enabler [
    base:desc "Low-level drivers for PT interaction enabling GPIO control of actuators via Raspberry Pi"
    DTDFVocab:enables TemperatureRegulationService
]

instance PythonScipy : DTDFVocab:Enabler [
    base:desc "Python (Scipy) environment for model calibration via non-linear least squares optimization"
    DTDFVocab:inputTo SimplifiedAirModel, DetailedThermalModel
]

instance StyrofoamInsulation : DTDFVocab:Enabler [
    base:desc "Styrofoam insulated box providing thermal isolation (0.03 m³ volume) for temperature regulation"
]

// C7: Models
instance SimplifiedAirModel : DTDFVocab:Model [
    base:desc "Single-parameter model (C_air) describing energy flow between box air and room via heat equation (Q = C_air × ΔT)"
    DTDFVocab:inputTo PythonScipy
]

instance DetailedThermalModel : DTDFVocab:Model [
    base:desc "Four-parameter model (C_air, C_heater, G_box, G_heater) accounting for heatbed thermal inertia and energy transfer between components"
    DTDFVocab:inputTo PythonScipy
]

// C8: Services
instance TemperatureRegulationService : DTDFVocab:Service [
    base:desc "Bang-bang control strategy maintaining target temperatures (293K-300K) via heatbed/fan adjustments with waiting delays"
    DTDFVocab:provides TemperatureRegulationInsight, TemperatureRegulationAction
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Non-linear least squares optimization refining parameters (C_air, C_heater, G_box, G_heater) for improved predictive accuracy"
    DTDFVocab:provides ModelParameterUpdateInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Temperature trend visualization and system state monitoring (heatbed/fan status) via RabbitMQ and data logging"
    DTDFVocab:provides TemperatureTrendVisualizationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Implicit fault detection via model validation and residual error minimization"
    DTDFVocab:provides ResidualErrorAnalysisInsight
]

// C9: Insights/Actions
instance TemperatureRegulationInsight : DTDFVocab:Insight [
    base:desc "Real-time temperature feedback from all sensors validating uniform temperature distribution (293K-300K target)"
]

instance TemperatureRegulationAction : DTDFVocab:Action [
    base:desc "Dynamic adjustment of heatbed/fan based on sensor feedback to maintain target temperature range"
    DTDFVocab:IsAutomatic true
]

instance ModelParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Optimized model parameters (C_air, C_heater, G_box, G_heater) from non-linear least squares calibration"
]

instance ResidualErrorAnalysisInsight : DTDFVocab:Insight [
    base:desc "Error analysis between model predictions and experimental data for fault detection and model refinement"
]

instance TemperatureTrendVisualizationInsight : DTDFVocab:Insight [
    base:desc "Temperature trend visualization data for system monitoring"
]

instance UniformTemperatureValidationInsight : DTDFVocab:Insight [
    base:desc "Experimental validation of uniform temperature distribution (figures 9-12) confirming model assumptions"
]

// C12: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator, FanActuator, RoomTemperatureSensor, InternalTemperatureSensorT2, InternalTemperatureSensorT3
]

instance ControlSystemEnvironment : DTDFVocab:Environment [
    base:contains RabbitMQBroker, LowLevelDrivers, PythonScipy, StyrofoamInsulation
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT communicates with the PT via the RabbitMQ server to issue commands for actuating the heatbed and fan. The interaction follows a bang-bang control strategy: the DT sends a heating command to the heatbed until the measured temperature (from T2/T3) reaches the reference temperature, followed by a waiting period (H and C parameters) to prevent overshoot. The DT uses a statechart-based controller (LL, UL, H, C parameters) to regulate temperature dynamically."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT operates on a **real-time to near-real-time** scale. Temperature data is sampled at a frequency determined by the control loop (H + C delay periods, e.g., ~2 seconds for heatbed actuation) and model updates occur via non-linear least squares calibration (experimental data collection rate: ~10–20 samples per minute). Synchronization between DT and PT is tightly coupled to the control cycle, ensuring timely feedback for temperature regulation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation is a **centralized architecture** with the following components orchestrated via RabbitMQ: (1) **Physical Twin (PT)**: Insulated box, heatbed, fan, sensors, and Raspberry Pi controller; (2) **Digital Twin (DT)**: Calibration algorithms (Python), model updates, and visualization tools; (3) **Communication Layer**: RabbitMQ server (on Raspberry Pi) for message synchronization between PT and DT; (4) **Control Loop**: PT → RabbitMQ → DT (temperature feedback) → DT → RabbitMQ → PT (actuation commands)."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT spans the following life-cycle stages for the incubator PT: (1) **As-designed**: Idealized models (Model A/B) with assumptions (uniform temperature, negligible heat loss to walls, constant air properties). (2) **As-manufactured**: Calibrated models (Model B) with four parameters (C_air, C_heater, G_box, G_heater) derived from experimental data. (3) **As-operated**: Real-time DT operation with temperature regulation, model updates, and fault monitoring during runtime."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "The DT’s fidelity and validity are ensured through: (1) **Assumptions Validation**: Uniform temperature distribution is experimentally validated (figs. 10–12), showing discrepancies ≤7°C with fan adjustments; (2) **Model Calibration**: Non-linear least squares optimization minimizes residual error between model predictions and experimental data (section 3.3); (3) **Uncertainty Handling**: Model parameters (C_air, C_heater, G_box, G_heater) are empirically derived from calibration experiments; (4) **Verification/Validation**: Experimental setup (figs. 9–12) and model comparison (Model B outperforms Model A by accounting for heatbed inertia)."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The DT technical connection uses a **networked CPS architecture** with the following details: (1) **Protocol**: RabbitMQ (open-source message broker) for real-time data exchange between PT and DT; (2) **Network**: Deployed on the Raspberry Pi (local network) with built-in Wi-Fi/Bluetooth; (3) **Communication Flow**: PT → RabbitMQ (temperature/fan status) → DT (model updates/control logic) → RabbitMQ → PT (actuation commands); (4) **Latency**: Control loop latency is dominated by H + C delays (~2 seconds), ensuring real-time synchronization."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT is hosted/deployed on the **Raspberry Pi 4 Model B** as a local, on-premises system. The RabbitMQ server runs on the same device, enabling low-latency communication between PT and DT components. The hardware/software specifications are publicly available in the INTO-CPS Association repository ([link](https://github.com/INTO-CPS-Association/example-incubator))."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT includes safety considerations: (1) **Hardware Isolation**: MOSFETs/optocouplers decouple Raspberry Pi control signals from high-current heatbed actuation; (2) **Control Protocol**: Bang-bang controller with waiting delays (H, C parameters) prevents overshoot; (3) **Data Safety**: RabbitMQ ensures message integrity and synchronization between PT and DT; (4) **Remote Operation**: The DT can remotely control the PT (heatbed/fan) via the Raspberry Pi’s GPIO and RabbitMQ, but physical safety is ensured by the hardware isolation and control logic (no direct human intervention required)."
]