// C3: Physical sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Internal temperature sensor positioned inside the incubator to measure temperature of the contents"
    DTDFVocab:producedData TemperatureDataMessage
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second internal temperature sensor positioned at a different location inside the incubator"
    DTDFVocab:producedData TemperatureDataMessage
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "External temperature sensor monitoring ambient conditions outside the incubator"
    DTDFVocab:producedData TemperatureDataMessage
]

// C4: Physical-to-virtual interaction
instance TemperatureDataMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1, InternalTempSensor2, ExternalTempSensor
    base:desc "AMQP message published to RabbitMQ containing raw temperature readings from the three sensors"
]

// C10: Data
instance TemperatureTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of temperature readings stored in the database for visualization, calibration and anomaly detection"
    DTDFVocab:fromData TemperatureDataMessage
    DTDFVocab:inputTo VisualizationDashboard, CalibrationEngine, KalmanFilterEngine, CoSimulationEngine, SelfAdaptationLoopEngine
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ broker handling AMQP messages from the Raspberry Pi"
]

instance VisualizationDashboard : DTDFVocab:Enabler [
    base:desc "Web‑based dashboard rendering real‑time temperature series"
    DTDFVocab:enables RealTimeVisualizationService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Automated calibration routine that adjusts parameters of Model A and Model B using incoming temperature data"
    DTDFVocab:enables CalibrationService
]

instance KalmanFilterEngine : DTDFVocab:Enabler [
    base:desc "Kalman filter that fuses temperature data with Model B to estimate heat‑bed temperature and detect anomalies"
    DTDFVocab:enables AnomalyDetectionService
]

instance CoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation framework that runs what‑if analyses by replaying historical or live data with the thermal models"
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationLoopEngine : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop that detects behavior changes, schedules experiments, recalibrates models, and updates controller settings"
    DTDFVocab:enables SelfAdaptationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualization of incubator temperature status"
    DTDFVocab:provides TemperatureTrendInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Offers on‑demand calibration of thermal models using streamed temperature data"
    DTDFVocab:provides CalibrationErrorInsight, UpdateControllerParametersAction
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Detects anomalies and estimates heat‑bed state via Kalman filter"
    DTDFVocab:provides AnomalyAlertInsight, StopHeatingAction, AdjustFanSpeedAction
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Executes what‑if co‑simulations to evaluate alternative controller parameter sets"
    DTDFVocab:provides SimulationResultInsight
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Runs self‑adaptation loop to reconfigure controller based on detected plant behaviour changes"
    DTDFVocab:provides AdaptationDecisionInsight, SetTemperatureSetpointAction
]

// C17: Insights
instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Insight into current temperature trend and proximity to the set‑point"
]

instance CalibrationErrorInsight : DTDFVocab:Insight [
    base:desc "Metric indicating calibration error of Model A and Model B after parameter estimation"
]

instance AnomalyAlertInsight : DTDFVocab:Insight [
    base:desc "Alert generated when temperature deviates beyond safety thresholds or Kalman residuals exceed limits"
]

instance SimulationResultInsight : DTDFVocab:Insight [
    base:desc "Result of what‑if simulation showing optimal controller parameters and predicted temperature response"
]

instance AdaptationDecisionInsight : DTDFVocab:Insight [
    base:desc "Decision recommendation produced by self‑adaptation loop for updating controller configuration"
]

// C17: Actions
instance SetTemperatureSetpointAction : DTDFVocab:Action [
    base:desc "Change the target temperature set‑point of the incubator via the controller"
    DTDFVocab:IsAutomatic true
]

instance AdjustFanSpeedAction : DTDFVocab:Action [
    base:desc "Adjust fan speed to modify heat distribution inside the incubator"
    DTDFVocab:IsAutomatic true
]

instance StopHeatingAction : DTDFVocab:Action [
    base:desc "Command to stop the resistive heat‑bed heating"
    DTDFVocab:IsAutomatic true
]

instance UpdateControllerParametersAction : DTDFVocab:Action [
    base:desc "Re‑program controller with newly calibrated model parameters"
    DTDFVocab:IsAutomatic true
]

// C10: Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model A with two free parameters representing coarse temperature dynamics"
    DTDFVocab:inputTo CalibrationEngine, CoSimulationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Analytical thermal model B with four free parameters capturing thermal inertia of the heat‑bed more accurately"
    DTDFVocab:inputTo CalibrationEngine, KalmanFilterEngine, CoSimulationEngine, SelfAdaptationLoopEngine
]

// C2: Acting components
instance ResistiveHeatBed : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that generates heat to raise incubator temperature, driven by GPIO via driver circuit"
]

instance CoolingFan : DTDFVocab:ActingComponent [
    base:desc "Fan that circulates air inside the insulated box to distribute heat, driven by GPIO via driver circuit"
]

// Additional components
instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi edge controller running the incubator control software, handling sensor acquisition and actuator commands"
]

// Environment composition
instance IncubatorBox : DTDFVocab:Environment [
    base:contains ResistiveHeatBed, CoolingFan, InternalTempSensor1, InternalTempSensor2, ExternalTempSensor, RaspberryPiController
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands (heat‑bed ON/OFF and fan ON/OFF) are issued by the Digital Twin as AMQP messages to the same RabbitMQ server; the low‑level driver receives these messages, validates them with an incorporated safe‑state protocol, and actuates the corresponding hardware, sending back status acknowledgments through the broker."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "The DT processes sensor data in near real‑time: controller and low‑level driver messages are streamed to a time‑series database and visualised on a dashboard, with on‑demand calibration, Kalman‑filter based anomaly detection and co‑simulation triggered as needed. The documents do not provide explicit sampling frequencies, latency requirements or temporal granularity specifications."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The system follows a centralized Digital Twin architecture that integrates the physical incubator (plant), a Raspberry‑Pi controller, a data acquisition layer that relays sensor readings to a time‑series database, a visualization dashboard, calibration algorithms, a Kalman filter for heat‑bed state estimation, and a co‑simulation engine for what‑if analysis. Components communicate through controller and driver messages, and the DT hosts models, monitoring and optimisation services as described in the documents."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is required to accurately represent the heat‑bed’s thermal inertia; this is validated experimentally by comparing model predictions against measured temperature trajectories, where Model B (four‑parameter) shows superior fidelity. Validation and verification are performed through on‑demand calibration that minimizes the error between sensor data and model output, and through Kalman‑filter residual monitoring for anomaly detection. Sources of uncertainty include sensor noise and parameter estimation errors; these are quantified during calibration and addressed by re‑calibrating the models when deviations exceed predefined thresholds. Quality assurance is maintained via continuous monitoring, automated calibration cycles, and the self‑adaptation loop that re‑configures models, filters and controllers in response to detected deviations."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The system uses a TCP/IP network with a RabbitMQ message broker (AMQP protocol) as the central hub; the Raspberry Pi controller, low‑level driver and Digital Twin components are connected in a client‑server topology, relying on RabbitMQ’s built‑in reliability (message persistence, acknowledgements); specific bandwidth, latency, or security (TLS) requirements are not detailed in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The RabbitMQ server and the controller software are deployed on‑premise (the RabbitMQ broker runs on a local machine; the controller runs on a Raspberry Pi); no cloud or edge platform is mentioned, and scalability or storage specifications are not provided."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "The DT ingests data from the incubator controller and low‑level drivers into a time‑series database and exchanges this information with calibration, estimation and simulation modules, but the documents do not specify any external communication protocols, interoperability standards, or integration with other enterprise systems."
]