// Sensing components
instance IncubatorInternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor measuring internal ambient temperature inside the incubator"
    DTDFVocab:producedData IncubatorInternalTempDataTransmitted1
]

instance IncubatorInternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor measuring internal ambient temperature inside the incubator"
    DTDFVocab:producedData IncubatorInternalTempDataTransmitted2
]

instance ExternalAmbientTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor measuring external ambient temperature"
    DTDFVocab:producedData ExternalAmbientTempDataTransmitted
]

// Data transmitted from sensors
instance IncubatorInternalTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInternalTempSensor1
]

instance IncubatorInternalTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInternalTempSensor2
]

instance ExternalAmbientTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalAmbientTempSensor
]

// Data recorded by DT
instance IncubatorInternalTempData1 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from IncubatorInternalTempSensor1"
    DTDFVocab:fromData IncubatorInternalTempDataTransmitted1
    DTDFVocab:inputTo RabbitMQServerEnabler
]

instance IncubatorInternalTempData2 : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from IncubatorInternalTempSensor2"
    DTDFVocab:fromData IncubatorInternalTempDataTransmitted2
    DTDFVocab:inputTo RabbitMQServerEnabler
]

instance ExternalAmbientTempData : DTDFVocab:Data [
    base:desc "Time‑stamped temperature reading from ExternalAmbientTempSensor"
    DTDFVocab:fromData ExternalAmbientTempDataTransmitted
    DTDFVocab:inputTo RabbitMQServerEnabler
]

// Enablers
instance RabbitMQServerEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ server for AMQP communication over Wi-Fi, publishing sensor data and events"
    DTDFVocab:enables RealTimeTemperatureMonitoringService, ThermalDynamicsSimulationService,
                    CalibrationPipelineService, DataLoggingService, VisualizationDashboardService
]

instance SciPyLeastSquaresOptimizerEnabler : DTDFVocab:Enabler [
    base:desc "SciPy least‑squares optimization engine used for calibrating the dynamic thermal models"
    DTDFVocab:enables CalibrationPipelineService
]

// Services
instance RealTimeTemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of temperature, detecting deviations between predicted and measured temperatures"
    DTDFVocab:provides TemperatureDeviationInsight, SafetyAlertInsight
]

instance ThermalDynamicsSimulationService : DTDFVocab:Service [
    base:desc "Simulation of thermal dynamics using two calibrated models (ModelA and ModelB)"
    DTDFVocab:provides ParameterAdjustmentSuggestionInsight
]

instance CalibrationPipelineService : DTDFVocab:Service [
    base:desc "Calibration pipeline performing non‑linear least‑squares optimization against experimental temperature traces"
]

instance DataLoggingService : DTDFVocab:Service [
    base:desc "Data logging service for persisting time‑stamped temperature, power consumption, fan/heatbed status, and calibration residuals"
]

instance VisualizationDashboardService : DTDFVocab:Service [
    base:desc "Open‑source online visualization dashboard for real‑time data display"
]

// Insights
instance TemperatureDeviationInsight : DTDFVocab:Insight [
    base:desc "Real‑time diagnostics highlighting the deviation between predicted and measured temperatures"
]

instance SafetyAlertInsight : DTDFVocab:Insight [
    base:desc "Safety alerts triggered when temperature setpoints are violated"
]

instance ParameterAdjustmentSuggestionInsight : DTDFVocab:Insight [
    base:desc "Parameter adjustment suggestions such as heating duration H and waiting duration C based on calibrated models"
]

// Actions
instance AdjustHeatingDurationAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of heating duration H to bring temperature to setpoint"
    DTDFVocab:IsAutomatic true
]

instance AdjustWaitingDurationAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of waiting duration C between heating cycles"
    DTDFVocab:IsAutomatic true
]

// Acting components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed heating element driven via MOSFETs and optocouplers"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12/24 V fan providing air circulation, controlled by Raspberry Pi"
]

instance RaspberryPiController : DTDFVocab:ActingComponent [
    base:desc "Raspberry Pi 4 Model B controller toggling actuators and running low‑level driver"
]

// Models
instance ModelA : DTDFVocab:Model [
    base:desc "Single‑zone air temperature dynamics with parameter C_air and heat‑loss rate G_box"
    DTDFVocab:inputTo SciPyLeastSquaresOptimizerEnabler
]

instance ModelB : DTDFVocab:Model [
    base:desc "Two‑zone dynamics including heatbed temperature with parameters C_heater and G_heater"
    DTDFVocab:inputTo SciPyLeastSquaresOptimizerEnabler
]

instance ModelASimulationOutputData : DTDFVocab:Data [
    base:desc "Simulation result from ModelA"
]

instance ModelBSimulationOutputData : DTDFVocab:Data [
    base:desc "Simulation result from ModelB"
]

// Environment containing the incubator system
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator, FanActuator, RaspberryPiController,
           IncubatorInternalTempSensor1, IncubatorInternalTempSensor2,
           ExternalAmbientTempSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes command messages via RabbitMQ (e.g., turn heatbed ON/OFF, turn fan ON/OFF) which are received by the low‑level driver on the Raspberry Pi and converted into GPIO outputs to actuate the heatbed/fan through MOSFETs and optocouplers."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A CPS‑based Digital Twin where the physical twin (incubator, Raspberry Pi, sensors, actuators) communicates with the DT via a RabbitMQ broker hosted on the Pi. The DT consists of a Python simulation layer (Model A/B), a controller layer implementing Bang‑Bang logic, and a communication layer that publishes control commands and diagnostics back to the Pi."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Four modeling assumptions (uniform temperature distribution, negligible wall heat accumulation, constant specific heat capacity of air, and heatbed heat‑loss neglect) were validated experimentally; calibration minimized residual errors; model validity assessed against temperature experiments; uncertainties derived from least‑squares fit; models capture thermal inertia but not detailed wall heat transfer."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "PT communicates over Wi‑Fi through RabbitMQ using AMQP; device and controller publish/subscribe to specific queues; DT components on host connect to the same RabbitMQ broker for data ingestion and command dissemination."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "RabbitMQ server is hosted on the Raspberry Pi; Digital Twin simulation and control logic run in Python on the same Pi or a local PC, with all software open‑source and available via GitHub."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Low‑level driver implements a safe protocol to prevent unsafe states; optocouplers and MOSFETs provide electrical isolation; communication via RabbitMQ over Wi‑Fi (TLS not specified), but system design includes isolation to avoid overheating or unsafe actuator commands."
]