// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Surface heatbed heating element driven by MOSFET switches on the custom PCB, controlled by the Raspberry Pi"
]

instance CirculationFanActuator : DTDFVocab:ActingComponent [
    base:desc "Internal circulation fan driven by MOSFET switches on the custom PCB, controlled by the Raspberry Pi"
]

// C3: Physical sensing components
instance InteriorTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside the incubator box (interior sensor 1) communicating over a 1‑Wire bus"
    DTDFVocab:producedData InteriorTempDataTx1
]

instance InteriorTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside the incubator box (interior sensor 2) communicating over a 1‑Wire bus"
    DTDFVocab:producedData InteriorTempDataTx2
]

instance ExteriorTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor measuring ambient temperature outside the insulated box, connected via the 1‑Wire bus"
    DTDFVocab:producedData ExteriorTempDataTx
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance InteriorTempDataTx1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTemperatureSensor1
]

instance InteriorTempDataTx2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InteriorTemperatureSensor2
]

instance ExteriorTempDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExteriorTemperatureSensor
]

// C5: Data generated from sensors
instance InteriorTempData1 : DTDFVocab:Data [
    base:desc "Temperature measurement (°C) from interior sensor 1"
    DTDFVocab:fromData InteriorTempDataTx1
    DTDFVocab:inputTo RabbitMQBroker
]

instance InteriorTempData2 : DTDFVocab:Data [
    base:desc "Temperature measurement (°C) from interior sensor 2"
    DTDFVocab:fromData InteriorTempDataTx2
    DTDFVocab:inputTo RabbitMQBroker
]

instance ExteriorTempData : DTDFVocab:Data [
    base:desc "Ambient temperature measurement (°C) from exterior sensor"
    DTDFVocab:fromData ExteriorTempDataTx
    DTDFVocab:inputTo RabbitMQBroker
]

// C6: Enablers (tools / platforms)
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker running on the Raspberry Pi, receives sensor measurements and actuator state messages"
    DTDFVocab:enables TemperaturePredictionService,
                        ParameterCalibrationService,
                        RealTimeMonitoringService,
                        ViolationDetectionService
]

instance SciPyCalibrationEngine : DTDFVocab:Enabler [
    base:desc "SciPy non‑linear least‑squares optimiser used to estimate thermal model parameters (C_air, G_box, G_heater, C_heater)"
    DTDFVocab:enables ParameterCalibrationService
]

instance PredictionEngine : DTDFVocab:Enabler [
    base:desc "Engine that consumes calibrated ModelA or ModelB to generate future temperature predictions"
    DTDFVocab:enables TemperaturePredictionService
]

// C10: Models
instance ModelA_ThermalBalance : DTDFVocab:Model [
    base:desc "Physics‑based temperature Model A derived from an energy‑balance equation with a single thermal capacitance parameter"
    DTDFVocab:inputTo PredictionEngine
]

instance ModelB_ThermalBalance : DTDFVocab:Model [
    base:desc "Physics‑based temperature Model B derived from an energy‑balance equation with four parameters (C_air, G_box, G_heater, C_heater)"
    DTDFVocab:inputTo PredictionEngine,
                        SciPyCalibrationEngine
]

// C6: Services
instance TemperaturePredictionService : DTDFVocab:Service [
    base:desc "Provides temperature predictions using Model A or Model B for the incubator air"
    DTDFVocab:provides PredictedTemperatureInsight
]

instance ParameterCalibrationService : DTDFVocab:Service [
    base:desc "Calibrates thermal models by estimating parameters with SciPy's non‑linear least‑squares optimizer"
    DTDFVocab:provides ParameterSetInsight
]

instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Monitors real‑time temperature against defined safety limits"
    DTDFVocab:provides TemperatureViolationInsight
]

instance ViolationDetectionService : DTDFVocab:Service [
    base:desc "Detects breaches of lower/upper temperature limits and triggers appropriate actions"
    DTDFVocab:provides AlertOperatorAction,
                        AdjustHeatingAction
]

// C17: Insights
instance PredictedTemperatureInsight : DTDFVocab:Insight [
    base:desc "Predicted incubator air temperature trajectory over the forecast horizon"
]

instance ParameterSetInsight : DTDFVocab:Insight [
    base:desc "Calibrated model parameter set (C_air, G_box, G_heater, C_heater) ready for use in predictions"
]

instance TemperatureViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature violating the configured lower or upper safety limits"
]

// C17: Actions
instance AlertOperatorAction : DTDFVocab:Action [
    base:desc "Send an alert to the operator when a temperature limit breach is detected"
    DTDFVocab:IsAutomatic false
]

instance AdjustHeatingAction : DTDFVocab:Action [
    base:desc "Automatically adjust heatbed power or fan speed to restore temperature within safe bounds"
    DTDFVocab:IsAutomatic true
]

// C14: Additional Physical Components
instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B executing the low‑level driver, controller logic, and RabbitMQ server"
]

instance CustomPCB : DTDFVocab:Component [
    base:desc "Custom PCB equipped with MOSFET switches and optocouplers that drive the heatbed and fan"
]

// C13: Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedActuator,
                CirculationFanActuator,
                InteriorTemperatureSensor1,
                InteriorTemperatureSensor2,
                ExteriorTemperatureSensor,
                RaspberryPiController,
                CustomPCB
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT publishes control commands (turn‑on/off heatbed, turn‑on/off fan) to the RabbitMQ server; the Raspberry Pi controller receives these messages and actuates the MOSFET driver circuit accordingly."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The architecture consists of the Physical Twin (hardware), a low‑level driver translating sensor reads and actuator commands, a RabbitMQ communication server on the Raspberry Pi, DT modules that subscribe to RabbitMQ for data ingestion and model execution, and a calibration/monitoring service that updates model parameters and generates control set‑points."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity relies on four assumptions (uniform temperature, negligible wall heat storage, constant air specific heat, all electrical power converted to heat) and is validated by uniformity experiments and calibration against measured temperature trajectories; residual errors are minimised using a gradient‑descent based least‑squares optimizer."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical‑to‑virtual and virtual‑to‑physical communication is implemented via RabbitMQ, a lightweight message broker using standard TCP/IP networking; messages carry sensor readings, actuator commands, and status flags."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT services (RabbitMQ server, low‑level driver, calibration scripts) are hosted on the same Raspberry Pi 4 that controls the incubator; all source code and hardware designs are hosted in a public GitHub repository."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol to keep the hardware in a safe state; monitoring monitors temperature limits to prevent unsafe overheating, though no explicit cybersecurity measures are described."
]