// Acting Components
instance HeatbedHeaterActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed heater element driven via a MOSFET switch on the Raspberry Pi GPIO through an optocoupler"
]

instance FanMotorActuator : DTDFVocab:ActingComponent [
    base:desc "Fan motor driven via a MOSFET and optocoupler controlled by Raspberry Pi GPIO"
]

instance PiGPIOActuator : DTDFVocab:ActingComponent [
    base:desc "GPIO outputs switched via MOSFETs and optocouplers to drive heatbed and fan actuation"
]

// Sensing Components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire digital thermometer inside the styrofoam box measuring internal temperature"
    DTDFVocab:producedData InternalTempDataTransmitted1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire digital thermometer inside the styrofoam box measuring internal temperature"
    DTDFVocab:producedData InternalTempDataTransmitted2
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor outside the styrofoam box for room temperature measurement"
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// Data Transmitted
instance InternalTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// Data
instance InternalTempData1 : DTDFVocab:Data [
    base:desc "Internal temperature measurement in degrees Celsius (sensor 1)"
    DTDFVocab:inputTo PythonRuntimeEnabler
    DTDFVocab:fromData InternalTempDataTransmitted1
]

instance InternalTempData2 : DTDFVocab:Data [
    base:desc "Internal temperature measurement in degrees Celsius (sensor 2)"
    DTDFVocab:inputTo PythonRuntimeEnabler
    DTDFVocab:fromData InternalTempDataTransmitted2
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Room temperature measurement in degrees Celsius"
    DTDFVocab:inputTo PythonRuntimeEnabler
    DTDFVocab:fromData ExternalTempDataTransmitted
]

// Enabler
instance PythonRuntimeEnabler : DTDFVocab:Enabler [
    base:desc "Python runtime environment (running on Raspberry Pi) for data processing, modeling, and optimization"
    DTDFVocab:enables TemperatureDynamicsSimulationService, ParameterOptimizationService, TemperatureMonitoringService
]

// Services
instance TemperatureDynamicsSimulationService : DTDFVocab:Service [
    base:desc "Simulates temperature dynamics using ModelA and ModelB with N-LSE calibration"
    DTDFVocab:provides ModelParameterUpdateInsight, ResidualAnalysisInsight
]

instance ParameterOptimizationService : DTDFVocab:Service [
    base:desc "Performs parameter optimization via least-squares residual minimization on experimental temperature data"
    DTDFVocab:provides ParameterOptimizationInsight
]

instance TemperatureMonitoringService : DTDFVocab:Service [
    base:desc "Monitors real-time temperature and power consumption of the incubator"
    DTDFVocab:provides TemperatureMonitoringInsight
]

// Models
instance ModelA : DTDFVocab:Model [
    base:desc "Temperature evolution model (ModelA) with parameters C_air and G_box"
    DTDFVocab:inputTo PythonRuntimeEnabler
]

instance ModelB : DTDFVocab:Model [
    base:desc "Temperature evolution model (ModelB) with parameters C_air, C_heater, G_box, G_heater"
    DTDFVocab:inputTo PythonRuntimeEnabler
]

// Insights
instance ModelParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Calibration results updating model parameters (C_air, G_box, etc.) for accurate predictions"
]

instance ResidualAnalysisInsight : DTDFVocab:Insight [
    base:desc "Detection of model fit residuals informs potential adjustments in control strategy"
]

instance ParameterOptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized parameters derived from least squares residual minimization improve model accuracy"
]

instance TemperatureMonitoringInsight : DTDFVocab:Insight [
    base:desc "Real-time temperature and power consumption monitoring feedback for operators"
]

// Actions
instance AdjustControlStrategyAction : DTDFVocab:Action [
    base:desc "Automatically adjusts control strategy based on residual analysis"
    DTDFVocab:IsAutomatic true
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedHeaterActuator, FanMotorActuator, PiGPIOActuator, InternalTempSensor1, InternalTempSensor2, ExternalTempSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The digital twin publishes control commands via RabbitMQ to the Raspberry Pi; the controller receives these commands to activate/deactivate the heatbed and fan, and to read sensor data back to the twin"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "An orchestrated set of components: low‑level driver (hardware abstraction), controller (bang‑bang logic with H/U/C/C parameters), simulation engine (Model A/B), RabbitMQ server (message broker), and PLC firmware hosted on Raspberry Pi"
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Validation through comparison of simulation with experimental temperature trajectories; non‑linear least squares to minimise residual error; assumptions on uniform temperature, insulated walls, constant specific heat, negligible heatbed losses; model fidelity assessed by residual error minimisation and parameter convergence"
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical twin communicates with the digital twin via a local RabbitMQ AMQP message broker running on the Raspberry Pi. Sensor data and finite‑state machine messages are transmitted over the Pi’s GPIO and 1‑Wire bus, while command messages travel over the AMQP exchange. Both components reside on the same Pi, with the RabbitMQ broker handling all message passing between low‑level driver, controller, and the digital twin simulation."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted locally on the Raspberry Pi 4 Model B; RabbitMQ server runs on same device; low‑level driver and controller firmware run on Pi; simulation and calibration scripts executed on the Pi or a remote computer linked via network"
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver implements a safe protocol to ensure the PT remains in a safe state. While the system uses open‑source software and standard protocols (RabbitMQ, AMQP, 1‑Wire), explicit cybersecurity measures are not described. The design focuses on safe operation of the physical hardware to avoid accidents, especially in the absence of human presence."
]