// C3: Physical sensing components
instance InsideTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer placed inside the insulated incubator enclosure accuracy ±0.5 °C."
    DTDFVocab:producedData InsideTempDataTransmitted1
]

instance InsideTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 high‑precision 1‑Wire digital thermometer placed inside the insulated incubator enclosure accuracy ±0.5 °C."
    DTDFVocab:producedData InsideTempDataTransmitted2
]

instance OutsideTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer placed outside the incubator enclosure accuracy ±0.5 °C."
    DTDFVocab:producedData OutsideTempDataTransmitted
]

// C4: Physical‑to‑virtual interaction – DataTransmitted
instance InsideTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor1
]

instance InsideTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor2
]

instance OutsideTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideTemperatureSensor
]

// C10: Data
instance InsideTempData1 : DTDFVocab:Data [
    base:desc "Scalar temperature reading (°C) from InsideTemperatureSensor1."
    DTDFVocab:fromData InsideTempDataTransmitted1
    DTDFVocab:inputTo RabbitMQBroker
]

instance InsideTempData2 : DTDFVocab:Data [
    base:desc "Scalar temperature reading (°C) from InsideTemperatureSensor2."
    DTDFVocab:fromData InsideTempDataTransmitted2
    DTDFVocab:inputTo RabbitMQBroker
]

instance OutsideTempData : DTDFVocab:Data [
    base:desc "Scalar temperature reading (°C) from OutsideTemperatureSensor."
    DTDFVocab:fromData OutsideTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

// C10: Models
instance ThermalModelTwoParameter : DTDFVocab:Model [
    base:desc "Analytical behavioral thermal model of the incubator with two free parameters predicts internal temperature."
    DTDFVocab:inputTo ThermalModelEnabler
]

instance ThermalModelFourParameter : DTDFVocab:Model [
    base:desc "Analytical behavioral thermal model of the incubator with four free parameters capturing heat‑bed thermal inertia."
    DTDFVocab:inputTo ThermalModelEnabler
]

// C11: Enablers (generic components to avoid disjointness conflict)
instance RabbitMQBroker : DTDFVocab:Component [
    base:desc "RabbitMQ server running on the Raspberry Pi transports sensor data to the cyber side and makes it available to DT algorithms."
    DTDFVocab:enables CalibrationService,
                     MonitoringService,
                     OptimisationService,
                     SafetyCheckingService,
                     VisualizationService
]

instance ThermalModelEnabler : DTDFVocab:Component [
    base:desc "Cyber‑layer engine that hosts calibrated thermal models and provides simulation capabilities."
    DTDFVocab:enables CalibrationService,
                     SimulationService
]

// C6: Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration algorithm that updates free parameters of the thermal models using the latest temperature data."
    DTDFVocab:provides ModelParameterUpdateInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of temperature streams to detect deviations from desired set‑points."
    DTDFVocab:provides TemperatureDeviationInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation/prediction service that reproduces and forecasts the incubator’s thermal behaviour under current conditions."
    DTDFVocab:provides ForecastInsight
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Optimisation service that suggests heat‑bed and fan set‑points to keep temperature within safe, optimal bounds."
    DTDFVocab:provides SetpointSuggestionAction
]

instance SafetyCheckingService : DTDFVocab:Service [
    base:desc "Safety‑checking monitor that raises alerts when temperature violations are detected, allowing operator intervention."
    DTDFVocab:provides SafetyAlertAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualization service that renders temperature trends for operator awareness."
    DTDFVocab:provides TemperatureTrendVisualizationInsight
]

// C17: Insights / Actions
instance ModelParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that thermal model parameters have been updated after calibration."
]

instance TemperatureDeviationInsight : DTDFVocab:Insight [
    base:desc "Insight that a temperature reading deviates from the desired range, triggering monitoring response."
]

instance ForecastInsight : DTDFVocab:Insight [
    base:desc "Insight delivering forecasted temperature trajectory based on the calibrated model."
]

instance SetpointSuggestionAction : DTDFVocab:Action [
    base:desc "Action recommending new heat‑bed and fan set‑points to maintain target temperature."
    DTDFVocab:IsAutomatic true
]

instance SafetyAlertAction : DTDFVocab:Action [
    base:desc "Action generating an alert for human operators when a safety violation occurs."
    DTDFVocab:IsAutomatic false
]

instance TemperatureTrendVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight visualising recent temperature trends for operator monitoring."
]

// C2: Acting components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heating element (heat‑bed) actuated by the incubator controller provides heating power to raise internal temperature."
]

// Additional component: Raspberry Pi controller
instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Embedded Raspberry Pi that reads 1‑Wire temperature sensors, forwards data via RabbitMQ, and receives set‑point commands for the heat‑bed and fan."
]

// Environment grouping
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedActuator,
                 InsideTemperatureSensor1,
                 InsideTemperatureSensor2,
                 OutsideTemperatureSensor,
                 RaspberryPiController,
                 ThermalModelTwoParameter,
                 ThermalModelFourParameter,
                 RabbitMQBroker,
                 ThermalModelEnabler
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is orchestrated as a layered framework that integrates three core artefacts: (1) **Data** obtained continuously from the Physical Twin (PT) via its sensors; (2) **Models** that represent the cyber‑physical behavior of the PT and its environment; and (3) **Algorithms** that consume the data and models to generate knowledge (e.g., fault detectors, state estimators, optimisers). Calibration algorithms are employed to periodically update the parameters of the CPS and environment models using the latest sensor data, thereby keeping the virtual representation aligned with the PT. The calibrated models feed monitoring components that assess safety and optimality criteria in real time. When a monitor signals a violation, a decision layer—implemented by either human operators or autonomous algorithms—triggers corrective actions on the PT. This orchestration follows the schematic depicted in Figure 1 of Document 1, emphasizing tight coupling between sensing, model updating, monitoring, and control loops."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by comparing the two thermal models against experimental temperature data. Validation experiments showed that the four‑parameter model more accurately reproduces the thermal inertia of the heat‑bed, thereby offering higher fidelity and being selected for further digital‑twin development. Uncertainty is reduced through calibration algorithms that estimate the best‑fit parameters, and model performance is monitored by the DT’s supervisory algorithms that detect deviations between predicted and measured temperatures."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The communication infrastructure consists of a single Raspberry Pi that hosts both the controller and a RabbitMQ server. Sensor data travel from the 1‑Wire bus to the low‑level driver, and all inter‑component messages (sensor updates and control commands) are exchanged via the RabbitMQ server. No additional network topology, bandwidth, latency, redundancy, or security protocols are specified in the documents."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin’s runtime environment is hosted directly on the edge device—the Raspberry Pi that also controls the incubator. The RabbitMQ server and the calibration/monitoring algorithms execute on this platform, implying modest compute and storage needs fitting the Pi’s resources. Scalability is limited to the single‑node deployment; no cloud or multi‑node scaling mechanisms are described. Availability relies on the Raspberry Pi remaining powered; no explicit high‑availability or fault‑tolerance strategies are provided."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The DT architecture described in Document 1 integrates safety monitoring by employing calibration algorithms that update models of the cyber‑physical system and its environment, and then feeds the resulting data to monitors that continuously evaluate whether the system is operating safely and optimally. Violations detected by these monitors can trigger human operators or automated algorithms to initiate corrective actions on the physical twin. While the documents do not detail specific cybersecurity protocols, access‑control, or authentication mechanisms, the safety‑oriented components include the use of runtime monitors and fault‑detectors as part of the algorithmic layer that support risk mitigation and fail‑safe responses."
]