// C3: Physical sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring air temperature inside the incubator box (sensor T2)."
    DTDFVocab:producedData TemperatureMessage
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring air temperature inside the incubator box (sensor T3)."
    DTDFVocab:producedData TemperatureMessage
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "Temperature sensor measuring ambient temperature outside the incubator box."
    DTDFVocab:producedData TemperatureMessage
]

// C4: Physical-to-virtual interaction
instance TemperatureMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1, InternalTempSensor2, ExternalTempSensor
]

// C5: Data
instance TemperatureTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series of temperature readings (°C) with timestamps persisted in a database for visualization, calibration and monitoring."
    DTDFVocab:fromData TemperatureMessage
    DTDFVocab:inputTo CalibrationAlgorithm, KalmanFilterEngine, AnomalyDetectionAlgorithm, VisualizationEngine, CoSimulationEngine, SelfAdaptationLoop
]

// C10: Models/Data
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Analytical thermal model (Model A) derived from Q = c·m·ΔT, assumes all electrical power transferred to air, uses two free parameters."
    DTDFVocab:inputTo CalibrationAlgorithm, CoSimulationEngine
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Enhanced analytical thermal model (Model B) that relaxes power transfer assumption, includes heat‑bed inertia, uses four free parameters."
    DTDFVocab:inputTo CalibrationAlgorithm, KalmanFilterEngine, CoSimulationEngine
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "AMQP over TCP/IP message broker that transports sensor messages and control commands between PT and DT components."
    DTDFVocab:enables RealTimeVisualizationService, ModelCalibrationService, StateEstimationService, AnomalyDetectionService, WhatIfSimulationService, SelfAdaptationService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "On‑demand calibration algorithm that ingests temperature data to estimate and update parameters of Model A and Model B in real time."
    DTDFVocab:enables ModelCalibrationService
]

instance KalmanFilterEngine : DTDFVocab:Enabler [
    base:desc "Kalman filter that combines calibrated Model B with live temperature data to estimate heat‑bed state and detect anomalies."
    DTDFVocab:enables StateEstimationService
]

instance AnomalyDetectionAlgorithm : DTDFVocab:Enabler [
    base:desc "Algorithm that analyses residuals from the Kalman filter to detect abnormal temperature behaviour."
    DTDFVocab:enables AnomalyDetectionService
]

instance VisualizationEngine : DTDFVocab:Enabler [
    base:desc "Visualization component that reads temperature time‑series from the database and streams real‑time plots to a dashboard."
    DTDFVocab:enables RealTimeVisualizationService
]

instance CoSimulationEngine : DTDFVocab:Enabler [
    base:desc "Co‑simulation infrastructure that runs what‑if scenarios by coupling live PT data with calibrated models for optimisation studies."
    DTDFVocab:enables WhatIfSimulationService
]

instance SelfAdaptationLoop : DTDFVocab:Enabler [
    base:desc "Self‑adaptation loop that detects behavioural changes, schedules experiments, re‑calibrates models, re‑configures the Kalman filter and bang‑bang controller."
    DTDFVocab:enables SelfAdaptationService
]

// C6: Services
instance RealTimeVisualizationService : DTDFVocab:Service [
    base:desc "Provides real‑time visualisation of incubator temperature on a dashboard."
    DTDFVocab:provides TemperatureInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Executes on‑demand calibration of Model A and Model B using incoming sensor data."
    DTDFVocab:provides CalibrationInsight
]

instance StateEstimationService : DTDFVocab:Service [
    base:desc "Delivers estimated heat‑bed temperature state using Kalman filtering."
    DTDFVocab:provides StateEstimationInsight
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Detects temperature anomalies and issues alerts."
    DTDFVocab:provides AnomalyInsight, AnomalyAlert
]

instance WhatIfSimulationService : DTDFVocab:Service [
    base:desc "Runs what‑if simulations to evaluate alternative controller parameter settings."
    DTDFVocab:provides SimulationInsight, ParameterRecommendation
]

instance SelfAdaptationService : DTDFVocab:Service [
    base:desc "Manages the closed‑loop self‑adaptation process, updating models, filters and controller parameters automatically."
    DTDFVocab:provides AdaptationAction
]

// C17: Insights/Actions
instance TemperatureInsight : DTDFVocab:Insight [
    base:desc "Real‑time visual insight of temperature trends displayed on the dashboard."
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating updated model parameters after calibration."
]

instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated internal temperature of the heat‑bed derived from Kalman filtering."
]

instance AnomalyInsight : DTDFVocab:Insight [
    base:desc "Detected deviation from expected temperature behavior."
]

instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Result of what‑if simulation showing expected temperature response for proposed controller settings."
]

instance AnomalyAlert : DTDFVocab:Action [
    base:desc "Automatic alert sent to operators when a temperature anomaly is detected."
    DTDFVocab:IsAutomatic true
]

instance ParameterRecommendation : DTDFVocab:Action [
    base:desc "Suggested adjustment of bang‑bang controller parameters (LL, UL, H, C) based on simulation outcomes."
    DTDFVocab:IsAutomatic true
]

instance AdaptationAction : DTDFVocab:Action [
    base:desc "Automated re‑calibration of models and re‑configuration of the Kalman filter and controller."
    DTDFVocab:IsAutomatic true
]

// C2: Acting components (optional)
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heating element (heat‑bed) that provides thermal energy to raise incubator temperature."
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan that circulates air inside the incubator to distribute heat uniformly."
]

instance BangBangController : DTDFVocab:Component [
    base:desc "Bang‑bang controller running on a Raspberry Pi with configurable parameters LL, UL, H, C."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The controller (running on a Raspberry Pi) receives control commands from the RabbitMQ server that specify actions for the fan and the heat‑bed (e.g., turn on, turn off, heating duration, waiting duration). The controller forwards these commands to the low‑level driver, which executes the actuator states on the physical twin. A safe‑protocol is incorporated in the low‑level driver to keep the device in a safe state before applying commands. The controller also publishes its own control‑state messages back to RabbitMQ, providing feedback that can be consumed by the digital twin. Message formats and authentication details are not described in the documents."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin is organised around a message‑oriented middleware pattern using a central RabbitMQ server. The physical twin’s low‑level driver reads temperature data periodically and publishes it to RabbitMQ; the controller subscribes to these messages, receives commands from RabbitMQ, and publishes its control states. DT components (e.g., calibration, monitoring, simulation modules) also subscribe to the same message streams, enabling decoupled interaction between cyber and physical elements and supporting the calibration, anomaly detection, what‑if simulation, and self‑adaptation loops described in the case study."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is addressed by developing two models with differing abstraction levels; experimental results (Fig. 13) show that Model B, which accounts for heat‑bed inertia, yields higher accuracy in predicting system magnitude and time scale, thus being the preferred model for the DT. Validation is performed through calibration experiments where sensor data are used to estimate model parameters, and through anomaly detection via a Kalman filter that compares measured temperatures with model‑predicted heat‑bed temperature, exposing discrepancies. Uncertainty sources stem from the modelling assumptions (uniform temperature distribution, negligible wall heat storage, constant specific heat capacity, and power‑to‑heat conversion). Calibration, on‑demand recalibration, and continuous monitoring constitute the quality‑assurance process, while the safe‑protocol in the low‑level driver mitigates risks from erroneous actuation."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The communication backbone of the incubator digital twin is a RabbitMQ message broker. Components (sensors, low‑level driver, controller, DT services) connect to the broker using the AMQP protocol over TCP/IP. The network topology follows a publish/subscribe pattern: PT sensors → low‑level driver → RabbitMQ → controller and DT subscribers. RabbitMQ is described as a mature, lightweight, and easy‑to‑deploy server that can run on‑premise or in the cloud, providing reliability through its built‑in message queuing and delivery guarantees. Specific bandwidth, latency or redundancy mechanisms are not quantified in the source material."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "Integration with external systems is achieved through the RabbitMQ message broker. The low‑level driver, controller, and DT services communicate by publishing and subscribing to messages on RabbitMQ, allowing other applications or enterprise systems that can connect to the broker to exchange sensor data, control commands, and status information."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The low‑level driver incorporates a safe protocol that keeps the physical twin in a safe state; communication between the controller, low‑level driver and other components is performed through a RabbitMQ message broker, which synchronises messages but the documents do not detail authentication, encryption, or access‑control mechanisms. Safety functions are supported by a Kalman‑filter based anomaly detection and heat‑bed state estimation that run on the digital twin to monitor deviations from expected behaviour. No explicit cybersecurity protocols, threat‑mitigation strategies, or formal risk‑assessment procedures are described in the provided documents."
]