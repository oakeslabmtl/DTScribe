// Acting Components
instance HeatbedHeaterActuator : DTDFVocab:ActingComponent [
    base:desc "Heatbed heater actuated by RaspberryPi through MOSFET driver and optocoupler"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "Fan actuated by RaspberryPi through MOSFET driver and optocoupler"
]

// Sensing Components
instance DS18S20_T1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital temperature sensor at T1 inside the box, 0.5°C accuracy from –10°C to +85°C"
    DTDFVocab:producedData T1DataTransmitted
]

instance DS18S20_T2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital temperature sensor at T2 inside the box, 0.5°C accuracy from –10°C to +85°C"
    DTDFVocab:producedData T2DataTransmitted
]

instance DS18S20_External : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital temperature sensor outside the box for ambient temperature, 0.5°C accuracy from –10°C to +85°C"
    DTDFVocab:producedData ExternalDataTransmitted
]

// Data Transmitted
instance T1DataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "JSON packet of T1 sensor value published by RaspberryPi via RabbitMQ"
    DTDFVocab:producedFrom DS18S20_T1
]

instance T2DataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "JSON packet of T2 sensor value published by RaspberryPi via RabbitMQ"
    DTDFVocab:producedFrom DS18S20_T2
]

instance ExternalDataTransmitted : DTDFVocab:DataTransmitted [
    base:desc "JSON packet of external ambient sensor value published by RaspberryPi via RabbitMQ"
    DTDFVocab:producedFrom DS18S20_External
]

// Data
instance T1TemperatureData : DTDFVocab:Data [
    base:desc "Temperature data from DS18S20 sensor T1 inside the box"
    DTDFVocab:fromData T1DataTransmitted
    DTDFVocab:inputTo DataLoggerEnabler, ControlEnabler, SimulationEnabler, CalibrationEnabler, FaultDetectionEnabler
]

instance T2TemperatureData : DTDFVocab:Data [
    base:desc "Temperature data from DS18S20 sensor T2 inside the box"
    DTDFVocab:fromData T2DataTransmitted
    DTDFVocab:inputTo DataLoggerEnabler, ControlEnabler, SimulationEnabler, CalibrationEnabler, FaultDetectionEnabler
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Temperature data from external DS18S20 sensor"
    DTDFVocab:fromData ExternalDataTransmitted
    DTDFVocab:inputTo DataLoggerEnabler, ControlEnabler, SimulationEnabler, CalibrationEnabler, FaultDetectionEnabler
]

// Enablers
instance DataLoggerEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that receives sensor data via RabbitMQ and forwards it to DataLoggingService"
    DTDFVocab:enables DataLoggingService
]

instance ControlEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that consumes sensor data and forwards it to BangBangControlService for control decisions"
    DTDFVocab:enables BangBangControlService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that streams sensor data to RealTimeTemperatureSimulationService"
    DTDFVocab:enables RealTimeTemperatureSimulationService
]

instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that aggregates calibration logs and forwards them to OnlineCalibrationService"
    DTDFVocab:enables OnlineCalibrationService
]

instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler that feeds sensor data to FaultDetectionService for anomaly identification"
    DTDFVocab:enables FaultDetectionService
]

// Services
instance DataLoggingService : DTDFVocab:Service [
    base:desc "Logs sensor telemetry and actuator states to persistent storage and publishes to visualization dashboards"
    DTDFVocab:provides DataLoggingInsight, VisualizationInsight
]

instance BangBangControlService : DTDFVocab:Service [
    base:desc "Implements bang‑bang control logic for heatbed heater and fan based on temperature readings"
    DTDFVocab:provides ControlAdjustmentSuggestionInsight, AdjustHeatingDurationAction
]

instance RealTimeTemperatureSimulationService : DTDFVocab:Service [
    base:desc "Runs real‑time temperature simulation using calibrated dynamic models (ModelA and ModelB)"
    DTDFVocab:provides PredictiveTemperatureProfileInsight
]

instance OnlineCalibrationService : DTDFVocab:Service [
    base:desc "Performs online calibration of model parameters via nonlinear least‑squares using SciPy"
    DTDFVocab:provides CalibrationUpdatedInsight, UpdateModelParametersAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects potential faults such as overheating the heatbed or fan failure"
    DTDFVocab:provides FaultDetectionInsight, DiagnoseFaultAction
]

// Insights
instance PredictiveTemperatureProfileInsight : DTDFVocab:Insight [
    base:desc "Predictive temperature trajectory within the incubator using calibrated dynamic models"
]

instance CalibrationUpdatedInsight : DTDFVocab:Insight [
    base:desc "Notification that model parameters have been updated after online calibration"
]

instance ControlAdjustmentSuggestionInsight : DTDFVocab:Insight [
    base:desc "Suggestion to adjust heating duration based on predictive modeling"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of potential faults such as overheating the heatbed or fan failure"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of sensor data, actuator states, and model predictions on operator dashboard"
]

instance DataLoggingInsight : DTDFVocab:Insight [
    base:desc "Insight that logs sensor telemetry and actuator states to persistent storage"
]

// Actions
instance AdjustHeatingDurationAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of heatbed ON/OFF timing determined by bang‑bang control logic"
    DTDFVocab:IsAutomatic true
]

instance UpdateModelParametersAction : DTDFVocab:Action [
    base:desc "Update model (ModelA or ModelB) with new parameters from nonlinear least‑squares calibration"
    DTDFVocab:IsAutomatic true
]

instance DiagnoseFaultAction : DTDFVocab:Action [
    base:desc "Investigate detected fault and suggest maintenance steps"
    DTDFVocab:IsAutomatic false
]

// Models
instance ModelA_RealTime : DTDFVocab:Model [
    base:desc "Dynamic heat balance equation for air inside the box: dT_air/dt = (V*I*Δt – G_box*(T_air – T_room)) / C_air"
    DTDFVocab:inputTo SimulationEnabler
]

instance ModelB_RealTime : DTDFVocab:Model [
    base:desc "Model including heatbed dynamics with parameters C_heater, G_heater, G_box in the heat balance equation"
    DTDFVocab:inputTo SimulationEnabler
]

// Environment
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedHeaterActuator, FanActuator, DS18S20_T1, DS18S20_T2, DS18S20_External, RaspberryPi4Device, RabbitMQBroker, PythonScipyRuntime, GitHubRepo
]

// Components
instance RaspberryPi4Device : DTDFVocab:Component [
    base:desc "RaspberryPi 4 Model B board that controls sensors, actuators, and publishes data via RabbitMQ"
]

instance RabbitMQBroker : DTDFVocab:Component [
    base:desc "RabbitMQ message broker used for JSON telemetry between PT and DT"
]

instance PythonScipyRuntime : DTDFVocab:Component [
    base:desc "Python runtime with SciPy optimizer for nonlinear least‑squares model calibration"
]

instance GitHubRepo : DTDFVocab:Component [
    base:desc "GitHub repository hosting open‑source controller and calibration code"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "DT (controller) publishes command messages (heatbed ON/OFF, fan ON/OFF, heating duration, waiting duration) to RabbitMQ; low‑level driver consumes these messages, validates inputs through a safe protocol, and drives the MOSFET/optocoupler switches to actuate the heatbed and fan."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Centralized architecture: Raspberry Pi hosts controller, low‑level driver, RabbitMQ broker, and DT simulation models; PT hardware connects via 1‑Wire and control lines; all components orchestrated through message queues on the Pi."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design → Deployed (operational) → Calibration and Validation; the twin is constructed based on the physical twin while it is in operation, with continuous monitoring and model updating."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Uniformity experiments showed maximum temperature discrepancy ≤ 7 °C; calibration reduced residual error to near‑zero; model assumptions (no heat transfer to walls, constant specific heat) were validated; uncertainty propagated via parameter estimation; validation against independent experimental runs."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "PT ↔ DT communication via RabbitMQ broker over TCP/IP on local network; 1‑Wire bus for sensors; isolated MOSFET switches controlled via optocouplers; all running on single Raspberry Pi board."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "Hosted locally on a Raspberry Pi 4 Model B; open‑source software distributed through GitHub; deployment includes Docker or direct Python scripts; operates on the Pi’s Wi‑Fi or Ethernet, with optional MQTT/HTTP endpoints."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Low‑level driver implements safe protocol to prevent unsafe actuator states; optocoupler/MOSFET isolation protects Pi; RabbitMQ supports TLS/username‑password authentication though not explicitly configured; overall system designed to avoid human harm by limiting actuator commands to safe ranges."
]