// Components of the Physical Twin
instance RigidBodyChassis : DTDFVocab:Component [
    base:desc "Rigid–body chassis that provides structural support for the vehicle and defines the geometric framework for CAD-based modeling."
]

instance WheelAssembly : DTDFVocab:Component [
    base:desc "Wheel assemblies incorporating wheel bearings, hubs, and tires, defining the vehicle’s interaction with the road surface."
]

instance InternalCombustionEngine : DTDFVocab:Component [
    base:desc "Internal combustion engine that converts fuel into mechanical energy, driving the vehicle."
]

instance TransmissionSystem : DTDFVocab:Component [
    base:desc "Transmission system that transfers the engine’s power to the wheel assemblies via gears or a continuously variable system."
]

instance BodyModule : DTDFVocab:Component [
    base:desc "Body modules that form the outer shell of the vehicle, including doors, panels, and aesthetic styling elements."
]

// Physical Sensing Component
instance VehicleMeasurementSensor : DTDFVocab:SensingComponent [
    base:desc "Aggregated sensor that collects a continuous stream of time–stamped measurements from the vehicle’s embedded sensors."
    DTDFVocab:producedData VehicleMeasurementTransmitted
]

// Data Transmitted from the Sensor
instance VehicleMeasurementTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleMeasurementSensor
]

// Data derived from the Transmitted Information
instance VehicleMeasurementData : DTDFVocab:Data [
    base:desc "Time–stamped measurement data collected from the Physical Twin, including parameters such as wheel speed, engine temperature, and vehicle acceleration."
    DTDFVocab:inputTo CalibrationTool, DataProcessingTool, SimulationTool, OptimizationTool, ControlTool, VisualizationTool
    DTDFVocab:fromData VehicleMeasurementTransmitted
]

// Enablers
instance CalibrationTool : DTDFVocab:Enabler [
    base:desc "Calibration algorithms that update model parameters to best match runtime sensor observations."
    DTDFVocab:enables CalibrationService
]

instance DataProcessingTool : DTDFVocab:Enabler [
    base:desc "Tools for monitoring, fault detection, supervisory control, state estimation, and optimisation that process incoming data streams."
    DTDFVocab:enables RealTimeMonitoringService
]

instance SimulationTool : DTDFVocab:Enabler [
    base:desc "Differential equation solver that runs forward–time simulations of the vehicle dynamics."
    DTDFVocab:enables PredictionSimulationService
]

instance OptimizationTool : DTDFVocab:Enabler [
    base:desc "Supervisory algorithms that adjust the control inputs or suggest maintenance actions to keep the vehicle at optimal performance."
    DTDFVocab:enables OptimizationService
]

instance ControlTool : DTDFVocab:Enabler [
    base:desc "Control software that can generate command recommendations or automated actuator directives based on model predictions."
    DTDFVocab:enables ControlService
]

instance VisualizationTool : DTDFVocab:Enabler [
    base:desc "Visualization engine that renders CAD‑based geometry and simulation outputs for user interaction."
    DTDFVocab:enables VisualizationService
]

// Digital Twin Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Real–time monitoring service that continuously evaluates safety and performance metrics against calibrated model parameters."
    DTDFVocab:provides SafetyPerformanceInsight, FaultDetectionInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibration service that adjusts model parameters to align with the latest sensor data, ensuring model fidelity."
    DTDFVocab:provides CalibrationAdjustmentAction
]

instance PredictionSimulationService : DTDFVocab:Service [
    base:desc "Prediction service that runs forward–time simulations to forecast vehicle dynamics under current operating conditions."
    DTDFVocab:provides VehicleTrajectoryInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimization service that recommends maintenance actions or tuning adjustments to maintain optimal efficiency."
    DTDFVocab:provides MaintenanceRecommendationAction
]

instance ControlService : DTDFVocab:Service [
    base:desc "Control service that derives actuator commands or steering inputs based on simulation outputs."
    DTDFVocab:provides SteeringControlAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualization service that displays updated CAD geometry and simulation results to engineers and operators."
    DTDFVocab:provides CADVisualizationInsight
]

// Insights
instance SafetyPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight indicating that vehicle safety and performance metrics are within calibrated bounds."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Insight detecting anomalies in sensor data that may indicate potential faults in the vehicle systems."
]

instance VehicleTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Insight projecting the vehicle’s future position and motion trajectory based on current dynamics."
]

instance CADVisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing a visual representation of the vehicle’s geometry and simulated dynamics within a CAD environment."
]

// Actions
instance CalibrationAdjustmentAction : DTDFVocab:Action [
    base:desc "Automatic action that updates the vehicle dynamics model parameters using the latest calibration data."
    DTDFVocab:IsAutomatic true
]

instance MaintenanceRecommendationAction : DTDFVocab:Action [
    base:desc "Automatic action that recommends maintenance tasks based on optimized trajectories and performance analysis."
    DTDFVocab:IsAutomatic true
]

instance SteeringControlAction : DTDFVocab:Action [
    base:desc "Automatic action that issues steering actuator commands derived from predictive simulation feedback."
    DTDFVocab:IsAutomatic true
]