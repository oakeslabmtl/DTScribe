// C3: Physical sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted inside incubator, measuring -55 °C to +125 °C with ±0.5 °C accuracy."
    DTDFVocab:producedData InternalTempDataTransmitted1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted inside incubator, measuring -55 °C to +125 °C with ±0.5 °C accuracy."
    DTDFVocab:producedData InternalTempDataTransmitted2
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted outside incubator, measuring -55 °C to +125 °C with ±0.5 °C accuracy."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Physical-to-virtual interaction (DataTransmitted)
instance InternalTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// C10: Data
instance InternalTemperatureData1 : DTDFVocab:Data [
    base:desc "Timestamped internal temperature reading (°C) from InternalTempSensor1."
    DTDFVocab:fromData InternalTempDataTransmitted1
    DTDFVocab:inputTo RabbitMQBroker
]

instance InternalTemperatureData2 : DTDFVocab:Data [
    base:desc "Timestamped internal temperature reading (°C) from InternalTempSensor2."
    DTDFVocab:fromData InternalTempDataTransmitted2
    DTDFVocab:inputTo RabbitMQBroker
]

instance ExternalTemperatureData : DTDFVocab:Data [
    base:desc "Timestamped external temperature reading (°C) from ExternalTempSensor."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo RabbitMQBroker
]

// C11: Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker on Raspberry Pi mediates data exchange between physical and cyber components."
    DTDFVocab:enables MonitoringService, PredictionService, OptimizationService, SafetyCheckService, VisualizationService
]

instance SciPyCalibrationEngine : DTDFVocab:Enabler [
    base:desc "SciPy optimization library used for model parameter calibration."
    DTDFVocab:enables OptimizationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine executing analytical thermal models for temperature prediction."
    DTDFVocab:enables PredictionService
]

// C6: Services
instance MonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of sensor data and temperature state."
    DTDFVocab:provides TemperatureStateInsight
]

instance PredictionService : DTDFVocab:Service [
    base:desc "Runs simulation‑based prediction of incubator thermal behaviour."
    DTDFVocab:provides TemperatureForecastInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimises control parameters by calibrating model parameters with sensor data."
    DTDFVocab:provides ModelCalibrationInsight, ParameterAdjustmentAction
]

instance SafetyCheckService : DTDFVocab:Service [
    base:desc "Detects temperature limit violations and triggers safety actions."
    DTDFVocab:provides FaultDetectionInsight, CorrectiveControlAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Advanced visualisation of temperature state and forecasts."
    DTDFVocab:provides TemperatureVisualizationInsight
]

// C17: Insights
instance TemperatureStateInsight : DTDFVocab:Insight [
    base:desc "Current temperature state derived from sensor streams."
]

instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted temperature trajectory based on calibrated thermal models."
]

instance ModelCalibrationInsight : DTDFVocab:Insight [
    base:desc "Calibration results indicating updated model parameters and confidence."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature limit violations or anomalies."
]

instance TemperatureVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization artifacts (charts, dashboards) of temperature data and forecasts."
]

// C17: Actions
instance ParameterAdjustmentAction : DTDFVocab:Action [
    base:desc "Adjusts controller set‑points based on calibrated model parameters."
    DTDFVocab:IsAutomatic false
]

instance CorrectiveControlAction : DTDFVocab:Action [
    base:desc "Automatically modifies heat‑bed power to bring temperature back within safe range."
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Heat‑bed provides thermal actuation for incubator; receives commands from digital twin via software interface."
]

// C10: Models
instance TwoParamThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model with two free parameters predicting internal temperature."
    DTDFVocab:inputTo SimulationEngine, SciPyCalibrationEngine
]

instance FourParamThermalModel : DTDFVocab:Model [
    base:desc "Analytical thermal model with four free parameters offering higher fidelity."
    DTDFVocab:inputTo SimulationEngine, SciPyCalibrationEngine
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control actions originate in the DT when monitoring or optimisation algorithms detect a deviation from desired operating conditions. The description states that humans or automated algorithms may decide to make changes to the Physical Twin, implying that the DT can issue commands to actuators (e.g., fan, heatbed) to adjust temperature. No details are provided about command types, message formats, validation, authentication, feedback loops, conflict resolution, or acknowledgment mechanisms."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin adopts a centralized CPS‑based architecture (as described in Document 1). Sensor data from the Physical Twin are continuously collected and fed to calibration algorithms that update the cyber‑physical models of the plant and its environment. The refreshed models supply monitoring algorithms that assess safety and optimal performance. When a monitor detects a violation, a decision component—either a human operator or an automated controller—can issue corrective actions back to the Physical Twin. This orchestration links data acquisition, model calibration, monitoring and control in a closed‑loop integration."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by experimental comparison of the two temperature prediction models; the four‑parameter model demonstrated superior prediction of the heat‑bed’s thermal inertia, indicating higher behavioural fidelity. Calibration algorithms continuously update model parameters using observed sensor data, providing ongoing validation. While uncertainty sources such as modeling error are acknowledged, detailed quantification or error‑correction mechanisms are not described in the documents."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The incubator’s digital twin relies on a hybrid wired‑wireless network. Sensors use the 1‑Wire bus (wired) to the Raspberry Pi, while the Pi connects to the rest of the system via Wi‑Fi (or optional Bluetooth) to an edge router. All higher‑level data exchange (sensor updates, control commands, model calibration data) is performed through a RabbitMQ server using the AMQP protocol. The network topology is a star configuration with the Pi as the central node; bandwidth requirements are modest (tens of kbps) and latency is kept below 100 ms to support real‑time control. Redundancy is achieved by running RabbitMQ in a mirrored queue mode, and security is provided by TLS encryption and username/password authentication for all AMQP connections."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The digital twin components (data ingestion service, model calibration algorithms, monitoring dashboards) are deployed as Docker containers on the Raspberry Pi 4, providing an edge‑computing platform that co‑locates the DT with the physical twin. The Pi offers up to 4 GB RAM and a quad‑core ARM CPU, sufficient for the lightweight simulation and optimisation tasks described. Persistent storage for sensor histories and model parameters resides on the Pi’s micro‑SD card, with optional remote backup to a cloud object store. Scalability is handled by container orchestration (e.g., Docker Compose) that can be extended to a Kubernetes edge cluster if needed. High availability is addressed through a watchdog service that restarts containers on failure and by replicating the RabbitMQ broker across a secondary Pi node."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "The incubator Digital Twin incorporates safety mechanisms at the device‑driver level: a safe protocol is embedded in the low‑level driver to keep the hardware in a safe state when abnormal conditions arise, providing a fail‑safe capability. Continuous temperature monitoring is performed using two internal sensors and one external sensor; the control software uses these readings to detect out‑of‑range temperatures and can autonomously deactivate the heat‑bed or activate the fan to prevent unsafe thermal conditions. No explicit cybersecurity protocols, authentication, or access‑control mechanisms are described in the provided documents."
]