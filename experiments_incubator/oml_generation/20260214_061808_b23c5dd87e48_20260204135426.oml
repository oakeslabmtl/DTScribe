// C3: Physical Sensing Components
instance EnvironmentalSensor : DTDFVocab:SensingComponent [
    base:desc "Collects real-time environmental interaction data (e.g., aerodynamics, terrain) for the Physical Twin's operational context"
    DTDFVocab:producedData EnvironmentalDataTransmitted
]

instance OperationalParameterSensor : DTDFVocab:SensingComponent [
    base:desc "Embedded sensor capturing operational parameters (e.g., forces, movement, structural stress) from the Physical Twin"
    DTDFVocab:producedData OperationalDataTransmitted
]

instance TelemetrySensor : DTDFVocab:SensingComponent [
    base:desc "Continuous data acquisition system providing real-time telemetry streams from the Physical Twin's cyber-physical components"
    DTDFVocab:producedData TelemetryDataTransmitted
]

instance StatusUpdateSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor system generating periodic status updates and system health indicators for the Physical Twin"
    DTDFVocab:producedData StatusUpdateDataTransmitted
]

// C4: Physical-to-Virtual Interaction
instance EnvironmentalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalSensor
]

instance OperationalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OperationalParameterSensor
]

instance TelemetryDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TelemetrySensor
]

instance StatusUpdateDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StatusUpdateSensor
]

// C10: Models/Data
instance GeometricModel : DTDFVocab:Model [
    base:desc "Abstract CAD representation of the Physical Twin's structural design and spatial properties (e.g., chassis geometry, wheel dimensions)"
    DTDFVocab:inputTo GeometricSimulationEngine
]

instance DynamicBehaviorModel : DTDFVocab:Model [
    base:desc "Physics-based differential equation models describing the Physical Twin's behavior under forces, environmental conditions, and operational constraints"
    DTDFVocab:inputTo DynamicSimulationEngine
]

instance StateEstimationModel : DTDFVocab:Model [
    base:desc "Kalman filter-based model for real-time state estimation and fault detection in the Physical Twin's cyber-physical system"
    DTDFVocab:inputTo StateEstimationEngine
]

instance EnvironmentalInteractionModel : DTDFVocab:Model [
    base:desc "Model capturing environmental physics (e.g., aerodynamics, terrain interactions) affecting the Physical Twin's performance"
    DTDFVocab:inputTo EnvironmentalSimulationEngine
]

instance SensedData : DTDFVocab:Data [
    base:desc "Raw and preprocessed real-time sensor data streams from the Physical Twin's operational environment and components"
    DTDFVocab:fromData EnvironmentalDataTransmitted, OperationalDataTransmitted, TelemetryDataTransmitted, StatusUpdateDataTransmitted
    DTDFVocab:inputTo DataPreprocessingEngine
]

instance HistoricalOperationalData : DTDFVocab:Data [
    base:desc "Archived operational logs and historical records for trend analysis, retrospective validation, and anomaly detection"
    DTDFVocab:fromData StatusUpdateDataTransmitted
    DTDFVocab:inputTo TrendAnalysisEngine
]

instance CalibratedModelParameters : DTDFVocab:Data [
    base:desc "Dynamic model parameters continuously updated via calibration algorithms to ensure alignment between Physical Twin and Digital Twin behavior"
    DTDFVocab:fromData SensedData
    DTDFVocab:inputTo DynamicSimulationEngine, StateEstimationEngine
]

// C11: Enablers
instance DataPreprocessingEngine : DTDFVocab:Enabler [
    base:desc "Engine for normalizing, filtering, and aggregating raw sensor data to prepare it for model integration and analysis"
    DTDFVocab:enables DataIntegrationService, MonitoringService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Parameter estimation algorithm (e.g., least squares, Bayesian inference) that dynamically adjusts model parameters using real-time sensor data"
    DTDFVocab:enables ModelRefinementService
]

instance DynamicSimulationEngine : DTDFVocab:Enabler [
    base:desc "Physics-based computational solver for simulating the Physical Twin's dynamic behavior under current or hypothetical conditions"
    DTDFVocab:enables PredictiveSimulationService
]

instance StateEstimationEngine : DTDFVocab:Enabler [
    base:desc "Real-time state estimator (e.g., Kalman filter) processing sensor data to detect deviations and operational anomalies"
    DTDFVocab:enables FaultDetectionService
]

instance GeometricSimulationEngine : DTDFVocab:Enabler [
    base:desc "Computational tool for rendering and analyzing the Physical Twin's geometric properties and spatial interactions"
    DTDFVocab:enables VisualizationService
]

instance EnvironmentalSimulationEngine : DTDFVocab:Enabler [
    base:desc "Engine simulating environmental physics (e.g., aerodynamics, terrain) affecting the Physical Twin's performance"
    DTDFVocab:enables EnvironmentalAnalysisService
]

instance DataIntegrationPlatform : DTDFVocab:Enabler [
    base:desc "Middleware framework unifying data streams, models, and algorithms into a cohesive Digital Twin system with interoperability capabilities"
    DTDFVocab:enables DataIntegrationService, VisualizationService, PredictiveSimulationService, OptimizationService, ControlService
]

instance VisualizationDashboard : DTDFVocab:Enabler [
    base:desc "Interactive 3D and data visualization tool presenting Digital Twin insights to users through intuitive interfaces"
    DTDFVocab:enables VisualizationService
]

instance OptimizationAlgorithm : DTDFVocab:Enabler [
    base:desc "Multi-objective optimization engine (e.g., genetic algorithms, Q-learning) suggesting parameter adjustments for improved efficiency and performance"
    DTDFVocab:enables OptimizationService
]

instance TrendAnalysisEngine : DTDFVocab:Enabler [
    base:desc "Time-series analysis tool identifying patterns, trends, and anomalies in historical and real-time operational data"
    DTDFVocab:enables PredictiveAnalyticsService
]

instance ValidationEngine : DTDFVocab:Enabler [
    base:desc "Model validation framework comparing Digital Twin predictions against ground-truth data for accuracy assessment"
    DTDFVocab:enables ValidationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Continuous assessment of Physical Twin health, operational parameters, and environmental interactions using real-time sensor data"
    DTDFVocab:provides SystemHealthInsight, FaultDetectionInsight, OperationalParameterInsight
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Dynamic model-based simulation of Physical Twin behavior under current or hypothetical conditions for what-if analysis"
    DTDFVocab:provides BehaviorPredictionInsight, FailureModeInsight, TrajectoryForecastInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Algorithmic adjustment of Physical Twin parameters (e.g., controller settings, resource allocation) for improved performance"
    DTDFVocab:provides EfficiencyOptimizationAction, SafetyOptimizationAction, PerformanceOptimizationAction
]

instance ControlService : DTDFVocab:Service [
    base:desc "Supervisory control framework providing actionable insights and automated adjustments for Physical Twin operations"
    DTDFVocab:provides CorrectiveAction, MaintenanceRecommendationAction, OperationalAdjustmentAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Collaborative platform for engineers to interpret complex Digital Twin data through interactive visualizations"
    DTDFVocab:provides 3DReconstructionInsight, RealTimeDashboardInsight, SpatialAnalysisInsight
]

instance DataIntegrationService : DTDFVocab:Service [
    base:desc "Unified data management framework integrating sensor streams, models, and algorithms into the Digital Twin system"
    DTDFVocab:provides DataConsistencyInsight, ModelAlignmentInsight
]

instance EnvironmentalAnalysisService : DTDFVocab:Service [
    base:desc "Simulation and analysis of environmental physics affecting the Physical Twin's performance and operational context"
    DTDFVocab:provides EnvironmentalImpactInsight, TerrainInteractionInsight
]

instance PredictiveAnalyticsService : DTDFVocab:Service [
    base:desc "Advanced analytics engine generating predictive insights about Physical Twin behavior and potential future states"
    DTDFVocab:provides FailurePredictionInsight, EnergyConsumptionInsight, PerformanceTrendInsight
]

instance ValidationService : DTDFVocab:Service [
    base:desc "Model validation framework ensuring Digital Twin predictions align with Physical Twin observations and historical data"
    DTDFVocab:provides AccuracyValidationInsight, ModelDriftInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Service for continuous monitoring of system health and operational parameters"
    DTDFVocab:provides SystemHealthInsight, OperationalParameterInsight
]

instance ModelRefinementService : DTDFVocab:Service [
    base:desc "Service for refining and calibrating digital twin models based on real-time data"
    DTDFVocab:provides CalibrationQualityInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Service for detecting operational faults and anomalies in the physical twin"
    DTDFVocab:provides FaultDetectionInsight
]

instance DesignValidationService : DTDFVocab:Service [
    base:desc "Service for validating design models against operational requirements"
    DTDFVocab:provides ModelAlignmentInsight
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Service providing decision support insights and recommendations"
    DTDFVocab:provides MaintenanceRecommendationInsight
]

