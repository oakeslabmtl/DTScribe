prefix DTDFVocab: http://example.org/DTDFVocab#
prefix rdfs: http://www.w3.org/2000/01/rdf-schema#
prefix base: http://example.org/base#
instance ProcessSensor : DTDFVocab:SensingComponent [
    base:desc "Sensor collecting operational parameters for system monitoring",
    DTDFVocab:producedData OperationalDataTransmitted
]
instance OperationalDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ProcessSensor
]
instance OperationalSensorData : DTDFVocab:Data [
    base:desc "Raw data collected from system sensors",
    DTDFVocab:fromData OperationalDataTransmitted,
    DTDFVocab:inputTo CalibrationAlgorithmEnabler, MonitoringEnabler
]
instance GeometricModel : DTDFVocab:Model [
    base:desc "CAD model representing structural dimensions of Physical Twin",
    DTDFVocab:inputTo SimulationEnabler, FaultDetectionEnabler, SupervisoryControllerEnabler, StateEstimatorEnabler, OptimizerEnabler, MonitoringEnabler
]
instance AnalyticalModel : DTDFVocab:Model [
    base:desc "Differential equations model for dynamic behavior of Physical Twin",
    DTDFVocab:inputTo SimulationEnabler, FaultDetectionEnabler, SupervisoryControllerEnabler, StateEstimatorEnabler, OptimizerEnabler, MonitoringEnabler
]
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for simulation services using geometric and analytical models",
    DTDFVocab:enables SimulationService
]
instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for fault detection algorithms",
    DTDFVocab:enables FaultDetectionService
]
instance SupervisoryControllerEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for supervisory control algorithms",
    DTDFVocab:enables SupervisoryControlService
]
instance StateEstimatorEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for state estimation algorithms",
    DTDFVocab:enables StateEstimationService
]
instance OptimizerEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for optimization algorithms",
    DTDFVocab:enables OptimizationService
]
instance CalibrationAlgorithmEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for calibration algorithms updating model parameters",
    DTDFVocab:enables CalibrationService
]
instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for monitoring services using sensor data and models",
    DTDFVocab:enables MonitoringService
]
instance SimulationService : DTDFVocab:Service [
    base:desc "Service to reproduce and predict Physical Twin behavior under current operating conditions",
    DTDFVocab:provides SimulationInsight
]
instance MonitoringService : DTDFVocab:Service [
    base:desc "Service to assess safety and optimal performance through real-time sensor data analysis",
    DTDFVocab:provides SafetyAssessmentInsight, OptimizationMetricInsight
]
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service for updating model parameters based on sensor data",
    DTDFVocab:provides ModelParameterUpdateInsight
]
instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Algorithmic service for fault detection",
    DTDFVocab:provides FaultDetectionInsight, FaultDetectionAction
]
instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Algorithmic service for supervisory control",
    DTDFVocab:provides SupervisoryControlAction
]
instance StateEstimationService : DTDFVocab:Service [
    base:desc "Algorithmic service for state estimation",
    DTDFVocab:provides StateEstimationInsight
]
instance OptimizationService : DTDFVocab:Service [
    base:desc "Algorithmic service for system optimization",
    DTDFVocab:provides OptimizationInsight
]
instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Predictive simulation results for system behavior"
]
instance SafetyAssessmentInsight : DTDFVocab:Insight [
    base:desc "Assessment of operational safety based on sensor data"
]
instance OptimizationMetricInsight : DTDFVocab:Insight [
    base:desc "Metrics for optimal performance evaluation"
]
instance ModelParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Updated model parameters from calibration algorithms"
]
instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Anomaly detection and fault identification"
]
instance FaultDetectionAction : DTDFVocab:Action [
    base:desc "Automated corrective action upon fault detection",
    DTDFVocab:IsAutomatic true
]
instance SupervisoryControlAction : DTDFVocab:Action [
    base:desc "Control actions for system supervision",
    DTDFVocab:IsAutomatic true
]
instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Estimated current state of the Physical Twin"
]
instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimization recommendations for system performance"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The Digital Twin system orchestrates data flow from physical sensors through calibration algorithms to update CPS and environmental models, with results feeding into monitoring systems for safety and optimality checks; human or algorithmic interventions trigger physical adjustments upon violation detection."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Calibration algorithms update models with parameter estimates to maintain fidelity, while monitors validate system performance by checking safety and operational optimality; violations detected by monitors trigger corrective actions via human or algorithmic interventions."
]