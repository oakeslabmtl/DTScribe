// C3: Physical sensing components
instance InternalTempSensorA : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer placed inside the incubator box, provides internal temperature with ±0.5 °C accuracy."
    DTDFVocab:producedData InternalTempSensorADataTx
]

instance InternalTempSensorB : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer placed inside the incubator box, provides internal temperature with ±0.5 °C accuracy."
    DTDFVocab:producedData InternalTempSensorBDataTx
]

instance ExternalTempSensorAmbient : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer placed outside the incubator box, measures ambient temperature with ±0.5 °C accuracy."
    DTDFVocab:producedData ExternalTempSensorAmbientDataTx
]

// C4: Physical-to-virtual interaction – data transmission
instance InternalTempSensorADataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorA
]

instance InternalTempSensorBDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensorB
]

instance ExternalTempSensorAmbientDataTx : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensorAmbient
]

// C10: Data components
instance InternalTempDataA : DTDFVocab:Data [
    base:desc "Time‑stamped temperature values acquired from InternalTempSensorA, received by the Digital Twin."
    DTDFVocab:fromData InternalTempSensorADataTx
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, SafetyEnabler
]

instance InternalTempDataB : DTDFVocab:Data [
    base:desc "Time‑stamped temperature values acquired from InternalTempSensorB, received by the Digital Twin."
    DTDFVocab:fromData InternalTempSensorBDataTx
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, SafetyEnabler
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Time‑stamped ambient temperature values acquired from ExternalTempSensorAmbient, received by the Digital Twin."
    DTDFVocab:fromData ExternalTempSensorAmbientDataTx
    DTDFVocab:inputTo CalibrationEnabler, MonitoringEnabler, SafetyEnabler
]

// C10: Models
instance ThermalModelTwoParam : DTDFVocab:Model [
    base:desc "Analytical temperature‑prediction model with two free parameters representing heat transfer dynamics."
    DTDFVocab:inputTo SimulationEnabler
]

instance ThermalModelFourParam : DTDFVocab:Model [
    base:desc "Analytical temperature‑prediction model with four free parameters capturing heat‑bed thermal inertia."
    DTDFVocab:inputTo SimulationEnabler
]

// C11: Enablers
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Algorithm that calibrates thermal model parameters using incoming sensor time‑series data."
    DTDFVocab:enables CalibrationService
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Real‑time monitoring algorithm that validates sensor data against safety limits."
    DTDFVocab:enables RealTimeMonitoringService
]

instance SafetyEnabler : DTDFVocab:Enabler [
    base:desc "Safety monitor that detects temperature violations and triggers alerts."
    DTDFVocab:enables SafetyMonitoringService
]

instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimization algorithm that computes optimal heating set‑points based on calibrated models."
    DTDFVocab:enables OptimizationRecommendationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs analytical temperature‑prediction models to forecast future trajectories."
    DTDFVocab:enables SimulationService, WhatIfAnalysisService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Visualization component that renders temperature trends and what‑if analysis results."
    DTDFVocab:enables VisualizationService
]

// C6: Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of the three temperature sensors."
    DTDFVocab:provides TemperatureTrendInsight
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Runs analytical temperature‑prediction models to simulate and forecast incubator temperature dynamics."
    DTDFVocab:provides ForecastInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Executes calibration algorithms to update model parameters with incoming sensor data."
    DTDFVocab:provides CalibrationAction
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Detects violations of temperature safety limits and raises alerts."
    DTDFVocab:provides SafetyViolationInsight
]

instance OptimizationRecommendationService : DTDFVocab:Service [
    base:desc "Generates optimal heating set‑point recommendations based on calibrated models."
    DTDFVocab:provides SetpointOptimizationAction
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Visualises temperature trends and model‑based what‑if analysis results."
    DTDFVocab:provides TemperatureVisualizationInsight
]

instance WhatIfAnalysisService : DTDFVocab:Service [
    base:desc "Performs what‑if analysis using the analytical models to evaluate alternative control strategies."
    DTDFVocab:provides WhatIfAnalysisInsight
]

// C17: Insights / Actions
instance TemperatureTrendInsight : DTDFVocab:Insight [
    base:desc "Insight into real‑time temperature trends from the three sensors."
]

instance ForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted future temperature trajectory generated by the analytical models."
]

instance CalibrationAction : DTDFVocab:Action [
    base:desc "Action that updates model parameters based on calibration algorithm outcomes."
    DTDFVocab:IsAutomatic true
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detection of temperature exceeding safety limits."
]

instance SetpointOptimizationAction : DTDFVocab:Action [
    base:desc "Recommendation of optimal heating set‑point for the incubator."
    DTDFVocab:IsAutomatic true
]

instance TemperatureVisualizationInsight : DTDFVocab:Insight [
    base:desc "Graphical visualisation of temperature data and model forecasts."
]

instance WhatIfAnalysisInsight : DTDFVocab:Insight [
    base:desc "Results of what‑if scenario simulations for alternative control configurations."
]

// C2: Acting Component
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that provides thermal energy to the incubator chamber, controlled via set‑point commands from the Digital Twin."
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Control commands are sent from the Digital Twin (or from external algorithms/human operators) through the same RabbitMQ broker to a controller program running on the Raspberry Pi. The controller listens for messages that command the fan and the heat‑bed actuators; the message format is not specified in the documents. Upon receipt, the controller validates the command, actuates the corresponding hardware, and the resulting physical state is observable again via the temperature sensors, providing implicit feedback to the DT. Conflict resolution and explicit command‑execution acknowledgements are not described."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is evaluated by comparing predicted temperature trajectories against the observed temperature data from the physical incubator. Experiments demonstrated that the four‑parameter model reproduces the thermal inertia of the heat‑bed more accurately than the two‑parameter model, indicating higher fidelity and suitability for further DT development. Model validation is performed through calibration runs where the model parameters are adjusted to minimise the error between simulated and measured temperatures. Uncertainty arises from sensor noise and unmodelled environmental effects; the calibration algorithm provides the best‑estimate parameters, quantifying this uncertainty. Continuous monitoring within the DT checks for deviations beyond tolerated thresholds, triggering alerts for possible model drift."
]