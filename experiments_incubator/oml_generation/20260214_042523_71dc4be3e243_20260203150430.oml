// Sensing Component (Physical sensor on the twin)
instance PhysicalTwinSensor : DTDFVocab:SensingComponent [
    base:desc "Time‑stamped sensor streams collected from the physical twin"
    DTDFVocab:producedData PhysicalTwinSensorDataTransmitted
]

// Data Transmitted instance (link from sensor to data)
instance PhysicalTwinSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PhysicalTwinSensor
]

// Data instance (sensor data stream)
instance PhysicalTwinSensorData : DTDFVocab:Data [
    base:desc "Time‑stamped sensor data stream (temperature, pressure, velocity) from the physical twin"
    DTDFVocab:fromData PhysicalTwinSensorDataTransmitted
    DTDFVocab:inputTo CalibrationEnabler
]

// Model: CAD geometric representation
instance CADVehicleModel : DTDFVocab:Model [
    base:desc "CAD geometric model of vehicle including wheel sizes and chassis shape"
    DTDFVocab:inputTo SimulationEngineEnabler
    DTDFVocab:inputTo CalibrationEnabler
]

// Model: Behavioral differential equation
instance VehicleDynamicsModel : DTDFVocab:Model [
    base:desc "Behavioral differential equation model capturing dynamic interactions of the vehicle"
    DTDFVocab:inputTo SimulationEngineEnabler
    DTDFVocab:inputTo CalibrationEnabler
]

// Service: Calibration
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service that provides calibration data and updates to the model enablers"
]

// Enabler: Calibration algorithm
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm continuously adjusts model parameters to align predictions with observed sensor data"
    DTDFVocab:enables CalibrationService
]

// Enabler: Simulation engine
instance SimulationEngineEnabler : DTDFVocab:Enabler [
    base:desc "Simulation engine executing CAD and dynamics models to replicate and predict vehicle behavior"
    DTDFVocab:enables SimulationService
]

// Enabler: Optimization engine
instance OptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Optimization engine adjusting model parameters or control actions to improve performance"
    DTDFVocab:enables OptimizationService
]

// Enabler: Fault detection algorithm
instance FaultDetectionEnabler : DTDFVocab:Enabler [
    base:desc "Fault detection algorithm identifies abnormal behavior within the digital twin"
    DTDFVocab:enables FaultDetectionService
]

// Enabler: State estimation system
instance StateEstimationEnabler : DTDFVocab:Enabler [
    base:desc "State estimation system reconstructs hidden system states from model outputs and sensor inputs"
    DTDFVocab:enables StateEstimationService
]

// Enabler: Supervisory control interface
instance SupervisoryControlEnabler : DTDFVocab:Enabler [
    base:desc "Supervisory control interface can override or adjust physical twin actions based on model predictions"
    DTDFVocab:enables SupervisoryControlService
]

// Service: Monitoring
instance MonitoringService : DTDFVocab:Service [
    base:desc "Monitors sensor‑derived data to verify safe and optimal operation"
    DTDFVocab:provides SafetyComplianceInsight
]

// Service: Simulation
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulates vehicle behavior reproducing and predicting physical twin’s behavior under current operating conditions"
    DTDFVocab:provides PredictedBehaviorInsight
]

// Service: Optimization
instance OptimizationService : DTDFVocab:Service [
    base:desc "Adjusts model parameters or control actions to improve performance"
    DTDFVocab:provides OptimalOperationInsight, AutomaticControlAction
]

// Service: Fault Detection
instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Identifies abnormal behavior within the digital twin"
    DTDFVocab:provides FailureLikelihoodInsight
]

// Service: State Estimation
instance StateEstimationService : DTDFVocab:Service [
    base:desc "Reconstructs hidden system states from model outputs and sensor inputs"
    DTDFVocab:provides StateEstimationInsight
]

// Service: Supervisory Control
instance SupervisoryControlService : DTDFVocab:Service [
    base:desc "Overrides or adjusts physical twin actions based on model predictions"
    DTDFVocab:provides SupervisoryControlAction
]

// Insight: Safety compliance status
instance SafetyComplianceInsight : DTDFVocab:Insight [
    base:desc "Current safety compliance status derived from monitored data"
]

// Insight: Predicted behavior
instance PredictedBehaviorInsight : DTDFVocab:Insight [
    base:desc "Predicted behavior of the vehicle under current operating conditions"
]

// Insight: Optimal operational point
instance OptimalOperationInsight : DTDFVocab:Insight [
    base:desc "Optimal operational point derived from optimization algorithms"
]

// Insight: Failure likelihood
instance FailureLikelihoodInsight : DTDFVocab:Insight [
    base:desc "Predicted likelihood of failure derived from fault detection and predictive analytics"
]

// Insight: State estimation
instance StateEstimationInsight : DTDFVocab:Insight [
    base:desc "Reconstructed hidden system states based on model outputs and sensor data"
]

// Action: Automatic control adjustment
instance AutomaticControlAction : DTDFVocab:Action [
    base:desc "Automated control adjustment of physical twin based on optimization directives"
    DTDFVocab:IsAutomatic true
]

// Action: Supervisory control adjustment
instance SupervisoryControlAction : DTDFVocab:Action [
    base:desc "Automated supervisory control adjustment of physical twin based on model predictions"
    DTDFVocab:IsAutomatic true
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A digital twin is structured as a framework that integrates three core components: data ingestion, modelling, and algorithms. Data is collected from the physical twin via sensors over continuous operational periods and fed into the system for real‑time update. Modelling comprises physical, cyber‑physical, and environmental knowledge bases; these models are continuously refined through calibration algorithms that adjust parameters based on incoming sensor data. The algorithmic layer includes fault detectors, supervisory controllers, state estimators, and optimisers that process the calibrated models and data to generate new insights and actionable outputs. The output from algorithms fuels monitors that evaluate safety and performance; when violations are detected, humans or autonomous decision‑making modules can issue corrective actions to the physical twin. This orchestrated interaction between data, model calibration, monitoring, and control constitutes the overall digital‑twin constellation."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Digital Twin lifecycle begins with the creation of CAD or dynamic simulation models of the physical system; during deployment the models are integrated with real‑time sensor data from the Physical Twin, followed by continuous calibration and monitoring that update model parameters and evaluate safety/optimisation; governance is achieved by periodic audit of model–data consistency and traceable configuration changes."
]