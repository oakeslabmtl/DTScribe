// C2: Acting Components
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heatbed that supplies heat to the incubator box."
]
instance ElectricFanActuator : DTDFVocab:ActingComponent [
    base:desc "Electric fan mounted on the incubator to provide airflow and heat distribution."
]
instance RaspberryPiGPIOOutputActuator : DTDFVocab:ActingComponent [
    base:desc "GPIO outputs through MOSFETs and optocouplers to control actuators like heatbed and fan."
]

// C3: Physical sensing components
instance InsideTemperatureSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire digital temperature sensor located inside the incubator."
    DTDFVocab:producedData InsideTemperatureDataTransmitted1
]
instance InsideTemperatureSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 1-Wire digital temperature sensor inside the incubator."
    DTDFVocab:producedData InsideTemperatureDataTransmitted2
]
instance OutsideTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1-Wire digital temperature sensor outside the incubator for ambient temperature monitoring."
    DTDFVocab:producedData OutsideTemperatureDataTransmitted
]

// C4: Physical-to-virtual interaction
instance InsideTemperatureDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor1
]
instance InsideTemperatureDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideTemperatureSensor2
]
instance OutsideTemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom OutsideTemperatureSensor
]

// C10: Models/Data
instance InsideTemperatureData1 : DTDFVocab:Data [
    base:desc "Measured inside temperature sample from first sensor."
    DTDFVocab:fromData InsideTemperatureDataTransmitted1
    DTDFVocab:inputTo RabbitMQPublisherEnabler, SciPyCalibrationEnabler
]
instance InsideTemperatureData2 : DTDFVocab:Data [
    base:desc "Measured inside temperature sample from second sensor."
    DTDFVocab:fromData InsideTemperatureDataTransmitted2
    DTDFVocab:inputTo RabbitMQPublisherEnabler, SciPyCalibrationEnabler
]
instance OutsideTemperatureData : DTDFVocab:Data [
    base:desc "Measured ambient temperature sample from outside sensor."
    DTDFVocab:fromData OutsideTemperatureDataTransmitted
    DTDFVocab:inputTo RabbitMQPublisherEnabler, SciPyCalibrationEnabler
]
instance ModelA : DTDFVocab:Model [
    base:desc "Dynamic thermal model A with parameters C_air, G_box, G_heater, C_heater."
    DTDFVocab:inputTo ThermalSimulationEnabler
]
instance ModelB : DTDFVocab:Model [
    base:desc "Dynamic thermal model B with parameters C_air, G_box, G_heater, C_heater."
    DTDFVocab:inputTo ThermalSimulationEnabler
]

// C11: Enablers
instance RabbitMQPublisherEnabler : DTDFVocab:Enabler [
    base:desc "Enables publishing of sensor data to local RabbitMQ server over TCP."
    DTDFVocab:enables SensorDataPublishService
]
instance SciPyCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Enables least-squares calibration of thermal model parameters via SciPy."
    DTDFVocab:enables CalibrationService
]
instance ThermalSimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enables running of dynamic thermal simulations using ModelA and ModelB."
    DTDFVocab:enables PredictiveSimulationService
]

// C6: Services
instance SensorDataPublishService : DTDFVocab:Service [
    base:desc "Publishes real-time sensor data to RabbitMQ over TCP."
    DTDFVocab:provides SensorDataPublishedInsight
]
instance CalibrationService : DTDFVocab:Service [
    base:desc "Performs model parameter calibration using collected temperature data."
    DTDFVocab:provides CalibratedParametersInsight
]
instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Runs predictive thermal simulations with ModelA and ModelB."
    DTDFVocab:provides TemperatureForecastInsight
]
instance BangBangTemperatureControllerService : DTDFVocab:Service [
    base:desc "Bang-bang controller to adjust heating duty cycle based on temperature thresholds."
    DTDFVocab:provides ControlHeatbedAction, AdjustHeatingAction
]

// C17: Insights/Actions
instance SensorDataPublishedInsight : DTDFVocab:Insight [
    base:desc "Notifies system of successful data publication to RabbitMQ."
]
instance CalibratedParametersInsight : DTDFVocab:Insight [
    base:desc "Calibrated estimates of parameters C_air, G_box, G_heater to inform controller tuning."
]
instance TemperatureForecastInsight : DTDFVocab:Insight [
    base:desc "Predicted inside-box temperature over time from dynamic models."
]
instance AdjustHeatingAction : DTDFVocab:Action [
    base:desc "Adjust heating duration H and waiting duration C based on temperature predictions."
    DTDFVocab:IsAutomatic true
]
instance ControlHeatbedAction : DTDFVocab:Action [
    base:desc "Turn heatbed on or off using GPIO output via MOSFETs."
    DTDFVocab:IsAutomatic true
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin publishes control commands (heatbed on/off, fan on/off, target temperature) to the RabbitMQ server; the Raspberry Pi controller subscribes to these messages, translates them into GPIO/MOSFET signals, and actuates the heatbed and fan accordingly."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Real‑time operation: sensor polling occurs approximately every 1 s, control logic executes upon new samples, and RabbitMQ messages are exchanged with millisecond latency; heating and waiting durations (H and C) are defined in seconds."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "On the Raspberry Pi the communication server (RabbitMQ), low‑level driver, controller, and simulation models form a tightly coupled orchestration; messages flow between PT hardware and DT services via the broker queues."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin covers the as‑designed phase (initial thermal model), manufactured phase (integration of actual hardware on the Raspberry Pi), and operated phase (runtime monitoring and calibration of the models)."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Uniform temperature, negligible wall heat accumulation, constant air heat capacity, and heatbed energy accumulation assumptions were experimentally tested; Model B fit measured data better, reducing prediction error to < 1 °C; model validation performed by comparing simulated temperature trajectories with measured traces."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "1‑Wire bus connects DS18S20 sensors to Raspberry Pi GPIO; Raspberry Pi hosts RabbitMQ, communicating over TCP on the local network using AMQP protocol; actuator signals are driven via MOSFETs from Pi GPIO."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin is hosted on the Raspberry Pi 4, running the controller, low‑level driver, RabbitMQ broker, and simulation model code; no external cloud hosting is used."
]

instance standardization : DTDFVocab:Standardization [
    base:desc "Employs 1‑Wire sensor protocol, AMQP over TCP for RabbitMQ; development follows open‑source repository practices; industry‑specific standards are not cited."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is implemented in the low‑level driver to maintain device safety; specific encryption or access‑control mechanisms are not detailed, but safety against human exposure is implicit through the use of insulated components and GPIO control."
]