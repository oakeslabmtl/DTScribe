// Physical sensing components
instance ChassisAccelerationSensor : DTDFVocab:SensingComponent [
    base:desc "A tri‑axial accelerometer mounted on the vehicle chassis to capture longitudinal, lateral, and vertical acceleration signals."
    DTDFVocab:producedData ChassisAccelerationData
]

instance WheelSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "A wheelspeed sensor installed on each drive wheel to measure vehicle speed and tire slip."
    DTDFVocab:producedData WheelSpeedData
]

instance EngineRPMSensor : DTDFVocab:SensingComponent [
    base:desc "An engine revolutions‑per‑minute sensor to monitor crankshaft speed during operation."
    DTDFVocab:producedData EngineRPMPowerData
]

instance EngineTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "A temperature sensor located in the engine coolant circuit to monitor engine temperature."
    DTDFVocab:producedData EngineTemperatureData
]

// Data transmitted by sensors
instance ChassisAccelerationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ChassisAccelerationSensor
]

instance WheelSpeedData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom WheelSpeedSensor
]

instance EngineRPMPowerData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EngineRPMSensor
]

instance EngineTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EngineTemperatureSensor
]

// Telemetry data ingested by the digital twin
instance ChassisAccelerationTelemetry : DTDFVocab:Data [
    base:desc "Time‑series acceleration data captured from the chassis accelerometer."
    DTDFVocab:inputTo DataAcquisitionPipeline
    DTDFVocab:fromData ChassisAccelerationData
]

instance WheelSpeedTelemetry : DTDFVocab:Data [
    base:desc "Wheel speed readings from the external sensors."
    DTDFVocab:inputTo DataAcquisitionPipeline
    DTDFVocab:fromData WheelSpeedData
]

instance EngineRPPTelemetry : DTDFVocab:Data [
    base:desc "Engine revolutions per minute telemetry from the crankshaft sensor."
    DTDFVocab:inputTo DataAcquisitionPipeline
    DTDFVocab:fromData EngineRPMPowerData
]

instance EngineTemperatureTelemetry : DTDFVocab:Data [
    base:desc "Engine coolant temperature telemetry from the engine temperature sensor."
    DTDFVocab:inputTo DataAcquisitionPipeline
    DTDFVocab:fromData EngineTemperatureData
]

// Enablers that drive the digital twin functionality
instance DataAcquisitionPipeline : DTDFVocab:Enabler [
    base:desc "A sensor‑based data acquisition pipeline that gathers telemetry from the vehicle’s sensors."
]

instance ModelCalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Calibration algorithms that update the vehicle dynamics model parameters with live data."
    DTDFVocab:enables SafetyMonitoringService
    DTDFVocab:enables PredictiveVehicleDynamicsSimulationService
    DTDFVocab:enables DrivingStrategyOptimizationService
    DTDFVocab:enables FaultDetectionService
    DTDFVocab:enables MaintenanceDecisionSupportService
]

instance SafetyMonitoringService : DTDFVocab:Service [
    base:desc "Monitoring modules that enforce safety and performance constraints on the vehicle."
    DTDFVocab:provides SafetyPerformanceInsight, TriggerCorrectiveAction
]

instance PredictiveVehicleDynamicsSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation of vehicle dynamics under current operating conditions."
    DTDFVocab:provides PredictiveSimulationInsight
]

instance DrivingStrategyOptimizationService : DTDFVocab:Service [
    base:desc "Optimization of driving strategies via supervisory controllers."
    DTDFVocab:provides OptimizationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection through state‑estimating algorithms."
    DTDFVocab:provides FaultDetectionInsight
]

instance MaintenanceDecisionSupportService : DTDFVocab:Service [
    base:desc "Data‑driven decision support for maintenance and design evaluation."
    DTDFVocab:provides MaintenanceDecisionSupportInsight
]

instance RealTimeSafetyMonitoringService : DTDFVocab:Service [
    base:desc "Real‑time monitoring of vehicle safety and performance metrics."
    DTDFVocab:provides SafetyPerformanceInsight, TriggerCorrectiveAction
]

// Models used in the digital twin
instance VehicleDynamicDifferentialEquationModel : DTDFVocab:Model [
    base:desc "A physics‑based differential equation model representing the dynamic behavior of the passenger car."
    DTDFVocab:inputTo ModelCalibrationAlgorithm
]

// Insights derived by the services
instance SafetyPerformanceInsight : DTDFVocab:Insight [
    base:desc "Safety and performance metrics evaluated by the safety monitoring modules."
]

instance PredictiveSimulationInsight : DTDFVocab:Insight [
    base:desc "Predicted vehicle behavior under current operating conditions from the simulation engine."
]

instance OptimizationInsight : DTDFVocab:Insight [
    base:desc "Optimized driving strategies determined by the supervisory control algorithm."
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Detection of anomalies identified by the fault‑detection algorithm."
]

instance MaintenanceDecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Maintenance decisions supported by analysis of telemetry and simulation outputs."
]

// Actions that can be taken by the digital twin
instance TriggerCorrectiveAction : DTDFVocab:Action [
    base:desc "Automatic corrective action prompted when safety thresholds are violated, providing confidence levels based on residuals from the calibrated models."
    DTDFVocab:IsAutomatic true
]

// Physical environment containing vehicle components
instance VehicleEnvironment : DTDFVocab:Environment [
    base:contains ChassisComponent, WheelComponent, SuspensionComponent, PowertrainComponent
]

instance ChassisComponent : DTDFVocab:Component [
    base:desc "Chassis geometry and structural components of the passenger car."
]

instance WheelComponent : DTDFVocab:Component [
    base:desc "Wheel dimensions and assemblies including tires and bearings."
]

instance SuspensionComponent : DTDFVocab:Component [
    base:desc "Suspension components such as springs, dampers, and linkages."
]

instance PowertrainComponent : DTDFVocab:Component [
    base:desc "On‑board powertrain subsystem including the engine, transmission, and drivetrain."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "DT is described as a framework that integrates modelling, simulation, monitoring and optimisation technologies. Its internal architecture consists of a data layer that collects sensor streams from the physical twin over time, a models layer that stores knowledge about both cyber and physical aspects of the system and its environment, and an algorithms layer that includes calibration routines, fault detectors, supervisory controllers, state estimators and optimisers. Calibration algorithms continually update the model parameters to reflect the best estimate of the system state, and the resulting model states are fed into monitoring components that assess whether the system operates safely and optimally. Decision logic—whether human or algorithmic—can act on monitoring outputs to adjust the physical twin. This orchestrated workflow demonstrates a component‑centric architecture with coordinated data‑model‑algorithm interactions, supporting real‑time data ingestion, model updating, and safety/optimality checks."
]