// Sensing Component
instance TemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "SensingComponent that collects temperature data from the physical twin over time."
    DTDFVocab:producedData TemperatureDataTransmitted
]

// Data Transmitted
instance TemperatureDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom TemperatureSensor
]

// Data
instance TemperatureRawData : DTDFVocab:Data [
    base:desc "Raw temperature data streams from the physical twin, captured by the TemperatureSensor."
    DTDFVocab:inputTo DataAggregator
    DTDFVocab:fromData TemperatureDataTransmitted
]

// Models
instance TemperatureDynamicModel : DTDFVocab:Model [
    base:desc "Dynamic behavioral model expressed by differential equations representing the system dynamics."
    DTDFVocab:inputTo SimulationEngine, CalibrationEngine
] 

instance TemperatureGeometricModel : DTDFVocab:Model [
    base:desc "Geometric model represented by CAD geometries encoding physical dimensions."
    DTDFVocab:inputTo SimulationEngine
]

instance TemperatureAnalyticalModel : DTDFVocab:Model [
    base:desc "Analytical knowledge‑based model capturing cyber‑physical interactions."
    DTDFVocab:inputTo MonitoringEngine
]

// Enablers
instance DataAggregator : DTDFVocab:Enabler [
    base:desc "Data layer aggregates time‑series temperature sensor data from the physical twin and streams it to the twin's computational core."
    DTDFVocab:enables MonitoringService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine for forward modeling of the digital twin."
    DTDFVocab:enables SimulationService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that updates model parameters using observed temperature data."
    DTDFVocab:enables CalibrationService
]

instance MonitoringEngine : DTDFVocab:Enabler [
    base:desc "Monitoring module that leverages calibrated models and real‑time data to perform safety and performance checks."
    DTDFVocab:enables MonitoringService
]

instance FaultDetectionEngine : DTDFVocab:Enabler [
    base:desc "Fault detection algorithm that alerts operators to violations of safety or performance constraints."
    DTDFVocab:enables FaultDetectionService
]

instance StateEstimationEngine : DTDFVocab:Enabler [
    base:desc "State estimation algorithm that provides real‑time insight into hidden system states."
    DTDFVocab:enables PrognosticsService
]

instance OptimizationEngine : DTDFVocab:Enabler [
    base:desc "Optimization engine that refines dynamic models and suggests optimization actions."
    DTDFVocab:enables PrognosticsService
]

instance SupervisoryControlEngine : DTDFVocab:Enabler [
    base:desc "Supervisory control algorithm that executes control actions when safety constraints are breached."
    DTDFVocab:enables MonitoringService
]

// Services
instance SimulationService : DTDFVocab:Service [
    base:desc "Simulation and prediction of the digital twin’s behavior under current operating conditions."
    DTDFVocab:provides SimulationInsight, RunSimulationAction
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Model calibration and optimization services that refine the dynamic models based on incoming data."
    DTDFVocab:provides CalibrationInsight, AdjustModelParametersAction
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring and supervisory control algorithms to alert operators to safety or performance violations."
    DTDFVocab:provides MonitoringInsight, ExecuteControlAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Fault detection and supervisory control algorithms that alert operators to violations of safety or performance constraints."
    DTDFVocab:provides FaultDetectedInsight, TriggerFaultCorrectionAction
]

instance PrognosticsService : DTDFVocab:Service [
    base:desc "State estimation and prognostics that provide real‑time insight into hidden system states and anticipate failures."
    DTDFVocab:provides PrognosticsInsight, PredictiveMaintenanceAction
]

// Insights
instance SimulationInsight : DTDFVocab:Insight [
    base:desc "Insight into the simulated behavior of the digital twin under current conditions."
]

instance CalibrationInsight : DTDFVocab:Insight [
    base:desc "Insight on updated model parameters after calibration."
]

instance MonitoringInsight : DTDFVocab:Insight [
    base:desc "Insight from safety and performance checks performed by monitoring."
]

instance FaultDetectedInsight : DTDFVocab:Insight [
    base:desc "Insight on violations of safety or performance constraints detected by the fault detection algorithm."
]

instance PrognosticsInsight : DTDFVocab:Insight [
    base:desc "Insight into predicted future failures based on state estimation and prognostics."
]

// Actions
instance RunSimulationAction : DTDFVocab:Action [
    base:desc "Action to run a forward simulation of the digital twin."
    DTDFVocab:IsAutomatic true
]

instance AdjustModelParametersAction : DTDFVocab:Action [
    base:desc "Automatic adjustment of model parameters based on calibration results."
    DTDFVocab:IsAutomatic true
]

instance ExecuteControlAction : DTDFVocab:Action [
    base:desc "Control action executed when monitoring detects a constraint violation."
    DTDFVocab:IsAutomatic true
]

instance TriggerFaultCorrectionAction : DTDFVocab:Action [
    base:desc "Action to initiate fault correction procedures upon fault detection."
    DTDFVocab:IsAutomatic true
]

instance PredictiveMaintenanceAction : DTDFVocab:Action [
    base:desc "Proactive maintenance action scheduled based on prognostics insights."
    DTDFVocab:IsAutomatic false
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "When the monitoring subsystem flags a violation, the digital twin’s control layer may issue adjustment commands (e.g., actuator or configuration changes) to the physical twin. Execution of these commands is confirmed via feedback from the PT, allowing the twin to resolve conflicts and validate outcomes."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "A Digital Twin system orchestrates data acquisition, model representation, and algorithmic reasoning in a tightly coupled, closed‑loop architecture. Time‑stamped sensor data from the physical twin are streamed continuously and feed calibration algorithms that update analytical models of both the cyber and physical domains of the system and its environment. These updated models are then queried by simulation, fault‑detection, supervisory controller, and optimization algorithms. A monitoring layer consumes the outputs of these algorithms to enforce safety and performance constraints, and when violations are detected, human operators or automated agents may decide to intervene or modify the physical twin. This flow integrates modeling, simulation, monitoring, and optimization to provide predictive and prescriptive capabilities."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The DT lifecycle consists of a design and modeling phase where abstract models (geometric, dynamical, material) are created to capture selected physical aspects of the target PT; a deployment phase where these models are integrated into a DT framework that ingests continuous sensor data streams from the PT; and an operational phase where calibration algorithms continuously update the models to maintain alignment, while monitors evaluate safety and performance metrics and trigger interventions; lifecycle governance is exercised through iterative calibration, monitoring, and human or automated decision‑making upon detection of violations."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is preserved through ongoing calibration against sensor data, whereby calibration algorithms iteratively adjust model parameters to match observed behavior within acceptable bounds. The Digital Twin employs monitoring mechanisms that evaluate the system’s performance against safety and optimality specifications; any detected violations trigger alerts or autonomous corrective actions. While explicit V&V procedures are not detailed, the architecture implies continuous verification via statistical consistency checks between model predictions and sensor observations, and validation through operational testing where the DT’s predictions are compared against real‐world outcomes. The system thereby implements an implicit quality assurance loop that flags inconsistencies and prompts human or automated intervention to reconcile discrepancies."
]