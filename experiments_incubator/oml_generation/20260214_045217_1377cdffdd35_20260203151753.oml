// Sensing Components
instance InsideBoxAirTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located inside the insulated box measuring air temperature."
    DTDFVocab:producedData InsideBoxAirTempDataTransmitted
]

instance InsideBoxAirTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideBoxAirTempSensor
]

instance InsideBoxAirTempData : DTDFVocab:Data [
    base:desc "Temperature reading from the inside box sensor."
    DTDFVocab:inputTo LowLevelDriverEnabler
    DTDFVocab:fromData InsideBoxAirTempDataTransmitted
]

instance InsideBoxAirTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 temperature sensor located inside the insulated box."
    DTDFVocab:producedData InsideBoxAirTempDataTransmitted2
]

instance InsideBoxAirTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InsideBoxAirTempSensor2
]

instance InsideBoxAirTempData2 : DTDFVocab:Data [
    base:desc "Temperature reading from the second inside box sensor."
    DTDFVocab:inputTo LowLevelDriverEnabler
    DTDFVocab:fromData InsideBoxAirTempDataTransmitted2
]

instance ExternalRoomTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 temperature sensor located outside the insulated box measuring room temperature."
    DTDFVocab:producedData ExternalRoomTempDataTransmitted
]

instance ExternalRoomTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalRoomTempSensor
]

instance ExternalRoomTempData : DTDFVocab:Data [
    base:desc "Temperature reading from the external room sensor."
    DTDFVocab:inputTo LowLevelDriverEnabler
    DTDFVocab:fromData ExternalRoomTempDataTransmitted
]

// Actuating Components
instance HeatbedHeatingElement : DTDFVocab:ActingComponent [
    base:desc "Heatbed heating element driven by MOSFETs controlled through the Raspberry Pi 4 controller."
]

instance HeatbedActuatorStateTransmitted : DTDFVocab:DataTransmitted [
    /* data transmission produced by the heating element */
]

instance HeatbedActuatorStateData : DTDFVocab:Data [
    base:desc "Actuator state (ON/OFF) of the heatbed heating element reported to the DT."
    DTDFVocab:inputTo RabbitMQCommunicatorEnabler
    DTDFVocab:fromData HeatbedActuatorStateTransmitted
]

instance FanMotor : DTDFVocab:ActingComponent [
    base:desc "Fan motor used to control airflow within the insulated box."
]

instance FanActuatorStateTransmitted : DTDFVocab:DataTransmitted [
    /* data transmission produced by the fan motor */
]

instance FanActuatorStateData : DTDFVocab:Data [
    base:desc "Actuator state (ON/OFF) of the fan motor reported to the DT."
    DTDFVocab:inputTo RabbitMQCommunicatorEnabler
    DTDFVocab:fromData FanActuatorStateTransmitted
]

// Supporting Components
instance RaspberryPi4Controller : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 board governing DC and AC actuators via MOSFETs and optocouplers."
]

instance MOSFETDriver : DTDFVocab:Component [
    base:desc "MOSFET driver circuit controlled by the Raspberry Pi to drive the heatbed."
]

instance OptocouplerCircuit : DTDFVocab:Component [
    base:desc "Optocoupler isolation circuit between the Raspberry Pi outputs and the MOSFET channels."
]

instance PowerSupplyMonitor : DTDFVocab:SensingComponent [
    base:desc "Internal power supply monitor providing voltage and current measurements for the Raspberry Pi 4."
    DTDFVocab:producedData PowerSupplyDataTransmitted
]

instance PowerSupplyDataTransmitted : DTDFVocab:DataTransmitted [
    /* data transmission produced by the power supply monitor */
]

instance PowerSupplyData : DTDFVocab:Data [
    base:desc "Voltage and current measurement of the Raspberry Pi 4 power supply."
    DTDFVocab:inputTo LowLevelDriverEnabler
    DTDFVocab:fromData PowerSupplyDataTransmitted
]

// Enablers
instance LowLevelDriverEnabler : DTDFVocab:Enabler [
    base:desc "Low‑level driver that polls DS18S20 sensors and uploads data to RabbitMQ."
    DTDFVocab:enables TempPollingService
]

instance RabbitMQCommunicatorEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker (AMQP over TCP/IP) used for data transmission between PT and DT."
    DTDFVocab:enables ActuatorCommunicationService
]

instance PythonSciPyOptimizerEnabler : DTDFVocab:Enabler [
    base:desc "Python with SciPy used for nonlinear least‑squares parameter estimation."
    DTDFVocab:enables OnlineCalibrationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for running calibrated thermal models and simulations."
    DTDFVocab:enables SimulationService
]

// Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Thermal dynamics model A with parameters C_air and G_box."
    DTDFVocab:inputTo SimulationEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Thermal dynamics model B with parameters C_air, C_heater, G_heater, G_box."
    DTDFVocab:inputTo SimulationEnabler
]

// Services
instance TempPollingService : DTDFVocab:Service [
    base:desc "Service that polls temperature sensors via the low‑level driver at periodic intervals."
    DTDFVocab:provides InsideBoxTempInsight, ExternalBoxTempInsight
]

instance ActuatorCommunicationService : DTDFVocab:Service [
    base:desc "Service that forwards actuator states to RabbitMQ and receives commands."
    DTDFVocab:provides ApplyHeatbedStateAction, ApplyFanStateAction
]

instance SimulationService : DTDFVocab:Service [
    base:desc "Service that simulates temperature dynamics using calibrated ModelA or ModelB."
    DTDFVocab:provides SimulationPredictionInsight
]

instance OnlineCalibrationService : DTDFVocab:Service [
    base:desc "Service performing online calibration of model parameters via nonlinear least‑squares."
    DTDFVocab:provides ParameterEstimatesInsight
]

instance ContinuousMonitoringService : DTDFVocab:Service [
    base:desc "Service for continuous monitoring of PT operation."
    DTDFVocab:provides PTPerformanceVisibilityInsight
]

instance BangBangControllerService : DTDFVocab:Service [
    base:desc "Bang‑bang controller enforcing temperature limits based on simulation predictions."
    DTDFVocab:provides AdjustHeatingStrategyInsight, ApplyHeatbedStateAction, ApplyFanStateAction
]

// Insights
instance InsideBoxTempInsight : DTDFVocab:Insight [
    base:desc "Real‑time temperature trend inside the insulated box."
]

instance ExternalBoxTempInsight : DTDFVocab:Insight [
    base:desc "Real‑time room temperature trend outside the insulated box."
]

instance ParameterEstimatesInsight : DTDFVocab:Insight [
    base:desc "Nonlinear least‑squares estimates of model parameters such as C_air, G_box, C_heater, and G_heater."
]

instance SimulationPredictionInsight : DTDFVocab:Insight [
    base:desc "Simulation predictions of thermal inertia and future temperature trends."
]

instance PTPerformanceVisibilityInsight : DTDFVocab:Insight [
    base:desc "Visibility into PT performance for operators."
]

instance AdjustHeatingStrategyInsight : DTDFVocab:Insight [
    base:desc "Insight enabling adjustments to heating strategy based on simulation predictions."
]

// Actions
instance ApplyHeatbedStateAction : DTDFVocab:Action [
    base:desc "Apply ON/OFF command to heatbed heating element."
    DTDFVocab:IsAutomatic true
]

instance ApplyFanStateAction : DTDFVocab:Action [
    base:desc "Apply ON/OFF command to fan motor."
    DTDFVocab:IsAutomatic true
]

instance AdjustHeatingPlanAction : DTDFVocab:Action [
    base:desc "Adjust heating plan based on temperature trends."
    DTDFVocab:IsAutomatic false
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains InsideBoxAirTempSensor, InsideBoxAirTempSensor2, ExternalRoomTempSensor,
           HeatbedHeatingElement, FanMotor, RaspberryPi4Controller, MOSFETDriver,
           OptocouplerCircuit, PowerSupplyMonitor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT sends control commands (heatbed on/off, fan on/off) to the Raspberry Pi controller via RabbitMQ messages, which the low‑level driver forwards to the heatbed and fan circuits."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Data acquisition and control updates occur at a sampling interval of a few seconds (set by the low‑level driver polling), while the simulation and calibration calculations run in real‑time with the same granularity."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "Hardware: heatbed, fan, sensors, Raspberry Pi controller. Software: low‑level driver, communication server (RabbitMQ), bang‑bang controller, simulation models, calibration engine. All orchestrated on the Pi with messages exchanged via AMQP."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "Design and model building → Calibration and validation experiments → Deployment of the twin on the Pi → Operational monitoring and online parameter updates; the DT represents the as‑operated state of the PT."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Assumptions of uniform internal temperature, negligible heat flux into walls, constant specific heat of air, and that electrical power goes to heatbody; validation performed by comparing simulated temperature traces to experimental measurements and minimizing residual error."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "RabbitMQ running on the Raspberry Pi, communicating via AMQP over TCP/IP to the low‑level driver; sensors connected over 1‑Wire bus; MOSFETs and optocouplers provide electrical isolation between Pi and high‑current circuits."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "All digital twin components (communication server, controller, simulation, calibration) are deployed locally on the Raspberry Pi 4 that physically hosts the PT; the system operates on the local network or via Wi‑Fi."
]