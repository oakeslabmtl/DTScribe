// Sensing Components
instance VehicleSpeedSensor : DTDFVocab:SensingComponent [
    base:desc "A sensor measuring the vehicle's forward speed in real time."
    DTDFVocab:producedData VehicleSpeedDataTrans
]
instance EngineTemperatureSensor : DTDFVocab:SensingComponent [
    base:desc "A sensor monitoring the engine temperature of the vehicle."
    DTDFVocab:producedData EngineTemperatureDataTrans
]

// Data Transmission
instance VehicleSpeedDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VehicleSpeedSensor
]
instance EngineTemperatureDataTrans : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EngineTemperatureSensor
]

// Data
instance VehicleSpeedTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series data stream of vehicle speed collected from the VehicleSpeedSensor."
    DTDFVocab:inputTo MonitoringEnabler, CalibrationEnabler, SimulationEnabler, DecisionSupportEnabler
]
instance EngineTemperatureTimeSeriesData : DTDFVocab:Data [
    base:desc "Time‑series data stream of engine temperature collected from the EngineTemperatureSensor."
    DTDFVocab:inputTo MonitoringEnabler, CalibrationEnabler, SimulationEnabler, DecisionSupportEnabler
]

// Models
instance VehicleGeometricModel : DTDFVocab:Model [
    base:desc "A CAD representation of the vehicle storing dimensional data such as wheel diameters, chassis geometry and styling attributes."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler, DecisionSupportEnabler
]
instance VehicleDynamicBehaviorModel : DTDFVocab:Model [
    base:desc "A dynamic model governed by differential equations that captures the temporal evolution of the vehicle under physical forces."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler, DecisionSupportEnabler
]
instance VehicleAnalyticalModel : DTDFVocab:Model [
    base:desc "An analytical model encoding knowledge about the cyber and physics of the vehicle twin and its environment."
    DTDFVocab:inputTo CalibrationEnabler, SimulationEnabler, DecisionSupportEnabler
]

// Enablers
instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Monitoring routine that evaluates safety and optimality using sensor time‑series data."
    DTDFVocab:enables ContinuousMonitoringService
]
instance CalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that iteratively adjusts parameter estimates of the cyber‑physical system and environmental models."
    DTDFVocab:enables OptimisationService
]
instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Predictive simulation routine that reproduces vehicle behaviour under current operating conditions."
    DTDFVocab:enables PredictiveSimulationService
]
instance DecisionSupportEnabler : DTDFVocab:Enabler [
    base:desc "Decision‑support mechanism that alerts humans or automated controllers when safety or performance thresholds are breached."
    DTDFVocab:enables DecisionSupportService
]

// Services
instance ContinuousMonitoringService : DTDFVocab:Service [
    base:desc "Continuous monitoring of vehicle performance for safety violations."
    DTDFVocab:provides SafetyViolationInsight, AlgorithmicRemedialAction
]
instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Predictive simulation that reproduces vehicle behaviour under current operating conditions."
    DTDFVocab:provides PredictionInsight
]
instance OptimisationService : DTDFVocab:Service [
    base:desc "Optimisation service that calibrates models of the cyber‑physical system to the best‑possible parameter estimates."
    DTDFVocab:provides OptimisationInsight
]
instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Decision‑support service alerting humans or controllers when thresholds are breached."
    DTDFVocab:provides DecisionSupportInsight, HumanRemedialAction
]

// Insights
instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Insight indicating a safety violation detected by the monitoring routine."
]
instance PredictionInsight : DTDFVocab:Insight [
    base:desc "Insight predicting future vehicle behaviour under current operating conditions."
]
instance OptimisationInsight : DTDFVocab:Insight [
    base:desc "Insight identifying optimal parameter values for the cyber‑physical system."
]
instance DecisionSupportInsight : DTDFVocab:Insight [
    base:desc "Insight summarising conditions that trigger human or automated remediation."
]

// Actions
instance HumanRemedialAction : DTDFVocab:Action [
    base:desc "Human‑initiated remedial action prompted when safety or performance thresholds are breached."
    DTDFVocab:IsAutomatic false
]
instance AlgorithmicRemedialAction : DTDFVocab:Action [
    base:desc "Automated remedial action performed by control algorithms upon detecting violations."
    DTDFVocab:IsAutomatic true
]