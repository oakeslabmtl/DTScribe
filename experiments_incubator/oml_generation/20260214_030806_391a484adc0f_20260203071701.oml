// C3: Physical sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted inside the incubator to monitor air temperature; range –55 °C to +125 °C, accuracy ±0.5 °C"
    DTDFVocab:producedData InternalTempDataTransmitted1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted inside the incubator to monitor air temperature; range –55 °C to +125 °C, accuracy ±0.5 °C"
    DTDFVocab:producedData InternalTempDataTransmitted2
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high‑precision 1‑Wire digital thermometer mounted outside the incubator to measure ambient temperature; range –55 °C to +125 °C, accuracy ±0.5 °C"
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// C4: Physical-to-virtual interaction
instance InternalTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// C10: Models/Data
instance AggregatedTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series of temperature measurements from the three DS18S20 sensors collected during incubator operation"
    DTDFVocab:fromData InternalTempDataTransmitted1, InternalTempDataTransmitted2, ExternalTempDataTransmitted
    DTDFVocab:inputTo CalibrationAlgorithm, SimulationEngine, MonitoringAlgorithm, OptimisationAlgorithm
]

instance SimpleThermalModel : DTDFVocab:Model [
    base:desc "Analytical differential‑equation model of internal temperature with two free parameters representing overall heat transfer"
    DTDFVocab:inputTo CalibrationAlgorithm, SimulationEngine, MonitoringAlgorithm
]

instance DetailedThermalModel : DTDFVocab:Model [
    base:desc "Analytical differential‑equation model of internal temperature with four free parameters capturing thermal inertia of the heat‑bed"
    DTDFVocab:inputTo CalibrationAlgorithm, SimulationEngine, MonitoringAlgorithm, OptimisationAlgorithm
]

// C11: Enablers
instance DataAcquisitionEnabler : DTDFVocab:Enabler [
    base:desc "Software component that collects sensor readings via 1‑Wire bus and forwards them over Wi‑Fi/Bluetooth to the DT data store"
    DTDFVocab:enables DataAcquisitionService
]

instance CalibrationAlgorithm : DTDFVocab:Enabler [
    base:desc "Calibration algorithm that updates model parameters to minimise error between simulated and measured temperature"
    DTDFVocab:enables ModelCalibrationService
]

instance SimulationEngine : DTDFVocab:Enabler [
    base:desc "Simulation engine that runs the thermal models to predict temperature trajectories under current operating conditions"
    DTDFVocab:enables SimulationPredictionService
]

instance MonitoringAlgorithm : DTDFVocab:Enabler [
    base:desc "Monitoring algorithm that evaluates updated models to detect safety or performance violations"
    DTDFVocab:enables MonitoringService
]

instance OptimisationAlgorithm : DTDFVocab:Enabler [
    base:desc "Optimisation algorithm that adjusts controller set‑points based on model predictions to improve performance"
    DTDFVocab:enables OptimisationService
]

// C6: Services
instance DataAcquisitionService : DTDFVocab:Service [
    base:desc "Acquires temperature data from the three sensors and stores it for further processing"
    DTDFVocab:provides RawTemperatureInsight
]

instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Runs continuous model calibration using sensor data to update model parameters"
    DTDFVocab:provides CalibrationUpdateInsight, UpdateModelParametersAction
]

instance SimulationPredictionService : DTDFVocab:Service [
    base:desc "Executes simulation‑based predictions of temperature trajectories under current operating conditions"
    DTDFVocab:provides TemperatureTrajectoryInsight
]

instance MonitoringService : DTDFVocab:Service [
    base:desc "Evaluates the calibrated models to detect safety or optimality violations"
    DTDFVocab:provides SafetyViolationInsight, GenerateAlertAction
]

instance OptimisationService : DTDFVocab:Service [
    base:desc "Optimises controller set‑points to maintain target temperature while minimizing energy consumption"
    DTDFVocab:provides PerformanceOptimizationInsight, AdjustSetpointAction
]

// C17: Insights
instance RawTemperatureInsight : DTDFVocab:Insight [
    base:desc "Provides raw temperature measurements for downstream analysis"
]

instance CalibrationUpdateInsight : DTDFVocab:Insight [
    base:desc "Indicates that model parameters have been refreshed after calibration"
]

instance TemperatureTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Predicts future temperature trajectory based on current operating conditions"
]

instance SafetyViolationInsight : DTDFVocab:Insight [
    base:desc "Detects a safety or performance violation in the incubator temperature profile"
]

instance PerformanceOptimizationInsight : DTDFVocab:Insight [
    base:desc "Identifies optimal set‑point adjustments to improve incubation efficiency"
]

// C17: Actions
instance UpdateModelParametersAction : DTDFVocab:Action [
    base:desc "Updates the thermal model parameters in the digital twin"
    DTDFVocab:IsAutomatic true
]

instance GenerateAlertAction : DTDFVocab:Action [
    base:desc "Generates an alert and recommendation for human/operator intervention"
    DTDFVocab:IsAutomatic false
]

instance AdjustSetpointAction : DTDFVocab:Action [
    base:desc "Adjusts the heat‑bed controller set‑point automatically"
    DTDFVocab:IsAutomatic true
]

// C2: Acting Components
instance HeatBedActuator : DTDFVocab:ActingComponent [
    base:desc "Resistive heat‑bed that provides heating power to raise the incubator internal temperature"
]

instance BangBangController : DTDFVocab:ActingComponent [
    base:desc "Bang‑bang controller running on a Raspberry Pi that switches the heat‑bed on/off based on temperature deviation from set‑point"
]

instance RabbitMQBroker : DTDFVocab:ActingComponent [
    base:desc "RabbitMQ message‑broker server used to transmit control commands over Wi‑Fi/Bluetooth to the Raspberry Pi"
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT is organized as a unified framework that ingests time‑stamped sensor data from the physical twin, applies calibration algorithms to estimate parameters and update the cyber‑physical system and environment models, then supplies the refreshed models to monitoring algorithms that evaluate safety and optimality. The loop can involve human operators or other automated algorithms to trigger actuation on the physical twin. This centralized data‑model‑algorithm pipeline is illustrated in Figure 1 of the documents."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity was evaluated experimentally by comparing the two temperature simulation models against measured temperature trajectories of the physical incubator. The four‑parameter model demonstrated higher accuracy in reproducing the thermal inertia of the heat‑bed, indicating superior fidelity for dynamic behaviour. Validation consisted of running the incubator under controlled conditions, recording temperature data, and computing prediction errors. Uncertainty sources include sensor noise and simplifications in the heat‑transfer equations. Calibration algorithms were used to reduce parameter uncertainty, and the resulting calibrated model serves as the validated representation within the digital twin."
]