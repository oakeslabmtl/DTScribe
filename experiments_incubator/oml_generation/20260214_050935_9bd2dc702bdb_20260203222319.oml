// C2 Acting Components
instance HeatBedHeaterActuator : DTDFVocab:ActingComponent [
    base:desc "Heat bed heater controlled via Raspberry Pi GPIO through MOSFET and optocoupler"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12V/24V fan controlled via Raspberry Pi GPIO through MOSFET and optocoupler"
]

instance RaspberryPiController : DTDFVocab:Component [
    base:desc "Raspberry Pi 4 Model B hosting firmware, Python/NumPy/SciPy, RabbitMQ broker"
]

instance CustomPCB : DTDFVocab:Component [
    base:desc "Custom PCB with MOSFETs and optocouplers for driver isolation"
]

// C3 Physical Sensing Components
instance DS18S20HotZoneSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 high-precision 1-Wire temperature sensor positioned at the hot zone inside the styrofoam insulation"
    DTDFVocab:producedData DS18S20HotZoneSensorDataTransmitted
]

instance DS18S20ColdZoneSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor positioned at the cold zone inside the styrofoam insulation"
    DTDFVocab:producedData DS18S20ColdZoneSensorDataTransmitted
]

instance DS18S20AmbientSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 sensor placed outside the incubator to monitor ambient temperature"
    DTDFVocab:producedData DS18S20AmbientSensorDataTransmitted
]

// C4 Data Transmitted
instance DS18S20HotZoneSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20HotZoneSensor
]

instance DS18S20ColdZoneSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20ColdZoneSensor
]

instance DS18S20AmbientSensorDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom DS18S20AmbientSensor
]

// C5 Data
instance HotZoneTemperatureData : DTDFVocab:Data [
    base:desc "Temperature reading from hot zone sensor"
    DTDFVocab:inputTo RabbitMQEnabler, PythonCalibrationEnabler, SimulationEnabler
    DTDFVocab:fromData DS18S20HotZoneSensorDataTransmitted
]

instance ColdZoneTemperatureData : DTDFVocab:Data [
    base:desc "Temperature reading from cold zone sensor"
    DTDFVocab:inputTo RabbitMQEnabler, PythonCalibrationEnabler, SimulationEnabler
    DTDFVocab:fromData DS18S20ColdZoneSensorDataTransmitted
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Ambient temperature reading from external sensor"
    DTDFVocab:inputTo RabbitMQEnabler, PythonCalibrationEnabler, SimulationEnabler
    DTDFVocab:fromData DS18S20AmbientSensorDataTransmitted
]

// C10 Models
instance ThermalModelA : DTDFVocab:Model [
    base:desc "Model A assumes complete conversion of electrical power to heat in the air"
    DTDFVocab:inputTo SimulationEnabler
]

instance ThermalModelB : DTDFVocab:Model [
    base:desc "Model B accounts for heat capacity of heater, in addition to power conversion"
    DTDFVocab:inputTo SimulationEnabler
]

// C11 Enablers
instance RabbitMQEnabler : DTDFVocab:Enabler [
    base:desc "RabbitMQ AMQP broker running on Raspberry Pi delivering sensor data and status updates"
    DTDFVocab:enables RealTimeMonitoringService, FaultDetectionService, VisualizationService
]

instance PythonCalibrationEnabler : DTDFVocab:Enabler [
    base:desc "Python/NumPy/SciPy runtime providing non-linear least squares calibration of ThermalModel parameters"
    DTDFVocab:enables ModelCalibrationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python simulation engine executing parametric temperature models using SciPy integration"
    DTDFVocab:enables TemperatureSimulationService
]

// Service for Model Calibration
instance ModelCalibrationService : DTDFVocab:Service [
    base:desc "Performs non-linear least squares calibration of ThermalModel parameters based on experimental data"
    DTDFVocab:provides GBoxParameterEstimate, GHeaterParameterEstimate
]

// C6 Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Monitors temperature readings in real-time and publishes via RabbitMQ"
    DTDFVocab:provides HotZoneTemperatureInsight, ColdZoneTemperatureInsight, AmbientTemperatureInsight
]

instance TemperatureSimulationService : DTDFVocab:Service [
    base:desc "Runs simulation of temperature dynamics using ThermalModelA and ThermalModelB"
    DTDFVocab:provides TemperatureSimulationInsight
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects sensor anomalies and actuator status to infer faults"
    DTDFVocab:provides FaultDetectionInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides visualization of sensor data streams and simulation results to operators"
    DTDFVocab:provides DataVisualizationInsight
]

// C17 Insights
instance HotZoneTemperatureInsight : DTDFVocab:Insight [
    base:desc "Real-time hot zone temperature reading"
]

instance ColdZoneTemperatureInsight : DTDFVocab:Insight [
    base:desc "Real-time cold zone temperature reading"
]

instance AmbientTemperatureInsight : DTDFVocab:Insight [
    base:desc "Real-time ambient temperature reading"
]

instance TemperatureSimulationInsight : DTDFVocab:Insight [
    base:desc "Simulation output of temperature dynamics using selected thermal model"
]

instance FaultDetectionInsight : DTDFVocab:Insight [
    base:desc "Inference of faults based on sensor anomalies"
]

instance DataVisualizationInsight : DTDFVocab:Insight [
    base:desc "Visualization of sensor data and simulation results to operators"
]

instance GBoxParameterEstimate : DTDFVocab:Insight [
    base:desc "Estimated parameter G_box from model calibration"
]

instance GHeaterParameterEstimate : DTDFVocab:Insight [
    base:desc "Estimated parameter G_heater from model calibration"
]

instance TemperatureUniformityLimitInsight : DTDFVocab:Insight [
    base:desc "Identified temperature uniformity limits within the incubator"
]

instance OptimalModelSelectionInsight : DTDFVocab:Insight [
    base:desc "Selection of Model B as optimal due to lower prediction error"
]

// C17 Actions
instance AdjustFanVoltageAction : DTDFVocab:Action [
    base:desc "Adjust fan voltage based on experimental insights to improve temperature uniformity"
    DTDFVocab:IsAutomatic false
]

instance UpdateSensorPlacementAction : DTDFVocab:Action [
    base:desc "Repurpose sensor placement to enhance temperature measurement accuracy"
    DTDFVocab:IsAutomatic false
]

// C4 Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatBedHeaterActuator, FanActuator, RaspberryPiController, CustomPCB,
           DS18S20HotZoneSensor, DS18S20ColdZoneSensor, DS18S20AmbientSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The DT consumes commands from RabbitMQ (e.g., set heat duration, waiting duration, fan state) which are forwarded by the controller to the Raspberry Pi’s GPIO, thus affecting the heat‑bed and fan. The DT also publishes control states back to the PT for monitoring."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT constellation consists of the Raspberry Pi controller, the low‑level driver, the RabbitMQ server, the heat‑bed heater, the fan, the DS18S20 sensors, and the custom PCB. The orchestration flow follows controller → RabbitMQ → PT hardware actions, and PT sensor data → RabbitMQ → DT services."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin is in the Validation/Experimental phase: models are designed and calibrated against experimental data, control logic is tested, and uniform‑temperature experiments validate assumptions. Full operational deployment and continuous production‑time twin are planned as future work, not yet implemented."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity is assessed through comparison of simulated temperature trajectories against measured data; validity is ensured by calibration of free parameters, assumption verification (e.g., uniform temperature, negligible wall heat accumulation), and residual error minimization during least‑squares fitting."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Communication uses RabbitMQ (AMQP) over TCP on the local network; sensor data travels over the 1‑Wire bus to the Raspberry Pi. The controller publishes and subscribes to relevant queues/exchanges to exchange messages with the PCBs and actuators."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT runtime, RabbitMQ broker, and calibration scripts are hosted directly on the Raspberry Pi 4, enabling low‑latency integration with the physical twin on the same embedded system."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "A safe protocol is incorporated into the low‑level driver to maintain safe states; optocouplers provide electrical isolation between the Pi and high‑current actuators. No authentication, encryption, or redundant control logic for safety or security is mentioned in the documents."
]