// Sensing components
instance InternalTempSensor1 : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer mounted inside the styrofoam box, reading internal temperature via 1‑Wire bus on Raspberry Pi."
    DTDFVocab:producedData InternalTempDataTransmitted1
]

instance InternalTempSensor2 : DTDFVocab:SensingComponent [
    base:desc "Second DS18S20 digital thermometer inside the styrofoam box, reading internal temperature via 1‑Wire bus on Raspberry Pi."
    DTDFVocab:producedData InternalTempDataTransmitted2
]

instance InternalTempSensor3 : DTDFVocab:SensingComponent [
    base:desc "Third DS18S20 digital thermometer inside the styrofoam box, reading internal temperature via 1‑Wire bus on Raspberry Pi."
    DTDFVocab:producedData InternalTempDataTransmitted3
]

instance ExternalTempSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 digital thermometer placed outside the box to measure room temperature via 1‑Wire bus on Raspberry Pi."
    DTDFVocab:producedData ExternalTempDataTransmitted
]

// Data transmitted
instance InternalTempDataTransmitted1 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor1
]

instance InternalTempDataTransmitted2 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor2
]

instance InternalTempDataTransmitted3 : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom InternalTempSensor3
]

instance ExternalTempDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ExternalTempSensor
]

// Power log sensing component
instance PowerLogSensor : DTDFVocab:SensingComponent [
    base:desc "Power utility logging component generating continuous power consumption data."
    DTDFVocab:producedData PowerLogDataTransmitted
]

instance PowerLogDataTransmitted : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom PowerLogSensor
]

// Data from sensors
instance InternalTempData1 : DTDFVocab:Data [
    base:desc "Time-series temperature data from InternalTempSensor1."
    DTDFVocab:fromData InternalTempDataTransmitted1
    DTDFVocab:inputTo CalibrationEngine, SimulationEnabler, MonitoringEnabler
]

instance InternalTempData2 : DTDFVocab:Data [
    base:desc "Time-series temperature data from InternalTempSensor2."
    DTDFVocab:fromData InternalTempDataTransmitted2
    DTDFVocab:inputTo CalibrationEngine, SimulationEnabler, MonitoringEnabler
]

instance InternalTempData3 : DTDFVocab:Data [
    base:desc "Time-series temperature data from InternalTempSensor3."
    DTDFVocab:fromData InternalTempDataTransmitted3
    DTDFVocab:inputTo CalibrationEngine, SimulationEnabler, MonitoringEnabler
]

instance ExternalTempData : DTDFVocab:Data [
    base:desc "Time-series temperature data from ExternalTempSensor."
    DTDFVocab:fromData ExternalTempDataTransmitted
    DTDFVocab:inputTo SimulationEnabler
]

instance PowerLogData : DTDFVocab:Data [
    base:desc "Continuous power consumption data generated by PowerLogSensor."
    DTDFVocab:fromData PowerLogDataTransmitted
    DTDFVocab:inputTo MonitoringEnabler
]

// Acting components
instance HeatbedHeater : DTDFVocab:ActingComponent [
    base:desc "Heatbed heater controlled via GPIO output from Raspberry Pi through MOSFET drivers and optocouplers."
]

instance Fan : DTDFVocab:ActingComponent [
    base:desc "Fan for air circulation controlled via GPIO output from Raspberry Pi through MOSFET drivers and optocouplers."
]

// Enablers
instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "RabbitMQ message broker used to publish sensor data and receive commands."
    DTDFVocab:enables RealTimeComplianceMonitoringService, CalibrationService, SafetyCheckService, GraphicalOverviewService
]

instance CalibrationEngine : DTDFVocab:Enabler [
    base:desc "Python-based SciPy least-squares calibration engine for free parameters."
    DTDFVocab:enables CalibrationService
]

instance SimulationEnabler : DTDFVocab:Enabler [
    base:desc "Python simulation engine for thermal models using heat equations."
    DTDFVocab:enables ModelSimulationServiceA, ModelSimulationServiceB
]

instance MonitoringEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for real-time monitoring and compliance checking."
    DTDFVocab:enables RealTimeComplianceMonitoringService
]

instance SafetyEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for safety checks such as over-temperature detection."
    DTDFVocab:enables SafetyCheckService
]

instance VisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler supporting graphical overview of actuator states."
    DTDFVocab:enables GraphicalOverviewService
]

instance FutureOptimizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for future optimization services of heating schedules."
    DTDFVocab:enables FutureOptimizationService
]

instance FutureVisualizationEnabler : DTDFVocab:Enabler [
    base:desc "Enabler for future visualization of internal heat distribution."
    DTDFVocab:enables FutureVisualizationService
]

// Services
instance CalibrationService : DTDFVocab:Service [
    base:desc "Service to calibrate free parameters (C_air, C_heater, G_box, G_heater) using non-linear least-squares."
    DTDFVocab:provides ParameterUpdateInsight
]

instance ModelSimulationServiceA : DTDFVocab:Service [
    base:desc "Service to simulate temperature dynamics using Model A (single-energy transfer)."
    DTDFVocab:provides ModelSimulationInsightA
]

instance ModelSimulationServiceB : DTDFVocab:Service [
    base:desc "Service to simulate temperature dynamics using Model B (dual-energy transfer with heatbed)."
    DTDFVocab:provides ModelSimulationInsightB
]

instance RealTimeComplianceMonitoringService : DTDFVocab:Service [
    base:desc "Service that monitors real-time temperature compliance and flags deviations."
    DTDFVocab:provides HeatingScheduleInferenceInsight, DeviationFlagAction
]

instance SafetyCheckService : DTDFVocab:Service [
    base:desc "Service to check for over-temperature safety conditions."
    DTDFVocab:provides SafetyRiskInsight
]

instance GraphicalOverviewService : DTDFVocab:Service [
    base:desc "Service providing graphical overview of actuator states."
    DTDFVocab:provides ActuatorStateOverviewAction
]

instance FutureOptimizationService : DTDFVocab:Service [
    base:desc "Future service to optimize heating schedules."
    DTDFVocab:provides OptimizationPlanAction
]

instance FutureVisualizationService : DTDFVocab:Service [
    base:desc "Future service to visualize internal heat distribution."
    DTDFVocab:provides HeatDistributionVisualizationAction
]

// Insights
instance ParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Updated parameter values resulting from calibration."
]

instance HeatingScheduleInferenceInsight : DTDFVocab:Insight [
    base:desc "Inference whether current heating schedule meets temperature targets."
]

instance ModelSimulationInsightA : DTDFVocab:Insight [
    base:desc "Model A simulation result of temperature dynamics."
]

instance ModelSimulationInsightB : DTDFVocab:Insight [
    base:desc "Model B simulation result of temperature dynamics."
]

instance SafetyRiskInsight : DTDFVocab:Insight [
    base:desc "Indicates a safety risk due to over-temperature."
]

// Actions
instance DeviationFlagAction : DTDFVocab:Action [
    base:desc "Action to flag prolonged deviation from target temperature."
    DTDFVocab:IsAutomatic true
]

instance ActuatorStateOverviewAction : DTDFVocab:Action [
    base:desc "Graphical overview of heatbed and fan actuator states."
    DTDFVocab:IsAutomatic false
]

instance OptimizationPlanAction : DTDFVocab:Action [
    base:desc "Optimization plan for heating schedules."
    DTDFVocab:IsAutomatic true
]

instance HeatDistributionVisualizationAction : DTDFVocab:Action [
    base:desc "Visualization of internal heat distribution."
    DTDFVocab:IsAutomatic false
]

// Environment
instance ThermalIncubatorEnvironment : DTDFVocab:Environment [
    base:contains HeatbedHeater, Fan, InternalTempSensor1, InternalTempSensor2, InternalTempSensor3, ExternalTempSensor
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "The Digital Twin publishes control commands (heatbed on/off, fan on/off, heating duration) to RabbitMQ; the low‑level driver consumes these messages and actuates the GPIO outputs to drive MOSFETs that switch the heater and fan."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "Synchronization is achieved in real‑time with sensor polling and command cycles occurring on the order of seconds; the bang‑bang controller uses heating bursts of duration H and waiting periods C, while the Digital Twin processes data and commands at a comparable time scale."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The constellation comprises the physical hardware (box, heater, fan, sensors, Raspberry Pi and PCB), the low‑level driver interfacing with the PT, the RabbitMQ broker routing messages between PT and DT, the Digital Twin logic subscribing to sensor streams, executing calibration and monitoring, publishing actuator commands, and a graphical interface visualising temperature and state—all orchestrated via AMQP queues on a local network."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The twin operates during the operational lifecycle of the incubator: it is calibrated at commissioning, continuously monitors and controls temperature during normal operation, and updates parameters or models during maintenance, covering the 'operated' stage of the PT."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Model fidelity depends on assumptions: uniform temperature distribution, negligible wall heat absorption, constant air specific heat, and negligible fan heat; validation compares simulated trajectories with experimental data using least‑squares residuals; uncertainties arise from sensor accuracy (±0.5 °C) and control loop delay causing over‑heating; safety monitors detect violations and can trigger human intervention."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "The PT–DT interface uses RabbitMQ running on the Raspberry Pi over the local Wi‑Fi network; messages follow the AMQP protocol; sensor data and actuator commands are transferred via dedicated queues; GPIO outputs drive MOSFETs isolated by optocouplers."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The Digital Twin runtime, simulation, and RabbitMQ broker are hosted on the same Raspberry Pi 4 Model B, providing edge deployment with low latency; the source code is open‑source and can be redeployed in alternative cloud environments if desired."
]

instance horizontal_integration : DTDFVocab:HoriIntegration [
    base:desc "No explicit horizontal integration with external systems or other Digital Twins is described in the documents."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Physical isolation is ensured via optocouplers between the Raspberry Pi and MOSFET drivers; the low‑level driver implements a safe protocol limiting heater duration to prevent overheating; cybersecurity aspects are not explicitly addressed in the documents."
]