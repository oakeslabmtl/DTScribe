// C3: Physical Sensing Components
instance HighFrequencyAccelerometer : DTDFVocab:SensingComponent [
    base:desc "High-frequency accelerometer deployed on the Physical Twin to capture dynamic motion data at 10Hz-1kHz sampling rates via wireless (Bluetooth/Zigbee) or wired (CAN/Ethernet) connections"
    DTDFVocab:producedData TimeSeriesAccelerationData
]

instance StrainGaugeSensor : DTDFVocab:SensingComponent [
    base:desc "Strain gauge sensor measuring deformation and stress on the Physical Twin with high-frequency sampling (10Hz-1kHz) through wired (CAN) or wireless (Zigbee) protocols"
    DTDFVocab:producedData TimeSeriesStrainData
]

instance ThermocoupleSensor : DTDFVocab:SensingComponent [
    base:desc "Thermocouple sensor capturing temperature data from the Physical Twin with high-frequency sampling (10Hz-1kHz) via wireless (Bluetooth) or wired (Ethernet) connections"
    DTDFVocab:producedData TimeSeriesTemperatureData
]

instance EnvironmentalHumiditySensor : DTDFVocab:SensingComponent [
    base:desc "Humidity sensor measuring environmental conditions affecting the Physical Twin's operation with low-frequency sampling (1Hz-10Hz) via wireless (Zigbee) connections"
    DTDFVocab:producedData EnvironmentalHumidityData
]

instance VibrationSensor : DTDFVocab:SensingComponent [
    base:desc "Vibration sensor detecting structural health metrics and operational anomalies in the Physical Twin with high-frequency sampling (100Hz-1kHz) through wired (CAN) connections"
    DTDFVocab:producedData TimeSeriesVibrationData
]

// C4: Physical-to-Virtual Interaction
instance TimeSeriesAccelerationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom HighFrequencyAccelerometer
]

instance TimeSeriesStrainData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom StrainGaugeSensor
]

instance TimeSeriesTemperatureData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom ThermocoupleSensor
]

instance EnvironmentalHumidityData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom EnvironmentalHumiditySensor
]

instance TimeSeriesVibrationData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor
]

instance EventTriggeredFaultData : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom VibrationSensor, StrainGaugeSensor, ThermocoupleSensor
]

// C10: Models/Data
instance PhysicalTwinGeometricModel : DTDFVocab:Model [
    base:desc "CAD-based geometric representation of the Physical Twin's structural components including dimensions, shapes, and material properties"
    DTDFVocab:inputTo InfluxDBTimeSeriesStorage, Neo4jRelationshipModeling
]

instance DifferentialEquationSolverModel : DTDFVocab:Model [
    base:desc "Physics-based model implementing Navier-Stokes and Euler-Lagrange equations for simulating the Physical Twin's dynamic behavior using MATLAB/Simulink or Python (SciPy)"
    DTDFVocab:inputTo MATLABSimulationEngine, BayesianParameterEstimation
]

instance ControlSystemModel : DTDFVocab:Model [
    base:desc "Cyber model representing PID controllers and state machines for the Physical Twin's operational control logic implemented in MATLAB Control System Toolbox or ROS"
    DTDFVocab:inputTo ROSControlEnvironment, ModelPredictiveControlEngine
]

instance LSTMTimeSeriesForecastModel : DTDFVocab:Model [
    base:desc "Data-driven predictive model using TensorFlow/PyTorch LSTM networks for forecasting time-series behavior patterns in the Physical Twin"
    DTDFVocab:inputTo TensorFlowTrainingEnvironment, AnomalyDetectionEngine
]

instance SymbolicRegressionModel : DTDFVocab:Model [
    base:desc "Symbolic AI model using Wolfram Language/SymPy for deriving mathematical expressions representing the Physical Twin's dynamic behavior"
    DTDFVocab:inputTo WolframLanguageEnvironment, PhysicsInformedSimulation
]

instance TimeSeriesAccelerationDatabase : DTDFVocab:Data [
    base:desc "Structured time-series database storing acceleration measurements from the Physical Twin with timestamps for real-time analysis"
    DTDFVocab:fromData TimeSeriesAccelerationData
    DTDFVocab:inputTo KalmanStateEstimation, AnomalyDetectionEngine
]

instance StrainMeasurementDatabase : DTDFVocab:Data [
    base:desc "Structured time-series database containing strain gauge measurements from the Physical Twin with timestamped deformation data"
    DTDFVocab:fromData TimeSeriesStrainData
    DTDFVocab:inputTo BayesianParameterEstimation, StructuralHealthMonitoringService
]

instance EnvironmentalConditionDatabase : DTDFVocab:Data [
    base:desc "Hybrid database combining relational (PostgreSQL) and NoSQL (MongoDB) storage for environmental data including humidity, temperature, and external forces"
    DTDFVocab:fromData EnvironmentalHumidityData, TimeSeriesTemperatureData
    DTDFVocab:inputTo EnvironmentalAnalysisEngine, FaultDetectionEngine
]

instance ComponentRelationshipGraph : DTDFVocab:Data [
    base:desc "Graph database model using Neo4j to represent relationships between Physical Twin components (e.g., 'SensorA → ActuatorB → StructuralDamage')"
    DTDFVocab:fromData EventTriggeredFaultData
    DTDFVocab:inputTo RelationshipAnalysisEngine, DigitalTwinIntegrationService
]

// C11: Enablers
instance InfluxDBTimeSeriesStorage : DTDFVocab:Enabler [
    base:desc "Time-series database for storing structured sensor data with timestamps from the Physical Twin with sub-second latency"
    DTDFVocab:enables TimeSeriesProcessingService, StateEstimationService
]

instance TimescaleDBStorage : DTDFVocab:Enabler [
    base:desc "Time-series database optimized for high-frequency sensor data storage and querying with sub-millisecond latency"
    DTDFVocab:enables VibrationAnalysisService, FaultProcessingService
]

instance Neo4jRelationshipModeling : DTDFVocab:Enabler [
    base:desc "Graph database platform for modeling relationships between Physical Twin components and their interactions"
    DTDFVocab:enables RelationshipAnalysisService, AnomalyPropagationService
]

instance MATLABSimulationEngine : DTDFVocab:Enabler [
    base:desc "Physics-based simulation environment using MATLAB/Simulink for solving differential equations representing the Physical Twin's dynamics"
    DTDFVocab:enables DifferentialEquationSimulationService, ControlDesignService
]

instance COMSOLMultiphysicsSimulation : DTDFVocab:Enabler [
    base:desc "High-fidelity multiphysics simulation platform for modeling mechanical, thermal, and fluid dynamics of the Physical Twin"
    DTDFVocab:enables PhysicsSimulationService, StructuralAnalysisService
]

instance ROSControlEnvironment : DTDFVocab:Enabler [
    base:desc "Robot Operating System environment for modeling and executing cyber components including PID controllers and state machines"
    DTDFVocab:enables CyberSimulationService, AdaptiveControlService
]

instance TensorFlowTrainingEnvironment : DTDFVocab:Enabler [
    base:desc "Machine learning framework for training LSTM networks and other deep learning models using time-series data from the Physical Twin"
    DTDFVocab:enables ModelTrainingService, DetectionModelingService
]

instance BayesianParameterEstimation : DTDFVocab:Enabler [
    base:desc "Statistical algorithm for updating Digital Twin models using sensor data through least squares, Bayesian optimization, or particle swarm optimization"
    DTDFVocab:enables ModelCalibrationService, UncertaintyQuantificationService
]

instance KalmanStateEstimation : DTDFVocab:Enabler [
    base:desc "State estimation algorithm using Kalman filters to reconstruct hidden states of the Physical Twin from noisy sensor measurements"
    DTDFVocab:enables StateReconstructionService, FaultDetectionService
]

instance ModelPredictiveControlEngine : DTDFVocab:Enabler [
    base:desc "Optimization framework implementing Model Predictive Control (MPC) using CasADi/YALMIP for optimal control of the Physical Twin"
    DTDFVocab:enables ControlImplementationService, AdaptiveControlService
]

instance AnomalyDetectionEngine : DTDFVocab:Enabler [
    base:desc "Machine learning-based engine using autoencoders and isolation forests for detecting anomalies in Physical Twin sensor data"
    DTDFVocab:enables AnomalyDetectionService, DiagnosisService
]

instance SiemensMindSpherePlatform : DTDFVocab:Enabler [
    base:desc "Digital Twin platform providing integrated modeling, simulation, and visualization capabilities for the Physical Twin"
    DTDFVocab:enables DigitalTwinOperationsService, CloudSimulationService
]

instance OPCUACommunicationProtocol : DTDFVocab:Enabler [
    base:desc "Industrial communication protocol enabling standardized machine-to-machine data exchange between Physical Twin sensors and Digital Twin services"
    DTDFVocab:enables DataIntegrationService, LegacyCompatibilityService
]

instance MQTTDataBroker : DTDFVocab:Enabler [
    base:desc "Lightweight publish-subscribe messaging protocol for efficient transmission of sensor data from the Physical Twin to Digital Twin services"
    DTDFVocab:enables DataFlowService, IoTIntegrationService
]

instance ApacheKafkaPipeline : DTDFVocab:Enabler [
    base:desc "Event-driven data pipeline using Apache Kafka for scalable, decoupled data ingestion and processing of Physical Twin sensor streams"
    DTDFVocab:enables DataIngestionService, RealTimeProcessingService
]

instance Unity3DVisualizationEngine : DTDFVocab:Enabler [
    base:desc "3D rendering engine for creating interactive visualizations of the Physical Twin's geometric and physical states in real-time"
    DTDFVocab:enables VisualizationService, ARVRService
]

instance GrafanaDashboardPlatform : DTDFVocab:Enabler [
    base:desc "Customizable dashboard platform providing real-time KPI visualization and interactive filtering for Digital Twin monitoring"
    DTDFVocab:enables MonitoringService, DecisionVisualizationService
]

// C6: Services
instance RealTimeStateEstimationService : DTDFVocab:Service [
    base:desc "Service providing real-time state estimation of the Physical Twin using Kalman filters and machine learning-based estimators"
    DTDFVocab:provides PhysicalTwinStateInsight, FaultDetectionAlert
]

instance PredictiveSimulationService : DTDFVocab:Service [
    base:desc "Service enabling replay simulations and predictive modeling of the Physical Twin's behavior using time-series forecasting and physics-informed simulations"
    DTDFVocab:provides FutureBehaviorInsight, WhatIfAnalysisResult
]

instance AdaptiveControlOptimizationService : DTDFVocab:Service [
    base:desc "Service implementing model-based optimization and adaptive control for the Physical Twin's operational parameters"
    DTDFVocab:provides ControlParameterRecommendation, AdaptiveControlResults
]

instance StructuralHealthMonitoringService : DTDFVocab:Service [
    base:desc "Service monitoring the Physical Twin's structural integrity through strain and vibration analysis with fault detection capabilities"
    DTDFVocab:provides StructuralIntegrityInsight, MaintenanceRecommendation
]

instance AnomalyDetectionService : DTDFVocab:Service [
    base:desc "Service detecting anomalies in Physical Twin sensor data using supervised and unsupervised machine learning techniques"
    DTDFVocab:provides AnomalyDetectionAlert, FaultDiagnosisReport
]

instance VisualizationAndCommunicationService : DTDFVocab:Service [
    base:desc "Service providing 3D visualizations, AR/VR inspections, and interactive dashboards for Physical Twin monitoring and communication"
    DTDFVocab:provides VisualizationInsight, CollaborativeInspectionResult
]

instance DecisionSupportService : DTDFVocab:Service [
    base:desc "Service providing automated decision-making and human-in-the-loop recommendations based on Digital Twin insights"
    DTDFVocab:provides DecisionRecommendation, ComplianceValidation
]

instance ModelManagementService : DTDFVocab:Service [
    base:desc "Service handling dynamic model updating, versioning, and validation for the Digital Twin's computational models"
    DTDFVocab:provides ModelPerformanceInsight, ModelUpdateNotification
]

// C17: Insights/Actions
instance PhysicalTwinStateInsight : DTDFVocab:Insight [
    base:desc "Insight representing the current estimated state of the Physical Twin reconstructed from sensor data using state estimation algorithms"
]

instance FaultDetectionAlert : DTDFVocab:Action [
    base:desc "Automated action triggering alerts when the Digital Twin detects deviations from expected behavior in the Physical Twin"
    DTDFVocab:IsAutomatic true
]

instance FutureBehaviorInsight : DTDFVocab:Insight [
    base:desc "Predictive insight showing the Physical Twin's expected behavior in the next time window based on current conditions and calibrated models"
]

instance WhatIfAnalysisResult : DTDFVocab:Insight [
    base:desc "Insight from hypothetical scenario testing showing potential outcomes of different operational configurations for the Physical Twin"
]

instance ControlParameterRecommendation : DTDFVocab:Action [
    base:desc "Action providing optimized control parameters for the Physical Twin's actuators and controllers to improve performance"
    DTDFVocab:IsAutomatic false
]

instance StructuralIntegrityInsight : DTDFVocab:Insight [
    base:desc "Insight assessing the Physical Twin's structural health through analysis of strain, vibration, and deformation data"
]

instance MaintenanceRecommendation : DTDFVocab:Action [
    base:desc "Action suggesting maintenance actions based on the Physical Twin's structural health assessment and predicted failure risks"
    DTDFVocab:IsAutomatic false
]

instance AnomalyDetectionAlert : DTDFVocab:Action [
    base:desc "Automated action alerting operators when the Digital Twin detects novel anomalies in sensor data"
    DTDFVocab:IsAutomatic true
]

instance FaultDiagnosisReport : DTDFVocab:Insight [
    base:desc "Detailed report diagnosing the root cause of detected faults in the Physical Twin based on sensor data and model analysis"
]

instance VisualizationInsight : DTDFVocab:Insight [
    base:desc "Insight providing interactive 3D visualizations and AR/VR representations of the Physical Twin's current state and historical performance"
]

instance CollaborativeInspectionResult : DTDFVocab:Insight [
    base:desc "Insight from immersive AR/VR inspections enabling collaborative analysis of the Physical Twin's internal states"
]

instance DecisionRecommendation : DTDFVocab:Action [
    base:desc "Action providing context-aware recommendations for Physical Twin operations based on Digital Twin insights"
    DTDFVocab:IsAutomatic false
]

instance ComplianceValidation : DTDFVocab:Insight [
    base:desc "Insight validating the Physical Twin's compliance with operational constraints and safety regulations through Digital Twin simulations"
]

instance ModelPerformanceInsight : DTDFVocab:Insight [
    base:desc "Insight quantifying the performance and confidence of Digital Twin models through validation against Physical Twin data"
]

instance ModelUpdateNotification : DTDFVocab:Action [
    base:desc "Automated action notifying stakeholders when Digital Twin models have been updated with new data or algorithms"
    DTDFVocab:IsAutomatic true
]

// C18: Environments/Components
instance PhysicalTwinEnvironment : DTDFVocab:Environment [
    base:contains HighFrequencyAccelerometer, StrainGaugeSensor, ThermocoupleSensor,
                 EnvironmentalHumiditySensor, VibrationSensor,
                 DifferentialEquationSolverModel, ControlSystemModel
]

instance DigitalTwinSimulationEnvironment : DTDFVocab:Environment [
    base:contains MATLABSimulationEngine, COMSOLMultiphysicsSimulation,
                 ROSControlEnvironment, TensorFlowTrainingEnvironment,
                 SiemensMindSpherePlatform
]

instance DataProcessingEnvironment : DTDFVocab:Environment [
    base:contains InfluxDBTimeSeriesStorage, TimescaleDBStorage,
                 Neo4jRelationshipModeling, ApacheKafkaPipeline,
                 MQTTDataBroker, OPCUACommunicationProtocol
]

instance VisualizationEnvironment : DTDFVocab:Environment [
    base:contains Unity3DVisualizationEngine, GrafanaDashboardPlatform
]

