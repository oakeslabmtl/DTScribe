// Sensors
instance IncubatorInsideHottestSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer inside the incubator box measuring core temperature with ±0.5 °C accuracy (range −10 °C to +85 °C)"
    DTDFVocab:producedData IncubatorInsideTemperatureMessage
]

instance IncubatorInsideBaseSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer inside the incubator box measuring base temperature with ±0.5 °C accuracy (range −10 °C to +85 °C)"
    DTDFVocab:producedData IncubatorInsideBaseTemperatureMessage
]

instance AmbientOutsideSensor : DTDFVocab:SensingComponent [
    base:desc "DS18S20 1‑Wire digital thermometer outside the incubator box measuring ambient room temperature with ±0.5 °C accuracy (range −10 °C to +85 °C)"
    DTDFVocab:producedData AmbientTemperatureMessage
]

// Data transmitted
instance IncubatorInsideTemperatureMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInsideHottestSensor
]

instance IncubatorInsideBaseTemperatureMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom IncubatorInsideBaseSensor
]

instance AmbientTemperatureMessage : DTDFVocab:DataTransmitted [
    DTDFVocab:producedFrom AmbientOutsideSensor
]

// Data
instance IncubatorInsideHottestData : DTDFVocab:Data [
    base:desc "Time‑series data of core temperature from IncubatorInsideHottestSensor"
    DTDFVocab:fromData IncubatorInsideTemperatureMessage
    DTDFVocab:inputTo RabbitMQBroker
]

instance IncubatorInsideBaseData : DTDFVocab:Data [
    base:desc "Time‑series data of base temperature from IncubatorInsideBaseSensor"
    DTDFVocab:fromData IncubatorInsideBaseTemperatureMessage
    DTDFVocab:inputTo RabbitMQBroker
]

instance AmbientTemperatureData : DTDFVocab:Data [
    base:desc "Time‑series data of ambient temperature from AmbientOutsideSensor"
    DTDFVocab:fromData AmbientTemperatureMessage
    DTDFVocab:inputTo RabbitMQBroker
]

instance ExperimentalCalibrationData : DTDFVocab:Data [
    base:desc "Experimental data for model calibration: temperature trajectories, power input, actuator status"
    DTDFVocab:inputTo PythonSciPy
]

// Actuators
instance HeatbedActuator : DTDFVocab:ActingComponent [
    base:desc "Electric heatbed providing 2 A current to heat air inside the styrofoam enclosure"
]

instance FanActuator : DTDFVocab:ActingComponent [
    base:desc "12/24 V fan for air circulation inside the incubator enclosure"
]

// Enablers
instance RaspberryPi : DTDFVocab:Enabler [
    base:desc "Raspberry Pi 4 Model B controlling sensors and actuators, running low‑level driver and controller"
    DTDFVocab:enables RealTimeMonitoringService, FaultDetectionService, VisualizationService
]

instance CustomPCB : DTDFVocab:Enabler [
    base:desc "Custom PCB integrating MOSFETs driven through optocouplers for actuator control"
]

instance LowLevelDriver : DTDFVocab:Enabler [
    base:desc "Software driver (Python/C) reading DS18S20 sensors and publishing messages via RabbitMQ"
    DTDFVocab:enables RealTimeMonitoringService
]

instance Controller : DTDFVocab:Enabler [
    base:desc "Bang‑bang control logic executed on Raspberry Pi to manage heatbed and fan"
    DTDFVocab:enables FaultDetectionService
]

instance RabbitMQBroker : DTDFVocab:Enabler [
    base:desc "Local RabbitMQ AMQP broker for message passing between components"
    DTDFVocab:enables RealTimeMonitoringService, DynamicSimulationService, VisualizationService
]

instance PythonSciPy : DTDFVocab:Enabler [
    base:desc "Python with SciPy for model calibration, identification, and optimization"
    DTDFVocab:enables CalibrationService, OptimizationService, DynamicSimulationService
]

// Models
instance ModelA : DTDFVocab:Model [
    base:desc "Simplified thermal dynamics model with a single heat source (Eq. 5)"
    DTDFVocab:inputTo PythonSciPy
]

instance ModelB : DTDFVocab:Model [
    base:desc "Dual‑body thermal dynamics model with heatbed heat capacity (Eq. 9)"
    DTDFVocab:inputTo PythonSciPy
]

// Services
instance RealTimeMonitoringService : DTDFVocab:Service [
    base:desc "Provides real‑time monitoring of temperature, heatbed, and fan state"
    DTDFVocab:provides RealTimeTemperatureInsight
]

instance DynamicSimulationService : DTDFVocab:Service [
    base:desc "Provides dynamic simulation via calibrated thermal models to predict temperature trajectories"
    DTDFVocab:provides PredictedTemperatureTrajectoryInsight
]

instance CalibrationService : DTDFVocab:Service [
    base:desc "Calibrates model parameters using non‑linear least squares"
    DTDFVocab:provides ModelParameterUpdateInsight
]

instance OptimizationService : DTDFVocab:Service [
    base:desc "Optimizes control parameters to maintain temperature while minimizing energy"
    DTDFVocab:provides EnergyConsumptionOptimizationAction
]

instance FaultDetectionService : DTDFVocab:Service [
    base:desc "Detects faults and performs supervisory control using bang‑bang logic"
    DTDFVocab:provides FaultDetectedInsight
]

instance VisualizationService : DTDFVocab:Service [
    base:desc "Provides visual dashboards for sensor readings"
    DTDFVocab:provides DashboardDisplayInsight
]

// Insights / Actions
instance RealTimeTemperatureInsight : DTDFVocab:Insight [
    base:desc "Current temperature readings and system status"
]

instance PredictedTemperatureTrajectoryInsight : DTDFVocab:Insight [
    base:desc "Forecasted temperature trajectories based on thermal models"
]

instance ModelParameterUpdateInsight : DTDFVocab:Insight [
    base:desc "Updated model parameters after calibration"
]

instance EnergyConsumptionOptimizationAction : DTDFVocab:Action [
    base:desc "Action to adjust control parameters to reduce energy consumption"
    DTDFVocab:IsAutomatic true
]

instance FaultDetectedInsight : DTDFVocab:Insight [
    base:desc "Detected fault conditions in heating or fan system"
]

instance DashboardDisplayInsight : DTDFVocab:Insight [
    base:desc "Dashboard display of sensor data and model forecasts"
]

// Physical components (for completeness)
instance IncubatorBox : DTDFVocab:Component [
    base:desc "Insulated styrofoam box that houses the heatbed and sensors"
]

instance PowerSupply : DTDFVocab:Component [
    base:desc "Custom PCB power supply delivering necessary voltages to heatbed and fan"
]

// Environment
instance IncubatorEnvironment : DTDFVocab:Environment [
    base:desc "Staged environment containing the incubator system components"
]

instance virtual_to_physical_interaction : DTDFVocab:VirtualToPhysical [
    base:desc "Commands generated by the DT, such as start/stop heatbed, enable/disable fan, or adjust power levels, are sent through RabbitMQ to the low‑level driver, which writes to the GPIO outputs (via MOSFET drivers). The transmission uses AMQP messages with command identifiers and payloads, enabling real‑time actuation."
]

instance twinning_time_scale : DTDFVocab:TimeScale [
    base:desc "All data interactions occur in near real‑time; the low‑level driver polls sensors and sends updates every few seconds (typical control loop frequency of 1 Hz), with command propagation latency of a few hundred milliseconds via RabbitMQ. Simulation and calibration tasks run offline or asynchronously during operation."
]

instance dt_constellation : DTDFVocab:Constellation [
    base:desc "The DT consisting of the Digital Twin model (thermal models), the physical twin, the communication server (RabbitMQ), the low‑level driver, the central controller, and simulation/optimization components forms an integrated constellation. Controllers send commands through RabbitMQ, which the low‑level driver translates into GPIO outputs to actuators; sensor data from the Pi are fed back to RabbitMQ for the DT to ingest; the simulation models consume this data for calibration and prediction."
]

instance life_cycle_stages : DTDFVocab:EvolutionStage [
    base:desc "The Digital Twin spans the design, manufacturing, and operating stages: (design) the theoretical model and prototype hardware are conceived; (manufacturing) the PCB, Raspberry Pi, heatbed, and sensors are assembled; (operating) real‑time monitoring, calibration, and control occur during usage; future phases include maintenance and iterative model refinement."
]

instance fidelity_and_validity_considerations : DTDFVocab:FidelityConsideration [
    base:desc "Fidelity limited by assumptions: (1) uniform temperature distribution enforced by fan; (2) negligible heat absorption by box walls; (3) constant specific heat capacity of air; (4) ignoring fan heat output in Model A. Validation uses experimental temperature data to compute residual error; parameters obtained by SciPy minimising J. Model B was shown to capture thermal inertia better, improving fidelity. Uncertainty quantification was not covered."
]

instance dt_technical_connection : DTDFVocab:TechnicalConnection [
    base:desc "Physical to virtual and vice versa use RabbitMQ broker running on the Raspberry Pi, implementing AMQP protocol over a wired/wireless local network (Wi‑Fi/Bluetooth). Sensors are accessed over 1‑Wire bus; GPIO pins control MOSFETs. Data packets are serialized in JSON/AMQP message format."
]

instance dt_hosting_deployment : DTDFVocab:Deployment [
    base:desc "The DT contracts are hosted locally on the Raspberry Pi; RabbitMQ runs on the Pi; simulation and calibration code can run on the same Pi or on a remote machine connected via network; all components are open‑source and can be deployed using Docker (not specified but repository likely includes scripts)."
]

instance security_and_safety_considerations : DTDFVocab:SecuritySafety [
    base:desc "Low‑level driver incorporates a safe protocol ensuring the device is kept in a safe state; MOSFETs isolated by optocouplers provide electrical isolation; faulty sensor data triggers safe shutdown via controller logic; no explicit network encryption or cybersecurity measures are described."
]